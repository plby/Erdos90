import Submission.ClassField.LubinTate.PadicRootAmbient
import Mathlib.RingTheory.DiscreteValuationRing.TFAE

/-!
# The cyclotomic Witt-root algebra is a discrete valuation ring

The reduced cyclotomic polynomial is Eisenstein over the Witt vectors.  This
file identifies the residue map of its root algebra, proves that its kernel is
generated by the distinguished root, and uses adic completeness to show that
this is the unique maximal ideal.  In particular the finite root algebra is a
discrete valuation ring with the cyclotomic root as uniformizer.
-/

namespace Submission.CField.LTate

open Polynomial PowerSeries

noncomputable section

variable (p : ℕ) [Fact p.Prime]
variable (k : Type*) [Field k] [CharP k p] [IsAlgClosed k]

private abbrev W := WittVector p k
private abbrev B (n : ℕ) := PadicWittRing p k n

omit [IsAlgClosed k] in
/-- The coefficient `p` is divisible by the distinguished cyclotomic root
in the finite Witt-root algebra. -/
theorem padic_witt_p (n : ℕ) :
    algebraMap (W p k) (B p k n) (p : W p k) ∈
      Ideal.span {cyclotomicWittRoot p k n} := by
  rw [Ideal.mem_span_singleton]
  let f := padicWittReduced p k n
  have hroot : (f.map (algebraMap (W p k) (B p k n))).IsRoot
      (cyclotomicWittRoot p k n) := AdjoinRoot.isRoot_root f
  have hf0 : f.coeff 0 = (p : W p k) := by
    dsimp only [f]
    rw [padicWittReduced, Polynomial.coeff_map,
      reduced_iterate_coeff _
        (padic_cyclotomic_lubin p),
      padic_lubin_coeff]
    exact map_natCast (padicIntWitt p k) p
  simpa [hf0] using hroot.dvd_coeff_zero

omit [IsAlgClosed k] in
private theorem cyclotomic_witt_reduced (n : ℕ) :
    Polynomial.eval₂ WittVector.constantCoeff 0
      (padicWittReduced p k n) = 0 := by
  rw [Polynomial.eval₂_at_zero]
  rw [padicWittReduced, Polynomial.coeff_map,
    reduced_iterate_coeff _
      (padic_cyclotomic_lubin p),
    padic_lubin_coeff]
  change WittVector.constantCoeff (padicIntWitt p k (p : ℤ_[p])) = 0
  rw [← frobenius_int_witt p k]
  simp [padicIntWitt]

/-- Reduction of the finite Witt-root algebra: reduce Witt coefficients to
`k` and send the distinguished root to zero. -/
noncomputable def padicWittResidue (n : ℕ) :
    B p k n →+* k :=
  AdjoinRoot.lift WittVector.constantCoeff 0
    (cyclotomic_witt_reduced p k n)

omit [IsAlgClosed k] in
theorem padic_witt_surjective (n : ℕ) :
    Function.Surjective (padicWittResidue p k n) := by
  intro a
  let w : W p k := WittVector.mk p (fun i ↦ if i = 0 then a else 0)
  refine ⟨algebraMap (W p k) (B p k n) w, ?_⟩
  calc
    padicWittResidue p k n
        (algebraMap (W p k) (B p k n) w) =
        WittVector.constantCoeff w := by
      exact AdjoinRoot.lift_of
        (cyclotomic_witt_reduced p k n)
    _ = a := by change w.coeff 0 = a; simp [w]

/-- The kernel of reduction is exactly the ideal generated by the
distinguished root. -/
theorem padic_witt_ker (n : ℕ) :
    RingHom.ker (padicWittResidue p k n) =
      Ideal.span {cyclotomicWittRoot p k n} := by
  apply le_antisymm
  · intro z hz
    obtain ⟨g, rfl⟩ := AdjoinRoot.mk_surjective z
    have hc0 : (g.coeff 0).coeff 0 = 0 := by
      have hz' : Polynomial.eval₂ WittVector.constantCoeff 0 g = 0 := by
        simpa only [padicWittResidue,
          AdjoinRoot.lift_mk] using hz
      rw [Polynomial.eval₂_at_zero] at hz'
      exact hz'
    have hcp : g.coeff 0 ∈ Ideal.span {(p : W p k)} :=
      (WittVector.mem_span_p_iff_coeff_zero_eq_zero
        (p := p) (g.coeff 0)).2 hc0
    obtain ⟨a, ha⟩ := Ideal.mem_span_singleton.mp hcp
    obtain ⟨h, hh⟩ := Polynomial.X_dvd_sub_C (p := g)
    let L : Ideal (B p k n) :=
      Ideal.span {cyclotomicWittRoot p k n}
    have hconst : (AdjoinRoot.mk
        (padicWittReduced p k n))
        (Polynomial.C (g.coeff 0)) ∈ L := by
      rw [AdjoinRoot.mk_C, ha, map_mul]
      exact L.mul_mem_right _ (padic_witt_p p k n)
    have htail : (AdjoinRoot.mk
        (padicWittReduced p k n))
        (g - Polynomial.C (g.coeff 0)) ∈ L := by
      rw [hh, map_mul, AdjoinRoot.mk_X]
      exact L.mul_mem_right _ (Ideal.mem_span_singleton_self _)
    have hsum := L.add_mem hconst htail
    simpa only [map_sub, map_add, add_sub_cancel] using hsum
  · rw [Ideal.span_le]
    intro z hz
    rw [Set.mem_singleton_iff] at hz
    subst z
    exact AdjoinRoot.lift_root
      (cyclotomic_witt_reduced p k n)

theorem padic_cyclotomic_maximal (n : ℕ) :
    (Ideal.span {cyclotomicWittRoot p k n} :
      Ideal (B p k n)).IsMaximal := by
  rw [← padic_witt_ker p k n]
  exact RingHom.ker_isMaximal_of_surjective
    (padicWittResidue p k n)
    (padic_witt_surjective p k n)

/-- The root ideal is the unique maximal ideal.  Adic completeness puts it
in the Jacobson radical, so every maximal ideal contains it. -/
noncomputable instance padic_witt_local (n : ℕ) :
    IsLocalRing (B p k n) := by
  let L : Ideal (B p k n) :=
    Ideal.span {cyclotomicWittRoot p k n}
  have hLmax : L.IsMaximal :=
    padic_cyclotomic_maximal p k n
  letI : IsAdicComplete L (B p k n) :=
    (padic_cyclotomic_adic p k n).isAdicComplete_iff.mpr
      ⟨inferInstance, inferInstance⟩
  apply IsLocalRing.of_unique_max_ideal
  refine ⟨L, hLmax, ?_⟩
  intro Q hQ
  symm
  apply hLmax.eq_of_le hQ.ne_top
  exact le_trans (IsAdicComplete.le_jacobson_bot L)
    (sInf_le ⟨bot_le, hQ⟩)

@[simp]
theorem padic_witt_maximal (n : ℕ) :
    IsLocalRing.maximalIdeal (B p k n) =
      Ideal.span {cyclotomicWittRoot p k n} :=
  (IsLocalRing.eq_maximalIdeal
    (padic_cyclotomic_maximal p k n)).symm

/-- The finite Witt-root algebra is a DVR and the cyclotomic root is its
uniformizer. -/
noncomputable instance padic_discrete_valuation
    (n : ℕ) : IsDiscreteValuationRing (B p k n) := by
  letI : IsNoetherianRing (B p k n) := inferInstance
  let hprincipal :
      (IsLocalRing.maximalIdeal (B p k n)).IsPrincipal := by
    rw [padic_witt_maximal p k n]
    exact ⟨_, rfl⟩
  let hpid : IsPrincipalIdealRing (B p k n) :=
    ((tfae_of_isNoetherianRing_of_isLocalRing_of_isDomain
      (B p k n)).out 4 0).mp hprincipal
  letI : IsPrincipalIdealRing (B p k n) := hpid
  refine { not_a_field' := ?_ }
  rw [padic_witt_maximal p k n]
  intro hbot
  have hpzero : algebraMap (W p k) (B p k n) (p : W p k) = 0 := by
    rw [← Ideal.mem_bot, ← hbot]
    exact padic_witt_p p k n
  exact WittVector.p_nonzero p k
    (FaithfulSMul.algebraMap_injective (W p k) (B p k n)
      (hpzero.trans (map_zero _).symm))

end

end Submission.CField.LTate
