import Submission.ClassField.NormCorrespondence.ArithmeticUnique
import Submission.ClassField.NormCorrespondence.Main
import Submission.ClassField.NormCorrespondence.InverseLimit
import Submission.ClassField.NormCorrespondence.StandardOpenSubgroups

/-!
# Chapter I, Theorem 1.13

Assuming the Local Existence Theorem, the two finite-level conditions in
the Local Recip Law determine the local Artin homomorphism uniquely.

The proof follows the text through finite subextensions.  For a prime
element `pi`, a sufficiently deep principal-unit subgroup gives a norm
extension on which `pi` acts trivially.  A canonical unramified extension
detects its Frobenius action.  Their compositum contains any prescribed
finite abelian extension, so the action of `pi` is determined at every
finite level.  Prime elements then generate `K^x`.
-/

namespace Submission.CField.NCorr

noncomputable section

universe u

open LBrauer
open Submission.CField.LFTheory

variable (K : Type u) [NontriviallyNormedField K] [IsUltrametricDist K]
  [ValuativeRel K] [IsNonarchimedeanLocalField K]
  [Valuation.Compatible (NormedField.valuation (K := K))]

/-- The elementary subgroup calculation in the proof of Theorem I.1.13.
If `H` contains the `m`th principal units, then intersecting the subgroup
generated by those units and a prime `pi` with the order-modulo-`[K^x:H]`
kernel lands inside `H`. -/
theorem standard_inf_ker
    (H : Subgroup Kˣ) [H.FiniteIndex] [NeZero H.index]
    (pi : Kˣ) (hpi : LocalPrimeElement K pi) (m : ℕ)
    (hprincipal : principalUnitField K m ≤ H) :
    standardOpenSubgroup K pi m 1 ⊓
        (localOrderMod K H.index).ker ≤ H := by
  intro x hx
  obtain ⟨u, hu, v, hv, rfl⟩ := Subgroup.mem_sup.mp hx.1
  simp only [pow_one] at hv
  obtain ⟨a, rfl⟩ := Subgroup.mem_zpowers_iff.mp hv
  have huH : u ∈ H := hprincipal hu
  have huUnit : u ∈ localUnitSubgroup K := by
    obtain ⟨w, hw, rfl⟩ := hu
    exact (integerUnitsUnit K w).property
  have huOrder :
      localUnitOrder K (Additive.ofMul u) = 0 :=
    (local_order_zero K u).1 huUnit
  have hpiOrder :
      localUnitOrder K (Additive.ofMul pi) = 1 :=
    (local_element_order K pi).1 hpi
  have hOrder :
      localUnitOrder K (Additive.ofMul (u * pi ^ a)) = a := by
    change localUnitOrder K
      (Additive.ofMul u + a • Additive.ofMul pi) = a
    rw [map_add, map_zsmul, huOrder, hpiOrder]
    simp
  have ha : (H.index : ℤ) ∣ a := by
    have ha' := (mod_ker_dvd K H.index
      (u * pi ^ a)).1 hx.2
    rwa [hOrder] at ha'
  obtain ⟨b, hb⟩ := ha
  have hpiIndex : pi ^ (H.index : ℤ) ∈ H := by
    simpa only [zpow_natCast] using H.pow_index_mem pi
  have hpiPower : pi ^ a ∈ H := by
    rw [hb, zpow_mul]
    exact H.zpow_mem hpiIndex b
  exact H.mul_mem huH hpiPower

variable (K : Type u) [NontriviallyNormedField K] [IsUltrametricDist K]
  [ValuativeRel K] [IsNonarchimedeanLocalField K]
  [Valuation.Compatible (NormedField.valuation (K := K))]

/-- Under local existence, two candidate reciprocity maps have the same
image of a prime element on every finite abelian subextension. -/
theorem restriction_unique_existence
    (hExistence : LocalExistenceTheorem K)
    (phi psi : Kˣ →* AbsoluteAbelianGalois K)
    (hphi : IsReciprocityMap K phi)
    (hpsi : IsReciprocityMap K psi)
    (pi : Kˣ) (hpi : LocalPrimeElement K pi)
    (L : FASubext K) :
    localAbelianRestriction L (phi pi) =
      localAbelianRestriction L (psi pi) := by
  let H := L.normGroup
  have hH : OFSubgro H :=
    (hExistence H).1 ⟨L, rfl⟩
  letI : H.FiniteIndex := hH.2
  letI : NeZero H.index := ⟨Subgroup.FiniteIndex.index_ne_zero⟩
  obtain ⟨m, hm⟩ :=
    Submission.CField.NCorr.principal_unit_field K H hH.1
  let J := Submission.CField.NCorr.standardOpenSubgroup K pi m 1
  obtain ⟨M, hM⟩ :=
    Submission.CField.NCorr.standard_open_group
      K hExistence pi hpi m
  let N := canonicalUnramifiedSubextension K H.index
  let C := M.sup N
  have hpiM : pi ∈ M.normGroup := by
    rw [hM]
    apply (show Subgroup.zpowers (pi ^ 1) ≤ J from le_sup_right)
    simpa only [pow_one] using Subgroup.mem_zpowers pi
  have hphiM : localAbelianRestriction M (phi pi) = 1 :=
    (norm_abelian_restriction
      phi hphi.2 M pi).1 hpiM
  have hpsiM : localAbelianRestriction M (psi pi) = 1 :=
    (norm_abelian_restriction
      psi hpsi.2 M pi).1 hpiM
  have hNunramified : N.IsUnramified K :=
    unramified_subextension K H.index
  have hphiNArithmetic : N.IsArithmeticFrobenius K
      (localAbelianRestriction N (phi pi)) :=
    hphi.1 pi hpi N hNunramified
  have hpsiNArithmetic : N.IsArithmeticFrobenius K
      (localAbelianRestriction N (psi pi)) :=
    hpsi.1 pi hpi N hNunramified
  have hphiN : localAbelianRestriction N (phi pi) =
      canonicalArithmeticFrobenius K H.index :=
    subextension_arithmetic_unique
      K H.index _ hphiNArithmetic
  have hpsiN : localAbelianRestriction N (psi pi) =
      canonicalArithmeticFrobenius K H.index :=
    subextension_arithmetic_unique
      K H.index _ hpsiNArithmetic
  have hnormC : C.normGroup =
      J ⊓ (localOrderMod K H.index).ker := by
    change (M.sup N).normGroup = _
    rw [normGroup_sup phi hphi.2 M N, hM,
      unramified_subextension_ker]
  have hLC : L.intermediateField ≤ C.intermediateField := by
    apply (intermediate_norm_group
      phi hphi.2 L C).2
    rw [hnormC]
    exact Submission.CField.NCorr.standard_inf_ker
      K H pi hpi m hm
  let q : AbsoluteAbelianGalois K := phi pi * (psi pi)⁻¹
  have hqM : localAbelianRestriction M q = 1 := by
    rw [show q = phi pi * (psi pi)⁻¹ by rfl, map_mul, map_inv,
      hphiM, hpsiM, inv_one, mul_one]
  have hqN : localAbelianRestriction N q = 1 := by
    rw [show q = phi pi * (psi pi)⁻¹ by rfl, map_mul, map_inv,
      hphiN, hpsiN, mul_inv_cancel]
  have hqC : localAbelianRestriction C q = 1 :=
    (abelian_restriction_sup M N q).2 ⟨hqM, hqN⟩
  have hqL : localAbelianRestriction L q = 1 :=
    local_abelian_restriction hLC q hqC
  have hquotient :
      localAbelianRestriction L (phi pi) *
          (localAbelianRestriction L (psi pi))⁻¹ = 1 := by
    simpa only [q, map_mul, map_inv] using hqL
  exact mul_inv_eq_one.mp hquotient

omit [IsUltrametricDist K] [ValuativeRel K]
  [IsNonarchimedeanLocalField K]
  [Valuation.Compatible (NormedField.valuation (K := K))] in
/-- Elements of the maximal abelian Galois group are determined by their
restrictions to all finite abelian subextensions. -/
theorem abelian_ext_restrictions
    (q r : AbsoluteAbelianGalois K)
    (h : ∀ L : FASubext K,
      localAbelianRestriction L q = localAbelianRestriction L r) :
    q = r := by
  apply (abelianGaloisMaximal K).injective
  apply (InfiniteGalois.mulEquivToLimit K
    (maximalAbelianIntermediate K)).injective
  apply Subtype.ext
  funext E
  change InfiniteGalois.proj E.unop
      (InfiniteGalois.algEquivToLimit K
        (maximalAbelianIntermediate K)
        (abelianGaloisMaximal K q)) =
    InfiniteGalois.proj E.unop
      (InfiniteGalois.algEquivToLimit K
        (maximalAbelianIntermediate K)
        (abelianGaloisMaximal K r))
  have hE := h (maximalAbelianSubextension K E.unop)
  rw [abelian_restriction_subextension,
    abelian_restriction_subextension] at hE
  exact (maximalAbelianLevel K E.unop).autCongr.injective hE

/-- Compatible-valuative-relation form of Theorem I.1.13.  This form is
useful internally when a valuative relation has already been installed. -/
theorem reciprocity_unique_existence
    (hExistence : LocalExistenceTheorem K)
    (phi psi : Kˣ →* AbsoluteAbelianGalois K)
    (hphi : IsReciprocityMap K phi)
    (hpsi : IsReciprocityMap K psi) :
    phi = psi := by
  apply Submission.CField.NCorr.monoid_hom_elements K phi psi
  intro pi hpi
  apply abelian_ext_restrictions K
  intro L
  exact restriction_unique_existence
    K hExistence phi psi hphi hpsi pi hpi L

end


section CanonicalValuation

open Submission.CField.LFTheory

universe u

variable (K : Type u) [NontriviallyNormedField K] [IsUltrametricDist K]

set_option maxHeartbeats 1000000 in
/-- **Theorem I.1.13 (statement).** Assuming local existence, there is at
most one homomorphism satisfying conditions (a) and (b) of the Local
Recip Law.  The valuative relation is the one canonically induced by
the norm valuation, so no normalization hypothesis is added to the text. -/
def LocalReciprocityUniqueness : Prop :=
  letI : ValuativeRel K :=
    ValuativeRel.ofValuation (NormedField.valuation (K := K))
  ∀ [IsNonarchimedeanLocalField K],
    LocalExistenceTheorem K →
      ∀ phi psi : Kˣ →* AbsoluteAbelianGalois K,
        IsReciprocityMap K phi →
        IsReciprocityMap K psi →
        phi = psi

/-- **Theorem I.1.13.** Local existence implies uniqueness of the local
Artin homomorphism characterized in Theorem I.1.1. -/
theorem localReciprocityUniqueness : LocalReciprocityUniqueness K := by
  letI : ValuativeRel K :=
    ValuativeRel.ofValuation (NormedField.valuation (K := K))
  dsimp only [LocalReciprocityUniqueness]
  intro _
  letI : Valuation.Compatible (NormedField.valuation (K := K)) :=
    Valuation.Compatible.ofValuation (NormedField.valuation (K := K))
  intro hExistence phi psi hphi hpsi
  exact reciprocity_unique_existence
    K hExistence phi psi hphi hpsi

end CanonicalValuation

end Submission.CField.NCorr
