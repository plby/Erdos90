import Mathlib
import Submission.Group.DenseGenerators.RestrictedBurnside
import Submission.Group.PowerWidth.FiniteWidthTopology


open scoped Topology Pointwise

noncomputable section

namespace Submission

universe u
universe v w z

/-- The dense subgroup generated by the image of a finite tuple in a power-subgroup quotient is
finitely generated. -/
lemma power_dense_fg
    {Γ : Type u} [Group Γ]
    {d : ℕ} (s : Fin d → Γ)
    (m : ℕ) :
    letI : (powerSubgroup Γ m).Normal := powerSubgroup_normal Γ m
    Group.FG
      (Subgroup.closure
        (Set.range
          (fun i : Fin d =>
            QuotientGroup.mk' (powerSubgroup Γ m) (s i))) :
        Subgroup (Γ ⧸ powerSubgroup Γ m)) := by
  letI : (powerSubgroup Γ m).Normal := powerSubgroup_normal Γ m
  infer_instance
/-- The dense subgroup generated by the image of a finite tuple in a positive power-subgroup
quotient is torsion. -/
lemma power_dense_torsion
    {Γ : Type u} [Group Γ]
    {d : ℕ} (s : Fin d → Γ)
    {m : ℕ}
    (hm : 0 < m) :
    letI : (powerSubgroup Γ m).Normal := powerSubgroup_normal Γ m
    Monoid.IsTorsion
      (Subgroup.closure
        (Set.range
          (fun i : Fin d =>
            QuotientGroup.mk' (powerSubgroup Γ m) (s i))) :
        Subgroup (Γ ⧸ powerSubgroup Γ m)) := by
  letI : (powerSubgroup Γ m).Normal := powerSubgroup_normal Γ m
  exact
    IsTorsion.subgroup
      (power_subgroup_torsion Γ hm)
      (Subgroup.closure
        (Set.range
          (fun i : Fin d =>
            QuotientGroup.mk' (powerSubgroup Γ m) (s i))))
/-- The dense subgroup in the power-subgroup quotient has exponent dividing `m`. -/
lemma dense_pow_one
    {Γ : Type u} [Group Γ]
    {d : ℕ} (s : Fin d → Γ)
    (m : ℕ) :
    letI : (powerSubgroup Γ m).Normal := powerSubgroup_normal Γ m
    ∀ x :
      (Subgroup.closure
        (Set.range
          (fun i : Fin d =>
            QuotientGroup.mk' (powerSubgroup Γ m) (s i))) :
        Subgroup (Γ ⧸ powerSubgroup Γ m)),
        x ^ m = 1 := by
  letI : (powerSubgroup Γ m).Normal := powerSubgroup_normal Γ m
  intro x
  apply Subtype.ext
  change (x : Γ ⧸ powerSubgroup Γ m) ^ m = 1
  exact
    power_pow_one Γ m
      (x : Γ ⧸ powerSubgroup Γ m)
/-- Subgroups of residually finite groups are residually finite. -/
lemma subgroup_residually_finite
    {G : Type u} [Group G] [Group.ResiduallyFinite G]
    (H : Subgroup G) :
    Group.ResiduallyFinite H := by
  rw [Group.residuallyFinite_iff_exists_finiteIndex]
  intro h hh
  have hne : (h : G) ≠ 1 := by
    intro h1
    exact hh (Subtype.ext h1)
  rcases
      (Group.residuallyFinite_iff_exists_finiteIndex.mp
        (inferInstance : Group.ResiduallyFinite G))
        (h : G) hne with
    ⟨K, hKfinite, hnotK⟩
  let L : Subgroup H := K.subgroupOf H
  haveI : K.FiniteIndex := hKfinite
  haveI : L.FiniteIndex := inferInstance
  refine ⟨L, inferInstance, ?_⟩
  intro hL
  exact hnotK (by simpa [L] using hL)
/-- A bounded-exponent Burnside input proves finiteness of the dense subgroup in the
power-subgroup quotient. -/
lemma bounded_exponent_burnside
    {Γ : Type u} [Group Γ]
    {d : ℕ} (s : Fin d → Γ)
    (m : ℕ)
    (hBurnside :
      ∀ (G : Type u) [Group G],
        Group.FG G → (∀ x : G, x ^ m = 1) → Finite G) :
    letI : (powerSubgroup Γ m).Normal := powerSubgroup_normal Γ m
    Finite
      (Subgroup.closure
        (Set.range
          (fun i : Fin d =>
            QuotientGroup.mk' (powerSubgroup Γ m) (s i))) :
        Subgroup (Γ ⧸ powerSubgroup Γ m)) := by
  letI : (powerSubgroup Γ m).Normal := powerSubgroup_normal Γ m
  let K : Subgroup (Γ ⧸ powerSubgroup Γ m) :=
    Subgroup.closure
      (Set.range
        (fun i : Fin d =>
          QuotientGroup.mk' (powerSubgroup Γ m) (s i)))
  have hfg : Group.FG K := by
    simpa [K] using
      power_dense_fg
        (Γ := Γ) s m
  have hpow : ∀ x : K, x ^ m = 1 := by
    simpa [K] using
      dense_pow_one
        (Γ := Γ) s m
  simpa [K] using hBurnside K hfg hpow
/-- A residually finite bounded-exponent Burnside input proves finiteness of the dense subgroup in
the power-subgroup quotient, provided the ambient quotient is residually finite. -/
lemma residually_exponent_burnside
    {Γ : Type u} [Group Γ]
    {d : ℕ} (s : Fin d → Γ)
    (m : ℕ)
    (hRF :
      letI : (powerSubgroup Γ m).Normal := powerSubgroup_normal Γ m
      Group.ResiduallyFinite (Γ ⧸ powerSubgroup Γ m))
    (hBurnside :
      ∀ (G : Type u) [Group G] [Group.ResiduallyFinite G],
        Group.FG G → (∀ x : G, x ^ m = 1) → Finite G) :
    letI : (powerSubgroup Γ m).Normal := powerSubgroup_normal Γ m
    Finite
      (Subgroup.closure
        (Set.range
          (fun i : Fin d =>
            QuotientGroup.mk' (powerSubgroup Γ m) (s i))) :
        Subgroup (Γ ⧸ powerSubgroup Γ m)) := by
  letI : (powerSubgroup Γ m).Normal := powerSubgroup_normal Γ m
  let K : Subgroup (Γ ⧸ powerSubgroup Γ m) :=
    Subgroup.closure
      (Set.range
        (fun i : Fin d =>
          QuotientGroup.mk' (powerSubgroup Γ m) (s i)))
  haveI : Group.ResiduallyFinite (Γ ⧸ powerSubgroup Γ m) := hRF
  haveI : Group.ResiduallyFinite K :=
    subgroup_residually_finite K
  have hfg : Group.FG K := by
    simpa [K] using
      power_dense_fg
        (Γ := Γ) s m
  have hpow : ∀ x : K, x ^ m = 1 := by
    simpa [K] using
      dense_pow_one
        (Γ := Γ) s m
  simpa [K] using hBurnside K hfg hpow
/-- If the dense finitely generated subgroup in a closed power-subgroup quotient is finite, then
the whole quotient is finite. -/
lemma power_subgroup_dense
    {Γ : Type u} [Group Γ] [TopologicalSpace Γ] [IsTopologicalGroup Γ]
    {d : ℕ} (s : Fin d → Γ)
    (hs : Subgroup.topologicalClosure (Subgroup.closure (Set.range s)) = ⊤)
    (m : ℕ)
    (hclosed : IsClosed ((powerSubgroup Γ m : Subgroup Γ) : Set Γ))
    (hfinite_dense :
      letI : (powerSubgroup Γ m).Normal := powerSubgroup_normal Γ m
      Finite
        (Subgroup.closure
          (Set.range
            (fun i : Fin d =>
              QuotientGroup.mk' (powerSubgroup Γ m) (s i))) :
          Subgroup (Γ ⧸ powerSubgroup Γ m))) :
    letI : (powerSubgroup Γ m).Normal := powerSubgroup_normal Γ m
    Finite (Γ ⧸ powerSubgroup Γ m) := by
  let P : Subgroup Γ := powerSubgroup Γ m
  letI : P.Normal := by
    dsimp [P]
    exact powerSubgroup_normal Γ m
  let K : Subgroup (Γ ⧸ P) :=
    Subgroup.closure
      (Set.range
        (fun i : Fin d =>
          QuotientGroup.mk' P (s i)))
  haveI : IsClosed (P : Set Γ) := by
    simpa [P] using hclosed
  haveI : T2Space (Γ ⧸ P) := by
    infer_instance
  haveI : Finite K := by
    simpa [K, P] using hfinite_dense
  exact
    finite_dense_subgroup
      (Ω := Γ ⧸ P)
      K
      (by
        simpa [K, P] using
          dense_generators_quotient
            (Γ := Γ) s hs m)
/-- Closedness plus finiteness of the dense generated subgroup gives an open normal subgroup inside
the power subgroup. -/
lemma dense_open_closed
    {Γ : Type u} [Group Γ] [TopologicalSpace Γ] [IsTopologicalGroup Γ]
    [CompactSpace Γ]
    {d : ℕ} (s : Fin d → Γ)
    (hs : Subgroup.topologicalClosure (Subgroup.closure (Set.range s)) = ⊤)
    (m : ℕ)
    (hclosed : IsClosed ((powerSubgroup Γ m : Subgroup Γ) : Set Γ))
    (hfinite_dense :
      letI : (powerSubgroup Γ m).Normal := powerSubgroup_normal Γ m
      Finite
        (Subgroup.closure
          (Set.range
            (fun i : Fin d =>
              QuotientGroup.mk' (powerSubgroup Γ m) (s i))) :
          Subgroup (Γ ⧸ powerSubgroup Γ m))) :
    ∃ N : OpenNormalSubgroup Γ,
      N.toSubgroup ≤ powerSubgroup Γ m := by
  letI : (powerSubgroup Γ m).Normal := powerSubgroup_normal Γ m
  have hfinite_quot : Finite (Γ ⧸ powerSubgroup Γ m) :=
    power_subgroup_dense
      (Γ := Γ) s hs m hclosed hfinite_dense
  exact
    open_normal_closed
      Γ m hclosed hfinite_quot
/-- Any nontrivial element of a profinite group is excluded by some open normal subgroup. -/
lemma open_not_ne
    {Γ : Type u} [Group Γ] [TopologicalSpace Γ] [IsTopologicalGroup Γ]
    [CompactSpace Γ] [TotallyDisconnectedSpace Γ]
    {g : Γ}
    (hg : g ≠ 1) :
    ∃ N : OpenNormalSubgroup Γ, g ∉ N := by
  obtain ⟨N, hN⟩ :=
    ProfiniteGrp.exist_openNormalSubgroup_sub_open_nhds_of_one
      (G := Γ)
      (U := ({g} : Set Γ)ᶜ)
      isOpen_compl_singleton
      (by simpa [Set.mem_compl_iff, Set.mem_singleton_iff] using hg.symm)
  refine ⟨N, ?_⟩
  intro hgN
  exact hN hgN rfl
/-- A profinite topological group is residually finite as an abstract group. -/
lemma profinite_residuallyFinite
    {Γ : Type u} [Group Γ] [TopologicalSpace Γ] [IsTopologicalGroup Γ]
    [CompactSpace Γ] [TotallyDisconnectedSpace Γ] :
    Group.ResiduallyFinite Γ := by
  rw [Group.residuallyFinite_iff_exists_finiteIndex]
  intro g hg
  rcases open_not_ne (Γ := Γ) hg with ⟨N, hN⟩
  let H : Subgroup Γ := N.toSubgroup
  haveI : H.FiniteIndex := by
    dsimp [H]
    exact N.finiteIndex_of_finite_quotient
  refine ⟨H, inferInstance, ?_⟩
  simpa [H] using hN
/-- Algebraic residual finiteness, expressed directly by separating finite quotient
homomorphisms. -/
def SFQuotie (G : Type u) [Group G] : Prop :=
  ∀ {g : G}, g ≠ 1 →
    ∃ (F : Type u) (_ : Group F) (_ : Finite F) (φ : G →* F),
      φ g ≠ 1
/-- The fixed-exponent weak restricted-Burnside input used by the profinite power-subgroup
argument.  This is the residually-finite consequence of Zelmanov's theorem, expressed directly
through separating finite quotients. -/
def SQBurnsi.{q} (m : ℕ) : Prop :=
  ∀ (G : Type q) [Group G],
    SFQuotie G →
      Group.FG G → (∀ x : G, x ^ m = 1) → Finite G
/-- A weak restricted-Burnside theorem for a larger exponent applies to every divisor exponent. -/
lemma SQBurnsi.of_dvd_exponent
    {mSmall mBig : ℕ}
    (hdiv : mSmall ∣ mBig)
    (hBurnside : SQBurnsi.{u} mBig) :
    SQBurnsi.{u} mSmall := by
  intro G _instGroup hsep hfg hexp
  apply hBurnside G hsep hfg
  intro x
  rcases hdiv with ⟨c, rfl⟩
  rw [pow_mul, hexp x, one_pow]
/-- The weak restricted-Burnside input is elementary at exponent two. -/
theorem separating_quotients_two :
    SQBurnsi.{u} 2 := by
  intro G _instGroup _hsep hfg hexp
  have horders : ∀ g : G, orderOf g ∣ 2 := by
    intro g
    exact orderOf_dvd_iff_pow_eq_one.mpr (hexp g)
  have hcomm : Std.Commutative (α := G) (· * ·) := by
    exact ⟨fun a b => (Commute.of_orderOf_dvd_two horders a b).eq⟩
  haveI : IsMulCommutative G := ⟨hcomm⟩
  letI : CommGroup G := { _instGroup with mul_comm := hcomm.comm }
  letI : Group.FG G := hfg
  have htor : Monoid.IsTorsion G := by
    intro g
    exact isOfFinOrder_iff_pow_eq_one.mpr ⟨2, by norm_num, hexp g⟩
  exact CommGroup.finite_of_fg_torsion G htor
/-- The weak restricted-Burnside input is elementary at exponent one. -/
theorem separating_quotients_bounded :
    SQBurnsi.{u} 1 := by
  exact
    SQBurnsi.of_dvd_exponent
      (Nat.one_dvd 2)
      separating_quotients_two
/-- Subgroups inherit separating finite quotients. -/
lemma SFQuotie.subgroup
    {G : Type u} [Group G]
    (hG : SFQuotie G)
    (H : Subgroup G) :
    SFQuotie H := by
  intro x hx
  have hxval : (x : G) ≠ 1 := by
    intro h
    exact hx (Subtype.ext h)
  rcases hG hxval with ⟨F, instF, instFiniteF, φ, hφ⟩
  letI : Group F := instF
  letI : Finite F := instFiniteF
  refine ⟨F, inferInstance, inferInstance, φ.comp H.subtype, ?_⟩
  simpa using hφ
/-- Topological finite-quotient separation by open normal subgroups. -/
def SOQuotie
    (G : Type u) [Group G] [TopologicalSpace G] : Prop :=
  ∀ {g : G}, g ≠ 1 →
    ∃ N : OpenNormalSubgroup G,
      Finite (G ⧸ N.toSubgroup) ∧
        QuotientGroup.mk' N.toSubgroup g ≠ 1
/-- Open-normal finite quotient separation gives algebraic separating finite quotients. -/
lemma SOQuotie.separating_fin_quots
    {G : Type u} [Group G] [TopologicalSpace G]
    (hG : SOQuotie G) :
    SFQuotie G := by
  intro g hg
  rcases hG hg with ⟨N, hfin, hsep⟩
  exact
    ⟨G ⧸ N.toSubgroup, inferInstance, hfin,
      QuotientGroup.mk' N.toSubgroup, hsep⟩
/-- A normal subgroup is separated by open normal finite quotients if every point outside it is
excluded by an open normal subgroup containing it. -/
def SeparatedOpenQuotients
    {G : Type u} [Group G] [TopologicalSpace G]
    (K : Subgroup G) : Prop :=
  ∀ {g : G}, g ∉ K →
    ∃ N : OpenNormalSubgroup G,
      K ≤ N.toSubgroup ∧
        g ∉ N.toSubgroup ∧
          Finite (G ⧸ N.toSubgroup)
/-- A closed normal subgroup of a profinite group is separated by open normal finite quotients. -/
lemma separated_quotients_closed
    {Γ : Type u} [Group Γ] [TopologicalSpace Γ] [IsTopologicalGroup Γ]
    [CompactSpace Γ] [TotallyDisconnectedSpace Γ]
    {K : Subgroup Γ} [K.Normal]
    (hclosed : IsClosed ((K : Subgroup Γ) : Set Γ)) :
    SeparatedOpenQuotients K := by
  intro g hgK
  let Kc : ClosedSubgroup Γ :=
    { toSubgroup := K
      isClosed' := hclosed }
  obtain ⟨S, hS, hgS⟩ :
      ∃ S : Subgroup Γ,
        (IsOpen ((S : Subgroup Γ) : Set Γ) ∧ Kc ≤ S) ∧ g ∉ S := by
    by_contra hnone
    have hg_sInf :
        g ∈ sInf {S : Subgroup Γ | IsOpen ((S : Subgroup Γ) : Set Γ) ∧ Kc ≤ S} := by
      exact
        Subgroup.mem_sInf.mpr
          (fun S hS => by
            by_contra hgS
            exact hnone ⟨S, hS, hgS⟩)
    have hgK' : g ∈ K := by
      change g ∈ ((Kc : Subgroup Γ) : Set Γ)
      rw [ProfiniteGrp.closedSubgroup_eq_sInf_open Kc]
      exact hg_sInf
    exact hgK hgK'
  let Sopen : OpenSubgroup Γ :=
    { toSubgroup := S
      isOpen' := hS.1 }
  haveI : Finite (Γ ⧸ S) :=
    Subgroup.quotient_finite_of_isOpen S hS.1
  haveI : S.FiniteIndex :=
    Subgroup.finiteIndex_of_finite_quotient
  let N : OpenNormalSubgroup Γ :=
    { toSubgroup := Subgroup.normalCore S
      isOpen' :=
        Subgroup.isOpen_of_isClosed_of_finiteIndex _
          (S.normalCore_isClosed Sopen.isClosed) }
  have hKN : K ≤ N.toSubgroup := by
    dsimp [N]
    exact Subgroup.normal_le_normalCore.mpr (fun x hx => hS.2 hx)
  have hgN : g ∉ N.toSubgroup := by
    intro hgN
    exact hgS (S.normalCore_le hgN)
  haveI : N.toSubgroup.FiniteIndex := by
    dsimp [N]
    infer_instance
  have hfinite : Finite (Γ ⧸ N.toSubgroup) := by
    infer_instance
  exact ⟨N, hKN, hgN, hfinite⟩
/-- If a normal subgroup is separated by open normal finite quotients, then the quotient has
separating finite quotients. -/
lemma separating_normal_separated
    {G : Type u} [Group G] [TopologicalSpace G]
    (K : Subgroup G) [K.Normal]
    (hsep : SeparatedOpenQuotients K) :
    SFQuotie (G ⧸ K) := by
  intro q hq
  rcases QuotientGroup.mk'_surjective K q with ⟨g, rfl⟩
  have hgK : g ∉ K := by
    intro hgK
    exact hq ((QuotientGroup.eq_one_iff (N := K) g).mpr hgK)
  rcases hsep hgK with ⟨N, hKN, hgN, hfinN⟩
  let φ : G ⧸ K →* G ⧸ N.toSubgroup :=
    QuotientGroup.lift K (QuotientGroup.mk' N.toSubgroup) (by
      intro x hxK
      exact (QuotientGroup.eq_one_iff (N := N.toSubgroup) x).mpr (hKN hxK))
  have hmkN : QuotientGroup.mk' N.toSubgroup g ≠ 1 := by
    intro h
    exact hgN ((QuotientGroup.eq_one_iff (N := N.toSubgroup) g).mp h)
  have hφ : φ (QuotientGroup.mk' K g) ≠ 1 := by
    simpa [φ] using hmkN
  exact ⟨G ⧸ N.toSubgroup, inferInstance, hfinN, φ, hφ⟩
/-- A separated power subgroup has a quotient with separating finite quotients. -/
lemma separating_quotients_separated
    {Γ : Type u} [Group Γ] [TopologicalSpace Γ]
    (m : ℕ)
    (hsep :
      SeparatedOpenQuotients
        (powerSubgroup Γ m)) :
    letI : (powerSubgroup Γ m).Normal := powerSubgroup_normal Γ m
    SFQuotie (Γ ⧸ powerSubgroup Γ m) := by
  letI : (powerSubgroup Γ m).Normal := powerSubgroup_normal Γ m
  intro q hq
  exact
    separating_normal_separated
      (G := Γ) (K := powerSubgroup Γ m) (hsep := hsep) hq
/-- The dense subgroup in a power-subgroup quotient inherits separating finite quotients from the
ambient quotient. -/
lemma separating_quotients_ambient
    {Γ : Type u} [Group Γ]
    {d : ℕ} (s : Fin d → Γ)
    (m : ℕ)
    (hQ :
      letI : (powerSubgroup Γ m).Normal := powerSubgroup_normal Γ m
      SFQuotie (Γ ⧸ powerSubgroup Γ m)) :
    letI : (powerSubgroup Γ m).Normal := powerSubgroup_normal Γ m
    SFQuotie
      (Subgroup.closure
        (Set.range
          (fun i : Fin d =>
            QuotientGroup.mk' (powerSubgroup Γ m) (s i))) :
        Subgroup (Γ ⧸ powerSubgroup Γ m)) := by
  letI : (powerSubgroup Γ m).Normal := powerSubgroup_normal Γ m
  intro x hx
  exact (SFQuotie.subgroup hQ _) hx
/-- Separation of the power subgroup by open normal finite quotients gives separating finite
quotients for the dense subgroup in the power-subgroup quotient. -/
lemma
    dense_normal_separated
    {Γ : Type u} [Group Γ] [TopologicalSpace Γ]
    {d : ℕ} (s : Fin d → Γ)
    (m : ℕ)
    (hsep :
      SeparatedOpenQuotients
        (powerSubgroup Γ m)) :
    letI : (powerSubgroup Γ m).Normal := powerSubgroup_normal Γ m
    SFQuotie
      (Subgroup.closure
        (Set.range
          (fun i : Fin d =>
            QuotientGroup.mk' (powerSubgroup Γ m) (s i))) :
        Subgroup (Γ ⧸ powerSubgroup Γ m)) := by
  exact
    separating_quotients_ambient
      (Γ := Γ) s m
      (separating_quotients_separated
        (Γ := Γ) m hsep)
/-- A Burnside input for groups with separating finite quotients proves finiteness of the dense
subgroup in the power-subgroup quotient. -/
lemma dense_separating_burnside
    {Γ : Type u} [Group Γ]
    {d : ℕ} (s : Fin d → Γ)
    (m : ℕ)
    (hsep :
      letI : (powerSubgroup Γ m).Normal := powerSubgroup_normal Γ m
      SFQuotie
        (Subgroup.closure
          (Set.range
            (fun i : Fin d =>
              QuotientGroup.mk' (powerSubgroup Γ m) (s i))) :
          Subgroup (Γ ⧸ powerSubgroup Γ m)))
    (hBurnside :
      ∀ (G : Type u) [Group G],
        SFQuotie G →
          Group.FG G → (∀ x : G, x ^ m = 1) → Finite G) :
    letI : (powerSubgroup Γ m).Normal := powerSubgroup_normal Γ m
    Finite
      (Subgroup.closure
        (Set.range
          (fun i : Fin d =>
            QuotientGroup.mk' (powerSubgroup Γ m) (s i))) :
        Subgroup (Γ ⧸ powerSubgroup Γ m)) := by
  letI : (powerSubgroup Γ m).Normal := powerSubgroup_normal Γ m
  let K : Subgroup (Γ ⧸ powerSubgroup Γ m) :=
    Subgroup.closure
      (Set.range
        (fun i : Fin d =>
          QuotientGroup.mk' (powerSubgroup Γ m) (s i)))
  have hsepK : SFQuotie K := by
    dsimp [K]
    dsimp at hsep
    exact hsep
  have hfg : Group.FG K := by
    simpa [K] using
      power_dense_fg
        (Γ := Γ) s m
  have hpow : ∀ x : K, x ^ m = 1 := by
    simpa [K] using
      dense_pow_one
        (Γ := Γ) s m
  simpa [K] using hBurnside K hsepK hfg hpow
/-- For one fixed exponent, bounded power width and the weak restricted-Burnside input make the
ambient power subgroup open. -/
lemma separating_quotients_burnside
    {Γ : Type u} [Group Γ] [TopologicalSpace Γ] [IsTopologicalGroup Γ]
    [CompactSpace Γ] [TotallyDisconnectedSpace Γ]
    {d : ℕ} (s : Fin d → Γ)
    (hs : Subgroup.topologicalClosure (Subgroup.closure (Set.range s)) = ⊤)
    {m k : ℕ}
    (hwidth : HPWidth Γ m k)
    (hBurnside : SQBurnsi.{u} m) :
    IsOpen ((powerSubgroup Γ m : Subgroup Γ) : Set Γ) := by
  have hclosed :
      IsClosed ((powerSubgroup Γ m : Subgroup Γ) : Set Γ) :=
    closed_totally_disconnected
      (Γ := Γ) hwidth
  letI : (powerSubgroup Γ m).Normal := powerSubgroup_normal Γ m
  have hfinite_dense :
      Finite
        (Subgroup.closure
          (Set.range
            (fun i : Fin d =>
              QuotientGroup.mk' (powerSubgroup Γ m) (s i))) :
          Subgroup (Γ ⧸ powerSubgroup Γ m)) := by
    exact
      dense_separating_burnside
        (Γ := Γ) s m
        (dense_normal_separated
          (Γ := Γ) s m
          (separated_quotients_closed
            (Γ := Γ) (K := powerSubgroup Γ m) hclosed))
        hBurnside
  have hfinite_quotient :
      Finite (Γ ⧸ powerSubgroup Γ m) :=
    power_subgroup_dense
      (Γ := Γ) s hs m hclosed hfinite_dense
  letI : Finite (Γ ⧸ powerSubgroup Γ m) := hfinite_quotient
  exact
    width_totally_disconnected
      (Γ := Γ) hwidth
/-- A closed power-subgroup quotient of a profinite group is residually finite. -/
lemma power_residually_closed
    {Γ : Type u} [Group Γ] [TopologicalSpace Γ] [IsTopologicalGroup Γ]
    [CompactSpace Γ] [TotallyDisconnectedSpace Γ]
    (m : ℕ)
    (_hclosed : IsClosed ((powerSubgroup Γ m : Subgroup Γ) : Set Γ))
    (hquot :
      letI : (powerSubgroup Γ m).Normal := powerSubgroup_normal Γ m
      TotallyDisconnectedSpace (Γ ⧸ powerSubgroup Γ m)) :
    letI : (powerSubgroup Γ m).Normal := powerSubgroup_normal Γ m
    Group.ResiduallyFinite (Γ ⧸ powerSubgroup Γ m) := by
  let P : Subgroup Γ := powerSubgroup Γ m
  letI : P.Normal := by
    dsimp [P]
    exact powerSubgroup_normal Γ m
  haveI : TotallyDisconnectedSpace (Γ ⧸ P) := by
    simpa [P] using hquot
  exact profinite_residuallyFinite (Γ := Γ ⧸ P)
end Submission
