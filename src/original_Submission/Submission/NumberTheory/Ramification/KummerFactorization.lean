/-!
# Milne, Algebraic Number Theory, Theorem 3.41

This file records the Kummer--Dedekind factorization theorem.  The general form identifies the
prime factors, with multiplicity, of the extension of a prime ideal when the integral closure is
generated by one integral element.  We also record the explicit ideal attached to a polynomial
factor.  The final statements specialize to rings of integers of number fields, where Mathlib's
API also gives the residue degree and ramification index.
-/

namespace Submission.NumberTheory.Milne

open Algebra Ideal Polynomial UniqueFactorizationMonoid

/-- Remark 3.42: a nonconstant polynomial over a field has zero discriminant exactly when it
is not separable. -/
theorem discr_not_separable
    {k : Type*} [Field k] {f : k[X]} (hdeg : 0 < f.natDegree) :
    f.discr = 0 ↔ ¬ f.Separable := by
  have hf0 : f ≠ 0 := by
    intro hf
    simp [hf] at hdeg
  have hlc : f.leadingCoeff ≠ 0 := leadingCoeff_ne_zero.mpr hf0
  have hderiv : f.derivative.natDegree ≤ f.natDegree - 1 :=
    f.natDegree_derivative_le
  have hpad :
      f.resultant f.derivative f.natDegree (f.natDegree - 1) =
        f.leadingCoeff ^ ((f.natDegree - 1) - f.derivative.natDegree) *
          f.resultant f.derivative := by
    have h := Polynomial.resultant_add_right_deg f f.derivative
      f.natDegree f.derivative.natDegree
      ((f.natDegree - 1) - f.derivative.natDegree) le_rfl
    rwa [Nat.add_sub_of_le hderiv] at h
  have hpositive : 0 < f.degree :=
    Polynomial.natDegree_pos_iff_degree_pos.mp hdeg
  have hdisc := Polynomial.resultant_deriv (f := f) hpositive
  calc
    f.discr = 0 ↔
        f.resultant f.derivative f.natDegree (f.natDegree - 1) = 0 := by
      rw [hdisc]
      simp [hlc]
    _ ↔ f.resultant f.derivative = 0 := by rw [hpad]; simp [hlc]
    _ ↔ (f ≠ 0 ∨ f.derivative ≠ 0) ∧ ¬ IsCoprime f f.derivative :=
      Polynomial.resultant_eq_zero_iff
    _ ↔ ¬ IsCoprime f f.derivative := by simp [hf0]
    _ ↔ ¬ f.Separable := (not_congr (Polynomial.separable_def f)).symm

/-- Over a perfect field, Remark 3.42's criterion says precisely that the discriminant
vanishes when the polynomial has a repeated irreducible factor. -/
theorem polynomial_discr_squarefree
    {k : Type*} [Field k] [PerfectField k] {f : k[X]} (hdeg : 0 < f.natDegree) :
    f.discr = 0 ↔ ¬ Squarefree f := by
  rw [discr_not_separable hdeg,
    PerfectField.separable_iff_squarefree]

/-- Polynomial discriminants commute with coefficient maps for monic nonconstant
polynomials. Monicity prevents the degree from dropping after applying the map. -/
theorem polynomial_discr_monic
    {R S : Type*} [CommRing R] [CommRing S] [Nontrivial S]
    (φ : R →+* S) (f : R[X]) (hf : f.Monic) (hdeg : 0 < f.natDegree) :
    φ f.discr = (f.map φ).discr := by
  have hdegree : 0 < f.degree := natDegree_pos_iff_degree_pos.mp hdeg
  have hmapdegree : 0 < (f.map φ).degree := by
    apply natDegree_pos_iff_degree_pos.mp
    simpa [hf.natDegree_map] using hdeg
  have hres := Polynomial.resultant_deriv (f := f) hdegree
  have hresmap := Polynomial.resultant_deriv (f := f.map φ) hmapdegree
  have hφres := Polynomial.resultant_map_map f f.derivative
    f.natDegree (f.natDegree - 1) φ
  let s : S := (-1) ^ (f.natDegree * (f.natDegree - 1) / 2)
  have hs : IsUnit s := by
    change IsUnit ((-1 : S) ^ (f.natDegree * (f.natDegree - 1) / 2))
    exact isUnit_one.neg.pow _
  apply hs.mul_left_cancel
  calc
    s * φ f.discr =
        φ ((-1) ^ (f.natDegree * (f.natDegree - 1) / 2) * f.discr) := by
      simp [s]
    _ = φ (f.resultant f.derivative f.natDegree (f.natDegree - 1)) := by
      rw [hres, hf.leadingCoeff, mul_one]
    _ = (f.map φ).resultant (f.derivative.map φ)
        f.natDegree (f.natDegree - 1) := hφres.symm
    _ = (f.map φ).resultant (f.map φ).derivative
        (f.map φ).natDegree ((f.map φ).natDegree - 1) := by
      rw [derivative_map, hf.natDegree_map]
    _ = s * (f.map φ).discr := by
      rw [hresmap, (hf.map φ).leadingCoeff, mul_one]
      simp [s, hf.natDegree_map]

/-- Remark 3.42 in its reduction-modulo-a-prime form: a prime contains the polynomial
discriminant exactly when the reduced polynomial has a repeated factor. -/
theorem discr_not_squarefree
    {A : Type*} [CommRing A] {p : Ideal A} [p.IsMaximal] [Finite (A ⧸ p)]
    (f : A[X]) (hf : f.Monic) (hdeg : 0 < f.natDegree) :
    f.discr ∈ p ↔ ¬ Squarefree (f.map (Ideal.Quotient.mk p)) := by
  letI : Field (A ⧸ p) := Ideal.Quotient.field p
  letI : PerfectField (A ⧸ p) := inferInstance
  rw [← Ideal.Quotient.eq_zero_iff_mem,
    polynomial_discr_monic (Ideal.Quotient.mk p) f hf hdeg]
  apply polynomial_discr_squarefree
  simpa [hf.natDegree_map] using hdeg

/-- Remark 3.43: the discriminant multiplier of the order `Z[alpha]` controls its
conductor.  If a rational prime does not divide that multiplier, then it is coprime to
the conductor, which is the local hypothesis needed by Kummer--Dedekind.

The basis `bAlpha` is the power basis of `Z[alpha]` in the application.  We state the
lemma for an arbitrary basis of that order, since only its discriminant is used. -/
theorem conductor_discriminant_ratio
    {B ι : Type*} [CommRing B] [Fintype ι] [DecidableEq ι]
    (b : Module.Basis ι ℤ B) (alpha : B)
    (bAlpha : Module.Basis ι ℤ (Algebra.adjoin ℤ ({alpha} : Set B)))
    (a : ℤ) {p : ℕ} [Fact p.Prime]
    (hdisc : Algebra.discr ℤ (fun i => (bAlpha i : B)) =
      a * Algebra.discr ℤ b)
    (hdisc_ne : Algebra.discr ℤ b ≠ 0)
    (hp : ¬ (p : ℤ) ∣ a) :
    (conductor ℤ alpha).comap (algebraMap ℤ B) ⊔ Ideal.span {(p : ℤ)} = ⊤ := by
  let N : Submodule ℤ B := (Algebra.adjoin ℤ ({alpha} : Set B)).toSubmodule
  let n : ℕ := N.toAddSubgroup.index
  have hindex := discr_submodule_sq b N bAlpha
  have hratio : (n : ℤ) ^ 2 = a := by
    apply mul_right_cancel₀ hdisc_ne
    calc
      (n : ℤ) ^ 2 * Algebra.discr ℤ b =
          Algebra.discr ℤ (fun i => (bAlpha i : B)) := hindex.symm
      _ = a * Algebra.discr ℤ b := hdisc
  have hpindex : ¬ (p : ℤ) ∣ (n : ℤ) := by
    intro hpn
    apply hp
    rw [← hratio, pow_two]
    exact dvd_mul_of_dvd_left hpn _
  have hn_conductor : (n : ℤ) ∈
      (conductor ℤ alpha).comap (algebraMap ℤ B) := by
    rw [Ideal.mem_comap, mem_conductor_iff]
    intro z
    simpa [algebraMap_int_eq, N, n] using
      AddSubgroup.nsmul_index_mem N.toAddSubgroup z
  have hn_not_mem : (n : ℤ) ∉ Ideal.span {(p : ℤ)} := by
    simpa [Ideal.mem_span_singleton] using hpindex
  have hnotle : ¬ (conductor ℤ alpha).comap (algebraMap ℤ B) ≤
      Ideal.span {(p : ℤ)} := by
    intro hle
    exact hn_not_mem (hle hn_conductor)
  by_contra hne
  have heq := Ideal.IsMaximal.eq_of_le
    (Int.ideal_span_isMaximal_of_prime p) hne le_sup_right
  apply hnotle
  rw [heq]
  exact le_sup_left

namespace GKDedeki

attribute [local instance] Ideal.Quotient.field

private theorem conductor_coprime_top
    {A B : Type*} [CommRing A] [CommRing B] [Algebra A B]
    {alpha : B} {p : Ideal A}
    (halpha : Algebra.adjoin A {alpha} = ⊤) :
    (conductor A alpha).comap (algebraMap A B) ⊔ p = ⊤ := by
  rw [conductor_eq_top_iff_adjoin_eq_top.mpr halpha, Ideal.comap_top, top_sup_eq]

variable {A B : Type*} [CommRing A] [CommRing B] [Algebra A B]
  [IsDomain A] [IsIntegrallyClosed A] [IsDedekindDomain B]
  [Module.IsTorsionFree A B]

open Classical in
/-- Remark 3.43: at one fixed prime, the Kummer--Dedekind correspondence only requires
that prime to be coprime to the conductor of `A[alpha]` in `B`; global monogenicity is
unnecessary. -/
noncomputable def factor_coprime_conductor
    {alpha : B} {p : Ideal A} [p.IsMaximal] (hp0 : p ≠ ⊥)
    (hcoprime : (conductor A alpha).comap (algebraMap A B) ⊔ p = ⊤)
    (halpha_int : IsIntegral A alpha) :
    {P : Ideal B // P ∈ normalizedFactors (p.map (algebraMap A B))} ≃
      {g : (A ⧸ p)[X] //
        g ∈ normalizedFactors ((minpoly A alpha).map (Ideal.Quotient.mk p))} :=
  KummerDedekind.normalizedFactorsMapEquivNormalizedFactorsMinPolyMk
    inferInstance hp0 hcoprime halpha_int

open Classical in
/-- Remark 3.43, factorization form: the normalized prime factors of `pB`, with
multiplicity, are obtained from the normalized factors of the reduced minimal polynomial
under the local conductor-coprimality hypothesis. -/
theorem minpol_copri_condu
    {alpha : B} {p : Ideal A} [p.IsMaximal] (hp0 : p ≠ ⊥)
    (hcoprime : (conductor A alpha).comap (algebraMap A B) ⊔ p = ⊤)
    (halpha_int : IsIntegral A alpha) :
    normalizedFactors (p.map (algebraMap A B)) =
      Multiset.map
        (fun g => ((factor_coprime_conductor hp0 hcoprime halpha_int).symm g :
          Ideal B))
        (normalizedFactors
          ((minpoly A alpha).map (Ideal.Quotient.mk p))).attach := by
  exact
    KummerDedekind.normalizedFactors_ideal_map_eq_normalizedFactors_min_poly_mk_map
      inferInstance hp0 hcoprime halpha_int

open Classical in
/-- Remark 3.43, explicit-prime form: a lifted irreducible factor `G` corresponds to
the prime ideal `(p, G(alpha))`, under the fixed-prime conductor hypothesis. -/
theorem pair_coprime_conductor
    {alpha : B} {p : Ideal A} [p.IsMaximal] (hp0 : p ≠ ⊥)
    (hcoprime : (conductor A alpha).comap (algebraMap A B) ⊔ p = ⊤)
    (halpha_int : IsIntegral A alpha) {G : A[X]}
    (hG : G.map (Ideal.Quotient.mk p) ∈
      normalizedFactors ((minpoly A alpha).map (Ideal.Quotient.mk p))) :
    ((factor_coprime_conductor hp0 hcoprime halpha_int).symm
        ⟨G.map (Ideal.Quotient.mk p), hG⟩ : Ideal B) =
      Ideal.span (p.map (algebraMap A B) ∪ {G.aeval alpha}) := by
  exact
    KummerDedekind.normalizedFactorsMapEquivNormalizedFactorsMinPolyMk_symm_apply_eq_span
      inferInstance hG hp0 hcoprime halpha_int

open Classical in
/-- Remark 3.43, exponent form: the exponent of `(p, G(alpha))` in `pB` is
the multiplicity of the corresponding factor of the reduced minimal polynomial. -/
theorem emulti_minpo_condu
    {alpha : B} {p : Ideal A} [p.IsMaximal] (hp0 : p ≠ ⊥)
    (hcoprime : (conductor A alpha).comap (algebraMap A B) ⊔ p = ⊤)
    (halpha_int : IsIntegral A alpha) {G : A[X]}
    (hG : G.map (Ideal.Quotient.mk p) ∈
      normalizedFactors ((minpoly A alpha).map (Ideal.Quotient.mk p))) :
    emultiplicity
        (Ideal.span (p.map (algebraMap A B) ∪ {G.aeval alpha}))
        (p.map (algebraMap A B)) =
      emultiplicity (G.map (Ideal.Quotient.mk p))
        ((minpoly A alpha).map (Ideal.Quotient.mk p)) := by
  rw [← pair_coprime_conductor hp0 hcoprime halpha_int hG]
  let e := KummerDedekind.normalizedFactorsMapEquivNormalizedFactorsMinPolyMk
    (x := alpha) inferInstance hp0 hcoprime halpha_int
  let g : {d : (A ⧸ p)[X] //
      d ∈ normalizedFactors ((minpoly A alpha).map (Ideal.Quotient.mk p))} :=
    ⟨G.map (Ideal.Quotient.mk p), hG⟩
  have h := KummerDedekind.emultiplicity_factors_map_eq_emultiplicity
    (x := alpha) inferInstance hp0 hcoprime halpha_int (e.symm g).prop
  rw [e.apply_symm_apply g] at h
  simpa [e, g, factor_coprime_conductor] using h

open Classical in
/-- The factorization assertion of Theorem 3.41, expressed as equality of the multisets of
normalized prime factors.  Thus the occurrence count of each factor on the right is its
ramification exponent. -/
theorem normalized_minpoly_top
    {alpha : B} {p : Ideal A} [p.IsMaximal] (hp0 : p ≠ ⊥)
    (halpha : Algebra.adjoin A {alpha} = ⊤) (halpha_int : IsIntegral A alpha) :
    normalizedFactors (p.map (algebraMap A B)) =
      Multiset.map
        (fun g =>
          ((KummerDedekind.normalizedFactorsMapEquivNormalizedFactorsMinPolyMk
            inferInstance hp0 (conductor_coprime_top halpha) halpha_int).symm g :
              Ideal B))
        (normalizedFactors
          ((minpoly A alpha).map (Ideal.Quotient.mk p))).attach := by
  exact
    KummerDedekind.normalizedFactors_ideal_map_eq_normalizedFactors_min_poly_mk_map
      inferInstance hp0 (conductor_coprime_top halpha) halpha_int

open Classical in
/-- A lifted irreducible factor `G` of the reduced minimal polynomial corresponds to the prime
ideal generated by `p` and `G(alpha)`, as in Theorem 3.41. -/
theorem pair_adjoin_top
    {alpha : B} {p : Ideal A} [p.IsMaximal] (hp0 : p ≠ ⊥)
    (halpha : Algebra.adjoin A {alpha} = ⊤) (halpha_int : IsIntegral A alpha)
    {G : A[X]}
    (hG : G.map (Ideal.Quotient.mk p) ∈
      normalizedFactors ((minpoly A alpha).map (Ideal.Quotient.mk p))) :
    ((KummerDedekind.normalizedFactorsMapEquivNormalizedFactorsMinPolyMk
      inferInstance hp0 (conductor_coprime_top halpha) halpha_int).symm
        ⟨G.map (Ideal.Quotient.mk p), hG⟩ : Ideal B) =
      Ideal.span (p.map (algebraMap A B) ∪ {G.aeval alpha}) := by
  exact
    KummerDedekind.normalizedFactorsMapEquivNormalizedFactorsMinPolyMk_symm_apply_eq_span
      inferInstance hG hp0 (conductor_coprime_top halpha) halpha_int

private noncomputable def factorResidueAlg
    {alpha : B} {p : Ideal A} [p.IsMaximal]
    {G : A[X]} {P : Ideal B} [P.IsPrime] [P.LiesOver p]
    (halpha : Algebra.adjoin A {alpha} = ⊤)
    (hGirr : Irreducible (G.map (Ideal.Quotient.mk p)))
    (hGeval : G.aeval alpha ∈ P) :
    ((A ⧸ p)[X] ⧸ Ideal.span {G.map (Ideal.Quotient.mk p)}) ≃ₐ[A ⧸ p]
      (B ⧸ P) := by
  let g : (A ⧸ p)[X] := G.map (Ideal.Quotient.mk p)
  letI : Fact (Irreducible g) := ⟨hGirr⟩
  let beta : B ⧸ P := Ideal.Quotient.mk P alpha
  have hroot : Polynomial.aeval beta g = 0 := by
    change Polynomial.aeval beta (G.map (algebraMap A (A ⧸ p))) = 0
    rw [Polynomial.aeval_map_algebraMap]
    change Polynomial.aeval ((Ideal.Quotient.mkₐ A P) alpha) G = 0
    rw [Polynomial.aeval_algHom_apply]
    exact Ideal.Quotient.eq_zero_iff_mem.mpr hGeval
  let phi : AdjoinRoot g →ₐ[A ⧸ p] (B ⧸ P) :=
    AdjoinRoot.liftAlgHom g (Algebra.ofId (A ⧸ p) (B ⧸ P)) beta
      (by simpa [Polynomial.aeval_def] using hroot)
  have hphi_surj : Function.Surjective phi := by
    intro z
    obtain ⟨b, rfl⟩ := Ideal.Quotient.mk_surjective z
    have hb : b ∈ Algebra.adjoin A {alpha} := by rw [halpha]; trivial
    obtain ⟨Q, hQ⟩ := Algebra.adjoin_mem_exists_aeval A alpha hb
    refine ⟨AdjoinRoot.mk g (Q.map (Ideal.Quotient.mk p)), ?_⟩
    rw [AdjoinRoot.liftAlgHom_mk]
    change Polynomial.aeval beta (Q.map (algebraMap A (A ⧸ p))) = _
    rw [Polynomial.aeval_map_algebraMap]
    change Polynomial.aeval ((Ideal.Quotient.mkₐ A P) alpha) Q = _
    rw [Polynomial.aeval_algHom_apply, hQ]
    rfl
  have hphi_inj : Function.Injective phi := RingHom.injective phi.toRingHom
  exact AlgEquiv.ofBijective phi ⟨hphi_inj, hphi_surj⟩

open Classical in
/-- The residue-ring clause of Theorem 3.41 in its general Dedekind-domain form:
the quotient by the prime attached to a reduced irreducible factor `G` is the polynomial
quotient by that factor over the base residue field. -/
noncomputable def factor_adjoin_top
    {alpha : B} {p : Ideal A} [p.IsMaximal] (hp0 : p ≠ ⊥)
    (halpha : Algebra.adjoin A {alpha} = ⊤) (halpha_int : IsIntegral A alpha)
    {G : A[X]}
    (hG : G.map (Ideal.Quotient.mk p) ∈
      normalizedFactors ((minpoly A alpha).map (Ideal.Quotient.mk p))) :
    ((A ⧸ p)[X] ⧸ Ideal.span {G.map (Ideal.Quotient.mk p)}) ≃+*
      (B ⧸ Ideal.span (p.map (algebraMap A B) ∪ {G.aeval alpha})) := by
  let P : Ideal B := Ideal.span (p.map (algebraMap A B) ∪ {G.aeval alpha})
  let factorEquiv :=
    KummerDedekind.normalizedFactorsMapEquivNormalizedFactorsMinPolyMk
      (x := alpha) inferInstance hp0 (conductor_coprime_top halpha) halpha_int
  have hPnormalized : P ∈ normalizedFactors (p.map (algebraMap A B)) := by
    rw [show P = (factorEquiv.symm
      ⟨G.map (Ideal.Quotient.mk p), hG⟩ : Ideal B) by
        exact (pair_adjoin_top hp0 halpha halpha_int hG).symm]
    exact (factorEquiv.symm ⟨G.map (Ideal.Quotient.mk p), hG⟩).prop
  have hPprimes : P ∈ Ideal.primesOver p B :=
    (Ideal.mem_primesOver_iff_mem_normalizedFactors B hp0).mpr hPnormalized
  letI : P.IsPrime := hPprimes.1
  letI : P.LiesOver p := hPprimes.2
  have hGirr : Irreducible (G.map (Ideal.Quotient.mk p)) :=
    irreducible_of_normalized_factor _ hG
  have hGeval : G.aeval alpha ∈ P :=
    Ideal.subset_span (Set.mem_union_right _ (Set.mem_singleton _))
  exact (factorResidueAlg halpha hGirr hGeval).toRingEquiv

open Classical in
/-- The exponent of the prime ideal `(p, G(alpha))` in `pB` is the multiplicity of the
corresponding irreducible factor of the reduced minimal polynomial. -/
theorem emulti_minpo_top
    {alpha : B} {p : Ideal A} [p.IsMaximal] (hp0 : p ≠ ⊥)
    (halpha : Algebra.adjoin A {alpha} = ⊤) (halpha_int : IsIntegral A alpha)
    {G : A[X]}
    (hG : G.map (Ideal.Quotient.mk p) ∈
      normalizedFactors ((minpoly A alpha).map (Ideal.Quotient.mk p))) :
    emultiplicity
        (Ideal.span (p.map (algebraMap A B) ∪ {G.aeval alpha}))
        (p.map (algebraMap A B)) =
      emultiplicity (G.map (Ideal.Quotient.mk p))
        ((minpoly A alpha).map (Ideal.Quotient.mk p)) := by
  rw [← pair_adjoin_top hp0 halpha halpha_int hG]
  let e := KummerDedekind.normalizedFactorsMapEquivNormalizedFactorsMinPolyMk
    (x := alpha) inferInstance hp0 (conductor_coprime_top halpha) halpha_int
  let g : {d : (A ⧸ p)[X] |
      d ∈ normalizedFactors ((minpoly A alpha).map (Ideal.Quotient.mk p))} :=
    ⟨G.map (Ideal.Quotient.mk p), hG⟩
  have h := KummerDedekind.emultiplicity_factors_map_eq_emultiplicity
    (x := alpha) inferInstance hp0 (conductor_coprime_top halpha) halpha_int
      (e.symm g).prop
  rw [e.apply_symm_apply g] at h
  exact h

open Classical in
/-- The residue-degree clause of Theorem 3.41 in its general Dedekind-domain form: the
inertia degree of `(p, G(alpha))` is the degree of the corresponding reduced irreducible
factor. -/
theorem inertia_deg_top
    {alpha : B} {p : Ideal A} [p.IsMaximal] (hp0 : p ≠ ⊥)
    (halpha : Algebra.adjoin A {alpha} = ⊤) (halpha_int : IsIntegral A alpha)
    {G : A[X]}
    (hG : G.map (Ideal.Quotient.mk p) ∈
      normalizedFactors ((minpoly A alpha).map (Ideal.Quotient.mk p))) :
    Ideal.inertiaDeg p (Ideal.span (p.map (algebraMap A B) ∪ {G.aeval alpha})) =
      (G.map (Ideal.Quotient.mk p)).natDegree := by
  let P : Ideal B := Ideal.span (p.map (algebraMap A B) ∪ {G.aeval alpha})
  let factorEquiv :=
    KummerDedekind.normalizedFactorsMapEquivNormalizedFactorsMinPolyMk
      (x := alpha) inferInstance hp0 (conductor_coprime_top halpha) halpha_int
  have hPnormalized : P ∈ normalizedFactors (p.map (algebraMap A B)) := by
    rw [show P = (factorEquiv.symm
      ⟨G.map (Ideal.Quotient.mk p), hG⟩ : Ideal B) by
        exact (pair_adjoin_top hp0 halpha halpha_int hG).symm]
    exact (factorEquiv.symm ⟨G.map (Ideal.Quotient.mk p), hG⟩).prop
  have hPprimes : P ∈ Ideal.primesOver p B :=
    (Ideal.mem_primesOver_iff_mem_normalizedFactors B hp0).mpr hPnormalized
  letI : P.IsPrime := hPprimes.1
  letI : P.LiesOver p := hPprimes.2
  have hGirr : Irreducible (G.map (Ideal.Quotient.mk p)) :=
    irreducible_of_normalized_factor _ hG
  have hGeval : G.aeval alpha ∈ P :=
    Ideal.subset_span (Set.mem_union_right _ (Set.mem_singleton _))
  let residueEquiv :
      ((A ⧸ p)[X] ⧸ Ideal.span {G.map (Ideal.Quotient.mk p)}) ≃ₐ[A ⧸ p]
        (B ⧸ P) :=
    factorResidueAlg halpha hGirr hGeval
  have hfinrank :
      Module.finrank (A ⧸ p)
          ((A ⧸ p)[X] ⧸ Ideal.span {G.map (Ideal.Quotient.mk p)}) =
        Module.finrank (A ⧸ p) (B ⧸ P) :=
    residueEquiv.toLinearEquiv.finrank_eq
  change Ideal.inertiaDeg p P = _
  rw [Ideal.inertiaDeg_algebraMap, ← hfinrank,
    finrank_quotient_span_eq_natDegree]

end GKDedeki

namespace NFCase

open NumberField RingOfIntegers

variable {K : Type*} [Field K] [NumberField K]
  {theta : 𝓞 K} {p : ℕ} [Fact p.Prime]

/-- For a rational prime not dividing the exponent of `theta`, the prime ideal corresponding to
a lifted factor `G` is exactly `(p, G(theta))`. -/
theorem kummer_dedekind_span
    (hp : ¬ p ∣ RingOfIntegers.exponent theta) {G : ℤ[X]}
    (hG : G.map (Int.castRingHom (ZMod p)) ∈ RingOfIntegers.monicFactorsMod theta p) :
    ((NumberField.Ideal.primesOverSpanEquivMonicFactorsMod hp).symm
      ⟨G.map (Int.castRingHom (ZMod p)), hG⟩ : Ideal (𝓞 K)) =
        Ideal.span {(p : 𝓞 K), G.aeval theta} := by
  exact NumberField.Ideal.primesOverSpanEquivMonicFactorsMod_symm_apply_eq_span hp hG

/-- The residue-ring isomorphism in Theorem 3.41 for number fields. -/
noncomputable def kummer_dedekind_residue
    (hp : ¬ p ∣ RingOfIntegers.exponent theta) {G : ℤ[X]}
    (hG : G.map (Int.castRingHom (ZMod p)) ∈ RingOfIntegers.monicFactorsMod theta p) :
    ((ZMod p)[X] ⧸ Ideal.span {G.map (Int.castRingHom (ZMod p))}) ≃+*
      (𝓞 K ⧸ Ideal.span {(p : 𝓞 K), G.aeval theta}) :=
  RingOfIntegers.ZModXQuotSpanEquivQuotSpanPair hp hG

/-- The residue degree clause of Theorem 3.41 for number fields: it is the degree of the
corresponding irreducible factor modulo `p`. -/
theorem kummer_dedekind_deg
    (hp : ¬ p ∣ RingOfIntegers.exponent theta) {G : ℤ[X]}
    (hG : G.map (Int.castRingHom (ZMod p)) ∈ RingOfIntegers.monicFactorsMod theta p) :
    Ideal.inertiaDeg (Ideal.span {(p : ℤ)})
      ((NumberField.Ideal.primesOverSpanEquivMonicFactorsMod hp).symm
        ⟨G.map (Int.castRingHom (ZMod p)), hG⟩ : Ideal (𝓞 K)) =
      (G.map (Int.castRingHom (ZMod p))).natDegree := by
  exact NumberField.Ideal.inertiaDeg_primesOverSpanEquivMonicFactorsMod_symm_apply hp hG

/-- The ramification exponent clause of Theorem 3.41 for number fields: it is the
multiplicity of the corresponding factor in the reduced minimal polynomial. -/
theorem kummer_dedek_multi
    (hp : ¬ p ∣ RingOfIntegers.exponent theta) {G : ℤ[X]}
    (hG : G.map (Int.castRingHom (ZMod p)) ∈ RingOfIntegers.monicFactorsMod theta p) :
    Ideal.ramificationIdx (Ideal.span {(p : ℤ)})
      ((NumberField.Ideal.primesOverSpanEquivMonicFactorsMod hp).symm
        ⟨G.map (Int.castRingHom (ZMod p)), hG⟩ : Ideal (𝓞 K)) =
      multiplicity (G.map (Int.castRingHom (ZMod p)))
        ((minpoly ℤ theta).map (Int.castRingHom (ZMod p))) := by
  exact NumberField.Ideal.ramificationIdx_primesOverSpanEquivMonicFactorsMod_symm_apply hp hG

omit [NumberField K] in
/-- Remark 3.43 in the number-field case: if the discriminant of a basis for `ℤ[theta]` is
`a` times the discriminant of an integral basis, then every rational prime not dividing `a`
also does not divide the exponent of `theta`. -/
theorem not_discriminant_ratio
    {ι : Type*} [Fintype ι] [DecidableEq ι]
    (b : Module.Basis ι ℤ (𝓞 K))
    (bTheta : Module.Basis ι ℤ (Algebra.adjoin ℤ ({theta} : Set (𝓞 K))))
    (a : ℤ)
    (hdisc : Algebra.discr ℤ (fun i => (bTheta i : 𝓞 K)) =
      a * Algebra.discr ℤ b)
    (hdisc_ne : Algebra.discr ℤ b ≠ 0)
    (hp : ¬ (p : ℤ) ∣ a) :
    ¬ p ∣ RingOfIntegers.exponent theta := by
  apply RingOfIntegers.not_dvd_exponent_iff.mpr
  rw [codisjoint_iff]
  exact conductor_discriminant_ratio
    b theta bTheta a hdisc hdisc_ne hp

end NFCase

end Submission.NumberTheory.Milne
