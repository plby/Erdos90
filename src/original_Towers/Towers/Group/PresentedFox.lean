/-- The historical and current augmentation-ideal APIs define the same ideal. -/
theorem golod_shafarevich_algebra
    (R G : Type*) [CommRing R] [Group G] :
    GShafar.augmentationIdeal R G =
      GroupAlgebra.augmentationIdeal R G := by
  unfold GShafar.augmentationIdeal GroupAlgebra.augmentationIdeal
  congr 1

/-- The submodule consisting of finite right-combinations of a finite family. -/
def rightDifferenceSpan
    (R G ι : Type*) [CommRing R] [Group G] [Fintype ι]
    (genDiff : ι → MonoidAlgebra R G) :
    Submodule R (MonoidAlgebra R G) where
  carrier := {x | ∃ coeff : ι → MonoidAlgebra R G,
    x = ∑ i, coeff i * genDiff i}
  zero_mem' := by
    refine ⟨fun _ => 0, ?_⟩
    simp
  add_mem' := by
    intro x y hx hy
    rcases hx with ⟨cx, rfl⟩
    rcases hy with ⟨cy, rfl⟩
    refine ⟨fun i => cx i + cy i, ?_⟩
    simp [add_mul, Finset.sum_add_distrib]
  smul_mem' := by
    intro c x hx
    rcases hx with ⟨cx, rfl⟩
    refine ⟨fun i => c • cx i, ?_⟩
    simp [Finset.smul_sum]

lemma right_difference_span
    (R G ι : Type*) [CommRing R] [Group G] [Fintype ι]
    (genDiff : ι → MonoidAlgebra R G)
    (a : MonoidAlgebra R G)
    {x : MonoidAlgebra R G}
    (hx : x ∈ rightDifferenceSpan R G ι genDiff) :
    a * x ∈ rightDifferenceSpan R G ι genDiff := by
  classical
  rcases hx with ⟨coeff, rfl⟩
  refine ⟨fun i => a * coeff i, ?_⟩
  rw [Finset.mul_sum]
  apply Finset.sum_congr rfl
  intro i _hi
  rw [mul_assoc]

/--
If a group element lies in the subgroup generated by `u`, then its augmentation
difference is an exact right-combination of the augmentation differences of
the elements of `u`.
-/
lemma difference_span_closure
    (R G ι : Type*) [CommRing R] [Group G] [Fintype ι]
    (u : ι → G) {g : G}
    (hg : g ∈ Subgroup.closure (Set.range u)) :
    augmentationDifference R G g ∈
      rightDifferenceSpan R G ι
        (fun i => augmentationDifference R G (u i)) := by
  classical
  let P : Subgroup G → Prop := fun _ => True
  refine Subgroup.closure_induction
    (k := Set.range u)
    (p := fun x _hx =>
      augmentationDifference R G x ∈
        rightDifferenceSpan R G ι
          (fun i => augmentationDifference R G (u i)))
    ?mem ?one ?mul ?inv hg
  · intro x hx
    rcases hx with ⟨i, rfl⟩
    refine ⟨fun j => if j = i then 1 else 0, ?_⟩
    simp
  · change augmentationDifference R G (1 : G) ∈
      rightDifferenceSpan R G ι
        (fun i => augmentationDifference R G (u i))
    simp [augmentationDifference, MonoidAlgebra.one_def]
  · intro x y _hx _hy hxP hyP
    rw [augmentation_difference_left]
    exact
      (rightDifferenceSpan R G ι
        (fun i => augmentationDifference R G (u i))).add_mem
        hxP
        (right_difference_span R G ι
          (fun i => augmentationDifference R G (u i))
          (MonoidAlgebra.single x (1 : R)) hyP)
  · intro x _hx hxP
    rw [difference_inv_neg]
    exact
      right_difference_span R G ι
        (fun i => augmentationDifference R G (u i))
        (-MonoidAlgebra.single x⁻¹ (1 : R)) hxP

/--
If `u` generates the group, then its augmentation differences generate the
whole augmentation ideal exactly by right-combinations.
-/
theorem augmentation_generated_closure
    (R G ι : Type*) [CommRing R] [Group G] [Fintype ι]
    (u : ι → G)
    (hclosure : Subgroup.closure (Set.range u) = ⊤)
    {x : MonoidAlgebra R G}
    (hx : x ∈ GShafar.augmentationIdeal R G) :
    ∃ coeff : ι → MonoidAlgebra R G,
      x = ∑ i, coeff i * augmentationDifference R G (u i) := by
  classical
  let S : Submodule R (MonoidAlgebra R G) :=
    rightDifferenceSpan R G ι
      (fun i => augmentationDifference R G (u i))
  have hall : ∀ g : G, augmentationDifference R G g ∈ S := by
    intro g
    apply difference_span_closure
    rw [hclosure]
    exact Subgroup.mem_top g
  have hspan_le :
      Submodule.span R (Set.range fun g : G => augmentationDifference R G g) ≤ S := by
    refine Submodule.span_le.mpr ?_
    intro y hy
    rcases hy with ⟨g, rfl⟩
    exact hall g
  have hxspan :
      x ∈ Submodule.span R (Set.range fun g : G => augmentationDifference R G g) := by
    have hxI :
        x ∈ (GShafar.augmentationIdeal R G).restrictScalars R := by
      simpa using hx
    simpa [restrict_scalars_differences
      (R := R) (G := G)] using hxI
  exact hspan_le hxspan

/--
The presentation generator differences exactly right-generate each positive
augmentation power from the previous one.
-/
theorem presented_generated_exact
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (n : ℕ)
    (hn : 1 ≤ n) :
    ∀ x : presentedAugmentationSubmodule (p := p) rels n,
      ∃ y : Fin d →
          presentedAugmentationSubmodule (p := p) rels (n - 1),
        (x : presentedGroupAlgebra (p := p) rels) =
          ∑ j,
            ((y j :
              presentedAugmentationSubmodule (p := p) rels (n - 1)) :
              presentedGroupAlgebra (p := p) rels) *
              presentedGeneratorDifference (p := p) rels j := by
  classical
  let A := presentedGroupAlgebra (p := p) rels
  let I : Ideal A := presentedAugmentationIdeal (p := p) rels
  haveI : I.IsTwoSided := by
    change (presentedAugmentationIdeal (p := p) rels).IsTwoSided
    dsimp [presentedAugmentationIdeal, GShafar.augmentationIdeal]
    infer_instance
  have hclosure :
      Subgroup.closure
          (Set.range
            (fun j : Fin d => PresentedGroup.of (rels := Set.range rels) j)) =
        ⊤ := by
    exact PresentedGroup.closure_range_of (Set.range rels)
  have hI_right :
      ∀ {z : A}, z ∈ I →
        ∃ coeff : Fin d → A,
          z = ∑ j, coeff j * presentedGeneratorDifference (p := p) rels j := by
    intro z hz
    simpa [A, I, presentedGeneratorDifference] using
      augmentation_generated_closure
        (R := ZMod p)
        (G := PresentedGroup (Set.range rels))
        (ι := Fin d)
        (fun j : Fin d => PresentedGroup.of (rels := Set.range rels) j)
        hclosure hz
  intro x
  have hxpow : (x : A) ∈ I ^ n := by
    exact x.2
  have hxmul : (x : A) ∈ I ^ (n - 1) * I := by
    have hdegree : (n - 1) + 1 = n := by omega
    have hpow : I ^ n = I ^ (n - 1) * I := by
      calc
        I ^ n = I ^ ((n - 1) + 1) := by rw [hdegree]
        _ = I ^ (n - 1) * I ^ 1 := by rw [Ideal.IsTwoSided.pow_add]
        _ = I ^ (n - 1) * I := by rw [Submodule.pow_one]
    simpa [hpow] using hxpow
  let P : A → Prop := fun z =>
    ∃ y : Fin d →
        presentedAugmentationSubmodule (p := p) rels (n - 1),
      z =
        ∑ j,
          ((y j :
            presentedAugmentationSubmodule (p := p) rels (n - 1)) :
            A) *
            presentedGeneratorDifference (p := p) rels j
  have hxP : P (x : A) := by
    refine Submodule.mul_induction_on hxmul ?mul_mem ?add_mem
    · intro a ha b hb
      rcases hI_right hb with ⟨coeff, hcoeff⟩
      let y : Fin d →
          presentedAugmentationSubmodule (p := p) rels (n - 1) :=
        fun j => ⟨a * coeff j, (I ^ (n - 1)).mul_mem_right (coeff j) ha⟩
      refine ⟨y, ?_⟩
      calc
        a * b = a * (∑ j, coeff j *
              presentedGeneratorDifference (p := p) rels j) := by rw [hcoeff]
        _ = ∑ j,
              ((y j :
                presentedAugmentationSubmodule (p := p) rels (n - 1)) :
                A) *
                presentedGeneratorDifference (p := p) rels j := by
              rw [Finset.mul_sum]
              apply Finset.sum_congr rfl
              intro j _hj
              dsimp [y]
              rw [mul_assoc]
    · intro u v hu hv
      rcases hu with ⟨yu, hyu⟩
      rcases hv with ⟨yv, hyv⟩
      let y : Fin d →
          presentedAugmentationSubmodule (p := p) rels (n - 1) :=
        fun j => yu j + yv j
      refine ⟨y, ?_⟩
      rw [hyu, hyv]
      dsimp [y]
      simp [add_mul, Finset.sum_add_distrib]
  simpa [P, A] using hxP

/--
Strictness of the right generator multiplication filtration: if a degree-`n`
boundary is actually in `I^(n+1)`, then it has a presentation using
coefficients from `I^n`.
-/
theorem presented_boundary_coefficients
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (n : ℕ)
    (hn : 1 ≤ n)
    (y : Fin d →
      presentedAugmentationSubmodule (p := p) rels (n - 1))
    (hboundary :
      (∑ j,
        ((y j :
          presentedAugmentationSubmodule (p := p) rels (n - 1)) :
          presentedGroupAlgebra (p := p) rels) *
          presentedGeneratorDifference (p := p) rels j) ∈
        presentedAugmentationSubmodule (p := p) rels (n + 1)) :
    ∃ z : Fin d → presentedAugmentationSubmodule (p := p) rels n,
      (∑ j,
        ((z j :
          presentedAugmentationSubmodule (p := p) rels n) :
          presentedGroupAlgebra (p := p) rels) *
          presentedGeneratorDifference (p := p) rels j) =
      ∑ j,
        ((y j :
          presentedAugmentationSubmodule (p := p) rels (n - 1)) :
          presentedGroupAlgebra (p := p) rels) *
          presentedGeneratorDifference (p := p) rels j := by
  classical
  let b : presentedAugmentationSubmodule (p := p) rels (n + 1) :=
    ⟨∑ j,
        ((y j :
          presentedAugmentationSubmodule (p := p) rels (n - 1)) :
          presentedGroupAlgebra (p := p) rels) *
          presentedGeneratorDifference (p := p) rels j,
      hboundary⟩
  rcases presented_generated_exact
      (p := p) rels (n + 1) (by omega) b with
    ⟨z, hz⟩
  exact ⟨z, hz.symm⟩

/-- The presented group algebra truncated modulo the `n`th augmentation power. -/
noncomputable abbrev presentedAugmentationTruncation
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d)) (n : ℕ) : Type :=
  presentedGroupAlgebra (p := p) rels ⧸
    (presentedAugmentationIdeal (p := p) rels) ^ n

/--
Right multiplication by an augmentation-ideal element descends from the
`n`th presented truncation to the `(n+1)`st.
-/
noncomputable def presentedTruncationIdeal
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (n : ℕ)
    (a : presentedGroupAlgebra (p := p) rels)
    (ha : a ∈ presentedAugmentationIdeal (p := p) rels) :
    presentedAugmentationTruncation (p := p) rels n →ₗ[ZMod p]
      presentedAugmentationTruncation (p := p) rels (n + 1) := by
  let A := presentedGroupAlgebra (p := p) rels
  let I : Ideal A := presentedAugmentationIdeal (p := p) rels
  haveI : I.IsTwoSided := by
    change (presentedAugmentationIdeal (p := p) rels).IsTwoSided
    dsimp [presentedAugmentationIdeal, GShafar.augmentationIdeal]
    infer_instance
  let ra : A →ₗ[ZMod p] A :=
    { toFun := fun x => x * a
      map_add' := by
        intro x y
        exact add_mul x y a
      map_smul' := by
        intro c x
        simp }
  let q : A →ₗ[ZMod p] A ⧸ I ^ (n + 1) :=
    (Ideal.Quotient.mkₐ (ZMod p) (I ^ (n + 1))).toLinearMap
  let f : A →ₗ[ZMod p] A ⧸ I ^ (n + 1) := q.comp ra
  let K : Submodule (ZMod p) A := Submodule.restrictScalars (ZMod p) (I ^ n)
  have hf : K ≤ LinearMap.ker f := by
    intro x hx
    have hx' : x ∈ I ^ n := by
      exact (Submodule.restrictScalars_mem (ZMod p) (I ^ n) x).mp hx
    rw [LinearMap.mem_ker]
    change Ideal.Quotient.mk _ (x * a) = 0
    exact Ideal.Quotient.eq_zero_iff_mem.2 <| by
      have hmul : x * a ∈ I ^ n * I ^ 1 :=
        Ideal.mul_mem_mul hx' (by simpa [Submodule.pow_one] using ha)
      rw [Ideal.IsTwoSided.pow_add (I := I) (m := n) (n := 1)]
      simpa using hmul
  let fq := K.liftQ f hf
  simpa [presentedAugmentationTruncation, A, I, K, f, q, ra] using fq

@[simp]
theorem presented_truncation_mk
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (n : ℕ)
    (a : presentedGroupAlgebra (p := p) rels)
    (ha : a ∈ presentedAugmentationIdeal (p := p) rels)
    (x : presentedGroupAlgebra (p := p) rels) :
    presentedTruncationIdeal
        (p := p) rels n a ha
        (Ideal.Quotient.mk
          ((presentedAugmentationIdeal (p := p) rels) ^ n) x) =
      Ideal.Quotient.mk
        ((presentedAugmentationIdeal (p := p) rels) ^ (n + 1)) (x * a) := by
  rfl

/--
The next presented truncation is generated by its scalar class and by right
multiples of the presentation-generator differences.
-/
noncomputable def presentedScalarGenerator
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (n : ℕ) :
    (ZMod p ×
      (Fin d → presentedAugmentationTruncation (p := p) rels n)) →ₗ[ZMod p]
      presentedAugmentationTruncation (p := p) rels (n + 1) := by
  let A := presentedGroupAlgebra (p := p) rels
  let I : Ideal A := presentedAugmentationIdeal (p := p) rels
  let q : A →ₗ[ZMod p] A ⧸ I ^ (n + 1) :=
    (Ideal.Quotient.mkₐ (ZMod p) (I ^ (n + 1))).toLinearMap
  let scalarToA : ZMod p →ₗ[ZMod p] A :=
    { toFun := fun c => c • (1 : A)
      map_add' := by
        intro c e
        simp [add_smul]
      map_smul' := by
        intro c e
        simp [smul_smul] }
  let scalarToTruncation : ZMod p →ₗ[ZMod p]
      presentedAugmentationTruncation (p := p) rels (n + 1) :=
    q.comp scalarToA
  let generatorToTruncation :
      (Fin d → presentedAugmentationTruncation (p := p) rels n) →ₗ[ZMod p]
        presentedAugmentationTruncation (p := p) rels (n + 1) :=
    LinearMap.lsum (ZMod p)
      (fun _ : Fin d => presentedAugmentationTruncation (p := p) rels n)
      (ZMod p)
      (fun j =>
        presentedTruncationIdeal
          (p := p) rels n
          (presentedGeneratorDifference (p := p) rels j)
          (presented_difference_ideal (p := p) rels j))
  exact
    scalarToTruncation.comp
        (LinearMap.fst (ZMod p) (ZMod p)
          (Fin d → presentedAugmentationTruncation (p := p) rels n)) +
      generatorToTruncation.comp
        (LinearMap.snd (ZMod p) (ZMod p)
          (Fin d → presentedAugmentationTruncation (p := p) rels n))

@[simp]
theorem presented_scalar_mk
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (n : ℕ)
    (c : ZMod p)
    (y : Fin d → presentedGroupAlgebra (p := p) rels) :
    presentedScalarGenerator (p := p) rels n
        (c, fun j =>
          Ideal.Quotient.mk
            ((presentedAugmentationIdeal (p := p) rels) ^ n) (y j)) =
      Ideal.Quotient.mk
        ((presentedAugmentationIdeal (p := p) rels) ^ (n + 1))
        (c • (1 : presentedGroupAlgebra (p := p) rels) +
          ∑ j, y j * presentedGeneratorDifference (p := p) rels j) := by
  classical
  simp [presentedScalarGenerator,
    LinearMap.lsum_apply, map_add, map_sum]

/-- The scalar-plus-generators map onto the next presented truncation is surjective. -/
theorem presented_scalar_surjective
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (n : ℕ) :
    Function.Surjective
      (presentedScalarGenerator (p := p) rels n) := by
  classical
  intro z
  rcases Ideal.Quotient.mk_surjective z with ⟨x, rfl⟩
  let A := presentedGroupAlgebra (p := p) rels
  let I : Ideal A := presentedAugmentationIdeal (p := p) rels
  let c : ZMod p := GShafar.augmentationHom (ZMod p)
    (PresentedGroup (Set.range rels)) x
  let y : A := x - c • (1 : A)
  have hyI : y ∈ I := by
    change y ∈ RingHom.ker
      (GShafar.augmentationHom (ZMod p)
        (PresentedGroup (Set.range rels))).toRingHom
    rw [RingHom.mem_ker]
    simp [y, c]
  let y1 : presentedAugmentationSubmodule (p := p) rels 1 :=
    ⟨y, by simpa [I, presentedAugmentationSubmodule, Submodule.pow_one] using hyI⟩
  rcases presented_generated_exact
      (p := p) rels 1 (by omega) y1 with
    ⟨coeff, hcoeff⟩
  refine
    ⟨(c, fun j =>
      Ideal.Quotient.mk
        ((presentedAugmentationIdeal (p := p) rels) ^ n)
        ((coeff j :
          presentedAugmentationSubmodule (p := p) rels 0) : A)), ?_⟩
  rw [presented_scalar_mk]
  congr 1
  rw [← hcoeff]
  dsimp [y1]
  simp [y, c, sub_eq_add_neg, add_left_comm]

/-- Every truncation of a finitely generated presented group algebra is finite-dimensional. -/
theorem module_presented_truncation
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (n : ℕ) :
    Module.Finite (ZMod p)
      (presentedAugmentationTruncation (p := p) rels n) := by
  induction n with
  | zero =>
      let f :
          (Fin 0 → ZMod p) →ₗ[ZMod p]
            presentedAugmentationTruncation (p := p) rels 0 := 0
      apply Module.Finite.of_surjective f
      intro z
      refine ⟨0, ?_⟩
      refine Submodule.Quotient.induction_on
        (p := (presentedAugmentationIdeal (p := p) rels) ^ 0) z ?_
      intro x
      change 0 = Ideal.Quotient.mk
        ((presentedAugmentationIdeal (p := p) rels) ^ 0) x
      symm
      apply Ideal.Quotient.eq_zero_iff_mem.2
      rw [Submodule.pow_zero, Ideal.one_eq_top]
      exact Submodule.mem_top
  | succ n ih =>
      letI := ih
      exact Module.Finite.of_surjective
        (presentedScalarGenerator (p := p) rels n)
        (presented_scalar_surjective
          (p := p) rels n)

/-- The current augmentation API's truncations are finite for a finite presentation. -/
theorem module_truncation_presented
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (n : ℕ) :
    Module.Finite (ZMod p)
      (GroupAlgebra.augmentationTruncation
        (ZMod p) (PresentedGroup (Set.range rels)) n) := by
  simpa only [GroupAlgebra.augmentationTruncation,
    GroupAlgebra.augmentationPower, presentedAugmentationTruncation,
    ← golod_shafarevich_algebra] using
      module_presented_truncation (p := p) rels n

/-- Cumulative augmentation-layer ranks are the presented truncation dimensions. -/
theorem rank_presented_truncation
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (n : ℕ) :
    (∑ k ∈ Finset.range n,
      GroupAlgebra.augmentationLayerRank
        (ZMod p) (PresentedGroup (Set.range rels)) k) =
      Module.finrank (ZMod p)
        (presentedAugmentationTruncation (p := p) rels n) := by
  rw [GroupAlgebra.truncation_finrank_module
    (K := ZMod p) (G := PresentedGroup (Set.range rels))
    (fun m =>
      module_truncation_presented
        (p := p) rels m) n]
  rfl

/--
The free-to-presented group-algebra map is filtered-surjective for augmentation
powers: every element of the presented `I^n` has a lift in the free `I^n`.
-/
theorem presented_submodule_lift
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (n : ℕ)
    (x : presentedAugmentationSubmodule (p := p) rels n) :
    ∃ y :
      ((GShafar.augmentationIdeal
        (R := ZMod p)
        (G := FreeGroup (Fin d))) ^ n).restrictScalars (ZMod p),
      GShafar.presentedAlgebra
          (R := ZMod p) (Set.range rels)
          (y : MonoidAlgebra (ZMod p) (FreeGroup (Fin d))) =
        (x : presentedGroupAlgebra (p := p) rels) := by
  classical
  let F := FreeGroup (Fin d)
  let AF := MonoidAlgebra (ZMod p) F
  let A := presentedGroupAlgebra (p := p) rels
  let IF : Ideal AF :=
    GShafar.augmentationIdeal (R := ZMod p) (G := F)
  let I : Ideal A := presentedAugmentationIdeal (p := p) rels
  let qmap : AF →+* A :=
    GShafar.presentedAlgebra
      (R := ZMod p) (Set.range rels)
  have hsurj : Function.Surjective qmap := by
    simpa [qmap, F, A] using
      GShafar.presented_algebra_surjective
        (R := ZMod p) (Set.range rels)
  have haug_q :
      ∀ z : AF,
        GShafar.augmentationHom
            (ZMod p) (PresentedGroup (Set.range rels)) (qmap z) =
          GShafar.augmentationHom (ZMod p) F z := by
    intro z
    simpa [qmap, F] using
      congrArg (fun f => f z)
        (GShafar.comp_presented_algebra
          (R := ZMod p) (α := Fin d) (rels := Set.range rels))
  induction n with
  | zero =>
      rcases hsurj (x : A) with ⟨y, hy⟩
      refine ⟨⟨y, ?_⟩, hy⟩
      simp [Submodule.pow_zero]
  | succ n ih =>
      have hxpow : (x : A) ∈ I ^ (n + 1) := by
        simp [I, presentedAugmentationSubmodule]
      have hxmul : (x : A) ∈ I ^ n * I := by
        simp
      let P : A → Prop := fun z =>
        ∃ y : (IF ^ (n + 1)).restrictScalars (ZMod p), qmap (y : AF) = z
      have hxP : P (x : A) := by
        refine Submodule.mul_induction_on hxmul ?mul_mem ?add_mem
        · intro a ha b hb
          rcases ih ⟨a, by
              simpa [I, presentedAugmentationSubmodule] using ha⟩ with
            ⟨ya, hya⟩
          rcases hsurj b with ⟨yb, hyb⟩
          have hb_aug :
              GShafar.augmentationHom
                  (ZMod p) (PresentedGroup (Set.range rels)) b = 0 := by
            simpa [I, presentedAugmentationIdeal,
              GShafar.augmentationIdeal] using hb
          have hyb_mem : yb ∈ IF := by
            have hyb_aug :
                GShafar.augmentationHom (ZMod p) F yb = 0 := by
              rw [← haug_q yb, hyb, hb_aug]
            simpa [IF, GShafar.augmentationIdeal] using hyb_aug
          refine ⟨⟨(ya : AF) * yb, ?_⟩, ?_⟩
          · have hprod : (ya : AF) * yb ∈ IF ^ n * IF :=
              Ideal.mul_mem_mul ya.2 hyb_mem
            simpa [Submodule.pow_succ] using hprod
          · rw [map_mul, hya, hyb]
        · intro a b ha hb
          rcases ha with ⟨ya, hya⟩
          rcases hb with ⟨yb, hyb⟩
          refine ⟨ya + yb, ?_⟩
          change qmap ((ya : AF) + (yb : AF)) = a + b
          rw [map_add, hya, hyb]
      simpa [P] using hxP

/-- The Fox derivative extended linearly to the whole free group algebra. -/
noncomputable def freeFoxDerivative
    (R ι : Type*) [CommRing R] [Fintype ι] [DecidableEq ι]
    (j : ι) :
    MonoidAlgebra R (FreeGroup ι) →ₗ[R]
      MonoidAlgebra R (FreeGroup ι) :=
  Finsupp.linearCombination R
    (fun g : FreeGroup ι => groupFoxDerivative R j g)

@[simp]
theorem free_derivative_single
    (R ι : Type*) [CommRing R] [Fintype ι] [DecidableEq ι]
    (j : ι) (g : FreeGroup ι) (c : R) :
    freeFoxDerivative R ι j (MonoidAlgebra.single g c) =
      c • groupFoxDerivative R j g := by
  exact
    Finsupp.linearCombination_single
      (R := R)
      (v := fun g : FreeGroup ι => groupFoxDerivative R j g)
      c g

theorem algebra_fox_derivative
    (R ι : Type*) [CommRing R] [Fintype ι] [DecidableEq ι]
    (j : ι)
    (x y : MonoidAlgebra R (FreeGroup ι)) :
    freeFoxDerivative R ι j (x * y) =
      (GShafar.augmentationHom R (FreeGroup ι) y) •
        freeFoxDerivative R ι j x +
      x * freeFoxDerivative R ι j y := by
  classical
  refine MonoidAlgebra.induction_on
    (p := fun x =>
      freeFoxDerivative R ι j (x * y) =
        (GShafar.augmentationHom R (FreeGroup ι) y) •
          freeFoxDerivative R ι j x +
        x * freeFoxDerivative R ι j y)
    x ?hof ?hadd ?hsmul
  · intro g
    refine MonoidAlgebra.induction_on
      (p := fun y =>
        freeFoxDerivative R ι j
            (MonoidAlgebra.of R (FreeGroup ι) g * y) =
          (GShafar.augmentationHom R (FreeGroup ι) y) •
            freeFoxDerivative R ι j
              (MonoidAlgebra.of R (FreeGroup ι) g) +
          MonoidAlgebra.of R (FreeGroup ι) g *
            freeFoxDerivative R ι j y)
      y ?yof ?yadd ?ysmul
    · intro h
      simp [MonoidAlgebra.of_apply, free_derivative_single,
        free_derivative_mul, GShafar.augmentationHom,
        GShafar.augmentationCharacter]
    · intro u v hu hv
      have hu' :
          freeFoxDerivative R ι j
              (MonoidAlgebra.single g (1 : R) * u) =
            (GShafar.augmentationHom R (FreeGroup ι) u) •
              groupFoxDerivative R j g +
            MonoidAlgebra.single g (1 : R) *
              freeFoxDerivative R ι j u := by
        simpa [MonoidAlgebra.of_apply, free_derivative_single]
          using hu
      have hv' :
          freeFoxDerivative R ι j
              (MonoidAlgebra.single g (1 : R) * v) =
            (GShafar.augmentationHom R (FreeGroup ι) v) •
              groupFoxDerivative R j g +
            MonoidAlgebra.single g (1 : R) *
              freeFoxDerivative R ι j v := by
        simpa [MonoidAlgebra.of_apply, free_derivative_single]
          using hv
      simp [mul_add, map_add, hu', hv', add_smul, add_assoc,         add_left_comm]
    · intro c u hu
      have hmul_smul :
          MonoidAlgebra.of R (FreeGroup ι) g * (c • u) =
            c • (MonoidAlgebra.of R (FreeGroup ι) g * u) := by
        simp
      rw [hmul_smul, map_smul, hu]
      simp [map_smul, smul_add, smul_smul]
  · intro u v hu hv
    simp [add_mul, map_add, hu, hv, smul_add, add_mul, add_assoc,
      add_comm, add_left_comm]
  · intro c u hu
    have hmul_smul :
        (c • u) * y = c • (u * y) := by
      simp
    rw [hmul_smul, map_smul, hu]
    simp [map_smul, smul_add, smul_smul, mul_comm]

/--
The Fox derivative of a free-group-algebra element lowers augmentation degree by
one.  This is the filtered form of the Leibniz rule: on a product
`a * b ∈ I^n * I`, the augmentation of `b` vanishes and only the term
`a * D b` remains.
-/
theorem fox_derivative_pred
    (R ι : Type*) [CommRing R] [Fintype ι] [DecidableEq ι]
    (j : ι)
    {n : ℕ}
    {x : MonoidAlgebra R (FreeGroup ι)}
    (hx :
      x ∈ (GShafar.augmentationIdeal
        (R := R) (G := FreeGroup ι)) ^ n) :
    freeFoxDerivative R ι j x ∈
      (GShafar.augmentationIdeal
        (R := R) (G := FreeGroup ι)) ^ (n - 1) := by
  classical
  let F := FreeGroup ι
  let AF := MonoidAlgebra R F
  let I : Ideal AF := GShafar.augmentationIdeal (R := R) (G := F)
  cases n with
  | zero =>
      change freeFoxDerivative R ι j x ∈ I ^ (0 - 1)
      simp [I, F, Submodule.pow_zero]
  | succ n =>
      have hxmul : x ∈ I ^ n * I := by
        simpa [I, F, Submodule.pow_succ] using hx
      let P : AF → Prop := fun z =>
        freeFoxDerivative R ι j z ∈ I ^ n
      have hxP : P x := by
        refine Submodule.mul_induction_on hxmul ?mul_mem ?add_mem
        · intro a ha b hb
          have hbaug :
              GShafar.augmentationHom R F b = 0 := by
            simpa [I, GShafar.augmentationIdeal] using hb
          have hprod :
              a * freeFoxDerivative R ι j b ∈ I ^ n :=
            (I ^ n).mul_mem_right
              (freeFoxDerivative R ι j b) ha
          dsimp [P]
          rw [algebra_fox_derivative]
          rw [hbaug, zero_smul, zero_add]
          exact hprod
        · intro a b ha hb
          dsimp [P] at ha hb ⊢
          rw [map_add]
          exact (I ^ n).add_mem ha hb
      change freeFoxDerivative R ι j x ∈ I ^ ((n + 1) - 1)
      simpa [I, F] using hxP

@[simp]
theorem derivative_augmentation_difference
    (R ι : Type*) [CommRing R] [Fintype ι] [DecidableEq ι]
    (j : ι)
    (g : FreeGroup ι) :
    freeFoxDerivative R ι j
        (augmentationDifference R (FreeGroup ι) g) =
      groupFoxDerivative R j g := by
  simp [augmentationDifference, MonoidAlgebra.one_def,
    free_derivative_single, group_fox_derivative]

/-- Fox derivatives lower augmentation-defined Zassenhaus depth directly.
This avoids passing through the closure-formula presentation of the
Zassenhaus filtration. -/
theorem presented_fox_least
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    {depth : Fin r → ℕ}
    (hdepth :
      ∀ i,
        (MonoidAlgebra.of (ZMod p) (FreeGroup (Fin d)) (rels i) - 1 :
          MonoidAlgebra (ZMod p) (FreeGroup (Fin d))) ∈
            (GroupAlgebra.augmentationIdeal
              (ZMod p) (FreeGroup (Fin d))) ^ depth i)
    (i : Fin r)
    (j : Fin d) :
    presentedFoxCoefficient (p := p) rels i j ∈
      (presentedAugmentationIdeal (p := p) rels) ^ (depth i - 1) := by
  let F := FreeGroup (Fin d)
  have hdiff :
      augmentationDifference (ZMod p) F (rels i) ∈
        (GShafar.augmentationIdeal (ZMod p) F) ^ depth i := by
    have hi := hdepth i
    simpa only [F, augmentationDifference, MonoidAlgebra.of_apply,
      ← golod_shafarevich_algebra] using hi
  have hfree :
      groupFoxDerivative (ZMod p) j (rels i) ∈
        (GShafar.augmentationIdeal (ZMod p) F) ^ (depth i - 1) := by
    simpa [F] using
      fox_derivative_pred
        (ZMod p) (Fin d) j hdiff
  have hmap :
      GShafar.presentedAlgebra (R := ZMod p) (Set.range rels)
          (groupFoxDerivative (ZMod p) j (rels i)) ∈
        (GShafar.augmentationIdeal (ZMod p)
          (PresentedGroup (Set.range rels))) ^ (depth i - 1) :=
    GShafar.presented_algebra_pow
      (R := ZMod p)
      (α := Fin d)
      (rels := Set.range rels)
      hfree
  simpa [presentedFoxCoefficient, presentedAugmentationIdeal, F] using hmap

@[simp]
theorem free_group_derivative
    (R ι : Type*) [CommRing R] [DecidableEq ι]
    (j i : ι) :
    groupFoxDerivative R j (FreeGroup.of i) =
      if i = j then (1 : MonoidAlgebra R (FreeGroup ι)) else 0 := by
  by_cases h : i = j
  · subst j
    simp [groupFoxDerivative, foxDerivativeList,
      foxLetterDerivative]
  · simp [groupFoxDerivative, foxDerivativeList,
      foxLetterDerivative, h]

@[simp]
theorem fox_derivative_one
    (R ι : Type*) [CommRing R] [Fintype ι] [DecidableEq ι]
    (j : ι) :
    freeFoxDerivative R ι j
        (1 : MonoidAlgebra R (FreeGroup ι)) = 0 := by
  simp [MonoidAlgebra.one_def, free_derivative_single,
    group_fox_derivative]

@[simp]
theorem free_fox_difference
    (R ι : Type*) [CommRing R] [Fintype ι] [DecidableEq ι]
    (j i : ι) :
    freeFoxDerivative R ι j
        (augmentationDifference R (FreeGroup ι) (FreeGroup.of i)) =
      if i = j then (1 : MonoidAlgebra R (FreeGroup ι)) else 0 := by
  by_cases h : i = j
  · subst j
    simp [augmentationDifference, free_derivative_single]
  · simp [augmentationDifference, free_derivative_single, h]

/--
Fox differentiation reads back the coefficients of a free right boundary
exactly.
-/
@[simp]
theorem fox_derivative_difference
    (R ι : Type*) [CommRing R] [Fintype ι] [DecidableEq ι]
    (coeff : ι → MonoidAlgebra R (FreeGroup ι))
    (j : ι) :
    freeFoxDerivative R ι j
        (∑ i, coeff i *
          augmentationDifference R (FreeGroup ι) (FreeGroup.of i)) =
      coeff j := by
  classical
  rw [map_sum, Finset.sum_eq_single j]
  · simp [algebra_fox_derivative,
            augmentationDifference, GShafar.augmentationHom,
      GShafar.augmentationCharacter]
  · intro i _hi hij
    simp [algebra_fox_derivative,
            augmentationDifference, GShafar.augmentationHom,
      GShafar.augmentationCharacter, hij]
  · intro hj
    exact (hj (Finset.mem_univ j)).elim

/-- The free generator differences have unique right-boundary coefficients. -/
theorem free_difference_zero
    (R ι : Type*) [CommRing R] [Fintype ι]
    (coeff : ι → MonoidAlgebra R (FreeGroup ι)) :
    (∑ i, coeff i *
        augmentationDifference R (FreeGroup ι) (FreeGroup.of i)) = 0 ↔
      coeff = 0 := by
  classical
  constructor
  · intro h
    funext j
    have hD :=
      congrArg (freeFoxDerivative R ι j) h
    rw [fox_derivative_difference] at hD
    simpa using hD
  · intro h
    rw [h]
    simp

/--
Every element of the free augmentation ideal is its Fox-derivative right
boundary.
-/
theorem free_derivative_difference
    (R ι : Type*) [CommRing R] [Fintype ι] [DecidableEq ι]
    {x : MonoidAlgebra R (FreeGroup ι)}
    (hx : x ∈ GShafar.augmentationIdeal R (FreeGroup ι)) :
    x = ∑ j, freeFoxDerivative R ι j x *
      augmentationDifference R (FreeGroup ι) (FreeGroup.of j) := by
  classical
  rcases augmentation_generated_closure
      R (FreeGroup ι) ι FreeGroup.of (FreeGroup.closure_range_of ι) hx with
    ⟨coeff, hcoeff⟩
  calc
    x = ∑ j, coeff j *
        augmentationDifference R (FreeGroup ι) (FreeGroup.of j) := hcoeff
    _ = ∑ j, freeFoxDerivative R ι j x *
        augmentationDifference R (FreeGroup ι) (FreeGroup.of j) := by
      apply Finset.sum_congr rfl
      intro j _hj
      have hread :=
        fox_derivative_difference
          R ι coeff j
      rw [← hcoeff] at hread
      rw [hread]

/--
Inside the free augmentation ideal, membership in the next power is equivalent
to all Fox derivatives lying in the preceding power.
-/
theorem succ_fox_derivative
    (R ι : Type*) [CommRing R] [Fintype ι] [DecidableEq ι]
    {n : ℕ}
    {x : MonoidAlgebra R (FreeGroup ι)}
    (hx : x ∈ GShafar.augmentationIdeal R (FreeGroup ι)) :
    x ∈ (GShafar.augmentationIdeal R (FreeGroup ι)) ^ (n + 1) ↔
      ∀ j,
        freeFoxDerivative R ι j x ∈
          (GShafar.augmentationIdeal R (FreeGroup ι)) ^ n := by
  classical
  let I : Ideal (MonoidAlgebra R (FreeGroup ι)) :=
    GShafar.augmentationIdeal R (FreeGroup ι)
  haveI : I.IsTwoSided := by
    dsimp [I, GShafar.augmentationIdeal]
    infer_instance
  constructor
  · intro hxpow j
    have hpred :=
      fox_derivative_pred
        R ι j hxpow
    simpa [I] using hpred
  · intro hD
    rw [free_derivative_difference
      R ι hx]
    apply Ideal.sum_mem
    intro j _hj
    have hdiff :
        augmentationDifference R (FreeGroup ι) (FreeGroup.of j) ∈ I :=
      augmentation_difference_ideal
        R (FreeGroup ι) (FreeGroup.of j)
    have hmul :
        freeFoxDerivative R ι j x *
            augmentationDifference R (FreeGroup ι) (FreeGroup.of j) ∈
          I ^ n * I ^ 1 :=
      Ideal.mul_mem_mul (hD j) (by simpa [Submodule.pow_one] using hdiff)
    change
      freeFoxDerivative R ι j x *
          augmentationDifference R (FreeGroup ι) (FreeGroup.of j) ∈
        I ^ (n + 1)
    rw [Ideal.IsTwoSided.pow_add (I := I) (m := n) (n := 1)]
    exact hmul

/-- Ungraded right boundary map for the presentation generators. -/
noncomputable def presentedGeneratorBoundary
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d)) :
    (Fin d → presentedGroupAlgebra (p := p) rels) →ₗ[ZMod p]
      presentedGroupAlgebra (p := p) rels where
  toFun y :=
    ∑ j, y j * presentedGeneratorDifference (p := p) rels j
  map_add' y z := by
    simp [Pi.add_apply, add_mul, Finset.sum_add_distrib]
  map_smul' c y := by
    simp [Pi.smul_apply, Finset.smul_sum]

/-- The ungraded relation module of the presentation. -/
abbrev presentedRelationModule
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d)) : Type :=
  LinearMap.ker (presentedGeneratorBoundary (p := p) rels)

/--
The augmentation filtration on the relation module.

The `n`th filtered piece consists of exact generator-boundary relations whose
`j`th coefficient lies in `I^n` of the presented group algebra.
-/
def presentedModuleFiltration
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d)) (n : ℕ) :
    Submodule (ZMod p) (presentedRelationModule (p := p) rels) where
  carrier :=
    {x | ∀ j,
      ((x : Fin d → presentedGroupAlgebra (p := p) rels) j) ∈
        presentedAugmentationSubmodule (p := p) rels n}
  zero_mem' := by
    intro j
    exact (presentedAugmentationSubmodule (p := p) rels n).zero_mem
  add_mem' := by
    intro x y hx hy j
    exact
      (presentedAugmentationSubmodule (p := p) rels n).add_mem
        (hx j) (hy j)
  smul_mem' := by
    intro c x hx j
    exact
      (presentedAugmentationSubmodule (p := p) rels n).smul_mem
        c (hx j)

@[simp]
theorem presented_relation_filtration
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d)) (n : ℕ)
    (x : presentedRelationModule (p := p) rels) :
    x ∈ presentedModuleFiltration (p := p) rels n ↔
      ∀ j,
        ((x : Fin d → presentedGroupAlgebra (p := p) rels) j) ∈
          presentedAugmentationSubmodule (p := p) rels n := by
  rfl

/-- The relation-module filtration is descending. -/
theorem presented_filtration_antitone
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    {m n : ℕ}
    (hmn : m ≤ n) :
    presentedModuleFiltration (p := p) rels n ≤
      presentedModuleFiltration (p := p) rels m := by
  intro x hx
  rw [presented_relation_filtration] at hx ⊢
  intro j
  let A := presentedGroupAlgebra (p := p) rels
  let I : Ideal A := presentedAugmentationIdeal (p := p) rels
  have hxpow :
      ((x : Fin d → A) j) ∈ I ^ n := by
    simpa [I, presentedAugmentationSubmodule] using hx j
  have hle : I ^ n ≤ I ^ m := Ideal.pow_le_pow_right hmn
  exact by
    simpa [I, presentedAugmentationSubmodule] using hle hxpow

/-- Kernel for the `n`th associated-graded relation-module layer. -/
abbrev presentedModuleKernel
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d)) (n : ℕ) :
    Submodule (ZMod p)
      (presentedModuleFiltration (p := p) rels n) :=
  (presentedModuleFiltration (p := p) rels (n + 1)).comap
    (Submodule.subtype
      (presentedModuleFiltration (p := p) rels n))

/-- The `n`th associated-graded layer of the filtered relation module. -/
noncomputable abbrev presentedModuleLayer
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d)) (n : ℕ) : Type :=
  (↥(presentedModuleFiltration (p := p) rels n)) ⧸
    presentedModuleKernel (p := p) rels n

/-- Ungraded Fox map attached to the defining relators. -/
noncomputable def presentedRelatorFox
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d)) :
    (Fin r → presentedGroupAlgebra (p := p) rels) →ₗ[ZMod p]
      (Fin d → presentedGroupAlgebra (p := p) rels) where
  toFun c := fun j =>
    ∑ i, c i * presentedFoxCoefficient (p := p) rels i j
  map_add' c e := by
    ext j
    simp [Pi.add_apply, add_mul, Finset.sum_add_distrib]
  map_smul' a c := by
    ext j
    simp [Pi.smul_apply, Finset.smul_sum]

/-- The relator Fox map gives genuine ungraded syzygies. -/
theorem presented_fox_boundary
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d)) :
    LinearMap.range (presentedRelatorFox (p := p) rels) ≤
      LinearMap.ker (presentedGeneratorBoundary (p := p) rels) := by
  classical
  intro y hy
  rcases hy with ⟨c, rfl⟩
  rw [LinearMap.mem_ker]
  dsimp [presentedGeneratorBoundary, presentedRelatorFox]
  calc
    ∑ j,
        (∑ i, c i * presentedFoxCoefficient (p := p) rels i j) *
          presentedGeneratorDifference (p := p) rels j
        =
        ∑ i,
          ∑ j,
            (c i * presentedFoxCoefficient (p := p) rels i j) *
              presentedGeneratorDifference (p := p) rels j := by
          rw [Finset.sum_comm]
          apply Finset.sum_congr rfl
          intro i _hi
          rw [Finset.sum_mul]
    _ = 0 := by
          apply Finset.sum_eq_zero
          intro i _hi
          exact presented_fox_syzygy
            (p := p) rels i (c i)

/-- The pushed-forward Fox derivative tuple of an arbitrary free-group word. -/
noncomputable def presentedDerivativeTuple
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (g : FreeGroup (Fin d)) :
    Fin d → presentedGroupAlgebra (p := p) rels :=
  fun j =>
    GShafar.presentedAlgebra
      (R := ZMod p) (Set.range rels)
      (groupFoxDerivative (ZMod p) j g)

@[simp]
theorem fox_derivative_tuple
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d)) :
    presentedDerivativeTuple (p := p) rels (1 : FreeGroup (Fin d)) = 0 := by
  funext j
  change
    GShafar.presentedAlgebra
        (R := ZMod p) (Set.range rels)
        (groupFoxDerivative (ZMod p) j (1 : FreeGroup (Fin d))) = 0
  rw [group_fox_derivative, map_zero]

theorem presented_derivative_tuple
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (x y : FreeGroup (Fin d)) :
    presentedDerivativeTuple (p := p) rels (x * y) =
      presentedDerivativeTuple (p := p) rels x +
        fun j =>
          MonoidAlgebra.single
              (PresentedGroup.mk (Set.range rels) x) (1 : ZMod p) *
            presentedDerivativeTuple (p := p) rels y j := by
  funext j
  change
    GShafar.presentedAlgebra
        (R := ZMod p) (Set.range rels)
        (groupFoxDerivative (ZMod p) j (x * y)) =
      GShafar.presentedAlgebra
          (R := ZMod p) (Set.range rels)
          (groupFoxDerivative (ZMod p) j x) +
        MonoidAlgebra.single
            (PresentedGroup.mk (Set.range rels) x) (1 : ZMod p) *
          GShafar.presentedAlgebra
            (R := ZMod p) (Set.range rels)
            (groupFoxDerivative (ZMod p) j y)
  rw [free_derivative_mul, map_add, map_mul]
  simp [GShafar.presentedAlgebra]

theorem presented_derivative_inv
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (x : FreeGroup (Fin d)) :
    presentedDerivativeTuple (p := p) rels x⁻¹ =
      fun j =>
        -MonoidAlgebra.single
            (PresentedGroup.mk (Set.range rels) x⁻¹) (1 : ZMod p) *
          presentedDerivativeTuple (p := p) rels x j := by
  funext j
  change
    GShafar.presentedAlgebra
        (R := ZMod p) (Set.range rels)
        (groupFoxDerivative (ZMod p) j x⁻¹) =
      -MonoidAlgebra.single
          (PresentedGroup.mk (Set.range rels) x⁻¹) (1 : ZMod p) *
        GShafar.presentedAlgebra
          (R := ZMod p) (Set.range rels)
          (groupFoxDerivative (ZMod p) j x)
  rw [free_derivative_inv, map_mul, map_neg]
  simp [GShafar.presentedAlgebra]

/-- The ungraded relator-Fox image is stable under left multiplication in the
presented group algebra. -/
theorem presented_fox_range
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (a : presentedGroupAlgebra (p := p) rels)
    {y : Fin d → presentedGroupAlgebra (p := p) rels}
    (hy : y ∈ LinearMap.range (presentedRelatorFox (p := p) rels)) :
    (fun j => a * y j) ∈
      LinearMap.range (presentedRelatorFox (p := p) rels) := by
  classical
  rcases hy with ⟨c, rfl⟩
  refine ⟨fun i => a * c i, ?_⟩
  ext j
  simp [presentedRelatorFox, Finset.mul_sum, mul_assoc]

theorem presented_fox_derivative
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    {x : MonoidAlgebra (ZMod p) (FreeGroup (Fin d))}
    (hx : x ∈ GShafar.relatorDifferenceIdeal
      (R := ZMod p) rels) :
    (fun j =>
      GShafar.presentedAlgebra
        (R := ZMod p) (Set.range rels)
        (freeFoxDerivative (ZMod p) (Fin d) j x)) ∈
      LinearMap.range (presentedRelatorFox (p := p) rels) := by
  classical
  let F := FreeGroup (Fin d)
  let qmap :
      MonoidAlgebra (ZMod p) F →+*
        MonoidAlgebra (ZMod p) (PresentedGroup (Set.range rels)) :=
    GShafar.presentedAlgebra
      (R := ZMod p) (Set.range rels)
  let aug : MonoidAlgebra (ZMod p) F →+* ZMod p :=
    (GShafar.augmentationHom (ZMod p) F).toRingHom
  let rangeS : Submodule (ZMod p)
      (Fin d → presentedGroupAlgebra (p := p) rels) :=
    LinearMap.range (presentedRelatorFox (p := p) rels)
  let Dtuple : MonoidAlgebra (ZMod p) F →
      Fin d → presentedGroupAlgebra (p := p) rels :=
    fun z j => qmap (freeFoxDerivative (ZMod p) (Fin d) j z)
  let P : TwoSidedIdeal (MonoidAlgebra (ZMod p) F) :=
    TwoSidedIdeal.mk'
      {z | qmap z = 0 ∧ aug z = 0 ∧ Dtuple z ∈ rangeS}
      (by
        constructor
        · exact map_zero qmap
        constructor
        · exact map_zero aug
        · have hD : Dtuple 0 = 0 := by
            funext j
            change qmap (0 : MonoidAlgebra (ZMod p) F) = 0
            exact map_zero qmap
          simp [hD])
      (by
        intro x y hx hy
        rcases hx with ⟨hxq, hxaug, hxD⟩
        rcases hy with ⟨hyq, hyaug, hyD⟩
        constructor
        · rw [map_add, hxq, hyq, add_zero]
        constructor
        · rw [map_add, hxaug, hyaug, add_zero]
        · have hD : Dtuple (x + y) = Dtuple x + Dtuple y := by
            funext j
            simp [Dtuple, map_add]
          rw [hD]
          exact rangeS.add_mem hxD hyD)
      (by
        intro x hx
        rcases hx with ⟨hxq, hxaug, hxD⟩
        constructor
        · rw [map_neg, hxq, neg_zero]
        constructor
        · rw [map_neg, hxaug, neg_zero]
        · have hD : Dtuple (-x) = -Dtuple x := by
            funext j
            simp [Dtuple, map_neg]
          rw [hD]
          exact rangeS.neg_mem hxD)
      (by
        intro x y hy
        rcases hy with ⟨hyq, hyaug, hyD⟩
        constructor
        · rw [map_mul, hyq, mul_zero]
        constructor
        · rw [map_mul, hyaug, mul_zero]
        · have hD :
            Dtuple (x * y) =
              fun j => qmap x * Dtuple y j := by
            funext j
            change
              qmap (freeFoxDerivative (ZMod p) (Fin d) j (x * y)) =
                qmap x *
                  qmap (freeFoxDerivative (ZMod p) (Fin d) j y)
            rw [algebra_fox_derivative]
            have hyaug' :
                (GShafar.augmentationHom
                  (ZMod p) (FreeGroup (Fin d))) y = 0 := by
              simpa [aug, F] using hyaug
            simp only [map_add, map_mul, add_eq_right]
            simp only [Algebra.smul_def, hyaug', map_zero, zero_mul]
          rw [hD]
          exact
            presented_fox_range
              (p := p) rels (qmap x) hyD)
      (by
        intro x y hx
        rcases hx with ⟨hxq, hxaug, hxD⟩
        constructor
        · rw [map_mul, hxq, zero_mul]
        constructor
        · rw [map_mul, hxaug, zero_mul]
        · have hD :
            Dtuple (x * y) =
              aug y • Dtuple x := by
            funext j
            change
              qmap (freeFoxDerivative (ZMod p) (Fin d) j (x * y)) =
                aug y •
                  qmap (freeFoxDerivative (ZMod p) (Fin d) j x)
            rw [algebra_fox_derivative]
            simp [hxq, aug, qmap, F, map_add, map_mul, Algebra.smul_def,
              GShafar.presentedAlgebra]
          rw [hD]
          exact rangeS.smul_mem (aug y) hxD)
  have hspan :
      TwoSidedIdeal.span
          (Set.range fun i =>
            MonoidAlgebra.of (ZMod p) F (rels i) - 1) ≤ P := by
    rw [TwoSidedIdeal.span_le]
    rintro _ ⟨i, rfl⟩
    change
      (MonoidAlgebra.of (ZMod p) F (rels i) - 1 :
        MonoidAlgebra (ZMod p) F) ∈ P
    have hgen :
        (MonoidAlgebra.of (ZMod p) F (rels i) - 1 :
          MonoidAlgebra (ZMod p) F) =
          augmentationDifference (ZMod p) F (rels i) := by
      simp [augmentationDifference, MonoidAlgebra.of_apply]
    rw [hgen]
    constructor
    · simpa [qmap, F] using
        presented_difference_zero
          (p := p) rels i
    constructor
    · simp [aug, F, augmentationDifference,
        GShafar.augmentationHom,
        GShafar.augmentationCharacter]
    · refine ⟨fun k => if k = i then 1 else 0, ?_⟩
      funext j
      simp [Dtuple, qmap, F, presentedRelatorFox,
        presentedFoxCoefficient, augmentationDifference,
        free_derivative_single]
  have hxP : x ∈ P := by
    change x ∈ TwoSidedIdeal.span
        (Set.range fun i =>
          MonoidAlgebra.of (ZMod p) F (rels i) - 1) at hx
    exact hspan hx
  simpa [Dtuple, rangeS, sub_zero] using hxP.2.2

theorem presented_boundary_range
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d)) :
    LinearMap.ker (presentedGeneratorBoundary (p := p) rels) ≤
      LinearMap.range (presentedRelatorFox (p := p) rels) := by
  classical
  intro y hy
  let F := FreeGroup (Fin d)
  let qmap :
      MonoidAlgebra (ZMod p) F →+*
        MonoidAlgebra (ZMod p) (PresentedGroup (Set.range rels)) :=
    GShafar.presentedAlgebra
      (R := ZMod p) (Set.range rels)
  have hsurj :
      Function.Surjective qmap := by
    simpa [qmap, F] using
      GShafar.presented_algebra_surjective
        (R := ZMod p) (Set.range rels)
  choose Y hY using fun j : Fin d => hsurj (y j)
  let B : MonoidAlgebra (ZMod p) F :=
    ∑ j, Y j *
      augmentationDifference (ZMod p) F (FreeGroup.of j)
  have hqB :
      qmap B = 0 := by
    have hqB_boundary :
        qmap B = presentedGeneratorBoundary (p := p) rels y := by
      dsimp [B, presentedGeneratorBoundary]
      rw [map_sum]
      apply Finset.sum_congr rfl
      intro j _hj
      rw [map_mul, hY j]
      simpa [qmap, F] using
        congrArg (fun z => y j * z)
          (presented_algebra_difference
            (p := p) rels j)
    rw [hqB_boundary]
    exact LinearMap.mem_ker.mp hy
  have hBideal :
      B ∈ GShafar.relatorDifferenceIdeal
        (R := ZMod p) rels := by
    rw [relator_difference_algebra
      (R := ZMod p) rels]
    change qmap B = 0
    exact hqB
  have hDrange :
      (fun j =>
        qmap (freeFoxDerivative (ZMod p) (Fin d) j B)) ∈
        LinearMap.range (presentedRelatorFox (p := p) rels) := by
    simpa [qmap, F] using
      presented_fox_derivative
        (p := p) rels hBideal
  have hDtuple :
      (fun j =>
        qmap (freeFoxDerivative (ZMod p) (Fin d) j B)) = y := by
    funext j
    dsimp [B]
    simp [algebra_fox_derivative,
            augmentationDifference, GShafar.augmentationHom,
      GShafar.augmentationCharacter, hY, qmap, F]
  simpa [hDtuple] using hDrange

/-- Coordinatewise augmentation-power conditions on a finite tuple. -/
def presentedTupleSubmodule
    {p d r s : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (degree : Fin s → ℕ) :
    Submodule (ZMod p) (Fin s → presentedGroupAlgebra (p := p) rels) :=
  Submodule.pi Set.univ (fun i =>
    ((presentedAugmentationIdeal (p := p) rels) ^ degree i).restrictScalars
      (ZMod p))

@[simp]
theorem presented_tuple_submodule
    {p d r s : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (degree : Fin s → ℕ)
    (x : Fin s → presentedGroupAlgebra (p := p) rels) :
    x ∈ presentedTupleSubmodule (p := p) rels degree ↔
      ∀ i, x i ∈ (presentedAugmentationIdeal (p := p) rels) ^ degree i := by
  simp [presentedTupleSubmodule]

/-- Boundary multiplication by generator differences raises tuple filtration by one. -/
theorem presented_generator_boundary
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (n : ℕ)
    (x : Fin d → presentedGroupAlgebra (p := p) rels)
    (hx : x ∈ presentedTupleSubmodule
      (p := p) rels (fun _ => n)) :
    presentedGeneratorBoundary (p := p) rels x ∈
      ((presentedAugmentationIdeal (p := p) rels) ^ (n + 1)).restrictScalars
        (ZMod p) := by
  classical
  let I : Ideal (presentedGroupAlgebra (p := p) rels) :=
    presentedAugmentationIdeal (p := p) rels
  haveI : I.IsTwoSided := by
    change (presentedAugmentationIdeal (p := p) rels).IsTwoSided
    dsimp [presentedAugmentationIdeal, GShafar.augmentationIdeal]
    infer_instance
  change ∑ j, x j * presentedGeneratorDifference (p := p) rels j ∈ I ^ (n + 1)
  apply Ideal.sum_mem
  intro j _hj
  have hxj : x j ∈ I ^ n := by
    simpa [I] using
      (presented_tuple_submodule
        (p := p) rels (fun _ => n) x).mp hx j
  have hgen :
      presentedGeneratorDifference (p := p) rels j ∈ I ^ 1 := by
    simpa [I, Submodule.pow_one] using
      presented_difference_ideal (p := p) rels j
  have hmul :
      x j * presentedGeneratorDifference (p := p) rels j ∈ I ^ n * I ^ 1 :=
    Ideal.mul_mem_mul hxj hgen
  rw [Ideal.IsTwoSided.pow_add (I := I) (m := n) (n := 1)]
  simpa using hmul

/-- Shifted relator coefficients land in the generator tuple filtration. -/
theorem presented_fox_tuple
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (depth : Fin r → ℕ)
    (hdepth :
      ∀ i,
        (MonoidAlgebra.of (ZMod p) (FreeGroup (Fin d)) (rels i) - 1 :
          MonoidAlgebra (ZMod p) (FreeGroup (Fin d))) ∈
            (GroupAlgebra.augmentationIdeal
              (ZMod p) (FreeGroup (Fin d))) ^ depth i)
    (hdepth2 : ∀ i, 2 ≤ depth i)
    (n : ℕ)
    (x : Fin r → presentedGroupAlgebra (p := p) rels)
    (hx : x ∈ presentedTupleSubmodule
      (p := p) rels (fun i => n + 1 - depth i)) :
    presentedRelatorFox (p := p) rels x ∈
      presentedTupleSubmodule (p := p) rels (fun _ => n) := by
  classical
  let I : Ideal (presentedGroupAlgebra (p := p) rels) :=
    presentedAugmentationIdeal (p := p) rels
  haveI : I.IsTwoSided := by
    change (presentedAugmentationIdeal (p := p) rels).IsTwoSided
    dsimp [presentedAugmentationIdeal, GShafar.augmentationIdeal]
    infer_instance
  rw [presented_tuple_submodule]
  intro j
  change ∑ i, x i * presentedFoxCoefficient (p := p) rels i j ∈ I ^ n
  apply Ideal.sum_mem
  intro i _hi
  have hxi : x i ∈ I ^ (n + 1 - depth i) := by
    simpa [I] using
      (presented_tuple_submodule
        (p := p) rels (fun i => n + 1 - depth i) x).mp hx i
  have hcoeff :
      presentedFoxCoefficient (p := p) rels i j ∈ I ^ (depth i - 1) := by
    simpa [I] using
      presented_fox_least
        (p := p) rels hdepth i j
  have hmul :
      x i * presentedFoxCoefficient (p := p) rels i j ∈
        I ^ (n + 1 - depth i) * I ^ (depth i - 1) :=
    Ideal.mul_mem_mul hxi hcoeff
  have hdegree :
      n ≤ (n + 1 - depth i) + (depth i - 1) := by
    have hdi := hdepth2 i
    omega
  have hle :
      I ^ ((n + 1 - depth i) + (depth i - 1)) ≤ I ^ n :=
    Ideal.pow_le_pow_right hdegree
  apply hle
  rw [Ideal.IsTwoSided.pow_add]
  exact hmul

/-- The generator-boundary map is strict for the augmentation filtration. -/
theorem presented_boundary_strict
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (n : ℕ)
    (x : Fin d → presentedGroupAlgebra (p := p) rels)
    (hx :
      presentedGeneratorBoundary (p := p) rels x ∈
        ((presentedAugmentationIdeal (p := p) rels) ^ (n + 1)).restrictScalars
          (ZMod p)) :
    ∃ y ∈ presentedTupleSubmodule
        (p := p) rels (fun _ => n),
      presentedGeneratorBoundary (p := p) rels y =
        presentedGeneratorBoundary (p := p) rels x := by
  classical
  let b : presentedAugmentationSubmodule (p := p) rels (n + 1) :=
    ⟨presentedGeneratorBoundary (p := p) rels x, hx⟩
  rcases presented_generated_exact
      (p := p) rels (n + 1) (by omega) b with
    ⟨y, hy⟩
  refine ⟨fun j => (y j : presentedGroupAlgebra (p := p) rels), ?_, ?_⟩
  · rw [presented_tuple_submodule]
    intro j
    exact (y j).2
  · simpa [b, presentedGeneratorBoundary] using hy.symm

/-- A tuple filtered coordinatewise by augmentation powers has the expected
product of presented augmentation truncations as its quotient. -/
noncomputable def presentedAugmentationTuple
    {p d r s : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (degree : Fin s → ℕ) :
    ((Fin s → presentedGroupAlgebra (p := p) rels) ⧸
        presentedTupleSubmodule (p := p) rels degree) ≃ₗ[ZMod p]
      (forall i : Fin s,
        presentedAugmentationTruncation (p := p) rels (degree i)) := by
  simpa only [presentedTupleSubmodule,
    presentedAugmentationTruncation] using
      (Submodule.quotientPi
        (fun i : Fin s =>
          ((presentedAugmentationIdeal (p := p) rels) ^ degree i).restrictScalars
            (ZMod p)))

set_option synthInstance.maxHeartbeats 200000 in
-- Typeclass synthesis expands the finite family of presented truncation modules.
/-- Dimension of a coordinatewise filtered tuple quotient. -/
theorem finrank_tuple_submodule
    {p d r s : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (degree : Fin s → ℕ) :
    Module.finrank (ZMod p)
        ((Fin s → presentedGroupAlgebra (p := p) rels) ⧸
          presentedTupleSubmodule (p := p) rels degree) =
      ∑ i, Module.finrank (ZMod p)
        (presentedAugmentationTruncation (p := p) rels (degree i)) := by
  letI : ∀ i : Fin s, Module.Finite (ZMod p)
      (presentedAugmentationTruncation (p := p) rels (degree i)) :=
    fun i => module_presented_truncation (p := p) rels (degree i)
  rw [(presentedAugmentationTuple
    (p := p) rels degree).finrank_eq]
  exact Module.finrank_pi_fintype (ZMod p)

/-- Coordinatewise filtered tuple quotients are finite-dimensional. -/
theorem module_tuple_submodule
    {p d r s : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (degree : Fin s → ℕ) :
    Module.Finite (ZMod p)
      ((Fin s → presentedGroupAlgebra (p := p) rels) ⧸
        presentedTupleSubmodule (p := p) rels degree) := by
  letI : ∀ i : Fin s, Module.Finite (ZMod p)
      (presentedAugmentationTruncation (p := p) rels (degree i)) :=
    fun i => module_presented_truncation (p := p) rels (degree i)
  exact Module.Finite.equiv
    (presentedAugmentationTuple (p := p) rels degree).symm

/-- Finite-level Fox rank estimate for a presented group algebra.  The relator
depth lower bounds shift the source truncations, while strictness of the
generator boundary filtration lets exactness descend to the quotient. -/
theorem presented_truncation_relator
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (depth : Fin r → ℕ)
    (hdepth :
      ∀ i,
        (MonoidAlgebra.of (ZMod p) (FreeGroup (Fin d)) (rels i) - 1 :
          MonoidAlgebra (ZMod p) (FreeGroup (Fin d))) ∈
            (GroupAlgebra.augmentationIdeal
              (ZMod p) (FreeGroup (Fin d))) ^ depth i)
    (hdepth2 : ∀ i, 2 ≤ depth i)
    (n : ℕ) :
    d * Module.finrank (ZMod p)
        (presentedAugmentationTruncation (p := p) rels n) ≤
      Module.finrank (ZMod p)
          (presentedAugmentationTruncation (p := p) rels (n + 1)) +
        ∑ i, Module.finrank (ZMod p)
          (presentedAugmentationTruncation (p := p) rels
            (n + 1 - depth i)) := by
  classical
  let A := presentedGroupAlgebra (p := p) rels
  let SR : Submodule (ZMod p) (Fin r → A) :=
    presentedTupleSubmodule
      (p := p) rels (fun i => n + 1 - depth i)
  let SM : Submodule (ZMod p) (Fin d → A) :=
    presentedTupleSubmodule (p := p) rels (fun _ => n)
  let SN : Submodule (ZMod p) A :=
    ((presentedAugmentationIdeal (p := p) rels) ^ (n + 1)).restrictScalars
      (ZMod p)
  let φ : (Fin r → A) →ₗ[ZMod p] (Fin d → A) :=
    presentedRelatorFox (p := p) rels
  let μ : (Fin d → A) →ₗ[ZMod p] A :=
    presentedGeneratorBoundary (p := p) rels
  have hSR : SR ≤ SM.comap φ := by
    intro x hx
    exact presented_fox_tuple
      (p := p) rels depth hdepth hdepth2 n x hx
  have hSM : SM ≤ SN.comap μ := by
    intro x hx
    exact presented_generator_boundary
      (p := p) rels n x hx
  have hexact : LinearMap.ker μ ≤ LinearMap.range φ := by
    change
      LinearMap.ker (presentedGeneratorBoundary (p := p) rels) ≤
        LinearMap.range (presentedRelatorFox (p := p) rels)
    exact presented_boundary_range
      (p := p) rels
  have hstrict : ∀ m, μ m ∈ SN → ∃ s ∈ SM, μ s = μ m := by
    intro m hm
    exact presented_boundary_strict (p := p) rels n m hm
  let φq := SR.mapQ SM φ hSR
  let μq := SM.mapQ SN μ hSM
  have hcover : LinearMap.ker μq ≤ LinearMap.range φq := by
    exact range_exact_strict
      φ μ SR SM SN hSR hSM hexact hstrict
  letI : Module.Finite (ZMod p) ((Fin r → A) ⧸ SR) := by
    dsimp [SR, A]
    exact module_tuple_submodule
      (p := p) rels (fun i => n + 1 - depth i)
  letI : Module.Finite (ZMod p) ((Fin d → A) ⧸ SM) := by
    dsimp [SM, A]
    exact module_tuple_submodule
      (p := p) rels (fun _ => n)
  letI : Module.Finite (ZMod p) (A ⧸ SN) := by
    change Module.Finite (ZMod p)
      (presentedAugmentationTruncation (p := p) rels (n + 1))
    exact module_presented_truncation (p := p) rels (n + 1)
  have hker :
      Module.finrank (ZMod p) (LinearMap.ker μq) ≤
        Module.finrank (ZMod p) ((Fin r → A) ⧸ SR) :=
    linear_finrank_range μq φq hcover
  have hrank := rank_nullity μq
  have hrange :
      Module.finrank (ZMod p) (LinearMap.range μq) ≤
        Module.finrank (ZMod p) (A ⧸ SN) :=
    Submodule.finrank_le (LinearMap.range μq)
  have hquot :
      Module.finrank (ZMod p) ((Fin d → A) ⧸ SM) ≤
        Module.finrank (ZMod p) (A ⧸ SN) +
          Module.finrank (ZMod p) ((Fin r → A) ⧸ SR) := by
    omega
  calc
    d * Module.finrank (ZMod p)
          (presentedAugmentationTruncation (p := p) rels n) =
        Module.finrank (ZMod p) ((Fin d → A) ⧸ SM) := by
          change d * Module.finrank (ZMod p)
              (presentedAugmentationTruncation (p := p) rels n) =
            Module.finrank (ZMod p)
              ((Fin d → presentedGroupAlgebra (p := p) rels) ⧸
                presentedTupleSubmodule
                  (p := p) rels (fun _ => n))
          rw [finrank_tuple_submodule]
          simp
    _ ≤ Module.finrank (ZMod p) (A ⧸ SN) +
          Module.finrank (ZMod p) ((Fin r → A) ⧸ SR) := hquot
    _ = Module.finrank (ZMod p)
          (presentedAugmentationTruncation (p := p) rels (n + 1)) +
        ∑ i, Module.finrank (ZMod p)
          (presentedAugmentationTruncation (p := p) rels
            (n + 1 - depth i)) := by
          change Module.finrank (ZMod p)
                (presentedAugmentationTruncation (p := p) rels (n + 1)) +
              Module.finrank (ZMod p)
                ((Fin r → presentedGroupAlgebra (p := p) rels) ⧸
                  presentedTupleSubmodule
                    (p := p) rels (fun i => n + 1 - depth i)) =
            _
          rw [finrank_tuple_submodule]

/-- Successor GS recurrence for presented augmentation-truncation dimensions,
with inactive relators written in the guarded-convolution form. -/
theorem presented_gs_succ
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (depth : Fin r → ℕ)
    (hdepth :
      ∀ i,
        (MonoidAlgebra.of (ZMod p) (FreeGroup (Fin d)) (rels i) - 1 :
          MonoidAlgebra (ZMod p) (FreeGroup (Fin d))) ∈
            (GroupAlgebra.augmentationIdeal
              (ZMod p) (FreeGroup (Fin d))) ^ depth i)
    (hdepth2 : ∀ i, 2 ≤ depth i)
    (n : ℕ) :
    d * Module.finrank (ZMod p)
        (presentedAugmentationTruncation (p := p) rels (n + 1)) ≤
      Module.finrank (ZMod p)
          (presentedAugmentationTruncation (p := p) rels ((n + 1) + 1)) +
        ∑ i, if depth i ≤ n + 1 then
          Module.finrank (ZMod p)
            (presentedAugmentationTruncation (p := p) rels
              (n + 1 - depth i + 1))
        else 0 := by
  classical
  have hzero :
      Module.finrank (ZMod p)
        (presentedAugmentationTruncation (p := p) rels 0) = 0 := by
    rw [← rank_presented_truncation
      (p := p) rels 0]
    simp
  have hsum :
      (∑ i, Module.finrank (ZMod p)
        (presentedAugmentationTruncation (p := p) rels
          ((n + 1) + 1 - depth i))) =
        ∑ i, if depth i ≤ n + 1 then
          Module.finrank (ZMod p)
            (presentedAugmentationTruncation (p := p) rels
              (n + 1 - depth i + 1))
        else 0 := by
    apply Finset.sum_congr rfl
    intro i _hi
    by_cases hi : depth i ≤ n + 1
    · rw [if_pos hi]
      have hdegree :
          (n + 1) + 1 - depth i = n + 1 - depth i + 1 := by
        omega
      rw [hdegree]
    · simp only [hi, ↓reduceIte]
      rw [show (n + 1) + 1 - depth i = 0 by omega]
      exact hzero
  have h :=
    presented_truncation_relator
      (p := p) rels depth hdepth hdepth2 (n + 1)
  rw [hsum] at h
  exact h

/-- Left multiplication preserves the ungraded relation module. -/
noncomputable def presentedModuleMul
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (a : presentedGroupAlgebra (p := p) rels) :
    presentedRelationModule (p := p) rels →ₗ[ZMod p]
      presentedRelationModule (p := p) rels where
  toFun x :=
    ⟨fun j => a * ((x : Fin d → presentedGroupAlgebra (p := p) rels) j), by
      classical
      let A := presentedGroupAlgebra (p := p) rels
      have hx0 :
          presentedGeneratorBoundary (p := p) rels
              ((x : presentedRelationModule (p := p) rels) : Fin d → A) = 0 :=
        LinearMap.mem_ker.mp x.2
      have hx :
          ∑ j,
            ((x : Fin d → A) j) *
              presentedGeneratorDifference (p := p) rels j = 0 := by
        change
          presentedGeneratorBoundary (p := p) rels
              ((x : presentedRelationModule (p := p) rels) : Fin d → A) = 0
        exact hx0
      change
        ∑ j,
          (a * ((x : Fin d → A) j)) *
            presentedGeneratorDifference (p := p) rels j = 0
      calc
        ∑ j,
            (a * ((x : Fin d → A) j)) *
              presentedGeneratorDifference (p := p) rels j
            =
            a *
              ∑ j,
                ((x : Fin d → A) j) *
                  presentedGeneratorDifference (p := p) rels j := by
              rw [Finset.mul_sum]
              apply Finset.sum_congr rfl
              intro j _hj
              rw [mul_assoc]
        _ = 0 := by
              rw [hx, mul_zero]⟩
  map_add' x y := by
    apply Subtype.ext
    funext j
    simp [mul_add]
  map_smul' c x := by
    apply Subtype.ext
    funext j
    simp

/--
The relator Fox map with codomain restricted to the relation module.

Its domain is `A^r`: one group-algebra coefficient for each defining relator.
-/
noncomputable def presentedFoxRelation
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d)) :
    (Fin r → presentedGroupAlgebra (p := p) rels) →ₗ[ZMod p]
      presentedRelationModule (p := p) rels where
  toFun c :=
    ⟨presentedRelatorFox (p := p) rels c,
      presented_fox_boundary
        (p := p) rels ⟨c, rfl⟩⟩
  map_add' c e := by
    apply Subtype.ext
    exact (presentedRelatorFox (p := p) rels).map_add c e
  map_smul' a c := by
    apply Subtype.ext
    exact (presentedRelatorFox (p := p) rels).map_smul a c

@[simp]
theorem presented_relator_relation
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (c : Fin r → presentedGroupAlgebra (p := p) rels)
    (j : Fin d) :
    ((presentedFoxRelation (p := p) rels c :
        presentedRelationModule (p := p) rels) :
        Fin d → presentedGroupAlgebra (p := p) rels) j =
      ∑ i, c i * presentedFoxCoefficient (p := p) rels i j := rfl

/-- The relation-module generator attached to a defining relator. -/
noncomputable def presentedRelatorRelation
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (i : Fin r) :
    presentedRelationModule (p := p) rels :=
  presentedFoxRelation (p := p) rels
    (fun k => if k = i then 1 else 0)

@[simp]
theorem relator_fox_relation
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (i : Fin r)
    (j : Fin d) :
    ((presentedRelatorRelation (p := p) rels i :
        presentedRelationModule (p := p) rels) :
        Fin d → presentedGroupAlgebra (p := p) rels) j =
      presentedFoxCoefficient (p := p) rels i j := by
  classical
  simp [presentedRelatorRelation]

/--
The relator Fox relation map is the sum of left multiples of the `r` basic
relator Fox relation vectors.
-/
theorem presented_fox_relation
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (c : Fin r → presentedGroupAlgebra (p := p) rels) :
    presentedFoxRelation (p := p) rels c =
      ∑ i,
        presentedModuleMul (p := p) rels (c i)
          (presentedRelatorRelation (p := p) rels i) := by
  classical
  apply Subtype.ext
  funext j
  simp [presentedModuleMul]

/--
The ungraded relation-module map attached to an arbitrary finite family of
relation-module generators.
-/
noncomputable def presentedModuleGenerator
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (generator : Fin r → presentedRelationModule (p := p) rels) :
    (Fin r → presentedGroupAlgebra (p := p) rels) →ₗ[ZMod p]
      presentedRelationModule (p := p) rels where
  toFun c :=
    ∑ i,
      presentedModuleMul (p := p) rels (c i) (generator i)
  map_add' c e := by
    classical
    apply Subtype.ext
    funext j
    simp [presentedModuleMul, Pi.add_apply, add_mul,
      Finset.sum_add_distrib]
  map_smul' a c := by
    classical
    apply Subtype.ext
    funext j
    simp [presentedModuleMul, Pi.smul_apply, Finset.smul_sum]

/-- The abstract generator map recovers the relator Fox relation map. -/
theorem presented_module_fox
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d)) :
    presentedModuleGenerator
        (p := p) rels (presentedRelatorRelation (p := p) rels) =
      presentedFoxRelation (p := p) rels := by
  classical
  apply LinearMap.ext
  intro c
  exact (presented_fox_relation (p := p) rels c).symm

/--
The relator Fox relation attached to a depth-`m` relator lies in relation-module
filtration degree `m - 1`.
-/
theorem presented_fox_filtration
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (depth : Fin r → ℕ)
    (hdepth :
      ∀ i, rels i ∈ zassenhausFiltration p (FreeGroup (Fin d)) (depth i))
    (hdepth2 : ∀ i, 2 ≤ depth i)
    (i : Fin r) :
    presentedRelatorRelation (p := p) rels i ∈
      presentedModuleFiltration (p := p) rels (depth i - 1) := by
  rw [presented_relation_filtration]
  intro j
  simpa using
    presented_relator_fox
      (p := p) rels hdepth hdepth2 i j

/--
A finite family of relation-module generators together with filtration degrees.

The intended use is to pass from ungraded relation-module generation to a
filtered/graded statement.  This package only records the filtered generators;
the associated-graded surjectivity is the next step.
-/
structure PresentedModuleFiltered
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (depth : Fin r → ℕ) where
  refinedDepth : Fin r → ℕ
  depth_le_refined : ∀ i, depth i ≤ refinedDepth i
  refined_two_le : ∀ i, 2 ≤ refinedDepth i
  generator : Fin r → presentedRelationModule (p := p) rels
  generator_mem :
    ∀ i, generator i ∈
      presentedModuleFiltration (p := p) rels (refinedDepth i - 1)
  generatorMap_surjective :
    Function.Surjective
      (presentedModuleGenerator (p := p) rels generator)

/--
The `r` relator Fox vectors generate the ungraded relation module: every exact
relation among presentation-generator augmentation differences is a
group-algebra linear combination of the relator Fox relations.
-/
theorem presented_fox_surjective
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d)) :
    Function.Surjective
      (presentedFoxRelation (p := p) rels) := by
  intro x
  have hx :
      ((x : presentedRelationModule (p := p) rels) :
        Fin d → presentedGroupAlgebra (p := p) rels) ∈
        LinearMap.range (presentedRelatorFox (p := p) rels) :=
    presented_boundary_range
      (p := p) rels x.2
  rcases hx with ⟨c, hc⟩
  refine ⟨c, ?_⟩
  apply Subtype.ext
  exact hc

/-- Range form of ungraded relation-module generation. -/
theorem presented_fox_top
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d)) :
    LinearMap.range (presentedFoxRelation (p := p) rels) = ⊤ := by
  exact LinearMap.range_eq_top.mpr
    (presented_fox_surjective (p := p) rels)

/--
The actual relator Fox relations give a filtration-compatible generating
family, with refined depths equal to the declared depths.
-/
theorem presented_filtered_relators
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (depth : Fin r → ℕ)
    (hdepth :
      ∀ i, rels i ∈ zassenhausFiltration p (FreeGroup (Fin d)) (depth i))
    (hdepth2 : ∀ i, 2 ≤ depth i) :
    Nonempty
      (PresentedModuleFiltered (p := p) rels depth) := by
  classical
  refine
    ⟨{
      refinedDepth := depth
      depth_le_refined := ?_
      refined_two_le := hdepth2
      generator := presentedRelatorRelation (p := p) rels
      generator_mem := ?_
      generatorMap_surjective := ?_
    }⟩
  · intro i
    exact le_rfl
  · intro i
    exact
      presented_fox_filtration
        (p := p) rels depth hdepth hdepth2 i
  · rw [presented_module_fox]
    exact presented_fox_surjective (p := p) rels

/-- Coefficient form of ungraded relation-module generation. -/
theorem presented_fox_coefficients
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (x : presentedRelationModule (p := p) rels) :
    ∃ c : Fin r → presentedGroupAlgebra (p := p) rels,
      ∀ j,
        ((x : presentedRelationModule (p := p) rels) :
          Fin d → presentedGroupAlgebra (p := p) rels) j =
          ∑ i, c i * presentedFoxCoefficient (p := p) rels i j := by
  rcases presented_fox_surjective (p := p) rels x with
    ⟨c, hc⟩
  refine ⟨c, ?_⟩
  intro j
  have hcoord :=
    congrArg
      (fun y : presentedRelationModule (p := p) rels =>
        ((y : presentedRelationModule (p := p) rels) :
          Fin d → presentedGroupAlgebra (p := p) rels) j)
      hc
  simpa using hcoord.symm

/--
The pushed-forward Fox derivative tuple of an element of the normal closure of
the defining relators lies in the range of the ungraded relator Fox map.
-/
theorem presented_derivative_closure
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    {g : FreeGroup (Fin d)}
    (hg : g ∈ Subgroup.normalClosure (Set.range rels)) :
    presentedDerivativeTuple (p := p) rels g ∈
      LinearMap.range (presentedRelatorFox (p := p) rels) := by
  classical
  let F := FreeGroup (Fin d)
  let Q := PresentedGroup (Set.range rels)
  let q : F →* Q := PresentedGroup.mk (Set.range rels)
  let A := presentedGroupAlgebra (p := p) rels
  let rangeS : Submodule (ZMod p) (Fin d → A) :=
    LinearMap.range (presentedRelatorFox (p := p) rels)
  let N : Subgroup F :=
    { carrier := {x | q x = 1 ∧
          presentedDerivativeTuple (p := p) rels x ∈ rangeS}
      one_mem' := by
        constructor
        · simp [q]
        · simp [rangeS]
      mul_mem' := by
        intro x y hx hy
        constructor
        · simp [q, hx.1, hy.1]
        · rw [presented_derivative_tuple]
          refine rangeS.add_mem hx.2 ?_
          exact
            presented_fox_range
              (p := p) rels
              (MonoidAlgebra.single (q x) (1 : ZMod p))
              hy.2
      inv_mem' := by
        intro x hx
        constructor
        · simp [q, hx.1]
        · rw [presented_derivative_inv]
          have hmul :
              (fun j =>
                MonoidAlgebra.single (q x⁻¹) (1 : ZMod p) *
                  presentedDerivativeTuple (p := p) rels x j) ∈ rangeS :=
            presented_fox_range
              (p := p) rels
              (MonoidAlgebra.single (q x⁻¹) (1 : ZMod p))
              hx.2
          simpa [Pi.neg_apply] using rangeS.neg_mem hmul }
  have hNnormal : N.Normal := by
    refine Subgroup.Normal.mk ?_
    intro n hn a
    constructor
    · simp [q, hn.1]
    · have htuple :
          presentedDerivativeTuple (p := p) rels (a * n * a⁻¹) =
            fun j =>
              MonoidAlgebra.single (q a) (1 : ZMod p) *
                presentedDerivativeTuple (p := p) rels n j := by
        ext j
        rw [presented_derivative_tuple]
        rw [presented_derivative_tuple]
        rw [presented_derivative_inv]
        simp [q, hn.1]
      rw [htuple]
      exact
        presented_fox_range
          (p := p) rels
          (MonoidAlgebra.single (q a) (1 : ZMod p))
          hn.2
  have hrels_le : Set.range rels ⊆ (N : Set F) := by
    rintro _ ⟨i, rfl⟩
    constructor
    · exact PresentedGroup.one_of_mem (rels := Set.range rels) ⟨i, rfl⟩
    · refine ⟨fun k => if k = i then 1 else 0, ?_⟩
      ext j
      simp [presentedDerivativeTuple, presentedRelatorFox,
        presentedFoxCoefficient]
  have hclosure_le : Subgroup.normalClosure (Set.range rels) ≤ N := by
    letI : N.Normal := hNnormal
    exact Subgroup.normalClosure_le_normal hrels_le
  exact (hclosure_le hg).2

/-- The generator kernel for the right-oriented high-degree presentation map. -/
abbrev presentedHighPresentation
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d)) (n : ℕ) (hn : 2 ≤ n) :
    Submodule (ZMod p)
      (pGTarget (p := p) rels n) :=
  LinearMap.ker
    (presentedHighMultiplication
      (p := p) rels n (by omega))

/--
Pointwise preimages for every element of a submodule are exactly what is needed
to prove that the submodule is contained in the range of a linear map.
-/
theorem submodule_forall_preimage
    {K G R : Type*} [Semiring K]
    [AddCommMonoid G] [Module K G]
    [AddCommMonoid R] [Module K R]
    (S : Submodule K G)
    (α : R →ₗ[K] G)
    (hpre : ∀ x : S, ∃ y : R, α y = (x : G)) :
    S ≤ LinearMap.range α := by
  intro x hx
  rcases hpre ⟨x, hx⟩ with ⟨y, hy⟩
  exact ⟨y, hy⟩

/-- The filtered boundary associated to a homogeneous generator tuple. -/
abbrev presentedHighBoundary
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d)) (n : ℕ) (hn : 2 ≤ n) :
    pGTarget (p := p) rels n →ₗ[ZMod p]
      pALayer (p := p) rels n :=
  presentedHighMultiplication
    (p := p) rels n (by omega)

/-- Membership in the high-degree generator kernel is exactly vanishing of the
filtered boundary. -/
theorem presented_high_boundary
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (n : ℕ)
    (hn : 2 ≤ n)
    (x : pGTarget (p := p) rels n) :
    x ∈ presentedHighPresentation (p := p) rels n hn ↔
      presentedHighBoundary (p := p) rels n hn x = 0 := by
  rfl

/-- The `j`th filtered coefficient of an element of the relation-module filtration. -/
def presentedFiltrationCoefficient
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (n : ℕ)
    (x : presentedModuleFiltration (p := p) rels n)
    (j : Fin d) :
    presentedAugmentationSubmodule (p := p) rels n :=
  ⟨((x : presentedRelationModule (p := p) rels) :
      Fin d → presentedGroupAlgebra (p := p) rels) j,
    x.2 j⟩

@[simp]
theorem presented_module_filtration
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (n : ℕ)
    (x y : presentedModuleFiltration (p := p) rels n)
    (j : Fin d) :
    presentedFiltrationCoefficient (p := p) rels n (x + y) j =
      presentedFiltrationCoefficient (p := p) rels n x j +
        presentedFiltrationCoefficient (p := p) rels n y j := by
  ext
  rfl

@[simp]
theorem presented_module_smul
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (n : ℕ)
    (c : ZMod p)
    (x : presentedModuleFiltration (p := p) rels n)
    (j : Fin d) :
    presentedFiltrationCoefficient (p := p) rels n (c • x) j =
      c • presentedFiltrationCoefficient (p := p) rels n x j := by
  ext
  rfl

/--
Take the initial class of a filtered relation-module element.

An exact relation whose coefficients lie in `I^(n-1)` gives a tuple in
`(I^(n-1)/I^n)^d`, before using exactness to see that this tuple lies in the
homogeneous generator-boundary kernel.
-/
noncomputable def presentedHighTarget
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (n : ℕ) :
    presentedModuleFiltration (p := p) rels (n - 1) →ₗ[ZMod p]
      pGTarget (p := p) rels n where
  toFun x := fun j =>
    (presentedAugmentationKernel (p := p) rels (n - 1)).mkQ
      (presentedFiltrationCoefficient (p := p) rels (n - 1) x j)
  map_add' x y := by
    funext j
    simp [map_add]
  map_smul' c x := by
    funext j
    simp [map_smul]

/--
The initial class of a filtered relation-module element lies in the
homogeneous high-degree generator kernel.
-/
theorem presented_high_target
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (n : ℕ)
    (hn : 2 ≤ n)
    (x : presentedModuleFiltration (p := p) rels (n - 1)) :
    presentedHighTarget
        (p := p) rels n x ∈
      presentedHighPresentation (p := p) rels n hn := by
  classical
  let A := presentedGroupAlgebra (p := p) rels
  let genDiff : Fin d → A := presentedGeneratorDifference (p := p) rels
  let hgen : ∀ j, genDiff j ∈ presentedAugmentationIdeal (p := p) rels := by
    intro j
    exact presented_difference_ideal (p := p) rels j
  let y : Fin d → presentedAugmentationSubmodule (p := p) rels (n - 1) :=
    fun j =>
      presentedFiltrationCoefficient (p := p) rels (n - 1) x j
  let Ktarget := presentedAugmentationKernel (p := p) rels n
  have hβ :
      presentedHighBoundary (p := p) rels n hn
          (presentedHighTarget
            (p := p) rels n x) =
        Ktarget.mkQ
          (∑ j,
            presentedRightMul
              (p := p) (rels := rels)
              (m := 1) (n := n - 1) (k := n)
              (by omega)
              (genDiff j)
              (by simpa [genDiff, Submodule.pow_one] using hgen j)
              (y j)) := by
    simpa [presentedHighBoundary,
      presentedHighMultiplication,
      presentedHighTarget,
      y, genDiff, Ktarget] using
      presented_multiplication_mk
        (p := p) rels genDiff hgen n (by omega) y
  have hsum_zero :
      (∑ j,
          presentedRightMul
            (p := p) (rels := rels)
            (m := 1) (n := n - 1) (k := n)
            (by omega)
            (genDiff j)
            (by simpa [genDiff, Submodule.pow_one] using hgen j)
              (y j)) = 0 := by
    apply Subtype.ext
    have hx_boundary :
        presentedGeneratorBoundary (p := p) rels
            ((x : presentedRelationModule (p := p) rels) :
              Fin d → A) = 0 :=
      LinearMap.mem_ker.mp
        ((x : presentedRelationModule (p := p) rels).2)
    dsimp [presentedGeneratorBoundary] at hx_boundary
    simpa [presented_augmentation_mul, y, genDiff, A]
      using hx_boundary
  rw [presented_high_boundary,
    hβ, hsum_zero, map_zero]

/--
The initial-class map from the filtered relation module into the homogeneous
generator kernel.
-/
noncomputable def presentedFiltrationHigh
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (n : ℕ)
    (hn : 2 ≤ n) :
    presentedModuleFiltration (p := p) rels (n - 1) →ₗ[ZMod p]
      presentedHighPresentation (p := p) rels n hn where
  toFun x :=
    ⟨presentedHighTarget
        (p := p) rels n x,
      presented_high_target
        (p := p) rels n hn x⟩
  map_add' x y := by
    ext j
    simp [presentedHighTarget]
  map_smul' c x := by
    ext j
    simp [presentedHighTarget]

/--
Every homogeneous generator-kernel class has numerator representatives whose
right boundary vanishes on the nose.  The given kernel condition first says that
an arbitrary representative has boundary in the next augmentation power; the
strict degree-one generation lemma then absorbs that boundary into higher-degree
coefficients.
-/
theorem presented_boundary_representative
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    [Finite (PresentedGroup (Set.range rels))]
    (n : ℕ)
    (hn : 2 ≤ n)
    (x : presentedHighPresentation (p := p) rels n hn) :
    ∃ y : Fin d → presentedAugmentationSubmodule (p := p) rels (n - 1),
      (∀ j,
        (presentedAugmentationKernel (p := p) rels (n - 1)).mkQ (y j) =
          (x : pGTarget (p := p) rels n) j) ∧
      (∑ j,
        ((y j :
          presentedAugmentationSubmodule (p := p) rels (n - 1)) :
          presentedGroupAlgebra (p := p) rels) *
          presentedGeneratorDifference (p := p) rels j) = 0 := by
  classical
  let A := presentedGroupAlgebra (p := p) rels
  let I : Ideal A := presentedAugmentationIdeal (p := p) rels
  let Kprev := presentedAugmentationKernel (p := p) rels (n - 1)
  let Ktarget := presentedAugmentationKernel (p := p) rels n
  let genDiff : Fin d → A := presentedGeneratorDifference (p := p) rels
  have hgen : ∀ j, genDiff j ∈ presentedAugmentationIdeal (p := p) rels := by
    intro j
    exact presented_difference_ideal (p := p) rels j
  choose y hy using fun j : Fin d => Kprev.mkQ_surjective
    ((x : pGTarget (p := p) rels n) j)
  let yProduct : Fin d → presentedAugmentationSubmodule (p := p) rels n :=
    fun j =>
      presentedRightMul
        (p := p) (rels := rels)
        (m := 1) (n := n - 1) (k := n)
        (by omega)
        (genDiff j)
        (by simpa [genDiff, Submodule.pow_one] using hgen j)
        (y j)
  let s : presentedAugmentationSubmodule (p := p) rels n :=
    ∑ j, yProduct j
  have hsval :
      (s : A) =
        ∑ j,
          ((y j :
            presentedAugmentationSubmodule (p := p) rels (n - 1)) :
            A) *
            genDiff j := by
    dsimp [s, yProduct]
    simp [presentedRightMul]
  have hβ :
      presentedHighMultiplication
          (p := p) rels n (by omega)
          (x : pGTarget (p := p) rels n) =
        Ktarget.mkQ s := by
    have hβy :
        presentedHighMultiplication
            (p := p) rels n (by omega)
            (fun j => Kprev.mkQ (y j)) =
          Ktarget.mkQ s := by
      simpa [presentedHighMultiplication,
        Kprev, Ktarget, genDiff, hgen, yProduct, s]
        using
          presented_multiplication_mk
            (p := p)
            rels
            genDiff
            hgen
            n
            (by omega)
            y
    have hx_eq : (fun j => Kprev.mkQ (y j)) =
        (x : pGTarget (p := p) rels n) := by
      funext j
      exact hy j
    rw [← hx_eq]
    exact hβy
  have hs_mem_next : (s : A) ∈ presentedAugmentationSubmodule (p := p) rels (n + 1) := by
    have hxker :
        presentedHighMultiplication
            (p := p) rels n (by omega)
            (x : pGTarget (p := p) rels n) = 0 := by
      exact LinearMap.mem_ker.mp x.2
    have hs_zero : Ktarget.mkQ s = 0 := by
      rw [← hβ, hxker]
    exact (Submodule.Quotient.mk_eq_zero Ktarget).mp hs_zero
  have hboundary :
      (∑ j,
        ((y j :
          presentedAugmentationSubmodule (p := p) rels (n - 1)) :
          A) *
          genDiff j) ∈
        presentedAugmentationSubmodule (p := p) rels (n + 1) := by
    simpa [hsval] using hs_mem_next
  rcases presented_boundary_coefficients
      (p := p) rels n (by omega) y hboundary with
    ⟨z, hz⟩
  let zDown : Fin d → presentedAugmentationSubmodule (p := p) rels (n - 1) :=
    fun j =>
      ⟨(z j : A), by
        have hzmem : (z j : A) ∈ I ^ n := by
          simp [I, presentedAugmentationSubmodule]
        have hle : I ^ n ≤ I ^ (n - 1) :=
          Ideal.pow_le_pow_right (by omega : n - 1 ≤ n)
        exact hle hzmem⟩
  let w : Fin d → presentedAugmentationSubmodule (p := p) rels (n - 1) :=
    fun j => y j - zDown j
  refine ⟨w, ?_, ?_⟩
  · intro j
    have hzker : zDown j ∈ Kprev := by
      have hzpow : (z j : A) ∈ I ^ ((n - 1) + 1) := by
        have hzmem : (z j : A) ∈ I ^ n := by
          simp [I, presentedAugmentationSubmodule]
        have hn' : n = (n - 1) + 1 := by omega
        have hpow : I ^ n = I ^ ((n - 1) + 1) :=
          congrArg (fun m : ℕ => I ^ m) hn'
        exact hpow ▸ hzmem
      change
        ((zDown j :
          presentedAugmentationSubmodule (p := p) rels (n - 1)) :
          A) ∈ I ^ ((n - 1) + 1)
      simpa [zDown] using hzpow
    have hzq : Kprev.mkQ (zDown j) = 0 :=
      (Submodule.Quotient.mk_eq_zero Kprev).mpr hzker
    calc
      Kprev.mkQ (w j) = Kprev.mkQ (y j) - Kprev.mkQ (zDown j) := by
        simp [w]
      _ = Kprev.mkQ (y j) := by
        rw [hzq, sub_zero]
      _ = (x : pGTarget (p := p) rels n) j := hy j
  · have hsum_w :
        (∑ j,
          ((w j :
            presentedAugmentationSubmodule (p := p) rels (n - 1)) :
            A) *
            genDiff j) =
          (∑ j,
            ((y j :
              presentedAugmentationSubmodule (p := p) rels (n - 1)) :
              A) *
              genDiff j) -
            ∑ j,
              ((z j :
                presentedAugmentationSubmodule (p := p) rels n) :
                A) *
                genDiff j := by
      dsimp [w, zDown]
      calc
        (∑ j, (↑(y j) - ↑(z j)) * genDiff j) =
            ∑ j, (↑(y j) * genDiff j - ↑(z j) * genDiff j) := by
          apply Finset.sum_congr rfl
          intro j _hj
          rw [sub_mul]
        _ =
            (∑ j, ↑(y j) * genDiff j) -
              ∑ j, ↑(z j) * genDiff j := by
          rw [Finset.sum_sub_distrib]
    have hz' :
        (∑ j,
          ((z j :
            presentedAugmentationSubmodule (p := p) rels n) :
            A) *
            genDiff j) =
          ∑ j,
            ((y j :
              presentedAugmentationSubmodule (p := p) rels (n - 1)) :
              A) *
              genDiff j := by
      simpa [genDiff] using hz
    rw [hsum_w, hz']
    exact sub_self _

/--
Every homogeneous high-degree kernel class is the initial class of an exact
relation-module element in the matching filtration degree.
-/
theorem presented_high_surjective
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    [Finite (PresentedGroup (Set.range rels))]
    (n : ℕ)
    (hn : 2 ≤ n) :
    Function.Surjective
      (presentedFiltrationHigh
        (p := p) rels n hn) := by
  classical
  intro x
  let A := presentedGroupAlgebra (p := p) rels
  rcases presented_boundary_representative
      (p := p) rels n hn x with
    ⟨y, hy_layer, hy_boundary⟩
  let rel : presentedRelationModule (p := p) rels :=
    ⟨fun j => (y j : A), by
      rw [LinearMap.mem_ker]
      change
        (∑ j,
          ((y j :
            presentedAugmentationSubmodule (p := p) rels (n - 1)) :
            A) *
            presentedGeneratorDifference (p := p) rels j) = 0
      exact hy_boundary⟩
  let relF : presentedModuleFiltration (p := p) rels (n - 1) :=
    ⟨rel, by
      intro j
      exact (y j).2⟩
  refine ⟨relF, ?_⟩
  apply Subtype.ext
  funext j
  simpa [presentedFiltrationHigh,
    presentedHighTarget,
    presentedFiltrationCoefficient, relF, rel, A]
    using hy_layer j

/--
The initial-class map factors through the associated-graded relation-module
layer.
-/
noncomputable def presentedModuleHigh
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (n : ℕ)
    (hn : 2 ≤ n) :
    presentedModuleLayer (p := p) rels (n - 1) →ₗ[ZMod p]
      presentedHighPresentation (p := p) rels n hn :=
  let K := presentedModuleKernel (p := p) rels (n - 1)
  let f :=
    presentedFiltrationHigh
      (p := p) rels n hn
  K.liftQ f (by
    classical
    intro x hx
    apply Subtype.ext
    funext j
    let A := presentedGroupAlgebra (p := p) rels
    let I : Ideal A := presentedAugmentationIdeal (p := p) rels
    let Kprev := presentedAugmentationKernel (p := p) rels (n - 1)
    have hxfil :
        ((x : presentedModuleFiltration (p := p) rels (n - 1)) :
          presentedRelationModule (p := p) rels) ∈
          presentedModuleFiltration (p := p) rels ((n - 1) + 1) := by
      simpa [K, presentedModuleKernel] using hx
    have hxcoeff :
        (((x : presentedModuleFiltration (p := p) rels (n - 1)) :
            presentedRelationModule (p := p) rels) :
            Fin d → A) j ∈
          presentedAugmentationSubmodule (p := p) rels ((n - 1) + 1) :=
      hxfil j
    change
      Kprev.mkQ
          (presentedFiltrationCoefficient
            (p := p) rels (n - 1) x j) = 0
    apply (Submodule.Quotient.mk_eq_zero Kprev).mpr
    change
      ((presentedFiltrationCoefficient
        (p := p) rels (n - 1) x j :
        presentedAugmentationSubmodule (p := p) rels (n - 1)) :
        A) ∈ I ^ ((n - 1) + 1)
    have hxpow :
        (((x : presentedModuleFiltration (p := p) rels (n - 1)) :
            presentedRelationModule (p := p) rels) :
            Fin d → A) j ∈ I ^ ((n - 1) + 1) := by
      simpa [I, presentedAugmentationSubmodule] using hxcoeff
    simpa [presentedFiltrationCoefficient, I] using hxpow)

/--
Every high-degree kernel class is represented by an associated-graded
relation-module class.
-/
theorem presented_module_high
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    [Finite (PresentedGroup (Set.range rels))]
    (n : ℕ)
    (hn : 2 ≤ n) :
    Function.Surjective
      (presentedModuleHigh
        (p := p) rels n hn) := by
  classical
  intro x
  rcases presented_high_surjective
      (p := p) rels n hn x with
    ⟨y, hy⟩
  let K := presentedModuleKernel (p := p) rels (n - 1)
  refine ⟨K.mkQ y, ?_⟩
  simpa [presentedModuleHigh, K] using hy

/--
The exact representative of a homogeneous generator-kernel class is an ungraded
Fox-relator combination.  This packages the numerator representative above with
the already-formal Fox exactness before any filtered control is imposed on the
relator coefficients.
-/
theorem presented_high_representative
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    [Finite (PresentedGroup (Set.range rels))]
    (n : ℕ)
    (hn : 2 ≤ n)
    (x : presentedHighPresentation (p := p) rels n hn) :
    ∃ y : Fin d → presentedAugmentationSubmodule (p := p) rels (n - 1),
      (∀ j,
        (presentedAugmentationKernel (p := p) rels (n - 1)).mkQ (y j) =
          (x : pGTarget (p := p) rels n) j) ∧
      (∑ j,
        ((y j :
          presentedAugmentationSubmodule (p := p) rels (n - 1)) :
          presentedGroupAlgebra (p := p) rels) *
          presentedGeneratorDifference (p := p) rels j) = 0 ∧
      (fun j =>
        ((y j :
          presentedAugmentationSubmodule (p := p) rels (n - 1)) :
          presentedGroupAlgebra (p := p) rels)) ∈
        LinearMap.range (presentedRelatorFox (p := p) rels) := by
  classical
  rcases presented_boundary_representative
      (p := p) rels n hn x with
    ⟨y, hy_layer, hy_boundary⟩
  refine ⟨y, hy_layer, hy_boundary, ?_⟩
  apply presented_boundary_range
    (p := p) rels
  rw [LinearMap.mem_ker]
  change
    (∑ j,
      ((y j :
        presentedAugmentationSubmodule (p := p) rels (n - 1)) :
        presentedGroupAlgebra (p := p) rels) *
        presentedGeneratorDifference (p := p) rels j) = 0
  exact hy_boundary

/--
The exact kernel representative can be lifted to the free group algebra in the
matching filtration degree.  Its free boundary lies in `I_F^n` and maps to zero
in the presented algebra, hence is a filtered element of the relator-difference
ideal.
-/
theorem filtered_boundary_lift
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    [Finite (PresentedGroup (Set.range rels))]
    (n : ℕ)
    (hn : 2 ≤ n)
    (x : presentedHighPresentation (p := p) rels n hn) :
    ∃ y : Fin d → presentedAugmentationSubmodule (p := p) rels (n - 1),
    ∃ Y : Fin d →
        ((GShafar.augmentationIdeal
          (R := ZMod p)
          (G := FreeGroup (Fin d))) ^ (n - 1)).restrictScalars (ZMod p),
      (∀ j,
        (presentedAugmentationKernel (p := p) rels (n - 1)).mkQ (y j) =
          (x : pGTarget (p := p) rels n) j) ∧
      (∀ j,
        GShafar.presentedAlgebra
            (R := ZMod p) (Set.range rels)
            (Y j : MonoidAlgebra (ZMod p) (FreeGroup (Fin d))) =
          (y j : presentedGroupAlgebra (p := p) rels)) ∧
      (let B : MonoidAlgebra (ZMod p) (FreeGroup (Fin d)) :=
        ∑ j,
          (Y j : MonoidAlgebra (ZMod p) (FreeGroup (Fin d))) *
            augmentationDifference (ZMod p) (FreeGroup (Fin d)) (FreeGroup.of j)
       B ∈
        (GShafar.augmentationIdeal
          (R := ZMod p)
          (G := FreeGroup (Fin d))) ^ n ∧
       GShafar.presentedAlgebra
          (R := ZMod p) (Set.range rels) B = 0) := by
  classical
  let F := FreeGroup (Fin d)
  let AF := MonoidAlgebra (ZMod p) F
  let IF : Ideal AF :=
    GShafar.augmentationIdeal (R := ZMod p) (G := F)
  let A := presentedGroupAlgebra (p := p) rels
  let qmap : AF →+* A :=
    GShafar.presentedAlgebra
      (R := ZMod p) (Set.range rels)
  rcases presented_boundary_representative
      (p := p) rels n hn x with
    ⟨y, hy_layer, hy_boundary⟩
  choose Y hY using fun j : Fin d =>
    presented_submodule_lift
      (p := p) rels (n - 1) (y j)
  refine ⟨y, Y, hy_layer, hY, ?_⟩
  let B : AF :=
    ∑ j,
      (Y j : AF) *
        augmentationDifference (ZMod p) F (FreeGroup.of j)
  have hBmem : B ∈ IF ^ n := by
    dsimp [B]
    refine Submodule.sum_mem _ ?_
    intro j _hj
    have hdiff : augmentationDifference (ZMod p) F (FreeGroup.of j) ∈ IF := by
      simpa [IF, F] using
        augmentation_difference_ideal
          (ZMod p) F (FreeGroup.of j)
    have hprod : (Y j : AF) *
          augmentationDifference (ZMod p) F (FreeGroup.of j) ∈
        IF ^ (n - 1) * IF :=
      Ideal.mul_mem_mul (Y j).2 hdiff
    have hdegree : (n - 1) + 1 = n := by omega
    have hpow : IF ^ (n - 1) * IF = IF ^ n := by
      calc
        IF ^ (n - 1) * IF = IF ^ (n - 1) * IF ^ (1 : ℕ) := by
          rw [Submodule.pow_one]
        _ = IF ^ ((n - 1) + 1) := by
          rw [Ideal.IsTwoSided.pow_add]
        _ = IF ^ n := by
          rw [hdegree]
    simpa [hpow] using hprod
  have hqB : qmap B = 0 := by
    calc
      qmap B =
          ∑ j,
            qmap (Y j : AF) *
              qmap (augmentationDifference (ZMod p) F (FreeGroup.of j)) := by
        dsimp [B]
        rw [map_sum]
        apply Finset.sum_congr rfl
        intro j _hj
        rw [map_mul]
      _ =
          ∑ j,
            (y j : A) *
              presentedGeneratorDifference (p := p) rels j := by
        apply Finset.sum_congr rfl
        intro j _hj
        rw [hY j]
        simpa [qmap, F] using
          congrArg (fun z : A => (y j : A) * z)
            (presented_algebra_difference
              (p := p) rels j)
      _ = 0 := by
        simpa [A] using hy_boundary
  change B ∈ IF ^ n ∧ qmap B = 0
  exact ⟨hBmem, hqB⟩

/--
The free filtered boundary lift also reads back the chosen homogeneous generator
representative under the free Fox derivatives.  This is the relation-ideal
boundary map that will be used to turn filtered relation-ideal generators into
kernel representatives.
-/
theorem filtered_boundary_derivative
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    [Finite (PresentedGroup (Set.range rels))]
    (n : ℕ)
    (hn : 2 ≤ n)
    (x : presentedHighPresentation (p := p) rels n hn) :
    ∃ y : Fin d → presentedAugmentationSubmodule (p := p) rels (n - 1),
    ∃ Y : Fin d →
        ((GShafar.augmentationIdeal
          (R := ZMod p)
          (G := FreeGroup (Fin d))) ^ (n - 1)).restrictScalars (ZMod p),
      (∀ j,
        (presentedAugmentationKernel (p := p) rels (n - 1)).mkQ (y j) =
          (x : pGTarget (p := p) rels n) j) ∧
      (∀ j,
        GShafar.presentedAlgebra
            (R := ZMod p) (Set.range rels)
            (Y j : MonoidAlgebra (ZMod p) (FreeGroup (Fin d))) =
          (y j : presentedGroupAlgebra (p := p) rels)) ∧
      (let B : MonoidAlgebra (ZMod p) (FreeGroup (Fin d)) :=
        ∑ j,
          (Y j : MonoidAlgebra (ZMod p) (FreeGroup (Fin d))) *
            augmentationDifference (ZMod p) (FreeGroup (Fin d)) (FreeGroup.of j)
       (∀ j,
          GShafar.presentedAlgebra
              (R := ZMod p) (Set.range rels)
              (freeFoxDerivative (ZMod p) (Fin d) j B) =
            (y j : presentedGroupAlgebra (p := p) rels)) ∧
       B ∈
        (GShafar.augmentationIdeal
          (R := ZMod p)
          (G := FreeGroup (Fin d))) ^ n ∧
       GShafar.presentedAlgebra
          (R := ZMod p) (Set.range rels) B = 0) := by
  classical
  let F := FreeGroup (Fin d)
  let AF := MonoidAlgebra (ZMod p) F
  let A := presentedGroupAlgebra (p := p) rels
  let qmap : AF →+* A :=
    GShafar.presentedAlgebra
      (R := ZMod p) (Set.range rels)
  rcases filtered_boundary_lift
      (p := p) rels n hn x with
    ⟨y, Y, hy_layer, hY, hBmem, hqB⟩
  refine ⟨y, Y, hy_layer, hY, ?_⟩
  let B : AF :=
    ∑ j,
      (Y j : AF) *
        augmentationDifference (ZMod p) F (FreeGroup.of j)
  have hD :
      ∀ j, qmap (freeFoxDerivative (ZMod p) (Fin d) j B) =
        (y j : A) := by
    intro j
    dsimp [B]
    simp [algebra_fox_derivative,
            augmentationDifference, GShafar.augmentationHom,
      GShafar.augmentationCharacter, hY, qmap, F]
  change (∀ j, qmap (freeFoxDerivative (ZMod p) (Fin d) j B) =
      (y j : A)) ∧ B ∈ _ ∧ qmap B = 0
  exact ⟨hD, hBmem, hqB⟩

/--
The derivative classes of filtered elements in the free relator ideal, in one
high degree.

An element of this submodule is represented by the pushed-forward Fox
derivatives of some free group-algebra element `B ∈ I_F^n` that maps to zero in
the presented group algebra.  This is the filtered relation-ideal layer that
contains the homogeneous generator-boundary kernel.
-/
def presentedHighDerivative
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (n : ℕ) :
    Submodule (ZMod p) (pGTarget (p := p) rels n) where
  carrier := by
    classical
    let F := FreeGroup (Fin d)
    let AF := MonoidAlgebra (ZMod p) F
    let IF : Ideal AF :=
      GShafar.augmentationIdeal (R := ZMod p) (G := F)
    let A := presentedGroupAlgebra (p := p) rels
    let qmap : AF →+* A :=
      GShafar.presentedAlgebra
        (R := ZMod p) (Set.range rels)
    exact
      {x |
        ∃ B : AF,
          B ∈ IF ^ n ∧
          qmap B = 0 ∧
          ∃ y : Fin d → presentedAugmentationSubmodule (p := p) rels (n - 1),
            (∀ j,
              qmap (freeFoxDerivative (ZMod p) (Fin d) j B) =
                (y j : A)) ∧
            x =
              fun j =>
                (presentedAugmentationKernel (p := p) rels (n - 1)).mkQ
                  (y j)}
  add_mem' := by
    classical
    intro x z hx hz
    let F := FreeGroup (Fin d)
    let AF := MonoidAlgebra (ZMod p) F
    let IF : Ideal AF :=
      GShafar.augmentationIdeal (R := ZMod p) (G := F)
    let A := presentedGroupAlgebra (p := p) rels
    let qmap : AF →+* A :=
      GShafar.presentedAlgebra
        (R := ZMod p) (Set.range rels)
    rcases hx with ⟨B, hBmem, hqB, y, hyD, rfl⟩
    rcases hz with ⟨C, hCmem, hqC, w, hwD, rfl⟩
    refine ⟨B + C, (IF ^ n).add_mem hBmem hCmem, ?_, y + w, ?_, ?_⟩
    · rw [map_add, hqB, hqC, add_zero]
    · intro j
      change qmap ((freeFoxDerivative (ZMod p) (Fin d) j) (B + C)) =
        ((y + w) j : A)
      rw [LinearMap.map_add, map_add, hyD j, hwD j]
      rfl
    · funext j
      simp [Pi.add_apply]
  zero_mem' := by
    classical
    let F := FreeGroup (Fin d)
    let AF := MonoidAlgebra (ZMod p) F
    let IF : Ideal AF :=
      GShafar.augmentationIdeal (R := ZMod p) (G := F)
    let A := presentedGroupAlgebra (p := p) rels
    let qmap : AF →+* A :=
      GShafar.presentedAlgebra
        (R := ZMod p) (Set.range rels)
    refine ⟨0, (IF ^ n).zero_mem, map_zero qmap, 0, ?_, ?_⟩
    · intro j
      rw [map_zero, map_zero]
      rfl
    · funext j
      simp
  smul_mem' := by
    classical
    intro c x hx
    let F := FreeGroup (Fin d)
    let AF := MonoidAlgebra (ZMod p) F
    let IF : Ideal AF :=
      GShafar.augmentationIdeal (R := ZMod p) (G := F)
    let A := presentedGroupAlgebra (p := p) rels
    let qmap : AF →+* A :=
      GShafar.presentedAlgebra
        (R := ZMod p) (Set.range rels)
    rcases hx with ⟨B, hBmem, hqB, y, hyD, rfl⟩
    refine ⟨c • B, ?_, ?_, c • y, ?_, ?_⟩
    · simpa [Algebra.smul_def] using
        (IF ^ n).mul_mem_left (algebraMap (ZMod p) AF c) hBmem
    · rw [Algebra.smul_def, map_mul, hqB, mul_zero]
    · intro j
      change qmap ((freeFoxDerivative (ZMod p) (Fin d) j) (c • B)) =
        ((c • y) j : A)
      rw [LinearMap.map_smul]
      have hmap :
          qmap (c • ((freeFoxDerivative (ZMod p) (Fin d) j) B)) =
            c • qmap ((freeFoxDerivative (ZMod p) (Fin d) j) B) := by
        simpa [qmap, F, GShafar.presentedAlgebra,
          MonoidAlgebra.mapDomainRingHom] using
          (Finsupp.mapDomain_smul
            (f := fun g : FreeGroup (Fin d) =>
              PresentedGroup.mk (Set.range rels) g)
            c ((freeFoxDerivative (ZMod p) (Fin d) j) B))
      rw [hmap, hyD j]
      simp [Pi.smul_apply]
    · funext j
      simp [Pi.smul_apply]

/--
The associated-graded relator Fox map in high degree `n`.

For an active relator `i`, the source coefficient lies in the shifted layer
`I^(n - depth i) / I^(n - depth i + 1)`.  Multiplying it on the right by the
Fox coefficient of the relator, which has degree at least `depth i - 1`, lands
in the generator target layer `I^(n - 1) / I^n`.
-/
noncomputable def presentedHighFox
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (depth : Fin r → ℕ)
    (hdepth :
      ∀ i, rels i ∈ zassenhausFiltration p (FreeGroup (Fin d)) (depth i))
    (hdepth2 : ∀ i, 2 ≤ depth i)
    (n : ℕ) :
    pHSrc (p := p) rels depth n →ₗ[ZMod p]
      pGTarget (p := p) rels n where
  toFun c := fun j =>
    ∑ i : pARelato depth n,
      presentedAugmentationMul
        (p := p) (rels := rels)
        (m := depth i.1 - 1) (n := n - depth i.1) (k := n - 1)
        (by
          have _hi : depth i.1 ≤ n := i.2
          have hdi : 2 ≤ depth i.1 := hdepth2 i.1
          omega)
        (presentedFoxCoefficient (p := p) rels i.1 j)
        (presented_relator_fox
          (p := p) rels hdepth hdepth2 i.1 j)
        (c i)
  map_add' c e := by
    ext j
    simp [Pi.add_apply, Finset.sum_add_distrib]
  map_smul' a c := by
    ext j
    simp [Pi.smul_apply, Finset.smul_sum]

/-- The high-degree relator Fox map on explicit augmentation-power representatives. -/
lemma presented_fox_mk
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (depth : Fin r → ℕ)
    (hdepth :
      ∀ i, rels i ∈ zassenhausFiltration p (FreeGroup (Fin d)) (depth i))
    (hdepth2 : ∀ i, 2 ≤ depth i)
    (n : ℕ)
    (c : ∀ i : pARelato depth n,
      presentedAugmentationSubmodule (p := p) rels (n - depth i.1)) :
    presentedHighFox
        (p := p) rels depth hdepth hdepth2 n
        (fun i =>
          (presentedAugmentationKernel
            (p := p) rels (n - depth i.1)).mkQ (c i)) =
      fun j =>
        (presentedAugmentationKernel (p := p) rels (n - 1)).mkQ
          (∑ i : pARelato depth n,
            presentedRightMul
              (p := p) (rels := rels)
              (m := depth i.1 - 1) (n := n - depth i.1) (k := n - 1)
              (by
                have _hi : depth i.1 ≤ n := i.2
                have hdi : 2 ≤ depth i.1 := hdepth2 i.1
                omega)
              (presentedFoxCoefficient (p := p) rels i.1 j)
              (presented_relator_fox
                (p := p) rels hdepth hdepth2 i.1 j)
              (c i)) := by
  classical
  funext j
  let K := presentedAugmentationKernel (p := p) rels (n - 1)
  calc
    presentedHighFox
        (p := p) rels depth hdepth hdepth2 n
        (fun i =>
          (presentedAugmentationKernel
            (p := p) rels (n - depth i.1)).mkQ (c i)) j
        =
        ∑ i : pARelato depth n,
          K.mkQ
            (presentedRightMul
              (p := p) (rels := rels)
              (m := depth i.1 - 1) (n := n - depth i.1) (k := n - 1)
              (by
                have _hi : depth i.1 ≤ n := i.2
                have hdi : 2 ≤ depth i.1 := hdepth2 i.1
                omega)
              (presentedFoxCoefficient (p := p) rels i.1 j)
              (presented_relator_fox
                (p := p) rels hdepth hdepth2 i.1 j)
              (c i)) := by
          dsimp [presentedHighFox, K]
          apply Finset.sum_congr rfl
          intro i _hi
          exact presented_augmentation_mk
            (p := p) (rels := rels)
            (m := depth i.1 - 1) (n := n - depth i.1) (k := n - 1)
            (by
              have _hi : depth i.1 ≤ n := i.2
              have hdi : 2 ≤ depth i.1 := hdepth2 i.1
              omega)
            (presentedFoxCoefficient (p := p) rels i.1 j)
            (presented_relator_fox
              (p := p) rels hdepth hdepth2 i.1 j)
            (c i)
    _ =
        K.mkQ
          (∑ i : pARelato depth n,
            presentedRightMul
              (p := p) (rels := rels)
              (m := depth i.1 - 1) (n := n - depth i.1) (k := n - 1)
              (by
                have _hi : depth i.1 ≤ n := i.2
                have hdi : 2 ≤ depth i.1 := hdepth2 i.1
                omega)
              (presentedFoxCoefficient (p := p) rels i.1 j)
              (presented_relator_fox
                (p := p) rels hdepth hdepth2 i.1 j)
              (c i)) := by
          exact (map_sum K.mkQ
            (fun i : pARelato depth n =>
              presentedRightMul
                (p := p) (rels := rels)
                (m := depth i.1 - 1) (n := n - depth i.1) (k := n - 1)
                (by
                  have _hi : depth i.1 ≤ n := i.2
                  have hdi : 2 ≤ depth i.1 := hdepth2 i.1
                  omega)
                (presentedFoxCoefficient (p := p) rels i.1 j)
                (presented_relator_fox
                  (p := p) rels hdepth hdepth2 i.1 j)
                (c i))
            Finset.univ).symm

/--
One active relator, with a numerator coefficient in the shifted augmentation
power, gives a filtered relation-module element in degree `n - 1`.
-/
noncomputable def presentedFiltrationSingle
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (depth : Fin r → ℕ)
    (hdepth :
      ∀ i, rels i ∈ zassenhausFiltration p (FreeGroup (Fin d)) (depth i))
    (hdepth2 : ∀ i, 2 ≤ depth i)
    (n : ℕ)
    (i : pARelato depth n) :
    presentedAugmentationSubmodule (p := p) rels (n - depth i.1) →ₗ[ZMod p]
      presentedModuleFiltration (p := p) rels (n - 1) where
  toFun a :=
    ⟨presentedModuleMul
        (p := p) rels (a : presentedGroupAlgebra (p := p) rels)
        (presentedRelatorRelation (p := p) rels i.1),
      by
        classical
        rw [presented_relation_filtration]
        intro j
        let A := presentedGroupAlgebra (p := p) rels
        let I : Ideal A := presentedAugmentationIdeal (p := p) rels
        let coeff :
            presentedAugmentationSubmodule
              (p := p) rels (depth i.1 - 1) :=
          ⟨presentedFoxCoefficient (p := p) rels i.1 j,
            by
              simpa [I, presentedAugmentationSubmodule] using
                presented_relator_fox
                  (p := p) rels hdepth hdepth2 i.1 j⟩
        have ha :
            (a : A) ∈ I ^ (n - depth i.1) := by
          simp [I, presentedAugmentationSubmodule]
        have hprod :
            (a : A) *
                (coeff : A) ∈
              presentedAugmentationSubmodule
                (p := p) rels ((n - depth i.1) + (depth i.1 - 1)) :=
          presented_augmentation_left
            (p := p) (rels := rels)
            (m := n - depth i.1) (n := depth i.1 - 1)
            ha coeff
        have hdegree :
            (n - depth i.1) + (depth i.1 - 1) = n - 1 := by
          have hi : depth i.1 ≤ n := i.2
          have hdi : 2 ≤ depth i.1 := hdepth2 i.1
          omega
        simpa [presentedModuleMul, coeff, A, hdegree]
          using hprod⟩
  map_add' a b := by
    apply Subtype.ext
    apply Subtype.ext
    funext j
    simp [presentedModuleMul, add_mul]
  map_smul' c a := by
    apply Subtype.ext
    apply Subtype.ext
    funext j
    simp [presentedModuleMul]

/--
The preceding numerator map kills the next shifted augmentation power, hence
descends to the associated-graded relation-module layer.
-/
noncomputable def presentedRelationSingle
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (depth : Fin r → ℕ)
    (hdepth :
      ∀ i, rels i ∈ zassenhausFiltration p (FreeGroup (Fin d)) (depth i))
    (hdepth2 : ∀ i, 2 ≤ depth i)
    (n : ℕ)
    (i : pARelato depth n) :
    pALayer (p := p) rels (n - depth i.1) →ₗ[ZMod p]
      presentedModuleLayer (p := p) rels (n - 1) :=
  let Ks := presentedAugmentationKernel (p := p) rels (n - depth i.1)
  let Kt := presentedModuleKernel (p := p) rels (n - 1)
  Ks.mapQ Kt
    (presentedFiltrationSingle
      (p := p) rels depth hdepth hdepth2 n i)
    (by
      classical
      intro a ha
      change
        ((presentedFiltrationSingle
            (p := p) rels depth hdepth hdepth2 n i a :
            presentedModuleFiltration (p := p) rels (n - 1)) :
            presentedRelationModule (p := p) rels) ∈
          presentedModuleFiltration (p := p) rels ((n - 1) + 1)
      rw [presented_relation_filtration]
      intro j
      let A := presentedGroupAlgebra (p := p) rels
      let I : Ideal A := presentedAugmentationIdeal (p := p) rels
      let coeff :
          presentedAugmentationSubmodule
            (p := p) rels (depth i.1 - 1) :=
        ⟨presentedFoxCoefficient (p := p) rels i.1 j,
          by
            simpa [I, presentedAugmentationSubmodule] using
              presented_relator_fox
                (p := p) rels hdepth hdepth2 i.1 j⟩
      have ha_pow :
          (a : A) ∈ I ^ ((n - depth i.1) + 1) := by
        simpa [I, Ks, presentedAugmentationKernel,
          presentedAugmentationSubmodule] using ha
      have hprod :
          (a : A) *
              (coeff : A) ∈
            presentedAugmentationSubmodule
              (p := p) rels (((n - depth i.1) + 1) + (depth i.1 - 1)) :=
        presented_augmentation_left
          (p := p) (rels := rels)
          (m := (n - depth i.1) + 1) (n := depth i.1 - 1)
          ha_pow coeff
      have hdegree :
          (((n - depth i.1) + 1) + (depth i.1 - 1)) = (n - 1) + 1 := by
        have hi : depth i.1 ≤ n := i.2
        have hdi : 2 ≤ depth i.1 := hdepth2 i.1
        omega
      simpa [presentedFiltrationSingle,
        presentedModuleMul, coeff, A, hdegree]
        using hprod)

/--
The associated-graded relation-module map supplied by the actual relator Fox
relations with shifted augmentation-layer coefficients.
-/
noncomputable def presentedHighLayer
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (depth : Fin r → ℕ)
    (hdepth :
      ∀ i, rels i ∈ zassenhausFiltration p (FreeGroup (Fin d)) (depth i))
    (hdepth2 : ∀ i, 2 ≤ depth i)
    (n : ℕ) :
    pHSrc (p := p) rels depth n →ₗ[ZMod p]
      presentedModuleLayer (p := p) rels (n - 1) :=
  LinearMap.lsum (ZMod p)
    (fun i : pARelato depth n =>
      pALayer (p := p) rels (n - depth i.1))
    (ZMod p)
    (fun i =>
      presentedRelationSingle
        (p := p) rels depth hdepth hdepth2 n i)

/-- The relation-layer relator map on explicit augmentation-power representatives. -/
lemma presented_high_mk
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (depth : Fin r → ℕ)
    (hdepth :
      ∀ i, rels i ∈ zassenhausFiltration p (FreeGroup (Fin d)) (depth i))
    (hdepth2 : ∀ i, 2 ≤ depth i)
    (n : ℕ)
    (a : ∀ i : pARelato depth n,
      presentedAugmentationSubmodule (p := p) rels (n - depth i.1)) :
    presentedHighLayer
        (p := p) rels depth hdepth hdepth2 n
        (fun i =>
          (presentedAugmentationKernel
            (p := p) rels (n - depth i.1)).mkQ (a i)) =
    (presentedModuleKernel (p := p) rels (n - 1)).mkQ
        (∑ i : pARelato depth n,
          presentedFiltrationSingle
            (p := p) rels depth hdepth hdepth2 n i (a i)) := by
  classical
  let K := presentedModuleKernel (p := p) rels (n - 1)
  calc
    presentedHighLayer
        (p := p) rels depth hdepth hdepth2 n
        (fun i =>
          (presentedAugmentationKernel
            (p := p) rels (n - depth i.1)).mkQ (a i))
        =
        ∑ i : pARelato depth n,
          K.mkQ
            (presentedFiltrationSingle
              (p := p) rels depth hdepth hdepth2 n i (a i)) := by
          dsimp [presentedHighLayer,
            presentedRelationSingle, K]
          simp
    _ =
      K.mkQ
        (∑ i : pARelato depth n,
          presentedFiltrationSingle
            (p := p) rels depth hdepth hdepth2 n i (a i)) := by
        exact (map_sum K.mkQ
          (fun i : pARelato depth n =>
            presentedFiltrationSingle
              (p := p) rels depth hdepth hdepth2 n i (a i))
          Finset.univ).symm

/--
Associated-graded generation of the relation module by the actual relator Fox
relations, in every high degree.
-/
def PresentedGradedGeneration
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (depth : Fin r → ℕ)
    (hdepth :
      ∀ i, rels i ∈ zassenhausFiltration p (FreeGroup (Fin d)) (depth i))
    (hdepth2 : ∀ i, 2 ≤ depth i) : Prop :=
  ∀ n (_hn : 2 ≤ n),
    Function.Surjective
      (presentedHighLayer
        (p := p) rels depth hdepth hdepth2 n)

/--
Free-side filtered strictness for the relator-difference ideal.

An element of the free augmentation power `I_F^n` that dies in the presented
group algebra is, modulo `I_F^(n+1)`, a sum of the defining relator
differences with coefficients in the shifted powers `I_F^(n - depth_i)`.
-/
def PresentedFilteredStrictness
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (depth : Fin r → ℕ) : Prop :=
  ∀ n (_hn : 2 ≤ n),
    let F := FreeGroup (Fin d)
    let AF := MonoidAlgebra (ZMod p) F
    let IF : Ideal AF :=
      GShafar.augmentationIdeal (R := ZMod p) (G := F)
    let qmap : AF →+*
        presentedGroupAlgebra (p := p) rels :=
      GShafar.presentedAlgebra
        (R := ZMod p) (Set.range rels)
    ∀ B : AF,
      B ∈ IF ^ n →
      qmap B = 0 →
        ∃ a : ∀ i : pARelato depth n,
            (IF ^ (n - depth i.1)).restrictScalars (ZMod p),
          B -
              ∑ i : pARelato depth n,
                (a i : AF) *
                  augmentationDifference (ZMod p) F (rels i.1) ∈
            IF ^ (n + 1)

/--
Jennings-Fox exactness for a filtered finite presentation.

The substantive exactness hypothesis is free-side filtered strictness of the
relator-difference ideal: modulo the next augmentation power, every filtered
relator-ideal element is a shifted combination of the defining relators.
Consequently, their Fox relations generate the associated graded relation
module in every high degree.
-/
theorem associated_generation_exactness
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (depth : Fin r → ℕ)
    (hdepth :
      ∀ i, rels i ∈ zassenhausFiltration p (FreeGroup (Fin d)) (depth i))
    (hdepth2 : ∀ i, 2 ≤ depth i)
    (hstrict : PresentedFilteredStrictness
      (p := p) rels depth) :
    PresentedGradedGeneration
      (p := p) rels depth hdepth hdepth2 := by
  classical
  intro n hn x
  refine Submodule.Quotient.induction_on
    (p := presentedModuleKernel (p := p) rels (n - 1)) x ?_
  intro y
  let F := FreeGroup (Fin d)
  let AF := MonoidAlgebra (ZMod p) F
  let IF : Ideal AF :=
    GShafar.augmentationIdeal (R := ZMod p) (G := F)
  let A := presentedGroupAlgebra (p := p) rels
  let I : Ideal A := presentedAugmentationIdeal (p := p) rels
  let qmap : AF →+* A :=
    GShafar.presentedAlgebra
      (R := ZMod p) (Set.range rels)
  let genDiffF : Fin d → AF :=
    fun j => augmentationDifference (ZMod p) F (FreeGroup.of j)
  choose Y hY using fun j : Fin d =>
    presented_submodule_lift
      (p := p) rels (n - 1)
      (presentedFiltrationCoefficient
        (p := p) rels (n - 1) y j)
  let B : AF := ∑ j, (Y j : AF) * genDiffF j
  have hBmem : B ∈ IF ^ n := by
    dsimp [B, genDiffF]
    refine Submodule.sum_mem _ ?_
    intro j _hj
    have hdiff : augmentationDifference (ZMod p) F (FreeGroup.of j) ∈ IF := by
      simpa [IF, F] using
        augmentation_difference_ideal
          (ZMod p) F (FreeGroup.of j)
    have hprod :
        (Y j : AF) *
            augmentationDifference (ZMod p) F (FreeGroup.of j) ∈
          IF ^ (n - 1) * IF :=
      Ideal.mul_mem_mul (Y j).2 hdiff
    have hpow : IF ^ (n - 1) * IF = IF ^ n := by
      calc
        IF ^ (n - 1) * IF = IF ^ (n - 1) * IF ^ (1 : ℕ) := by
          rw [Submodule.pow_one]
        _ = IF ^ ((n - 1) + 1) := by
          rw [Ideal.IsTwoSided.pow_add]
        _ = IF ^ n := by
          congr 1
          omega
    simpa [hpow]
      using hprod
  have hqB : qmap B = 0 := by
    have hy_boundary :
        presentedGeneratorBoundary (p := p) rels
            ((y : presentedRelationModule (p := p) rels) : Fin d → A) = 0 :=
      LinearMap.mem_ker.mp
        ((y : presentedRelationModule (p := p) rels).2)
    calc
      qmap B =
          ∑ j,
            qmap (Y j : AF) *
              qmap (genDiffF j) := by
        dsimp [B]
        rw [map_sum]
        apply Finset.sum_congr rfl
        intro j _hj
        rw [map_mul]
      _ =
          ∑ j,
            (((y : presentedRelationModule (p := p) rels) :
                Fin d → A) j) *
              presentedGeneratorDifference (p := p) rels j := by
        apply Finset.sum_congr rfl
        intro j _hj
        rw [hY j]
        simpa [qmap, genDiffF, F,
          presentedFiltrationCoefficient] using
          congrArg
            (fun z : A =>
              ((presentedFiltrationCoefficient
                (p := p) rels (n - 1) y j :
                presentedAugmentationSubmodule (p := p) rels (n - 1)) :
                A) * z)
              (presented_algebra_difference
                (p := p) rels j)
      _ = 0 := by
        change
          presentedGeneratorBoundary (p := p) rels
              ((y : presentedRelationModule (p := p) rels) : Fin d → A) = 0
        exact hy_boundary
  rcases hstrict n hn B hBmem hqB with ⟨aF, hBstrict⟩
  let aP : ∀ i : pARelato depth n,
      presentedAugmentationSubmodule (p := p) rels (n - depth i.1) :=
    fun i =>
      ⟨qmap (aF i : AF), by
        have hmap :
            qmap (aF i : AF) ∈
              (presentedAugmentationIdeal (p := p) rels) ^
                (n - depth i.1) := by
          have hfree : (aF i : AF) ∈ IF ^ (n - depth i.1) := by
            simp [IF]
          simpa [qmap, I, presentedAugmentationIdeal, F, A] using
            GShafar.presented_algebra_pow
              (R := ZMod p)
              (α := Fin d)
              (rels := Set.range rels)
              hfree
        simpa [I, presentedAugmentationSubmodule] using hmap⟩
  let c : pHSrc (p := p) rels depth n :=
    fun i =>
      (presentedAugmentationKernel
        (p := p) rels (n - depth i.1)).mkQ (aP i)
  refine ⟨c, ?_⟩
  let relSum : presentedModuleFiltration (p := p) rels (n - 1) :=
    ∑ i : pARelato depth n,
      presentedFiltrationSingle
        (p := p) rels depth hdepth hdepth2 n i (aP i)
  have hmapc :
      presentedHighLayer
          (p := p) rels depth hdepth hdepth2 n c =
        (presentedModuleKernel (p := p) rels (n - 1)).mkQ
          relSum := by
    simpa [c, relSum] using
      presented_high_mk
        (p := p) rels depth hdepth hdepth2 n aP
  rw [hmapc]
  let Rsum : AF :=
    ∑ i : pARelato depth n,
      (aF i : AF) * augmentationDifference (ZMod p) F (rels i.1)
  let C : AF := B - Rsum
  have hCmem : C ∈ IF ^ (n + 1) := by
    simpa [C, Rsum, F, AF, IF, qmap] using hBstrict
  have hdiff_mem :
      y - relSum ∈ presentedModuleKernel (p := p) rels (n - 1) := by
    change
      ((y - relSum :
          presentedModuleFiltration (p := p) rels (n - 1)) :
          presentedRelationModule (p := p) rels) ∈
        presentedModuleFiltration (p := p) rels ((n - 1) + 1)
    rw [presented_relation_filtration]
    intro j
    have hDfree :
        freeFoxDerivative (ZMod p) (Fin d) j C ∈ IF ^ n := by
      have hpred :=
        fox_derivative_pred
          (ZMod p) (Fin d) j (n := n + 1) hCmem
      simpa [IF] using hpred
    have hDpresent :
        qmap (freeFoxDerivative (ZMod p) (Fin d) j C) ∈
          I ^ n := by
      simpa [qmap, I, presentedAugmentationIdeal, F, A] using
        GShafar.presented_algebra_pow
          (R := ZMod p)
          (α := Fin d)
          (rels := Set.range rels)
          hDfree
    have hDB :
        qmap (freeFoxDerivative (ZMod p) (Fin d) j B) =
          (((y : presentedRelationModule (p := p) rels) :
              Fin d → A) j) := by
      calc
        qmap (freeFoxDerivative (ZMod p) (Fin d) j B) =
            ∑ k : Fin d,
              qmap
                (freeFoxDerivative (ZMod p) (Fin d) j
                  ((Y k : AF) * genDiffF k)) := by
              dsimp [B]
              rw [map_sum, map_sum]
        _ =
            ∑ k : Fin d, if k = j then qmap (Y k : AF) else 0 := by
              apply Finset.sum_congr rfl
              intro k _hk
              rw [algebra_fox_derivative, map_add, map_mul]
              simp [genDiffF, augmentationDifference,
                                GShafar.augmentationHom,
                GShafar.augmentationCharacter, qmap, F]
        _ = qmap (Y j : AF) := by
              simp
        _ =
            (((y : presentedRelationModule (p := p) rels) :
              Fin d → A) j) := by
              simpa [presentedFiltrationCoefficient] using hY j
    have hDR :
        qmap (freeFoxDerivative (ZMod p) (Fin d) j Rsum) =
          ∑ i : pARelato depth n,
            (aP i : A) *
              presentedFoxCoefficient (p := p) rels i.1 j := by
      dsimp [Rsum]
      rw [map_sum]
      rw [map_sum]
      apply Finset.sum_congr rfl
      intro i _hi
      rw [algebra_fox_derivative, map_add, map_mul]
      have haug_rel :
          GShafar.augmentationHom (ZMod p) F
              (augmentationDifference (ZMod p) F (rels i.1)) = 0 := by
        simp [augmentationDifference, GShafar.augmentationHom,
          GShafar.augmentationCharacter, F]
      have hq_rel :
          qmap (augmentationDifference (ZMod p) F (rels i.1)) = 0 := by
        simpa [qmap, F] using
          presented_difference_zero
            (p := p) rels i.1
      have hDdiff :
          freeFoxDerivative (ZMod p) (Fin d) j
              (augmentationDifference (ZMod p) F (rels i.1)) =
            groupFoxDerivative (ZMod p) j (rels i.1) := by
        unfold augmentationDifference
        rw [map_sub, fox_derivative_one, sub_zero]
        rw [free_derivative_single]
        simp
      simp only [MonoidAlgebra.mapDomainRingHom, haug_rel, zero_smul,
        RingHom.coe_mk, MonoidHom.coe_mk, OneHom.coe_mk,
        MonoidAlgebra.mapDomain, hDdiff, presentedFoxCoefficient,
        GShafar.presentedAlgebra, add_eq_right, qmap, F, aP]
      exact Finsupp.mapDomain_zero
    have hDC :
        qmap (freeFoxDerivative (ZMod p) (Fin d) j C) =
          (((y : presentedRelationModule (p := p) rels) :
              Fin d → A) j) -
            ∑ i : pARelato depth n,
              (aP i : A) *
                presentedFoxCoefficient (p := p) rels i.1 j := by
      dsimp [C]
      rw [map_sub, map_sub, hDB, hDR]
    have hrelSum_coord :
        (((relSum : presentedModuleFiltration (p := p) rels (n - 1)) :
            presentedRelationModule (p := p) rels) :
            Fin d → A) j =
          ∑ i : pARelato depth n,
            (aP i : A) *
              presentedFoxCoefficient (p := p) rels i.1 j := by
      dsimp [relSum]
      simp [presentedFiltrationSingle,
        presentedModuleMul, aP]
    have hcoord :
        (((y - relSum :
            presentedModuleFiltration (p := p) rels (n - 1)) :
            presentedRelationModule (p := p) rels) :
            Fin d → A) j =
          qmap (freeFoxDerivative (ZMod p) (Fin d) j C) := by
      rw [hDC]
      change
        (((y : presentedRelationModule (p := p) rels) :
            Fin d → A) j) -
          (((relSum : presentedModuleFiltration (p := p) rels (n - 1)) :
            presentedRelationModule (p := p) rels) :
            Fin d → A) j =
        (((y : presentedRelationModule (p := p) rels) :
            Fin d → A) j) -
          ∑ i : pARelato depth n,
            (aP i : A) *
              presentedFoxCoefficient (p := p) rels i.1 j
      rw [hrelSum_coord]
    have htarget :
        (((y - relSum :
            presentedModuleFiltration (p := p) rels (n - 1)) :
            presentedRelationModule (p := p) rels) :
            Fin d → A) j ∈ I ^ n := by
      rw [hcoord]
      exact hDpresent
    have hn' : n = (n - 1) + 1 := by omega
    have hpow : I ^ n = I ^ ((n - 1) + 1) :=
      congrArg (fun m : ℕ => I ^ m) hn'
    simpa [I, presentedAugmentationSubmodule, hpow] using htarget
  have hdiff_mem' :
      relSum - y ∈ presentedModuleKernel (p := p) rels (n - 1) := by
    rw [← neg_sub]
    exact (presentedModuleKernel (p := p) rels (n - 1)).neg_mem
      hdiff_mem
  exact (Submodule.Quotient.eq
    (presentedModuleKernel (p := p) rels (n - 1))).mpr
    hdiff_mem'

/--
Compatibility name exposing the precise filtered-strictness hypothesis used by
`associated_generation_exactness`.
-/
theorem generation_filtered_strictness
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (depth : Fin r → ℕ)
    (hdepth :
      ∀ i, rels i ∈ zassenhausFiltration p (FreeGroup (Fin d)) (depth i))
    (hdepth2 : ∀ i, 2 ≤ depth i)
    (hstrict : PresentedFilteredStrictness
      (p := p) rels depth) :
    PresentedGradedGeneration
      (p := p) rels depth hdepth hdepth2 :=
  associated_generation_exactness
    (p := p) rels depth hdepth hdepth2 hstrict

/--
A surjective associated-graded relator map gives the expected dimension bound
on the relation-module layer.
-/
theorem finrank_high_surjective
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (depth : Fin r → ℕ)
    (hdepth :
      ∀ i, rels i ∈ zassenhausFiltration p (FreeGroup (Fin d)) (depth i))
    (hdepth2 : ∀ i, 2 ≤ depth i)
    [Finite (PresentedGroup (Set.range rels))]
    (n : ℕ)
    (hsurj :
      Function.Surjective
        (presentedHighLayer
          (p := p) rels depth hdepth hdepth2 n)) :
    Module.finrank (ZMod p)
        (presentedModuleLayer (p := p) rels (n - 1)) ≤
      Module.finrank (ZMod p)
        (pHSrc (p := p) rels depth n) := by
  classical
  have hle :=
    Module.finrank_le_finrank_of_rank_le_rank
      (LinearMap.lift_rank_le_of_surjective
        (presentedHighLayer
          (p := p) rels depth hdepth hdepth2 n)
        hsurj)
      (Module.rank_lt_aleph0 (ZMod p)
        (pHSrc (p := p) rels depth n))
  exact hle

/--
Together with the already-constructed surjection from the relation-module
layer onto the homogeneous generator kernel, associated-graded relation-module
generation bounds the kernel by the shifted relator source.
-/
theorem finrank_relation_surjective
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (depth : Fin r → ℕ)
    (hdepth :
      ∀ i, rels i ∈ zassenhausFiltration p (FreeGroup (Fin d)) (depth i))
    (hdepth2 : ∀ i, 2 ≤ depth i)
    [Finite (PresentedGroup (Set.range rels))]
    (n : ℕ)
    (hn : 2 ≤ n)
    (hsurj :
      Function.Surjective
        (presentedHighLayer
          (p := p) rels depth hdepth hdepth2 n)) :
    Module.finrank (ZMod p)
        (presentedHighPresentation (p := p) rels n hn) ≤
      Module.finrank (ZMod p)
        (pHSrc (p := p) rels depth n) := by
  classical
  have hker_le_layer :
      Module.finrank (ZMod p)
          (presentedHighPresentation (p := p) rels n hn) ≤
        Module.finrank (ZMod p)
          (presentedModuleLayer (p := p) rels (n - 1)) := by
    have hlayer_surj :
        Function.Surjective
          (presentedModuleHigh
            (p := p) rels n hn) :=
      presented_module_high
        (p := p) rels n hn
    exact
      Module.finrank_le_finrank_of_rank_le_rank
        (LinearMap.lift_rank_le_of_surjective
          (presentedModuleHigh
            (p := p) rels n hn)
          hlayer_surj)
        (Module.rank_lt_aleph0 (ZMod p)
          (presentedModuleLayer (p := p) rels (n - 1)))
  exact hker_le_layer.trans
    (finrank_high_surjective
      (p := p) rels depth hdepth hdepth2 n hsurj)

/--
Every homogeneous kernel class is represented by a filtered relator-ideal
derivative class.
-/
theorem presented_presentation_derivative
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    [Finite (PresentedGroup (Set.range rels))]
    (n : ℕ)
    (hn : 2 ≤ n) :
    presentedHighPresentation (p := p) rels n hn ≤
      presentedHighDerivative (p := p) rels n := by
  classical
  intro x hx
  let xker : presentedHighPresentation (p := p) rels n hn :=
    ⟨x, hx⟩
  rcases filtered_boundary_derivative
      (p := p) rels n hn xker with
    ⟨y, Y, hy_layer, _hY, hD, hBmem, hqB⟩
  let F := FreeGroup (Fin d)
  let AF := MonoidAlgebra (ZMod p) F
  let B : AF :=
    ∑ j,
      (Y j : AF) *
        augmentationDifference (ZMod p) F (FreeGroup.of j)
  refine ⟨B, ?_, ?_, y, ?_, ?_⟩
  · simpa [B, F] using hBmem
  · simpa [B, F] using hqB
  · intro j
    simpa [B, F] using hD j
  · funext j
    exact (hy_layer j).symm

/--
Zassenhaus depth gives the corresponding free augmentation-ideal depth for a
relator difference.
-/
theorem presented_difference_pow
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (depth : Fin r → ℕ)
    (hdepth :
      ∀ i, rels i ∈ zassenhausFiltration p (FreeGroup (Fin d)) (depth i))
    (i : Fin r) :
    augmentationDifference (ZMod p) (FreeGroup (Fin d)) (rels i) ∈
      (GShafar.augmentationIdeal
        (R := ZMod p)
        (G := FreeGroup (Fin d))) ^ depth i := by
  classical
  have hi :
      rels i ∈ GShafar.augmentationPowerSubgroup
        (R := ZMod p) (G := FreeGroup (Fin d)) (depth i) := by
    exact
      GShafar.zassenhaus_filtration_subgroup
        (p := p) (G := FreeGroup (Fin d)) (depth i) (hdepth i)
  simpa [GShafar.augmentationPowerSubgroup, augmentationDifference]
    using hi

/--
The free-side depth-and-vanishing package for the defining relators.
-/
def PRDataa
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (depth : Fin r → ℕ) : Prop :=
  ∀ i,
    let x : MonoidAlgebra (ZMod p) (FreeGroup (Fin d)) :=
      augmentationDifference (ZMod p) (FreeGroup (Fin d)) (rels i)
    x ∈
        (GShafar.augmentationIdeal
          (R := ZMod p)
          (G := FreeGroup (Fin d))) ^ depth i ∧
      GShafar.presentedAlgebra
        (R := ZMod p) (Set.range rels) x = 0

namespace PRDataa

/-- Unpack the depth half of the relator depth/zero data. -/
theorem free_augmentation_pow
    {p d r : ℕ} [Fact p.Prime]
    {rels : Fin r → FreeGroup (Fin d)}
    {depth : Fin r → ℕ}
    (hrel : PRDataa (p := p) rels depth)
    (i : Fin r) :
    augmentationDifference (ZMod p) (FreeGroup (Fin d)) (rels i) ∈
      (GShafar.augmentationIdeal
        (R := ZMod p)
        (G := FreeGroup (Fin d))) ^ depth i := by
  classical
  have hi := hrel i
  dsimp [PRDataa] at hi
  exact hi.1

/-- Unpack the vanishing half of the relator depth/zero data. -/
theorem presented_relator_zero
    {p d r : ℕ} [Fact p.Prime]
    {rels : Fin r → FreeGroup (Fin d)}
    {depth : Fin r → ℕ}
    (hrel : PRDataa (p := p) rels depth)
    (i : Fin r) :
    GShafar.presentedAlgebra
        (R := ZMod p) (Set.range rels)
        (augmentationDifference (ZMod p) (FreeGroup (Fin d)) (rels i)) = 0 := by
  classical
  have hi := hrel i
  dsimp [PRDataa] at hi
  exact hi.2

end PRDataa

/--
Zassenhaus depth hypotheses supply the free-side depth-and-vanishing package.
-/
theorem presented_relator_depth
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (depth : Fin r → ℕ)
    (hdepth :
      ∀ i, rels i ∈ zassenhausFiltration p (FreeGroup (Fin d)) (depth i)) :
    PRDataa (p := p) rels depth := by
  classical
  intro i
  dsimp [PRDataa]
  constructor
  · exact
      presented_difference_pow
        (p := p) rels depth hdepth i
  · exact
      presented_difference_zero
        (p := p) rels i

/--
Every actual shifted relator-Fox combination is a derivative-layer element.

The converse containment is the filtered relation-ideal spanning statement
needed for Golod-Shafarevich; this theorem proves the formal direction that
the concrete associated-graded relator Fox map lands in the derivative layer.
-/
theorem presented_derivative_relation
    {p d r : ℕ} [Fact p.Prime]
    (rels : Fin r → FreeGroup (Fin d))
    (depth : Fin r → ℕ)
    (hdepth :
      ∀ i, rels i ∈ zassenhausFiltration p (FreeGroup (Fin d)) (depth i))
    (hdepth2 : ∀ i, 2 ≤ depth i)
    (n : ℕ) :
    LinearMap.range
        (presentedHighFox
          (p := p) rels depth hdepth hdepth2 n) ≤
      presentedHighDerivative (p := p) rels n := by
  classical
  intro x hx
  rcases hx with ⟨c, rfl⟩
  let F := FreeGroup (Fin d)
  let AF := MonoidAlgebra (ZMod p) F
  let IF : Ideal AF :=
    GShafar.augmentationIdeal (R := ZMod p) (G := F)
  let A := presentedGroupAlgebra (p := p) rels
  let qmap : AF →+* A :=
    GShafar.presentedAlgebra
      (R := ZMod p) (Set.range rels)
  haveI : IF.IsTwoSided := by
    dsimp [IF, GShafar.augmentationIdeal]
    infer_instance
  have hrepr :
      ∀ i : pARelato depth n,
        ∃ a : presentedAugmentationSubmodule
            (p := p) rels (n - depth i.1),
          (presentedAugmentationKernel
            (p := p) rels (n - depth i.1)).mkQ a = c i := by
    intro i
    exact
      (presentedAugmentationKernel
        (p := p) rels (n - depth i.1)).mkQ_surjective (c i)
  choose a ha using hrepr
  have hsource :
      (fun i : pARelato depth n =>
        (presentedAugmentationKernel
          (p := p) rels (n - depth i.1)).mkQ (a i)) = c := by
    funext i
    exact ha i
  have hlift :
      ∀ i : pARelato depth n,
        ∃ aF : ((IF ^ (n - depth i.1)).restrictScalars (ZMod p)),
          qmap (aF : AF) = (a i : A) := by
    intro i
    simpa [IF, qmap, F, A] using
      presented_submodule_lift
        (p := p) rels (n - depth i.1) (a i)
  choose aF haF using hlift
  let δ : Fin r → AF :=
    fun i => augmentationDifference (ZMod p) F (rels i)
  let B : AF :=
    ∑ i : pARelato depth n, (aF i : AF) * δ i.1
  let yTerm :
      pARelato depth n → Fin d →
        presentedAugmentationSubmodule (p := p) rels (n - 1) :=
    fun i j =>
      presentedRightMul
        (p := p) (rels := rels)
        (m := depth i.1 - 1) (n := n - depth i.1) (k := n - 1)
        (by
          have _hi : depth i.1 ≤ n := i.2
          have hdi : 2 ≤ depth i.1 := hdepth2 i.1
          omega)
        (presentedFoxCoefficient (p := p) rels i.1 j)
        (presented_relator_fox
          (p := p) rels hdepth hdepth2 i.1 j)
        (a i)
  let y : Fin d → presentedAugmentationSubmodule (p := p) rels (n - 1) :=
    fun j => ∑ i : pARelato depth n, yTerm i j
  refine ⟨B, ?_, ?_, y, ?_, ?_⟩
  · dsimp [B]
    apply Submodule.sum_mem
    intro i _hi
    have hδ :
        δ i.1 ∈ IF ^ depth i.1 := by
      simpa [δ, IF, F] using
        presented_difference_pow
          (p := p) rels depth hdepth i.1
    have hprod :
        (aF i : AF) * δ i.1 ∈
          IF ^ (n - depth i.1) * IF ^ depth i.1 :=
      Ideal.mul_mem_mul (aF i).2 hδ
    have htarget :
        (aF i : AF) * δ i.1 ∈
          IF ^ ((n - depth i.1) + depth i.1) := by
      rw [Ideal.IsTwoSided.pow_add]
      exact hprod
    have hdegree : (n - depth i.1) + depth i.1 = n := by
      have _hi : depth i.1 ≤ n := i.2
      omega
    simpa [hdegree] using htarget
  · dsimp [B]
    change qmap (∑ i : pARelato depth n, (aF i : AF) * δ i.1) = 0
    rw [map_sum]
    apply Finset.sum_eq_zero
    intro i _hi
    have hδq : qmap (δ i.1) = 0 := by
      simpa [qmap, δ, F] using
        presented_difference_zero
          (p := p) rels i.1
    rw [map_mul, haF i, hδq, mul_zero]
  · intro j
    change
      qmap (freeFoxDerivative (ZMod p) (Fin d) j B) =
        (y j : A)
    have hDsum :
        freeFoxDerivative (ZMod p) (Fin d) j B =
          ∑ i : pARelato depth n,
            freeFoxDerivative (ZMod p) (Fin d) j
              ((aF i : AF) * δ i.1) := by
      dsimp [B]
      exact map_sum
        (freeFoxDerivative (ZMod p) (Fin d) j)
        (fun i : pARelato depth n =>
          (aF i : AF) * δ i.1)
        Finset.univ
    rw [hDsum, map_sum]
    calc
      ∑ i : pARelato depth n,
          qmap
            (freeFoxDerivative (ZMod p) (Fin d) j
              ((aF i : AF) * δ i.1))
          =
          ∑ i : pARelato depth n,
            (a i : A) *
              presentedFoxCoefficient (p := p) rels i.1 j := by
            apply Finset.sum_congr rfl
            intro i _hi
            have haugδ :
                GShafar.augmentationHom (ZMod p) F (δ i.1) = 0 := by
              simp [δ, F, augmentationDifference,
                GShafar.augmentationHom,
                GShafar.augmentationCharacter]
            have hDδ :
                qmap
                    (freeFoxDerivative (ZMod p) (Fin d) j
                      (δ i.1)) =
                  presentedFoxCoefficient (p := p) rels i.1 j := by
              simp [qmap, δ, F, presentedFoxCoefficient,
                GShafar.presentedAlgebra,
                MonoidAlgebra.mapDomainRingHom, augmentationDifference,
                free_derivative_single]
            calc
              qmap
                  (freeFoxDerivative (ZMod p) (Fin d) j
                    ((aF i : AF) * δ i.1))
                  =
                  qmap
                    ((aF i : AF) *
                      freeFoxDerivative (ZMod p) (Fin d) j
                        (δ i.1)) := by
                    rw [algebra_fox_derivative]
                    simp [haugδ, F]
              _ =
                  qmap (aF i : AF) *
                    qmap
                      (freeFoxDerivative (ZMod p) (Fin d) j
                        (δ i.1)) := by
                    rw [map_mul]
              _ =
                  (a i : A) *
                    presentedFoxCoefficient (p := p) rels i.1 j := by
                    rw [haF i, hDδ]
      _ = (y j : A) := by
            dsimp [y, yTerm]
            simp [presented_augmentation_mul]
  · rw [← hsource]
    simpa [y, yTerm] using
      presented_fox_mk
        (p := p) rels depth hdepth hdepth2 n a
end TBluepr

end Towers
