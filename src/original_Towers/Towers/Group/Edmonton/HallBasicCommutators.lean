/-!
# The Edmonton Notes on Nilpotent Groups: Section 5 basic commutators

This file begins the section on collecting processes and basic commutators.
-/

namespace Towers
namespace Edmonton

open Group
open scoped commutatorElement Pointwise IsMulCommutative

universe u

variable {G : Type u} [Group G]

/-- The sequence `a₀ = a`, `aₖ₊₁ = [aₖ,b]` used in Hall's definition
of `A*b`. -/
def iteratedCommutatorRight (a b : G) : ℕ → G
  | 0 => a
  | n + 1 => hallCommutator (iteratedCommutatorRight a b n) b

@[simp]
lemma iterated_commutator_zero (a b : G) :
    iteratedCommutatorRight a b 0 = a :=
  rfl

@[simp]
lemma iterated_commutator_succ (a b : G) (n : ℕ) :
    iteratedCommutatorRight a b (n + 1) =
      hallCommutator (iteratedCommutatorRight a b n) b :=
  rfl

/-- Hall's set `A*b`: all iterated commutators with `b`, starting from
members of `A` other than `b`. -/
def hallStar (A : Set G) (b : G) : Set G :=
  {x | ∃ a ∈ A, a ≠ b ∧ ∃ n : ℕ, iteratedCommutatorRight a b n = x}

/-- Every iterated commutator from an allowed starting element lies in
`A*b`. -/
lemma iterated_commutator_star
    {A : Set G} {a b : G} (ha : a ∈ A) (hab : a ≠ b) (n : ℕ) :
    iteratedCommutatorRight a b n ∈ hallStar A b :=
  ⟨a, ha, hab, n, rfl⟩

/-- Iterating commutation on the right by an element of `X` descends
through the ambient lower central series of `X`. -/
lemma iterated_ambient_series
    (X : Subgroup G) {a b : G} (ha : a ∈ X) (hb : b ∈ X) :
    ∀ n : ℕ,
      iteratedCommutatorRight a b n ∈ ambientLowerSeries X n := by
  intro n
  induction n with
  | zero =>
      simpa using ha
  | succ n ih =>
      rw [iterated_commutator_succ, ambient_series_succ]
      exact hall_commutator ih hb

/-- The ambient lower central series of a nilpotent subgroup is trivial at
its nilpotency class. -/
lemma ambient_nilpotency_class
    (X : Subgroup G) [Group.IsNilpotent X] :
    ambientLowerSeries X (Group.nilpotencyClass X) = ⊥ := by
  simp [ambientLowerSeries]

/-- The ambient lower central series is decreasing. -/
lemma ambient_lower_antitone (X : Subgroup G) :
    Antitone (ambientLowerSeries X) := by
  intro m n hmn
  exact Subgroup.map_mono (Subgroup.lowerCentralSeries_antitone hmn)

/-- Iterated commutation reaches the identity by the nilpotency class. -/
lemma iterated_commutator_nilpotency
    (X : Subgroup G) [Group.IsNilpotent X]
    {a b : G} (ha : a ∈ X) (hb : b ∈ X) :
    iteratedCommutatorRight a b (Group.nilpotencyClass X) = 1 := by
  apply Subgroup.mem_bot.mp
  rw [← ambient_nilpotency_class X]
  exact iterated_ambient_series X ha hb _

/-- Hall conjugation satisfies `x^y = x [x,y]`. -/
lemma hall_conjugate_commutator (x y : G) :
    hallConjugate x y = x * hallCommutator x y := by
  simp [hallConjugate, hallCommutator, mul_assoc]

/-- Hall's recurrence for replacing commutation by `b⁻¹` with deeper
commutators by `b`. -/
lemma commutator_inv_recurrence (x b : G) :
    hallCommutator x b⁻¹ =
      (hallCommutator (hallCommutator x b) b⁻¹)⁻¹ *
        (hallCommutator x b)⁻¹ := by
  simp [hallCommutator, mul_assoc]

/-- In Hall's collecting process, every commutator `[aₖ,b⁻¹]` belongs to
the subgroup generated by `A*b`. -/
lemma iterated_inv_star
    (A : Set G) {a b : G} (ha : a ∈ A) (hb : b ∈ A) (hab : a ≠ b)
    [Group.IsNilpotent (Subgroup.closure A)] :
    ∀ k : ℕ,
      hallCommutator (iteratedCommutatorRight a b k) b⁻¹ ∈
        Subgroup.closure (hallStar A b) := by
  let X : Subgroup G := Subgroup.closure A
  let K : Subgroup G := Subgroup.closure (hallStar A b)
  let c : ℕ := Group.nilpotencyClass X
  have haX : a ∈ X := Subgroup.subset_closure ha
  have hbX : b ∈ X := Subgroup.subset_closure hb
  have hiter_memK :
      ∀ n : ℕ, iteratedCommutatorRight a b n ∈ K := by
    intro n
    exact Subgroup.subset_closure
      (iterated_commutator_star ha hab n)
  have hiter_c_one :
      iteratedCommutatorRight a b c = 1 := by
    exact iterated_commutator_nilpotency X haX hbX
  have hdown :
      ∀ d : ℕ, d ≤ c →
        hallCommutator (iteratedCommutatorRight a b (c - d)) b⁻¹ ∈ K := by
    intro d hd
    induction d with
    | zero =>
        rw [Nat.sub_zero, hiter_c_one]
        simp [hallCommutator]
    | succ d ih =>
        have hdle : d ≤ c := le_trans (Nat.le_succ d) hd
        have hidx : c - (d + 1) + 1 = c - d := by
          omega
        have hrec :=
          commutator_inv_recurrence
            (iteratedCommutatorRight a b (c - (d + 1))) b
        rw [← iterated_commutator_succ, hidx] at hrec
        rw [hrec]
        exact K.mul_mem (K.inv_mem (ih hdle))
          (K.inv_mem (hiter_memK (c - d)))
  intro k
  by_cases hck : c ≤ k
  · have hmem :
        iteratedCommutatorRight a b k ∈ ambientLowerSeries X c :=
      (ambient_lower_antitone X hck)
        (iterated_ambient_series X haX hbX k)
    have hone : iteratedCommutatorRight a b k = 1 := by
      apply Subgroup.mem_bot.mp
      rw [← ambient_nilpotency_class X]
      exact hmem
    rw [hone]
    simp [hallCommutator]
  · have hkc : k ≤ c := Nat.le_of_lt (lt_of_not_ge hck)
    have h := hdown (c - k) (Nat.sub_le c k)
    simpa [Nat.sub_sub_self hkc] using h

/-- Conjugation by `b⁻¹` preserves the subgroup generated by `A*b`. -/
lemma inv_conjugate_star
    (A : Set G) {b z : G} (hz : z ∈ Subgroup.closure (hallStar A b)) :
    b⁻¹ * z * b ∈ Subgroup.closure (hallStar A b) := by
  let K : Subgroup G := Subgroup.closure (hallStar A b)
  induction hz using Subgroup.closure_induction with
  | mem z hz =>
      obtain ⟨a, ha, hab, n, rfl⟩ := hz
      have hcur :
          iteratedCommutatorRight a b n ∈ K :=
        Subgroup.subset_closure
          (iterated_commutator_star ha hab n)
      have hnext :
          iteratedCommutatorRight a b (n + 1) ∈ K :=
        Subgroup.subset_closure
          (iterated_commutator_star ha hab (n + 1))
      have hprod := K.mul_mem hcur hnext
      rw [iterated_commutator_succ,
        ← hall_conjugate_commutator] at hprod
      simpa [hallConjugate] using hprod
  | one =>
      simp
  | mul x y _ _ hx hy =>
      simpa [mul_assoc] using K.mul_mem hx hy
  | inv x _ hx =>
      simpa [mul_assoc] using K.inv_mem hx

/-- In the nilpotent collecting setting, conjugation by `b` preserves the
subgroup generated by `A*b`. -/
lemma conjugate_closure_star
    (A : Set G) {b z : G} (hb : b ∈ A)
    [Group.IsNilpotent (Subgroup.closure A)]
    (hz : z ∈ Subgroup.closure (hallStar A b)) :
    b * z * b⁻¹ ∈ Subgroup.closure (hallStar A b) := by
  let K : Subgroup G := Subgroup.closure (hallStar A b)
  induction hz using Subgroup.closure_induction with
  | mem z hz =>
      obtain ⟨a, ha, hab, n, rfl⟩ := hz
      have hcur :
          iteratedCommutatorRight a b n ∈ K :=
        Subgroup.subset_closure
          (iterated_commutator_star ha hab n)
      have hstar :
          hallCommutator (iteratedCommutatorRight a b n) b⁻¹ ∈ K :=
        iterated_inv_star
          A ha hb hab n
      have hprod := K.mul_mem hcur hstar
      rw [← hall_conjugate_commutator] at hprod
      simpa [hallConjugate] using hprod
  | one =>
      simp
  | mul x y _ _ hx hy =>
      rw [← conj_mul]
      exact K.mul_mem hx hy
  | inv x _ hx =>
      rw [← conj_inv]
      exact K.inv_mem hx

/-- In the nilpotent collecting setting, `b` normalizes `⟨A*b⟩`. -/
lemma normalizer_closure_star
    (A : Set G) {b : G} (hb : b ∈ A)
    [Group.IsNilpotent (Subgroup.closure A)] :
    b ∈ Subgroup.normalizer (Subgroup.closure (hallStar A b) : Set G) := by
  rw [Subgroup.mem_normalizer_iff]
  intro z
  constructor
  · exact conjugate_closure_star A hb
  · intro hz
    have hback := inv_conjugate_star A hz
    simpa [mul_assoc] using hback

/-- Every iterated commutator used in `A*b` remains in `⟨A⟩`. -/
lemma closure_hall_star (A : Set G) {b : G} (hb : b ∈ A) :
    Subgroup.closure (hallStar A b) ≤ Subgroup.closure A := by
  rw [Subgroup.closure_le]
  rintro _ ⟨a, ha, _hab, n, rfl⟩
  exact (ambient_lower_series (Subgroup.closure A) n)
    (iterated_ambient_series
      (Subgroup.closure A) (Subgroup.subset_closure ha)
        (Subgroup.subset_closure hb) n)

/-- The subgroup generated by `A` is generated by `b` together with
`A*b`. -/
lemma zpowers_sup_star
    (A : Set G) {b : G} (hb : b ∈ A) :
    Subgroup.closure A =
      Subgroup.zpowers b ⊔ Subgroup.closure (hallStar A b) := by
  apply le_antisymm
  · rw [Subgroup.closure_le]
    intro a ha
    by_cases hab : a = b
    · rw [hab]
      exact Subgroup.mem_sup_left (Subgroup.mem_zpowers b)
    · exact Subgroup.mem_sup_right
        (Subgroup.subset_closure
          (iterated_commutator_star ha hab 0))
  · exact sup_le
      (Subgroup.zpowers_le_of_mem (Subgroup.subset_closure hb))
      (closure_hall_star A hb)

/-- **Hall, Lemma 5.1.** If `⟨A⟩` is nilpotent and `b ∈ A`, then
`⟨A⟩ = ⟨b⟩⟨A*b⟩` as a literal pointwise product. -/
theorem closure_zpowers_star
    (A : Set G) {b : G} (hb : b ∈ A)
    [Group.IsNilpotent (Subgroup.closure A)] :
    ((Subgroup.closure A : Subgroup G) : Set G) =
      (Subgroup.zpowers b : Set G) *
        (Subgroup.closure (hallStar A b) : Set G) := by
  rw [zpowers_sup_star A hb,
    Subgroup.coe_mul_of_left_le_normalizer_right]
  exact Subgroup.zpowers_le_of_mem (normalizer_closure_star A hb)

/-! ## Formal collecting -/

/-- Hall's formal commutator expressions in variables indexed by `X`. -/
abbrev FormalCommutator (X : Type*) :=
  FreeMagma X

/-- A formal bracket `[u,v]`. -/
def formalBracket {X : Type*}
    (u v : FormalCommutator X) : FormalCommutator X :=
  u * v

/-- The weight of a formal commutator is its number of variable occurrences. -/
abbrev formalWeight {X : Type*} (u : FormalCommutator X) : ℕ :=
  u.length

@[simp]
lemma formalWeight_variable {X : Type*} (x : X) :
    formalWeight (FreeMagma.of x) = 1 :=
  rfl

@[simp]
lemma formalWeight_bracket {X : Type*} (u v : FormalCommutator X) :
    formalWeight (formalBracket u v) = formalWeight u + formalWeight v :=
  rfl

/-- The formal right-iterated commutator
`a, [a,b], [[a,b],b], ...`. -/
def iteratedFormalBracket {X : Type*}
    (a b : FormalCommutator X) : ℕ → FormalCommutator X
  | 0 => a
  | n + 1 => formalBracket (iteratedFormalBracket a b n) b

@[simp]
lemma iterated_bracket_zero {X : Type*}
    (a b : FormalCommutator X) :
    iteratedFormalBracket a b 0 = a :=
  rfl

@[simp]
lemma iterated_formal_bracket {X : Type*}
    (a b : FormalCommutator X) (n : ℕ) :
    iteratedFormalBracket a b (n + 1) =
      formalBracket (iteratedFormalBracket a b n) b :=
  rfl

@[simp]
lemma formal_bracket_right {X : Type*}
    (a b : FormalCommutator X) (n : ℕ) :
    formalWeight (iteratedFormalBracket a b n) =
      formalWeight a + n * formalWeight b := by
  induction n with
  | zero =>
      simp
  | succ n ih =>
      simp [ih, Nat.succ_mul, Nat.add_assoc]

/-- A presented element of Hall's formal set `A*b`: a starting symbol
different from `b`, together with the number of brackets by `b`. -/
def FSFactor {α : Type*} (b : α) :=
  {a : α // a ≠ b} × ℕ

/-- Interpret a presented star factor as a formal commutator expression. -/
def FSFactor.value {X : Type*} (b : FormalCommutator X)
    (a : FSFactor b) : FormalCommutator X :=
  iteratedFormalBracket a.1.1 b a.2

@[simp]
lemma formal_star_factor {X : Type*}
    (b : FormalCommutator X) (a : FSFactor b) :
    formalWeight (a.value b) =
      formalWeight a.1.1 + a.2 * formalWeight b :=
  formal_bracket_right _ _ _

/-- Expand a presented star factor back into the word which it collects. -/
def expandFormalStar {α : Type*} (b : α)
    (a : FSFactor b) : List α :=
  a.1.1 :: List.replicate a.2 b

/-- Collect the distinguished letter `b` in a formal word. The natural
number is the initial power of `b`; each remaining factor records a
letter different from `b` and the run of copies of `b` following it. -/
def collectFormalWord {α : Type*} [DecidableEq α] (b : α) :
    List α → ℕ × List (FSFactor b)
  | [] => (0, [])
  | a :: q =>
      if h : a = b then
        let z := collectFormalWord b q
        (z.1 + 1, z.2)
      else
        let z := collectFormalWord b q
        (0, (⟨a, h⟩, z.1) :: z.2)

/-- Undo formal collection by replacing every iterated bracket by the
corresponding letter followed by a power of `b`. -/
def uncollectFormalWord {α : Type*} (b : α)
    (z : ℕ × List (FSFactor b)) : List α :=
  List.replicate z.1 b ++ z.2.flatMap (expandFormalStar b)

@[simp]
lemma collect_formal_nil {α : Type*} [DecidableEq α] (b : α) :
    collectFormalWord b [] = (0, []) :=
  rfl

@[simp]
lemma formal_cons_self {α : Type*} [DecidableEq α]
    (b : α) (q : List α) :
    collectFormalWord b (b :: q) =
      ((collectFormalWord b q).1 + 1, (collectFormalWord b q).2) := by
  simp [collectFormalWord]

@[simp]
lemma formal_cons_ne {α : Type*} [DecidableEq α]
    (b : α) {a : α} (h : a ≠ b) (q : List α) :
    collectFormalWord b (a :: q) =
      (0, (⟨a, h⟩, (collectFormalWord b q).1) ::
        (collectFormalWord b q).2) := by
  simp only [collectFormalWord, dif_neg h]
  congr

lemma formal_replicate_append {α : Type*} [DecidableEq α]
    (b : α) (n : ℕ) (q : List α) :
    collectFormalWord b (List.replicate n b ++ q) =
      ((collectFormalWord b q).1 + n, (collectFormalWord b q).2) := by
  induction n with
  | zero =>
      simp
  | succ n ih =>
      simp [List.replicate_succ, ih, Nat.add_assoc]

@[simp]
lemma formal_flat_expand {α : Type*} [DecidableEq α]
    (b : α) (q : List (FSFactor b)) :
    collectFormalWord b (q.flatMap (expandFormalStar b)) = (0, q) := by
  induction q with
  | nil =>
      simp
  | cons a q ih =>
      rcases a with ⟨⟨a, ha⟩, n⟩
      rw [List.flatMap_cons]
      change collectFormalWord b
          (a :: (List.replicate n b ++ q.flatMap (expandFormalStar b))) =
        (0, (⟨a, ha⟩, n) :: q)
      rw [formal_cons_ne b ha,
        formal_replicate_append, ih]
      congr
      simp

@[simp]
lemma collect_formal_uncollect {α : Type*} [DecidableEq α]
    (b : α) (z : ℕ × List (FSFactor b)) :
    collectFormalWord b (uncollectFormalWord b z) = z := by
  rcases z with ⟨n, q⟩
  simp [uncollectFormalWord, formal_replicate_append]

@[simp]
lemma uncollect_formal_collect {α : Type*} [DecidableEq α]
    (b : α) (q : List α) :
    uncollectFormalWord b (collectFormalWord b q) = q := by
  induction q with
  | nil =>
      simp [uncollectFormalWord]
  | cons a q ih =>
      by_cases h : a = b
      · subst a
        calc
          uncollectFormalWord b (collectFormalWord b (b :: q)) =
              b :: uncollectFormalWord b (collectFormalWord b q) := by
            rw [formal_cons_self]
            simp [uncollectFormalWord, Nat.add_comm, List.replicate_add]
          _ = b :: q := congrArg (b :: ·) ih
      · calc
          uncollectFormalWord b (collectFormalWord b (a :: q)) =
              a :: uncollectFormalWord b (collectFormalWord b q) := by
            rw [formal_cons_ne b h]
            change
              (a :: List.replicate (collectFormalWord b q).1 b) ++
                  (collectFormalWord b q).2.flatMap (expandFormalStar b) =
                a :: (List.replicate (collectFormalWord b q).1 b ++
                  (collectFormalWord b q).2.flatMap (expandFormalStar b))
            rfl
          _ = a :: q := congrArg (a :: ·) ih

/-- Formal collection is a bijection between words in `A` and an initial
power of `b` followed by a word in the presented set `A*b`. -/
def formalCollectEquiv {α : Type*} [DecidableEq α] (b : α) :
    List α ≃ ℕ × List (FSFactor b) where
  toFun := collectFormalWord b
  invFun := uncollectFormalWord b
  left_inv := uncollect_formal_collect b
  right_inv := collect_formal_uncollect b

/-- Weight of a formal associative word. -/
def formalWordWeight {α : Type*} (wt : α → ℕ) : List α → ℕ
  | [] => 0
  | a :: q => wt a + formalWordWeight wt q

@[simp]
lemma formal_weight_nil {α : Type*} (wt : α → ℕ) :
    formalWordWeight wt [] = 0 :=
  rfl

@[simp]
lemma formal_weight_cons {α : Type*} (wt : α → ℕ)
    (a : α) (q : List α) :
    formalWordWeight wt (a :: q) = wt a + formalWordWeight wt q :=
  rfl

lemma formal_weight_append {α : Type*} (wt : α → ℕ)
    (q r : List α) :
    formalWordWeight wt (q ++ r) =
      formalWordWeight wt q + formalWordWeight wt r := by
  induction q with
  | nil =>
      simp
  | cons a q ih =>
      simp [ih, Nat.add_assoc]

@[simp]
lemma formal_weight_replicate {α : Type*} (wt : α → ℕ)
    (a : α) (n : ℕ) :
    formalWordWeight wt (List.replicate n a) = n * wt a := by
  induction n with
  | zero =>
      simp
  | succ n ih =>
      simp [List.replicate_succ, ih, Nat.succ_mul, Nat.add_comm]

/-- Weight assigned to the iterated bracket represented by a star factor. -/
def formalStarWeight {α : Type*} (wt : α → ℕ) (b : α)
    (a : FSFactor b) : ℕ :=
  wt a.1.1 + a.2 * wt b

@[simp]
lemma formal_expand_star {α : Type*}
    (wt : α → ℕ) (b : α) (a : FSFactor b) :
    formalWordWeight wt (expandFormalStar b a) =
      formalStarWeight wt b a := by
  simp [expandFormalStar, formalStarWeight]

lemma formal_word_expand {α : Type*}
    (wt : α → ℕ) (b : α) (q : List (FSFactor b)) :
    formalWordWeight wt (q.flatMap (expandFormalStar b)) =
      formalWordWeight (formalStarWeight wt b) q := by
  induction q with
  | nil =>
      simp
  | cons a q ih =>
      simp [formal_weight_append, ih]

lemma formal_weight_uncollect {α : Type*}
    (wt : α → ℕ) (b : α) (z : ℕ × List (FSFactor b)) :
    formalWordWeight wt (uncollectFormalWord b z) =
      z.1 * wt b + formalWordWeight (formalStarWeight wt b) z.2 := by
  simp [uncollectFormalWord, formal_weight_append,
    formal_word_expand]

/-- Hall's formal prefix `b_1^{r_1} ... b_i^{r_i}`. -/
def HallPrefix : ℕ → Type
  | 0 => PUnit
  | i + 1 => HallPrefix i × ℕ

/-- Hall's set `P_i`, presented as a prefix of powers of already collected
basic terms and a residual formal word in the current alphabet. -/
def HallFormalProduct (i : ℕ) (α : Type*) :=
  HallPrefix i × List α

/-- The weight of a presented element of `P_i`. -/
def hallFormalWeight {i : ℕ} {α : Type*}
    (prefixWeight : HallPrefix i → ℕ) (wt : α → ℕ)
    (p : HallFormalProduct i α) : ℕ :=
  prefixWeight p.1 + formalWordWeight wt p.2

/-- Extend a prefix weight after collecting the next basic term `b`. -/
def prefixSuccWeight {i : ℕ} (prefixWeight : HallPrefix i → ℕ)
    (wb : ℕ) : HallPrefix (i + 1) → ℕ
  | (p, r) => prefixWeight p + r * wb

/-- The collecting correspondence from `P_i` to `P_{i+1}`. -/
def hallFormalCollect {i : ℕ} {α : Type*}
    [DecidableEq α] (b : α) :
    HallFormalProduct i α ≃ HallFormalProduct (i + 1) (FSFactor b) where
  toFun p :=
    ((p.1, (formalCollectEquiv b p.2).1), (formalCollectEquiv b p.2).2)
  invFun p :=
    (p.1.1, (formalCollectEquiv b).symm (p.1.2, p.2))
  left_inv p := by
    rcases p with ⟨p, q⟩
    simp
  right_inv p := by
    rcases p with ⟨⟨p, r⟩, q⟩
    simp

/-- **Hall, Lemma 5.2.** Collecting `b_i` gives a one-to-one,
onto, weight-preserving correspondence from `P_{i-1}` to `P_i`.

The index is zero-based here: the displayed map is from `P_i` to
`P_{i+1}`. -/
theorem formal_collect_preserves {i : ℕ} {α : Type*} [DecidableEq α]
    (prefixWeight : HallPrefix i → ℕ) (wt : α → ℕ) (b : α)
    (p : HallFormalProduct i α) :
    hallFormalWeight
        (prefixSuccWeight prefixWeight (wt b))
        (formalStarWeight wt b)
        (hallFormalCollect b p) =
      hallFormalWeight prefixWeight wt p := by
  rcases p with ⟨pre, q⟩
  change prefixWeight pre +
        (collectFormalWord b q).1 * wt b +
        formalWordWeight (formalStarWeight wt b)
          (collectFormalWord b q).2 =
      prefixWeight pre + formalWordWeight wt q
  have hweight :=
    formal_weight_uncollect wt b (collectFormalWord b q)
  rw [uncollect_formal_collect] at hweight
  omega

/-- The fiber of elements having a specified weight. -/
def WeightFiber {α : Type*} (wt : α → ℕ) (w : ℕ) :=
  {a : α // wt a = w}

/-- Lemma 5.2 restricts to an equivalence on every fixed-weight fiber. -/
def formalFiberEquiv {i : ℕ} {α : Type*} [DecidableEq α]
    (prefixWeight : HallPrefix i → ℕ) (wt : α → ℕ) (b : α) (w : ℕ) :
    WeightFiber (hallFormalWeight prefixWeight wt) w ≃
      WeightFiber
        (hallFormalWeight
          (prefixSuccWeight prefixWeight (wt b))
          (formalStarWeight wt b))
        w :=
  (hallFormalCollect b).subtypeEquiv fun p => by
    rw [formal_collect_preserves prefixWeight wt b p]

@[simp]
lemma formal_word_length {α : Type*} (q : List α) :
    formalWordWeight (fun _ => 1) q = q.length := by
  induction q with
  | nil =>
      rfl
  | cons a q ih =>
      simp [ih, Nat.add_comm]

/-- Weight-`w` elements of `P_0` are precisely words of length `w`. -/
def hallFormalVector (α : Type*) (w : ℕ) :
    WeightFiber
        (hallFormalWeight (i := 0) (fun _ => 0) (fun _ : α => 1))
        w ≃
      List.Vector α w where
  toFun p :=
    ⟨p.1.2, by
      simpa [HallFormalProduct, HallPrefix, hallFormalWeight] using p.2⟩
  invFun q :=
    ⟨(PUnit.unit, q.1), by
      simp [hallFormalWeight]⟩
  left_inv p := by
    rcases p with ⟨⟨pre, q⟩, hp⟩
    cases pre
    rfl
  right_inv q := by
    rcases q with ⟨q, hq⟩
    rfl

/-- Weight-`w` elements of `P_0` are naturally indexed by the `w`-tuples
of variables. -/
def hallFormalTuple (α : Type*) (w : ℕ) :
    WeightFiber
        (hallFormalWeight (i := 0) (fun _ => 0) (fun _ : α => 1))
        w ≃
      (Fin w → α) :=
  (hallFormalVector α w).trans
    (Equiv.vectorEquivFin α w)

/-- **Hall, Corollary after Lemma 5.2, uncollected form.** For `q`
variables there are exactly `q^w` formal products of weight `w` in
`P_0`. Each collecting step preserves this fixed-weight cardinality by
`formalFiberEquiv`. -/
theorem card_formal_weight
    (α : Type*) [Fintype α] (w : ℕ) :
    Nat.card
        (WeightFiber
          (hallFormalWeight (i := 0) (fun _ => 0) (fun _ : α => 1))
          w) =
      Fintype.card α ^ w := by
  rw [Nat.card_congr (hallFormalTuple α w),
    Nat.card_fun, Nat.card_fin, Nat.card_eq_fintype_card]

/-! ## The free associative ring collection relation -/

/-- Hall's ring interpretation of `[u,v]`, namely `uv - vu`. -/
def associativeBracket {R : Type*} [Ring R] (u v : R) : R :=
  u * v - v * u

/-- The right-iterated associative bracket
`u, [u,v], [[u,v],v], ...`. -/
def iteratedAssociativeBracket {R : Type*} [Ring R] (u v : R) :
    ℕ → R
  | 0 => u
  | n + 1 =>
      associativeBracket (iteratedAssociativeBracket u v n) v

@[simp]
lemma iterated_associative_zero {R : Type*} [Ring R]
    (u v : R) :
    iteratedAssociativeBracket u v 0 = u :=
  rfl

@[simp]
lemma iterated_associative_succ {R : Type*} [Ring R]
    (u v : R) (n : ℕ) :
    iteratedAssociativeBracket u v (n + 1) =
      associativeBracket (iteratedAssociativeBracket u v n) v :=
  rfl

/-- Iterated right bracketing by `v` is the corresponding power of the
difference between right and left multiplication by `v`. -/
lemma iterated_associative_endomorphism
    {R : Type*} [Ring R] (u v : R) (n : ℕ) :
    iteratedAssociativeBracket u v n =
      ((LinearMap.mulRight ℤ v - LinearMap.mulLeft ℤ v) ^ n) u := by
  induction n with
  | zero =>
      simp
  | succ n ih =>
      rw [iterated_associative_succ, associativeBracket, ih,
        pow_succ', Module.End.mul_apply]
      rfl

/-- **Hall's equation (3), endomorphism form.** This is the binomial
expansion of the operator `rightMul v - leftMul v`. -/
lemma iterated_bracket_endomorphism
    {R : Type*} [Ring R] (u v : R) (n : ℕ) :
    iteratedAssociativeBracket u v n =
      ∑ k ∈ Finset.range (n + 1),
        (((-(LinearMap.mulLeft ℤ v)) ^ k *
            (LinearMap.mulRight ℤ v) ^ (n - k) *
            n.choose k : Module.End ℤ R) u) := by
  rw [iterated_associative_endomorphism]
  have hcomm :
      Commute (-(LinearMap.mulLeft ℤ v)) (LinearMap.mulRight ℤ v) :=
    (LinearMap.commute_mulLeft_right (R := ℤ) v v).neg_left
  rw [show LinearMap.mulRight ℤ v - LinearMap.mulLeft ℤ v =
      -(LinearMap.mulLeft ℤ v) + LinearMap.mulRight ℤ v by abel,
    hcomm.add_pow]
  simp only [LinearMap.sum_apply]

/-- Evaluate a power of negated left multiplication without asking the
simplifier to normalize powers in the endomorphism ring. -/
lemma neg_left_pow {R : Type*} [Ring R] (u v : R) (n : ℕ) :
    ((-(LinearMap.mulLeft ℤ v)) ^ n : Module.End ℤ R) u =
      (-1 : ℤ) ^ n • (v ^ n * u) := by
  induction n with
  | zero =>
      simp
  | succ n ih =>
      simp only [pow_succ', Module.End.mul_apply, LinearMap.neg_apply,
        LinearMap.mulLeft_apply, ih, mul_smul_comm, mul_assoc]
      rw [neg_one_mul, neg_smul]

/-- **Hall's equation (3).** The explicit binomial expansion of the
right-iterated associative commutator. -/
theorem iterated_associative_binomial {R : Type*} [Ring R] (u v : R) (n : ℕ) :
    iteratedAssociativeBracket u v n =
      ∑ k ∈ Finset.range (n + 1),
        ((-1 : ℤ) ^ k * n.choose k) •
          (v ^ k * u * v ^ (n - k)) := by
  rw [iterated_bracket_endomorphism]
  apply Finset.sum_congr rfl
  intro k hk
  rw [Module.End.mul_apply, Module.End.mul_apply,
    Module.End.natCast_apply, LinearMap.pow_mulRight,
    LinearMap.mulRight_apply, neg_left_pow]
  rw [← Nat.cast_smul_eq_nsmul ℤ]
  simp only [smul_mul_assoc, mul_smul_comm, smul_smul, mul_assoc]

/-- Hall's equation (3), solved for its leading word `uv^n`. Every
remaining associative word has at least one copy of `v` moved to the
left of `u`. -/
theorem associative_bracket_sum
    {R : Type*} [Ring R] (u v : R) (n : ℕ) :
    u * v ^ n =
      iteratedAssociativeBracket u v n -
        ∑ k ∈ Finset.range n,
          ((-1 : ℤ) ^ (k + 1) * n.choose (k + 1)) •
            (v ^ (k + 1) * u * v ^ (n - (k + 1))) := by
  rw [iterated_associative_binomial, Finset.sum_range_succ']
  simp

/-- The generators appearing in one local Hall collection replacement:
the iterated bracket and the associative words obtained by moving at
least one copy of `v` to the left of `u`. -/
def hallCollectionGenerators {R : Type*} [Ring R]
    (u v : R) (n : ℕ) : Set R :=
  Set.insert (iteratedAssociativeBracket u v n)
    (Set.range fun k : Fin n =>
      v ^ (k.1 + 1) * u * v ^ (n - (k.1 + 1)))

/-- The local spanning step in Hall's proof of Lemma 5.3: `uv^n` is an
integral linear combination of its iterated bracket and terms with
strictly fewer out-of-order pairs. -/
theorem span_collection_generators
    {R : Type*} [Ring R] (u v : R) (n : ℕ) :
    u * v ^ n ∈
      Submodule.span ℤ (hallCollectionGenerators u v n) := by
  let S : Submodule ℤ R :=
    Submodule.span ℤ (hallCollectionGenerators u v n)
  rw [associative_bracket_sum]
  apply S.sub_mem
  · exact Submodule.subset_span (Set.mem_insert _ _)
  · refine Submodule.sum_mem _ fun k hk => ?_
    apply S.smul_mem
    apply Submodule.subset_span
    exact Set.mem_insert_iff.mpr
      (Or.inr ⟨⟨k, Finset.mem_range.mp hk⟩, rfl⟩)

/-! ## Termination of one collecting step -/

/-- A word during collection of `b` consists of copies of `b` and
already-created factors from `A*b`. -/
inductive HallCollectionLetter {α : Type*} (b : α)
  | distinguished
  | star (a : FSFactor b)

/-- Increase the number of right brackets by the distinguished letter. -/
def FSFactor.next {α : Type*} {b : α}
    (a : FSFactor b) : FSFactor b :=
  (a.1, a.2 + 1)

/-- Number of copies of the distinguished letter in a mixed collection
word. -/
def hallDistinguishedCount {α : Type*} {b : α} :
    List (HallCollectionLetter b) → ℕ
  | [] => 0
  | HallCollectionLetter.distinguished :: q =>
      hallDistinguishedCount q + 1
  | HallCollectionLetter.star _ :: q =>
      hallDistinguishedCount q

/-- Number of star factors in a mixed collection word. -/
def hallStarCount {α : Type*} {b : α} :
    List (HallCollectionLetter b) → ℕ
  | [] => 0
  | HallCollectionLetter.distinguished :: q =>
      hallStarCount q
  | HallCollectionLetter.star _ :: q =>
      hallStarCount q + 1

/-- Number of out-of-order pairs consisting of a star factor followed
later by the distinguished letter. -/
def hallCollectionInversions {α : Type*} {b : α} :
    List (HallCollectionLetter b) → ℕ
  | [] => 0
  | HallCollectionLetter.distinguished :: q =>
      hallCollectionInversions q
  | HallCollectionLetter.star _ :: q =>
      hallDistinguishedCount q + hallCollectionInversions q

@[simp]
lemma distinguished_count_append {α : Type*} {b : α}
    (q r : List (HallCollectionLetter b)) :
    hallDistinguishedCount (q ++ r) =
      hallDistinguishedCount q + hallDistinguishedCount r := by
  induction q with
  | nil =>
      simp [hallDistinguishedCount]
  | cons a q ih =>
      cases a <;>
        (simp [hallDistinguishedCount, ih, Nat.add_assoc] <;> omega)

@[simp]
lemma star_count_append {α : Type*} {b : α}
    (q r : List (HallCollectionLetter b)) :
    hallStarCount (q ++ r) = hallStarCount q + hallStarCount r := by
  induction q with
  | nil =>
      simp [hallStarCount]
  | cons a q ih =>
      cases a <;>
        (simp [hallStarCount, ih, Nat.add_assoc] <;> omega)

/-- Inversions across an append are exactly a star in the left word
paired with a distinguished letter in the right word. -/
lemma collection_inversions_append {α : Type*} {b : α}
    (q r : List (HallCollectionLetter b)) :
    hallCollectionInversions (q ++ r) =
      hallCollectionInversions q +
        hallStarCount q * hallDistinguishedCount r +
          hallCollectionInversions r := by
  induction q with
  | nil =>
      simp [hallCollectionInversions, hallStarCount]
  | cons a q ih =>
      cases a <;>
        (simp [hallCollectionInversions, hallStarCount, ih, Nat.add_mul] <;>
          omega)

/-- Replacing an adjacent bad pair `a b` by the next iterated bracket
strictly decreases the inversion count. -/
lemma collection_inversions_next {α : Type*} {b : α}
    (pre post : List (HallCollectionLetter b))
    (a : FSFactor b) :
    hallCollectionInversions
        (pre ++ HallCollectionLetter.star a.next :: post) <
      hallCollectionInversions
        (pre ++ HallCollectionLetter.star a ::
          HallCollectionLetter.distinguished :: post) := by
  rw [collection_inversions_append, collection_inversions_append]
  simp [hallCollectionInversions, hallDistinguishedCount, Nat.mul_add]
  omega

/-- Swapping an adjacent bad pair `a b` to `b a` strictly decreases the
inversion count. -/
lemma collection_inversions_swap {α : Type*} {b : α}
    (pre post : List (HallCollectionLetter b))
    (a : FSFactor b) :
    hallCollectionInversions
        (pre ++ HallCollectionLetter.distinguished ::
          HallCollectionLetter.star a :: post) <
      hallCollectionInversions
        (pre ++ HallCollectionLetter.star a ::
          HallCollectionLetter.distinguished :: post) := by
  rw [collection_inversions_append, collection_inversions_append]
  simp [hallCollectionInversions, hallDistinguishedCount, Nat.mul_add]

/-- A mixed collection word with a positive inversion count contains an
adjacent out-of-order pair. -/
lemma adjacent_collection_inversion {α : Type*} {b : α}
    (q : List (HallCollectionLetter b))
    (h : 0 < hallCollectionInversions q) :
    ∃ (pre : List (HallCollectionLetter b)) (a : FSFactor b)
        (post : List (HallCollectionLetter b)),
      q = pre ++ HallCollectionLetter.star a ::
        HallCollectionLetter.distinguished :: post := by
  induction q with
  | nil =>
      simp [hallCollectionInversions] at h
  | cons c q ih =>
      cases c with
      | distinguished =>
          obtain ⟨pre, a, post, hq⟩ :=
            ih (by simpa [hallCollectionInversions] using h)
          exact ⟨HallCollectionLetter.distinguished :: pre, a, post,
            by simp [hq]⟩
      | star a =>
          cases q with
          | nil =>
              simp [hallCollectionInversions, hallDistinguishedCount] at h
          | cons c q =>
              cases c with
              | distinguished =>
                  exact ⟨[], a, q, rfl⟩
              | star d =>
                  have htail :
                      0 < hallCollectionInversions
                        (HallCollectionLetter.star d :: q) := by
                    simp [hallCollectionInversions,
                      hallDistinguishedCount] at h ⊢
                    omega
                  obtain ⟨pre, e, post, hq⟩ := ih htail
                  exact ⟨HallCollectionLetter.star a :: pre, e, post,
                    by simp [hq]⟩

/-- Evaluate an associative word by multiplying its letters from left to
right. -/
def evalAssociativeWord {α R : Type*} [Monoid R]
    (f : α → R) (q : List α) : R :=
  (q.map f).prod

@[simp]
lemma eval_associative_nil {α R : Type*} [Monoid R]
    (f : α → R) :
    evalAssociativeWord f [] = 1 :=
  rfl

@[simp]
lemma eval_associative_cons {α R : Type*} [Monoid R]
    (f : α → R) (a : α) (q : List α) :
    evalAssociativeWord f (a :: q) = f a * evalAssociativeWord f q :=
  rfl

@[simp]
lemma eval_associative_append {α R : Type*} [Monoid R]
    (f : α → R) (q r : List α) :
    evalAssociativeWord f (q ++ r) =
      evalAssociativeWord f q * evalAssociativeWord f r := by
  simp [evalAssociativeWord]

/-- Ring value of a letter occurring while collecting the distinguished
letter `b`. -/
def evalCollectionLetter {α R : Type*} [Ring R]
    (f : α → R) (b : α) : HallCollectionLetter b → R
  | HallCollectionLetter.distinguished => f b
  | HallCollectionLetter.star a =>
      iteratedAssociativeBracket (f a.1.1) (f b) a.2

/-- Ring value of a mixed word occurring while collecting `b`. -/
def evalCollectionWord {α R : Type*} [Ring R]
    (f : α → R) (b : α) (q : List (HallCollectionLetter b)) : R :=
  evalAssociativeWord (evalCollectionLetter f b) q

@[simp]
lemma eval_letter_next {α R : Type*} [Ring R]
    (f : α → R) (b : α) (a : FSFactor b) :
    evalCollectionLetter f b (HallCollectionLetter.star a.next) =
      associativeBracket
        (evalCollectionLetter f b (HallCollectionLetter.star a))
        (f b) := by
  change iteratedAssociativeBracket (f a.1.1) (f b) (a.2 + 1) =
    associativeBracket
      (iteratedAssociativeBracket (f a.1.1) (f b) a.2) (f b)
  rfl

/-- The adjacent collection rewrite in the free associative ring
interpretation. -/
lemma collection_bad_pair {α R : Type*} [Ring R]
    (f : α → R) (b : α)
    (pre post : List (HallCollectionLetter b))
    (a : FSFactor b) :
    evalCollectionWord f b
        (pre ++ HallCollectionLetter.star a ::
          HallCollectionLetter.distinguished :: post) =
      evalCollectionWord f b
          (pre ++ HallCollectionLetter.star a.next :: post) +
        evalCollectionWord f b
          (pre ++ HallCollectionLetter.distinguished ::
            HallCollectionLetter.star a :: post) := by
  simp only [evalCollectionWord, eval_associative_append,
    eval_associative_cons, eval_letter_next]
  change
    evalAssociativeWord (evalCollectionLetter f b) pre *
          (evalCollectionLetter f b (HallCollectionLetter.star a) *
            (f b * evalAssociativeWord (evalCollectionLetter f b) post)) =
      evalAssociativeWord (evalCollectionLetter f b) pre *
          (associativeBracket
            (evalCollectionLetter f b (HallCollectionLetter.star a))
            (f b) *
              evalAssociativeWord (evalCollectionLetter f b) post) +
        evalAssociativeWord (evalCollectionLetter f b) pre *
          (f b *
            (evalCollectionLetter f b (HallCollectionLetter.star a) *
              evalAssociativeWord (evalCollectionLetter f b) post))
  rw [associativeBracket]
  noncomm_ring

/-- Collected mixed words are precisely the words with no star factor
preceding a distinguished letter. -/
def CollectedHallWord {α : Type*} (b : α) :=
  {q : List (HallCollectionLetter b) // hallCollectionInversions q = 0}

/-- Values of the fully collected words for one collecting step. -/
def hallCollectedValues {α R : Type*} [Ring R]
    (f : α → R) (b : α) : Set R :=
  Set.range fun q : CollectedHallWord b =>
    evalCollectionWord f b q.1

/-- The global spanning step in Hall's proof of Lemma 5.3. Repeated
adjacent collection expresses every mixed word as an integral linear
combination of fully collected words. -/
theorem eval_collection_collected
    {α R : Type*} [Ring R] (f : α → R) (b : α)
    (q : List (HallCollectionLetter b)) :
    evalCollectionWord f b q ∈
      Submodule.span ℤ (hallCollectedValues f b) := by
  generalize hn : hallCollectionInversions q = n
  induction n using Nat.strong_induction_on generalizing q with
  | h n ih =>
      by_cases hz : n = 0
      · apply Submodule.subset_span
        exact ⟨⟨q, by omega⟩, rfl⟩
      · have hpos : 0 < hallCollectionInversions q := by omega
        obtain ⟨pre, a, post, hq⟩ :=
          adjacent_collection_inversion q hpos
        subst q
        rw [collection_bad_pair]
        apply Submodule.add_mem
        · exact ih _
            (lt_of_lt_of_eq
              (collection_inversions_next pre post a) hn) _ rfl
        · exact ih _
            (lt_of_lt_of_eq
              (collection_inversions_swap pre post a) hn) _ rfl

/-- A word containing no distinguished letters is a word of star
factors. -/
lemma star_distinguished_count
    {α : Type*} {b : α} (q : List (HallCollectionLetter b))
    (h : hallDistinguishedCount q = 0) :
    ∃ s : List (FSFactor b),
      q = s.map HallCollectionLetter.star := by
  induction q with
  | nil =>
      exact ⟨[], rfl⟩
  | cons c q ih =>
      cases c with
      | distinguished =>
          simp [hallDistinguishedCount] at h
      | star a =>
          obtain ⟨s, hs⟩ :=
            ih (by simpa [hallDistinguishedCount] using h)
          exact ⟨a :: s, by simp [hs]⟩

/-- A zero-inversion word has Hall's collected form: an initial power of
the distinguished letter followed by a word of star factors. -/
lemma collected_presentation_inversions
    {α : Type*} {b : α} (q : List (HallCollectionLetter b))
    (h : hallCollectionInversions q = 0) :
    ∃ n : ℕ, ∃ s : List (FSFactor b),
      q = List.replicate n HallCollectionLetter.distinguished ++
        s.map HallCollectionLetter.star := by
  induction q with
  | nil =>
      exact ⟨0, [], rfl⟩
  | cons c q ih =>
      cases c with
      | distinguished =>
          obtain ⟨n, s, hs⟩ :=
            ih (by simpa [hallCollectionInversions] using h)
          exact ⟨n + 1, s, by simp [List.replicate_succ, hs]⟩
      | star a =>
          have hd : hallDistinguishedCount q = 0 := by
            simp [hallCollectionInversions] at h
            omega
          obtain ⟨s, hs⟩ :=
            star_distinguished_count q hd
          exact ⟨0, a :: s, by simp [hs]⟩

/-- Ring value of a concrete collected presentation `b^r q`, where
`q` is a word of star factors. -/
def evalCollectedPresentation {α R : Type*} [Ring R]
    (f : α → R) (b : α)
    (z : ℕ × List (FSFactor b)) : R :=
  f b ^ z.1 *
    evalAssociativeWord
      (evalCollectionLetter f b ∘ HallCollectionLetter.star)
      z.2

/-- Values of Hall's concrete collected presentations. -/
def hallPresentedValues {α R : Type*} [Ring R]
    (f : α → R) (b : α) : Set R :=
  Set.range (evalCollectedPresentation f b)

/-- Every zero-inversion mixed-word value has a concrete Hall collected
presentation. -/
lemma collected_values_presented
    {α R : Type*} [Ring R] (f : α → R) (b : α) :
    hallCollectedValues f b ⊆ hallPresentedValues f b := by
  rintro x ⟨q, rfl⟩
  obtain ⟨n, s, hs⟩ :=
    collected_presentation_inversions q.1 q.2
  refine ⟨(n, s), ?_⟩
  change evalCollectedPresentation f b (n, s) =
    evalCollectionWord f b q.1
  rw [hs]
  simp [evalCollectionWord, evalCollectedPresentation,
    evalAssociativeWord, evalCollectionLetter]

/-- Embed an original alphabet letter into a mixed word for collection
of `b`; letters other than `b` become zero-fold star factors. -/
def hallCollectionLetter {α : Type*} [DecidableEq α]
    (b a : α) : HallCollectionLetter b :=
  if h : a = b then
    HallCollectionLetter.distinguished
  else
    HallCollectionLetter.star (⟨a, h⟩, 0)

/-- Embed an original word into the mixed-word representation used by
the terminating collection argument. -/
def hallCollectionWord {α : Type*} [DecidableEq α]
    (b : α) (q : List α) : List (HallCollectionLetter b) :=
  q.map (hallCollectionLetter b)

@[simp]
lemma eval_collection_letter
    {α R : Type*} [DecidableEq α] [Ring R]
    (f : α → R) (b a : α) :
    evalCollectionLetter f b (hallCollectionLetter b a) = f a := by
  by_cases h : a = b
  · subst a
    simp [hallCollectionLetter, evalCollectionLetter]
  · simp [hallCollectionLetter, evalCollectionLetter, h]

@[simp]
lemma eval_collection_word
    {α R : Type*} [DecidableEq α] [Ring R]
    (f : α → R) (b : α) (q : List α) :
    evalCollectionWord f b (hallCollectionWord b q) =
      evalAssociativeWord f q := by
  induction q with
  | nil =>
      rfl
  | cons a q ih =>
      change
        evalCollectionLetter f b (hallCollectionLetter b a) *
            evalCollectionWord f b (hallCollectionWord b q) =
          f a * evalAssociativeWord f q
      rw [eval_collection_letter, ih]

/-- **Hall, Lemma 5.3, one-step spanning theorem.** Every associative
word in the current alphabet is an integral linear combination of
values of collected presentations `b^r q` with `q` a word in `A*b`. -/
theorem associative_collected_values
    {α R : Type*} [Ring R]
    (f : α → R) (b : α) (q : List α) :
    evalAssociativeWord f q ∈
      Submodule.span ℤ (hallPresentedValues f b) := by
  classical
  rw [← eval_collection_word f b q]
  exact
    (Submodule.span_mono (collected_values_presented f b))
      (eval_collection_collected f b
        (hallCollectionWord b q))

/-! ## Weight-preserving one-step spanning -/

/-- Hall weight of a mixed collection letter. -/
def collectionLetterWeight {α : Type*}
    (wt : α → ℕ) (b : α) : HallCollectionLetter b → ℕ
  | HallCollectionLetter.distinguished => wt b
  | HallCollectionLetter.star a => formalStarWeight wt b a

/-- Hall weight of a mixed collection word. -/
def hallCollectionWeight {α : Type*}
    (wt : α → ℕ) (b : α) (q : List (HallCollectionLetter b)) : ℕ :=
  formalWordWeight (collectionLetterWeight wt b) q

@[simp]
lemma collection_letter_next {α : Type*}
    (wt : α → ℕ) (b : α) (a : FSFactor b) :
    collectionLetterWeight wt b (HallCollectionLetter.star a.next) =
      collectionLetterWeight wt b (HallCollectionLetter.star a) +
        wt b := by
  simp [collectionLetterWeight, FSFactor.next,
    formalStarWeight, Nat.add_mul, Nat.add_assoc]

lemma hall_collection_append {α : Type*}
    (wt : α → ℕ) (b : α)
    (q r : List (HallCollectionLetter b)) :
    hallCollectionWeight wt b (q ++ r) =
      hallCollectionWeight wt b q +
        hallCollectionWeight wt b r :=
  formal_weight_append (collectionLetterWeight wt b) q r

/-- Replacing a bad pair by its next iterated bracket preserves weight. -/
lemma hall_collection_next {α : Type*}
    (wt : α → ℕ) (b : α)
    (pre post : List (HallCollectionLetter b))
    (a : FSFactor b) :
    hallCollectionWeight wt b
        (pre ++ HallCollectionLetter.star a.next :: post) =
      hallCollectionWeight wt b
        (pre ++ HallCollectionLetter.star a ::
          HallCollectionLetter.distinguished :: post) := by
  simp only [hallCollectionWeight, formal_weight_append,
    formal_weight_cons]
  rw [collection_letter_next]
  simp only [collectionLetterWeight]
  omega

/-- Swapping a bad pair preserves weight. -/
lemma hall_collection_swap {α : Type*}
    (wt : α → ℕ) (b : α)
    (pre post : List (HallCollectionLetter b))
    (a : FSFactor b) :
    hallCollectionWeight wt b
        (pre ++ HallCollectionLetter.distinguished ::
          HallCollectionLetter.star a :: post) =
      hallCollectionWeight wt b
        (pre ++ HallCollectionLetter.star a ::
          HallCollectionLetter.distinguished :: post) := by
  simp only [hallCollectionWeight, formal_weight_append,
    formal_weight_cons, collectionLetterWeight]
  omega

/-- Values of fully collected mixed words of a specified weight. -/
def collectedValuesWeight {α R : Type*} [Ring R]
    (f : α → R) (wt : α → ℕ) (b : α) (w : ℕ) : Set R :=
  Set.range fun q :
      {q : List (HallCollectionLetter b) //
        hallCollectionInversions q = 0 ∧
          hallCollectionWeight wt b q = w} =>
    evalCollectionWord f b q.1

/-- The weight-preserving global spanning step: every mixed word is an
integral linear combination of fully collected words of the same
weight. -/
theorem collection_span_collected
    {α R : Type*} [Ring R] (f : α → R) (wt : α → ℕ) (b : α)
    (q : List (HallCollectionLetter b)) :
    evalCollectionWord f b q ∈
      Submodule.span ℤ
        (collectedValuesWeight f wt b
          (hallCollectionWeight wt b q)) := by
  generalize hn : hallCollectionInversions q = n
  induction n using Nat.strong_induction_on generalizing q with
  | h n ih =>
      by_cases hz : n = 0
      · apply Submodule.subset_span
        exact ⟨⟨q, by exact ⟨by omega, rfl⟩⟩, rfl⟩
      · have hpos : 0 < hallCollectionInversions q := by omega
        obtain ⟨pre, a, post, hq⟩ :=
          adjacent_collection_inversion q hpos
        subst q
        rw [collection_bad_pair]
        apply Submodule.add_mem
        · have hmem := ih _
            (lt_of_lt_of_eq
              (collection_inversions_next pre post a) hn) _ rfl
          rw [hall_collection_next wt b pre post a] at hmem
          exact hmem
        · have hmem := ih _
            (lt_of_lt_of_eq
              (collection_inversions_swap pre post a) hn) _ rfl
          rw [hall_collection_swap wt b pre post a] at hmem
          exact hmem

/-- Hall weight of a concrete collected presentation. -/
def collectedPresentationWeight {α : Type*}
    (wt : α → ℕ) (b : α)
    (z : ℕ × List (FSFactor b)) : ℕ :=
  z.1 * wt b + formalWordWeight (formalStarWeight wt b) z.2

/-- Values of concrete Hall collected presentations of a specified
weight. -/
def presentedCollectedValues {α R : Type*} [Ring R]
    (f : α → R) (wt : α → ℕ) (b : α) (w : ℕ) : Set R :=
  Set.range fun z : WeightFiber (collectedPresentationWeight wt b) w =>
    evalCollectedPresentation f b z.1

@[simp]
lemma hall_collection_star {α : Type*}
    (wt : α → ℕ) (b : α) (s : List (FSFactor b)) :
    hallCollectionWeight wt b (s.map HallCollectionLetter.star) =
      formalWordWeight (formalStarWeight wt b) s := by
  change
    formalWordWeight (collectionLetterWeight wt b)
        (s.map HallCollectionLetter.star) =
      formalWordWeight (formalStarWeight wt b) s
  induction s with
  | nil =>
      rfl
  | cons a s ih =>
      simp [collectionLetterWeight, ih]

/-- The mixed word associated to a concrete Hall presentation has its
declared presentation weight. -/
lemma hall_collection_presentation {α : Type*}
    (wt : α → ℕ) (b : α) (n : ℕ)
    (s : List (FSFactor b)) :
    hallCollectionWeight wt b
        (List.replicate n HallCollectionLetter.distinguished ++
          s.map HallCollectionLetter.star) =
      collectedPresentationWeight wt b (n, s) := by
  rw [hall_collection_append,
    hall_collection_star]
  simp [hallCollectionWeight, collectedPresentationWeight,
    collectionLetterWeight]

/-- Every fully collected mixed-word value of weight `w` has a concrete
Hall presentation of weight `w`. -/
lemma values_subset_presented
    {α R : Type*} [Ring R] (f : α → R) (wt : α → ℕ)
    (b : α) (w : ℕ) :
    collectedValuesWeight f wt b w ⊆
      presentedCollectedValues f wt b w := by
  rintro x ⟨q, rfl⟩
  obtain ⟨n, s, hs⟩ :=
    collected_presentation_inversions q.1 q.2.1
  refine ⟨⟨(n, s), ?_⟩, ?_⟩
  · rw [← q.2.2, hs, hall_collection_presentation]
  · change evalCollectedPresentation f b (n, s) =
      evalCollectionWord f b q.1
    rw [hs]
    simp [evalCollectionWord, evalCollectedPresentation,
      evalAssociativeWord, evalCollectionLetter]

@[simp]
lemma collection_letter_weight
    {α : Type*} [DecidableEq α] (wt : α → ℕ) (b a : α) :
    collectionLetterWeight wt b (hallCollectionLetter b a) = wt a := by
  by_cases h : a = b
  · subst a
    simp [hallCollectionLetter, collectionLetterWeight]
  · simp [hallCollectionLetter, collectionLetterWeight,
      formalStarWeight, h]

@[simp]
lemma hall_collection_weight
    {α : Type*} [DecidableEq α] (wt : α → ℕ) (b : α)
    (q : List α) :
    hallCollectionWeight wt b (hallCollectionWord b q) =
      formalWordWeight wt q := by
  change
    formalWordWeight (collectionLetterWeight wt b)
        (q.map (hallCollectionLetter b)) =
      formalWordWeight wt q
  induction q with
  | nil =>
      rfl
  | cons a q ih =>
      simp [ih]

/-- **Hall, Lemma 5.3, weight-preserving one-step spanning theorem.**
Every word in the current alphabet is an integral linear combination of
collected presentations of exactly the same weight. -/
theorem associative_presented_values
    {α R : Type*} [Ring R]
    (f : α → R) (wt : α → ℕ) (b : α) (q : List α) :
    evalAssociativeWord f q ∈
      Submodule.span ℤ
        (presentedCollectedValues f wt b
          (formalWordWeight wt q)) := by
  classical
  rw [← eval_collection_word f b q,
    ← hall_collection_weight wt b q]
  exact
    (Submodule.span_mono
      (values_subset_presented f wt b
        (hallCollectionWeight wt b (hallCollectionWord b q))))
      (collection_span_collected f wt b
        (hallCollectionWord b q))

/-- Left multiplication by a fixed ring element carries a span of a
range into the span of the correspondingly left-multiplied range. -/
lemma mul_span_range {ι R : Type*} [Ring R]
    (p : R) (g : ι → R) {x : R}
    (hx : x ∈ Submodule.span ℤ (Set.range g)) :
    p * x ∈ Submodule.span ℤ (Set.range fun i => p * g i) := by
  induction hx using Submodule.span_induction with
  | mem x hx =>
      obtain ⟨i, rfl⟩ := hx
      exact Submodule.subset_span ⟨i, rfl⟩
  | zero =>
      simp
  | add x y _ _ hx hy =>
      rw [mul_add]
      exact Submodule.add_mem _ hx hy
  | smul z x _ hx =>
      rw [mul_smul_comm]
      exact Submodule.smul_mem _ z hx

/-- Values of same-weight collected presentations with an already
collected prefix fixed on the left. -/
def prefixedPresentedValues
    {α R : Type*} [Ring R] (p : R)
    (f : α → R) (wt : α → ℕ) (b : α) (w : ℕ) : Set R :=
  Set.range fun z : WeightFiber (collectedPresentationWeight wt b) w =>
    p * evalCollectedPresentation f b z.1

/-- **Hall, Lemma 5.3, full one-step spanning form.** Keeping the
already-collected prefix fixed, every `P_{i-1}` word is an integral
linear combination of `P_i` presentations having the same residual
weight. -/
theorem associative_prefixed_presented
    {α R : Type*} [Ring R]
    (p : R) (f : α → R) (wt : α → ℕ) (b : α) (q : List α) :
    p * evalAssociativeWord f q ∈
      Submodule.span ℤ
        (prefixedPresentedValues p f wt b
          (formalWordWeight wt q)) := by
  classical
  exact
    mul_span_range p
      (fun z : WeightFiber
          (collectedPresentationWeight wt b)
          (formalWordWeight wt q) =>
        evalCollectedPresentation f b z.1)
      (associative_presented_values
        f wt b q)

/-- Evaluate a formal commutator expression in an associative ring, using
the ring commutator `uv - vu` for every formal bracket. -/
def evalFormalCommutator {X R : Type*} [Ring R] (f : X → R) :
    FormalCommutator X → R
  | FreeMagma.of x => f x
  | FreeMagma.mul u v =>
      associativeBracket (evalFormalCommutator f u) (evalFormalCommutator f v)

@[simp]
lemma eval_formal_variable {X R : Type*} [Ring R]
    (f : X → R) (x : X) :
    evalFormalCommutator f (FreeMagma.of x) = f x :=
  rfl

@[simp]
lemma eval_formal_bracket {X R : Type*} [Ring R]
    (f : X → R) (u v : FormalCommutator X) :
    evalFormalCommutator f (formalBracket u v) =
      associativeBracket (evalFormalCommutator f u)
        (evalFormalCommutator f v) :=
  rfl

@[simp]
lemma formal_iterated_bracket
    {X R : Type*} [Ring R] (f : X → R)
    (a b : FormalCommutator X) (n : ℕ) :
    evalFormalCommutator f (iteratedFormalBracket a b n) =
      iteratedAssociativeBracket
        (evalFormalCommutator f a) (evalFormalCommutator f b) n := by
  induction n with
  | zero =>
      rfl
  | succ n ih =>
      simp [ih]

@[simp]
lemma formal_star_value
    {X R : Type*} [Ring R] (f : X → R)
    (b : FormalCommutator X) (a : FSFactor b) :
    evalFormalCommutator f (a.value b) =
      iteratedAssociativeBracket
        (evalFormalCommutator f a.1.1) (evalFormalCommutator f b) a.2 :=
  formal_iterated_bracket _ _ _ _

/-- Evaluate a formal commutator expression in a group, using Hall's
multiplicative commutator for every formal bracket. -/
def formalGroupCommutator {X G : Type*} [Group G] (f : X → G) :
    FormalCommutator X → G
  | FreeMagma.of x => f x
  | FreeMagma.mul u v =>
      hallCommutator (formalGroupCommutator f u)
        (formalGroupCommutator f v)

@[simp]
lemma formal_commutator_variable {X G : Type*} [Group G]
    (f : X → G) (x : X) :
    formalGroupCommutator f (FreeMagma.of x) = f x :=
  rfl

@[simp]
lemma formal_commutator_bracket {X G : Type*} [Group G]
    (f : X → G) (u v : FormalCommutator X) :
    formalGroupCommutator f (formalBracket u v) =
      hallCommutator (formalGroupCommutator f u)
        (formalGroupCommutator f v) :=
  rfl

/-! ## The filtered-ring commutator comparison -/

/-- Products of elements in powers of a two-sided ideal have the
expected filtration degree. -/
lemma mul_ideal_add {R : Type*} [Ring R]
    (I : Ideal R) [I.IsTwoSided] {a b : R} {r s : ℕ}
    (ha : a ∈ I ^ r) (hb : b ∈ I ^ s) :
    a * b ∈ I ^ (r + s) := by
  rw [Ideal.IsTwoSided.pow_add]
  exact Ideal.mul_mem_mul ha hb

/-- Associative brackets add filtration degrees. -/
lemma associative_bracket_add
    {R : Type*} [Ring R] (I : Ideal R) [I.IsTwoSided]
    {a b : R} {r s : ℕ}
    (ha : a ∈ I ^ r) (hb : b ∈ I ^ s) :
    associativeBracket a b ∈ I ^ (r + s) := by
  exact (I ^ (r + s)).sub_mem
    (mul_ideal_add I ha hb)
    (by
      rw [Nat.add_comm]
      exact mul_ideal_add I hb ha)

/-- A formal associative commutator of weight `r`, evaluated in elements
of `I`, lies in `I ^ r`. -/
lemma formal_commutator_pow
    {X R : Type*} [Ring R] (I : Ideal R) [I.IsTwoSided]
    (f : X → R) (hf : ∀ x, f x ∈ I) (u : FormalCommutator X) :
    evalFormalCommutator f u ∈ I ^ formalWeight u := by
  induction u with
  | of x =>
      simpa only [eval_formal_variable, formalWeight_variable,
        Submodule.pow_one] using hf x
  | mul u v ihu ihv =>
      exact associative_bracket_add I ihu ihv

/-- If `b² = 0` and a unit has value `1 + b`, then all of its integer
powers have the expected linear form. -/
lemma zpow_zsmul_self
    {R : Type*} [Ring R] (u : Rˣ) (b : R)
    (hu : (u : R) = 1 + b) (hb : b * b = 0) (m : ℤ) :
    ((u ^ m : Rˣ) : R) = 1 + m • b := by
  have huinv : ((u⁻¹ : Rˣ) : R) = 1 - b := by
    have hmul : (u : R) * (1 - b) = 1 := by
      rw [hu, show (1 + b) * (1 - b) = 1 - b * b by noncomm_ring,
        hb, sub_zero]
    calc
      ((u⁻¹ : Rˣ) : R) = ((u⁻¹ : Rˣ) : R) * 1 := by simp
      _ = ((u⁻¹ : Rˣ) : R) * ((u : R) * (1 - b)) := by rw [hmul]
      _ = 1 - b := by simp [← mul_assoc]
  refine Int.induction_on m ?_ (fun m ih => ?_) (fun m ih => ?_)
  · simp
  · rw [zpow_add_one]
    rw [Units.val_mul]
    rw [ih, hu]
    simp only [zsmul_eq_mul, Int.cast_natCast, Int.cast_add, Int.cast_one]
    simp only [one_mul, add_mul]
    noncomm_ring
    rw [hb, mul_zero, add_zero]
  · rw [zpow_sub_one]
    rw [Units.val_mul]
    rw [ih, huinv]
    simp only [neg_smul, zsmul_eq_mul, Int.cast_natCast, Int.cast_sub,
      Int.cast_neg, Int.cast_one]
    simp only [one_mul, add_mul]
    noncomm_ring
    rw [hb, mul_zero, add_zero]

/-- A power of a principal unit has leading term `m • b` in filtration
degree `w`. -/
lemma zpow_sub_zsmul
    {R : Type*} [Ring R] (I : Ideal R) [I.IsTwoSided]
    (c : Rˣ) {b : R} {w : ℕ} (hw : 0 < w)
    (hb : b ∈ I ^ w)
    (hc : (c : R) - (1 + b) ∈ I ^ (w + 1)) (m : ℤ) :
    ((c ^ m : Rˣ) : R) - (1 + m • b) ∈ I ^ (w + 1) := by
  let J : Ideal R := I ^ (w + 1)
  let q : R →+* R ⧸ J := Ideal.Quotient.mk J
  let cq : (R ⧸ J)ˣ := Units.map q.toMonoidHom c
  let bq : R ⧸ J := q b
  have hcq : (cq : R ⧸ J) = 1 + bq := by
    change q (c : R) = 1 + q b
    rw [← q.map_one, ← q.map_add]
    exact Ideal.Quotient.eq.2 hc
  have hbb : b * b ∈ J := by
    exact (Ideal.pow_le_pow_right (by omega))
      (mul_ideal_add I hb hb)
  have hbq : bq * bq = 0 := by
    change q b * q b = 0
    rw [← q.map_mul, Ideal.Quotient.eq_zero_iff_mem]
    exact hbb
  apply Ideal.Quotient.eq.1
  calc
    q (((c ^ m : Rˣ) : R)) = ((cq ^ m : (R ⧸ J)ˣ) : R ⧸ J) := by
      change q (((c ^ m : Rˣ) : R)) =
        (((Units.map q.toMonoidHom c) ^ m : (R ⧸ J)ˣ) : R ⧸ J)
      rw [← map_zpow]
      rfl
    _ = 1 + m • bq :=
      zpow_zsmul_self cq bq hcq hbq m
    _ = q (1 + m • b) := by simp [bq]

/-- Multiplication preserves congruence modulo a two-sided ideal in both
arguments. -/
lemma sub_ideal
    {R : Type*} [Ring R] (J : Ideal R) [J.IsTwoSided]
    {a a₀ b b₀ : R} (ha : a - a₀ ∈ J) (hb : b - b₀ ∈ J) :
    a * b - a₀ * b₀ ∈ J := by
  rw [show a * b - a₀ * b₀ =
      (a - a₀) * b + a₀ * (b - b₀) by noncomm_ring]
  exact J.add_mem (J.mul_mem_right b ha) (J.mul_mem_left a₀ hb)

/-- The ordered product `c₁^μ₁ ... cₙ^μₙ` in an arbitrary group. -/
def orderedZPow {ι G : Type*} [Group G]
    (c : ι → G) (μ : ι → ℤ) (l : List ι) : G :=
  (l.map fun i => c i ^ μ i).prod

/-- Applying a group homomorphism to an ordered product applies it to every
factor. Only the factors displayed in the list need to satisfy the stated
comparison. -/
lemma ordered_z_list
    {ι G H : Type*} [Group G] [Group H]
    (f : G →* H) (c : ι → G) (d : ι → H) (μ : ι → ℤ) (l : List ι)
    (h : ∀ i ∈ l, f (c i) = d i) :
    f (orderedZPow c μ l) = orderedZPow d μ l := by
  induction l with
  | nil =>
      simp [orderedZPow]
  | cons i l ih =>
      have hi : f (c i) = d i := h i (by simp)
      have hl : ∀ j ∈ l, f (c j) = d j := by
        intro j hj
        exact h j (by simp [hj])
      change
        f (c i ^ μ i * orderedZPow c μ l) =
          d i ^ μ i * orderedZPow d μ l
      rw [map_mul, map_zpow, hi, ih hl]

/-- An ordered product is trivial when every displayed exponent is zero. -/
lemma ordered_z_zero
    {ι G : Type*} [Group G]
    (c : ι → G) (μ : ι → ℤ) (l : List ι)
    (hzero : ∀ i ∈ l, μ i = 0) :
    orderedZPow c μ l = 1 := by
  induction l with
  | nil =>
      simp [orderedZPow]
  | cons i l ih =>
      have hi : μ i = 0 := hzero i (by simp)
      have hl : ∀ j ∈ l, μ j = 0 := by
        intro j hj
        exact hzero j (by simp [hj])
      change c i ^ μ i * orderedZPow c μ l = 1
      rw [hi, zpow_zero, one_mul, ih hl]

/-- The ordered product `c₁^μ₁ ... cₙ^μₙ`. -/
def orderedZProduct {ι R : Type*} [Ring R]
    (c : ι → Rˣ) (μ : ι → ℤ) (l : List ι) : Rˣ :=
  (l.map fun i => c i ^ μ i).prod

/-- The unit-valued ordered product is the specialization of the generic
group-valued ordered product. -/
lemma ordered_z_product
    {ι R : Type*} [Ring R]
    (c : ι → Rˣ) (μ : ι → ℤ) (l : List ι) :
    orderedZProduct c μ l = orderedZPow c μ l :=
  rfl

/-- The corresponding integer linear combination `μ₁b₁ + ... + μₙbₙ`. -/
def integerLinearCombination {ι R : Type*} [AddGroup R]
    (b : ι → R) (μ : ι → ℤ) (l : List ι) : R :=
  (l.map fun i => μ i • b i).sum

/-- An integer linear combination of elements of one ideal power remains
in that ideal power. -/
lemma integer_linear_combination
    {ι R : Type*} [Ring R] (I : Ideal R)
    (b : ι → R) (μ : ι → ℤ) (l : List ι) {w : ℕ}
    (hb : ∀ i ∈ l, b i ∈ I ^ w) :
    integerLinearCombination b μ l ∈ I ^ w := by
  induction l with
  | nil =>
      simp [integerLinearCombination]
  | cons i l ih =>
      have hi : b i ∈ I ^ w := hb i (by simp)
      have hl : ∀ j ∈ l, b j ∈ I ^ w := by
        intro j hj
        exact hb j (by simp [hj])
      simp only [integerLinearCombination, List.map_cons, List.sum_cons]
      exact (I ^ w).add_mem (zsmul_mem hi (μ i)) (ih hl)

/-- The fixed-weight leading-term calculation in Hall's Lemma 5.5.
An ordered product of powers of units congruent to `1 + bᵢ` has leading
term the corresponding integer linear combination of the `bᵢ`. -/
lemma z_integer_combination
    {ι R : Type*} [Ring R] (I : Ideal R) [I.IsTwoSided]
    (c : ι → Rˣ) (b : ι → R) (μ : ι → ℤ) (l : List ι)
    {w : ℕ} (hw : 0 < w)
    (hb : ∀ i ∈ l, b i ∈ I ^ w)
    (hc : ∀ i ∈ l, (c i : R) - (1 + b i) ∈ I ^ (w + 1)) :
    ((orderedZProduct c μ l : Rˣ) : R) -
        (1 + integerLinearCombination b μ l) ∈ I ^ (w + 1) := by
  induction l with
  | nil =>
      simp [orderedZProduct, integerLinearCombination]
  | cons i l ih =>
      have hbi : b i ∈ I ^ w := hb i (by simp)
      have hci : (c i : R) - (1 + b i) ∈ I ^ (w + 1) := hc i (by simp)
      have hbTail : ∀ j ∈ l, b j ∈ I ^ w := by
        intro j hj
        exact hb j (by simp [hj])
      have hcTail : ∀ j ∈ l, (c j : R) - (1 + b j) ∈ I ^ (w + 1) := by
        intro j hj
        exact hc j (by simp [hj])
      have hpow :=
        zpow_sub_zsmul I (c i) hw hbi hci (μ i)
      have htail := ih hbTail hcTail
      have hhead : μ i • b i ∈ I ^ w := zsmul_mem hbi (μ i)
      have hsum :
          integerLinearCombination b μ l ∈ I ^ w :=
        integer_linear_combination I b μ l hbTail
      have hcross0 :
          (μ i • b i) * integerLinearCombination b μ l ∈ I ^ (w + w) :=
        mul_ideal_add I hhead hsum
      have hcross :
          (μ i • b i) * integerLinearCombination b μ l ∈ I ^ (w + 1) :=
        (Ideal.pow_le_pow_right (by omega)) hcross0
      have hprod :
          ((c i ^ μ i : Rˣ) : R) *
                ((orderedZProduct c μ l : Rˣ) : R) -
              (1 + μ i • b i) *
                (1 + integerLinearCombination b μ l) ∈
            I ^ (w + 1) :=
        sub_ideal (I ^ (w + 1)) hpow htail
      change
        ((c i ^ μ i : Rˣ) : R) *
              ((orderedZProduct c μ l : Rˣ) : R) -
            (1 + (μ i • b i + integerLinearCombination b μ l)) ∈
          I ^ (w + 1)
      rw [show
          ((c i ^ μ i : Rˣ) : R) *
                ((orderedZProduct c μ l : Rˣ) : R) -
              (1 + (μ i • b i +
                integerLinearCombination b μ l)) =
            (((c i ^ μ i : Rˣ) : R) *
                ((orderedZProduct c μ l : Rˣ) : R) -
              (1 + μ i • b i) *
                (1 + integerLinearCombination b μ l)) +
              (μ i • b i) * integerLinearCombination b μ l by
          noncomm_ring]
      exact (I ^ (w + 1)).add_mem hprod hcross

/-- If two fixed-weight ordered products are equal, then their leading
integer linear combinations agree modulo the next filtration layer. -/
lemma integer_combination_z
    {ι R : Type*} [Ring R] (I : Ideal R) [I.IsTwoSided]
    (c : ι → Rˣ) (b : ι → R) (lam mu : ι → ℤ) (l : List ι)
    {w : ℕ} (hw : 0 < w)
    (hb : ∀ i ∈ l, b i ∈ I ^ w)
    (hc : ∀ i ∈ l, (c i : R) - (1 + b i) ∈ I ^ (w + 1))
    (hprod : orderedZProduct c lam l = orderedZProduct c mu l) :
    integerLinearCombination b lam l - integerLinearCombination b mu l ∈
      I ^ (w + 1) := by
  have hlam :=
    z_integer_combination
      I c b lam l hw hb hc
  have hmu :=
    z_integer_combination
      I c b mu l hw hb hc
  have hprodVal :
      ((orderedZProduct c lam l : Rˣ) : R) =
        ((orderedZProduct c mu l : Rˣ) : R) :=
    congrArg Units.val hprod
  have h := (I ^ (w + 1)).sub_mem hmu hlam
  rw [show
      (((orderedZProduct c mu l : Rˣ) : R) -
          (1 + integerLinearCombination b mu l)) -
        (((orderedZProduct c lam l : Rˣ) : R) -
          (1 + integerLinearCombination b lam l)) =
        integerLinearCombination b lam l -
          integerLinearCombination b mu l by
      rw [hprodVal]
      noncomm_ring] at h
  exact h

/-- **Hall, Lemma 5.5, fixed-weight uniqueness step.** If a finite
ordered family of principal units has linearly independent leading terms
in filtration degree `w`, then its ordered exponent vector is unique. -/
theorem principal_unique_fixed
    {R : Type*} [Ring R] (I : Ideal R) [I.IsTwoSided]
    {n : ℕ} (c : Fin n → Rˣ) (b : Fin n → R)
    {w : ℕ} (hw : 0 < w)
    (hb : ∀ i, b i ∈ I ^ w)
    (hc : ∀ i, (c i : R) - (1 + b i) ∈ I ^ (w + 1))
    (hli :
      LinearIndependent ℤ
        (fun i : Fin n => Ideal.Quotient.mk (I ^ (w + 1)) (b i)))
    {lam mu : Fin n → ℤ}
    (hprod :
      orderedZProduct c lam (List.finRange n) =
        orderedZProduct c mu (List.finRange n)) :
    lam = mu := by
  let q : R →+* R ⧸ I ^ (w + 1) := Ideal.Quotient.mk (I ^ (w + 1))
  have hbList : ∀ i ∈ List.finRange n, b i ∈ I ^ w := by
    intro i _
    exact hb i
  have hcList :
      ∀ i ∈ List.finRange n, (c i : R) - (1 + b i) ∈ I ^ (w + 1) := by
    intro i _
    exact hc i
  have hdiff :=
    integer_combination_z
      I c b lam mu (List.finRange n) hw hbList hcList hprod
  have hqeq :
      q (integerLinearCombination b lam (List.finRange n)) =
        q (integerLinearCombination b mu (List.finRange n)) := by
    rw [← sub_eq_zero, ← q.map_sub, Ideal.Quotient.eq_zero_iff_mem]
    exact hdiff
  have hsum :
      (∑ i, lam i • q (b i)) = ∑ i, mu i • q (b i) := by
    rw [Fin.sum_univ_def, Fin.sum_univ_def]
    simpa [q, integerLinearCombination, map_list_sum] using hqeq
  funext i
  exact hli.eq_coords_of_eq hsum i

/-- The contribution of a term of filtration weight `v` to the leading
layer of weight `w`. Terms of higher weight contribute zero. -/
def leadingTermWeight {R : Type*} [AddGroup R]
    (b : R) (m : ℤ) (v w : ℕ) : R :=
  if v = w then m • b else 0

/-- Sum of the terms of exact weight `w` in an ordered exponent vector. -/
def weightLeadingCombination {ι R : Type*} [AddGroup R]
    (b : ι → R) (m : ι → ℤ) (wt : ι → ℕ) (w : ℕ) (l : List ι) : R :=
  (l.map fun i => leadingTermWeight (b i) (m i) (wt i) w).sum

/-- Every exact-weight leading term belongs to the current ideal power. -/
lemma leading_term_pow
    {R : Type*} [Ring R] (I : Ideal R)
    {b : R} {m : ℤ} {v w : ℕ} (hge : w ≤ v) (hb : b ∈ I ^ v) :
    leadingTermWeight b m v w ∈ I ^ w := by
  by_cases h : v = w
  · subst v
    simpa [leadingTermWeight] using zsmul_mem hb m
  · simp [leadingTermWeight, h]

/-- The current-weight leading combination of a tail whose terms all
have weight at least `w` belongs to `I ^ w`. -/
lemma leading_combination_pow
    {ι R : Type*} [Ring R] (I : Ideal R)
    (b : ι → R) (m : ι → ℤ) (wt : ι → ℕ) (w : ℕ) (l : List ι)
    (hge : ∀ i ∈ l, w ≤ wt i)
    (hb : ∀ i ∈ l, b i ∈ I ^ wt i) :
    weightLeadingCombination b m wt w l ∈ I ^ w := by
  induction l with
  | nil =>
      simp [weightLeadingCombination]
  | cons i l ih =>
      have hgei : w ≤ wt i := hge i (by simp)
      have hbi : b i ∈ I ^ wt i := hb i (by simp)
      have hgeTail : ∀ j ∈ l, w ≤ wt j := by
        intro j hj
        exact hge j (by simp [hj])
      have hbTail : ∀ j ∈ l, b j ∈ I ^ wt j := by
        intro j hj
        exact hb j (by simp [hj])
      change
        leadingTermWeight (b i) (m i) (wt i) w +
            weightLeadingCombination b m wt w l ∈ I ^ w
      exact (I ^ w).add_mem
        (leading_term_pow I hgei hbi)
        (ih hgeTail hbTail)

/-- A principal-unit power contributes only its term of exact current
weight modulo the next filtration layer. -/
lemma zpow_sub_leading
    {R : Type*} [Ring R] (I : Ideal R) [I.IsTwoSided]
    (c : Rˣ) {b : R} {v w : ℕ} (hw : 0 < w) (hge : w ≤ v)
    (hb : b ∈ I ^ v)
    (hc : (c : R) - (1 + b) ∈ I ^ (v + 1)) (m : ℤ) :
    ((c ^ m : Rˣ) : R) -
        (1 + leadingTermWeight b m v w) ∈ I ^ (w + 1) := by
  by_cases h : v = w
  · subst v
    simpa [leadingTermWeight] using
      zpow_sub_zsmul I c hw hb hc m
  · have hvpos : 0 < v := lt_of_lt_of_le hw hge
    have hwv : w + 1 ≤ v := by omega
    have hpow0 :=
      zpow_sub_zsmul I c hvpos hb hc m
    have hpow :
        ((c ^ m : Rˣ) : R) - (1 + m • b) ∈ I ^ (w + 1) :=
      (Ideal.pow_le_pow_right (by omega)) hpow0
    have hbm : m • b ∈ I ^ (w + 1) :=
      zsmul_mem ((Ideal.pow_le_pow_right hwv) hb) m
    simp only [leadingTermWeight, if_neg h, add_zero]
    rw [show
        ((c ^ m : Rˣ) : R) - 1 =
          (((c ^ m : Rˣ) : R) - (1 + m • b)) + m • b by
        noncomm_ring]
    exact (I ^ (w + 1)).add_mem hpow hbm

/-- The leading-term comparison for a sorted tail in Hall's Lemma 5.5.
Only factors of the current weight survive modulo the next layer. -/
lemma z_leading_combination
    {ι R : Type*} [Ring R] (I : Ideal R) [I.IsTwoSided]
    (c : ι → Rˣ) (b : ι → R) (m : ι → ℤ) (wt : ι → ℕ)
    (w : ℕ) (l : List ι) (hw : 0 < w)
    (hge : ∀ i ∈ l, w ≤ wt i)
    (hb : ∀ i ∈ l, b i ∈ I ^ wt i)
    (hc : ∀ i ∈ l, (c i : R) - (1 + b i) ∈ I ^ (wt i + 1)) :
    ((orderedZProduct c m l : Rˣ) : R) -
        (1 + weightLeadingCombination b m wt w l) ∈ I ^ (w + 1) := by
  induction l with
  | nil =>
      simp [orderedZProduct, weightLeadingCombination]
  | cons i l ih =>
      have hgei : w ≤ wt i := hge i (by simp)
      have hbi : b i ∈ I ^ wt i := hb i (by simp)
      have hci : (c i : R) - (1 + b i) ∈ I ^ (wt i + 1) := hc i (by simp)
      have hgeTail : ∀ j ∈ l, w ≤ wt j := by
        intro j hj
        exact hge j (by simp [hj])
      have hbTail : ∀ j ∈ l, b j ∈ I ^ wt j := by
        intro j hj
        exact hb j (by simp [hj])
      have hcTail :
          ∀ j ∈ l, (c j : R) - (1 + b j) ∈ I ^ (wt j + 1) := by
        intro j hj
        exact hc j (by simp [hj])
      have hpow :=
        zpow_sub_leading
          I (c i) hw hgei hbi hci (m i)
      have htail := ih hgeTail hbTail hcTail
      have hhead :
          leadingTermWeight (b i) (m i) (wt i) w ∈ I ^ w :=
        leading_term_pow I hgei hbi
      have hsum :
          weightLeadingCombination b m wt w l ∈ I ^ w :=
        leading_combination_pow I b m wt w l hgeTail hbTail
      have hcross0 :
          leadingTermWeight (b i) (m i) (wt i) w *
              weightLeadingCombination b m wt w l ∈ I ^ (w + w) :=
        mul_ideal_add I hhead hsum
      have hcross :
          leadingTermWeight (b i) (m i) (wt i) w *
              weightLeadingCombination b m wt w l ∈ I ^ (w + 1) :=
        (Ideal.pow_le_pow_right (by omega)) hcross0
      have hprod :
          ((c i ^ m i : Rˣ) : R) *
                ((orderedZProduct c m l : Rˣ) : R) -
              (1 + leadingTermWeight (b i) (m i) (wt i) w) *
                (1 + weightLeadingCombination b m wt w l) ∈
            I ^ (w + 1) :=
        sub_ideal (I ^ (w + 1)) hpow htail
      change
        ((c i ^ m i : Rˣ) : R) *
              ((orderedZProduct c m l : Rˣ) : R) -
            (1 + (leadingTermWeight (b i) (m i) (wt i) w +
              weightLeadingCombination b m wt w l)) ∈
          I ^ (w + 1)
      rw [show
          ((c i ^ m i : Rˣ) : R) *
                ((orderedZProduct c m l : Rˣ) : R) -
              (1 + (leadingTermWeight (b i) (m i) (wt i) w +
                weightLeadingCombination b m wt w l)) =
            (((c i ^ m i : Rˣ) : R) *
                ((orderedZProduct c m l : Rˣ) : R) -
              (1 + leadingTermWeight (b i) (m i) (wt i) w) *
                (1 + weightLeadingCombination b m wt w l)) +
              leadingTermWeight (b i) (m i) (wt i) w *
                weightLeadingCombination b m wt w l by
          noncomm_ring]
      exact (I ^ (w + 1)).add_mem hprod hcross

/-- Equal sorted-tail products have equal current-weight leading
combinations modulo the next layer. -/
lemma leading_combination_z
    {ι R : Type*} [Ring R] (I : Ideal R) [I.IsTwoSided]
    (c : ι → Rˣ) (b : ι → R) (lam mu : ι → ℤ) (wt : ι → ℕ)
    (w : ℕ) (l : List ι) (hw : 0 < w)
    (hge : ∀ i ∈ l, w ≤ wt i)
    (hb : ∀ i ∈ l, b i ∈ I ^ wt i)
    (hc : ∀ i ∈ l, (c i : R) - (1 + b i) ∈ I ^ (wt i + 1))
    (hprod : orderedZProduct c lam l = orderedZProduct c mu l) :
    weightLeadingCombination b lam wt w l -
        weightLeadingCombination b mu wt w l ∈ I ^ (w + 1) := by
  have hlam :=
    z_leading_combination
      I c b lam wt w l hw hge hb hc
  have hmu :=
    z_leading_combination
      I c b mu wt w l hw hge hb hc
  have hprodVal :
      ((orderedZProduct c lam l : Rˣ) : R) =
        ((orderedZProduct c mu l : Rˣ) : R) :=
    congrArg Units.val hprod
  have h := (I ^ (w + 1)).sub_mem hmu hlam
  rw [show
      (((orderedZProduct c mu l : Rˣ) : R) -
          (1 + weightLeadingCombination b mu wt w l)) -
        (((orderedZProduct c lam l : Rˣ) : R) -
          (1 + weightLeadingCombination b lam wt w l)) =
        weightLeadingCombination b lam wt w l -
          weightLeadingCombination b mu wt w l by
      rw [hprodVal]
      noncomm_ring] at h
  exact h

/-- **Hall, Lemma 5.5, uniqueness.** For a sequence ordered by
nondecreasing positive weight, equality of ordered products forces
equality of every exponent, provided each weight layer separates its
integer leading combinations modulo the next filtration layer.

In Hall's application, the separation hypothesis is supplied by
Lemma 5.3, while the congruence hypotheses are supplied by Lemma 5.4. -/
theorem principal_exponent_unique
    {ι R : Type*} [Ring R] (I : Ideal R) [I.IsTwoSided]
    (c : ι → Rˣ) (b : ι → R) (wt : ι → ℕ) (l : List ι)
    (hpos : ∀ i ∈ l, 0 < wt i)
    (hsorted : l.Pairwise fun i j => wt i ≤ wt j)
    (hb : ∀ i ∈ l, b i ∈ I ^ wt i)
    (hc : ∀ i ∈ l, (c i : R) - (1 + b i) ∈ I ^ (wt i + 1))
    (lam mu : ι → ℤ)
    (hsep :
      ∀ w,
        weightLeadingCombination b lam wt w l -
            weightLeadingCombination b mu wt w l ∈ I ^ (w + 1) →
          ∀ i ∈ l, wt i = w → lam i = mu i)
    (hprod : orderedZProduct c lam l = orderedZProduct c mu l) :
    ∀ i ∈ l, lam i = mu i := by
  induction l with
  | nil =>
      simp
  | cons i l ih =>
      have hposi : 0 < wt i := hpos i (by simp)
      have hposTail : ∀ j ∈ l, 0 < wt j := by
        intro j hj
        exact hpos j (by simp [hj])
      have hsortedParts := List.pairwise_cons.mp hsorted
      have hi_le : ∀ j ∈ l, wt i ≤ wt j := hsortedParts.1
      have hsortedTail : l.Pairwise fun j k => wt j ≤ wt k := hsortedParts.2
      have hbTail : ∀ j ∈ l, b j ∈ I ^ wt j := by
        intro j hj
        exact hb j (by simp [hj])
      have hcTail :
          ∀ j ∈ l, (c j : R) - (1 + b j) ∈ I ^ (wt j + 1) := by
        intro j hj
        exact hc j (by simp [hj])
      by_cases heq : lam i = mu i
      · have hprodTail :
            orderedZProduct c lam l =
              orderedZProduct c mu l := by
          change
            c i ^ lam i * orderedZProduct c lam l =
              c i ^ mu i * orderedZProduct c mu l at hprod
          rw [heq] at hprod
          exact mul_left_cancel hprod
        have hsepTail :
            ∀ w,
              weightLeadingCombination b lam wt w l -
                  weightLeadingCombination b mu wt w l ∈ I ^ (w + 1) →
                ∀ j ∈ l, wt j = w → lam j = mu j := by
          intro w hlead j hj hjw
          apply hsep w
          · simpa [weightLeadingCombination, heq] using hlead
          · simp [hj]
          · exact hjw
        have htail :=
          ih hposTail hsortedTail hbTail hcTail hsepTail hprodTail
        intro j hj
        rcases List.mem_cons.mp hj with rfl | hj
        · exact heq
        · exact htail j hj
      · have hge : ∀ j ∈ i :: l, wt i ≤ wt j := by
          intro j hj
          rcases List.mem_cons.mp hj with rfl | hj
          · exact le_rfl
          · exact hi_le j hj
        have hlead :=
          leading_combination_z
            I c b lam mu wt (wt i) (i :: l) hposi hge hb hc hprod
        have := hsep (wt i) hlead i (by simp) rfl
        exact (heq this).elim

/-- **Hall, Lemma 5.5, abstract normal-form package.** Suppose collection
provides an ordered-product expression for every element of `H`. If the
factors have positive nondecreasing weights and their leading terms
separate every weight layer, then all exponents occurring in the displayed
ordered list are uniquely determined.

This separates the two ingredients in Hall's proof: existence comes from
repeated collection using Lemma 5.1, and uniqueness comes from Lemmas 5.3
and 5.4 via `principal_exponent_unique`. -/
theorem principal_form_unique
    {ι R : Type*} [Ring R] (I : Ideal R) [I.IsTwoSided]
    (c : ι → Rˣ) (b : ι → R) (wt : ι → ℕ) (l : List ι)
    (H : Subgroup Rˣ)
    (hpos : ∀ i ∈ l, 0 < wt i)
    (hsorted : l.Pairwise fun i j => wt i ≤ wt j)
    (hb : ∀ i ∈ l, b i ∈ I ^ wt i)
    (hc : ∀ i ∈ l, (c i : R) - (1 + b i) ∈ I ^ (wt i + 1))
    (hexists :
      ∀ h : H, ∃ m : ι → ℤ,
        orderedZProduct c m l = h.1)
    (hsep :
      ∀ (lam mu : ι → ℤ) w,
        weightLeadingCombination b lam wt w l -
            weightLeadingCombination b mu wt w l ∈ I ^ (w + 1) →
          ∀ i ∈ l, wt i = w → lam i = mu i) :
    ∀ h : H, ∃ m : ι → ℤ,
      orderedZProduct c m l = h.1 ∧
        ∀ mu : ι → ℤ,
          orderedZProduct c mu l = h.1 →
            ∀ i ∈ l, mu i = m i := by
  intro h
  obtain ⟨m, hm⟩ := hexists h
  refine ⟨m, hm, ?_⟩
  intro mu hmu
  exact principal_exponent_unique I c b wt l hpos hsorted hb hc mu m
    (hsep mu m) (hmu.trans hm.symm)

/-- The form of Lemma 5.5 used in Hall's proof of Theorem 5.6: if an
ordered product is one, every displayed exponent is zero. -/
theorem ordered_principal_exponents
    {ι R : Type*} [Ring R] (I : Ideal R) [I.IsTwoSided]
    (c : ι → Rˣ) (b : ι → R) (wt : ι → ℕ) (l : List ι)
    (hpos : ∀ i ∈ l, 0 < wt i)
    (hsorted : l.Pairwise fun i j => wt i ≤ wt j)
    (hb : ∀ i ∈ l, b i ∈ I ^ wt i)
    (hc : ∀ i ∈ l, (c i : R) - (1 + b i) ∈ I ^ (wt i + 1))
    (m : ι → ℤ)
    (hsep :
      ∀ w,
        weightLeadingCombination b m wt w l -
            weightLeadingCombination b (fun _ => 0) wt w l ∈ I ^ (w + 1) →
          ∀ i ∈ l, wt i = w → m i = 0)
    (hprod : orderedZProduct c m l = 1) :
    ∀ i ∈ l, m i = 0 := by
  have hzeroProd :
      orderedZProduct c (fun _ => 0) l = 1 := by
    rw [ordered_z_product]
    exact ordered_z_zero c (fun _ => 0) l
      (by simp)
  exact principal_exponent_unique I c b wt l hpos hsorted hb hc
    m (fun _ => 0) hsep (hprod.trans hzeroProd.symm)

/-- Lemma 5.5 applied to a subgroup of the unit group. This is the exact
uniqueness input required by the free-group kernel argument. -/
theorem subgroup_exponents_zero
    {ι R : Type*} [Ring R] (I : Ideal R) [I.IsTwoSided]
    (H : Subgroup Rˣ) (c : ι → H) (b : ι → R)
    (wt : ι → ℕ) (l : List ι)
    (hpos : ∀ i ∈ l, 0 < wt i)
    (hsorted : l.Pairwise fun i j => wt i ≤ wt j)
    (hb : ∀ i ∈ l, b i ∈ I ^ wt i)
    (hc : ∀ i ∈ l, ((c i : H) : Rˣ) - (1 + b i) ∈ I ^ (wt i + 1))
    (hsep :
      ∀ (lam mu : ι → ℤ) w,
        weightLeadingCombination b lam wt w l -
            weightLeadingCombination b mu wt w l ∈ I ^ (w + 1) →
          ∀ i ∈ l, wt i = w → lam i = mu i)
    (m : ι → ℤ)
    (hprod : orderedZPow c m l = 1) :
    ∀ i ∈ l, m i = 0 := by
  have hprodUnits :
      orderedZProduct (fun i => (c i : Rˣ)) m l = 1 := by
    rw [ordered_z_product,
      ← ordered_z_list H.subtype c
        (fun i => (c i : Rˣ)) m l (by simp)]
    simp [hprod]
  exact ordered_principal_exponents I
    (fun i => (c i : Rˣ)) b wt l hpos hsorted hb hc m
      (hsep m (fun _ => 0)) hprodUnits

/-- If a lower-central term vanishes in the target of a homomorphism, the
corresponding lower-central term of the source lies in its kernel. -/
lemma lower_target_bot
    {G H : Type*} [Group G] [Group H]
    (f : G →* H) (n : ℕ) (hH : Subgroup.lowerCentralSeries H n = ⊥) :
    Subgroup.lowerCentralSeries G n ≤ f.ker := by
  rw [← Subgroup.map_eq_bot_iff]
  apply eq_bot_iff.mpr
  exact (Subgroup.lowerCentralSeries.map f n).trans (by rw [hH])

/-- A function into a group generates the target exactly when its free-group
lift is surjective. -/
lemma free_range_top
    {α H : Type*} [Group H] (y : α → H)
    (hgen : Subgroup.closure (Set.range y) = ⊤) :
    Function.Surjective (FreeGroup.lift y) := by
  rw [← MonoidHom.range_eq_top, FreeGroup.range_lift_eq_closure, hgen]

/-- Hall's kernel argument in Theorem 5.6. Suppose `N ≤ ker θ`, every source
element has an ordered normal form modulo `N`, and the corresponding ordered
products in the target have unique exponents. Then `ker θ ≤ N`.

For Hall's application, `N` is the appropriate lower-central term of the
free group. -/
theorem ker_forms_unique
    {ι F H : Type*} [Group F] [Group H]
    (N : Subgroup F) (θ : F →* H)
    (cF : ι → F) (cH : ι → H) (l : List ι)
    (hNker : N ≤ θ.ker)
    (hmap : ∀ i ∈ l, θ (cF i) = cH i)
    (hcollect :
      ∀ x : F, ∃ m : ι → ℤ,
        x * (orderedZPow cF m l)⁻¹ ∈ N)
    (hunique :
      ∀ m : ι → ℤ,
        orderedZPow cH m l = 1 →
          ∀ i ∈ l, m i = 0) :
    θ.ker ≤ N := by
  intro x hx
  obtain ⟨m, hm⟩ := hcollect x
  have hθx : θ x = 1 := MonoidHom.mem_ker.mp hx
  have hθrel :
      θ (x * (orderedZPow cF m l)⁻¹) = 1 :=
    MonoidHom.mem_ker.mp (hNker hm)
  have hθprod : θ (orderedZPow cF m l) = 1 := by
    simpa [hθx] using hθrel
  have hprodH : orderedZPow cH m l = 1 := by
    rw [← ordered_z_list θ cF cH m l hmap]
    exact hθprod
  have hzero : ∀ i ∈ l, m i = 0 := hunique m hprodH
  have hprodF : orderedZPow cF m l = 1 :=
    ordered_z_zero cF m l hzero
  simpa [hprodF] using hm

/-- **Hall, Theorem 5.6, normal-form form.** Let `F` be the free group on
the symbols `α`, and let `θ : F → H` send them to a generating family `y`.
If `H` has lower-central term `γₙ(H)` trivial, collection gives ordered
normal forms modulo `γₙ(F)`, and those forms have unique exponents in `H`,
then `H ≃ F / γₙ(F)`.

Mathlib numbers the lower central series from zero, so Hall's one-based
`γₙ` is `Subgroup.lowerCentralSeries _ (n - 1)` here. -/
noncomputable def free_nilpotent_forms
    {α ι H : Type*} [Group H]
    (y : α → H) (n : ℕ)
    (cF : ι → FreeGroup α) (cH : ι → H) (l : List ι)
    (hgen : Subgroup.closure (Set.range y) = ⊤)
    (hH : Subgroup.lowerCentralSeries H (n - 1) = ⊥)
    (hmap : ∀ i ∈ l, FreeGroup.lift y (cF i) = cH i)
    (hcollect :
      ∀ x : FreeGroup α, ∃ m : ι → ℤ,
        x * (orderedZPow cF m l)⁻¹ ∈
          Subgroup.lowerCentralSeries (FreeGroup α) (n - 1))
    (hunique :
      ∀ m : ι → ℤ,
        orderedZPow cH m l = 1 →
          ∀ i ∈ l, m i = 0) :
    FreeGroup α ⧸ Subgroup.lowerCentralSeries (FreeGroup α) (n - 1) ≃* H := by
  let θ : FreeGroup α →* H := FreeGroup.lift y
  have hsurj : Function.Surjective θ :=
    free_range_top y hgen
  have htermKer :
      Subgroup.lowerCentralSeries (FreeGroup α) (n - 1) ≤ θ.ker :=
    lower_target_bot θ (n - 1) hH
  have hkerTerm :
      θ.ker ≤ Subgroup.lowerCentralSeries (FreeGroup α) (n - 1) :=
    ker_forms_unique
      (Subgroup.lowerCentralSeries (FreeGroup α) (n - 1))
      θ cF cH l htermKer hmap hcollect hunique
  exact QuotientGroup.liftEquiv
    (Subgroup.lowerCentralSeries (FreeGroup α) (n - 1)) hsurj
      (le_antisymm htermKer hkerTerm)

/-- **Hall, Theorem 5.6, filtered-ring specialization.** The congruences
from Lemma 5.4 and the weight-layer separation from Lemma 5.3 imply the
uniqueness hypothesis in `free_nilpotent_forms`. Thus only
the collection normal forms modulo `γₙ(F)` and the nilpotence of `H` remain
as group-theoretic inputs. -/
noncomputable def nilpotent_filtered_forms
    {α ι R : Type*} [Ring R] (I : Ideal R) [I.IsTwoSided]
    (H : Subgroup Rˣ) (y : α → H) (n : ℕ)
    (cF : ι → FreeGroup α) (cH : ι → H)
    (b : ι → R) (wt : ι → ℕ) (l : List ι)
    (hgen : Subgroup.closure (Set.range y) = ⊤)
    (hH : Subgroup.lowerCentralSeries H (n - 1) = ⊥)
    (hmap : ∀ i ∈ l, FreeGroup.lift y (cF i) = cH i)
    (hcollect :
      ∀ x : FreeGroup α, ∃ m : ι → ℤ,
        x * (orderedZPow cF m l)⁻¹ ∈
          Subgroup.lowerCentralSeries (FreeGroup α) (n - 1))
    (hpos : ∀ i ∈ l, 0 < wt i)
    (hsorted : l.Pairwise fun i j => wt i ≤ wt j)
    (hb : ∀ i ∈ l, b i ∈ I ^ wt i)
    (hc : ∀ i ∈ l, ((cH i : H) : Rˣ) - (1 + b i) ∈ I ^ (wt i + 1))
    (hsep :
      ∀ (lam mu : ι → ℤ) w,
        weightLeadingCombination b lam wt w l -
            weightLeadingCombination b mu wt w l ∈ I ^ (w + 1) →
          ∀ i ∈ l, wt i = w → lam i = mu i) :
    FreeGroup α ⧸ Subgroup.lowerCentralSeries (FreeGroup α) (n - 1) ≃* H :=
  free_nilpotent_forms y n cF cH l hgen hH hmap hcollect
    (fun m hprod =>
      subgroup_exponents_zero
        I H cH b wt l hpos hsorted hb hc hsep m hprod)

/-- A commutative group in which every element has a unique finite integer
linear combination of a family `c` is the free abelian group on that family.
The codomain is written additively so that the resulting equivalence records
the claimed free-abelian structure directly. -/
noncomputable def abelianUniqueExpressions
    {ι A : Type*} [CommGroup A] (c : ι → A)
    (hexists :
      Function.Surjective
        (FreeAbelianGroup.lift (fun i => Additive.ofMul (c i))))
    (hunique :
      ∀ z : FreeAbelianGroup ι,
        FreeAbelianGroup.lift (fun i => Additive.ofMul (c i)) z = 0 →
          z = 0) :
    FreeAbelianGroup ι ≃+ Additive A := by
  let f : FreeAbelianGroup ι →+ Additive A :=
    FreeAbelianGroup.lift (fun i => Additive.ofMul (c i))
  apply AddEquiv.ofBijective f
  refine ⟨?_, hexists⟩
  intro x y hxy
  have hzero : f (x - y) = 0 := by
    rw [map_sub, hxy, sub_self]
  exact sub_eq_zero.mp (hunique (x - y) hzero)

/-- The equivalence supplied by unique expressions sends each canonical
free-abelian basis element to the corresponding selected element. -/
@[simp]
theorem abelian_unique_expressions
    {ι A : Type*} [CommGroup A] (c : ι → A)
    (hexists :
      Function.Surjective
        (FreeAbelianGroup.lift (fun i => Additive.ofMul (c i))))
    (hunique :
      ∀ z : FreeAbelianGroup ι,
        FreeAbelianGroup.lift (fun i => Additive.ofMul (c i)) z = 0 →
          z = 0)
    (i : ι) :
    abelianUniqueExpressions c hexists hunique
        (FreeAbelianGroup.of i) =
      Additive.ofMul (c i) := by
  simp [abelianUniqueExpressions]

/-- Hall's one-based lower-central factor `γ_w(G) / γ_{w+1}(G)`.
Mathlib's lower central series is zero-based, so the numerator has index
`w - 1` and the denominator has index `w`. -/
def lowerCentralFactor (G : Type u) [Group G] (w : ℕ) : Type u :=
  (Subgroup.lowerCentralSeries G (w - 1)) ⧸
    (Subgroup.lowerCentralSeries G w).subgroupOf (Subgroup.lowerCentralSeries G (w - 1))

/-- The inherited quotient-group structure on a lower-central factor. -/
instance lower_factor_group
    {G : Type u} [Group G] (w : ℕ) :
    Group (lowerCentralFactor G w) := by
  unfold lowerCentralFactor
  infer_instance

/-- Every positive-weight lower-central factor is commutative. -/
instance lower_factor_commutative
    {G : Type u} [Group G] (w : ℕ) [Fact (0 < w)] :
    IsMulCommutative (lowerCentralFactor G w) := by
  apply (Subgroup.Normal.quotient_commutative_iff_commutator_le).2
  change
    commutator (Subgroup.lowerCentralSeries G (w - 1)) ≤
      (Subgroup.lowerCentralSeries G w).subgroupOf (Subgroup.lowerCentralSeries G (w - 1))
  intro x hx
  rw [Subgroup.mem_subgroupOf]
  have hxAmbient :
      (x : G) ∈
        ⁅Subgroup.lowerCentralSeries G (w - 1), Subgroup.lowerCentralSeries G (w - 1)⁆ := by
    rw [← Subgroup.map_subtype_commutator (Subgroup.lowerCentralSeries G (w - 1))]
    exact Subgroup.mem_map_of_mem (Subgroup.lowerCentralSeries G (w - 1)).subtype hx
  exact Subgroup.lowerCentralSeries_antitone (by omega)
    (lower_central_commutator (G := G) (w - 1) (w - 1) hxAmbient)

/-- **Hall, corollary after Theorem 5.6, abstract basis form.** For positive
`w`, once the selected weight-`w` commutators give unique expressions in
`γ_w(G) / γ_{w+1}(G)`, that factor is the free abelian group on those
commutators. The equivalence sends each canonical free-abelian generator to
its represented commutator class. -/
noncomputable def lower_abelian_equiv
    {ι G : Type*} [Group G] (w : ℕ) [Fact (0 < w)]
    (c : ι → lowerCentralFactor G w)
    (hexists :
      Function.Surjective
        (FreeAbelianGroup.lift (fun i => Additive.ofMul (c i))))
    (hunique :
      ∀ z : FreeAbelianGroup ι,
        FreeAbelianGroup.lift (fun i => Additive.ofMul (c i)) z = 0 →
          z = 0) :
    FreeAbelianGroup ι ≃+ Additive (lowerCentralFactor G w) :=
  abelianUniqueExpressions c hexists hunique

/-- The basis-identification part of Hall's corollary after Theorem 5.6. -/
@[simp]
theorem lower_free_abelian
    {ι G : Type*} [Group G] (w : ℕ) [Fact (0 < w)]
    (c : ι → lowerCentralFactor G w)
    (hexists :
      Function.Surjective
        (FreeAbelianGroup.lift (fun i => Additive.ofMul (c i))))
    (hunique :
      ∀ z : FreeAbelianGroup ι,
        FreeAbelianGroup.lift (fun i => Additive.ofMul (c i)) z = 0 →
          z = 0)
    (i : ι) :
    lower_abelian_equiv w c hexists hunique
        (FreeAbelianGroup.of i) =
      Additive.ofMul (c i) := by
  simp [lower_abelian_equiv]

/-- The integer numerator in Witt's formula. -/
def wittNumerator (q w : ℕ) : ℤ :=
  w.divisors.sum fun d : ℕ =>
    ArithmeticFunction.moebius d * (q : ℤ) ^ (w / d)

/-- **Witt, Theorem 5.7, Möbius-inversion form.** If the number `n(w)` of
weight-`w` basic commutators satisfies the coefficient identity
`q^w = ∑_{d ∣ w} d n(d)`, then
`w n(w) = ∑_{d ∣ w} μ(d) q^(w/d)`.

This is the integral form of Witt's formula and records the divisibility by
`w` automa. -/
theorem witt_numerator_count
    (q : ℕ) (nBasic : ℕ → ℕ)
    (hcoeff :
      ∀ w > 0,
        w.divisors.sum (fun d : ℕ => (d : ℤ) * (nBasic d : ℤ)) =
          (q : ℤ) ^ w)
    (w : ℕ) (hw : 0 < w) :
    (w : ℤ) * (nBasic w : ℤ) = wittNumerator q w := by
  have hinv :=
    (ArithmeticFunction.sum_eq_iff_sum_mul_moebius_eq
      (f := fun d => (d : ℤ) * (nBasic d : ℤ))
      (g := fun r => (q : ℤ) ^ r)).mp hcoeff w hw
  rw [wittNumerator, ← Nat.sum_divisorsAntidiagonal
    (fun d e => ArithmeticFunction.moebius d * (q : ℤ) ^ e)]
  exact hinv.symm

/-- **Witt, Theorem 5.7.** Rational form of the displayed formula
`n(w,q) = (1/w) ∑_{d ∣ w} μ(d) q^(w/d)`. -/
theorem wittFormula
    (q : ℕ) (nBasic : ℕ → ℕ)
    (hcoeff :
      ∀ w > 0,
        w.divisors.sum (fun d : ℕ => (d : ℤ) * (nBasic d : ℤ)) =
          (q : ℤ) ^ w)
    (w : ℕ) (hw : 0 < w) :
    (nBasic w : ℚ) =
      w.divisors.sum
          (fun d : ℕ =>
            (ArithmeticFunction.moebius d : ℚ) * (q : ℚ) ^ (w / d)) /
        (w : ℚ) := by
  rw [eq_div_iff (by positivity)]
  have hcast :=
    congrArg (fun z : ℤ => (z : ℚ))
      (witt_numerator_count q nBasic hcoeff w hw)
  simpa [wittNumerator, mul_comm] using hcast

/-- The local filtered-ring identity behind Hall's Lemma 5.4. If
`β` and `γ` have positive filtration degrees `r` and `s`, then
`(1+β)(1+γ)` equals `(1+γ)(1+β)(1+[β,γ])` modulo degree
`r+s+1`. -/
lemma sub_swapped_bracket
    {R : Type*} [Ring R] (I : Ideal R) [I.IsTwoSided]
    {β γ : R} {r s : ℕ} (hr : 0 < r) (hs : 0 < s)
    (hβ : β ∈ I ^ r) (hγ : γ ∈ I ^ s) :
    (1 + β) * (1 + γ) -
        ((1 + γ) * (1 + β) * (1 + associativeBracket β γ)) ∈
      I ^ (r + s + 1) := by
  let c := associativeBracket β γ
  have hc : c ∈ I ^ (r + s) :=
    associative_bracket_add I hβ hγ
  have hβc0 : β * c ∈ I ^ (r + (r + s)) :=
    mul_ideal_add I hβ hc
  have hβc : β * c ∈ I ^ (r + s + 1) :=
    (Ideal.pow_le_pow_right (by omega)) hβc0
  have hγc0 : γ * c ∈ I ^ (s + (r + s)) :=
    mul_ideal_add I hγ hc
  have hγc : γ * c ∈ I ^ (r + s + 1) :=
    (Ideal.pow_le_pow_right (by omega)) hγc0
  have hγβ : γ * β ∈ I ^ (s + r) :=
    mul_ideal_add I hγ hβ
  have hγβc0 : (γ * β) * c ∈ I ^ ((s + r) + (r + s)) :=
    mul_ideal_add I hγβ hc
  have hγβc : (γ * β) * c ∈ I ^ (r + s + 1) :=
    (Ideal.pow_le_pow_right (by omega)) hγβc0
  rw [show
      (1 + β) * (1 + γ) -
          ((1 + γ) * (1 + β) * (1 + associativeBracket β γ)) =
        -(β * c + γ * c + (γ * β) * c) by
      dsimp [c, associativeBracket]
      noncomm_ring]
  exact (I ^ (r + s + 1)).neg_mem
    ((I ^ (r + s + 1)).add_mem
      ((I ^ (r + s + 1)).add_mem hβc hγc) hγβc)

/-- Unit-level form of the local comparison in Hall's Lemma 5.4:
the multiplicative Hall commutator of `1+β` and `1+γ` is congruent to
`1 + (βγ-γβ)` modulo filtration degree `r+s+1`. -/
lemma units_associative_bracket
    {R : Type*} [Ring R] (I : Ideal R) [I.IsTwoSided]
    (c d : Rˣ) {β γ : R} {r s : ℕ} (hr : 0 < r) (hs : 0 < s)
    (hβ : β ∈ I ^ r) (hγ : γ ∈ I ^ s)
    (hc : (c : R) = 1 + β) (hd : (d : R) = 1 + γ) :
    ((hallCommutator c d : Rˣ) : R) -
        (1 + associativeBracket β γ) ∈
      I ^ (r + s + 1) := by
  have hrel :=
    sub_swapped_bracket
      I hr hs hβ hγ
  rw [← hc, ← hd] at hrel
  have hmul :=
    (I ^ (r + s + 1)).mul_mem_left (((d * c)⁻¹ : Rˣ) : R) hrel
  simpa [hallCommutator, mul_sub, mul_assoc] using hmul

/-- Multiplication respects one-higher-order congruences in a two-sided
ideal filtration. -/
lemma mul_sub_ideal
    {R : Type*} [Ring R] (I : Ideal R) [I.IsTwoSided]
    {a a₀ b b₀ : R} {r s : ℕ}
    (ha₀ : a₀ ∈ I ^ r) (hb : b ∈ I ^ s)
    (haa₀ : a - a₀ ∈ I ^ (r + 1))
    (hbb₀ : b - b₀ ∈ I ^ (s + 1)) :
    a * b - a₀ * b₀ ∈ I ^ (r + s + 1) := by
  have hleft0 : (a - a₀) * b ∈ I ^ ((r + 1) + s) :=
    mul_ideal_add I haa₀ hb
  have hleft : (a - a₀) * b ∈ I ^ (r + s + 1) := by
    simpa [Nat.add_assoc, Nat.add_comm, Nat.add_left_comm] using hleft0
  have hright0 : a₀ * (b - b₀) ∈ I ^ (r + (s + 1)) :=
    mul_ideal_add I ha₀ hbb₀
  have hright : a₀ * (b - b₀) ∈ I ^ (r + s + 1) := by
    simpa [Nat.add_assoc] using hright0
  rw [show a * b - a₀ * b₀ =
      (a - a₀) * b + a₀ * (b - b₀) by noncomm_ring]
  exact (I ^ (r + s + 1)).add_mem hleft hright

/-- Associative brackets respect one-higher-order congruences in each
argument. -/
lemma associative_bracket_sub
    {R : Type*} [Ring R] (I : Ideal R) [I.IsTwoSided]
    {a a₀ b b₀ : R} {r s : ℕ}
    (ha : a ∈ I ^ r) (ha₀ : a₀ ∈ I ^ r)
    (hb : b ∈ I ^ s) (hb₀ : b₀ ∈ I ^ s)
    (haa₀ : a - a₀ ∈ I ^ (r + 1))
    (hbb₀ : b - b₀ ∈ I ^ (s + 1)) :
    associativeBracket a b - associativeBracket a₀ b₀ ∈
      I ^ (r + s + 1) := by
  have hab :
      a * b - a₀ * b₀ ∈ I ^ (r + s + 1) :=
    mul_sub_ideal I ha₀ hb haa₀ hbb₀
  have hba0 :
      b * a - b₀ * a₀ ∈ I ^ (s + r + 1) :=
    mul_sub_ideal I hb₀ ha hbb₀ haa₀
  have hba :
      b * a - b₀ * a₀ ∈ I ^ (r + s + 1) := by
    simpa [Nat.add_comm] using hba0
  rw [show
      associativeBracket a b - associativeBracket a₀ b₀ =
        (a * b - a₀ * b₀) - (b * a - b₀ * a₀) by
      unfold associativeBracket
      noncomm_ring]
  exact (I ^ (r + s + 1)).sub_mem hab hba

/-- The induction step in Hall's Lemma 5.4. If two unit-valued
expressions agree with `1+b` and `1+d` to one order above their
respective weights, then their multiplicative commutator agrees with
`1+[b,d]` to one order above the sum of the weights. -/
lemma principal_congr_step
    {R : Type*} [Ring R] (I : Ideal R) [I.IsTwoSided]
    (c d : Rˣ) {β γ b e : R} {r s : ℕ}
    (hr : 0 < r) (hs : 0 < s)
    (hβ : β ∈ I ^ r) (hb : b ∈ I ^ r)
    (hγ : γ ∈ I ^ s) (he : e ∈ I ^ s)
    (hβb : β - b ∈ I ^ (r + 1))
    (hγe : γ - e ∈ I ^ (s + 1))
    (hc : (c : R) = 1 + β) (hd : (d : R) = 1 + γ) :
    ((hallCommutator c d : Rˣ) : R) -
        (1 + associativeBracket b e) ∈
      I ^ (r + s + 1) := by
  have hunit :=
    units_associative_bracket
      I c d hr hs hβ hγ hc hd
  have hbracket :=
    associative_bracket_sub
      I hβ hb hγ he hβb hγe
  rw [show
      ((hallCommutator c d : Rˣ) : R) -
          (1 + associativeBracket b e) =
        (((hallCommutator c d : Rˣ) : R) -
            (1 + associativeBracket β γ)) +
          (associativeBracket β γ - associativeBracket b e) by
      noncomm_ring]
  exact (I ^ (r + s + 1)).add_mem hunit hbracket

/-- **Hall, Lemma 5.4.** Let `I` be a two-sided ideal in an associative
ring. If every group variable `yₓ` is the unit `1 + fₓ`, with `fₓ ∈ I`,
then a formal group commutator of weight `r` is congruent to one plus the
corresponding associative-ring commutator modulo `I ^ (r + 1)`. -/
theorem formal_principal_congr
    {X R : Type*} [Ring R] (I : Ideal R) [I.IsTwoSided]
    (f : X → R) (y : X → Rˣ)
    (hf : ∀ x, f x ∈ I)
    (hy : ∀ x, (y x : R) = 1 + f x)
    (u : FormalCommutator X) :
    ((formalGroupCommutator y u : Rˣ) : R) -
        (1 + evalFormalCommutator f u) ∈
      I ^ (formalWeight u + 1) := by
  induction u with
  | of x =>
      simp [hy x]
  | mul u v ihu ihv =>
      let b := evalFormalCommutator f u
      let e := evalFormalCommutator f v
      let c := formalGroupCommutator y u
      let d := formalGroupCommutator y v
      let β : R := (c : R) - 1
      let γ : R := (d : R) - 1
      have hb : b ∈ I ^ formalWeight u :=
        formal_commutator_pow I f hf u
      have he : e ∈ I ^ formalWeight v :=
        formal_commutator_pow I f hf v
      have hβb : β - b ∈ I ^ (formalWeight u + 1) := by
        rw [show β - b = (c : R) - (1 + b) by
          dsimp [β]
          noncomm_ring]
        simpa [c, b] using ihu
      have hγe : γ - e ∈ I ^ (formalWeight v + 1) := by
        rw [show γ - e = (d : R) - (1 + e) by
          dsimp [γ]
          noncomm_ring]
        simpa [d, e] using ihv
      have hβb' : β - b ∈ I ^ formalWeight u :=
        (Ideal.pow_le_pow_right (Nat.le_succ _)) hβb
      have hγe' : γ - e ∈ I ^ formalWeight v :=
        (Ideal.pow_le_pow_right (Nat.le_succ _)) hγe
      have hβ : β ∈ I ^ formalWeight u := by
        rw [show β = b + (β - b) by noncomm_ring]
        exact (I ^ formalWeight u).add_mem hb hβb'
      have hγ : γ ∈ I ^ formalWeight v := by
        rw [show γ = e + (γ - e) by noncomm_ring]
        exact (I ^ formalWeight v).add_mem he hγe'
      have hc : (c : R) = 1 + β := by
        dsimp [β]
        noncomm_ring
      have hd : (d : R) = 1 + γ := by
        dsimp [γ]
        noncomm_ring
      have hstep :=
        principal_congr_step I c d
          (FreeMagma.length_pos u) (FreeMagma.length_pos v)
          hβ hb hγ he hβb hγe hc hd
      simpa [c, d, b, e] using hstep

/-- The triangular content of Hall's equation (3): the iterated bracket
`[u,v,...,v]` has leading term `uv^n`, and every other term is
left-divisible by `v`. -/
lemma iterated_associative_bracket
    {R : Type*} [Ring R] (u v : R) :
    ∀ n : ℕ, ∃ z : R,
      iteratedAssociativeBracket u v n = u * v ^ n + v * z := by
  intro n
  induction n with
  | zero =>
      exact ⟨0, by simp⟩
  | succ n ih =>
      obtain ⟨z, hz⟩ := ih
      refine ⟨z * v - iteratedAssociativeBracket u v n, ?_⟩
      rw [iterated_associative_succ, associativeBracket, hz,
        pow_succ]
      noncomm_ring

/-- Hall's collection rewrite: a block `uv^n` is an iterated bracket
plus terms which begin with `v`. Repeated use of this relation decreases
the number of out-of-order pairs in Lemma 5.3. -/
lemma associative_bracket_left
    {R : Type*} [Ring R] (u v : R) (n : ℕ) :
    ∃ z : R,
      u * v ^ n = iteratedAssociativeBracket u v n + v * z := by
  obtain ⟨z, hz⟩ :=
    iterated_associative_bracket u v n
  refine ⟨-z, ?_⟩
  rw [hz]
  noncomm_ring

/-- **Hall, Lemma 5.3, basis step.** Once the weight-`w` basic
products span `R_w` and their number equals the rank of `R_w`, they form
a basis of the free additive abelian group `R_w`.

The preceding triangular collection relation is the algebraic step used
in Hall's proof to establish `hspan`; the counting corollary after
Lemma 5.2 establishes `hcard`. -/
noncomputable def basisBasicProducts
    {ι M : Type*} [Fintype ι] [AddCommGroup M] [Module ℤ M]
    (basicProducts : ι → M)
    (hspan : ⊤ ≤ Submodule.span ℤ (Set.range basicProducts))
    (hcard : Fintype.card ι = Module.finrank ℤ M) :
    Module.Basis ι ℤ M :=
  basisOfTopLeSpanOfCardEqFinrank basicProducts hspan hcard

/-- In particular, the basic products in Hall's Lemma 5.3 are linearly
independent once the span and cardinality parts of the collecting
argument have been proved. -/
theorem products_independent_card
    {ι M : Type*} [Fintype ι] [AddCommGroup M] [Module ℤ M]
    (basicProducts : ι → M)
    (hspan : ⊤ ≤ Submodule.span ℤ (Set.range basicProducts))
    (hcard : Fintype.card ι = Module.finrank ℤ M) :
    LinearIndependent ℤ basicProducts :=
  by
    simpa [basisBasicProducts] using
      (basisBasicProducts basicProducts hspan hcard).linearIndependent

/-- A group is residually finite-`p` if every nonidentity element survives
in a finite quotient which is a `p`-group. This is Hall's definition
immediately before Theorem 5.8, expressed using bundled finite-index normal
subgroups. -/
def RFP (p : ℕ) (G : Type u) [Group G] : Prop :=
  ∀ g : G, g ≠ 1 →
    ∃ K : FiniteIndexNormalSubgroup G,
      IsPGroup p (G ⧸ K.toSubgroup) ∧ g ∉ K

/-- Residually finite-`p` groups are residually finite. -/
theorem RFP.residuallyFinite
    {p : ℕ} (h : RFP p G) :
    _root_.Group.ResiduallyFinite G := by
  rw [_root_.Group.residuallyFinite_iff_exists_finiteIndexNormalSubgroup]
  intro g hg
  obtain ⟨K, _hKp, hgK⟩ := h g hg
  exact ⟨K, hgK⟩

/-- Since finite `p`-groups are nilpotent, a residually finite-`p` group
has trivial intersection of its lower central series. This is the
"in particular" assertion of Hall's Theorem 5.8. -/
theorem RFP.iinf_lowercentral_serieseqbot
    {p : ℕ} [Fact p.Prime] (h : RFP p G) :
    (⨅ n : ℕ, Subgroup.lowerCentralSeries G n) = ⊥ := by
  rw [Subgroup.eq_bot_iff_forall]
  intro g hg
  rw [Subgroup.mem_iInf] at hg
  by_contra hgne
  obtain ⟨K, hKp, hgK⟩ := h g hgne
  letI : K.toSubgroup.Normal := K.isNormal'
  letI : K.toSubgroup.FiniteIndex := K.isFiniteIndex'
  let q : G →* (G ⧸ K.toSubgroup) := QuotientGroup.mk' K.toSubgroup
  have hnil : _root_.Group.IsNilpotent (G ⧸ K.toSubgroup) :=
    _root_.IsPGroup.isNilpotent hKp
  obtain ⟨n, hn⟩ := Subgroup.nilpotent_iff_lowerCentralSeries.mp hnil
  have hqmemMap :
      q g ∈ Subgroup.map q (Subgroup.lowerCentralSeries G n) :=
    ⟨g, hg n, rfl⟩
  have hqmem : q g ∈ Subgroup.lowerCentralSeries (G ⧸ K.toSubgroup) n :=
    Subgroup.lowerCentralSeries.map q n hqmemMap
  have hqbot : q g ∈ (⊥ : Subgroup (G ⧸ K.toSubgroup)) :=
    hn ▸ hqmem
  have hqeq : q g = 1 := by
    exact Subgroup.mem_bot.mp hqbot
  apply hgK
  exact FiniteIndexNormalSubgroup.mem_toSubgroup_iff.mp
    ((QuotientGroup.eq_one_iff g).mp (by simpa [q] using hqeq))

/-- **Hall, Theorem 5.8.** Hall's truncated noncommutative-polynomial
construction supplies `hseparate`: for every nonidentity free-group word,
a finite `p`-group quotient in which it survives. Consequently the free
group is residually finite-`p`, and its lower central series has trivial
intersection. -/
theorem residually_inf_bot
    {α : Type u} {p : ℕ} [Fact p.Prime]
    (hseparate :
      ∀ y : FreeGroup α, y ≠ 1 →
        ∃ K : FiniteIndexNormalSubgroup (FreeGroup α),
          IsPGroup p (FreeGroup α ⧸ K.toSubgroup) ∧ y ∉ K) :
    RFP p (FreeGroup α) ∧
      (⨅ n : ℕ, Subgroup.lowerCentralSeries (FreeGroup α) n) = ⊥ := by
  have hres : RFP p (FreeGroup α) := hseparate
  exact ⟨hres, hres.iinf_lowercentral_serieseqbot⟩

end Edmonton
end Towers
