open GroupAlgebra

noncomputable section

variable (p : ℕ) (P : Presentation) [Fact p.Prime] [Fintype P.Gen] [Fintype P.Relator]

/-- Conditional generator bound using the first Zassenhaus quotient. -/
theorem card_generators_reverse
    (hrev : zSubgro p P.Group 2 ≤ modPFrattini p P.Group) :
    Fintype.card P.Gen ≤
      Module.finrank (ZMod p) (zTAdditi p P.Group) +
        Fintype.card P.Relator := by
  classical
  have hf := finrank_relator_reverse
    (p := p) (P := P) hrev
  have hb := finrank_span_relators (p := p) (P := P)
  omega

/-- Conditional generator bound using the first Zassenhaus layer kernel. -/
theorem card_relators_reverse
    (hrev : zSubgro p P.Group 2 ≤ modPFrattini p P.Group) :
    Fintype.card P.Gen ≤
      Module.finrank (ZMod p) (Additive (zLKern p P.Group 1)) +
        Fintype.card P.Relator := by
  classical
  have hf := finrank_span_reverse
    (p := p) (P := P) hrev
  have hb := finrank_span_relators (p := p) (P := P)
  omega

