import Towers.Group.DegreeOneMinimal
import Mathlib.LinearAlgebra.Dimension.Constructions
import Mathlib.LinearAlgebra.Dimension.RankNullity
import Mathlib.LinearAlgebra.Dimension.DivisionRing
import Mathlib.LinearAlgebra.Finsupp.Pi
import Mathlib.Algebra.Field.ZMod
import Mathlib.FieldTheory.Finiteness

namespace Towers
namespace Presentation

noncomputable section

variable (p : ℕ) (P : Presentation) [Fact p.Prime] [Fintype P.Gen]

/-- The free degree-one module has dimension equal to the number of generators. -/
theorem finrank_free_module :
    Module.finrank (ZMod p) (degreeFreeModule p P) = Fintype.card P.Gen := by
  classical
  rw [LinearEquiv.finrank_eq (Finsupp.linearEquivFunOnFinite (ZMod p) (ZMod p) P.Gen)]
  exact Module.finrank_fintype_fun_eq_card (ZMod p)

end
end Presentation
end Towers

namespace Towers
namespace Presentation

noncomputable section

variable (p : ℕ) (P : Presentation) [Fact p.Prime] [Fintype P.Gen]

/-- Rank-nullity for the degree-one presentation: quotient dimension plus relation-span dimension
is the number of generators. -/
theorem finrank_frattini_span :
    Module.finrank (ZMod p) (mFAdditi p P.Group) +
      Module.finrank (ZMod p) (degreeRelatorSpan p P) = Fintype.card P.Gen := by
  classical
  rw [← finrank_free_module (p := p) (P := P)]
  rw [← LinearEquiv.finrank_eq (degreeRelationFrattini p P)]
  exact Submodule.finrank_quotient_add_finrank (degreeRelatorSpan p P)

end
end Presentation
end Towers

namespace Towers
namespace Presentation

noncomputable section

variable (p : ℕ) (P : Presentation) [Fact p.Prime] [Fintype P.Gen]

/-- In a degree-one minimal finite-generator presentation, the Frattini quotient dimension is
exactly the number of generators. -/
theorem finrank_frattini_minimal (h : degreeOneMinimal p P) :
    Module.finrank (ZMod p) (mFAdditi p P.Group) = Fintype.card P.Gen := by
  classical
  have hs : degreeRelatorSpan p P = ⊥ :=
    (degree_minimal_bot p P).1 h
  have hf := finrank_frattini_span (p := p) (P := P)
  rw [hs] at hf
  simpa using hf

end
end Presentation
end Towers

namespace Towers
namespace Presentation

noncomputable section

variable (p : ℕ) (P : Presentation) [Fact p.Prime] [Fintype P.Gen]

/-- For finite-generator presentations, degree-one minimality is equivalent to the expected
Frattini quotient dimension. -/
theorem minimal_frattini_card :
    degreeOneMinimal p P ↔
      Module.finrank (ZMod p) (mFAdditi p P.Group) = Fintype.card P.Gen := by
  constructor
  · exact finrank_frattini_minimal p P
  · intro hdim
    have hf := finrank_frattini_span (p := p) (P := P)
    rw [hdim] at hf
    have hzero : Module.finrank (ZMod p) (degreeRelatorSpan p P) = 0 := by
      omega
    have hs : degreeRelatorSpan p P = ⊥ := by
      exact (Submodule.finrank_eq_zero).1 hzero
    exact (degree_minimal_bot p P).2 hs

end
end Presentation
end Towers

namespace Towers
namespace Presentation

noncomputable section

variable (p : ℕ) (P : Presentation) [Fact p.Prime]

/-- Relator span can equivalently be generated by the bundled relator subtype. -/
theorem degree_span_range :
    degreeRelatorSpan p P =
      Submodule.span (ZMod p)
        (Set.range (fun r : P.Relator => exponentVector p P.Gen (r : P.Free))) := by
  have hset : Set.image (fun r : P.Free => exponentVector p P.Gen r) P.rels =
      Set.range (fun r : P.Relator => exponentVector p P.Gen (r : P.Free)) := by
    ext v
    constructor
    · intro hv
      rcases hv with ⟨r, hr, rfl⟩
      exact ⟨⟨r, hr⟩, rfl⟩
    · intro hv
      rcases hv with ⟨r, rfl⟩
      exact ⟨(r : P.Free), r.property, rfl⟩
  simp [degreeRelatorSpan, hset]


variable [Fintype P.Relator]

/-- The relator exponent-span has dimension at most the number of bundled relators. -/
theorem finrank_span_relators :
    Module.finrank (ZMod p) (degreeRelatorSpan p P) ≤ Fintype.card P.Relator := by
  classical
  rw [degree_span_range (p := p) (P := P)]
  exact finrank_range_le_card (R := ZMod p)
    (fun r : P.Relator => exponentVector p P.Gen (r : P.Free))

end
end Presentation
end Towers

namespace Towers
namespace Presentation

noncomputable section

variable (p : ℕ) (P : Presentation) [Fact p.Prime] [Fintype P.Gen] [Fintype P.Relator]

/-- The basic finite-relator dimension inequality: generators are bounded by degree-one
dimension plus the number of relators. -/
theorem card_frattini_relators :
    Fintype.card P.Gen ≤
      Module.finrank (ZMod p) (mFAdditi p P.Group) + Fintype.card P.Relator := by
  classical
  have hf := finrank_frattini_span (p := p) (P := P)
  have hb := finrank_span_relators (p := p) (P := P)
  omega

end
end Presentation
end Towers

namespace Towers
namespace Presentation

noncomputable section

variable (p : ℕ) (P : Presentation) [Fact p.Prime] [Fintype P.Gen] [Fintype P.Relator]

/-- Naive degree-one deficiency of a finite presentation (generators minus relators). -/
def degreeOneDeficiency : ℕ := Fintype.card P.Gen - Fintype.card P.Relator

/-- The naive deficiency is bounded above by the dimension of the degree-one quotient. -/
theorem deficiency_finrank_frattini :
    degreeOneDeficiency P ≤
      Module.finrank (ZMod p) (mFAdditi p P.Group) := by
  classical
  unfold degreeOneDeficiency
  have h := card_frattini_relators (p := p) (P := P)
  omega

end
end Presentation
end Towers

namespace Towers
namespace Presentation

noncomputable section

variable (p : ℕ) (P : Presentation) [Fact p.Prime] [Fintype P.Gen] [Fintype P.Relator]

/-- Integer-valued generator-minus-relator count, avoiding truncated subtraction. -/
def degreeEulerDeficiency : ℤ := (Fintype.card P.Gen : ℤ) - (Fintype.card P.Relator : ℤ)

/-- Integer deficiency is bounded by the degree-one quotient dimension. -/
theorem euler_deficiency_frattini :
    degreeEulerDeficiency P ≤
      (Module.finrank (ZMod p) (mFAdditi p P.Group) : ℤ) := by
  classical
  unfold degreeEulerDeficiency
  have h := card_frattini_relators (p := p) (P := P)
  omega

end
end Presentation
end Towers

namespace Towers
namespace Presentation

noncomputable section

variable (p : ℕ) (P : Presentation) [Fact p.Prime] [Fintype P.Gen] [Fintype P.Relator]

/-- Independence of the degree-one exponent vectors of the bundled relators. -/
def degreeRelatorsIndependent : Prop :=
  LinearIndependent (ZMod p) (fun r : P.Relator => exponentVector p P.Gen (r : P.Free))

omit [Fintype P.Gen] in
/-- If relator exponent vectors are independent, their span has dimension `#relators`. -/
theorem finrank_relators_independent
    (h : degreeRelatorsIndependent p P) :
    Module.finrank (ZMod p) (degreeRelatorSpan p P) = Fintype.card P.Relator := by
  classical
  rw [degree_span_range (p := p) (P := P)]
  exact finrank_span_eq_card h

/-- With independent degree-one relator vectors, rank-nullity is an exact
generator/relator count. -/
theorem finrank_frattini_independent
    (h : degreeRelatorsIndependent p P) :
    Module.finrank (ZMod p) (mFAdditi p P.Group) + Fintype.card P.Relator =
      Fintype.card P.Gen := by
  classical
  have hf := finrank_frattini_span (p := p) (P := P)
  rw [finrank_relators_independent (p := p) (P := P) h] at hf
  exact hf

end
end Presentation
end Towers

namespace Towers
namespace Presentation

open GroupAlgebra

noncomputable section

variable (p : ℕ) (P : Presentation) [Fact p.Prime]

/-- Under the reverse degree-one containment, the first Zassenhaus quotient has the same
finite dimension as the mod-`p` Frattini quotient. -/
theorem two_frattini_reverse
    (hrev : zSubgro p P.Group 2 ≤ modPFrattini p P.Group) :
    Module.finrank (ZMod p) (zTAdditi p P.Group) =
      Module.finrank (ZMod p) (mFAdditi p P.Group) := by
  rw [← LinearEquiv.finrank_eq
    (mFAdditi.zass_twolin_equivreverse p P.Group hrev)]

/-- The first layer kernel has the same finite dimension as the Frattini quotient under
the reverse degree-one containment. -/
theorem finrank_frattini_reverse
    (hrev : zSubgro p P.Group 2 ≤ modPFrattini p P.Group) :
    Module.finrank (ZMod p) (Additive (zLKern p P.Group 1)) =
      Module.finrank (ZMod p) (mFAdditi p P.Group) := by
  rw [← LinearEquiv.finrank_eq
    (mFAdditi.zasslayer_onelin_equivreverse p P.Group hrev)]

variable [Fintype P.Gen]

/-- Rank-nullity with the first Zassenhaus quotient as target, conditional on the reverse
containment `D₂ ≤ G^p [G,G]`. -/
theorem finrank_relator_reverse
    (hrev : zSubgro p P.Group 2 ≤ modPFrattini p P.Group) :
    Module.finrank (ZMod p) (zTAdditi p P.Group) +
      Module.finrank (ZMod p) (degreeRelatorSpan p P) = Fintype.card P.Gen := by
  classical
  have hf := finrank_frattini_span (p := p) (P := P)
  have he := two_frattini_reverse (p := p) (P := P) hrev
  rw [he]
  exact hf

/-- Rank-nullity with the first layer kernel as target, conditional on the reverse
containment `D₂ ≤ G^p [G,G]`. -/
theorem finrank_span_reverse
    (hrev : zSubgro p P.Group 2 ≤ modPFrattini p P.Group) :
    Module.finrank (ZMod p) (Additive (zLKern p P.Group 1)) +
      Module.finrank (ZMod p) (degreeRelatorSpan p P) = Fintype.card P.Gen := by
  classical
  have hf := finrank_frattini_span (p := p) (P := P)
  have he := finrank_frattini_reverse (p := p) (P := P) hrev
  rw [he]
  exact hf

/-- Conditional finite-dimensional criterion for degree-one minimality using `G/D₂`. -/
theorem minimal_finrank_reverse
    (hrev : zSubgro p P.Group 2 ≤ modPFrattini p P.Group) :
    degreeOneMinimal p P ↔
      Module.finrank (ZMod p) (zTAdditi p P.Group) =
        Fintype.card P.Gen := by
  constructor
  · intro h
    have hf := finrank_frattini_minimal (p := p) (P := P) h
    rw [two_frattini_reverse (p := p) (P := P) hrev]
    exact hf
  · intro hz
    apply (minimal_frattini_card (p := p) (P := P)).2
    rw [← two_frattini_reverse (p := p) (P := P) hrev]
    exact hz

/-- Conditional finite-dimensional criterion for degree-one minimality using the first
Zassenhaus layer kernel. -/
theorem degree_minimal_reverse
    (hrev : zSubgro p P.Group 2 ≤ modPFrattini p P.Group) :
    degreeOneMinimal p P ↔
      Module.finrank (ZMod p) (Additive (zLKern p P.Group 1)) =
        Fintype.card P.Gen := by
  constructor
  · intro h
    have hf := finrank_frattini_minimal (p := p) (P := P) h
    rw [finrank_frattini_reverse (p := p) (P := P) hrev]
    exact hf
  · intro hz
    apply (minimal_frattini_card (p := p) (P := P)).2
    rw [← finrank_frattini_reverse (p := p) (P := P) hrev]
    exact hz

variable [Fintype P.Relator]

/-- The naive deficiency is bounded by the dimension of the first Zassenhaus quotient,
under the reverse degree-one containment. -/
theorem deficiency_two_reverse
    (hrev : zSubgro p P.Group 2 ≤ modPFrattini p P.Group) :
    degreeOneDeficiency P ≤
      Module.finrank (ZMod p) (zTAdditi p P.Group) := by
  classical
  have h := deficiency_finrank_frattini (p := p) (P := P)
  have he := two_frattini_reverse (p := p) (P := P) hrev
  omega

/-- Integer deficiency is bounded by the dimension of the first Zassenhaus quotient,
under the reverse degree-one containment. -/
theorem euler_deficiency_finrank
    (hrev : zSubgro p P.Group 2 ≤ modPFrattini p P.Group) :
    degreeEulerDeficiency P ≤
      (Module.finrank (ZMod p) (zTAdditi p P.Group) : ℤ) := by
  classical
  have h := euler_deficiency_frattini (p := p) (P := P)
  have he := two_frattini_reverse (p := p) (P := P) hrev
  omega

/-- The naive deficiency is bounded by the dimension of the first Zassenhaus layer kernel,
under the reverse degree-one containment. -/
theorem deficiency_finrank_reverse
    (hrev : zSubgro p P.Group 2 ≤ modPFrattini p P.Group) :
    degreeOneDeficiency P ≤
      Module.finrank (ZMod p) (Additive (zLKern p P.Group 1)) := by
  classical
  have h := deficiency_finrank_frattini (p := p) (P := P)
  have he := finrank_frattini_reverse (p := p) (P := P) hrev
  omega

/-- Integer deficiency is bounded by the dimension of the first Zassenhaus layer kernel,
under the reverse degree-one containment. -/
theorem degree_euler_deficiency
    (hrev : zSubgro p P.Group 2 ≤ modPFrattini p P.Group) :
    degreeEulerDeficiency P ≤
      (Module.finrank (ZMod p) (Additive (zLKern p P.Group 1)) : ℤ) := by
  classical
  have h := euler_deficiency_frattini (p := p) (P := P)
  have he := finrank_frattini_reverse (p := p) (P := P) hrev
  omega

/-- With independent degree-one relator vectors, the conditional Zassenhaus quotient
rank-nullity formula has the relator count in place of the relator-span dimension. -/
theorem card_independent_reverse
    (hrev : zSubgro p P.Group 2 ≤ modPFrattini p P.Group)
    (h : degreeRelatorsIndependent p P) :
    Module.finrank (ZMod p) (zTAdditi p P.Group) +
      Fintype.card P.Relator = Fintype.card P.Gen := by
  classical
  have hf := finrank_relator_reverse (p := p) (P := P) hrev
  rw [finrank_relators_independent (p := p) (P := P) h] at hf
  exact hf

/-- With independent degree-one relator vectors, the conditional first-layer rank-nullity
formula has the relator count in place of the relator-span dimension. -/
theorem finrank_independent_reverse
    (hrev : zSubgro p P.Group 2 ≤ modPFrattini p P.Group)
    (h : degreeRelatorsIndependent p P) :
    Module.finrank (ZMod p) (Additive (zLKern p P.Group 1)) +
      Fintype.card P.Relator = Fintype.card P.Gen := by
  classical
  have hf := finrank_span_reverse (p := p) (P := P) hrev
  rw [finrank_relators_independent (p := p) (P := P) h] at hf
  exact hf

end
end Presentation
end Towers

namespace Towers
namespace Presentation

open GroupAlgebra

noncomputable section

variable (p : ℕ) (P : Presentation) [Fact p.Prime] [Fintype P.Gen] [Fintype P.Relator]

/-- Under independence of degree-one relator vectors, the integer Euler deficiency is exactly
 the Frattini quotient dimension. -/
theorem finrank_deficiency_independent
    (h : degreeRelatorsIndependent p P) :
    (Module.finrank (ZMod p) (mFAdditi p P.Group) : ℤ) =
      degreeEulerDeficiency P := by
  classical
  unfold degreeEulerDeficiency
  have hf := finrank_frattini_independent (p := p) (P := P) h
  omega

/-- Conditional Zassenhaus-quotient version of the Euler deficiency equality under
independent degree-one relator vectors. -/
theorem euler_deficiency_independent
    (hrev : zSubgro p P.Group 2 ≤ modPFrattini p P.Group)
    (h : degreeRelatorsIndependent p P) :
    (Module.finrank (ZMod p) (zTAdditi p P.Group) : ℤ) =
      degreeEulerDeficiency P := by
  classical
  unfold degreeEulerDeficiency
  have hf := card_independent_reverse
    (p := p) (P := P) hrev h
  omega

/-- Conditional first-layer version of the Euler deficiency equality under independent
 degree-one relator vectors. -/
theorem euler_deficiency_reverse
    (hrev : zSubgro p P.Group 2 ≤ modPFrattini p P.Group)
    (h : degreeRelatorsIndependent p P) :
    (Module.finrank (ZMod p) (Additive (zLKern p P.Group 1)) : ℤ) =
      degreeEulerDeficiency P := by
  classical
  unfold degreeEulerDeficiency
  have hf := finrank_independent_reverse
    (p := p) (P := P) hrev h
  omega

end
end Presentation
end Towers

