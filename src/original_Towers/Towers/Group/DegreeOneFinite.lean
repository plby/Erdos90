namespace Towers
namespace Presentation

noncomputable section

variable (p : ℕ) (P : Presentation) [Fact p.Prime] [Fintype P.Gen] [Fintype P.Relator]

omit [Fintype P.Gen] in
/-- A finite degree-one minimal presentation with independent degree-one relator vectors has
no bundled relators (in cardinality). -/
theorem card_minimal_independent
    (hmin : degreeOneMinimal p P) (hind : degreeRelatorsIndependent p P) :
    Fintype.card P.Relator = 0 := by
  classical
  have hs := relator_bot_minimal (p := p) (P := P) hmin
  have hf := finrank_relators_independent (p := p) (P := P) hind
  rw [hs] at hf
  simpa using hf.symm

/-- In the same situation, the naive deficiency is just the number of generators. -/
theorem deficiency_minimal_independent
    (hmin : degreeOneMinimal p P) (hind : degreeRelatorsIndependent p P) :
    degreeOneDeficiency P = Fintype.card P.Gen := by
  classical
  unfold degreeOneDeficiency
  have hc := card_minimal_independent
    (p := p) (P := P) hmin hind
  omega

end
end Presentation
end Towers


namespace Towers
namespace Presentation

noncomputable section

variable (p : ℕ) (P : Presentation)

/-- The relation quotient of a finite-generator presentation is finite as a type. -/
noncomputable instance dRQuot.fintype [Fact p.Prime] [Fintype P.Gen] :
    Fintype (dRQuot p P) := by
  infer_instance

/-- The mod-`p` Frattini quotient of a finitely generated presentation is finite (additive form). -/
noncomputable instance pFAdditi.fintype [Fact p.Prime] [Fintype P.Gen] :
    Fintype (mFAdditi p P.Group) := by
  classical
  exact Fintype.ofEquiv (dRQuot p P)
    (degreeRelationFrattini p P).toEquiv

/-- The mod-`p` Frattini quotient of a finitely generated presentation is finite. -/
noncomputable instance pFQuot.fintype [Fact p.Prime] [Fintype P.Gen] :
    Fintype (mFQuot p P.Group) := by
  classical
  exact Fintype.ofEquiv (mFAdditi p P.Group) Additive.ofMul.symm

/-- Cardinality of a finitely generated presented Frattini quotient, in terms of its finrank. -/
@[simp] theorem card_presented_additive [Fact p.Prime] [Fintype P.Gen] :
    Fintype.card (mFAdditi p P.Group) =
      p ^ Module.finrank (ZMod p) (mFAdditi p P.Group) := by
  classical
  rw [Module.card_eq_pow_finrank (K := ZMod p)
    (V := mFAdditi p P.Group)]
  rw [ZMod.card]

/-- Multiplicative form of the cardinality formula for a finitely generated presentation. -/
@[simp] theorem card_presented_frattini [Fact p.Prime] [Fintype P.Gen] :
    Fintype.card (mFQuot p P.Group) =
      p ^ Module.finrank (ZMod p) (mFAdditi p P.Group) := by
  classical
  calc
    Fintype.card (mFQuot p P.Group) =
        Fintype.card (mFAdditi p P.Group) :=
      Fintype.card_congr Additive.ofMul
    _ = p ^ Module.finrank (ZMod p) (mFAdditi p P.Group) :=
      card_presented_additive p P

/-- Cardinality in terms of generators minus the degree-one relator-span dimension. -/
theorem card_presented_span
    [Fact p.Prime] [Fintype P.Gen] :
    Fintype.card (mFAdditi p P.Group) =
      p ^ (Fintype.card P.Gen -
        Module.finrank (ZMod p) (degreeRelatorSpan p P)) := by
  rw [card_presented_additive]
  have h := finrank_frattini_span (p := p) (P := P)
  congr 1
  omega

/-- Multiplicative quotient cardinality in generator-minus-relator-span form. -/
theorem card_frattini_span
    [Fact p.Prime] [Fintype P.Gen] :
    Fintype.card (mFQuot p P.Group) =
      p ^ (Fintype.card P.Gen -
        Module.finrank (ZMod p) (degreeRelatorSpan p P)) := by
  rw [card_presented_frattini]
  have h := finrank_frattini_span (p := p) (P := P)
  congr 1
  omega

end
end Presentation
end Towers

namespace Towers
namespace Presentation

noncomputable section

variable (p : ℕ) (P : Presentation)

/-- If degree-one relator vectors are independent, the Frattini quotient cardinality is the
expected generator-minus-relator power. -/
theorem additive_relators_independent
    [Fact p.Prime] [Fintype P.Gen] [Fintype P.Relator]
    (h : degreeRelatorsIndependent p P) :
    Fintype.card (mFAdditi p P.Group) =
      p ^ (Fintype.card P.Gen - Fintype.card P.Relator) := by
  rw [card_presented_span]
  rw [finrank_relators_independent (p := p) (P := P) h]

/-- Multiplicative quotient version of the independent-relator cardinality formula. -/
theorem presented_frattini_independent
    [Fact p.Prime] [Fintype P.Gen] [Fintype P.Relator]
    (h : degreeRelatorsIndependent p P) :
    Fintype.card (mFQuot p P.Group) =
      p ^ (Fintype.card P.Gen - Fintype.card P.Relator) := by
  rw [card_frattini_span]
  rw [finrank_relators_independent (p := p) (P := P) h]

/-- In the degree-one minimal case, the Frattini quotient has cardinality `p ^ #Gen`. -/
theorem presented_frattini_minimal
    [Fact p.Prime] [Fintype P.Gen] (h : degreeOneMinimal p P) :
    Fintype.card (mFAdditi p P.Group) = p ^ Fintype.card P.Gen := by
  rw [card_presented_additive]
  rw [finrank_frattini_minimal (p := p) (P := P) h]

