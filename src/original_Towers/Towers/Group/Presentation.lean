/-- Add a set of extra relators to a presentation, keeping the same generators. -/
def addRelators (P : Presentation.{u}) (S : Set P.Free) : Presentation.{u} where
  Gen := P.Gen
  rels := P.rels ∪ S

@[simp] theorem addRelators_free (P : Presentation.{u}) (S : Set P.Free) :
    (P.addRelators S).Free = P.Free := rfl

/-- Adding no relators leaves a presentation unchanged. -/
@[simp] theorem addRelators_empty (P : Presentation.{u}) :
    P.addRelators (∅ : Set P.Free) = P := by
  cases P with
  | mk Gen rels =>
    simp [addRelators]

@[simp] theorem relators_empty_rels (P : Presentation.{u}) :
    (P.addRelators (∅ : Set P.Free)).rels = P.rels := by
  cases P with
  | mk Gen rels =>
    simp [addRelators]


/-- Adding relators in two stages is the same presentation as adding their union. -/
@[simp] theorem add_relators_relators (P : Presentation.{u})
    (S T : Set P.Free) :
    (P.addRelators S).addRelators T = P.addRelators (S ∪ T) := by
  cases P with
  | mk Gen rels =>
    exact congrArg (fun R : Set (FreeGroup Gen) =>
        ({ Gen := Gen, rels := R } : Presentation))
      (Set.union_assoc rels S T)

/-- The order of two batches of added relators does not matter at the presentation level. -/
theorem aRuc_comm (P : Presentation.{u}) (S T : Set P.Free) :
    P.addRelators (S ∪ T) = P.addRelators (T ∪ S) := by
  cases P with
  | mk Gen rels =>
    apply congrArg (fun R : Set (FreeGroup Gen) =>
      ({ Gen := Gen, rels := R } : Presentation))
    ext x
    constructor <;> intro hx
    · rcases hx with hx | hx
      · exact Or.inl hx
      · rcases hx with hs | ht
        · exact Or.inr (Or.inr hs)
        · exact Or.inr (Or.inl ht)
    · rcases hx with hx | hx
      · exact Or.inl hx
      · rcases hx with ht | hs
        · exact Or.inr (Or.inr ht)
        · exact Or.inr (Or.inl hs)

/-- Two successive batches of added relators commute. -/
theorem add_relators (P : Presentation.{u})
    (S T : Set P.Free) :
    (P.addRelators S).addRelators T = (P.addRelators T).addRelators S := by
  rw [add_relators_relators, add_relators_relators]
  exact aRuc_comm P S T


@[simp] theorem relators_rels_left {P : Presentation.{u}} {S : Set P.Free}
    {r : P.Free} (hr : r ∈ P.rels) :
    r ∈ (P.addRelators S).rels := Or.inl hr

@[simp] theorem relators_rels_right {P : Presentation.{u}} {S : Set P.Free}
    {r : P.Free} (hr : r ∈ S) :
    r ∈ (P.addRelators S).rels := Or.inr hr

/-- Old relator consequences remain consequences after adding relators. -/
theorem relator_closure_relators (P : Presentation.{u}) (S : Set P.Free) :
    P.rNClos ≤ (P.addRelators S).rNClos := by
  haveI : (P.addRelators S).rNClos.Normal := Subgroup.normalClosure_normal
  refine Subgroup.normalClosure_le_normal (N := (P.addRelators S).rNClos) ?_
  intro r hr
  exact Subgroup.subset_normalClosure (Or.inl hr)

/-- Each newly added relator lies in the enlarged relator normal closure. -/
theorem relators_closure_right {P : Presentation.{u}}
    {S : Set P.Free} {r : P.Free} (hr : r ∈ S) :
    r ∈ (P.addRelators S).rNClos :=
  Subgroup.subset_normalClosure (Or.inr hr)

/-- Enlarging the added-relator set enlarges the resulting normal closure. -/
theorem relators_closure_mono (P : Presentation.{u})
    {S T : Set P.Free} (hST : S ⊆ T) :
    (P.addRelators S).rNClos ≤ (P.addRelators T).rNClos := by
  haveI : (P.addRelators T).rNClos.Normal := Subgroup.normalClosure_normal
  refine Subgroup.normalClosure_le_normal (N := (P.addRelators T).rNClos) ?_
  intro r hr
  rcases hr with hr | hr
  · exact Subgroup.subset_normalClosure (Or.inl hr)
  · exact Subgroup.subset_normalClosure (Or.inr (hST hr))



/-- If every relator in `T` is already a consequence after adding `S`, then adding
`S ∪ T` has the same relator normal closure as adding `S`. -/
theorem closure_union_subset
    (P : Presentation.{u}) (S T : Set P.Free)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → t ∈ (P.addRelators S).rNClos) :
    (P.addRelators S).rNClos =
      (P.addRelators (S ∪ T)).rNClos := by
  apply le_antisymm
  · exact relators_closure_mono P (by intro r hr; exact Or.inl hr)
  · let K := (P.addRelators S).rNClos
    haveI : K.Normal := by
      dsimp [K, Presentation.rNClos]
      infer_instance
    change (P.addRelators (S ∪ T)).rNClos ≤ K
    apply (Subgroup.normalClosure_le_normal (N := K))
    intro r hr
    change r ∈ K
    dsimp [K]
    rcases hr with hp | hst
    · exact Subgroup.subset_normalClosure (Or.inl hp)
    · rcases hst with hs | ht
      · exact Subgroup.subset_normalClosure (Or.inr hs)
      · exact hT ht

/-- A fixed-generator morphism between added-relator presentations induced by an
inclusion of their relator normal closures.  This is the normal-closure version of
`addRelatorsMono`, useful when two different added sets generate the same
relations. -/
def addNormalClosure (P : Presentation.{u}) {S T : Set P.Free}
    (h : (P.addRelators S).rNClos ≤
      (P.addRelators T).rNClos) :
    Hom (P.addRelators S) (P.addRelators T) where
  gen := id
  map_rel := by
    intro r hr
    change FreeGroup.map id r ∈ (P.addRelators T).rNClos
    rw [FreeGroup.map.id]
    exact h (Subgroup.subset_normalClosure hr)

@[simp] theorem add_relators_gen (P : Presentation.{u})
    {S T : Set P.Free}
    (h : (P.addRelators S).rNClos ≤
      (P.addRelators T).rNClos) (x : P.Gen) :
    (addNormalClosure P h).gen x = x := rfl

@[simp] theorem add_relators_group
    (P : Presentation.{u}) {S T : Set P.Free}
    (h : (P.addRelators S).rNClos ≤
      (P.addRelators T).rNClos) (x : P.Gen) :
    (addNormalClosure P h).toGroupHom ((P.addRelators S).of x) =
      (P.addRelators T).of x := rfl

@[simp] theorem add_relators_closure
    (P : Presentation.{u}) {S T : Set P.Free}
    (h : (P.addRelators S).rNClos ≤
      (P.addRelators T).rNClos) (w : P.Free) :
    (addNormalClosure P h).toGroupHom
        ((P.addRelators S).quotientMap w) =
      (P.addRelators T).quotientMap w := by
  rw [Hom.group_quotient]
  change (P.addRelators T).quotientMap (FreeGroup.map id w) = _
  rw [FreeGroup.map.id]

/-- Normal-closure-induced fixed-generator maps are surjective. -/
theorem add_relators_surjective (P : Presentation.{u})
    {S T : Set P.Free}
    (h : (P.addRelators S).rNClos ≤
      (P.addRelators T).rNClos) :
    Function.Surjective (addNormalClosure P h).toGroupHom := by
  apply Hom.group_surjective_free
  intro w
  refine ⟨w, ?_⟩
  change FreeGroup.map id w = w
  rw [FreeGroup.map.id]

@[simp] theorem add_closure_refl (P : Presentation.{u})
    (S : Set P.Free) :
    addNormalClosure P
        (show (P.addRelators S).rNClos ≤
          (P.addRelators S).rNClos from le_rfl) =
      Hom.id (P.addRelators S) := by
  ext x
  rfl

theorem add_relators_comp (P : Presentation.{u})
    {S T U : Set P.Free}
    (hST : (P.addRelators S).rNClos ≤
      (P.addRelators T).rNClos)
    (hTU : (P.addRelators T).rNClos ≤
      (P.addRelators U).rNClos) :
    (addNormalClosure (P := P) (S := T) (T := U) hTU).comp
        (addNormalClosure (P := P) (S := S) (T := T) hST) =
      addNormalClosure (P := P) (S := S) (T := U)
        (fun _ hw => hTU (hST hw)) := by
  ext x
  rfl

/-- Equal relator normal closures for two added-relator presentations give a
canonical isomorphism of the presented groups. -/
noncomputable def addRelatorsClosure (P : Presentation.{u})
    {S T : Set P.Free}
    (h : (P.addRelators S).rNClos =
      (P.addRelators T).rNClos) :
    (P.addRelators S).Group ≃* (P.addRelators T).Group :=
  Hom.groupEquivInverse
    (addNormalClosure P (by rw [h]))
    (addNormalClosure P (by rw [h]))
    (by ext x; rfl) (by ext x; rfl)

@[simp] theorem relators_closure_monoid
    (P : Presentation.{u}) {S T : Set P.Free}
    (h : (P.addRelators S).rNClos =
      (P.addRelators T).rNClos) :
    (addRelatorsClosure P h).toMonoidHom =
      (addNormalClosure P (by rw [h])).toGroupHom := rfl

@[simp] theorem equiv_normal_closure (P : Presentation.{u})
    {S T : Set P.Free}
    (h : (P.addRelators S).rNClos =
      (P.addRelators T).rNClos) (x : P.Gen) :
    addRelatorsClosure P h ((P.addRelators S).of x) =
      (P.addRelators T).of x := rfl

@[simp] theorem add_relators_quotient (P : Presentation.{u})
    {S T : Set P.Free}
    (h : (P.addRelators S).rNClos =
      (P.addRelators T).rNClos) (w : P.Free) :
    addRelatorsClosure P h ((P.addRelators S).quotientMap w) =
      (P.addRelators T).quotientMap w := by
  change (addNormalClosure P (by rw [h])).toGroupHom
      ((P.addRelators S).quotientMap w) = (P.addRelators T).quotientMap w
  rw [Hom.group_quotient]
  change (P.addRelators T).quotientMap (FreeGroup.map id w) = _
  rw [FreeGroup.map.id]

@[simp] theorem equiv_normal_symm (P : Presentation.{u})
    {S T : Set P.Free}
    (h : (P.addRelators S).rNClos =
      (P.addRelators T).rNClos) :
    (addRelatorsClosure P h).symm =
      addRelatorsClosure P h.symm := by
  apply MulEquiv.ext
  intro q
  rcases (P.addRelators T).quotientMap_surjective q with ⟨w, rfl⟩
  change (addNormalClosure P (by rw [h])).toGroupHom
      ((P.addRelators T).quotientMap w) = _
  rw [add_relators_closure]
  rw [add_relators_quotient]

@[simp] theorem add_relators_normal
    (P : Presentation.{u}) {S T : Set P.Free}
    (h : (P.addRelators S).rNClos =
      (P.addRelators T).rNClos) (w : P.Free) :
    (addRelatorsClosure P h).symm
        ((P.addRelators T).quotientMap w) =
      (P.addRelators S).quotientMap w := by
  rw [equiv_normal_symm,
    add_relators_quotient]

@[simp] theorem add_normal_symm
    (P : Presentation.{u}) {S T : Set P.Free}
    (h : (P.addRelators S).rNClos =
      (P.addRelators T).rNClos)
    (x : (P.addRelators S).Group) :
    (addRelatorsClosure P h).symm
        (addRelatorsClosure P h x) = x :=
  (addRelatorsClosure P h).left_inv x

@[simp] theorem add_closure_symm
    (P : Presentation.{u}) {S T : Set P.Free}
    (h : (P.addRelators S).rNClos =
      (P.addRelators T).rNClos)
    (y : (P.addRelators T).Group) :
    addRelatorsClosure P h
        ((addRelatorsClosure P h).symm y) = y :=
  (addRelatorsClosure P h).right_inv y

@[simp] theorem add_normal_closure
    (P : Presentation.{u}) {S T : Set P.Free}
    (h : (P.addRelators S).rNClos =
      (P.addRelators T).rNClos)
    (y : (P.addRelators T).Group) (x : (P.addRelators S).Group) :
    (addRelatorsClosure P h).symm y = x ↔
      y = addRelatorsClosure P h x := by
  rw [MulEquiv.symm_apply_eq]

@[simp] theorem add_equiv_symm
    (P : Presentation.{u}) {S T : Set P.Free}
    (h : (P.addRelators S).rNClos =
      (P.addRelators T).rNClos)
    (x : (P.addRelators S).Group) (y : (P.addRelators T).Group) :
    x = (addRelatorsClosure P h).symm y ↔
      addRelatorsClosure P h x = y := by
  rw [eq_comm, add_normal_closure, eq_comm]

@[simp] theorem add_relators_refl (P : Presentation.{u})
    (S : Set P.Free) :
    addRelatorsClosure P
        (rfl : (P.addRelators S).rNClos =
          (P.addRelators S).rNClos) =
      MulEquiv.refl (P.addRelators S).Group := by
  apply MulEquiv.ext
  intro q
  rcases (P.addRelators S).quotientMap_surjective q with ⟨w, rfl⟩
  rw [add_relators_quotient]
  rfl

theorem add_relators_trans (P : Presentation.{u})
    {S T U : Set P.Free}
    (hST : (P.addRelators S).rNClos =
      (P.addRelators T).rNClos)
    (hTU : (P.addRelators T).rNClos =
      (P.addRelators U).rNClos) :
    (addRelatorsClosure (P := P) (S := S) (T := T) hST).trans
        (addRelatorsClosure (P := P) (S := T) (T := U) hTU) =
      addRelatorsClosure (P := P) (S := S) (T := U)
        (Eq.trans hST hTU) := by
  apply MulEquiv.ext
  intro q
  rcases (P.addRelators S).quotientMap_surjective q with ⟨w, rfl⟩
  change addRelatorsClosure (P := P) (S := T) (T := U) hTU
      (addRelatorsClosure (P := P) (S := S) (T := T) hST
        ((P.addRelators S).quotientMap w)) =
    addRelatorsClosure (P := P) (S := S) (T := U) (Eq.trans hST hTU)
      ((P.addRelators S).quotientMap w)
  rw [add_relators_quotient]
  rw [add_relators_quotient]
  rw [add_relators_quotient]


/-- Commuting the two added-relator batches induces the identity-on-words equivalence. -/
noncomputable def addUnionComm (P : Presentation.{u}) (S T : Set P.Free) :
    (P.addRelators (S ∪ T)).Group ≃* (P.addRelators (T ∪ S)).Group :=
  addRelatorsClosure P (by
    cases P with
    | mk Gen rels =>
      change Subgroup.normalClosure (rels ∪ (S ∪ T)) =
        Subgroup.normalClosure (rels ∪ (T ∪ S))
      congr 1
      ext x
      simp [or_comm])

@[simp] theorem relators_comm_quotient
    (P : Presentation.{u}) (S T : Set P.Free) (w : P.Free) :
    addUnionComm P S T
        ((P.addRelators (S ∪ T)).quotientMap w) =
      (P.addRelators (T ∪ S)).quotientMap w := by
  exact add_relators_quotient P _ w

@[simp] theorem add_comm_equiv
    (P : Presentation.{u}) (S T : Set P.Free) :
    (addUnionComm P S T).symm =
      addUnionComm P T S := by
  apply MulEquiv.ext
  intro q
  rcases (P.addRelators (T ∪ S)).quotientMap_surjective q with ⟨w, rfl⟩
  rw [MulEquiv.symm_apply_eq]
  rw [relators_comm_quotient, relators_comm_quotient]

@[simp] theorem add_relators_comm
    (P : Presentation.{u}) (S T : Set P.Free) (w : P.Free) :
    (addUnionComm P S T).symm
        ((P.addRelators (T ∪ S)).quotientMap w) =
      (P.addRelators (S ∪ T)).quotientMap w := by
  rw [add_comm_equiv, relators_comm_quotient]

@[simp] theorem add_union_comm
    (P : Presentation.{u}) (S T : Set P.Free)
    (x : (P.addRelators (S ∪ T)).Group) :
    (addUnionComm P S T).symm
        (addUnionComm P S T x) = x :=
  (addUnionComm P S T).left_inv x

@[simp] theorem add_comm_symm
    (P : Presentation.{u}) (S T : Set P.Free)
    (y : (P.addRelators (T ∪ S)).Group) :
    addUnionComm P S T
        ((addUnionComm P S T).symm y) = y :=
  (addUnionComm P S T).right_inv y

/-- Reassociate an added-relator union.  As for the fixed-relator version, this is
identity on free-word representatives. -/
noncomputable def addUnionAssoc (P : Presentation.{u})
    (S T U : Set P.Free) :
    (P.addRelators ((S ∪ T) ∪ U)).Group ≃*
      (P.addRelators (S ∪ (T ∪ U))).Group :=
  addRelatorsClosure P (by
    cases P with
    | mk Gen rels =>
      change Subgroup.normalClosure (rels ∪ ((S ∪ T) ∪ U)) =
        Subgroup.normalClosure (rels ∪ (S ∪ (T ∪ U)))
      congr 1
      rw [Set.union_assoc])

@[simp] theorem add_union_equiv
    (P : Presentation.{u}) (S T U : Set P.Free) (x : P.Gen) :
    addUnionAssoc P S T U
        ((P.addRelators ((S ∪ T) ∪ U)).of x) =
      (P.addRelators (S ∪ (T ∪ U))).of x := by
  exact equiv_normal_closure P _ x


@[simp] theorem add_assoc_quotient
    (P : Presentation.{u}) (S T U : Set P.Free) (w : P.Free) :
    addUnionAssoc P S T U
        ((P.addRelators ((S ∪ T) ∪ U)).quotientMap w) =
      (P.addRelators (S ∪ (T ∪ U))).quotientMap w := by
  exact add_relators_quotient P _ w

@[simp] theorem add_relators_assoc
    (P : Presentation.{u}) (S T U : Set P.Free) (w : P.Free) :
    (addUnionAssoc P S T U).symm
        ((P.addRelators (S ∪ (T ∪ U))).quotientMap w) =
      (P.addRelators ((S ∪ T) ∪ U)).quotientMap w := by
  exact add_relators_normal P _ w

@[simp] theorem add_assoc_equiv
    (P : Presentation.{u}) (S T U : Set P.Free) (x : P.Gen) :
    (addUnionAssoc P S T U).symm
        ((P.addRelators (S ∪ (T ∪ U))).of x) =
      (P.addRelators ((S ∪ T) ∪ U)).of x := by
  rw [← quotientMap_of]
  rw [add_relators_assoc]
  rfl

@[simp] theorem add_union_assoc
    (P : Presentation.{u}) (S T U : Set P.Free)
    (x : (P.addRelators ((S ∪ T) ∪ U)).Group) :
    (addUnionAssoc P S T U).symm
        (addUnionAssoc P S T U x) = x :=
  (addUnionAssoc P S T U).left_inv x

@[simp] theorem add_assoc_symm
    (P : Presentation.{u}) (S T U : Set P.Free)
    (y : (P.addRelators (S ∪ (T ∪ U))).Group) :
    addUnionAssoc P S T U
        ((addUnionAssoc P S T U).symm y) = y :=
  (addUnionAssoc P S T U).right_inv y

@[simp] theorem union_equiv_symm
    (P : Presentation.{u}) (S T U : Set P.Free)
    (y : (P.addRelators (S ∪ (T ∪ U))).Group)
    (x : (P.addRelators ((S ∪ T) ∪ U)).Group) :
    (addUnionAssoc P S T U).symm y = x ↔
      y = addUnionAssoc P S T U x := by
  rw [MulEquiv.symm_apply_eq]

@[simp] theorem relators_assoc_equiv
    (P : Presentation.{u}) (S T U : Set P.Free)
    (x : (P.addRelators ((S ∪ T) ∪ U)).Group)
    (y : (P.addRelators (S ∪ (T ∪ U))).Group) :
    x = (addUnionAssoc P S T U).symm y ↔
      addUnionAssoc P S T U x = y := by
  rw [eq_comm, union_equiv_symm, eq_comm]

@[simp] theorem relators_comm_equiv
    (P : Presentation.{u}) (S T : Set P.Free)
    (y : (P.addRelators (T ∪ S)).Group)
    (x : (P.addRelators (S ∪ T)).Group) :
    (addUnionComm P S T).symm y = x ↔
      y = addUnionComm P S T x := by
  rw [MulEquiv.symm_apply_eq]

@[simp] theorem relators_union_equiv
    (P : Presentation.{u}) (S T : Set P.Free)
    (x : (P.addRelators (S ∪ T)).Group)
    (y : (P.addRelators (T ∪ S)).Group) :
    x = (addUnionComm P S T).symm y ↔
      addUnionComm P S T x = y := by
  rw [eq_comm, relators_comm_equiv, eq_comm]

/-- Equivalence induced by adding only relators already implied after adding `S`. -/
noncomputable def relatorsUnionSubset
    (P : Presentation.{u}) (S T : Set P.Free)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → t ∈ (P.addRelators S).rNClos) :
    (P.addRelators S).Group ≃* (P.addRelators (S ∪ T)).Group :=
  addRelatorsClosure P
    (closure_union_subset P S T hT)

@[simp] theorem union_left_subset
    (P : Presentation.{u}) (S T : Set P.Free)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → t ∈ (P.addRelators S).rNClos)
    (w : P.Free) :
    relatorsUnionSubset P S T hT
        ((P.addRelators S).quotientMap w) =
      (P.addRelators (S ∪ T)).quotientMap w := by
  exact add_relators_quotient P
    (closure_union_subset P S T hT) w



/-- Monotonicity of adding relators: enlarging the added set gives a canonical
quotient morphism between the resulting presentations. -/
def addRelatorsMono (P : Presentation.{u}) {S T : Set P.Free} (hST : S ⊆ T) :
    Hom (P.addRelators S) (P.addRelators T) where
  gen := id
  map_rel := by
    intro r hr
    change FreeGroup.map id r ∈ (P.addRelators T).rNClos
    rw [FreeGroup.map.id]
    rcases hr with hr | hr
    · exact Subgroup.subset_normalClosure (Or.inl hr)
    · exact Subgroup.subset_normalClosure (Or.inr (hST hr))

@[simp] theorem add_mono_gen (P : Presentation.{u}) {S T : Set P.Free}
    (hST : S ⊆ T) (x : P.Gen) :
    (addRelatorsMono P hST).gen x = x := rfl

/-- The monotonicity morphism for a reflexive inclusion is the identity. -/
@[simp] theorem add_mono_refl (P : Presentation.{u}) {S : Set P.Free} :
    addRelatorsMono P (by intro x hx; exact hx : S ⊆ S) =
      Hom.id (P.addRelators S) := by
  ext x
  rfl

/-- Monotonicity morphisms for added relators compose transitively. -/
@[simp] theorem add_mono_comp (P : Presentation.{u}) {S T U : Set P.Free}
    (hST : S ⊆ T) (hTU : T ⊆ U) :
    (addRelatorsMono P hTU).comp (addRelatorsMono P hST) =
      addRelatorsMono P (by intro x hx; exact hTU (hST hx)) := by
  ext x
  rfl

/-- Cancellation across an added-relator inclusion map. -/
theorem Hom.eqcomp_addrelators_monohomeq {P Q : Presentation.{u}}
    {S T : Set P.Free} (hST : S ⊆ T)
    {f g : Hom (P.addRelators T) Q}
    (h : f.comp (addRelatorsMono P hST) =
      g.comp (addRelatorsMono P hST)) :
    f = g := by
  ext x
  have hx := congrArg (fun k : Hom (P.addRelators S) Q => k.gen x) h
  simpa using hx


/-- Adding relators to a relator-subpresentation is definitionally the same as
using the union of the two relator sets. -/
@[simp] theorem relators_add (P : Presentation.{u})
    (S T : Set P.Free) :
    (P.withRelators S).addRelators T = P.withRelators (S ∪ T) := rfl

/-- The canonical quotient morphism after adding relators. -/
def addRelatorsHom (P : Presentation.{u}) (S : Set P.Free) :
    Hom P (P.addRelators S) where
  gen := id
  map_rel := by
    intro r hr
    change FreeGroup.map id r ∈ (P.addRelators S).rNClos
    rw [FreeGroup.map.id]
    exact Subgroup.subset_normalClosure (Or.inl hr)

@[simp] theorem relators_hom_gen (P : Presentation.{u}) (S : Set P.Free)
    (x : P.Gen) :
    (addRelatorsHom P S).gen x = x := rfl

@[simp] theorem relators_hom_group (P : Presentation.{u})
    (S : Set P.Free) (x : P.Gen) :
    (addRelatorsHom P S).toGroupHom (P.of x) = (P.addRelators S).of x := rfl

/-- On quotient representatives, the canonical `addRelators` morphism is the obvious
quotient map. -/
@[simp] theorem add_relators_hom (P : Presentation.{u})
    (S : Set P.Free) (w : P.Free) :
    (addRelatorsHom P S).toGroupHom (P.quotientMap w) =
      (P.addRelators S).quotientMap w := by
  rw [Hom.group_quotient]
  dsimp [Hom.freeMap, addRelatorsHom]
  exact congrArg _ (FreeGroup.map.id w)

@[simp] theorem add_mono_group (P : Presentation.{u})
    {S T : Set P.Free} (hST : S ⊆ T) (x : P.Gen) :
    (addRelatorsMono P hST).toGroupHom ((P.addRelators S).of x) =
      (P.addRelators T).of x := rfl

/-- On quotient representatives, an `addRelators` monotonicity morphism is the obvious
quotient map. -/
@[simp] theorem add_relators_mono (P : Presentation.{u})
    {S T : Set P.Free} (hST : S ⊆ T) (w : P.Free) :
    (addRelatorsMono P hST).toGroupHom ((P.addRelators S).quotientMap w) =
      (P.addRelators T).quotientMap w := by
  rw [Hom.group_quotient]
  dsimp [Hom.freeMap, addRelatorsMono]
  exact congrArg _ (FreeGroup.map.id w)


/-- An equal-normal-closure equivalence for added-relator presentations commutes
with the canonical quotient maps from any smaller added-relator presentation. -/
theorem comp_mono_hom (P : Presentation.{u})
    {A S T : Set P.Free}
    (hST : (P.addRelators S).rNClos =
      (P.addRelators T).rNClos)
    (hAS : A ⊆ S) (hAT : A ⊆ T) :
    (addRelatorsClosure (P := P) (S := S) (T := T) hST).toMonoidHom.comp
        (addRelatorsMono P hAS).toGroupHom =
      (addRelatorsMono P hAT).toGroupHom := by
  apply MonoidHom.ext
  intro q
  rcases (P.addRelators A).quotientMap_surjective q with ⟨w, rfl⟩
  rw [MonoidHom.comp_apply]
  rw [add_relators_mono]
  change addRelatorsClosure (P := P) (S := S) (T := T) hST
      ((P.addRelators S).quotientMap w) = _
  rw [add_relators_quotient]
  rw [add_relators_mono]

/-- Specialized coherence form for the added-relator union associator: any canonical
map from a smaller added-relator set commutes across reassociation. -/
theorem assoc_comp_mono (P : Presentation.{u})
    (S T U A : Set P.Free)
    (hL : A ⊆ (S ∪ T) ∪ U) (hR : A ⊆ S ∪ (T ∪ U)) :
    (addUnionAssoc P S T U).toMonoidHom.comp
        (addRelatorsMono P hL).toGroupHom =
      (addRelatorsMono P hR).toGroupHom := by
  apply MonoidHom.ext
  intro q
  rcases (P.addRelators A).quotientMap_surjective q with ⟨w, rfl⟩
  rw [MonoidHom.comp_apply]
  rw [add_relators_mono]
  change addUnionAssoc P S T U
      ((P.addRelators ((S ∪ T) ∪ U)).quotientMap w) = _
  rw [add_assoc_quotient]
  rw [add_relators_mono]

/-- Reverse-direction coherence for the added-relator union associator. -/
theorem union_assoc_mono (P : Presentation.{u})
    (S T U A : Set P.Free)
    (hR : A ⊆ S ∪ (T ∪ U)) (hL : A ⊆ (S ∪ T) ∪ U) :
    (addUnionAssoc P S T U).symm.toMonoidHom.comp
        (addRelatorsMono P hR).toGroupHom =
      (addRelatorsMono P hL).toGroupHom := by
  apply MonoidHom.ext
  intro q
  rcases (P.addRelators A).quotientMap_surjective q with ⟨w, rfl⟩
  rw [MonoidHom.comp_apply]
  rw [add_relators_mono]
  change (addUnionAssoc P S T U).symm
      ((P.addRelators (S ∪ (T ∪ U))).quotientMap w) = _
  rw [add_relators_assoc]
  rw [add_relators_mono]

/-- Monotonicity maps between added-relator presentations are surjective. -/
theorem add_mono_surjective (P : Presentation.{u})
    {S T : Set P.Free} (hST : S ⊆ T) :
    Function.Surjective (addRelatorsMono P hST).toGroupHom := by
  apply Hom.group_surjective_free
  intro w
  refine ⟨w, ?_⟩
  change FreeGroup.map id w = w
  rw [FreeGroup.map.id]


/-- Kernel of the quotient map induced by enlarging the added-relator set.  It is
the normal closure, in the smaller added-relator quotient, of the images of the
larger added set. -/
theorem ker_add_mono (P : Presentation.{u}) {S T : Set P.Free}
    (hST : S ⊆ T) :
    MonoidHom.ker (addRelatorsMono P hST).toGroupHom =
      Subgroup.normalClosure ((P.addRelators S).quotientMap '' T) := by
  classical
  let PS := P.addRelators S
  let PT := P.addRelators T
  let c := (addRelatorsMono P hST).toGroupHom
  let K : Subgroup PS.Group := Subgroup.normalClosure (PS.quotientMap '' T)
  apply le_antisymm
  · intro q hq
    rcases PS.quotientMap_surjective q with ⟨w, rfl⟩
    have hwT : w ∈ PT.rNClos := by
      have hc : c (PS.quotientMap w) = 1 := MonoidHom.mem_ker.mp hq
      change PT.quotientMap (FreeGroup.map id w) = 1 at hc
      rw [FreeGroup.map.id] at hc
      exact PT.quotient_one.mp hc
    change PS.quotientMap w ∈ K
    haveI : K.Normal := Subgroup.normalClosure_normal
    let qmap : PT.Free →* PS.Group := PS.quotientMap
    have hN : (K.comap qmap).Normal :=
      (show K.Normal from inferInstance).comap qmap
    letI : (K.comap qmap).Normal := hN
    have hclosure : PT.rNClos ≤ K.comap qmap := by
      apply Subgroup.normalClosure_le_normal
      intro r hr
      dsimp [PT] at hr
      dsimp [qmap]
      change PS.quotientMap r ∈ K
      rcases hr with hr | hr
      · rw [PS.quotient_rel_one (Or.inl hr)]
        exact K.one_mem
      · exact Subgroup.subset_normalClosure ⟨r, hr, rfl⟩
    exact hclosure hwT
  · haveI : (MonoidHom.ker c).Normal := MonoidHom.normal_ker c
    apply Subgroup.normalClosure_le_normal
    intro q hq
    rcases hq with ⟨t, ht, rfl⟩
    change c (PS.quotientMap t) = 1
    rw [Hom.group_quotient]
    change PT.quotientMap (FreeGroup.map id t) = 1
    rw [FreeGroup.map.id]
    exact PT.quotient_rel_one (Or.inr ht)

/-- Pointwise kernel criterion for an added-relator monotonicity morphism. -/
@[simp] theorem ker_mono_hom (P : Presentation.{u})
    {S T : Set P.Free} (hST : S ⊆ T) (q : (P.addRelators S).Group) :
    q ∈ MonoidHom.ker (addRelatorsMono P hST).toGroupHom ↔
      q ∈ Subgroup.normalClosure ((P.addRelators S).quotientMap '' T) := by
  rw [ker_add_mono]


/-- Canonical quotient map from adding `S` to adding `S ∪ T`. -/
def addUnionHom (P : Presentation.{u}) (S T : Set P.Free) :
    Hom (P.addRelators S) (P.addRelators (S ∪ T)) :=
  addRelatorsMono P (by intro r hr; exact Or.inl hr)

/-- Canonical quotient map from adding `T` to adding `S ∪ T`. -/
def addRelatorsUnion (P : Presentation.{u}) (S T : Set P.Free) :
    Hom (P.addRelators T) (P.addRelators (S ∪ T)) :=
  addRelatorsMono P (by intro r hr; exact Or.inr hr)

@[simp] theorem add_union_left
    (P : Presentation.{u}) (S T : Set P.Free) (w : P.Free) :
    (addUnionHom P S T).toGroupHom ((P.addRelators S).quotientMap w) =
      (P.addRelators (S ∪ T)).quotientMap w := by
  exact add_relators_mono P (by intro r hr; exact Or.inl hr) w

@[simp] theorem add_union_right
    (P : Presentation.{u}) (S T : Set P.Free) (w : P.Free) :
    (addRelatorsUnion P S T).toGroupHom ((P.addRelators T).quotientMap w) =
      (P.addRelators (S ∪ T)).quotientMap w := by
  exact add_relators_mono P (by intro r hr; exact Or.inr hr) w

/-- Descent out of an added-relator union from the left batch. -/
def Hom.desc_addrelators_unionleft {P Q : Presentation.{u}} {S T : Set P.Free}
    (f : Hom (P.addRelators S) Q)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → f.freeMap t ∈ Q.rNClos) :
    Hom (P.addRelators (S ∪ T)) Q where
  gen := f.gen
  map_rel := by
    intro r hr
    rcases hr with hrP | hrU
    · exact f.map_rel (Or.inl hrP)
    · rcases hrU with hrS | hrT
      · exact f.map_rel (Or.inr hrS)
      · exact hT hrT

@[simp] theorem Hom.descadd_relatorsunion_leftgen {P Q : Presentation.{u}}
    {S T : Set P.Free} (f : Hom (P.addRelators S) Q)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → f.freeMap t ∈ Q.rNClos)
    (x : P.Gen) :
    (f.desc_addrelators_unionleft hT).gen x = f.gen x := rfl

@[simp] theorem Hom.descadd_relaunioleft_complefthom {P Q : Presentation.{u}}
    {S T : Set P.Free} (f : Hom (P.addRelators S) Q)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → f.freeMap t ∈ Q.rNClos) :
    (f.desc_addrelators_unionleft hT).comp (addUnionHom P S T) = f := by
  ext x
  rfl

@[simp] theorem Hom.descad_union_homqu
    {P Q : Presentation.{u}} {S T : Set P.Free}
    (f : Hom (P.addRelators S) Q)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → f.freeMap t ∈ Q.rNClos)
    (w : P.Free) :
    (f.desc_addrelators_unionleft hT).toGroupHom
        ((P.addRelators (S ∪ T)).quotientMap w) =
      f.toGroupHom ((P.addRelators S).quotientMap w) := by
  rw [Hom.group_quotient, Hom.group_quotient]
  rfl

/-- Descent out of an added-relator union from the right batch. -/
def Hom.desc_addrelators_unionright {P Q : Presentation.{u}} {S T : Set P.Free}
    (f : Hom (P.addRelators T) Q)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos) :
    Hom (P.addRelators (S ∪ T)) Q where
  gen := f.gen
  map_rel := by
    intro r hr
    rcases hr with hrP | hrU
    · exact f.map_rel (Or.inl hrP)
    · rcases hrU with hrS | hrT
      · exact hS hrS
      · exact f.map_rel (Or.inr hrT)

@[simp] theorem Hom.descadd_relatorsunion_rightgen {P Q : Presentation.{u}}
    {S T : Set P.Free} (f : Hom (P.addRelators T) Q)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (x : P.Gen) :
    (f.desc_addrelators_unionright hS).gen x = f.gen x := rfl

@[simp] theorem Hom.descadd_relauniorigh_comprighthom {P Q : Presentation.{u}}
    {S T : Set P.Free} (f : Hom (P.addRelators T) Q)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos) :
    (f.desc_addrelators_unionright hS).comp (addRelatorsUnion P S T) = f := by
  ext x
  rfl

@[simp] theorem Hom.descad_union_homqa
    {P Q : Presentation.{u}} {S T : Set P.Free}
    (f : Hom (P.addRelators T) Q)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (w : P.Free) :
    (f.desc_addrelators_unionright hS).toGroupHom
        ((P.addRelators (S ∪ T)).quotientMap w) =
      f.toGroupHom ((P.addRelators T).quotientMap w) := by
  rw [Hom.group_quotient, Hom.group_quotient]
  rfl

/-- Uniqueness of descent out of an added-relator union from the left side. -/
theorem Hom.descadd_relatorsunion_leftuniq {P Q : Presentation.{u}}
    {S T : Set P.Free} (f : Hom (P.addRelators S) Q)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → f.freeMap t ∈ Q.rNClos)
    (k : Hom (P.addRelators (S ∪ T)) Q)
    (hk : k.comp (addUnionHom P S T) = f) :
    k = f.desc_addrelators_unionleft hT := by
  ext x
  have hx := congrArg (fun h : Hom (P.addRelators S) Q => h.gen x) hk
  simpa using hx

/-- Uniqueness of descent out of an added-relator union from the right side. -/
theorem Hom.descadd_relatorsunion_rightuniq {P Q : Presentation.{u}}
    {S T : Set P.Free} (f : Hom (P.addRelators T) Q)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (k : Hom (P.addRelators (S ∪ T)) Q)
    (hk : k.comp (addRelatorsUnion P S T) = f) :
    k = f.desc_addrelators_unionright hS := by
  ext x
  have hx := congrArg (fun h : Hom (P.addRelators T) Q => h.gen x) hk
  simpa using hx

/-- Left added-union descent preserves surjectivity. -/
theorem Hom.descadd_relatorsunion_leftsurj {P Q : Presentation.{u}}
    {S T : Set P.Free} (f : Hom (P.addRelators S) Q)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → f.freeMap t ∈ Q.rNClos)
    (hf : Function.Surjective f.toGroupHom) :
    Function.Surjective (f.desc_addrelators_unionleft hT).toGroupHom := by
  intro y
  rcases hf y with ⟨x, rfl⟩
  refine ⟨(addUnionHom P S T).toGroupHom x, ?_⟩
  change (((f.desc_addrelators_unionleft hT).toGroupHom.comp
      (addUnionHom P S T).toGroupHom) x) = f.toGroupHom x
  rw [← Hom.comp_group_hom, Hom.descadd_relaunioleft_complefthom]

/-- Right added-union descent preserves surjectivity. -/
theorem Hom.descadd_relatorsunion_rightsurj {P Q : Presentation.{u}}
    {S T : Set P.Free} (f : Hom (P.addRelators T) Q)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (hf : Function.Surjective f.toGroupHom) :
    Function.Surjective (f.desc_addrelators_unionright hS).toGroupHom := by
  intro y
  rcases hf y with ⟨x, rfl⟩
  refine ⟨(addRelatorsUnion P S T).toGroupHom x, ?_⟩
  change (((f.desc_addrelators_unionright hS).toGroupHom.comp
      (addRelatorsUnion P S T).toGroupHom) x) = f.toGroupHom x
  rw [← Hom.comp_group_hom, Hom.descadd_relauniorigh_comprighthom]

/-- The left union quotient is surjective. -/
theorem union_left_surjective (P : Presentation.{u}) (S T : Set P.Free) :
    Function.Surjective (addUnionHom P S T).toGroupHom :=
  add_mono_surjective P (by intro r hr; exact Or.inl hr)

/-- The right union quotient is surjective. -/
theorem add_union_surjective (P : Presentation.{u}) (S T : Set P.Free) :
    Function.Surjective (addRelatorsUnion P S T).toGroupHom :=
  add_mono_surjective P (by intro r hr; exact Or.inr hr)



/-- Range form of surjectivity for the left added-relator union map. -/
theorem add_union_top (P : Presentation.{u}) (S T : Set P.Free) :
    (addUnionHom P S T).toGroupHom.range = ⊤ :=
  MonoidHom.range_eq_top.mpr (union_left_surjective P S T)

/-- Range form of surjectivity for the right added-relator union map. -/
theorem union_range_top (P : Presentation.{u}) (S T : Set P.Free) :
    (addRelatorsUnion P S T).toGroupHom.range = ⊤ :=
  MonoidHom.range_eq_top.mpr (add_union_surjective P S T)

/-- Swapping an added-relator union carries the left inclusion to the right inclusion
for the swapped pair. -/
theorem relators_comm_hom (P : Presentation.{u})
    (S T : Set P.Free) :
    (addUnionComm P S T).toMonoidHom.comp
        (addUnionHom P S T).toGroupHom =
      (addRelatorsUnion P T S).toGroupHom := by
  apply MonoidHom.ext
  intro q
  rcases (P.addRelators S).quotientMap_surjective q with ⟨w, rfl⟩
  change (addUnionComm P S T)
        ((addUnionHom P S T).toGroupHom
          ((P.addRelators S).quotientMap w)) =
      (addRelatorsUnion P T S).toGroupHom
        ((P.addRelators S).quotientMap w)
  rw [add_union_left,
    relators_comm_quotient,
    add_union_right]

/-- Swapping an added-relator union carries the right inclusion to the left inclusion
for the swapped pair. -/
theorem union_comm_hom (P : Presentation.{u})
    (S T : Set P.Free) :
    (addUnionComm P S T).toMonoidHom.comp
        (addRelatorsUnion P S T).toGroupHom =
      (addUnionHom P T S).toGroupHom := by
  apply MonoidHom.ext
  intro q
  rcases (P.addRelators T).quotientMap_surjective q with ⟨w, rfl⟩
  change (addUnionComm P S T)
        ((addRelatorsUnion P S T).toGroupHom
          ((P.addRelators T).quotientMap w)) =
      (addUnionHom P T S).toGroupHom
        ((P.addRelators T).quotientMap w)
  rw [add_union_right,
    relators_comm_quotient,
    add_union_left]

/-- Kernel of the left union map is generated by the genuinely new `T`-relators. -/
theorem ker_left_hom (P : Presentation.{u}) (S T : Set P.Free) :
    MonoidHom.ker (addUnionHom P S T).toGroupHom =
      Subgroup.normalClosure ((P.addRelators S).quotientMap '' T) := by
  classical
  let PS := P.addRelators S
  let PT := P.addRelators (S ∪ T)
  let c := (addUnionHom P S T).toGroupHom
  let K : Subgroup PS.Group := Subgroup.normalClosure (PS.quotientMap '' T)
  apply le_antisymm
  · intro q hq
    rcases PS.quotientMap_surjective q with ⟨w, rfl⟩
    have hwT : w ∈ PT.rNClos := by
      have hc : c (PS.quotientMap w) = 1 := MonoidHom.mem_ker.mp hq
      change PT.quotientMap (FreeGroup.map id w) = 1 at hc
      rw [FreeGroup.map.id] at hc
      exact PT.quotient_one.mp hc
    change PS.quotientMap w ∈ K
    haveI : K.Normal := Subgroup.normalClosure_normal
    let qmap : PT.Free →* PS.Group := PS.quotientMap
    have hN : (K.comap qmap).Normal :=
      (show K.Normal from inferInstance).comap qmap
    letI : (K.comap qmap).Normal := hN
    have hclosure : PT.rNClos ≤ K.comap qmap := by
      apply Subgroup.normalClosure_le_normal
      intro r hr
      dsimp [PT] at hr
      dsimp [qmap]
      change PS.quotientMap r ∈ K
      rcases hr with hr | hr
      · rw [PS.quotient_rel_one (Or.inl hr)]
        exact K.one_mem
      · rcases hr with hs | ht
        · rw [PS.quotient_rel_one (Or.inr hs)]
          exact K.one_mem
        · exact Subgroup.subset_normalClosure ⟨r, ht, rfl⟩
    exact hclosure hwT
  · haveI : (MonoidHom.ker c).Normal := MonoidHom.normal_ker c
    apply Subgroup.normalClosure_le_normal
    intro q hq
    rcases hq with ⟨t, ht, rfl⟩
    change c (PS.quotientMap t) = 1
    rw [Hom.group_quotient]
    change PT.quotientMap (FreeGroup.map id t) = 1
    rw [FreeGroup.map.id]
    exact PT.quotient_rel_one (Or.inr (Or.inr ht))

@[simp] theorem ker_union_left
    (P : Presentation.{u}) (S T : Set P.Free) (q : (P.addRelators S).Group) :
    q ∈ MonoidHom.ker (addUnionHom P S T).toGroupHom ↔
      q ∈ Subgroup.normalClosure ((P.addRelators S).quotientMap '' T) := by
  rw [ker_left_hom]


/-- Kernel of the right union map is generated by the genuinely new `S`-relators. -/
theorem ker_add_union (P : Presentation.{u}) (S T : Set P.Free) :
    MonoidHom.ker (addRelatorsUnion P S T).toGroupHom =
      Subgroup.normalClosure ((P.addRelators T).quotientMap '' S) := by
  classical
  let PT0 := P.addRelators T
  let PU := P.addRelators (S ∪ T)
  let c := (addRelatorsUnion P S T).toGroupHom
  let K : Subgroup PT0.Group := Subgroup.normalClosure (PT0.quotientMap '' S)
  apply le_antisymm
  · intro q hq
    rcases PT0.quotientMap_surjective q with ⟨w, rfl⟩
    have hwU : w ∈ PU.rNClos := by
      have hc : c (PT0.quotientMap w) = 1 := MonoidHom.mem_ker.mp hq
      change PU.quotientMap (FreeGroup.map id w) = 1 at hc
      rw [FreeGroup.map.id] at hc
      exact PU.quotient_one.mp hc
    change PT0.quotientMap w ∈ K
    haveI : K.Normal := Subgroup.normalClosure_normal
    let qmap : PU.Free →* PT0.Group := PT0.quotientMap
    have hN : (K.comap qmap).Normal :=
      (show K.Normal from inferInstance).comap qmap
    letI : (K.comap qmap).Normal := hN
    have hclosure : PU.rNClos ≤ K.comap qmap := by
      apply Subgroup.normalClosure_le_normal
      intro r hr
      dsimp [PU] at hr
      dsimp [qmap]
      change PT0.quotientMap r ∈ K
      rcases hr with hr | hr
      · rw [PT0.quotient_rel_one (Or.inl hr)]
        exact K.one_mem
      · rcases hr with hs | ht
        · exact Subgroup.subset_normalClosure ⟨r, hs, rfl⟩
        · rw [PT0.quotient_rel_one (Or.inr ht)]
          exact K.one_mem
    exact hclosure hwU
  · haveI : (MonoidHom.ker c).Normal := MonoidHom.normal_ker c
    apply Subgroup.normalClosure_le_normal
    intro q hq
    rcases hq with ⟨s, hs, rfl⟩
    change c (PT0.quotientMap s) = 1
    rw [Hom.group_quotient]
    change PU.quotientMap (FreeGroup.map id s) = 1
    rw [FreeGroup.map.id]
    exact PU.quotient_rel_one (Or.inr (Or.inl hs))

@[simp] theorem ker_union_hom
    (P : Presentation.{u}) (S T : Set P.Free) (q : (P.addRelators T).Group) :
    q ∈ MonoidHom.ker (addRelatorsUnion P S T).toGroupHom ↔
      q ∈ Subgroup.normalClosure ((P.addRelators T).quotientMap '' S) := by
  rw [ker_add_union]


/-- Quotient criterion for injectivity of a left added-union descent. -/
theorem Hom.descadd_relaunioleft_injkernelle
    {P Q : Presentation.{u}} {S T : Set P.Free}
    (f : Hom (P.addRelators S) Q)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → f.freeMap t ∈ Q.rNClos)
    (hker : MonoidHom.ker f.toGroupHom ≤
      Subgroup.normalClosure ((P.addRelators S).quotientMap '' T)) :
    Function.Injective (f.desc_addrelators_unionleft hT).toGroupHom := by
  let c := (addUnionHom P S T).toGroupHom
  let g := (f.desc_addrelators_unionleft hT).toGroupHom
  have hc_surj : Function.Surjective c := union_left_surjective P S T
  have hcomp : g.comp c = f.toGroupHom := by
    rw [← Hom.comp_group_hom, Hom.descadd_relaunioleft_complefthom]
  have hker_c : MonoidHom.ker c =
      Subgroup.normalClosure ((P.addRelators S).quotientMap '' T) :=
    ker_left_hom P S T
  have htriv : ∀ {z}, g z = 1 → z = 1 := by
    intro z hz
    rcases hc_surj z with ⟨x, rfl⟩
    have hxF : f.toGroupHom x = 1 := by
      rw [← hcomp]
      exact hz
    have hxK : x ∈ MonoidHom.ker c := by
      rw [hker_c]
      exact hker (MonoidHom.mem_ker.mpr hxF)
    exact MonoidHom.mem_ker.mp hxK
  intro a b hab
  apply eq_of_mul_inv_eq_one
  apply htriv
  rw [map_mul, map_inv, hab, mul_inv_cancel]

/-- Quotient criterion for injectivity of a right added-union descent. -/
theorem Hom.descadd_relauniorigh_injkernelle
    {P Q : Presentation.{u}} {S T : Set P.Free}
    (f : Hom (P.addRelators T) Q)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (hker : MonoidHom.ker f.toGroupHom ≤
      Subgroup.normalClosure ((P.addRelators T).quotientMap '' S)) :
    Function.Injective (f.desc_addrelators_unionright hS).toGroupHom := by
  let c := (addRelatorsUnion P S T).toGroupHom
  let g := (f.desc_addrelators_unionright hS).toGroupHom
  have hc_surj : Function.Surjective c := add_union_surjective P S T
  have hcomp : g.comp c = f.toGroupHom := by
    rw [← Hom.comp_group_hom, Hom.descadd_relauniorigh_comprighthom]
  have hker_c : MonoidHom.ker c =
      Subgroup.normalClosure ((P.addRelators T).quotientMap '' S) :=
    ker_add_union P S T
  have htriv : ∀ {z}, g z = 1 → z = 1 := by
    intro z hz
    rcases hc_surj z with ⟨x, rfl⟩
    have hxF : f.toGroupHom x = 1 := by
      rw [← hcomp]
      exact hz
    have hxK : x ∈ MonoidHom.ker c := by
      rw [hker_c]
      exact hker (MonoidHom.mem_ker.mpr hxF)
    exact MonoidHom.mem_ker.mp hxK
  intro a b hab
  apply eq_of_mul_inv_eq_one
  apply htriv
  rw [map_mul, map_inv, hab, mul_inv_cancel]

/-- Bijective form of the left added-union descent criterion. -/
theorem Hom.descad_union_kerne
    {P Q : Presentation.{u}} {S T : Set P.Free}
    (f : Hom (P.addRelators S) Q)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → f.freeMap t ∈ Q.rNClos)
    (hker : MonoidHom.ker f.toGroupHom ≤
      Subgroup.normalClosure ((P.addRelators S).quotientMap '' T))
    (hf : Function.Surjective f.toGroupHom) :
    Function.Bijective (f.desc_addrelators_unionleft hT).toGroupHom :=
  ⟨f.descadd_relaunioleft_injkernelle hT hker,
    f.descadd_relatorsunion_leftsurj hT hf⟩

