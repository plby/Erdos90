  exact (add_relators_union P S T hS w).symm

@[simp] theorem add_union_subset
    (P : Presentation.{u}) (S T : Set P.Free)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → t ∈ (P.addRelators S).rNClos)
    (y : (P.addRelators (S ∪ T)).Group) (x : (P.addRelators S).Group) :
    (relatorsUnionSubset P S T hT).symm y = x ↔
      y = (addUnionHom P S T).toGroupHom x := by
  rw [MulEquiv.symm_apply_eq]
  change y = (relatorsUnionSubset P S T hT).toMonoidHom x ↔
    y = (addUnionHom P S T).toGroupHom x
  rw [union_monoid_hom]

@[simp] theorem add_union_symm
    (P : Presentation.{u}) (S T : Set P.Free)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → s ∈ (P.addRelators T).rNClos)
    (y : (P.addRelators (S ∪ T)).Group) (x : (P.addRelators T).Group) :
    (unionSubsetClosure P S T hS).symm y = x ↔
      y = (addRelatorsUnion P S T).toGroupHom x := by
  rw [MulEquiv.symm_apply_eq]
  change y = (unionSubsetClosure P S T hS).toMonoidHom x ↔
    y = (addRelatorsUnion P S T).toGroupHom x
  rw [union_subset_monoid]

@[simp] theorem add_relators_symm
    (P : Presentation.{u}) (S T : Set P.Free)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → t ∈ (P.addRelators S).rNClos)
    (x : (P.addRelators S).Group) (y : (P.addRelators (S ∪ T)).Group) :
    x = (relatorsUnionSubset P S T hT).symm y ↔
      (addUnionHom P S T).toGroupHom x = y := by
  rw [eq_comm, add_union_subset, eq_comm]

@[simp] theorem add_subset_symm
    (P : Presentation.{u}) (S T : Set P.Free)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → s ∈ (P.addRelators T).rNClos)
    (x : (P.addRelators T).Group) (y : (P.addRelators (S ∪ T)).Group) :
    x = (unionSubsetClosure P S T hS).symm y ↔
      (addRelatorsUnion P S T).toGroupHom x = y := by
  rw [eq_comm, add_union_symm, eq_comm]

@[simp] theorem add_union_comp
    (P : Presentation.{u}) (S T : Set P.Free) :
    (addUnionHom P S T).comp (addRelatorsHom P S) =
      addRelatorsHom P (S ∪ T) := by
  ext x
  rfl

@[simp] theorem relators_union_comp
    (P : Presentation.{u}) (S T : Set P.Free) :
    (addRelatorsUnion P S T).comp (addRelatorsHom P T) =
      addRelatorsHom P (S ∪ T) := by
  ext x
  rfl

/-- The monotonicity morphism composes with the first quotient map to the larger
quotient map. -/
@[simp] theorem relators_mono_comp (P : Presentation.{u})
    {S T : Set P.Free} (hST : S ⊆ T) :
    (addRelatorsMono P hST).comp (addRelatorsHom P S) =
      addRelatorsHom P T := by
  ext x
  rfl


/-- Adding relators gives a surjective map of presented groups. -/
theorem relators_surjective (P : Presentation.{u}) (S : Set P.Free) :
    Function.Surjective (addRelatorsHom P S).toGroupHom :=
  (addRelatorsHom P S).group_surjective_gen (by
    intro x
    exact ⟨x, rfl⟩)

/-- The kernel of the quotient map obtained by adding relators is the normal
closure, in the old presented group, of the images of the new relators. -/
theorem ker_add_hom (P : Presentation.{u}) (S : Set P.Free) :
    MonoidHom.ker (addRelatorsHom P S).toGroupHom =
      Subgroup.normalClosure (P.quotientMap '' S) := by
  classical
  let c := (addRelatorsHom P S).toGroupHom
  let K : Subgroup P.Group := Subgroup.normalClosure (P.quotientMap '' S)
  apply le_antisymm
  · intro q hq
    rcases P.quotientMap_surjective q with ⟨w, rfl⟩
    have hwAdd : w ∈ (P.addRelators S).rNClos := by
      have hc : c (P.quotientMap w) = 1 := MonoidHom.mem_ker.mp hq
      change (P.addRelators S).quotientMap (FreeGroup.map id w) = 1 at hc
      have hid : FreeGroup.map id w = w := FreeGroup.map.id w
      have hc' : (P.addRelators S).quotientMap w = 1 := by
        rw [← hid]
        exact hc
      exact (P.addRelators S).quotient_one.mp hc'
    change P.quotientMap w ∈ K
    haveI : K.Normal := Subgroup.normalClosure_normal
    let qmap : (P.addRelators S).Free →* P.Group := P.quotientMap
    have hN : (K.comap qmap).Normal :=
      (show K.Normal from inferInstance).comap qmap
    letI : (K.comap qmap).Normal := hN
    have hclosure :
        (P.addRelators S).rNClos ≤ K.comap qmap := by
      apply Subgroup.normalClosure_le_normal
      intro r hr
      rcases hr with hr | hr
      · dsimp [qmap]
        change P.quotientMap r ∈ K
        rw [P.quotient_rel_one hr]
        exact K.one_mem
      · dsimp [qmap]
        change P.quotientMap r ∈ K
        exact Subgroup.subset_normalClosure ⟨r, hr, rfl⟩
    exact hclosure hwAdd
  · haveI : (MonoidHom.ker c).Normal := MonoidHom.normal_ker c
    apply Subgroup.normalClosure_le_normal
    intro q hq
    rcases hq with ⟨s, hs, rfl⟩
    change c (P.quotientMap s) = 1
    rw [Hom.group_quotient]
    change (P.addRelators S).quotientMap (FreeGroup.map id s) = 1
    rw [FreeGroup.map.id]
    exact (P.addRelators S).quotient_rel_one (Or.inr hs)

/-- Pointwise kernel criterion for the canonical map adding relators. -/
@[simp] theorem ker_add_relators (P : Presentation.{u}) (S : Set P.Free)
    (q : P.Group) :
    q ∈ MonoidHom.ker (addRelatorsHom P S).toGroupHom ↔
      q ∈ Subgroup.normalClosure (P.quotientMap '' S) := by
  rw [ker_add_hom]

/-- If the added relators were already consequences of the old relators, there is
an evident morphism back from the enlarged presentation. -/
def subsetNormalClosure (P : Presentation.{u}) {S : Set P.Free}
    (hS : S ≤ P.rNClos) : Hom (P.addRelators S) P where
  gen := id
  map_rel := by
    intro r hr
    change FreeGroup.map id r ∈ P.rNClos
    rw [FreeGroup.map.id]
    rcases hr with hr | hr
    · exact Subgroup.subset_normalClosure hr
    · exact hS hr

@[simp] theorem relators_subset_gen
    (P : Presentation.{u}) {S : Set P.Free} (hS : S ≤ P.rNClos)
    (x : P.Gen) :
    (subsetNormalClosure P hS).gen x = x := rfl


@[simp] theorem relators_subset_group
    (P : Presentation.{u}) {S : Set P.Free} (hS : S ≤ P.rNClos)
    (x : P.Gen) :
    (subsetNormalClosure P hS).toGroupHom
        ((P.addRelators S).of x) = P.of x := rfl

@[simp] theorem add_relators_subset
    (P : Presentation.{u}) {S : Set P.Free} (hS : S ≤ P.rNClos)
    (w : P.Free) :
    (subsetNormalClosure P hS).toGroupHom
        ((P.addRelators S).quotientMap w) = P.quotientMap w := by
  rw [Hom.group_quotient]
  change P.quotientMap (FreeGroup.map id w) = _
  rw [FreeGroup.map.id]

/-- The backward morphism after adding redundant relators is surjective. -/
theorem subset_closure_surjective
    (P : Presentation.{u}) {S : Set P.Free} (hS : S ≤ P.rNClos) :
    Function.Surjective (subsetNormalClosure P hS).toGroupHom := by
  apply Hom.group_surjective_free
  intro w
  refine ⟨w, ?_⟩
  change FreeGroup.map id w = w
  rw [FreeGroup.map.id]

@[simp] theorem relators_subset_comp
    (P : Presentation.{u}) {S : Set P.Free} (hS : S ≤ P.rNClos) :
    (subsetNormalClosure P hS).comp (addRelatorsHom P S) =
      Hom.id P := by
  ext x
  rfl

@[simp] theorem relators_subset_closure
    (P : Presentation.{u}) {S : Set P.Free} (hS : S ≤ P.rNClos) :
    (addRelatorsHom P S).comp (subsetNormalClosure P hS) =
      Hom.id (P.addRelators S) := by
  ext x
  rfl

/-- Adding only relators already in the old normal closure does not change the
presented group. -/
noncomputable def addSubsetClosure (P : Presentation.{u})
    {S : Set P.Free} (hS : S ≤ P.rNClos) :
    P.Group ≃* (P.addRelators S).Group :=
  Hom.groupEquivInverse (addRelatorsHom P S)
    (subsetNormalClosure P hS)
    (relators_subset_comp P hS)
    (relators_subset_closure P hS)

@[simp] theorem add_subset_normal
    (P : Presentation.{u}) {S : Set P.Free} (hS : S ≤ P.rNClos)
    (x : P.Group) :
    addSubsetClosure P hS x =
      (addRelatorsHom P S).toGroupHom x := rfl

@[simp] theorem subset_normal_symm
    (P : Presentation.{u}) {S : Set P.Free} (hS : S ≤ P.rNClos)
    (y : (P.addRelators S).Group) :
    (addSubsetClosure P hS).symm y =
      (subsetNormalClosure P hS).toGroupHom y := rfl


@[simp] theorem subset_normal_closure
    (P : Presentation.{u}) {S : Set P.Free} (hS : S ≤ P.rNClos)
    (w : P.Free) :
    addSubsetClosure P hS (P.quotientMap w) =
      (P.addRelators S).quotientMap w := by
  change (addRelatorsHom P S).toGroupHom (P.quotientMap w) = _
  rw [add_relators_hom]

@[simp] theorem relators_subset_normal
    (P : Presentation.{u}) {S : Set P.Free} (hS : S ≤ P.rNClos)
    (w : P.Free) :
    (addSubsetClosure P hS).symm
        ((P.addRelators S).quotientMap w) = P.quotientMap w := by
  change (subsetNormalClosure P hS).toGroupHom
      ((P.addRelators S).quotientMap w) = _
  rw [add_relators_subset]

@[simp] theorem subset_monoid_hom
    (P : Presentation.{u}) {S : Set P.Free} (hS : S ≤ P.rNClos) :
    (addSubsetClosure P hS).toMonoidHom =
      (addRelatorsHom P S).toGroupHom := rfl

/-- Explicit equivalence witnessing that adding the empty relator set changes nothing. -/
noncomputable def addRelatorsEmpty (P : Presentation.{u}) :
    P.Group ≃* (P.addRelators (∅ : Set P.Free)).Group :=
  addSubsetClosure P (by intro r hr; cases hr)

@[simp] theorem add_relators_empty (P : Presentation.{u}) (x : P.Group) :
    addRelatorsEmpty P x = (addRelatorsHom P (∅ : Set P.Free)).toGroupHom x := rfl

/-- Universal property of adding relators: a morphism out of `P` descends to the
presentation with extra relators exactly when it kills those extra relators. -/
def Hom.descAddRelators {P Q : Presentation.{u}} (f : Hom P Q) {S : Set P.Free}
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos) :
    Hom (P.addRelators S) Q where
  gen := f.gen
  map_rel := by
    intro r hr
    rcases hr with hr | hr
    · exact f.map_rel hr
    · exact hS hr

@[simp] theorem Hom.desc_add_relatorsgen {P Q : Presentation.{u}} (f : Hom P Q)
    {S : Set P.Free}
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (x : P.Gen) :
    (f.descAddRelators hS).gen x = f.gen x := rfl


@[simp] theorem Hom.descadd_relatorsgroup_homquotmap {P Q : Presentation.{u}}
    (f : Hom P Q) {S : Set P.Free}
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (w : P.Free) :
    (f.descAddRelators hS).toGroupHom ((P.addRelators S).quotientMap w) =
      f.toGroupHom (P.quotientMap w) := by
  rw [Hom.group_quotient, Hom.group_quotient]
  rfl

@[simp] theorem Hom.descadd_relatorscomp_addrelators {P Q : Presentation.{u}}
    (f : Hom P Q) {S : Set P.Free}
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos) :
    (f.descAddRelators hS).comp (addRelatorsHom P S) = f := by
  cases f
  rfl

/-- Cancellation across the canonical map that adds relators.  This is the
presentation-level epimorphism property of `addRelatorsHom`. -/
theorem Hom.eqcomp_addrelators_homeq {P Q : Presentation.{u}} {S : Set P.Free}
    {f g : Hom (P.addRelators S) Q}
    (h : f.comp (addRelatorsHom P S) = g.comp (addRelatorsHom P S)) :
    f = g := by
  ext x
  have hx := congrArg (fun k : Hom P Q => k.gen x) h
  simpa using hx

/-- Uniqueness of descent through added relators. -/
theorem Hom.desc_add_relatorsuniq {P Q : Presentation.{u}} (f : Hom P Q)
    {S : Set P.Free}
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (k : Hom (P.addRelators S) Q)
    (hk : k.comp (addRelatorsHom P S) = f) :
    k = f.descAddRelators hS := by
  apply Hom.eqcomp_addrelators_homeq (P := P) (S := S)
  rw [hk, Hom.descadd_relatorscomp_addrelators]


@[simp] theorem Hom.descadd_relatorsgroup_homcomp {P Q : Presentation.{u}}
    (f : Hom P Q) {S : Set P.Free}
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos) :
    (f.descAddRelators hS).toGroupHom.comp (addRelatorsHom P S).toGroupHom =
      f.toGroupHom := by
  rw [← Hom.comp_group_hom, Hom.descadd_relatorscomp_addrelators]

/-- Descent through added relators preserves surjectivity of the original
presentation morphism. -/
theorem Hom.desc_add_relatorssurj {P Q : Presentation.{u}}
    (f : Hom P Q) {S : Set P.Free}
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (hf : Function.Surjective f.toGroupHom) :
    Function.Surjective (f.descAddRelators hS).toGroupHom := by
  intro y
  rcases hf y with ⟨x, rfl⟩
  refine ⟨(addRelatorsHom P S).toGroupHom x, ?_⟩
  change ((f.descAddRelators hS).toGroupHom.comp
      (addRelatorsHom P S).toGroupHom) x = f.toGroupHom x
  rw [Hom.descadd_relatorsgroup_homcomp]

/-- If the kernel of a morphism is contained in the normal closure of the added
relator images, then the descended morphism is injective.  The reverse inclusion
is automatic from the descent hypothesis, so this is the usual quotient
criterion in a one-sided form. -/
theorem Hom.descadd_relatorsinj_kernelle {P Q : Presentation.{u}}
    (f : Hom P Q) {S : Set P.Free}
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (hker : MonoidHom.ker f.toGroupHom ≤
      Subgroup.normalClosure (P.quotientMap '' S)) :
    Function.Injective (f.descAddRelators hS).toGroupHom := by
  let c := (addRelatorsHom P S).toGroupHom
  let g := (f.descAddRelators hS).toGroupHom
  have hc_surj : Function.Surjective c :=
    relators_surjective P S
  have hcomp : g.comp c = f.toGroupHom :=
    Hom.descadd_relatorsgroup_homcomp f hS
  have hker_c : MonoidHom.ker c =
      Subgroup.normalClosure (P.quotientMap '' S) :=
    ker_add_hom P S
  have htriv : ∀ {z}, g z = 1 → z = 1 := by
    intro z hz
    rcases hc_surj z with ⟨x, rfl⟩
    have hxF : f.toGroupHom x = 1 := by
      rw [← hcomp]
      exact hz
    have hxK : x ∈ MonoidHom.ker c := by
      rw [hker_c]
      exact hker (MonoidHom.mem_ker.mpr hxF)
    exact MonoidHom.mem_ker.mp hxK
  intro a b hab
  apply eq_of_mul_inv_eq_one
  apply htriv
  rw [map_mul, map_inv, hab, mul_inv_cancel]

/-- Kernel form of the injectivity criterion for descent through added relators. -/
theorem Hom.kerdesc_addrelatorseq_botkernelle {P Q : Presentation.{u}}
    (f : Hom P Q) {S : Set P.Free}
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (hker : MonoidHom.ker f.toGroupHom ≤
      Subgroup.normalClosure (P.quotientMap '' S)) :
    MonoidHom.ker (f.descAddRelators hS).toGroupHom = ⊥ :=
  (MonoidHom.ker_eq_bot_iff _).2
    (f.descadd_relatorsinj_kernelle hS hker)

/-- Bijectivity form of the descent quotient criterion. -/
theorem Hom.descadd_relatorsbij_kernellesurj
    {P Q : Presentation.{u}} (f : Hom P Q) {S : Set P.Free}
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (hker : MonoidHom.ker f.toGroupHom ≤
      Subgroup.normalClosure (P.quotientMap '' S))
    (hf : Function.Surjective f.toGroupHom) :
    Function.Bijective (f.descAddRelators hS).toGroupHom :=
  ⟨f.descadd_relatorsinj_kernelle hS hker,
    f.desc_add_relatorssurj hS hf⟩

/-- Equivalence form of the descent quotient criterion for added relators. -/
noncomputable def Hom.desc_relators_surjective
    {P Q : Presentation.{u}} (f : Hom P Q) {S : Set P.Free}
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (hker : MonoidHom.ker f.toGroupHom ≤
      Subgroup.normalClosure (P.quotientMap '' S))
    (hf : Function.Surjective f.toGroupHom) :
    (P.addRelators S).Group ≃* Q.Group :=
  Hom.groupEquivBijective (f.descAddRelators hS)
    (f.descadd_relatorsbij_kernellesurj hS hker hf)

@[simp] theorem Hom.desc_add_relators
    {P Q : Presentation.{u}} (f : Hom P Q) {S : Set P.Free}
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (hker : MonoidHom.ker f.toGroupHom ≤
      Subgroup.normalClosure (P.quotientMap '' S))
    (hf : Function.Surjective f.toGroupHom) (x : (P.addRelators S).Group) :
    f.desc_relators_surjective hS hker hf x =
      (f.descAddRelators hS).toGroupHom x := rfl

@[simp] theorem Hom.descadd_relatorsequiv_monoidhom
    {P Q : Presentation.{u}} (f : Hom P Q) {S : Set P.Free}
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (hker : MonoidHom.ker f.toGroupHom ≤
      Subgroup.normalClosure (P.quotientMap '' S))
    (hf : Function.Surjective f.toGroupHom) :
    (f.desc_relators_surjective hS hker hf).toMonoidHom =
      (f.descAddRelators hS).toGroupHom := rfl

/-- The inverse of the descent equivalence cancels the descended hom. -/
@[simp] theorem Hom.descadd_relatorsequiv_symmapplydesc
    {P Q : Presentation.{u}} (f : Hom P Q) {S : Set P.Free}
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (hker : MonoidHom.ker f.toGroupHom ≤
      Subgroup.normalClosure (P.quotientMap '' S))
    (hf : Function.Surjective f.toGroupHom) (x : (P.addRelators S).Group) :
    (f.desc_relators_surjective hS hker hf).symm
        ((f.descAddRelators hS).toGroupHom x) = x := by
  exact (f.desc_relators_surjective hS hker hf).left_inv x

/-- The descended hom cancels the inverse of the descent equivalence. -/
@[simp] theorem Hom.descadd_relatorsequiv_descapplysymm
    {P Q : Presentation.{u}} (f : Hom P Q) {S : Set P.Free}
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (hker : MonoidHom.ker f.toGroupHom ≤
      Subgroup.normalClosure (P.quotientMap '' S))
    (hf : Function.Surjective f.toGroupHom) (y : Q.Group) :
    (f.descAddRelators hS).toGroupHom
        ((f.desc_relators_surjective hS hker hf).symm y) = y := by
  change f.desc_relators_surjective hS hker hf
        ((f.desc_relators_surjective hS hker hf).symm y) = y
  exact (f.desc_relators_surjective hS hker hf).right_inv y

/-- Pointwise formula for the equivalence obtained from a quotient criterion on representatives. -/
@[simp] theorem Hom.descadd_relatorsequiv_quotmap
    {P Q : Presentation.{u}} (f : Hom P Q) {S : Set P.Free}
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (hker : MonoidHom.ker f.toGroupHom ≤
      Subgroup.normalClosure (P.quotientMap '' S))
    (hf : Function.Surjective f.toGroupHom) (w : P.Free) :
    f.desc_relators_surjective hS hker hf
        ((P.addRelators S).quotientMap w) =
      f.toGroupHom (P.quotientMap w) := by
  rw [Hom.desc_add_relators, Hom.descadd_relatorsgroup_homquotmap]

/-- The inverse equivalence sends an image representative back to its
added-relator representative. -/
@[simp] theorem Hom.descadd_relaequisymm_imagequotmap
    {P Q : Presentation.{u}} (f : Hom P Q) {S : Set P.Free}
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (hker : MonoidHom.ker f.toGroupHom ≤
      Subgroup.normalClosure (P.quotientMap '' S))
    (hf : Function.Surjective f.toGroupHom) (w : P.Free) :
    (f.desc_relators_surjective hS hker hf).symm
        (f.toGroupHom (P.quotientMap w)) =
      (P.addRelators S).quotientMap w := by
  rw [← Hom.descadd_relatorsequiv_quotmap f hS hker hf w]
  exact (f.desc_relators_surjective hS hker hf).left_inv _

/-- Characterize the inverse of the equivalence obtained after adding relators. -/
@[simp] theorem Hom.descadd_relatorsequiv_symmapplyeq
    {P Q : Presentation.{u}} (f : Hom P Q) {S : Set P.Free}
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (hker : MonoidHom.ker f.toGroupHom ≤
      Subgroup.normalClosure (P.quotientMap '' S))
    (hf : Function.Surjective f.toGroupHom) (y : Q.Group)
    (x : (P.addRelators S).Group) :
    (f.desc_relators_surjective hS hker hf).symm y = x ↔
      y = (f.descAddRelators hS).toGroupHom x := by
  rw [MulEquiv.symm_apply_eq]
  rfl

/-- Alternate orientation of `Hom.descadd_relatorsequiv_symmapplyeq`. -/
@[simp] theorem Hom.eqdesc_addrelators_equivsymmapply
    {P Q : Presentation.{u}} (f : Hom P Q) {S : Set P.Free}
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (hker : MonoidHom.ker f.toGroupHom ≤
      Subgroup.normalClosure (P.quotientMap '' S))
    (hf : Function.Surjective f.toGroupHom)
    (x : (P.addRelators S).Group) (y : Q.Group) :
    x = (f.desc_relators_surjective hS hker hf).symm y ↔
      (f.descAddRelators hS).toGroupHom x = y := by
  rw [eq_comm, Hom.descadd_relatorsequiv_symmapplyeq, eq_comm]

end Presentation
end Towers
