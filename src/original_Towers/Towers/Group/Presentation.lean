      Subgroup.normalClosure ((P.withRelators S).quotientMap '' T))
    (hf : Function.Surjective f.toGroupHom) (y : Q.Group) :
    (f.desc_relators_unionleft hT).toGroupHom
        ((f.descre_union_kerna hT hker hf).symm y) = y := by
  change f.descre_union_kerna hT hker hf
        ((f.descre_union_kerna hT hker hf).symm y) = y
  exact (f.descre_union_kerna hT hker hf).right_inv y

