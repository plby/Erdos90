import Mathlib.GroupTheory.PresentedGroup
import Mathlib.GroupTheory.QuotientGroup.Basic

/-!
# Presentation conventions

Mathlib already supplies `FreeGroup` and `PresentedGroup`.  This file bundles the
small amount of notation/convention Towers will use around them, without replacing
mathlib's universal property.
-/

namespace Towers

universe u v

/-- A (set-based) group presentation: generators together with relators in the free group. -/
structure Presentation where
  Gen : Type u
  rels : Set (FreeGroup Gen)

namespace Presentation

/-- The presentation with generators `α` and no relators. -/
def free (α : Type u) : Presentation.{u} where
  Gen := α
  rels := ∅

variable (P : Presentation.{u})

/-- The free group on the generators of a presentation. -/
abbrev Free : Type u := FreeGroup P.Gen

/-- The group presented by `P`. -/
abbrev Group : Type u := PresentedGroup P.rels

instance : _root_.Group P.Group := inferInstance

/-- The quotient map from the free group to the presented group. -/
def quotientMap : P.Free →* P.Group := PresentedGroup.mk P.rels

/-- The image of a generator in the presented group. -/
def of (x : P.Gen) : P.Group := PresentedGroup.of (rels := P.rels) x

/-- A no-relator presentation presents the free group. -/
noncomputable def freeGroupEquiv (α : Type u) : (free α).Group ≃* FreeGroup α := by
  change (FreeGroup α ⧸ Subgroup.normalClosure (∅ : Set (FreeGroup α))) ≃* FreeGroup α
  exact (QuotientGroup.quotientMulEquivOfEq
    (Subgroup.normalClosure_empty :
      Subgroup.normalClosure (∅ : Set (FreeGroup α)) = ⊥)).trans
    QuotientGroup.quotientBot

@[simp] theorem free_equiv (α : Type u) (x : α) :
    freeGroupEquiv α ((free α).of x) = FreeGroup.of x := rfl


/-- The quotient map sends a free generator to the corresponding presented generator. -/
@[simp] theorem quotientMap_of (x : P.Gen) :
    P.quotientMap (FreeGroup.of x) = P.of x := rfl

/-- The presentation quotient map is the free-group lift of the canonical generators. -/
theorem map_eq_of :
    P.quotientMap = FreeGroup.lift P.of := by
  apply FreeGroup.ext_hom
  intro x
  rfl

@[simp] theorem quotientMap_surjective : Function.Surjective P.quotientMap :=
  PresentedGroup.mk_surjective P.rels

@[simp] theorem quotient_rel_one {r : P.Free} (hr : r ∈ P.rels) :
    P.quotientMap r = 1 :=
  PresentedGroup.one_of_mem hr

/-- The normal subgroup of the free group generated by the relators. -/
abbrev rNClos : Subgroup P.Free := Subgroup.normalClosure P.rels


/-- The relator closure is normal, as a named instance for downstream conjugation proofs. -/
instance rNClos.instNormal : P.rNClos.Normal :=
  Subgroup.normalClosure_normal

/-- Conjugating a relator-closure element stays in the relator closure. -/
theorem relator_closure_conj {x : P.Free}
    (hx : x ∈ P.rNClos) (g : P.Free) :
    g * x * g⁻¹ ∈ P.rNClos := by
  exact (show P.rNClos.Normal from inferInstance).conj_mem x hx g

/-- Natural powers of relator-closure elements stay in the relator closure. -/
theorem relator_closure_pow {x : P.Free}
    (hx : x ∈ P.rNClos) (n : ℕ) :
    x ^ n ∈ P.rNClos :=
  P.rNClos.pow_mem hx n

/-- Integer powers of relator-closure elements stay in the relator closure. -/
theorem relator_closure_zpow {x : P.Free}
    (hx : x ∈ P.rNClos) (n : ℤ) :
    x ^ n ∈ P.rNClos :=
  P.rNClos.zpow_mem hx n

/-- Kernel characterization for the presentation quotient map. -/
theorem quotient_one {x : P.Free} :
    P.quotientMap x = 1 ↔ x ∈ P.rNClos :=
  PresentedGroup.mk_eq_one_iff

/-- Conjugates of relator-closure words map trivially in the presented group. -/
@[simp] theorem quotient_conj_one {x : P.Free}
    (hx : x ∈ P.rNClos) (g : P.Free) :
    P.quotientMap (g * x * g⁻¹) = 1 := by
  exact P.quotient_one.mpr (P.relator_closure_conj hx g)

/-- Natural powers of relator-closure words map trivially in the presented group. -/
@[simp] theorem quotient_pow_one {x : P.Free}
    (hx : x ∈ P.rNClos) (n : ℕ) :
    P.quotientMap (x ^ n) = 1 := by
  exact P.quotient_one.mpr (P.relator_closure_pow hx n)

/-- Integer powers of relator-closure words map trivially in the presented group. -/
@[simp] theorem quotient_zpow_one {x : P.Free}
    (hx : x ∈ P.rNClos) (n : ℤ) :
    P.quotientMap (x ^ n) = 1 := by
  exact P.quotient_one.mpr (P.relator_closure_zpow hx n)

/-- The kernel of the quotient map is exactly the normal closure of the relators. -/
@[simp] theorem ker_quotientMap : MonoidHom.ker P.quotientMap = P.rNClos := by
  ext x
  exact quotient_one P

/-- A word maps trivially iff it lies in the kernel, in relator-normal-closure form. -/
@[simp] theorem ker_quotient {x : P.Free} :
    x ∈ MonoidHom.ker P.quotientMap ↔ x ∈ P.rNClos := by
  rw [ker_quotientMap]

/-- Equality in a presented group, expressed on free-word representatives. -/
theorem eq_map_iff {x y : P.Free} :
    P.quotientMap x = P.quotientMap y ↔ x⁻¹ * y ∈ P.rNClos := by
  change ((x : P.Free) : P.Free ⧸ P.rNClos) =
      ((y : P.Free) : P.Free ⧸ P.rNClos) ↔ _
  exact QuotientGroup.eq


/-- A quotient representative `x⁻¹*y` is trivial exactly when the two representatives
have the same image. -/
@[simp] theorem quotient_inv_one {x y : P.Free} :
    P.quotientMap (x⁻¹ * y) = 1 ↔ P.quotientMap x = P.quotientMap y := by
  constructor
  · intro h
    have h' := congrArg (fun z => P.quotientMap x * z) h
    have hyx : P.quotientMap y = P.quotientMap x := by
      simpa [map_mul, mul_assoc] using h'
    exact hyx.symm
  · intro h
    simp [map_mul, h]

/-- Right-oriented trivial representative criterion. -/
@[simp] theorem mul_inv_one {x y : P.Free} :
    P.quotientMap (x * y⁻¹) = 1 ↔ P.quotientMap x = P.quotientMap y := by
  constructor
  · intro h
    have h' := congrArg (fun z => z * P.quotientMap y) h
    simpa [map_mul, mul_assoc] using h'
  · intro h
    simp [map_mul, h]

/-- Normal-closure membership criterion in left-difference form. -/
@[simp] theorem inv_normal_closure {x y : P.Free} :
    x⁻¹ * y ∈ P.rNClos ↔ P.quotientMap x = P.quotientMap y := by
  rw [← P.quotient_one, quotient_inv_one]

/-- Normal-closure membership criterion in right-difference form. -/
@[simp] theorem inv_relator_closure {x y : P.Free} :
    x * y⁻¹ ∈ P.rNClos ↔ P.quotientMap x = P.quotientMap y := by
  rw [← P.quotient_one, mul_inv_one]

/-- Symmetric representative criterion, often more convenient for right quotients. -/
theorem quotient_mul_inv {x y : P.Free} :
    P.quotientMap x = P.quotientMap y ↔ x * y⁻¹ ∈ P.rNClos := by
  rw [eq_map_iff]
  constructor
  · intro h
    have hn : (P.rNClos).Normal := Subgroup.normalClosure_normal
    have hc : x * (x⁻¹ * y) * x⁻¹ ∈ P.rNClos :=
      hn.conj_mem (x⁻¹ * y) h x
    have hyx : y * x⁻¹ ∈ P.rNClos := by
      simpa [mul_assoc] using hc
    simpa [mul_assoc] using (P.rNClos.inv_mem hyx)
  · intro h
    have hn : (P.rNClos).Normal := Subgroup.normalClosure_normal
    have hyx : y * x⁻¹ ∈ P.rNClos := by
      simpa [mul_assoc] using (P.rNClos.inv_mem h)
    have hc : x⁻¹ * (y * x⁻¹) * x ∈ P.rNClos := by
      simpa using hn.conj_mem (y * x⁻¹) hyx x⁻¹
    simpa [mul_assoc] using hc

@[simp] theorem relator_closure_free (α : Type u) :
    (free α).rNClos = ⊥ := by
  change Subgroup.normalClosure (∅ : Set (FreeGroup α)) = ⊥
  exact Subgroup.normalClosure_empty

/-- The quotient map for a no-relator presentation is injective. -/
theorem quotient_free_injective (α : Type u) :
    Function.Injective (free α).quotientMap := by
  apply (MonoidHom.ker_eq_bot_iff (free α).quotientMap).mp
  rw [ker_quotientMap, relator_closure_free]

/-- The explicit free-presentation equivalence is a left inverse to the quotient map. -/
@[simp] theorem free_group_quotient (α : Type u) (w : FreeGroup α) :
    freeGroupEquiv α ((free α).quotientMap w) = w := by
  have h : (freeGroupEquiv α).toMonoidHom.comp ((free α).quotientMap) =
      MonoidHom.id (FreeGroup α) := by
    apply FreeGroup.ext_hom
    intro x
    rfl
  exact DFunLike.congr_fun h w

/-- The quotient map is a right inverse to the explicit free-presentation equivalence. -/
@[simp] theorem free_group_equiv (α : Type u) (q : (free α).Group) :
    (free α).quotientMap (freeGroupEquiv α q) = q := by
  rcases (free α).quotientMap_surjective q with ⟨w, rfl⟩
  simp

/-- The canonical generators generate the presented group. -/
theorem closure_range_of :
    Subgroup.closure (Set.range P.of) = (⊤ : Subgroup P.Group) := by
  change Subgroup.closure (Set.range (PresentedGroup.of : P.Gen → PresentedGroup P.rels)) = ⊤
  exact PresentedGroup.closure_range_of P.rels
/-- Homomorphisms out of a presented group are determined by the images of the
canonical generators. -/
theorem groupHom_ext {K : Type v} [_root_.Group K] {f g : P.Group →* K}
    (h : ∀ x : P.Gen, f (P.of x) = g (P.of x)) : f = g := by
  apply MonoidHom.ext
  intro q
  rcases P.quotientMap_surjective q with ⟨w, rfl⟩
  induction w using FreeGroup.induction_on with
  | C1 => simp
  | of x => simpa using h x
  | inv_of x ih => simp [map_inv, h x]
  | mul x y hx hy => simp [hx, hy]

/-- Homomorphisms out of a presented group are determined by their values on
quotient representatives.  This is a convenient extensionality form when a proof
already works in the ambient free group. -/
theorem group_hom_ext {K : Type v} [_root_.Group K]
    {f g : P.Group →* K}
    (h : ∀ w : P.Free, f (P.quotientMap w) = g (P.quotientMap w)) : f = g := by
  apply MonoidHom.ext
  intro q
  rcases P.quotientMap_surjective q with ⟨w, rfl⟩
  exact h w

/-- Iff form of representative-level extensionality for homomorphisms out of a
presented group. -/
theorem group_hom {K : Type v} [_root_.Group K]
    {f g : P.Group →* K} :
    f = g ↔ ∀ w : P.Free, f (P.quotientMap w) = g (P.quotientMap w) := by
  constructor
  · intro h w
    rw [h]
  · exact P.group_hom_ext

/-- Iff form of generator-level extensionality for homomorphisms out of a presented
 group. -/
theorem eq_iff_of {K : Type v} [_root_.Group K]
    {f g : P.Group →* K} :
    f = g ↔ ∀ x : P.Gen, f (P.of x) = g (P.of x) := by
  constructor
  · intro h x
    rw [h]
  · exact P.groupHom_ext

/-- Multiplicative equivalences out of a presented group are determined by the
images of the canonical generators. -/
theorem groupEquiv_ext {Q : Type v} [_root_.Group Q] {e₁ e₂ : P.Group ≃* Q}
    (h : ∀ x : P.Gen, e₁ (P.of x) = e₂ (P.of x)) : e₁ = e₂ := by
  apply MulEquiv.ext
  intro q
  have hh : e₁.toMonoidHom = e₂.toMonoidHom := P.groupHom_ext h
  exact DFunLike.congr_fun hh q

/-- Multiplicative equivalences out of a presented group are determined by their
values on quotient representatives. -/
theorem group_ext_quotient {Q : Type v} [_root_.Group Q]
    {e₁ e₂ : P.Group ≃* Q}
    (h : ∀ w : P.Free, e₁ (P.quotientMap w) = e₂ (P.quotientMap w)) : e₁ = e₂ := by
  apply MulEquiv.ext
  intro q
  rcases P.quotientMap_surjective q with ⟨w, rfl⟩
  exact h w

/-- Iff form of representative-level extensionality for equivalences out of a
presented group. -/
theorem group_equiv_quotient {Q : Type v} [_root_.Group Q]
    {e₁ e₂ : P.Group ≃* Q} :
    e₁ = e₂ ↔ ∀ w : P.Free, e₁ (P.quotientMap w) = e₂ (P.quotientMap w) := by
  constructor
  · intro h w
    rw [h]
  · exact P.group_ext_quotient

/-- Iff form of generator-level extensionality for equivalences out of a presented
 group. -/
theorem group_equiv {Q : Type v} [_root_.Group Q]
    {e₁ e₂ : P.Group ≃* Q} :
    e₁ = e₂ ↔ ∀ x : P.Gen, e₁ (P.of x) = e₂ (P.of x) := by
  constructor
  · intro h x
    rw [h]
  · exact P.groupEquiv_ext

/-- Equivalences are equal if their inverse functions agree everywhere.  This
orientation is often more convenient for quotient equivalences constructed by
surjectivity. -/
theorem equiv_ext_symm {Q : Type v} [_root_.Group Q] {e₁ e₂ : P.Group ≃* Q}
    (h : ∀ y : Q, e₁.symm y = e₂.symm y) : e₁ = e₂ := by
  apply MulEquiv.ext
  intro x
  have hy := h (e₂ x)
  -- Applying `e₁` turns equality of inverse values into equality of forward values.
  simpa using (congrArg (fun z : P.Group => e₁ z) hy).symm

/-- Inverse-orientation extensionality using quotient representatives in the target
presentation. -/
theorem group_ext_symm (Q : Presentation.{v})
    {e₁ e₂ : P.Group ≃* Q.Group}
    (h : ∀ w : Q.Free, e₁.symm (Q.quotientMap w) = e₂.symm (Q.quotientMap w)) :
    e₁ = e₂ := by
  apply P.equiv_ext_symm
  intro y
  rcases Q.quotientMap_surjective y with ⟨w, rfl⟩
  exact h w


/-- Universal property wrapper: a generator map satisfying all relators extends to
a homomorphism out of the presented group. -/
noncomputable def lift {K : Type v} [_root_.Group K] (f : P.Gen → K)
    (h : ∀ r ∈ P.rels, FreeGroup.lift f r = 1) : P.Group →* K :=
  PresentedGroup.toGroup (rels := P.rels) h

@[simp] theorem lift_of {K : Type v} [_root_.Group K] (f : P.Gen → K)
    (h : ∀ r ∈ P.rels, FreeGroup.lift f r = 1) (x : P.Gen) :
    P.lift f h (P.of x) = f x := by
  exact PresentedGroup.toGroup.of h

/-- The lifted homomorphism agrees with the free-group lift on quotient representatives. -/
@[simp] theorem lift_quotientMap {K : Type v} [_root_.Group K] (f : P.Gen → K)
    (h : ∀ r ∈ P.rels, FreeGroup.lift f r = 1) (w : P.Free) :
    P.lift f h (P.quotientMap w) = FreeGroup.lift f w := by
  rfl

/-- Uniqueness in the universal property of a presentation. -/
theorem lift_unique {K : Type v} [_root_.Group K] (f : P.Gen → K)
    (h : ∀ r ∈ P.rels, FreeGroup.lift f r = 1) (g : P.Group →* K)
    (hg : ∀ x : P.Gen, g (P.of x) = f x) : g = P.lift f h := by
  apply groupHom_ext P
  intro x
  simp [lift_of, hg]

/-- The lift of the canonical generator map is the identity homomorphism. -/
@[simp] theorem lift_of_self {h : ∀ r ∈ P.rels, FreeGroup.lift P.of r = 1} :
    P.lift P.of h = MonoidHom.id P.Group := by
  apply groupHom_ext P
  intro x
  simp [lift_of]

/-- Postcomposing a lifted map is again the lift of the postcomposed generator map.
The relator proof for the postcomposition is supplied explicitly, which keeps this
lemma convenient in both computable and noncomputable contexts. -/
@[simp] theorem comp_lift {K : Type v} {L : Type*} [_root_.Group K] [_root_.Group L]
    (f : P.Gen → K) (h : ∀ r ∈ P.rels, FreeGroup.lift f r = 1)
    (k : K →* L)
    (h' : ∀ r ∈ P.rels, FreeGroup.lift (fun x => k (f x)) r = 1) :
    k.comp (P.lift f h) = P.lift (fun x => k (f x)) h' := by
  apply groupHom_ext P
  intro x
  simp [lift_of]



end Presentation

namespace Presentation

/-!
## Morphisms of presentations

For later filtered-presentation constructions it is useful to have a very small
concrete notion of a map of presentations: a function on generators whose induced
free-group map sends each relator into the normal closure of the target relators.
This section deliberately avoids setting up a category; it only packages the
induced homomorphism on presented groups and the identity/composition calculus.
-/

variable {P Q R : Presentation.{u}}

/-- A map of presentations, given by a generator map respecting relators up to
normal closure. -/
structure Hom (P Q : Presentation.{u}) where
  gen : P.Gen → Q.Gen
  map_rel : ∀ ⦃r : P.Free⦄, r ∈ P.rels →
    FreeGroup.map gen r ∈ Q.rNClos

namespace Hom

/-- Two presentation morphisms are equal when they agree on generators. -/
@[ext] theorem ext {f g : Hom P Q} (h : ∀ x, f.gen x = g.gen x) : f = g := by
  cases f with
  | mk fgen fmap =>
  cases g with
  | mk ggen gmap =>
  have hg : fgen = ggen := funext h
  subst hg
  rfl

/-- The universal presentation morphism out of a no-relator presentation, induced by
an arbitrary function on generators. -/
def fromFree {α : Type u} (f : α → Q.Gen) : Hom (free α) Q where
  gen := f
  map_rel := by
    intro r hr
    exfalso
    simpa [free] using hr

@[simp] theorem fromFree_gen {α : Type u} (f : α → Q.Gen) (x : α) :
    (fromFree (Q := Q) f).gen x = f x := rfl


/-- Morphisms out of a free presentation are uniquely determined by their generator map. -/
theorem fromFree_unique {α : Type u} (f : Hom (free α) Q) :
    fromFree (Q := Q) f.gen = f := by
  ext x
  rfl



/-- Constructor using the equivalent condition that mapped relators are trivial
in the target presented group. -/
def relatorsOne (gen : P.Gen → Q.Gen)
    (h : ∀ ⦃r : P.Free⦄, r ∈ P.rels →
      Q.quotientMap (FreeGroup.map gen r) = 1) : Hom P Q where
  gen := gen
  map_rel := by
    intro r hr
    exact Q.quotient_one.mp (h hr)

/-- The induced homomorphism on free groups. -/
def freeMap (f : Hom P Q) : P.Free →* Q.Free :=
  FreeGroup.map f.gen

@[simp] theorem freeMap_of (f : Hom P Q) (x : P.Gen) :
    f.freeMap (FreeGroup.of x) = FreeGroup.of (f.gen x) := rfl

@[simp] theorem from_map_of {α : Type u} (f : α → Q.Gen) (x : α) :
    (fromFree (Q := Q) f).freeMap (FreeGroup.of x) =
      FreeGroup.of (f x) := rfl

/-- A presentation morphism sends the whole relator normal closure into the target
relator normal closure. -/
theorem map_normalClosure (f : Hom P Q) :
    P.rNClos ≤ (Q.rNClos).comap f.freeMap := by
  classical
  haveI : (Q.rNClos).Normal := Subgroup.normalClosure_normal
  apply Subgroup.normalClosure_le_normal
  intro r hr
  change f.freeMap r ∈ Q.rNClos
  exact f.map_rel hr

/-- Pointwise form of `map_normalClosure`. -/
theorem normal_closure (f : Hom P Q) {x : P.Free}
    (hx : x ∈ P.rNClos) :
    f.freeMap x ∈ Q.rNClos :=
  f.map_normalClosure hx

/-- The homomorphism of presented groups induced by a presentation morphism. -/
noncomputable def toGroupHom (f : Hom P Q) : P.Group →* Q.Group := by
  refine QuotientGroup.lift P.rNClos (Q.quotientMap.comp f.freeMap) ?_
  intro x hx
  change Q.quotientMap (f.freeMap x) = 1
  exact Q.quotient_one.mpr (f.normal_closure hx)

@[simp] theorem group_quotient (f : Hom P Q) (x : P.Free) :
    f.toGroupHom (P.quotientMap x) = Q.quotientMap (f.freeMap x) := by
  rfl

@[simp] theorem to_hom_of (f : Hom P Q) (x : P.Gen) :
    f.toGroupHom (P.of x) = Q.of (f.gen x) := by
  rfl

/-- Representative-level kernel criterion for the homomorphism induced by a presentation
morphism. -/
theorem group_hom_one (f : Hom P Q) {w : P.Free} :
    f.toGroupHom (P.quotientMap w) = 1 ↔
      f.freeMap w ∈ Q.rNClos := by
  rw [group_quotient]
  exact Q.quotient_one

/-- Equality of two induced images, expressed as a target relator consequence of the
left difference of free representatives. -/
theorem group_hom_quotient (f : Hom P Q) {x y : P.Free} :
    f.toGroupHom (P.quotientMap x) = f.toGroupHom (P.quotientMap y) ↔
      (f.freeMap x)⁻¹ * f.freeMap y ∈ Q.rNClos := by
  simp only [group_quotient]
  exact Q.eq_map_iff

/-- Equality criterion with the difference taken before applying the free map. -/
theorem free_inv_mul (f : Hom P Q) {x y : P.Free} :
    f.toGroupHom (P.quotientMap x) = f.toGroupHom (P.quotientMap y) ↔
      f.freeMap (x⁻¹ * y) ∈ Q.rNClos := by
  rw [group_hom_quotient]
  simp [map_mul]

/-- Right-difference version of the representative equality criterion. -/
theorem group_free_inv (f : Hom P Q) {x y : P.Free} :
    f.toGroupHom (P.quotientMap x) = f.toGroupHom (P.quotientMap y) ↔
      f.freeMap (x * y⁻¹) ∈ Q.rNClos := by
  simp only [group_quotient]
  rw [Q.quotient_mul_inv]
  simp [map_mul]



/-- Kernel membership for an arbitrary presented-group element, via a chosen free-word
representative. -/
theorem group_hom_rep (f : Hom P Q) {q : P.Group} :
    f.toGroupHom q = 1 ↔
      ∃ w : P.Free, P.quotientMap w = q ∧ f.freeMap w ∈ Q.rNClos := by
  constructor
  · intro h
    rcases P.quotientMap_surjective q with ⟨w, rfl⟩
    refine ⟨w, rfl, ?_⟩
    rw [← Q.quotient_one]
    simpa [group_quotient] using h
  · rintro ⟨w, rfl, hw⟩
    rw [group_quotient]
    exact Q.quotient_one.mpr hw

/-- If the induced free-group map is surjective, then so is the induced map on
presented groups. -/
theorem group_surjective_free (f : Hom P Q)
    (hf : Function.Surjective f.freeMap) :
    Function.Surjective f.toGroupHom := by
  intro y
  rcases Q.quotientMap_surjective y with ⟨qy, rfl⟩
  rcases hf qy with ⟨px, hpx⟩
  refine ⟨P.quotientMap px, ?_⟩
  simp [hpx]

/-- A surjective generator map induces a surjective free-group map. -/
theorem free_surjective_gen (f : Hom P Q)
    (hf : Function.Surjective f.gen) :
    Function.Surjective f.freeMap := by
  intro y
  induction y using FreeGroup.induction_on with
  | C1 =>
      exact ⟨1, by simp [freeMap]⟩
  | of y =>
      rcases hf y with ⟨x, rfl⟩
      exact ⟨FreeGroup.of x, rfl⟩
  | inv_of y ih =>
      rcases ih with ⟨x, hx⟩
      refine ⟨x⁻¹, ?_⟩
      change f.freeMap x⁻¹ = (FreeGroup.of y)⁻¹
      rw [map_inv, hx]
  | mul y z ihy ihz =>
      rcases ihy with ⟨x, hx⟩
      rcases ihz with ⟨w, hw⟩
      refine ⟨x * w, ?_⟩
      change f.freeMap (x * w) = y * z
      rw [map_mul, hx, hw]

/-- A surjective generator map induces a surjective homomorphism of presented
groups. -/
theorem group_surjective_gen (f : Hom P Q)
    (hf : Function.Surjective f.gen) :
    Function.Surjective f.toGroupHom :=
  f.group_surjective_free
    (f.free_surjective_gen hf)

/-- Kernel criterion for injectivity of the induced map on presented groups:
if every free word whose image is a target consequence of relators was already a
source consequence of relators, then the quotient map is injective. -/
theorem group_hom_comap (f : Hom P Q)
    (hker : (Q.rNClos).comap f.freeMap ≤ P.rNClos)
    {x : P.Group} (hx : f.toGroupHom x = 1) : x = 1 := by
  rcases P.quotientMap_surjective x with ⟨w, rfl⟩
  rw [group_quotient] at hx
  have hwQ : f.freeMap w ∈ Q.rNClos :=
    Q.quotient_one.mp hx
  have hwP : w ∈ P.rNClos := hker hwQ
  exact P.quotient_one.mpr hwP

/-- Injectivity criterion for a presentation morphism, stated on normal closures
in the free groups. -/
theorem hom_injective_comap (f : Hom P Q)
    (hker : (Q.rNClos).comap f.freeMap ≤ P.rNClos) :
    Function.Injective f.toGroupHom := by
  intro a b hab
  apply eq_of_mul_inv_eq_one
  apply f.group_hom_comap hker
  rw [map_mul, map_inv, hab, mul_inv_cancel]

/-- Exact kernel criterion for injectivity of an induced presentation morphism. -/
theorem group_injective_comap (f : Hom P Q) :
    Function.Injective f.toGroupHom ↔
      (Q.rNClos).comap f.freeMap ≤ P.rNClos := by
  constructor
  · intro hinj w hw
    have hq : f.toGroupHom (P.quotientMap w) = 1 := by
      rw [group_quotient]
      exact Q.quotient_one.mpr hw
    have hpre : P.quotientMap w = 1 := by
      apply hinj
      simpa using hq
    exact P.quotient_one.mp hpre
  · exact f.hom_injective_comap

/-- Kernel-as-bottom version of the normal-closure injectivity criterion. -/
theorem ker_bot_comap (f : Hom P Q) :
    MonoidHom.ker f.toGroupHom = ⊥ ↔
      (Q.rNClos).comap f.freeMap ≤ P.rNClos := by
  rw [MonoidHom.ker_eq_bot_iff, f.group_injective_comap]

/-- Pointwise trivial-kernel form of the normal-closure injectivity criterion. -/
@[simp] theorem group_one_comap (f : Hom P Q)
    (hker : (Q.rNClos).comap f.freeMap ≤ P.rNClos)
    (x : P.Group) :
    f.toGroupHom x = 1 ↔ x = 1 := by
  constructor
  · exact f.group_hom_comap hker
  · intro hx
    simp [hx]

/-- Bijectivity criterion combining the normal-closure injectivity condition with
surjectivity of the free map. -/
theorem bijective_comap_surjective (f : Hom P Q)
    (hker : (Q.rNClos).comap f.freeMap ≤ P.rNClos)
    (hsurj : Function.Surjective f.freeMap) :
    Function.Bijective f.toGroupHom :=
  ⟨f.hom_injective_comap hker,
    f.group_surjective_free hsurj⟩

/-- Bijectivity criterion using a surjective generator map instead of a free-map
surjectivity hypothesis. -/
theorem bijective_comap_gen (f : Hom P Q)
    (hker : (Q.rNClos).comap f.freeMap ≤ P.rNClos)
    (hgen : Function.Surjective f.gen) :
    Function.Bijective f.toGroupHom :=
  f.bijective_comap_surjective hker
    (f.free_surjective_gen hgen)


/-- Identity morphism of a presentation. -/
protected def id (P : Presentation.{u}) : Hom P P where
  gen := id
  map_rel := by
    intro r hr
    simpa [freeMap] using (Subgroup.subset_normalClosure hr)

@[simp] theorem id_gen (x : P.Gen) : (Hom.id P).gen x = x := rfl

@[simp] theorem fromFree_id {α : Type u} :
    fromFree (Q := free α) (fun x : α => x) = Hom.id (free α) := by
  ext x
  rfl

@[simp] theorem id_freeMap (x : P.Free) : (Hom.id P).freeMap x = x := by
  exact FreeGroup.map.id x

@[simp] theorem id_group_hom :
    (Hom.id P).toGroupHom = MonoidHom.id P.Group := by
  apply MonoidHom.ext
  intro q
  rcases P.quotientMap_surjective q with ⟨x, rfl⟩
  simp [group_quotient]

/-- Composition of presentation morphisms.  The order is categorical: `g.comp f`
first applies `f` and then `g`. -/
def comp (g : Hom Q R) (f : Hom P Q) : Hom P R where
  gen := g.gen ∘ f.gen
  map_rel := by
    intro r hr
    have hf : f.freeMap r ∈ Q.rNClos := f.map_rel hr
    have hg : g.freeMap (f.freeMap r) ∈ R.rNClos :=
      g.normal_closure hf
    simpa [freeMap, FreeGroup.map.comp, Function.comp_def] using hg

@[simp] theorem comp_gen (g : Hom Q R) (f : Hom P Q) (x : P.Gen) :
    (g.comp f).gen x = g.gen (f.gen x) := rfl

/-- Composition out of a free presentation is again the free morphism induced by
composing generator maps. -/
@[simp] theorem comp_fromFree {α : Type u} (g : Hom Q R) (f : α → Q.Gen) :
    g.comp (fromFree (Q := Q) f) =
      fromFree (Q := R) (fun x : α => g.gen (f x)) := by
  ext x
  rfl

@[simp] theorem comp_freeMap (g : Hom Q R) (f : Hom P Q) (x : P.Free) :
    (g.comp f).freeMap x = g.freeMap (f.freeMap x) := by
  change FreeGroup.map (g.gen ∘ f.gen) x =
    FreeGroup.map g.gen (FreeGroup.map f.gen x)
  rw [FreeGroup.map.comp]

@[simp] theorem comp_group_hom (g : Hom Q R) (f : Hom P Q) :
    (g.comp f).toGroupHom = g.toGroupHom.comp f.toGroupHom := by
  apply MonoidHom.ext
  intro q
  rcases P.quotientMap_surjective q with ⟨x, rfl⟩
  simp [group_quotient]

/-- Composition of presentation morphisms is associative. -/
@[simp] theorem comp_assoc {S : Presentation.{u}} (h : Hom R S) (g : Hom Q R)
    (f : Hom P Q) : h.comp (g.comp f) = (h.comp g).comp f := by
  ext x
  rfl

@[simp] theorem comp_id (f : Hom P Q) : f.comp (Hom.id P) = f := by
  cases f
  rfl

@[simp] theorem id_comp (f : Hom P Q) : (Hom.id Q).comp f = f := by
  cases f
  rfl

/-- Mutually inverse presentation morphisms induce an isomorphism of the presented
groups.  This avoids committing to a category of presentations while still
providing the usual transport tool. -/
noncomputable def groupEquivInverse (f : Hom P Q) (g : Hom Q P)
    (hleft : g.comp f = Hom.id P) (hright : f.comp g = Hom.id Q) :
    P.Group ≃* Q.Group where
  toFun := f.toGroupHom
  invFun := g.toGroupHom
  left_inv := by
    intro x
    have hcomp : g.toGroupHom.comp f.toGroupHom = MonoidHom.id P.Group := by
      rw [← comp_group_hom, hleft, id_group_hom]
    change (g.toGroupHom.comp f.toGroupHom) x = x
    rw [hcomp]
    rfl
  right_inv := by
    intro y
    have hcomp : f.toGroupHom.comp g.toGroupHom = MonoidHom.id Q.Group := by
      rw [← comp_group_hom, hright, id_group_hom]
    change (f.toGroupHom.comp g.toGroupHom) y = y
    rw [hcomp]
    rfl
  map_mul' := f.toGroupHom.map_mul

@[simp] theorem group_inverse (f : Hom P Q) (g : Hom Q P)
    (hleft : g.comp f = Hom.id P) (hright : f.comp g = Hom.id Q)
    (x : P.Group) :
    groupEquivInverse f g hleft hright x = f.toGroupHom x := rfl

@[simp] theorem group_equiv_inverse (f : Hom P Q) (g : Hom Q P)
    (hleft : g.comp f = Hom.id P) (hright : f.comp g = Hom.id Q)
    (y : Q.Group) :
    (groupEquivInverse f g hleft hright).symm y = g.toGroupHom y := rfl

@[simp] theorem group_monoid_hom (f : Hom P Q) (g : Hom Q P)
    (hleft : g.comp f = Hom.id P) (hright : f.comp g = Hom.id Q) :
    (groupEquivInverse f g hleft hright).toMonoidHom = f.toGroupHom := rfl

@[simp] theorem inverse_symm (f : Hom P Q) (g : Hom Q P)
    (hleft : g.comp f = Hom.id P) (hright : f.comp g = Hom.id Q) :
    (groupEquivInverse f g hleft hright).symm =
      groupEquivInverse g f hright hleft := by
  ext y
  rfl

@[simp] theorem inverse_symm_hom
    (f : Hom P Q) (g : Hom Q P)
    (hleft : g.comp f = Hom.id P) (hright : f.comp g = Hom.id Q)
    (x : P.Group) :
    (groupEquivInverse f g hleft hright).symm (f.toGroupHom x) = x := by
  exact (groupEquivInverse f g hleft hright).left_inv x

@[simp] theorem group_inverse_symm
    (f : Hom P Q) (g : Hom Q P)
    (hleft : g.comp f = Hom.id P) (hright : f.comp g = Hom.id Q)
    (y : Q.Group) :
    f.toGroupHom ((groupEquivInverse f g hleft hright).symm y) = y := by
  change groupEquivInverse f g hleft hright
      ((groupEquivInverse f g hleft hright).symm y) = y
  exact (groupEquivInverse f g hleft hright).right_inv y

@[simp] theorem group_equiv_symm
    (f : Hom P Q) (g : Hom Q P)
    (hleft : g.comp f = Hom.id P) (hright : f.comp g = Hom.id Q)
    (y : Q.Group) (x : P.Group) :
    (groupEquivInverse f g hleft hright).symm y = x ↔
      y = f.toGroupHom x := by
  rw [MulEquiv.symm_apply_eq]
  rfl

@[simp] theorem equiv_inverse_symm
    (f : Hom P Q) (g : Hom Q P)
    (hleft : g.comp f = Hom.id P) (hright : f.comp g = Hom.id Q)
    (x : P.Group) (y : Q.Group) :
    x = (groupEquivInverse f g hleft hright).symm y ↔
      f.toGroupHom x = y := by
  rw [eq_comm, group_equiv_symm, eq_comm]

/-- A bijective presentation morphism induces a multiplicative equivalence of
the presented groups.  This is often more convenient than explicitly building
an inverse morphism (for instance after quotienting by extra relators). -/
noncomputable def groupEquivBijective (f : Hom P Q)
    (hf : Function.Bijective f.toGroupHom) : P.Group ≃* Q.Group :=
  MulEquiv.ofBijective f.toGroupHom hf

@[simp] theorem group_bijective (f : Hom P Q)
    (hf : Function.Bijective f.toGroupHom) (x : P.Group) :
    groupEquivBijective f hf x = f.toGroupHom x := rfl

@[simp] theorem bijective_monoid_hom (f : Hom P Q)
    (hf : Function.Bijective f.toGroupHom) :
    (groupEquivBijective f hf).toMonoidHom = f.toGroupHom := rfl

/-- The inverse of the equivalence attached to a bijective morphism cancels its map. -/
@[simp] theorem bijective_symm_hom (f : Hom P Q)
    (hf : Function.Bijective f.toGroupHom) (x : P.Group) :
    (groupEquivBijective f hf).symm (f.toGroupHom x) = x := by
  exact (groupEquivBijective f hf).left_inv x

/-- Applying a bijective morphism after the chosen inverse equivalence cancels. -/
@[simp] theorem group_bijective_symm (f : Hom P Q)
    (hf : Function.Bijective f.toGroupHom) (y : Q.Group) :
    f.toGroupHom ((groupEquivBijective f hf).symm y) = y := by
  change groupEquivBijective f hf ((groupEquivBijective f hf).symm y) = y
  exact (groupEquivBijective f hf).right_inv y

/-- Characterize the inverse of the equivalence attached to a bijective
presentation morphism.  This avoids unfolding the choice of inverse made by
`MulEquiv.ofBijective` in downstream quotient arguments. -/
@[simp] theorem group_equiv_bijective (f : Hom P Q)
    (hf : Function.Bijective f.toGroupHom) (y : Q.Group) (x : P.Group) :
    (groupEquivBijective f hf).symm y = x ↔ y = f.toGroupHom x := by
  rw [MulEquiv.symm_apply_eq]
  rfl

/-- Alternate orientation of `group_equiv_bijective`. -/
@[simp] theorem equiv_bijective_symm (f : Hom P Q)
    (hf : Function.Bijective f.toGroupHom) (x : P.Group) (y : Q.Group) :
    x = (groupEquivBijective f hf).symm y ↔ f.toGroupHom x = y := by
  rw [eq_comm, group_equiv_bijective, eq_comm]

/-- The kernel of a bijective presentation morphism is trivial. -/
theorem ker_bot_bijective (f : Hom P Q)
    (hf : Function.Bijective f.toGroupHom) :
    MonoidHom.ker f.toGroupHom = ⊥ :=
  (MonoidHom.ker_eq_bot_iff f.toGroupHom).2 hf.1

/-- Pointwise trivial-kernel form for a bijective presentation morphism. -/
@[simp] theorem group_hom_bijective (f : Hom P Q)
    (hf : Function.Bijective f.toGroupHom) (x : P.Group) :
    f.toGroupHom x = 1 ↔ x = 1 := by
  constructor
  · intro hx
    exact hf.1 (by simpa using hx)
  · intro hx
    simp [hx]

/-- Equivalence induced by a presentation morphism satisfying the normal-closure
injectivity criterion and surjectivity on generators. -/
noncomputable def comapGenSurjective (f : Hom P Q)
    (hker : (Q.rNClos).comap f.freeMap ≤ P.rNClos)
    (hgen : Function.Surjective f.gen) : P.Group ≃* Q.Group :=
  groupEquivBijective f
    (f.bijective_comap_gen hker hgen)

@[simp] theorem group_gen_surjective (f : Hom P Q)
    (hker : (Q.rNClos).comap f.freeMap ≤ P.rNClos)
    (hgen : Function.Surjective f.gen) (x : P.Group) :
    comapGenSurjective f hker hgen x = f.toGroupHom x := rfl

@[simp] theorem comap_gen_monoid (f : Hom P Q)
    (hker : (Q.rNClos).comap f.freeMap ≤ P.rNClos)
    (hgen : Function.Surjective f.gen) :
    (comapGenSurjective f hker hgen).toMonoidHom = f.toGroupHom := rfl

/-- Inverse-characterization for the generator-surjective equivalence criterion. -/
@[simp] theorem group_comap_gen
    (f : Hom P Q)
    (hker : (Q.rNClos).comap f.freeMap ≤ P.rNClos)
    (hgen : Function.Surjective f.gen) (y : Q.Group) (x : P.Group) :
    (comapGenSurjective f hker hgen).symm y = x ↔
      y = f.toGroupHom x := by
  rw [comapGenSurjective, group_equiv_bijective]

@[simp] theorem comap_gen_surjective
    (f : Hom P Q)
    (hker : (Q.rNClos).comap f.freeMap ≤ P.rNClos)
    (hgen : Function.Surjective f.gen) (x : P.Group) :
    (comapGenSurjective f hker hgen).symm
        (f.toGroupHom x) = x := by
  rw [comapGenSurjective]
  exact bijective_symm_hom f _ x

@[simp] theorem comap_gen_symm
    (f : Hom P Q)
    (hker : (Q.rNClos).comap f.freeMap ≤ P.rNClos)
    (hgen : Function.Surjective f.gen) (y : Q.Group) :
    f.toGroupHom ((comapGenSurjective f hker hgen).symm y) = y := by
  rw [comapGenSurjective]
  exact group_bijective_symm f _ y

@[simp] theorem gen_surjective_symm
    (f : Hom P Q)
    (hker : (Q.rNClos).comap f.freeMap ≤ P.rNClos)
    (hgen : Function.Surjective f.gen) (x : P.Group) (y : Q.Group) :
    x = (comapGenSurjective f hker hgen).symm y ↔
      f.toGroupHom x = y := by
  rw [eq_comm, group_comap_gen, eq_comm]

/-- The map induced between no-relator presentations agrees, under the explicit
free-group equivalences, with the usual map of free groups. -/
@[simp] theorem free_hom_equiv {α β : Type u} (f : α → β)
    (q : (free α).Group) :
    freeGroupEquiv β ((fromFree (Q := free β) f).toGroupHom q) =
      FreeGroup.map f (freeGroupEquiv α q) := by
  rcases (free α).quotientMap_surjective q with ⟨w, rfl⟩
  simp [group_quotient, freeMap, free_group_quotient, fromFree]
  rfl

/-- An equivalence of generator types induces an equivalence of the corresponding
no-relator presented groups. -/
noncomputable def freePresentationEquiv {α β : Type u} (e : α ≃ β) :
    (free α).Group ≃* (free β).Group :=
  groupEquivInverse (fromFree (Q := free β) e)
    (fromFree (Q := free α) e.symm) (by ext x; simp) (by ext x; simp)

@[simp] theorem presentation_equiv {α β : Type u} (e : α ≃ β) (x : α) :
    freePresentationEquiv e ((free α).of x) = (free β).of (e x) := rfl

@[simp] theorem presentation_equiv_quotient {α β : Type u}
    (e : α ≃ β) (w : (free α).Free) :
    freePresentationEquiv e ((free α).quotientMap w) =
      (free β).quotientMap (FreeGroup.map e w) := by
  change (fromFree (Q := free β) e).toGroupHom ((free α).quotientMap w) = _
  rw [group_quotient]
  rfl

/-- Under the explicit identifications with free groups, `freePresentationEquiv` is just
`FreeGroup.map` of the generator equivalence. -/
@[simp] theorem free_group_presentation {α β : Type u} (e : α ≃ β)
    (q : (free α).Group) :
    freeGroupEquiv β (freePresentationEquiv e q) =
      FreeGroup.map e (freeGroupEquiv α q) := by
  change freeGroupEquiv β ((fromFree (Q := free β) e).toGroupHom q) = _
  exact free_hom_equiv e q


/-- The identity equivalence of generators induces the identity on the free presentation. -/
@[simp] theorem free_presentation_refl (α : Type u) :
    freePresentationEquiv (Equiv.refl α) = MulEquiv.refl ((free α).Group) := by
  apply MulEquiv.ext
  intro q
  apply (freeGroupEquiv α).injective
  simp [free_group_presentation]

/-- Equivalences of generator types compose functorially on no-relator presentations. -/
@[simp] theorem free_presentation_trans {α β γ : Type u} (e : α ≃ β) (f : β ≃ γ) :
    freePresentationEquiv (e.trans f) =
      (freePresentationEquiv e).trans (freePresentationEquiv f) := by
  apply MulEquiv.ext
  intro q
  apply (freeGroupEquiv γ).injective
  simp [free_group_presentation, FreeGroup.map.comp]


/-- The inverse equivalence on a no-relator presentation is induced by the inverse
bijection of generators. -/
@[simp] theorem free_presentation {α β : Type u} (e : α ≃ β) :
    (freePresentationEquiv e).symm = freePresentationEquiv e.symm := by
  apply MulEquiv.ext
  intro q
  apply (freePresentationEquiv e).injective
  have hcomp : (freePresentationEquiv e.symm).trans (freePresentationEquiv e) =
      MulEquiv.refl ((free β).Group) := by
    calc
      (freePresentationEquiv e.symm).trans (freePresentationEquiv e) =
          freePresentationEquiv (e.symm.trans e) := by
            rw [← free_presentation_trans]
      _ = MulEquiv.refl ((free β).Group) := by
            simp
  have := congrArg (fun (F : (free β).Group ≃* (free β).Group) => F q) hcomp
  simpa using this.symm

@[simp] theorem presentation_symm {α β : Type u} (e : α ≃ β) (y : β) :
    (freePresentationEquiv e).symm ((free β).of y) = (free α).of (e.symm y) := by
  rw [free_presentation, presentation_equiv]

@[simp] theorem free_presentation_quotient {α β : Type u}
    (e : α ≃ β) (w : (free β).Free) :
    (freePresentationEquiv e).symm ((free β).quotientMap w) =
      (free α).quotientMap (FreeGroup.map e.symm w) := by
  rw [free_presentation, presentation_equiv_quotient]

@[simp] theorem presentation_equiv_symm {α β : Type u}
    (e : α ≃ β) (x : (free α).Group) :
    (freePresentationEquiv e).symm (freePresentationEquiv e x) = x :=
  (freePresentationEquiv e).left_inv x

@[simp] theorem free_presentation_symm {α β : Type u}
    (e : α ≃ β) (y : (free β).Group) :
    freePresentationEquiv e ((freePresentationEquiv e).symm y) = y :=
  (freePresentationEquiv e).right_inv y

@[simp] theorem free_equiv_symm {α β : Type u}
    (e : α ≃ β) (y : (free β).Group) (x : (free α).Group) :
    (freePresentationEquiv e).symm y = x ↔ y = freePresentationEquiv e x := by
  rw [MulEquiv.symm_apply_eq]

@[simp] theorem free_presentation_equiv {α β : Type u}
    (e : α ≃ β) (x : (free α).Group) (y : (free β).Group) :
    x = (freePresentationEquiv e).symm y ↔ freePresentationEquiv e x = y := by
  rw [eq_comm, free_equiv_symm, eq_comm]



end Hom

/-- Replace the relator set of a presentation while keeping its generator type.
This is a convenient way to talk about finite/active subpresentations of a fixed
ambient free group. -/
def withRelators (P : Presentation.{u}) (S : Set P.Free) : Presentation.{u} where
  Gen := P.Gen
  rels := S

@[simp] theorem withRelators_free (P : Presentation.{u}) (S : Set P.Free) :
    (P.withRelators S).Free = P.Free := rfl

@[simp] theorem withRelators_rels (P : Presentation.{u}) (S : Set P.Free) :
    (P.withRelators S).rels = S := rfl

/-- Replacing a union of fixed relator sets in the opposite order gives the same presentation. -/
theorem with_union_comm (P : Presentation.{u}) (S T : Set P.Free) :
    P.withRelators (S ∪ T) = P.withRelators (T ∪ S) := by
  cases P with
  | mk Gen rels =>
    apply congrArg (fun R : Set (FreeGroup Gen) =>
      ({ Gen := Gen, rels := R } : Presentation))
    exact Set.union_comm S T

/-- Replacing relators by the existing relator set is definitionally the same presentation. -/
@[simp] theorem withRelators_self (P : Presentation.{u}) : P.withRelators P.rels = P := by
  cases P
  rfl

/-- Monotonicity of relator normal closures for fixed generators. -/
theorem relators_normal_mono (P : Presentation.{u}) {S T : Set P.Free}
    (hST : S ⊆ T) :
    (P.withRelators S).rNClos ≤
      (P.withRelators T).rNClos := by
  change Subgroup.normalClosure S ≤ Subgroup.normalClosure T
  exact Subgroup.normalClosure_mono hST

/-- Pointwise form of `relators_normal_mono`. -/
theorem relators_closure_subset (P : Presentation.{u}) {S T : Set P.Free}
    (hST : S ⊆ T) {w : P.Free}
    (hw : w ∈ (P.withRelators S).rNClos) :
    w ∈ (P.withRelators T).rNClos :=
  relators_normal_mono P hST hw

/-- A map between fixed-generator presentations from an inclusion of relator normal closures. -/
def relatorsHomClosure (P : Presentation.{u}) {S T : Set P.Free}
    (h : (P.withRelators S).rNClos ≤
      (P.withRelators T).rNClos) :
    Hom (P.withRelators S) (P.withRelators T) where
  gen := id
  map_rel := by
    intro r hr
    change FreeGroup.map id r ∈ (P.withRelators T).rNClos
    rw [FreeGroup.map.id]
    exact h (Subgroup.subset_normalClosure hr)

@[simp] theorem relators_closure_gen (P : Presentation.{u})
    {S T : Set P.Free}
    (h : (P.withRelators S).rNClos ≤
      (P.withRelators T).rNClos) (x : P.Gen) :
    (relatorsHomClosure P h).gen x = x := rfl

@[simp] theorem relators_closure_group
    (P : Presentation.{u}) {S T : Set P.Free}
    (h : (P.withRelators S).rNClos ≤
      (P.withRelators T).rNClos) (x : P.Gen) :
    (relatorsHomClosure P h).toGroupHom ((P.withRelators S).of x) =
      (P.withRelators T).of x := rfl

@[simp] theorem relators_normal_closure
    (P : Presentation.{u}) {S T : Set P.Free}
    (h : (P.withRelators S).rNClos ≤
      (P.withRelators T).rNClos) (w : P.Free) :
    (relatorsHomClosure P h).toGroupHom
        ((P.withRelators S).quotientMap w) =
      (P.withRelators T).quotientMap w := by
  rw [Hom.group_quotient]
  change (P.withRelators T).quotientMap (FreeGroup.map id w) = _
  rw [FreeGroup.map.id]

@[simp] theorem relators_normal_refl (P : Presentation.{u})
    (S : Set P.Free) :
    relatorsHomClosure P
        (show (P.withRelators S).rNClos ≤
          (P.withRelators S).rNClos from le_rfl) =
      Hom.id (P.withRelators S) := by
  ext x
  rfl

theorem relators_closure_comp (P : Presentation.{u})
    {S T U : Set P.Free}
    (hST : (P.withRelators S).rNClos ≤
      (P.withRelators T).rNClos)
    (hTU : (P.withRelators T).rNClos ≤
      (P.withRelators U).rNClos) :
    (relatorsHomClosure (P := P) (S := T) (T := U) hTU).comp
        (relatorsHomClosure (P := P) (S := S) (T := T) hST) =
      relatorsHomClosure (P := P) (S := S) (T := U)
        (fun _ hw => hTU (hST hw)) := by
  ext x
  rfl

/-- Equal relator normal closures give canonically isomorphic presented groups. -/
noncomputable def relatorsNormalClosure (P : Presentation.{u})
    {S T : Set P.Free}
    (h : (P.withRelators S).rNClos =
      (P.withRelators T).rNClos) :
    (P.withRelators S).Group ≃* (P.withRelators T).Group :=
  Hom.groupEquivInverse
    (relatorsHomClosure P (by rw [h]))
    (relatorsHomClosure P (by rw [h]))
    (by ext x; rfl) (by ext x; rfl)

@[simp] theorem relators_monoid_hom
    (P : Presentation.{u}) {S T : Set P.Free}
    (h : (P.withRelators S).rNClos =
      (P.withRelators T).rNClos) :
    (relatorsNormalClosure P h).toMonoidHom =
      (relatorsHomClosure P (by rw [h])).toGroupHom := rfl

@[simp] theorem relators_equiv_closure (P : Presentation.{u})
    {S T : Set P.Free}
    (h : (P.withRelators S).rNClos =
      (P.withRelators T).rNClos) (x : P.Gen) :
    relatorsNormalClosure P h ((P.withRelators S).of x) =
      (P.withRelators T).of x := rfl

@[simp] theorem relators_closure_quotient (P : Presentation.{u})
    {S T : Set P.Free}
    (h : (P.withRelators S).rNClos =
      (P.withRelators T).rNClos) (w : P.Free) :
    relatorsNormalClosure P h ((P.withRelators S).quotientMap w) =
      (P.withRelators T).quotientMap w := by
  change (relatorsHomClosure P (by rw [h])).toGroupHom
      ((P.withRelators S).quotientMap w) = (P.withRelators T).quotientMap w
  rw [Hom.group_quotient]
  change (P.withRelators T).quotientMap (FreeGroup.map id w) = _
  rw [FreeGroup.map.id]

@[simp] theorem relators_equiv_normal (P : Presentation.{u})
    {S T : Set P.Free}
    (h : (P.withRelators S).rNClos =
      (P.withRelators T).rNClos) :
    (relatorsNormalClosure P h).symm =
      relatorsNormalClosure P h.symm := by
  apply MulEquiv.ext
  intro q
  rcases (P.withRelators T).quotientMap_surjective q with ⟨w, rfl⟩
  -- Both inverse equivalences are the identity on free-word representatives.
  change (relatorsHomClosure P (by rw [h])).toGroupHom
      ((P.withRelators T).quotientMap w) = _
  rw [relators_normal_closure]
  rw [relators_closure_quotient]

@[simp] theorem relators_symm_quotient
    (P : Presentation.{u}) {S T : Set P.Free}
    (h : (P.withRelators S).rNClos =
      (P.withRelators T).rNClos) (w : P.Free) :
    (relatorsNormalClosure P h).symm
        ((P.withRelators T).quotientMap w) =
      (P.withRelators S).quotientMap w := by
  rw [relators_equiv_normal,
    relators_closure_quotient]

@[simp] theorem normal_closure_symm
    (P : Presentation.{u}) {S T : Set P.Free}
    (h : (P.withRelators S).rNClos =
      (P.withRelators T).rNClos)
    (x : (P.withRelators S).Group) :
    (relatorsNormalClosure P h).symm
        (relatorsNormalClosure P h x) = x :=
  (relatorsNormalClosure P h).left_inv x

@[simp] theorem relators_normal_symm
    (P : Presentation.{u}) {S T : Set P.Free}
    (h : (P.withRelators S).rNClos =
      (P.withRelators T).rNClos)
    (y : (P.withRelators T).Group) :
    relatorsNormalClosure P h
        ((relatorsNormalClosure P h).symm y) = y :=
  (relatorsNormalClosure P h).right_inv y

@[simp] theorem equiv_closure_symm
    (P : Presentation.{u}) {S T : Set P.Free}
    (h : (P.withRelators S).rNClos =
      (P.withRelators T).rNClos)
    (y : (P.withRelators T).Group) (x : (P.withRelators S).Group) :
    (relatorsNormalClosure P h).symm y = x ↔
      y = relatorsNormalClosure P h x := by
  rw [MulEquiv.symm_apply_eq]

@[simp] theorem relators_equiv_symm
    (P : Presentation.{u}) {S T : Set P.Free}
    (h : (P.withRelators S).rNClos =
      (P.withRelators T).rNClos)
    (x : (P.withRelators S).Group) (y : (P.withRelators T).Group) :
    x = (relatorsNormalClosure P h).symm y ↔
      relatorsNormalClosure P h x = y := by
  rw [eq_comm, equiv_closure_symm, eq_comm]

@[simp] theorem relators_closure_refl (P : Presentation.{u})
    (S : Set P.Free) :
    relatorsNormalClosure P
        (rfl : (P.withRelators S).rNClos =
          (P.withRelators S).rNClos) =
      MulEquiv.refl (P.withRelators S).Group := by
  apply MulEquiv.ext
  intro q
  rcases (P.withRelators S).quotientMap_surjective q with ⟨w, rfl⟩
  rw [relators_closure_quotient]
  rfl

theorem relators_closure_trans (P : Presentation.{u})
    {S T U : Set P.Free}
    (hST : (P.withRelators S).rNClos =
      (P.withRelators T).rNClos)
    (hTU : (P.withRelators T).rNClos =
      (P.withRelators U).rNClos) :
    (relatorsNormalClosure (P := P) (S := S) (T := T) hST).trans
        (relatorsNormalClosure (P := P) (S := T) (T := U) hTU) =
      relatorsNormalClosure (P := P) (S := S) (T := U) (Eq.trans hST hTU) := by
  apply MulEquiv.ext
  intro q
  rcases (P.withRelators S).quotientMap_surjective q with ⟨w, rfl⟩
  change relatorsNormalClosure (P := P) (S := T) (T := U) hTU
      (relatorsNormalClosure (P := P) (S := S) (T := T) hST
        ((P.withRelators S).quotientMap w)) =
    relatorsNormalClosure (P := P) (S := S) (T := U) (Eq.trans hST hTU)
      ((P.withRelators S).quotientMap w)
  rw [relators_closure_quotient]
  rw [relators_closure_quotient]
  rw [relators_closure_quotient]

/-- Commuting the two sides of a fixed-relator union induces the identity-on-words equivalence. -/
noncomputable def relatorsUnionComm (P : Presentation.{u}) (S T : Set P.Free) :
    (P.withRelators (S ∪ T)).Group ≃* (P.withRelators (T ∪ S)).Group :=
  relatorsNormalClosure P (by
    change Subgroup.normalClosure (S ∪ T) = Subgroup.normalClosure (T ∪ S)
    rw [Set.union_comm])

@[simp] theorem union_comm_quotient
    (P : Presentation.{u}) (S T : Set P.Free) (w : P.Free) :
    relatorsUnionComm P S T
        ((P.withRelators (S ∪ T)).quotientMap w) =
      (P.withRelators (T ∪ S)).quotientMap w := by
  exact relators_closure_quotient P _ w

@[simp] theorem relators_comm
    (P : Presentation.{u}) (S T : Set P.Free) :
    (relatorsUnionComm P S T).symm =
      relatorsUnionComm P T S := by
  apply MulEquiv.ext
  intro q
  rcases (P.withRelators (T ∪ S)).quotientMap_surjective q with ⟨w, rfl⟩
  rw [MulEquiv.symm_apply_eq]
  rw [union_comm_quotient, union_comm_quotient]

@[simp] theorem relators_comm_symm
    (P : Presentation.{u}) (S T : Set P.Free) (w : P.Free) :
    (relatorsUnionComm P S T).symm
        ((P.withRelators (T ∪ S)).quotientMap w) =
      (P.withRelators (S ∪ T)).quotientMap w := by
  rw [relators_comm, union_comm_quotient]

@[simp] theorem union_comm_symm
    (P : Presentation.{u}) (S T : Set P.Free)
    (x : (P.withRelators (S ∪ T)).Group) :
    (relatorsUnionComm P S T).symm
        (relatorsUnionComm P S T x) = x :=
  (relatorsUnionComm P S T).left_inv x

@[simp] theorem relators_union_comm
    (P : Presentation.{u}) (S T : Set P.Free)
    (y : (P.withRelators (T ∪ S)).Group) :
    relatorsUnionComm P S T
        ((relatorsUnionComm P S T).symm y) = y :=
  (relatorsUnionComm P S T).right_inv y

/-- Reassociate a fixed-generator union of relator sets.  This equivalence is the
identity on free-word representatives; it is useful for keeping iterated relator
additions in a chosen normal form. -/
noncomputable def relatorsUnionAssoc (P : Presentation.{u})
    (S T U : Set P.Free) :
    (P.withRelators ((S ∪ T) ∪ U)).Group ≃*
      (P.withRelators (S ∪ (T ∪ U))).Group :=
  relatorsNormalClosure P (by
    change Subgroup.normalClosure ((S ∪ T) ∪ U) =
      Subgroup.normalClosure (S ∪ (T ∪ U))
    rw [Set.union_assoc])

@[simp] theorem relators_union
    (P : Presentation.{u}) (S T U : Set P.Free) (x : P.Gen) :
    relatorsUnionAssoc P S T U
        ((P.withRelators ((S ∪ T) ∪ U)).of x) =
      (P.withRelators (S ∪ (T ∪ U))).of x := by
  exact relators_equiv_closure P _ x


@[simp] theorem relators_assoc_quotient
    (P : Presentation.{u}) (S T U : Set P.Free) (w : P.Free) :
    relatorsUnionAssoc P S T U
        ((P.withRelators ((S ∪ T) ∪ U)).quotientMap w) =
      (P.withRelators (S ∪ (T ∪ U))).quotientMap w := by
  exact relators_closure_quotient P _ w

@[simp] theorem union_assoc_quotient
    (P : Presentation.{u}) (S T U : Set P.Free) (w : P.Free) :
    (relatorsUnionAssoc P S T U).symm
        ((P.withRelators (S ∪ (T ∪ U))).quotientMap w) =
      (P.withRelators ((S ∪ T) ∪ U)).quotientMap w := by
  exact relators_symm_quotient P _ w

@[simp] theorem relators_assoc
    (P : Presentation.{u}) (S T U : Set P.Free) (x : P.Gen) :
    (relatorsUnionAssoc P S T U).symm
        ((P.withRelators (S ∪ (T ∪ U))).of x) =
      (P.withRelators ((S ∪ T) ∪ U)).of x := by
  rw [← quotientMap_of]
  rw [union_assoc_quotient]
  rfl

@[simp] theorem relators_assoc_symm
    (P : Presentation.{u}) (S T U : Set P.Free)
    (x : (P.withRelators ((S ∪ T) ∪ U)).Group) :
    (relatorsUnionAssoc P S T U).symm
        (relatorsUnionAssoc P S T U x) = x :=
  (relatorsUnionAssoc P S T U).left_inv x

@[simp] theorem union_assoc_symm
    (P : Presentation.{u}) (S T U : Set P.Free)
    (y : (P.withRelators (S ∪ (T ∪ U))).Group) :
    relatorsUnionAssoc P S T U
        ((relatorsUnionAssoc P S T U).symm y) = y :=
  (relatorsUnionAssoc P S T U).right_inv y

@[simp] theorem union_assoc_equiv
    (P : Presentation.{u}) (S T U : Set P.Free)
    (y : (P.withRelators (S ∪ (T ∪ U))).Group)
    (x : (P.withRelators ((S ∪ T) ∪ U)).Group) :
    (relatorsUnionAssoc P S T U).symm y = x ↔
      y = relatorsUnionAssoc P S T U x := by
  rw [MulEquiv.symm_apply_eq]

@[simp] theorem assoc_equiv_symm
    (P : Presentation.{u}) (S T U : Set P.Free)
    (x : (P.withRelators ((S ∪ T) ∪ U)).Group)
    (y : (P.withRelators (S ∪ (T ∪ U))).Group) :
    x = (relatorsUnionAssoc P S T U).symm y ↔
      relatorsUnionAssoc P S T U x = y := by
  rw [eq_comm, union_assoc_equiv, eq_comm]

@[simp] theorem union_comm_equiv
    (P : Presentation.{u}) (S T : Set P.Free)
    (y : (P.withRelators (T ∪ S)).Group)
    (x : (P.withRelators (S ∪ T)).Group) :
    (relatorsUnionComm P S T).symm y = x ↔
      y = relatorsUnionComm P S T x := by
  rw [MulEquiv.symm_apply_eq]

@[simp] theorem comm_equiv_symm
    (P : Presentation.{u}) (S T : Set P.Free)
    (x : (P.withRelators (S ∪ T)).Group)
    (y : (P.withRelators (T ∪ S)).Group) :
    x = (relatorsUnionComm P S T).symm y ↔
      relatorsUnionComm P S T x = y := by
  rw [eq_comm, union_comm_equiv, eq_comm]

/-- Inclusion of relator sets induces the canonical quotient morphism between
presentations with the same generators. -/
def relatorsMonoHom (P : Presentation.{u}) {S T : Set P.Free} (hST : S ⊆ T) :
    Hom (P.withRelators S) (P.withRelators T) where
  gen := id
  map_rel := by
    intro r hr
    change FreeGroup.map id r ∈ (P.withRelators T).rNClos
    rw [FreeGroup.map.id]
    exact Subgroup.subset_normalClosure (hST hr)

@[simp] theorem relators_mono_gen (P : Presentation.{u}) {S T : Set P.Free}
    (hST : S ⊆ T) (x : P.Gen) :
    (relatorsMonoHom P hST).gen x = x := rfl

@[simp] theorem relators_mono_group (P : Presentation.{u})
    {S T : Set P.Free} (hST : S ⊆ T) (x : P.Gen) :
    (relatorsMonoHom P hST).toGroupHom ((P.withRelators S).of x) =
      (P.withRelators T).of x := rfl

@[simp] theorem relators_mono_hom (P : Presentation.{u})
    {S T : Set P.Free} (hST : S ⊆ T) (w : P.Free) :
    (relatorsMonoHom P hST).toGroupHom
        ((P.withRelators S).quotientMap w) =
      (P.withRelators T).quotientMap w := by
  rw [Hom.group_quotient]
  change (P.withRelators T).quotientMap (FreeGroup.map id w) = _
  rw [FreeGroup.map.id]

@[simp] theorem relators_mono_refl (P : Presentation.{u}) (S : Set P.Free) :
    relatorsMonoHom P (show S ⊆ S from fun _ h => h) = Hom.id (P.withRelators S) := by
  ext x
  rfl

@[simp] theorem mono_hom_comp (P : Presentation.{u})
    {S T U : Set P.Free} (hST : S ⊆ T) (hTU : T ⊆ U) :
    (relatorsMonoHom P hTU).comp (relatorsMonoHom P hST) =
      relatorsMonoHom P (fun _ hx => hTU (hST hx)) := by
  ext x
  rfl

/-- Cancellation across a fixed-generator relator-inclusion map.  These maps are
presentation-level epimorphisms because they are the identity on generators. -/
theorem Hom.eqcomp_relatorsmono_homeq {P Q : Presentation.{u}}
    {S T : Set P.Free} (hST : S ⊆ T)
    {f g : Hom (P.withRelators T) Q}
    (h : f.comp (relatorsMonoHom P hST) =
      g.comp (relatorsMonoHom P hST)) :
    f = g := by
  ext x
  have hx := congrArg (fun k : Hom (P.withRelators S) Q => k.gen x) h
  simpa using hx


/-- The canonical map from a relator-subpresentation into the original presentation. -/
def relatorsOriginalHom (P : Presentation.{u}) {S : Set P.Free} (hS : S ⊆ P.rels) :
    Hom (P.withRelators S) P :=
  relatorsMonoHom P hS

@[simp] theorem relators_original_gen (P : Presentation.{u})
    {S : Set P.Free} (hS : S ⊆ P.rels) (x : P.Gen) :
    (relatorsOriginalHom P hS).gen x = x := rfl

@[simp] theorem relators_original_group
    (P : Presentation.{u}) {S : Set P.Free} (hS : S ⊆ P.rels) (x : P.Gen) :
    (relatorsOriginalHom P hS).toGroupHom ((P.withRelators S).of x) =
      P.of x := rfl

@[simp] theorem relators_original_hom
    (P : Presentation.{u}) {S : Set P.Free} (hS : S ⊆ P.rels) (w : P.Free) :
    (relatorsOriginalHom P hS).toGroupHom
        ((P.withRelators S).quotientMap w) = P.quotientMap w := by
  exact relators_mono_hom P hS w

/-- Fixed-generator relator-inclusion maps are surjective on presented groups. -/
theorem relators_mono_surjective (P : Presentation.{u})
    {S T : Set P.Free} (hST : S ⊆ T) :
    Function.Surjective (relatorsMonoHom P hST).toGroupHom := by
  apply Hom.group_surjective_free
  intro w
  refine ⟨w, ?_⟩
  change FreeGroup.map id w = w
  rw [FreeGroup.map.id]

/-- Fixed-generator normal-closure-inclusion maps are surjective on presented groups. -/
theorem relators_closure_surjective (P : Presentation.{u})
    {S T : Set P.Free}
    (h : (P.withRelators S).rNClos ≤
      (P.withRelators T).rNClos) :
    Function.Surjective (relatorsHomClosure P h).toGroupHom := by
  apply Hom.group_surjective_free
  intro w
  refine ⟨w, ?_⟩
  change FreeGroup.map id w = w
  rw [FreeGroup.map.id]

/-- The canonical map from a relator-subpresentation to the original presentation is surjective. -/
theorem relators_original_surjective (P : Presentation.{u})
    {S : Set P.Free} (hS : S ⊆ P.rels) :
    Function.Surjective (relatorsOriginalHom P hS).toGroupHom :=
  relators_mono_surjective P hS

/-- Kernel of the quotient map induced by enlarging a relator set.  It is the
normal closure, in the smaller presented group, of the images of the larger
relator set (equivalently, of the newly added relators). -/
theorem relators_mono (P : Presentation.{u}) {S T : Set P.Free}
    (hST : S ⊆ T) :
    MonoidHom.ker (relatorsMonoHom P hST).toGroupHom =
      Subgroup.normalClosure ((P.withRelators S).quotientMap '' T) := by
  classical
  let PS := P.withRelators S
  let PT := P.withRelators T
  let c := (relatorsMonoHom P hST).toGroupHom
  let K : Subgroup PS.Group := Subgroup.normalClosure (PS.quotientMap '' T)
  apply le_antisymm
  · intro q hq
    rcases PS.quotientMap_surjective q with ⟨w, rfl⟩
    have hwT : w ∈ PT.rNClos := by
      have hc : c (PS.quotientMap w) = 1 := MonoidHom.mem_ker.mp hq
      change PT.quotientMap (FreeGroup.map id w) = 1 at hc
      rw [FreeGroup.map.id] at hc
      exact PT.quotient_one.mp hc
    change PS.quotientMap w ∈ K
    haveI : K.Normal := Subgroup.normalClosure_normal
    let qmap : PT.Free →* PS.Group := PS.quotientMap
    have hN : (K.comap qmap).Normal :=
      (show K.Normal from inferInstance).comap qmap
    letI : (K.comap qmap).Normal := hN
    have hclosure : PT.rNClos ≤ K.comap qmap := by
      apply Subgroup.normalClosure_le_normal
      intro r hr
      dsimp [PT] at hr
      dsimp [qmap]
      change PS.quotientMap r ∈ K
      exact Subgroup.subset_normalClosure ⟨r, hr, rfl⟩
    exact hclosure hwT
  · haveI : (MonoidHom.ker c).Normal := MonoidHom.normal_ker c
    apply Subgroup.normalClosure_le_normal
    intro q hq
    rcases hq with ⟨t, ht, rfl⟩
    change c (PS.quotientMap t) = 1
    rw [Hom.group_quotient]
    change PT.quotientMap (FreeGroup.map id t) = 1
    rw [FreeGroup.map.id]
    exact PT.quotient_rel_one ht

/-- Pointwise kernel criterion for a fixed-generator relator-inclusion morphism. -/
@[simp] theorem ker_relators_mono (P : Presentation.{u})
    {S T : Set P.Free} (hST : S ⊆ T) (q : (P.withRelators S).Group) :
    q ∈ MonoidHom.ker (relatorsMonoHom P hST).toGroupHom ↔
      q ∈ Subgroup.normalClosure ((P.withRelators S).quotientMap '' T) := by
  rw [relators_mono]


/-- An equal-normal-closure equivalence commutes with the canonical quotient maps
from any smaller fixed-relator presentation. -/
theorem relators_comp_mono (P : Presentation.{u})
    {A S T : Set P.Free}
    (hST : (P.withRelators S).rNClos =
      (P.withRelators T).rNClos)
    (hAS : A ⊆ S) (hAT : A ⊆ T) :
    (relatorsNormalClosure (P := P) (S := S) (T := T) hST).toMonoidHom.comp
        (relatorsMonoHom P hAS).toGroupHom =
      (relatorsMonoHom P hAT).toGroupHom := by
  apply MonoidHom.ext
  intro q
  rcases (P.withRelators A).quotientMap_surjective q with ⟨w, rfl⟩
  rw [MonoidHom.comp_apply]
  rw [relators_mono_hom]
  change relatorsNormalClosure (P := P) (S := S) (T := T) hST
      ((P.withRelators S).quotientMap w) = _
  rw [relators_closure_quotient]
  rw [relators_mono_hom]

/-- Specialized coherence form for the fixed-relator union associator: any canonical
map from a smaller relator set commutes across reassociation. -/
theorem relators_assoc_mono (P : Presentation.{u})
    (S T U A : Set P.Free)
    (hL : A ⊆ (S ∪ T) ∪ U) (hR : A ⊆ S ∪ (T ∪ U)) :
    (relatorsUnionAssoc P S T U).toMonoidHom.comp
        (relatorsMonoHom P hL).toGroupHom =
      (relatorsMonoHom P hR).toGroupHom := by
  apply MonoidHom.ext
  intro q
  rcases (P.withRelators A).quotientMap_surjective q with ⟨w, rfl⟩
  rw [MonoidHom.comp_apply]
  rw [relators_mono_hom]
  change relatorsUnionAssoc P S T U
      ((P.withRelators ((S ∪ T) ∪ U)).quotientMap w) = _
  rw [relators_assoc_quotient]
  rw [relators_mono_hom]

/-- Reverse-direction coherence for the fixed-relator union associator. -/
theorem relators_union_assoc (P : Presentation.{u})
    (S T U A : Set P.Free)
    (hR : A ⊆ S ∪ (T ∪ U)) (hL : A ⊆ (S ∪ T) ∪ U) :
    (relatorsUnionAssoc P S T U).symm.toMonoidHom.comp
        (relatorsMonoHom P hR).toGroupHom =
      (relatorsMonoHom P hL).toGroupHom := by
  apply MonoidHom.ext
  intro q
  rcases (P.withRelators A).quotientMap_surjective q with ⟨w, rfl⟩
  rw [MonoidHom.comp_apply]
  rw [relators_mono_hom]
  change (relatorsUnionAssoc P S T U).symm
      ((P.withRelators (S ∪ (T ∪ U))).quotientMap w) = _
  rw [union_assoc_quotient]
  rw [relators_mono_hom]

/-- Canonical quotient map from relator set `S` to `S ∪ T` for fixed generators. -/
def relatorsUnionLeft (P : Presentation.{u}) (S T : Set P.Free) :
    Hom (P.withRelators S) (P.withRelators (S ∪ T)) :=
  relatorsMonoHom P (by intro r hr; exact Or.inl hr)

/-- Canonical quotient map from relator set `T` to `S ∪ T` for fixed generators. -/
def relatorsUnionHom (P : Presentation.{u}) (S T : Set P.Free) :
    Hom (P.withRelators T) (P.withRelators (S ∪ T)) :=
  relatorsMonoHom P (by intro r hr; exact Or.inr hr)

@[simp] theorem union_left_hom
    (P : Presentation.{u}) (S T : Set P.Free) (w : P.Free) :
    (relatorsUnionLeft P S T).toGroupHom ((P.withRelators S).quotientMap w) =
      (P.withRelators (S ∪ T)).quotientMap w := by
  exact relators_mono_hom P (by intro r hr; exact Or.inl hr) w

@[simp] theorem relators_union_group
    (P : Presentation.{u}) (S T : Set P.Free) (w : P.Free) :
    (relatorsUnionHom P S T).toGroupHom ((P.withRelators T).quotientMap w) =
      (P.withRelators (S ∪ T)).quotientMap w := by
  exact relators_mono_hom P (by intro r hr; exact Or.inr hr) w

/-- Descent out of a fixed-generator union: a morphism from the `S`-presentation
extends across adding the relators `T` when it kills every relator in `T`. -/
def Hom.desc_relators_unionleft {P Q : Presentation.{u}} {S T : Set P.Free}
    (f : Hom (P.withRelators S) Q)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → f.freeMap t ∈ Q.rNClos) :
    Hom (P.withRelators (S ∪ T)) Q where
  gen := f.gen
  map_rel := by
    intro r hr
    rcases hr with hrS | hrT
    · exact f.map_rel hrS
    · exact hT hrT

@[simp] theorem Hom.desc_relatorsunion_leftgen {P Q : Presentation.{u}}
    {S T : Set P.Free} (f : Hom (P.withRelators S) Q)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → f.freeMap t ∈ Q.rNClos)
    (x : P.Gen) :
    (f.desc_relators_unionleft hT).gen x = f.gen x := rfl

@[simp] theorem Hom.descrelators_unionleft_complefthom {P Q : Presentation.{u}}
    {S T : Set P.Free} (f : Hom (P.withRelators S) Q)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → f.freeMap t ∈ Q.rNClos) :
    (f.desc_relators_unionleft hT).comp (relatorsUnionLeft P S T) = f := by
  ext x
  rfl

@[simp] theorem Hom.descre_union_homqu
    {P Q : Presentation.{u}} {S T : Set P.Free}
    (f : Hom (P.withRelators S) Q)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → f.freeMap t ∈ Q.rNClos)
    (w : P.Free) :
    (f.desc_relators_unionleft hT).toGroupHom
        ((P.withRelators (S ∪ T)).quotientMap w) =
      f.toGroupHom ((P.withRelators S).quotientMap w) := by
  rw [Hom.group_quotient, Hom.group_quotient]
  rfl

/-- Descent from the left side preserves surjectivity on presented groups. -/
theorem Hom.desc_relatorsunion_leftsurj {P Q : Presentation.{u}}
    {S T : Set P.Free} (f : Hom (P.withRelators S) Q)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → f.freeMap t ∈ Q.rNClos)
    (hf : Function.Surjective f.toGroupHom) :
    Function.Surjective (f.desc_relators_unionleft hT).toGroupHom := by
  intro y
  rcases hf y with ⟨x, rfl⟩
  refine ⟨(relatorsUnionLeft P S T).toGroupHom x, ?_⟩
  change (((f.desc_relators_unionleft hT).toGroupHom.comp
      (relatorsUnionLeft P S T).toGroupHom) x) = f.toGroupHom x
  rw [← Hom.comp_group_hom, Hom.descrelators_unionleft_complefthom]

/-- Uniqueness of descent out of a fixed-generator union from the left side. -/
theorem Hom.desc_relatorsunion_leftuniq {P Q : Presentation.{u}}
    {S T : Set P.Free} (f : Hom (P.withRelators S) Q)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → f.freeMap t ∈ Q.rNClos)
    (k : Hom (P.withRelators (S ∪ T)) Q)
    (hk : k.comp (relatorsUnionLeft P S T) = f) :
    k = f.desc_relators_unionleft hT := by
  ext x
  have hx := congrArg (fun h : Hom (P.withRelators S) Q => h.gen x) hk
  simpa using hx


/-- Descent out of a fixed-generator union from the right side. -/
def Hom.desc_relators_unionright {P Q : Presentation.{u}} {S T : Set P.Free}
    (f : Hom (P.withRelators T) Q)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos) :
    Hom (P.withRelators (S ∪ T)) Q where
  gen := f.gen
  map_rel := by
    intro r hr
    rcases hr with hrS | hrT
    · exact hS hrS
    · exact f.map_rel hrT

@[simp] theorem Hom.desc_relatorsunion_rightgen {P Q : Presentation.{u}}
    {S T : Set P.Free} (f : Hom (P.withRelators T) Q)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (x : P.Gen) :
    (f.desc_relators_unionright hS).gen x = f.gen x := rfl

@[simp] theorem Hom.descre_union_compr {P Q : Presentation.{u}}
    {S T : Set P.Free} (f : Hom (P.withRelators T) Q)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos) :
    (f.desc_relators_unionright hS).comp (relatorsUnionHom P S T) = f := by
  ext x
  rfl

@[simp] theorem Hom.descre_union_homqa
    {P Q : Presentation.{u}} {S T : Set P.Free}
    (f : Hom (P.withRelators T) Q)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (w : P.Free) :
    (f.desc_relators_unionright hS).toGroupHom
        ((P.withRelators (S ∪ T)).quotientMap w) =
      f.toGroupHom ((P.withRelators T).quotientMap w) := by
  rw [Hom.group_quotient, Hom.group_quotient]
  rfl

/-- Descent from the right side preserves surjectivity on presented groups. -/
theorem Hom.desc_relatorsunion_rightsurj {P Q : Presentation.{u}}
    {S T : Set P.Free} (f : Hom (P.withRelators T) Q)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (hf : Function.Surjective f.toGroupHom) :
    Function.Surjective (f.desc_relators_unionright hS).toGroupHom := by
  intro y
  rcases hf y with ⟨x, rfl⟩
  refine ⟨(relatorsUnionHom P S T).toGroupHom x, ?_⟩
  change (((f.desc_relators_unionright hS).toGroupHom.comp
      (relatorsUnionHom P S T).toGroupHom) x) = f.toGroupHom x
  rw [← Hom.comp_group_hom, Hom.descre_union_compr]

/-- Uniqueness of descent out of a fixed-generator union from the right side. -/
theorem Hom.desc_relatorsunion_rightuniq {P Q : Presentation.{u}}
    {S T : Set P.Free} (f : Hom (P.withRelators T) Q)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (k : Hom (P.withRelators (S ∪ T)) Q)
    (hk : k.comp (relatorsUnionHom P S T) = f) :
    k = f.desc_relators_unionright hS := by
  ext x
  have hx := congrArg (fun h : Hom (P.withRelators T) Q => h.gen x) hk
  simpa using hx

/-- The left fixed-relator union map is surjective. -/
theorem relators_hom_surjective (P : Presentation.{u}) (S T : Set P.Free) :
    Function.Surjective (relatorsUnionLeft P S T).toGroupHom :=
  relators_mono_surjective P (by intro r hr; exact Or.inl hr)

/-- The right fixed-relator union map is surjective. -/
theorem relators_union_surjective (P : Presentation.{u}) (S T : Set P.Free) :
    Function.Surjective (relatorsUnionHom P S T).toGroupHom :=
  relators_mono_surjective P (by intro r hr; exact Or.inr hr)

/-- Range form of surjectivity for the left fixed-relator union map. -/
theorem relators_union_range (P : Presentation.{u}) (S T : Set P.Free) :
    (relatorsUnionLeft P S T).toGroupHom.range = ⊤ :=
  MonoidHom.range_eq_top.mpr (relators_hom_surjective P S T)

/-- Range form of surjectivity for the right fixed-relator union map. -/
theorem relators_union_top (P : Presentation.{u}) (S T : Set P.Free) :
    (relatorsUnionHom P S T).toGroupHom.range = ⊤ :=
  MonoidHom.range_eq_top.mpr (relators_union_surjective P S T)

/-- Swapping a fixed-relator union carries the left inclusion to the right inclusion
for the swapped pair. -/
theorem relators_comm_comp (P : Presentation.{u})
    (S T : Set P.Free) :
    (relatorsUnionComm P S T).toMonoidHom.comp
        (relatorsUnionLeft P S T).toGroupHom =
      (relatorsUnionHom P T S).toGroupHom := by
  apply MonoidHom.ext
  intro q
  rcases (P.withRelators S).quotientMap_surjective q with ⟨w, rfl⟩
  change (relatorsUnionComm P S T)
        ((relatorsUnionLeft P S T).toGroupHom
          ((P.withRelators S).quotientMap w)) =
      (relatorsUnionHom P T S).toGroupHom
        ((P.withRelators S).quotientMap w)
  rw [union_left_hom,
    union_comm_quotient,
    relators_union_group]

/-- Swapping a fixed-relator union carries the right inclusion to the left inclusion
for the swapped pair. -/
theorem union_comm_comp (P : Presentation.{u})
    (S T : Set P.Free) :
    (relatorsUnionComm P S T).toMonoidHom.comp
        (relatorsUnionHom P S T).toGroupHom =
      (relatorsUnionLeft P T S).toGroupHom := by
  apply MonoidHom.ext
  intro q
  rcases (P.withRelators T).quotientMap_surjective q with ⟨w, rfl⟩
  change (relatorsUnionComm P S T)
        ((relatorsUnionHom P S T).toGroupHom
          ((P.withRelators T).quotientMap w)) =
      (relatorsUnionLeft P T S).toGroupHom
        ((P.withRelators T).quotientMap w)
  rw [relators_union_group,
    union_comm_quotient,
    union_left_hom]

/-- Kernel of the left fixed-relator union map is generated by the new `T` relators. -/
theorem ker_relators_left (P : Presentation.{u}) (S T : Set P.Free) :
    MonoidHom.ker (relatorsUnionLeft P S T).toGroupHom =
      Subgroup.normalClosure ((P.withRelators S).quotientMap '' T) := by
  classical
  let PS := P.withRelators S
  let PU := P.withRelators (S ∪ T)
  let c := (relatorsUnionLeft P S T).toGroupHom
  let K : Subgroup PS.Group := Subgroup.normalClosure (PS.quotientMap '' T)
  apply le_antisymm
  · intro q hq
    rcases PS.quotientMap_surjective q with ⟨w, rfl⟩
    have hwU : w ∈ PU.rNClos := by
      have hc : c (PS.quotientMap w) = 1 := MonoidHom.mem_ker.mp hq
      change PU.quotientMap (FreeGroup.map id w) = 1 at hc
      rw [FreeGroup.map.id] at hc
      exact PU.quotient_one.mp hc
    change PS.quotientMap w ∈ K
    haveI : K.Normal := Subgroup.normalClosure_normal
    let qmap : PU.Free →* PS.Group := PS.quotientMap
    have hN : (K.comap qmap).Normal :=
      (show K.Normal from inferInstance).comap qmap
    letI : (K.comap qmap).Normal := hN
    have hclosure : PU.rNClos ≤ K.comap qmap := by
      apply Subgroup.normalClosure_le_normal
      intro r hr
      dsimp [PU] at hr
      dsimp [qmap]
      change PS.quotientMap r ∈ K
      rcases hr with hs | ht
      · rw [PS.quotient_rel_one hs]
        exact K.one_mem
      · exact Subgroup.subset_normalClosure ⟨r, ht, rfl⟩
    exact hclosure hwU
  · haveI : (MonoidHom.ker c).Normal := MonoidHom.normal_ker c
    apply Subgroup.normalClosure_le_normal
    intro q hq
    rcases hq with ⟨t, ht, rfl⟩
    change c (PS.quotientMap t) = 1
    rw [Hom.group_quotient]
    change PU.quotientMap (FreeGroup.map id t) = 1
    rw [FreeGroup.map.id]
    exact PU.quotient_rel_one (Or.inr ht)

@[simp] theorem ker_relators_hom
    (P : Presentation.{u}) (S T : Set P.Free) (q : (P.withRelators S).Group) :
    q ∈ MonoidHom.ker (relatorsUnionLeft P S T).toGroupHom ↔
      q ∈ Subgroup.normalClosure ((P.withRelators S).quotientMap '' T) := by
  rw [ker_relators_left]


/-- Kernel of the right fixed-relator union map is generated by the new `S` relators. -/
theorem ker_union_right (P : Presentation.{u}) (S T : Set P.Free) :
    MonoidHom.ker (relatorsUnionHom P S T).toGroupHom =
      Subgroup.normalClosure ((P.withRelators T).quotientMap '' S) := by
  classical
  let PT := P.withRelators T
  let PU := P.withRelators (S ∪ T)
  let c := (relatorsUnionHom P S T).toGroupHom
  let K : Subgroup PT.Group := Subgroup.normalClosure (PT.quotientMap '' S)
  apply le_antisymm
  · intro q hq
    rcases PT.quotientMap_surjective q with ⟨w, rfl⟩
    have hwU : w ∈ PU.rNClos := by
      have hc : c (PT.quotientMap w) = 1 := MonoidHom.mem_ker.mp hq
      change PU.quotientMap (FreeGroup.map id w) = 1 at hc
      rw [FreeGroup.map.id] at hc
      exact PU.quotient_one.mp hc
    change PT.quotientMap w ∈ K
    haveI : K.Normal := Subgroup.normalClosure_normal
    let qmap : PU.Free →* PT.Group := PT.quotientMap
    have hN : (K.comap qmap).Normal :=
      (show K.Normal from inferInstance).comap qmap
    letI : (K.comap qmap).Normal := hN
    have hclosure : PU.rNClos ≤ K.comap qmap := by
      apply Subgroup.normalClosure_le_normal
      intro r hr
      dsimp [PU] at hr
      dsimp [qmap]
      change PT.quotientMap r ∈ K
      rcases hr with hs | ht
      · exact Subgroup.subset_normalClosure ⟨r, hs, rfl⟩
      · rw [PT.quotient_rel_one ht]
        exact K.one_mem
    exact hclosure hwU
  · haveI : (MonoidHom.ker c).Normal := MonoidHom.normal_ker c
    apply Subgroup.normalClosure_le_normal
    intro q hq
    rcases hq with ⟨s, hs, rfl⟩
    change c (PT.quotientMap s) = 1
    rw [Hom.group_quotient]
    change PU.quotientMap (FreeGroup.map id s) = 1
    rw [FreeGroup.map.id]
    exact PU.quotient_rel_one (Or.inl hs)

@[simp] theorem ker_relators_union
    (P : Presentation.{u}) (S T : Set P.Free) (q : (P.withRelators T).Group) :
    q ∈ MonoidHom.ker (relatorsUnionHom P S T).toGroupHom ↔
      q ∈ Subgroup.normalClosure ((P.withRelators T).quotientMap '' S) := by
  rw [ker_union_right]


/-- Quotient criterion for injectivity of a left-union descent. -/
theorem Hom.descrelators_unionleft_injkernelle
    {P Q : Presentation.{u}} {S T : Set P.Free}
    (f : Hom (P.withRelators S) Q)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → f.freeMap t ∈ Q.rNClos)
    (hker : MonoidHom.ker f.toGroupHom ≤
      Subgroup.normalClosure ((P.withRelators S).quotientMap '' T)) :
    Function.Injective (f.desc_relators_unionleft hT).toGroupHom := by
  let c := (relatorsUnionLeft P S T).toGroupHom
  let g := (f.desc_relators_unionleft hT).toGroupHom
  have hc_surj : Function.Surjective c := relators_hom_surjective P S T
  have hcomp : g.comp c = f.toGroupHom := by
    rw [← Hom.comp_group_hom, Hom.descrelators_unionleft_complefthom]
  have hker_c : MonoidHom.ker c =
      Subgroup.normalClosure ((P.withRelators S).quotientMap '' T) :=
    ker_relators_left P S T
  have htriv : ∀ {z}, g z = 1 → z = 1 := by
    intro z hz
    rcases hc_surj z with ⟨x, rfl⟩
    have hxF : f.toGroupHom x = 1 := by
      rw [← hcomp]
      exact hz
    have hxK : x ∈ MonoidHom.ker c := by
      rw [hker_c]
      exact hker (MonoidHom.mem_ker.mpr hxF)
    exact MonoidHom.mem_ker.mp hxK
  intro a b hab
  apply eq_of_mul_inv_eq_one
  apply htriv
  rw [map_mul, map_inv, hab, mul_inv_cancel]

/-- Quotient criterion for injectivity of a right-union descent. -/
theorem Hom.descrelators_unionright_injkernelle
    {P Q : Presentation.{u}} {S T : Set P.Free}
    (f : Hom (P.withRelators T) Q)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (hker : MonoidHom.ker f.toGroupHom ≤
      Subgroup.normalClosure ((P.withRelators T).quotientMap '' S)) :
    Function.Injective (f.desc_relators_unionright hS).toGroupHom := by
  let c := (relatorsUnionHom P S T).toGroupHom
  let g := (f.desc_relators_unionright hS).toGroupHom
  have hc_surj : Function.Surjective c := relators_union_surjective P S T
  have hcomp : g.comp c = f.toGroupHom := by
    rw [← Hom.comp_group_hom, Hom.descre_union_compr]
  have hker_c : MonoidHom.ker c =
      Subgroup.normalClosure ((P.withRelators T).quotientMap '' S) :=
    ker_union_right P S T
  have htriv : ∀ {z}, g z = 1 → z = 1 := by
    intro z hz
    rcases hc_surj z with ⟨x, rfl⟩
    have hxF : f.toGroupHom x = 1 := by
      rw [← hcomp]
      exact hz
    have hxK : x ∈ MonoidHom.ker c := by
      rw [hker_c]
      exact hker (MonoidHom.mem_ker.mpr hxF)
    exact MonoidHom.mem_ker.mp hxK
  intro a b hab
  apply eq_of_mul_inv_eq_one
  apply htriv
  rw [map_mul, map_inv, hab, mul_inv_cancel]

/-- Bijective form of the left-union descent quotient criterion. -/
theorem Hom.descre_union_kerne
    {P Q : Presentation.{u}} {S T : Set P.Free}
    (f : Hom (P.withRelators S) Q)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → f.freeMap t ∈ Q.rNClos)
    (hker : MonoidHom.ker f.toGroupHom ≤
      Subgroup.normalClosure ((P.withRelators S).quotientMap '' T))
    (hf : Function.Surjective f.toGroupHom) :
    Function.Bijective (f.desc_relators_unionleft hT).toGroupHom :=
  ⟨f.descrelators_unionleft_injkernelle hT hker,
    f.desc_relatorsunion_leftsurj hT hf⟩

/-- Bijective form of the right-union descent quotient criterion. -/
theorem Hom.descre_union_kernb
    {P Q : Presentation.{u}} {S T : Set P.Free}
    (f : Hom (P.withRelators T) Q)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (hker : MonoidHom.ker f.toGroupHom ≤
      Subgroup.normalClosure ((P.withRelators T).quotientMap '' S))
    (hf : Function.Surjective f.toGroupHom) :
    Function.Bijective (f.desc_relators_unionright hS).toGroupHom :=
  ⟨f.descrelators_unionright_injkernelle hS hker,
    f.desc_relatorsunion_rightsurj hS hf⟩

/-- Equivalence form of the left-union descent quotient criterion. -/
noncomputable def Hom.descre_union_kerna
    {P Q : Presentation.{u}} {S T : Set P.Free}
    (f : Hom (P.withRelators S) Q)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → f.freeMap t ∈ Q.rNClos)
    (hker : MonoidHom.ker f.toGroupHom ≤
      Subgroup.normalClosure ((P.withRelators S).quotientMap '' T))
    (hf : Function.Surjective f.toGroupHom) :
    (P.withRelators (S ∪ T)).Group ≃* Q.Group :=
  Hom.groupEquivBijective (f.desc_relators_unionleft hT)
    (f.descre_union_kerne hT hker hf)

@[simp] theorem Hom.descrelators_unionleft_equivapply
    {P Q : Presentation.{u}} {S T : Set P.Free}
    (f : Hom (P.withRelators S) Q)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → f.freeMap t ∈ Q.rNClos)
    (hker : MonoidHom.ker f.toGroupHom ≤
      Subgroup.normalClosure ((P.withRelators S).quotientMap '' T))
    (hf : Function.Surjective f.toGroupHom)
    (x : (P.withRelators (S ∪ T)).Group) :
    f.descre_union_kerna hT hker hf x =
      (f.desc_relators_unionleft hT).toGroupHom x := rfl

/-- Equivalence form of the right-union descent quotient criterion. -/
noncomputable def Hom.descre_union_kernc
    {P Q : Presentation.{u}} {S T : Set P.Free}
    (f : Hom (P.withRelators T) Q)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (hker : MonoidHom.ker f.toGroupHom ≤
      Subgroup.normalClosure ((P.withRelators T).quotientMap '' S))
    (hf : Function.Surjective f.toGroupHom) :
    (P.withRelators (S ∪ T)).Group ≃* Q.Group :=
  Hom.groupEquivBijective (f.desc_relators_unionright hS)
    (f.descre_union_kernb hS hker hf)

@[simp] theorem Hom.descrelators_unionright_equivapply
    {P Q : Presentation.{u}} {S T : Set P.Free}
    (f : Hom (P.withRelators T) Q)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (hker : MonoidHom.ker f.toGroupHom ≤
      Subgroup.normalClosure ((P.withRelators T).quotientMap '' S))
    (hf : Function.Surjective f.toGroupHom)
    (x : (P.withRelators (S ∪ T)).Group) :
    f.descre_union_kernc hS hker hf x =
      (f.desc_relators_unionright hS).toGroupHom x := rfl

@[simp] theorem Hom.descre_union_equiv
    {P Q : Presentation.{u}} {S T : Set P.Free}
    (f : Hom (P.withRelators S) Q)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → f.freeMap t ∈ Q.rNClos)
    (hker : MonoidHom.ker f.toGroupHom ≤
      Subgroup.normalClosure ((P.withRelators S).quotientMap '' T))
    (hf : Function.Surjective f.toGroupHom) :
    (f.descre_union_kerna hT hker hf).toMonoidHom =
      (f.desc_relators_unionleft hT).toGroupHom := rfl

@[simp] theorem Hom.descre_union_equia
    {P Q : Presentation.{u}} {S T : Set P.Free}
    (f : Hom (P.withRelators T) Q)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → f.freeMap s ∈ Q.rNClos)
    (hker : MonoidHom.ker f.toGroupHom ≤
      Subgroup.normalClosure ((P.withRelators T).quotientMap '' S))
    (hf : Function.Surjective f.toGroupHom) :
    (f.descre_union_kernc hS hker hf).toMonoidHom =
      (f.desc_relators_unionright hS).toGroupHom := rfl

/-- The inverse of a left-union descent equivalence cancels the descended hom. -/
@[simp] theorem Hom.descre_union_symma
    {P Q : Presentation.{u}} {S T : Set P.Free}
    (f : Hom (P.withRelators S) Q)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → f.freeMap t ∈ Q.rNClos)
    (hker : MonoidHom.ker f.toGroupHom ≤
      Subgroup.normalClosure ((P.withRelators S).quotientMap '' T))
    (hf : Function.Surjective f.toGroupHom)
    (x : (P.withRelators (S ∪ T)).Group) :
    (f.descre_union_kerna hT hker hf).symm
        ((f.desc_relators_unionleft hT).toGroupHom x) = x := by
  exact (f.descre_union_kerna hT hker hf).left_inv x

