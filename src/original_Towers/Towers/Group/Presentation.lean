/-- The left fixed-relator union map is injective when `T` is already a consequence of `S`. -/
theorem relators_injective_subset
    (P : Presentation.{u}) (S T : Set P.Free)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → t ∈ (P.withRelators S).rNClos) :
    Function.Injective (relatorsUnionLeft P S T).toGroupHom := by
  rw [← MonoidHom.ker_eq_bot_iff]
  rw [ker_relators_left]
  apply le_antisymm
  · apply Subgroup.normalClosure_le_normal
    intro q hq
    rcases hq with ⟨t, ht, rfl⟩
    change (P.withRelators S).quotientMap t = 1
    exact (P.withRelators S).quotient_one.mpr (hT ht)
  · exact bot_le

/-- The right fixed-relator union map is injective when `S` is already a consequence of `T`. -/
theorem relators_union_injective
    (P : Presentation.{u}) (S T : Set P.Free)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → s ∈ (P.withRelators T).rNClos) :
    Function.Injective (relatorsUnionHom P S T).toGroupHom := by
  rw [← MonoidHom.ker_eq_bot_iff]
  rw [ker_union_right]
  apply le_antisymm
  · apply Subgroup.normalClosure_le_normal
    intro q hq
    rcases hq with ⟨s, hs, rfl⟩
    change (P.withRelators T).quotientMap s = 1
    exact (P.withRelators T).quotient_one.mpr (hS hs)
  · exact bot_le


/-- The left fixed-relator union map is bijective when `T` is redundant modulo `S`. -/
theorem relators_bijective_subset
    (P : Presentation.{u}) (S T : Set P.Free)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → t ∈ (P.withRelators S).rNClos) :
    Function.Bijective (relatorsUnionLeft P S T).toGroupHom :=
  ⟨relators_injective_subset P S T hT,
    relators_hom_surjective P S T⟩

/-- The right fixed-relator union map is bijective when `S` is redundant modulo `T`. -/
theorem relators_union_bijective
    (P : Presentation.{u}) (S T : Set P.Free)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → s ∈ (P.withRelators T).rNClos) :
    Function.Bijective (relatorsUnionHom P S T).toGroupHom :=
  ⟨relators_union_injective P S T hS,
    relators_union_surjective P S T⟩

/-- Equivalence form of the left fixed-relator union map under a redundancy hypothesis. -/
noncomputable def relatorsSubsetClosure
    (P : Presentation.{u}) (S T : Set P.Free)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → t ∈ (P.withRelators S).rNClos) :
    (P.withRelators S).Group ≃* (P.withRelators (S ∪ T)).Group :=
  Hom.groupEquivBijective (relatorsUnionLeft P S T)
    (relators_bijective_subset P S T hT)

/-- Equivalence form of the right fixed-relator union map under a redundancy hypothesis. -/
noncomputable def relatorsUnionClosure
    (P : Presentation.{u}) (S T : Set P.Free)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → s ∈ (P.withRelators T).rNClos) :
    (P.withRelators T).Group ≃* (P.withRelators (S ∪ T)).Group :=
  Hom.groupEquivBijective (relatorsUnionHom P S T)
    (relators_union_bijective P S T hS)

@[simp] theorem relators_subset_monoid
    (P : Presentation.{u}) (S T : Set P.Free)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → t ∈ (P.withRelators S).rNClos) :
    (relatorsSubsetClosure P S T hT).toMonoidHom =
      (relatorsUnionLeft P S T).toGroupHom := by
  exact Hom.bijective_monoid_hom (relatorsUnionLeft P S T)
    (relators_bijective_subset P S T hT)

@[simp] theorem relators_union_monoid
    (P : Presentation.{u}) (S T : Set P.Free)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → s ∈ (P.withRelators T).rNClos) :
    (relatorsUnionClosure P S T hS).toMonoidHom =
      (relatorsUnionHom P S T).toGroupHom := by
