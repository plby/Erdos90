/-- The redundant-left-union canonical map cancels the inverse equivalence. -/
@[simp] theorem subset_closure_symm
    (P : Presentation.{u}) (S T : Set P.Free)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → t ∈ (P.withRelators S).rNClos)
    (y : (P.withRelators (S ∪ T)).Group) :
    (relatorsUnionLeft P S T).toGroupHom
        ((relatorsSubsetClosure P S T hT).symm y) = y := by
  change (relatorsSubsetClosure P S T hT)
        ((relatorsSubsetClosure P S T hT).symm y) = y
  exact (relatorsSubsetClosure P S T hT).right_inv y

