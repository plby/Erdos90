/-- The left union map is injective when the new `T` relators are already consequences. -/
theorem add_union_closure
    (P : Presentation.{u}) (S T : Set P.Free)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → t ∈ (P.addRelators S).rNClos) :
    Function.Injective (addUnionHom P S T).toGroupHom := by
  rw [← MonoidHom.ker_eq_bot_iff]
  rw [ker_left_hom]
  apply le_antisymm
  · apply Subgroup.normalClosure_le_normal
    intro q hq
    rcases hq with ⟨t, ht, rfl⟩
    change (P.addRelators S).quotientMap t = 1
    exact (P.addRelators S).quotient_one.mpr (hT ht)
  · exact bot_le

/-- The right union map is injective when the new `S` relators are already consequences. -/
theorem injective_subset_closure
    (P : Presentation.{u}) (S T : Set P.Free)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → s ∈ (P.addRelators T).rNClos) :
    Function.Injective (addRelatorsUnion P S T).toGroupHom := by
  rw [← MonoidHom.ker_eq_bot_iff]
  rw [ker_add_union]
  apply le_antisymm
  · apply Subgroup.normalClosure_le_normal
    intro q hq
    rcases hq with ⟨t, ht, rfl⟩
    change (P.addRelators T).quotientMap t = 1
    exact (P.addRelators T).quotient_one.mpr (hS ht)
  · exact bot_le


/-- The left union map is bijective when the new `T` relators are redundant. -/
theorem union_bijective_subset
    (P : Presentation.{u}) (S T : Set P.Free)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → t ∈ (P.addRelators S).rNClos) :
    Function.Bijective (addUnionHom P S T).toGroupHom :=
  ⟨add_union_closure P S T hT,
    union_left_surjective P S T⟩

/-- The right union map is bijective when the new `S` relators are redundant. -/
theorem bijective_subset_closure
    (P : Presentation.{u}) (S T : Set P.Free)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → s ∈ (P.addRelators T).rNClos) :
    Function.Bijective (addRelatorsUnion P S T).toGroupHom :=
  ⟨injective_subset_closure P S T hS,
    add_union_surjective P S T⟩

/-- Underlying hom of the canonical redundant-left union equivalence. -/
@[simp] theorem union_monoid_hom
    (P : Presentation.{u}) (S T : Set P.Free)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → t ∈ (P.addRelators S).rNClos) :
    (relatorsUnionSubset P S T hT).toMonoidHom =
      (addUnionHom P S T).toGroupHom := by
  apply MonoidHom.ext
  intro q
  rcases (P.addRelators S).quotientMap_surjective q with ⟨w, rfl⟩
  change relatorsUnionSubset P S T hT
        ((P.addRelators S).quotientMap w) =
      (addUnionHom P S T).toGroupHom
        ((P.addRelators S).quotientMap w)
  rw [union_left_subset,
    add_union_left]

/-- Equivalence form of the right added-relator union map under a redundancy hypothesis. -/
noncomputable def unionSubsetClosure
    (P : Presentation.{u}) (S T : Set P.Free)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → s ∈ (P.addRelators T).rNClos) :
    (P.addRelators T).Group ≃* (P.addRelators (S ∪ T)).Group :=
  Hom.groupEquivBijective (addRelatorsUnion P S T)
    (bijective_subset_closure P S T hS)

@[simp] theorem union_subset_monoid
    (P : Presentation.{u}) (S T : Set P.Free)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → s ∈ (P.addRelators T).rNClos) :
    (unionSubsetClosure P S T hS).toMonoidHom =
      (addRelatorsUnion P S T).toGroupHom :=
  Hom.bijective_monoid_hom (addRelatorsUnion P S T)
    (bijective_subset_closure P S T hS)

/-- Left union equivalence: inverse cancels the canonical union hom. -/
@[simp] theorem add_union_hom
    (P : Presentation.{u}) (S T : Set P.Free)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → t ∈ (P.addRelators S).rNClos)
    (x : (P.addRelators S).Group) :
    (relatorsUnionSubset P S T hT).symm
        ((addUnionHom P S T).toGroupHom x) = x := by
  rw [← congrFun (congrArg DFunLike.coe
    (union_monoid_hom P S T hT)) x]
  exact (relatorsUnionSubset P S T hT).left_inv x

/-- Left union hom cancels the inverse of the redundant-union equivalence. -/
@[simp] theorem union_hom_symm
    (P : Presentation.{u}) (S T : Set P.Free)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → t ∈ (P.addRelators S).rNClos)
    (y : (P.addRelators (S ∪ T)).Group) :
    (addUnionHom P S T).toGroupHom
        ((relatorsUnionSubset P S T hT).symm y) = y := by
  rw [← congrFun (congrArg DFunLike.coe
    (union_monoid_hom P S T hT))]
  exact (relatorsUnionSubset P S T hT).right_inv y

/-- Right union equivalence: inverse cancels the canonical union hom. -/
@[simp] theorem union_symm_hom
    (P : Presentation.{u}) (S T : Set P.Free)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → s ∈ (P.addRelators T).rNClos)
    (x : (P.addRelators T).Group) :
    (unionSubsetClosure P S T hS).symm
        ((addRelatorsUnion P S T).toGroupHom x) = x := by
  rw [← congrFun (congrArg DFunLike.coe
    (union_subset_monoid P S T hS)) x]
  exact (unionSubsetClosure P S T hS).left_inv x

/-- Right union hom cancels the inverse of the redundant-union equivalence. -/
@[simp] theorem union_right_symm
    (P : Presentation.{u}) (S T : Set P.Free)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → s ∈ (P.addRelators T).rNClos)
    (y : (P.addRelators (S ∪ T)).Group) :
    (addRelatorsUnion P S T).toGroupHom
        ((unionSubsetClosure P S T hS).symm y) = y := by
  rw [← congrFun (congrArg DFunLike.coe
    (union_subset_monoid P S T hS))]
  exact (unionSubsetClosure P S T hS).right_inv y

@[simp] theorem add_relators_union
    (P : Presentation.{u}) (S T : Set P.Free)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → s ∈ (P.addRelators T).rNClos)
    (w : P.Free) :
    unionSubsetClosure P S T hS
        ((P.addRelators T).quotientMap w) =
      (P.addRelators (S ∪ T)).quotientMap w := by
  exact add_union_right P S T w

@[simp] theorem union_subset_symm
    (P : Presentation.{u}) (S T : Set P.Free)
    (hT : ∀ ⦃t : P.Free⦄, t ∈ T → t ∈ (P.addRelators S).rNClos)
    (w : P.Free) :
    (relatorsUnionSubset P S T hT).symm
        ((P.addRelators (S ∪ T)).quotientMap w) =
      (P.addRelators S).quotientMap w := by
  rw [MulEquiv.symm_apply_eq]
  exact (union_left_subset P S T hT w).symm

@[simp] theorem union_subset_closure
    (P : Presentation.{u}) (S T : Set P.Free)
    (hS : ∀ ⦃s : P.Free⦄, s ∈ S → s ∈ (P.addRelators T).rNClos)
    (w : P.Free) :
    (unionSubsetClosure P S T hS).symm
        ((P.addRelators (S ∪ T)).quotientMap w) =
      (P.addRelators T).quotientMap w := by
