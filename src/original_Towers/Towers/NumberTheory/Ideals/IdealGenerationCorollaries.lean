import Mathlib


/-!
# Milne, Algebraic Number Theory, Corollaries 3.15--3.17

Ideals in a Dedekind domain are generated by two elements, with one generator prescribed, and
every nonzero ideal has a nonzero ideal multiple that is principal.  The complementary ideal can
also be chosen coprime to any prescribed nonzero ideal.
-/

namespace Towers.NumberTheory.Milne

variable {A : Type*} [CommRing A] [IsDomain A] [IsDedekindDomain A]

omit [IsDomain A] in
/-- Corollary 3.15: if `I ≤ J` and `I ≠ 0`, then `J = I + (a)` for some `a`. -/
theorem sup_span_singleton {I J : Ideal A} (hIJ : I ≤ J) (hI : I ≠ ⊥) :
    ∃ a : A, J = I ⊔ Ideal.span {a} := by
  obtain ⟨a, ha⟩ := IsDedekindDomain.exists_sup_span_eq hIJ hI
  exact ⟨a, ha.symm⟩

omit [IsDomain A] in
/-- Corollary 3.16: a prescribed nonzero element of an ideal can be completed to a pair of
generators. -/
theorem span_pair {I : Ideal A} {a : A} (haI : a ∈ I) (ha : a ≠ 0) :
    ∃ b : A, I = Ideal.span {a, b} :=
  IsDedekindDomain.exists_eq_span_pair haI ha

omit [IsDomain A] in
/-- The prescribed-generator part of Corollary 3.17: if `a ∈ I` is nonzero, then `(a) = I J`
for a nonzero ideal `J`. -/
theorem nonzero_span_singleton
    {I : Ideal A} {a : A} (haI : a ∈ I) (ha : a ≠ 0) :
    ∃ J : Ideal A, J ≠ ⊥ ∧ I * J = Ideal.span {a} := by
  obtain ⟨J, hJ⟩ : I ∣ Ideal.span {a} :=
    Ideal.dvd_iff_le.mpr (I.span_singleton_le_iff_mem.mpr haI)
  refine ⟨J, ?_, hJ.symm⟩
  intro hJzero
  have hspan : Ideal.span ({a} : Set A) = ⊥ := by simpa [hJzero] using hJ
  exact ha (Ideal.span_singleton_eq_bot.mp hspan)

omit [IsDomain A] in
/-- The basic existence assertion of Corollary 3.17. -/
theorem nonzero_ideal_principal {I : Ideal A} (hI : I ≠ ⊥) :
    ∃ J : Ideal A, J ≠ ⊥ ∧ Submodule.IsPrincipal (I * J) := by
  obtain ⟨a, haI, ha⟩ : ∃ a ∈ I, a ≠ 0 := by
    obtain ⟨a, haI, ha0⟩ := SetLike.exists_of_lt (bot_lt_iff_ne_bot.mpr hI)
    exact ⟨a, haI, by simpa using ha0⟩
  obtain ⟨J, hJ, hmul⟩ :=
    nonzero_span_singleton haI ha
  refine ⟨J, hJ, ?_⟩
  rw [hmul]
  infer_instance

/-- The coprime refinement of Corollary 3.17: the complementary ideal can be chosen coprime to
any prescribed nonzero ideal. -/
theorem coprime_nonzero_principal
    {I C : Ideal A} (hI : I ≠ ⊥) (hC : C ≠ ⊥) :
    ∃ J : Ideal A, J ≠ ⊥ ∧ IsCoprime J C ∧ Submodule.IsPrincipal (I * J) := by
  by_cases hCtop : C = ⊤
  · obtain ⟨J, hJ, hprincipal⟩ := nonzero_ideal_principal hI
    refine ⟨J, hJ, ?_, hprincipal⟩
    rw [Ideal.isCoprime_iff_sup_eq, hCtop]
    exact sup_top_eq J
  have hIC : I * C ≠ ⊥ := mul_ne_zero hI hC
  have hIC_le : I * C ≤ I := Ideal.mul_le_right
  obtain ⟨a, ha⟩ := IsDedekindDomain.exists_sup_span_eq hIC_le hIC
  have haI : a ∈ I := by
    rw [← ha]
    exact (show Ideal.span {a} ≤ I * C ⊔ Ideal.span {a} from le_sup_right)
      (Ideal.mem_span_singleton_self a)
  have ha0 : a ≠ 0 := by
    intro ha0
    subst a
    have hspan0 : Ideal.span ({0} : Set A) = ⊥ :=
      Ideal.span_singleton_eq_bot.mpr rfl
    rw [hspan0, sup_bot_eq] at ha
    apply hCtop
    apply mul_left_cancel₀ hI
    simpa using ha
  obtain ⟨J, hJ, hmul⟩ :=
    nonzero_span_singleton haI ha0
  refine ⟨J, hJ, ?_, ?_⟩
  · rw [Ideal.isCoprime_iff_sup_eq]
    apply mul_left_cancel₀ hI
    calc
      I * (J ⊔ C) = I * J ⊔ I * C := Ideal.mul_sup I J C
      _ = I * C ⊔ Ideal.span {a} := by rw [hmul, sup_comm]
      _ = I := ha
      _ = I * ⊤ := by simp
  · rw [hmul]
    infer_instance

end Towers.NumberTheory.Milne
