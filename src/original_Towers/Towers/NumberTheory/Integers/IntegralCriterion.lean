import Mathlib

/-!
# Milne, Algebraic Number Theory, Proposition 2.4

An element is integral exactly when it stabilizes a nonzero finitely generated submodule.
For the forward implication, the submodule can be taken to be the algebra generated by the
element.
-/

namespace Towers.NumberTheory.Milne

variable (A L : Type*) [CommRing A] [Field L] [Algebra A L]

/-- An element `x` is integral over `A` if and only if it stabilizes a nonzero finitely generated
`A`-submodule of `L`. This is Proposition 2.4. -/
theorem fg_stable_submodule (x : L) :
    IsIntegral A x ↔
      ∃ M : Submodule A L, M ≠ ⊥ ∧ M.FG ∧ ∀ m ∈ M, x • m ∈ M := by
  constructor
  · intro hx
    let S : Subalgebra A L := Algebra.adjoin A {x}
    refine ⟨S.toSubmodule, ?_, hx.fg_adjoin_singleton, ?_⟩
    · intro hbot
      have hone : (1 : L) ∈ S.toSubmodule := S.one_mem
      rw [hbot] at hone
      change (1 : L) = 0 at hone
      exact one_ne_zero hone
    · intro m hm
      change x * m ∈ S
      exact S.mul_mem (Algebra.subset_adjoin (Set.mem_singleton x)) hm
  · rintro ⟨M, hM, hMfg, hx⟩
    exact isIntegral_of_smul_mem_submodule M hM hMfg x hx

end Towers.NumberTheory.Milne
