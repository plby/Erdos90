import Mathlib.Algebra.MonoidAlgebra.Basic
import Mathlib.RingTheory.Ideal.Maps
import Mathlib.RingTheory.Ideal.Quotient.Basic
import Mathlib.RingTheory.Ideal.Quotient.Operations
import Mathlib.LinearAlgebra.Quotient.Basic
import Mathlib.LinearAlgebra.Isomorphisms
import Mathlib.LinearAlgebra.TensorProduct.RightExactness

/-!
# Augmentation for group algebras

This file provides a small, explicit API for the augmentation map of a monoid/group
algebra.  Mathlib has the universal `MonoidAlgebra.lift`, but (at the time of writing)
not a named augmentation ideal/layer API.  We keep the definitions lightweight so later
Zassenhaus/Jennings files can build on stable names.
-/

namespace Submission
namespace GroupAlgebra

noncomputable section


variable (R G : Type*) [CommRing R] [Group G]

/-- The trivial multiplicative character `G →* R`, sending every group element to `1`. -/
def trivialCharacter : G →* R := 1

@[simp] theorem trivialCharacter_apply (g : G) : trivialCharacter R G g = (1 : R) := rfl

/-- The augmentation algebra homomorphism `R[G] →ₐ[R] R`. -/
def augmentation : (MonoidAlgebra R G) →ₐ[R] R :=
  _root_.MonoidAlgebra.lift R R G (trivialCharacter R G)

@[simp] theorem augmentation_of (g : G) :
    augmentation R G (_root_.MonoidAlgebra.of R G g) = (1 : R) := by
  simp [augmentation, trivialCharacter]

@[simp] theorem augmentation_single (g : G) (r : R) :
    augmentation R G (Finsupp.single g r : MonoidAlgebra R G) = r := by
  simp [augmentation, trivialCharacter]

/-- The augmentation ideal, i.e. the kernel of the augmentation map. -/
def augmentationIdeal : Ideal (MonoidAlgebra R G) :=
  RingHom.ker (augmentation R G).toRingHom

/-- Membership in the augmentation ideal is vanishing under augmentation. -/
@[simp] theorem mem_augmentationIdeal {x : MonoidAlgebra R G} :
    x ∈ augmentationIdeal R G ↔ augmentation R G x = 0 := by
  change (augmentation R G).toRingHom x = 0 ↔ _
  rfl


/-- The `R`-submodule spanned by the elementary augmentation differences `g - 1`. -/
def augmentationGeneratorSubmodule : Submodule R (MonoidAlgebra R G) :=
  Submodule.span R (Set.range (fun g : G =>
    (_root_.MonoidAlgebra.of R G g - 1 : MonoidAlgebra R G)))

/-- Each elementary difference belongs to the generator submodule. -/
theorem sub_generator_submodule (g : G) :
    (_root_.MonoidAlgebra.of R G g - 1 : MonoidAlgebra R G) ∈
      augmentationGeneratorSubmodule R G := by
  exact Submodule.subset_span ⟨g, rfl⟩

/-- Subtracting the scalar augmentation leaves an `R`-linear combination of `g - 1` terms. -/
theorem sub_algebra_submodule (x : MonoidAlgebra R G) :
    x - algebraMap R (MonoidAlgebra R G) (augmentation R G x) ∈
      augmentationGeneratorSubmodule R G := by
  refine MonoidAlgebra.induction_on
    (p := fun x : MonoidAlgebra R G =>
      x - algebraMap R (MonoidAlgebra R G) (augmentation R G x) ∈
        augmentationGeneratorSubmodule R G) x ?hM ?hadd ?hsmul
  · intro g
    simpa using (sub_generator_submodule R G g)
  · intro x y hx hy
    have hsum : x + y - algebraMap R (MonoidAlgebra R G) (augmentation R G (x + y)) =
        (x - algebraMap R (MonoidAlgebra R G) (augmentation R G x)) +
        (y - algebraMap R (MonoidAlgebra R G) (augmentation R G y)) := by
      simp [map_add, sub_eq_add_neg, add_assoc, add_comm, add_left_comm]
    rw [hsum]
    exact (augmentationGeneratorSubmodule R G).add_mem hx hy
  · intro r x hx
    have hsc : r • x - algebraMap R (MonoidAlgebra R G) (augmentation R G (r • x)) =
        r • (x - algebraMap R (MonoidAlgebra R G) (augmentation R G x)) := by
      simp only [Algebra.smul_def, map_mul]
      rw [mul_sub]
      congr 1
      simp
    rw [hsc]
    exact (augmentationGeneratorSubmodule R G).smul_mem r hx

/-- The augmentation ideal, as an `R`-submodule, is spanned by the differences `g - 1`. -/
theorem submodule_restrict_scalars :
    augmentationGeneratorSubmodule R G = (augmentationIdeal R G).restrictScalars R := by
  apply le_antisymm
  · apply Submodule.span_le.mpr
    rintro x ⟨g, rfl⟩
    change (_root_.MonoidAlgebra.of R G g - 1 : MonoidAlgebra R G) ∈
      RingHom.ker (augmentation R G).toRingHom
    rw [RingHom.mem_ker]
    simp
  · intro x hx
    change x ∈ augmentationIdeal R G at hx
    rw [mem_augmentationIdeal] at hx
    have h := sub_algebra_submodule R G x
    have h' : x - algebraMap R (MonoidAlgebra R G) 0 ∈ augmentationGeneratorSubmodule R G := by
      simpa [hx] using h
    rw [map_zero, sub_zero] at h'
    exact h'

/-- The ideal generated by the elementary augmentation differences `g - 1`. -/
def augmentationGeneratorIdeal : Ideal (MonoidAlgebra R G) :=
  Ideal.span {x : MonoidAlgebra R G |
    ∃ g : G, x = _root_.MonoidAlgebra.of R G g - 1}

/-- Each elementary difference belongs to the generator ideal. -/
theorem sub_generator_ideal (g : G) :
    (_root_.MonoidAlgebra.of R G g - 1 : MonoidAlgebra R G) ∈
      augmentationGeneratorIdeal R G := by
  apply Ideal.subset_span
  exact ⟨g, rfl⟩

/-- Subtracting the scalar augmentation leaves an element generated by `g - 1` terms. -/
theorem sub_algebra_ideal (x : MonoidAlgebra R G) :
    x - algebraMap R (MonoidAlgebra R G) (augmentation R G x) ∈
      augmentationGeneratorIdeal R G := by
  refine MonoidAlgebra.induction_on
    (p := fun x : MonoidAlgebra R G =>
      x - algebraMap R (MonoidAlgebra R G) (augmentation R G x) ∈
        augmentationGeneratorIdeal R G) x ?hM ?hadd ?hsmul
  · intro g
    simpa [augmentationGeneratorIdeal] using
      (sub_generator_ideal R G g)
  · intro x y hx hy
    have hsum : x + y - algebraMap R (MonoidAlgebra R G) (augmentation R G (x + y)) =
        (x - algebraMap R (MonoidAlgebra R G) (augmentation R G x)) +
        (y - algebraMap R (MonoidAlgebra R G) (augmentation R G y)) := by
      simp [map_add, sub_eq_add_neg, add_assoc, add_comm, add_left_comm]
    rw [hsum]
    exact (augmentationGeneratorIdeal R G).add_mem hx hy
  · intro r x hx
    have hsc : r • x - algebraMap R (MonoidAlgebra R G) (augmentation R G (r • x)) =
        r • (x - algebraMap R (MonoidAlgebra R G) (augmentation R G x)) := by
      simp only [Algebra.smul_def, map_mul]
      rw [mul_sub]
      congr 1
      simp
    rw [hsc]
    rw [Algebra.smul_def]
    exact Ideal.mul_mem_left (augmentationGeneratorIdeal R G)
      (algebraMap R (MonoidAlgebra R G) r) hx

/-- The elementary differences generate a subideal of the augmentation ideal. -/
theorem augmentation_ideal :
    augmentationGeneratorIdeal R G ≤ augmentationIdeal R G := by
  apply Ideal.span_le.mpr
  intro x hx
  rcases hx with ⟨g, rfl⟩
  change (_root_.MonoidAlgebra.of R G g - 1 : MonoidAlgebra R G) ∈
    RingHom.ker (augmentation R G).toRingHom
  rw [RingHom.mem_ker]
  simp

/-- The augmentation ideal is generated by the elementary differences `g - 1`. -/
theorem augmentation_generator_ideal :
    augmentationGeneratorIdeal R G = augmentationIdeal R G := by
  apply le_antisymm
  · exact augmentation_ideal R G
  · intro x hx
    rw [mem_augmentationIdeal] at hx
    have h := sub_algebra_ideal R G x
    have h' : x - algebraMap R (MonoidAlgebra R G) 0 ∈ augmentationGeneratorIdeal R G := by
      simpa [hx] using h
    rw [map_zero, sub_zero] at h'
    exact h' 

/-- Every group element has `g - 1` in the augmentation ideal.  This is the basic
relation underlying dimension subgroups and quotient-kernel calculations. -/
theorem sub_augmentation_ideal (g : G) :
    (_root_.MonoidAlgebra.of R G g - 1 : MonoidAlgebra R G) ∈ augmentationIdeal R G := by
  change (_root_.MonoidAlgebra.of R G g - 1 : MonoidAlgebra R G) ∈
    RingHom.ker (augmentation R G).toRingHom
  rw [RingHom.mem_ker]
  simp

theorem augmentation_ideal_sided : (augmentationIdeal R G).IsTwoSided := by
  dsimp [augmentationIdeal]
  infer_instance

instance : (augmentationIdeal R G).IsTwoSided := augmentation_ideal_sided R G

/-- The `n`th power of the augmentation ideal. We use `n = 0` for the whole algebra. -/
def augmentationPower (n : ℕ) : Ideal (MonoidAlgebra R G) :=
  augmentationIdeal R G ^ n

theorem augmentation_two_sided (n : ℕ) : (augmentationPower R G n).IsTwoSided := by
  dsimp [augmentationPower]
  haveI : (augmentationIdeal R G).IsTwoSided := augmentation_ideal_sided R G
  infer_instance

instance (n : ℕ) : (augmentationPower R G n).IsTwoSided := augmentation_two_sided R G n

@[simp] theorem augmentationPower_zero : augmentationPower R G 0 = ⊤ := by
  simp [augmentationPower]

@[simp] theorem augmentationPower_one : augmentationPower R G 1 = augmentationIdeal R G := by
  exact Submodule.pow_one (augmentationIdeal R G)

/-- Subtracting the scalar augmentation lands in the first augmentation power. -/
theorem sub_algebra_augmentation (x : MonoidAlgebra R G) :
    x - algebraMap R (MonoidAlgebra R G) (augmentation R G x) ∈
      augmentationPower R G 1 := by
  rw [augmentationPower_one, ← augmentation_generator_ideal R G]
  exact sub_algebra_ideal R G x

/-- Augmentation powers form a descending chain. -/
theorem augmentationPower_antitone : Antitone (augmentationPower R G) := by
  intro m n hmn
  dsimp [augmentationPower]
  exact Ideal.pow_le_pow_right hmn



/-- Sums of augmentation powers are governed by the smaller index. -/
theorem augmentation_sup_min (m n : ℕ) :
    augmentationPower R G m ⊔ augmentationPower R G n = augmentationPower R G (min m n) := by
  rcases le_total m n with hmn | hnm
  · have hle : augmentationPower R G n ≤ augmentationPower R G m :=
      augmentationPower_antitone R G hmn
    simpa [min_eq_left hmn] using (sup_eq_left.mpr hle)
  · have hle : augmentationPower R G m ≤ augmentationPower R G n :=
      augmentationPower_antitone R G hnm
    simpa [min_eq_right hnm] using (sup_eq_right.mpr hle)

/-- Intersections of augmentation powers are governed by the larger index. -/
theorem augmentation_inf_max (m n : ℕ) :
    augmentationPower R G m ⊓ augmentationPower R G n = augmentationPower R G (max m n) := by
  apply le_antisymm
  · intro x hx
    have hp : x ∈ augmentationPower R G m ∧ x ∈ augmentationPower R G n := by
      simpa using hx
    rcases le_total m n with hmn | hnm
    · simpa [max_eq_right hmn] using hp.2
    · simpa [max_eq_left hnm] using hp.1
  · intro x hx
    constructor
    · exact augmentationPower_antitone R G (Nat.le_max_left m n) hx
    · exact augmentationPower_antitone R G (Nat.le_max_right m n) hx

/-- Comparable-intersection orientation for augmentation powers. -/
theorem augmentation_inf_right {m n : ℕ} (h : m ≤ n) :
    augmentationPower R G m ⊓ augmentationPower R G n = augmentationPower R G n := by
  rw [augmentation_inf_max]
  simp [max_eq_right h]

/-- Symmetric comparable-intersection orientation for augmentation powers. -/
theorem augmentation_inf_left {m n : ℕ} (h : n ≤ m) :
    augmentationPower R G m ⊓ augmentationPower R G n = augmentationPower R G m := by
  rw [augmentation_inf_max]
  simp [max_eq_left h]

/-- Comparable-join orientation for augmentation powers. -/
theorem augmentation_sup_left {m n : ℕ} (h : m ≤ n) :
    augmentationPower R G m ⊔ augmentationPower R G n = augmentationPower R G m := by
  rw [augmentation_sup_min]
  simp [min_eq_left h]

/-- Symmetric comparable-join orientation for augmentation powers. -/
theorem augmentation_sup_right {m n : ℕ} (h : n ≤ m) :
    augmentationPower R G m ⊔ augmentationPower R G n = augmentationPower R G n := by
  rw [augmentation_sup_min]
  simp [min_eq_right h]

/-- Membership form of the max/intersection rule for augmentation powers. -/
theorem augmentation_power_max {x : MonoidAlgebra R G} {m n : ℕ} :
    x ∈ augmentationPower R G (max m n) ↔
      x ∈ augmentationPower R G m ∧ x ∈ augmentationPower R G n := by
  rw [← augmentation_inf_max (R := R) (G := G) m n]
  rfl

/-- Successive augmentation powers are nested. -/
theorem augmentation_succ (n : ℕ) :
    augmentationPower R G (n + 1) ≤ augmentationPower R G n :=
  augmentationPower_antitone R G (Nat.le_succ n)

/-- Product formula for positive right exponent augmentation powers. -/
theorem augmentation_add_mul {m n : ℕ} (hn : n ≠ 0) :
    augmentationPower R G (m + n) = augmentationPower R G m * augmentationPower R G n := by
  dsimp [augmentationPower]
  exact Submodule.pow_add _ hn

/-- Multiplying elements in augmentation powers adds their indices.  The statement
also covers the zero-index edge case using ideal absorption. -/
theorem mul_augmentation_add {m n : ℕ} {a b : MonoidAlgebra R G}
    (ha : a ∈ augmentationPower R G m) (hb : b ∈ augmentationPower R G n) :
    a * b ∈ augmentationPower R G (m + n) := by
  by_cases hn : n = 0
  · subst n
    simpa using (Ideal.mul_mem_right b (augmentationPower R G m) ha)
  · have hmul : a * b ∈ augmentationPower R G m * augmentationPower R G n :=
      Ideal.mul_mem_mul ha hb
    rw [augmentation_add_mul (R := R) (G := G) (m := m) (n := n) hn]
    exact hmul

/-- Reversed-order version of the augmentation-power product estimate. -/
theorem mul_augmentation_comm {m n : ℕ} {a b : MonoidAlgebra R G}
    (ha : a ∈ augmentationPower R G m) (hb : b ∈ augmentationPower R G n) :
    b * a ∈ augmentationPower R G (m + n) := by
  have h := mul_augmentation_add (R := R) (G := G) hb ha
  simpa [Nat.add_comm] using h

/-- If an element lies in `I^n`, then its `k`th power lies in `I^(n*k)`.
This elementary bookkeeping lemma is useful for Zassenhaus power estimates. -/
theorem pow_power_mul {n k : ℕ} {a : MonoidAlgebra R G}
    (ha : a ∈ augmentationPower R G n) :
    a ^ k ∈ augmentationPower R G (n * k) := by
  by_cases hn : n = 0
  · subst n
    simp [augmentationPower_zero]
  · induction k with
    | zero =>
        dsimp [augmentationPower]
        rw [Submodule.pow_zero]
        change (1 : MonoidAlgebra R G) ∈
          (1 : Submodule (MonoidAlgebra R G) (MonoidAlgebra R G))
        rw [Submodule.one_eq_span]
        exact Submodule.mem_span_singleton_self (1 : MonoidAlgebra R G)
    | succ k ih =>
        have hprod : a ^ k * a ∈
            augmentationPower R G (n * k) * augmentationPower R G n :=
          Ideal.mul_mem_mul ih ha
        dsimp [augmentationPower] at hprod ⊢
        have hpow : augmentationIdeal R G ^ (n * k + n) =
            augmentationIdeal R G ^ (n * k) * augmentationIdeal R G ^ n :=
          Submodule.pow_add _ hn
        rw [← hpow] at hprod
        simpa [pow_succ, Nat.mul_succ, Nat.add_comm, Nat.add_left_comm, Nat.add_assoc]
          using hprod

/-- The augmentation-power ideal regarded as an `R`-submodule of the group algebra. -/
def augmentationPowerSubmodule (n : ℕ) : Submodule R (MonoidAlgebra R G) :=
  (augmentationPower R G n).restrictScalars R

/-- Membership in the submodule version is definitionally membership in the ideal version. -/
@[simp] theorem augmentation_power_submodule {n : ℕ} {x : MonoidAlgebra R G} :
    x ∈ augmentationPowerSubmodule R G n ↔ x ∈ augmentationPower R G n := by
  rfl

/-- The zeroth augmentation-power submodule is the whole group algebra. -/
@[simp] theorem augmentation_submodule_zero :
    augmentationPowerSubmodule R G 0 = ⊤ := by
  ext x
  simp [augmentationPowerSubmodule]

/-- The first augmentation-power submodule is the augmentation ideal as a submodule. -/
@[simp] theorem augmentation_submodule_one :
    augmentationPowerSubmodule R G 1 = (augmentationIdeal R G).restrictScalars R := by
  simp [augmentationPowerSubmodule]

/-- Augmentation-power submodules form a descending chain. -/
theorem augmentation_submodule_antitone : Antitone (augmentationPowerSubmodule R G) := by
  intro m n hmn x hx
  exact augmentationPower_antitone R G hmn hx



/-- Sums of augmentation-power submodules are governed by the smaller index. -/
theorem submodule_sup_min (m n : ℕ) :
    augmentationPowerSubmodule R G m ⊔ augmentationPowerSubmodule R G n =
      augmentationPowerSubmodule R G (min m n) := by
  rcases le_total m n with hmn | hnm
  · have hle : augmentationPowerSubmodule R G n ≤ augmentationPowerSubmodule R G m :=
      augmentation_submodule_antitone R G hmn
    simpa [min_eq_left hmn] using (sup_eq_left.mpr hle)
  · have hle : augmentationPowerSubmodule R G m ≤ augmentationPowerSubmodule R G n :=
      augmentation_submodule_antitone R G hnm
    simpa [min_eq_right hnm] using (sup_eq_right.mpr hle)

/-- Intersections of augmentation-power submodules are governed by the larger index. -/
theorem submodule_inf_max (m n : ℕ) :
    augmentationPowerSubmodule R G m ⊓ augmentationPowerSubmodule R G n =
      augmentationPowerSubmodule R G (max m n) := by
  apply le_antisymm
  · intro x hx
    have hp : x ∈ augmentationPowerSubmodule R G m ∧
        x ∈ augmentationPowerSubmodule R G n := by
      simpa using hx
    rcases le_total m n with hmn | hnm
    · simpa [max_eq_right hmn] using hp.2
    · simpa [max_eq_left hnm] using hp.1
  · intro x hx
    constructor
    · exact augmentation_submodule_antitone R G (Nat.le_max_left m n) hx
    · exact augmentation_submodule_antitone R G (Nat.le_max_right m n) hx

/-- Membership form of the max/intersection rule for augmentation-power submodules. -/
theorem augmentation_submodule_max {x : MonoidAlgebra R G} {m n : ℕ} :
    x ∈ augmentationPowerSubmodule R G (max m n) ↔
      x ∈ augmentationPowerSubmodule R G m ∧
        x ∈ augmentationPowerSubmodule R G n := by
  rw [← submodule_inf_max (R := R) (G := G) m n]
  rfl

/-- Successive augmentation-power submodules are nested. -/
theorem augmentation_submodule_succ (n : ℕ) :
    augmentationPowerSubmodule R G (n + 1) ≤ augmentationPowerSubmodule R G n :=
  augmentation_submodule_antitone R G (Nat.le_succ n)

/-- The denominator submodule for the successive layer `I^n / I^(n+1)`, inside `I^n`. -/
def augmentationLayerDenom (n : ℕ) :
    Submodule R (augmentationPowerSubmodule R G n) :=
  Submodule.comap (augmentationPowerSubmodule R G n).subtype
    (augmentationPowerSubmodule R G (n + 1))

/-- Membership in the layer denominator is exactly membership of the underlying
algebra element in the next augmentation power. -/
@[simp] theorem augmentation_layer_denom {n : ℕ}
    {x : augmentationPowerSubmodule R G n} :
    x ∈ augmentationLayerDenom R G n ↔
      (x : MonoidAlgebra R G) ∈ augmentationPowerSubmodule R G (n + 1) := Iff.rfl

/-- The canonical inclusion of the next power into the current power. -/
def augmentationSuccIncl (n : ℕ) :
    augmentationPowerSubmodule R G (n + 1) →ₗ[R] augmentationPowerSubmodule R G n :=
  (augmentationPowerSubmodule R G (n + 1)).subtype.codRestrict
    (augmentationPowerSubmodule R G n) (fun x =>
      augmentation_submodule_succ R G n x.property)

@[simp] theorem augmentation_incl_coe (n : ℕ)
    (x : augmentationPowerSubmodule R G (n + 1)) :
    ((augmentationSuccIncl R G n x : augmentationPowerSubmodule R G n) :
      MonoidAlgebra R G) = (x : MonoidAlgebra R G) := rfl

/-- The range of the inclusion `I^(n+1) → I^n` is the layer denominator. -/
theorem range_succ_incl (n : ℕ) :
    LinearMap.range (augmentationSuccIncl R G n) = augmentationLayerDenom R G n := by
  ext x
  constructor
  · rintro ⟨y, rfl⟩
    exact y.property
  · intro hx
    refine ⟨⟨(x : MonoidAlgebra R G), hx⟩, ?_⟩
    ext
    rfl

/-- The successive augmentation layer `I^n / I^(n+1)` as an `R`-module. -/
abbrev augmentationLayer (n : ℕ) : Type _ :=
  (augmentationPowerSubmodule R G n) ⧸ augmentationLayerDenom R G n


/-- Reindex augmentation layers along an equality of degrees.  This small wrapper keeps
cast-heavy graded statements readable (for example unit/associativity laws involving
`0 + n`, `n + 0`, and `(l + m) + n`). -/
def augmentationLayerReindex {m n : ℕ} (h : m = n) :
    augmentationLayer R G m ≃ₗ[R] augmentationLayer R G n := by
  subst n
  exact LinearEquiv.refl R _

@[simp] theorem augmentation_layer_rfl (n : ℕ) :
    augmentationLayerReindex R G (rfl : n = n) = LinearEquiv.refl R _ := rfl

@[simp] theorem augmentation_reindex_rfl (n : ℕ)
    (x : augmentationLayer R G n) :
    augmentationLayerReindex R G (rfl : n = n) x = x := rfl

/-- Reindexing a quotient representative just transports the underlying power-submodule
membership proof.  This is the main simp lemma for graded degree casts. -/
@[simp] theorem augmentation_reindex_mk {m n : ℕ} (h : m = n)
    (a : augmentationPowerSubmodule R G m) :
    augmentationLayerReindex R G h (Submodule.Quotient.mk a) =
      Submodule.Quotient.mk
        (⟨(a : MonoidAlgebra R G), by
          subst n
          exact a.property⟩ : augmentationPowerSubmodule R G n) := by
  subst n
  rfl

@[simp] theorem layer_reindex {m n : ℕ} (h : m = n) :
    (augmentationLayerReindex R G h).symm = augmentationLayerReindex R G h.symm := by
  subst n
  rfl


/-- Applying a reindexing equivalence is heterogeneously equal to the original class.
This is often the most convenient way to discharge proof-irrelevance casts in graded
statements. -/
theorem augmentation_reindex_heq {m n : ℕ} (h : m = n)
    (x : augmentationLayer R G m) :
    HEq (augmentationLayerReindex R G h x) x := by
  subst n
  rfl

/-- Reindexing a layer and then reindexing back is the identity. -/
@[simp] theorem augmentation_layer_reindex {m n : ℕ} (h : m = n)
    (x : augmentationLayer R G m) :
    augmentationLayerReindex R G h.symm (augmentationLayerReindex R G h x) = x := by
  subst n
  rfl

/-- Reindexing back and then forward is the identity. -/
@[simp] theorem layer_reindex_symm {m n : ℕ} (h : m = n)
    (x : augmentationLayer R G n) :
    augmentationLayerReindex R G h (augmentationLayerReindex R G h.symm x) = x := by
  subst n
  rfl

/-- Reindexing along a composite equality is the composite reindexing equivalence. -/
theorem augmentation_reindex_trans {l m n : ℕ} (h₁ : l = m) (h₂ : m = n) :
    (augmentationLayerReindex R G h₁).trans (augmentationLayerReindex R G h₂) =
      augmentationLayerReindex R G (h₁.trans h₂) := by
  subst m
  subst n
  rfl

/-- The denominator inside `I^n` is linearly the same as the next power `I^(n+1)`. -/
noncomputable def augmentationDenomNext (n : ℕ) :
    augmentationLayerDenom R G n ≃ₗ[R] augmentationPowerSubmodule R G (n + 1) where
  toFun x := ⟨(x : augmentationPowerSubmodule R G n), x.property⟩
  invFun y := ⟨⟨(y : MonoidAlgebra R G),
      augmentation_submodule_succ R G n y.property⟩, y.property⟩
  left_inv x := by
    ext
    rfl
  right_inv y := by
    ext
    rfl
  map_add' x y := by
    ext
    rfl
  map_smul' a x := by
    ext
    rfl

@[simp] theorem augmentation_denom_next (n : ℕ)
    (x : augmentationLayerDenom R G n) :
    ((augmentationDenomNext R G n x : augmentationPowerSubmodule R G (n + 1)) :
      MonoidAlgebra R G) = (x : augmentationPowerSubmodule R G n) := rfl

@[simp] theorem denom_next_symm (n : ℕ)
    (x : augmentationPowerSubmodule R G (n + 1)) :
    (((augmentationDenomNext R G n).symm x :
        augmentationLayerDenom R G n) : augmentationPowerSubmodule R G n) =
      ⟨(x : MonoidAlgebra R G), augmentation_submodule_succ R G n x.property⟩ := rfl

/-- The augmentation map restricted to the zeroth augmentation power (the whole algebra). -/
def augmentationZeroLinear : augmentationPowerSubmodule R G 0 →ₗ[R] R :=
  (augmentation R G).toLinearMap.domRestrict (augmentationPowerSubmodule R G 0)

/-- The restricted augmentation map in degree zero is surjective. -/
theorem zero_linear_surjective :
    Function.Surjective (augmentationZeroLinear R G) := by
  intro a
  refine ⟨⟨Finsupp.single (1 : G) a, ?_⟩, ?_⟩
  · simp [augmentationPowerSubmodule]
  · simp [augmentationZeroLinear]

/-- The denominator of the zeroth layer is the kernel of restricted augmentation. -/
theorem augmentation_denom_ker :
    augmentationLayerDenom R G 0 = LinearMap.ker (augmentationZeroLinear R G) := by
  ext x
  constructor
  · intro hx
    change (x : MonoidAlgebra R G) ∈ augmentationPowerSubmodule R G 1 at hx
    change augmentationZeroLinear R G x = 0
    simpa [augmentationZeroLinear, augmentationPowerSubmodule, augmentationPower_one,
      augmentationIdeal] using hx
  · intro hx
    change (x : MonoidAlgebra R G) ∈ augmentationPowerSubmodule R G 1
    change augmentationZeroLinear R G x = 0 at hx
    simpa [augmentationZeroLinear, augmentationPowerSubmodule, augmentationPower_one,
      augmentationIdeal] using hx

/-- The zeroth augmentation layer is canonically linearly equivalent to the base ring. -/
noncomputable def augmentationZeroEquiv : augmentationLayer R G 0 ≃ₗ[R] R :=
  (Submodule.quotEquivOfEq _ _ (augmentation_denom_ker R G)).trans
    ((augmentationZeroLinear R G).quotKerEquivOfSurjective
      (zero_linear_surjective R G))

/-- Evaluation formula for the canonical degree-zero layer equivalence. -/
@[simp] theorem augmentation_layer_mk (x : augmentationPowerSubmodule R G 0) :
    augmentationZeroEquiv R G (Submodule.Quotient.mk x) =
      augmentationZeroLinear R G x := by
  unfold augmentationZeroEquiv
  simp [LinearEquiv.trans_apply]

/-- The class of `1` in the zeroth augmentation layer maps to `1`. -/
@[simp] theorem augmentation_mk_one :
    augmentationZeroEquiv R G
      (Submodule.Quotient.mk
        (⟨(1 : MonoidAlgebra R G), by simp [augmentationPowerSubmodule]⟩ :
          augmentationPowerSubmodule R G 0)) = (1 : R) := by
  simp [augmentationZeroLinear]


/-- The distinguished degree-zero class of the unit of the group algebra.  This is the
unit element for the associated-graded multiplication (unit laws are stated with the
usual degree casts in downstream files). -/
def augmentationLayerOne : augmentationLayer R G 0 :=
  Submodule.Quotient.mk
    (⟨(1 : MonoidAlgebra R G), by simp [augmentationPowerSubmodule]⟩ :
      augmentationPowerSubmodule R G 0)

/-- The distinguished degree-zero class corresponds to `1` under the canonical
identification `I^0/I^1 ≃ R`. -/
@[simp] theorem augmentation_layer_one :
    augmentationZeroEquiv R G (augmentationLayerOne R G) = 1 := by
  change augmentationZeroLinear R G
    (⟨(1 : MonoidAlgebra R G), by simp [augmentationPowerSubmodule]⟩ :
      augmentationPowerSubmodule R G 0) = 1
  simp [augmentationZeroLinear]

/-- Explicit representative for the inverse of the degree-zero layer equivalence. -/
@[simp] theorem layer_zero_symm (r : R) :
    (augmentationZeroEquiv R G).symm r =
      Submodule.Quotient.mk
        (⟨algebraMap R (MonoidAlgebra R G) r, by simp [augmentationPowerSubmodule]⟩ :
          augmentationPowerSubmodule R G 0) := by
  apply (augmentationZeroEquiv R G).injective
  simp [augmentationZeroLinear]

/-- The inverse degree-zero equivalence sends scalars to scalar multiples of the
distinguished unit class.  This form avoids exposing the group-algebra
representative in later graded calculations. -/
theorem augmentation_symm_smul (r : R) :
    (augmentationZeroEquiv R G).symm r = r • augmentationLayerOne R G := by
  apply (augmentationZeroEquiv R G).injective
  simp only [LinearEquiv.apply_symm_apply]
  rw [map_smul]
  simp

@[simp] theorem augmentation_smul_one (r : R) :
    augmentationZeroEquiv R G (r • augmentationLayerOne R G) = r := by
  have h := congrArg (augmentationZeroEquiv R G)
    (augmentation_symm_smul (R := R) (G := G) r)
  simpa only [LinearEquiv.apply_symm_apply] using h.symm

@[simp] theorem augmentation_symm_one :
    (augmentationZeroEquiv R G).symm (1 : R) = augmentationLayerOne R G := by
  simpa using augmentation_symm_smul (R := R) (G := G) (1 : R)

@[simp] theorem zero_equiv_symm :
    (augmentationZeroEquiv R G).symm (0 : R) = 0 := by
  exact map_zero (augmentationZeroEquiv R G).symm



/-!
## Multiplication on successive augmentation layers

The following maps package multiplication in the filtered algebra as a bilinear
operation `I^m/I^(m+1) → I^n/I^(n+1) → I^(m+n)/I^(m+n+1)`.  We construct it
by descending multiplication one quotient variable at a time.
-/


/-- Multiplication by a fixed representative in `I^m`, landing in the `(m+n)`-th layer.
This is the first (right-variable) descent step for the associated graded product. -/
def augmentationMulRep (m n : ℕ) (a : augmentationPowerSubmodule R G m) :
    augmentationPowerSubmodule R G n →ₗ[R] augmentationLayer R G (m+n) where
  toFun b :=
    Submodule.Quotient.mk
      (⟨(a : MonoidAlgebra R G) * (b : MonoidAlgebra R G), by
        exact mul_augmentation_add (R := R) (G := G) a.property b.property⟩)
  map_add' b c := by
    apply (Submodule.Quotient.eq (augmentationLayerDenom R G (m+n))).mpr
    change
      (a : MonoidAlgebra R G) *
          ((b + c : augmentationPowerSubmodule R G n) : MonoidAlgebra R G) -
        ((a : MonoidAlgebra R G) * (b : MonoidAlgebra R G) +
          (a : MonoidAlgebra R G) * (c : MonoidAlgebra R G)) ∈
        augmentationPower R G ((m+n)+1)
    simp [mul_add]
  map_smul' r b := by
    apply (Submodule.Quotient.eq (augmentationLayerDenom R G (m+n))).mpr
    change
      (a : MonoidAlgebra R G) *
          ((r • b : augmentationPowerSubmodule R G n) : MonoidAlgebra R G) -
        r • ((a : MonoidAlgebra R G) * (b : MonoidAlgebra R G)) ∈
        augmentationPower R G ((m+n)+1)
    simp only [Algebra.smul_def]
    let s : MonoidAlgebra R G := algebraMap R (MonoidAlgebra R G) r
    have hcomm : (a : MonoidAlgebra R G) * s = s * (a : MonoidAlgebra R G) := by
      exact (Algebra.commutes r (a : MonoidAlgebra R G)).symm
    have hmul : (a : MonoidAlgebra R G) * (s * (b : MonoidAlgebra R G)) =
        s * ((a : MonoidAlgebra R G) * (b : MonoidAlgebra R G)) := by
      calc
        (a : MonoidAlgebra R G) * (s * (b : MonoidAlgebra R G)) =
            ((a : MonoidAlgebra R G) * s) * (b : MonoidAlgebra R G) := by rw [mul_assoc]
        _ = (s * (a : MonoidAlgebra R G)) * (b : MonoidAlgebra R G) := by rw [hcomm]
        _ = s * ((a : MonoidAlgebra R G) * (b : MonoidAlgebra R G)) := by rw [mul_assoc]
    have hbsmul : ((r • b : augmentationPowerSubmodule R G n) : MonoidAlgebra R G) =
        s * (b : MonoidAlgebra R G) := by
      simp [Algebra.smul_def, s]
    rw [hbsmul]
    change (a : MonoidAlgebra R G) * (s * (b : MonoidAlgebra R G)) -
      s * ((a : MonoidAlgebra R G) * (b : MonoidAlgebra R G)) ∈ augmentationPower R G ((m+n)+1)
    rw [hmul]
    simp

/-- If the right representative lies in `I^(n+1)`, multiplication by an `I^m` element
vanishes in the `(m+n)`-th layer. -/
theorem rep_kill_right (m n : ℕ) (a : augmentationPowerSubmodule R G m) :
    augmentationLayerDenom R G n ≤ LinearMap.ker (augmentationMulRep R G m n a) := by
  intro b hb
  rw [LinearMap.mem_ker]
  change Submodule.Quotient.mk _ = (0 : augmentationLayer R G (m+n))
  apply (Submodule.Quotient.mk_eq_zero (augmentationLayerDenom R G (m+n))).2
  change ((a : MonoidAlgebra R G) * (b : MonoidAlgebra R G)) ∈ augmentationPower R G ((m+n)+1)
  have hb' : (b : MonoidAlgebra R G) ∈ augmentationPower R G (n+1) := hb
  have hprod := mul_augmentation_add (R := R) (G := G) a.property hb'
  -- hprod index m + (n+1)
  simpa [Nat.add_assoc] using hprod

/-- Multiplication by a fixed `I^m` representative descends to the right quotient layer. -/
def augmentationLayerRep (m n : ℕ) (a : augmentationPowerSubmodule R G m) :
    augmentationLayer R G n →ₗ[R] augmentationLayer R G (m+n) :=
  (augmentationLayerDenom R G n).liftQ (augmentationMulRep R G m n a)
    (rep_kill_right R G m n a)

/-- Representative formula for multiplication by a fixed left representative. -/
@[simp] theorem augmentation_rep_mk (m n : ℕ) (a : augmentationPowerSubmodule R G m)
    (b : augmentationPowerSubmodule R G n) :
    augmentationLayerRep R G m n a (Submodule.Quotient.mk b) =
      Submodule.Quotient.mk (⟨(a : MonoidAlgebra R G) * (b : MonoidAlgebra R G),
        mul_augmentation_add (R := R) (G := G) a.property b.property⟩ :
          augmentationPowerSubmodule R G (m+n)) := rfl

/-- The previous construction is linear in the left representative before quotienting. -/
def augmentationRepLinear (m n : ℕ) :
    augmentationPowerSubmodule R G m →ₗ[R]
      (augmentationLayer R G n →ₗ[R] augmentationLayer R G (m+n)) where
  toFun a := augmentationLayerRep R G m n a
  map_add' a a' := by
    apply LinearMap.ext
    intro z
    refine Quotient.inductionOn' z ?_
    intro b
    simp only [LinearMap.add_apply]
    apply (Submodule.Quotient.eq (augmentationLayerDenom R G (m+n))).mpr
    change
      ((a + a' : augmentationPowerSubmodule R G m) : MonoidAlgebra R G) *
          (b : MonoidAlgebra R G) -
        ((a : MonoidAlgebra R G) * (b : MonoidAlgebra R G) +
          (a' : MonoidAlgebra R G) * (b : MonoidAlgebra R G)) ∈
        augmentationPower R G ((m+n)+1)
    simp [add_mul]
  map_smul' r a := by
    apply LinearMap.ext
    intro z
    refine Quotient.inductionOn' z ?_
    intro b
    simp only [RingHom.id_apply, LinearMap.smul_apply]
    apply (Submodule.Quotient.eq (augmentationLayerDenom R G (m+n))).mpr
    change ((((r • a : augmentationPowerSubmodule R G m) : MonoidAlgebra R G) *
        (b : MonoidAlgebra R G)) -
      (r • ((a : MonoidAlgebra R G) * (b : MonoidAlgebra R G))) : MonoidAlgebra R G) ∈
        augmentationPower R G ((m+n)+1)
    simp [Algebra.smul_def, mul_assoc]

/-- Left representatives from `I^(m+1)` induce the zero map on the right layer. -/
theorem rep_kill_left (m n : ℕ) :
    augmentationLayerDenom R G m ≤ LinearMap.ker (augmentationRepLinear R G m n) := by
  intro a ha
  rw [LinearMap.mem_ker]
  apply LinearMap.ext
  intro z
  refine Quotient.inductionOn' z ?_
  intro b
  change augmentationLayerRep R G m n a (Submodule.Quotient.mk b) = 0
  rw [augmentation_rep_mk]
  apply (Submodule.Quotient.mk_eq_zero (augmentationLayerDenom R G (m+n))).2
  change ((a : MonoidAlgebra R G) * (b : MonoidAlgebra R G)) ∈ augmentationPower R G ((m+n)+1)
  have ha' : (a : MonoidAlgebra R G) ∈ augmentationPower R G (m+1) := ha
  have hprod := mul_augmentation_add (R := R) (G := G) ha' b.property
  -- index (m+1)+n = (m+n)+1
  simpa [Nat.add_assoc, Nat.add_comm, Nat.add_left_comm] using hprod

/-- The bilinear (curried linear) multiplication on successive augmentation layers. -/
def augmentationLayerMul (m n : ℕ) :
    augmentationLayer R G m →ₗ[R]
      (augmentationLayer R G n →ₗ[R] augmentationLayer R G (m+n)) :=
  (augmentationLayerDenom R G m).liftQ (augmentationRepLinear R G m n)
    (rep_kill_left R G m n)

/-- On representatives, layer multiplication is induced by multiplication in the group algebra. -/
@[simp] theorem augmentation_mul_mk (m n : ℕ)
    (a : augmentationPowerSubmodule R G m) (b : augmentationPowerSubmodule R G n) :
    (augmentationLayerMul R G m n (Submodule.Quotient.mk a)) (Submodule.Quotient.mk b) =
      Submodule.Quotient.mk (⟨(a : MonoidAlgebra R G) * (b : MonoidAlgebra R G),
        mul_augmentation_add (R := R) (G := G) a.property b.property⟩ :
          augmentationPowerSubmodule R G (m+n)) := rfl

/-- Layer multiplication is additive in the left argument. -/
@[simp] theorem augmentation_add_left (m n : ℕ)
    (x x' : augmentationLayer R G m) (y : augmentationLayer R G n) :
    (augmentationLayerMul R G m n (x + x')) y =
      (augmentationLayerMul R G m n x) y + (augmentationLayerMul R G m n x') y := by
  simp

/-- Layer multiplication is additive in the right argument. -/
@[simp] theorem augmentation_add_right (m n : ℕ)
    (x : augmentationLayer R G m) (y y' : augmentationLayer R G n) :
    (augmentationLayerMul R G m n x) (y + y') =
      (augmentationLayerMul R G m n x) y + (augmentationLayerMul R G m n x) y' := by
  simp

/-- Zero in the left argument annihilates layer multiplication. -/
@[simp] theorem augmentation_left_arg (m n : ℕ)
    (y : augmentationLayer R G n) :
    (augmentationLayerMul R G m n 0) y = 0 := by
  simp

/-- Zero in the right argument annihilates layer multiplication. -/
@[simp] theorem augmentation_layer_arg (m n : ℕ)
    (x : augmentationLayer R G m) :
    (augmentationLayerMul R G m n x) 0 = 0 := by
  simp

/-- Layer multiplication is scalar-linear in the left argument. -/
@[simp] theorem augmentation_smul_left (m n : ℕ) (r : R)
    (x : augmentationLayer R G m) (y : augmentationLayer R G n) :
    (augmentationLayerMul R G m n (r • x)) y =
      r • ((augmentationLayerMul R G m n x) y) := by
  simp

/-- Layer multiplication is scalar-linear in the right argument. -/
@[simp] theorem augmentation_smul_right (m n : ℕ) (r : R)
    (x : augmentationLayer R G m) (y : augmentationLayer R G n) :
    (augmentationLayerMul R G m n x) (r • y) =
      r • ((augmentationLayerMul R G m n x) y) := by
  simp



/-- Negation in the left argument passes through layer multiplication. -/
@[simp] theorem augmentation_neg_left (m n : ℕ)
    (x : augmentationLayer R G m) (y : augmentationLayer R G n) :
    (augmentationLayerMul R G m n (-x)) y =
      -((augmentationLayerMul R G m n x) y) := by
  simp

/-- Negation in the right argument passes through layer multiplication. -/
@[simp] theorem augmentation_neg_right (m n : ℕ)
    (x : augmentationLayer R G m) (y : augmentationLayer R G n) :
    (augmentationLayerMul R G m n x) (-y) =
      -((augmentationLayerMul R G m n x) y) := by
  simp

/-- Subtraction in the left argument distributes through layer multiplication. -/
@[simp] theorem augmentation_sub_left (m n : ℕ)
    (x x' : augmentationLayer R G m) (y : augmentationLayer R G n) :
    (augmentationLayerMul R G m n (x - x')) y =
      (augmentationLayerMul R G m n x) y - (augmentationLayerMul R G m n x') y := by
  simp [sub_eq_add_neg]

/-- Subtraction in the right argument distributes through layer multiplication. -/
@[simp] theorem augmentation_sub_right (m n : ℕ)
    (x : augmentationLayer R G m) (y y' : augmentationLayer R G n) :
    (augmentationLayerMul R G m n x) (y - y') =
      (augmentationLayerMul R G m n x) y - (augmentationLayerMul R G m n x) y' := by
  simp [sub_eq_add_neg]


/-- Reindex a tensor product of augmentation layers along equalities of both degrees. -/
def augmentationTensorReindex {m m' n n' : ℕ} (hm : m = m') (hn : n = n') :
    TensorProduct R (augmentationLayer R G m) (augmentationLayer R G n) ≃ₗ[R]
      TensorProduct R (augmentationLayer R G m') (augmentationLayer R G n') :=
  TensorProduct.congr (augmentationLayerReindex R G hm) (augmentationLayerReindex R G hn)

/-- Reindexing a pure tensor reindexes both factors. -/
@[simp] theorem tensor_reindex_tmul {m m' n n' : ℕ}
    (hm : m = m') (hn : n = n')
    (x : augmentationLayer R G m) (y : augmentationLayer R G n) :
    augmentationTensorReindex R G hm hn (TensorProduct.tmul R x y) =
      TensorProduct.tmul R
        (augmentationLayerReindex R G hm x)
        (augmentationLayerReindex R G hn y) := rfl

@[simp] theorem tensor_reindex_rfl (m n : ℕ) :
    augmentationTensorReindex R G (rfl : m = m) (rfl : n = n) =
      LinearEquiv.refl R (TensorProduct R (augmentationLayer R G m) (augmentationLayer R G n)) := by
  apply LinearEquiv.toLinearMap_injective
  apply TensorProduct.ext'
  intro x y
  rfl

@[simp] theorem tensor_reindex {m m' n n' : ℕ}
    (hm : m = m') (hn : n = n') :
    (augmentationTensorReindex R G hm hn).symm =
      augmentationTensorReindex R G hm.symm hn.symm := by
  subst m'
  subst n'
  simp [augmentationTensorReindex]

/-- Reindexing a tensor and then reindexing back is the identity. -/
@[simp] theorem augmentation_reindex_symm {m m' n n' : ℕ}
    (hm : m = m') (hn : n = n')
    (z : TensorProduct R (augmentationLayer R G m) (augmentationLayer R G n)) :
    augmentationTensorReindex R G hm.symm hn.symm
        (augmentationTensorReindex R G hm hn z) = z := by
  subst m'
  subst n'
  simp [augmentationTensorReindex]

/-- Reindexing back and then forward is the identity. -/
@[simp] theorem tensor_reindex_symm {m m' n n' : ℕ}
    (hm : m = m') (hn : n = n')
    (z : TensorProduct R (augmentationLayer R G m') (augmentationLayer R G n')) :
    augmentationTensorReindex R G hm hn
        (augmentationTensorReindex R G hm.symm hn.symm z) = z := by
  subst m'
  subst n'
  simp [augmentationTensorReindex]

theorem tensor_reindex_trans {m₁ m₂ m₃ n₁ n₂ n₃ : ℕ}
    (hm₁ : m₁ = m₂) (hm₂ : m₂ = m₃)
    (hn₁ : n₁ = n₂) (hn₂ : n₂ = n₃) :
    (augmentationTensorReindex R G hm₁ hn₁).trans
        (augmentationTensorReindex R G hm₂ hn₂) =
      augmentationTensorReindex R G (hm₁.trans hm₂) (hn₁.trans hn₂) := by
  subst m₂
  subst m₃
  subst n₂
  subst n₃
  simp [augmentationTensorReindex]

/-- Uncurried tensor-product form of associated-graded layer multiplication. -/
noncomputable def augmentationTensorMul (m n : ℕ) :
    TensorProduct R (augmentationLayer R G m) (augmentationLayer R G n) →ₗ[R]
      augmentationLayer R G (m + n) :=
  TensorProduct.lift (augmentationLayerMul R G m n)

/-- Tensor-product multiplication sends pure tensors to layer products. -/
@[simp] theorem tensor_mul_tmul (m n : ℕ)
    (x : augmentationLayer R G m) (y : augmentationLayer R G n) :
    augmentationTensorMul R G m n (TensorProduct.tmul R x y) =
      (augmentationLayerMul R G m n x) y := rfl

/-- Tensor multiplication commutes with reindexing both tensor factors. -/
theorem tensor_reindex_mul {m m' n n' : ℕ}
    (hm : m = m') (hn : n = n')
    (z : TensorProduct R (augmentationLayer R G m) (augmentationLayer R G n)) :
    augmentationLayerReindex R G (congrArg₂ Nat.add hm hn)
        (augmentationTensorMul R G m n z) =
      augmentationTensorMul R G m' n'
        (augmentationTensorReindex R G hm hn z) := by
  subst m'
  subst n'
  simp

/-- Reverse-orientation form of tensor multiplication compatibility with degree reindexing. -/
theorem tensor_mul_reindex {m m' n n' : ℕ}
    (hm : m = m') (hn : n = n')
    (z : TensorProduct R (augmentationLayer R G m) (augmentationLayer R G n)) :
    augmentationTensorMul R G m' n'
        (augmentationTensorReindex R G hm hn z) =
      augmentationLayerReindex R G (congrArg₂ Nat.add hm hn)
        (augmentationTensorMul R G m n z) := by
  exact (tensor_reindex_mul R G hm hn z).symm

/-- Linear-map form of compatibility between tensor multiplication and degree reindexing. -/
theorem augmentation_tensor_reindex {m m' n n' : ℕ}
    (hm : m = m') (hn : n = n') :
    (augmentationLayerReindex R G (congrArg₂ Nat.add hm hn)).toLinearMap.comp
        (augmentationTensorMul R G m n) =
      (augmentationTensorMul R G m' n').comp
        (augmentationTensorReindex R G hm hn).toLinearMap := by
  apply LinearMap.ext
  intro z
  exact tensor_reindex_mul R G hm hn z

/-- Left unit law for associated-graded multiplication, with the canonical degree
reindexing `0 + n = n`. -/
@[simp] theorem augmentation_layer_left (n : ℕ) (x : augmentationLayer R G n) :
    augmentationLayerReindex R G (Nat.zero_add n)
      ((augmentationLayerMul R G 0 n (augmentationLayerOne R G)) x) = x := by
  refine Quotient.inductionOn' x ?_
  intro b
  change augmentationLayerReindex R G (Nat.zero_add n)
      ((augmentationLayerMul R G 0 n
        (Submodule.Quotient.mk
          (⟨(1 : MonoidAlgebra R G), by simp [augmentationPowerSubmodule]⟩ :
            augmentationPowerSubmodule R G 0))) (Submodule.Quotient.mk b)) = _
  rw [augmentation_mul_mk]
  simp [one_mul]
  rfl

/-- Right unit law for associated-graded multiplication, with the canonical degree
reindexing `n + 0 = n`. -/
@[simp] theorem augmentation_layer_right (n : ℕ) (x : augmentationLayer R G n) :
    augmentationLayerReindex R G (Nat.add_zero n)
      ((augmentationLayerMul R G n 0 x) (augmentationLayerOne R G)) = x := by
  refine Quotient.inductionOn' x ?_
  intro b
  change augmentationLayerReindex R G (Nat.add_zero n)
      ((augmentationLayerMul R G n 0 (Submodule.Quotient.mk b))
        (Submodule.Quotient.mk
          (⟨(1 : MonoidAlgebra R G), by simp [augmentationPowerSubmodule]⟩ :
            augmentationPowerSubmodule R G 0))) = _
  rw [augmentation_mul_mk]
  simp [mul_one]
  rfl

/-- Tensor-product left unit law on pure tensors. -/
@[simp] theorem tensor_left_tmul (n : ℕ)
    (x : augmentationLayer R G n) :
    augmentationLayerReindex R G (Nat.zero_add n)
      (augmentationTensorMul R G 0 n
        (TensorProduct.tmul R (augmentationLayerOne R G) x)) = x := by
  exact augmentation_layer_left R G n x

/-- Tensor-product right unit law on pure tensors. -/
@[simp] theorem augmentation_tensor_tmul (n : ℕ)
    (x : augmentationLayer R G n) :
    augmentationLayerReindex R G (Nat.add_zero n)
      (augmentationTensorMul R G n 0
        (TensorProduct.tmul R x (augmentationLayerOne R G))) = x := by
  simpa using augmentation_layer_right R G n x

/-- Associativity of associated-graded multiplication, with the canonical degree
reindexing `(l + m) + n = l + (m + n)`. -/
@[simp] theorem augmentation_layer_assoc (l m n : ℕ)
    (x : augmentationLayer R G l) (y : augmentationLayer R G m)
    (z : augmentationLayer R G n) :
    augmentationLayerReindex R G (Nat.add_assoc l m n)
      ((augmentationLayerMul R G (l + m) n
        ((augmentationLayerMul R G l m x) y)) z) =
    (augmentationLayerMul R G l (m + n) x)
      ((augmentationLayerMul R G m n y) z) := by
  refine Quotient.inductionOn' x ?_
  intro a
  refine Quotient.inductionOn' y ?_
  intro b
  refine Quotient.inductionOn' z ?_
  intro c
  change augmentationLayerReindex R G (Nat.add_assoc l m n)
      ((augmentationLayerMul R G (l + m) n
        ((augmentationLayerMul R G l m (Submodule.Quotient.mk a))
          (Submodule.Quotient.mk b))) (Submodule.Quotient.mk c)) =
    (augmentationLayerMul R G l (m + n) (Submodule.Quotient.mk a))
      ((augmentationLayerMul R G m n (Submodule.Quotient.mk b))
        (Submodule.Quotient.mk c))
  rw [augmentation_mul_mk]
  rw [augmentation_mul_mk]
  rw [augmentation_mul_mk]
  rw [augmentation_mul_mk]
  simp [mul_assoc]


/-- Tensor-product associativity law on pure tensors, with the canonical reindexing. -/
@[simp] theorem tensor_assoc_tmul (l m n : ℕ)
    (x : augmentationLayer R G l) (y : augmentationLayer R G m)
    (z : augmentationLayer R G n) :
    augmentationLayerReindex R G (Nat.add_assoc l m n)
      (augmentationTensorMul R G (l + m) n
        (TensorProduct.tmul R
          (augmentationTensorMul R G l m (TensorProduct.tmul R x y)) z)) =
    augmentationTensorMul R G l (m + n)
      (TensorProduct.tmul R x
        (augmentationTensorMul R G m n (TensorProduct.tmul R y z))) := by
  exact augmentation_layer_assoc R G l m n x y z

/-- A degree-zero class acts on the left of the associated graded by its scalar
augmentation.  The equality is stated after the canonical `0 + n = n` reindexing. -/
@[simp] theorem augmentation_left_scalar (n : ℕ)
    (x : augmentationLayer R G 0) (y : augmentationLayer R G n) :
    augmentationLayerReindex R G (Nat.zero_add n)
      ((augmentationLayerMul R G 0 n x) y) =
    (augmentationZeroEquiv R G x) • y := by
  refine Quotient.inductionOn' x ?_
  intro a
  refine Quotient.inductionOn' y ?_
  intro b
  change augmentationLayerReindex R G (Nat.zero_add n)
      ((augmentationLayerMul R G 0 n (Submodule.Quotient.mk a))
        (Submodule.Quotient.mk b)) =
    (augmentationZeroEquiv R G (Submodule.Quotient.mk a)) •
      (Submodule.Quotient.mk b : augmentationLayer R G n)
  simp only [augmentation_layer_mk]
  rw [augmentation_mul_mk]
  simp only [augmentation_reindex_mk]
  change Submodule.Quotient.mk
      (⟨(a : MonoidAlgebra R G) * (b : MonoidAlgebra R G), _⟩ :
        augmentationPowerSubmodule R G n) =
    (augmentationZeroLinear R G a) • Submodule.Quotient.mk b
  rw [← Submodule.Quotient.mk_smul]
  apply (Submodule.Quotient.eq (augmentationLayerDenom R G n)).mpr
  change ((a : MonoidAlgebra R G) * (b : MonoidAlgebra R G) -
      ((augmentationZeroLinear R G a) • (b : augmentationPowerSubmodule R G n) :
        augmentationPowerSubmodule R G n) : MonoidAlgebra R G) ∈
    augmentationPower R G (n + 1)
  simp only [Submodule.coe_smul_of_tower]
  have haI := sub_algebra_augmentation R G (a : MonoidAlgebra R G)
  have hb : (b : MonoidAlgebra R G) ∈ augmentationPower R G n := b.property
  have hprod := mul_augmentation_add (R := R) (G := G) haI hb
  simpa [augmentationZeroLinear, sub_mul, Algebra.smul_def, Nat.one_add,
    Nat.add_comm, Nat.add_left_comm, Nat.add_assoc] using hprod

/-- A degree-zero class acts on the right of the associated graded by the same scalar
augmentation.  Centrality of the base algebra map is used to commute the scalar past a
representative. -/
@[simp] theorem augmentation_layer_scalar (n : ℕ)
    (y : augmentationLayer R G n) (x : augmentationLayer R G 0) :
    augmentationLayerReindex R G (Nat.add_zero n)
      ((augmentationLayerMul R G n 0 y) x) =
    (augmentationZeroEquiv R G x) • y := by
  refine Quotient.inductionOn' y ?_
  intro b
  refine Quotient.inductionOn' x ?_
  intro a
  change augmentationLayerReindex R G (Nat.add_zero n)
      ((augmentationLayerMul R G n 0 (Submodule.Quotient.mk b))
        (Submodule.Quotient.mk a)) =
    (augmentationZeroEquiv R G (Submodule.Quotient.mk a)) •
      (Submodule.Quotient.mk b : augmentationLayer R G n)
  simp only [augmentation_layer_mk]
  rw [augmentation_mul_mk]
  simp only [augmentation_reindex_mk]
  change Submodule.Quotient.mk
      (⟨(b : MonoidAlgebra R G) * (a : MonoidAlgebra R G), _⟩ :
        augmentationPowerSubmodule R G n) =
    (augmentationZeroLinear R G a) • Submodule.Quotient.mk b
  rw [← Submodule.Quotient.mk_smul]
  apply (Submodule.Quotient.eq (augmentationLayerDenom R G n)).mpr
  change ((b : MonoidAlgebra R G) * (a : MonoidAlgebra R G) -
      ((augmentationZeroLinear R G a) • (b : augmentationPowerSubmodule R G n) :
        augmentationPowerSubmodule R G n) : MonoidAlgebra R G) ∈
    augmentationPower R G (n + 1)
  simp only [Submodule.coe_smul_of_tower]
  have haI := sub_algebra_augmentation R G (a : MonoidAlgebra R G)
  have hb : (b : MonoidAlgebra R G) ∈ augmentationPower R G n := b.property
  have hprod := mul_augmentation_add (R := R) (G := G) hb haI
  rw [mul_sub] at hprod
  have hc : (b : MonoidAlgebra R G) *
        algebraMap R (MonoidAlgebra R G) (augmentation R G (a : MonoidAlgebra R G)) =
      algebraMap R (MonoidAlgebra R G) (augmentation R G (a : MonoidAlgebra R G)) *
        (b : MonoidAlgebra R G) := by
    exact (Algebra.commutes (augmentation R G (a : MonoidAlgebra R G))
      (b : MonoidAlgebra R G)).symm
  rw [hc] at hprod
  simpa [augmentationZeroLinear, Algebra.smul_def, Nat.add_comm, Nat.add_left_comm,
    Nat.add_assoc] using hprod


/-- Scalar-specialized form of left degree-zero multiplication. -/
@[simp] theorem augmentation_scalar_left (n : ℕ) (r : R)
    (y : augmentationLayer R G n) :
    augmentationLayerReindex R G (Nat.zero_add n)
      ((augmentationLayerMul R G 0 n ((augmentationZeroEquiv R G).symm r)) y) =
    r • y := by
  have h := augmentation_left_scalar R G n
    ((augmentationZeroEquiv R G).symm r) y
  rw [(augmentationZeroEquiv R G).apply_symm_apply r] at h
  exact h

/-- Scalar-specialized form of right degree-zero multiplication. -/
@[simp] theorem augmentation_scalar_right (n : ℕ) (r : R)
    (y : augmentationLayer R G n) :
    augmentationLayerReindex R G (Nat.add_zero n)
      ((augmentationLayerMul R G n 0 y) ((augmentationZeroEquiv R G).symm r)) =
    r • y := by
  have h := augmentation_layer_scalar R G n y
    ((augmentationZeroEquiv R G).symm r)
  simpa [augmentationZeroLinear] using h

/-- Tensor-product scalar-specialized left degree-zero multiplication on pure tensors. -/
@[simp] theorem augmentation_scalar_tmul (n : ℕ) (r : R)
    (y : augmentationLayer R G n) :
    augmentationLayerReindex R G (Nat.zero_add n)
      (augmentationTensorMul R G 0 n
        (TensorProduct.tmul R ((augmentationZeroEquiv R G).symm r) y)) =
    r • y := by
  exact augmentation_scalar_left R G n r y

/-- Tensor-product scalar-specialized right degree-zero multiplication on pure tensors. -/
@[simp] theorem tensor_scalar_tmul (n : ℕ) (r : R)
    (y : augmentationLayer R G n) :
    augmentationLayerReindex R G (Nat.add_zero n)
      (augmentationTensorMul R G n 0
        (TensorProduct.tmul R y ((augmentationZeroEquiv R G).symm r))) =
    r • y := by
  exact augmentation_scalar_right R G n r y

/-- Layer multiplication commutes with reindexing both input degrees (and hence the
output degree).  This is the cast-management lemma used for graded associativity/unit
statements. -/
theorem augmentation_reindex_mul {m m' n n' : ℕ} (hm : m = m') (hn : n = n')
    (x : augmentationLayer R G m) (y : augmentationLayer R G n) :
    augmentationLayerReindex R G (congrArg₂ Nat.add hm hn)
        ((augmentationLayerMul R G m n x) y) =
      (augmentationLayerMul R G m' n'
        (augmentationLayerReindex R G hm x))
        (augmentationLayerReindex R G hn y) := by
  subst m'
  subst n'
  rfl


/-- Reverse-orientation form of layer multiplication compatibility with degree reindexing. -/
theorem augmentation_mul_reindex {m m' n n' : ℕ} (hm : m = m') (hn : n = n')
    (x : augmentationLayer R G m) (y : augmentationLayer R G n) :
    (augmentationLayerMul R G m' n'
        (augmentationLayerReindex R G hm x))
        (augmentationLayerReindex R G hn y) =
      augmentationLayerReindex R G (congrArg₂ Nat.add hm hn)
        ((augmentationLayerMul R G m n x) y) := by
  exact (augmentation_reindex_mul R G hm hn x y).symm



/-- The truncated group algebra `R[G] / I^n`. This is often convenient before passing to layers. -/
abbrev augmentationTruncation (n : ℕ) : Type _ :=
  (MonoidAlgebra R G) ⧸ augmentationPower R G n

/-- The zeroth truncation is the quotient by the top ideal, hence every element is zero. -/
theorem augmentation_zero
    (q : augmentationTruncation R G 0) : q = 0 := by
  refine Quotient.inductionOn' q ?_
  intro x
  change Ideal.Quotient.mk (augmentationPower R G 0) x = 0
  rw [Ideal.Quotient.eq_zero_iff_mem]
  simp [augmentationPower_zero]

/-- The zeroth augmentation truncation is subsingleton. -/
theorem augmentation_truncation_subsingleton :
    Subsingleton (augmentationTruncation R G 0) :=
  ⟨fun a b => by
    rw [augmentation_zero R G a,
      augmentation_zero R G b]⟩

/-- The canonical quotient map between truncations: if `m ≤ n`, then
`I^n ≤ I^m`, hence `R[G]/I^n → R[G]/I^m`. -/
def augmentationTruncationMap {m n : ℕ} (hmn : m ≤ n) :
    augmentationTruncation R G n →+* augmentationTruncation R G m :=
  Ideal.quotientMap (augmentationPower R G m) (RingHom.id (MonoidAlgebra R G)) (by
    intro x hx
    change x ∈ augmentationPower R G m
    exact augmentationPower_antitone R G hmn hx)

/-- Every transition into the zeroth truncation is the zero map (the target is the
quotient by the top ideal). -/
theorem truncation_map_to {n : ℕ} (h0n : 0 ≤ n)
    (q : augmentationTruncation R G n) :
    augmentationTruncationMap R G h0n q = 0 :=
  augmentation_zero R G _

@[simp] theorem truncation_mk {m n : ℕ} (hmn : m ≤ n)
    (x : MonoidAlgebra R G) :
    augmentationTruncationMap R G hmn (Ideal.Quotient.mk (augmentationPower R G n) x) =
      Ideal.Quotient.mk (augmentationPower R G m) x := by
  simp [augmentationTruncationMap, Ideal.quotientMap_mk]

@[simp] theorem truncation_id (n : ℕ) :
    augmentationTruncationMap R G (le_refl n) = RingHom.id (augmentationTruncation R G n) := by
  apply RingHom.ext
  intro q
  refine Quotient.inductionOn' q ?_
  intro x
  change augmentationTruncationMap R G (le_refl n) (Ideal.Quotient.mk (augmentationPower R G n) x) =
      (RingHom.id (augmentationTruncation R G n)) (Ideal.Quotient.mk (augmentationPower R G n) x)
  simp [truncation_mk]

@[simp] theorem truncation_comp {l m n : ℕ} (hlm : l ≤ m) (hmn : m ≤ n) :
    (augmentationTruncationMap R G hlm).comp (augmentationTruncationMap R G hmn) =
      augmentationTruncationMap R G (le_trans hlm hmn) := by
  apply RingHom.ext
  intro q
  refine Quotient.inductionOn' q ?_
  intro x
  change augmentationTruncationMap R G hlm
        (augmentationTruncationMap R G hmn (Ideal.Quotient.mk (augmentationPower R G n) x)) =
      augmentationTruncationMap R G (le_trans hlm hmn)
        (Ideal.Quotient.mk (augmentationPower R G n) x)
  simp [truncation_mk]

/-- The underlying `R`-linear map of a truncation transition. -/
noncomputable def augmentationLinear {m n : ℕ} (hmn : m ≤ n) :
    augmentationTruncation R G n →ₗ[R] augmentationTruncation R G m where
  toFun := augmentationTruncationMap R G hmn
  map_add' := by intro x y; exact map_add _ x y
  map_smul' := by
    intro r x
    refine Quotient.inductionOn' x ?_
    intro a
    change augmentationTruncationMap R G hmn
        (r • Ideal.Quotient.mk (augmentationPower R G n) a) =
      r • augmentationTruncationMap R G hmn
        (Ideal.Quotient.mk (augmentationPower R G n) a)
    simp only [Algebra.smul_def, truncation_mk]
    rw [← Ideal.Quotient.mk_algebraMap R (augmentationPower R G m) r]
    rfl

@[simp] theorem truncation_linear {m n : ℕ} (hmn : m ≤ n)
    (q : augmentationTruncation R G n) :
    augmentationLinear R G hmn q = augmentationTruncationMap R G hmn q := rfl

/-- The linear transition map into the zeroth truncation is pointwise zero. -/
@[simp] theorem augmentation_linear_zero {n : ℕ} (h0n : 0 ≤ n)
    (q : augmentationTruncation R G n) :
    augmentationLinear R G h0n q = 0 := by
  change augmentationTruncationMap R G h0n q = 0
  exact truncation_map_to R G h0n q

/-- Linear-map form of the collapse of transitions into the zeroth truncation. -/
@[simp] theorem truncation_linear_zero {n : ℕ} (h0n : 0 ≤ n) :
    augmentationLinear R G h0n = 0 := by
  apply LinearMap.ext
  intro q
  exact augmentation_linear_zero R G h0n q

/-- The kernel of a transition into the zeroth truncation is the whole source. -/
@[simp] theorem augmentation_truncation_top {n : ℕ} (h0n : 0 ≤ n) :
    LinearMap.ker (augmentationLinear R G h0n) = ⊤ := by
  rw [truncation_linear_zero]
  exact LinearMap.ker_zero

/-- The range of a transition into the zeroth truncation is bottom. -/
@[simp] theorem truncation_range_bot {n : ℕ} (h0n : 0 ≤ n) :
    LinearMap.range (augmentationLinear R G h0n) = ⊥ := by
  rw [truncation_linear_zero]
  exact LinearMap.range_zero

@[simp] theorem augmentation_linear_mk {m n : ℕ} (hmn : m ≤ n)
    (x : MonoidAlgebra R G) :
    augmentationLinear R G hmn
        (Ideal.Quotient.mk (augmentationPower R G n) x) =
      Ideal.Quotient.mk (augmentationPower R G m) x := by
  exact truncation_mk R G hmn x

@[simp] theorem truncation_linear_id (n : ℕ) :
    augmentationLinear R G (le_refl n) =
      LinearMap.id := by
  apply LinearMap.ext
  intro q
  simp

@[simp] theorem augmentation_linear_comp {l m n : ℕ}
    (hlm : l ≤ m) (hmn : m ≤ n) :
    (augmentationLinear R G hlm).comp
        (augmentationLinear R G hmn) =
      augmentationLinear R G (le_trans hlm hmn) := by
  apply LinearMap.ext
  intro q
  simp [← RingHom.comp_apply, truncation_comp]

/-- On representatives, the transition map is zero exactly when the representative
already lies in the smaller power. -/
@[simp] theorem augmentation_truncation_mk {m n : ℕ} (hmn : m ≤ n)
    (x : MonoidAlgebra R G) :
    augmentationTruncationMap R G hmn
        (Ideal.Quotient.mk (augmentationPower R G n) x) = 0 ↔
      x ∈ augmentationPower R G m := by
  rw [truncation_mk]
  exact Ideal.Quotient.eq_zero_iff_mem

/-- Transition maps between augmentation truncations are surjective. -/
theorem truncation_surjective {m n : ℕ} (hmn : m ≤ n) :
    Function.Surjective (augmentationTruncationMap R G hmn) := by
  intro q
  refine Quotient.inductionOn' q ?_
  intro x
  refine ⟨Ideal.Quotient.mk (augmentationPower R G n) x, ?_⟩
  change augmentationTruncationMap R G hmn
      (Ideal.Quotient.mk (augmentationPower R G n) x) =
    Ideal.Quotient.mk (augmentationPower R G m) x
  simp [truncation_mk]

/-- Linear truncation transitions are surjective. -/
theorem augmentation_linear_surjective {m n : ℕ} (hmn : m ≤ n) :
    Function.Surjective (augmentationLinear R G hmn) :=
  truncation_surjective R G hmn

/-- Range form of surjectivity for linear truncation transitions. -/
theorem truncation_range_top {m n : ℕ} (hmn : m ≤ n) :
    LinearMap.range (augmentationLinear R G hmn) = ⊤ :=
  LinearMap.range_eq_top.mpr (augmentation_linear_surjective R G hmn)

/-- Identity transitions have trivial kernel. -/
@[simp] theorem truncation_id_bot (n : ℕ) :
    LinearMap.ker (augmentationLinear R G (le_refl n)) = ⊥ := by
  rw [truncation_linear_id]
  exact LinearMap.ker_id

/-- Identity transitions have full range. -/
@[simp] theorem truncation_id_top (n : ℕ) :
    LinearMap.range (augmentationLinear R G (le_refl n)) = ⊤ := by
  rw [truncation_linear_id]
  exact LinearMap.range_id

/-- Representative criterion for the kernel of the linear truncation transition. -/
@[simp] theorem ker_truncation_mk {m n : ℕ} (hmn : m ≤ n)
    (x : MonoidAlgebra R G) :
    Ideal.Quotient.mk (augmentationPower R G n) x ∈
        LinearMap.ker (augmentationLinear R G hmn) ↔
      x ∈ augmentationPower R G m := by
  rw [LinearMap.mem_ker]
  change augmentationLinear R G hmn
      (Ideal.Quotient.mk (augmentationPower R G n) x) = 0 ↔ _
  rw [augmentation_linear_mk]
  exact Ideal.Quotient.eq_zero_iff_mem

/-- Concrete kernel description for a linear truncation transition. -/
theorem ker_truncation_linear {m n : ℕ} (hmn : m ≤ n)
    (q : augmentationTruncation R G n) :
    q ∈ LinearMap.ker (augmentationLinear R G hmn) ↔
      ∃ x : MonoidAlgebra R G, x ∈ augmentationPower R G m ∧
        q = Ideal.Quotient.mk (augmentationPower R G n) x := by
  refine Quotient.inductionOn' q ?_
  intro x
  constructor
  · intro hx
    exact ⟨x, (ker_truncation_mk R G hmn x).1 hx, rfl⟩
  · rintro ⟨y, hy, hxy⟩
    rw [hxy]
    exact (ker_truncation_mk R G hmn y).2 hy

/-- Concrete kernel description for a truncation transition: a class modulo `I^n`
lies in the kernel of `R[G]/I^n → R[G]/I^m` iff it has a representative in `I^m`. -/
theorem ker_augmentation_truncation {m n : ℕ} (hmn : m ≤ n)
    (q : augmentationTruncation R G n) :
    q ∈ RingHom.ker (augmentationTruncationMap R G hmn) ↔
      ∃ x : MonoidAlgebra R G, x ∈ augmentationPower R G m ∧
        q = Ideal.Quotient.mk (augmentationPower R G n) x := by
  refine Quotient.inductionOn' q ?_
  intro x
  constructor
  · intro hx
    change augmentationTruncationMap R G hmn
        (Ideal.Quotient.mk (augmentationPower R G n) x) = 0 at hx
    rw [augmentation_truncation_mk (R := R) (G := G) hmn] at hx
    exact ⟨x, hx, rfl⟩
  · rintro ⟨y, hy, hxy⟩
    rw [RingHom.mem_ker]
    change augmentationTruncationMap R G hmn
        (Ideal.Quotient.mk (augmentationPower R G n) x) = 0
    change Ideal.Quotient.mk (augmentationPower R G n) x =
        Ideal.Quotient.mk (augmentationPower R G n) y at hxy
    rw [hxy]
    rw [augmentation_truncation_mk (R := R) (G := G) hmn]
    exact hy



/-- The augmentation map is surjective (scalars give a section). -/
theorem augmentation_surjective : Function.Surjective (augmentation R G).toRingHom := by
  intro r
  refine ⟨algebraMap R (MonoidAlgebra R G) r, ?_⟩
  simp [augmentation]

/-- The first augmentation truncation `R[G]/I` is canonically the coefficient ring. -/
noncomputable def augmentationTruncationOne : augmentationTruncation R G 1 ≃+* R :=
  (Ideal.quotEquivOfEq (augmentationPower_one R G)).trans
    ((augmentation R G).toRingHom.quotientKerEquivOfSurjective
      (augmentation_surjective R G))

@[simp] theorem truncation_equiv_mk (x : MonoidAlgebra R G) :
    augmentationTruncationOne R G
        (Ideal.Quotient.mk (augmentationPower R G 1) x) = augmentation R G x := by
  change ((augmentation R G).toRingHom.quotientKerEquivOfSurjective
      (augmentation_surjective R G))
      (Ideal.Quotient.mk (RingHom.ker (augmentation R G).toRingHom) x) =
    (augmentation R G).toRingHom x
  exact RingHom.quotientKerEquivOfSurjective_apply_mk
    (augmentation_surjective R G) x

@[simp] theorem truncation_equiv_symm (r : R) :
    (augmentationTruncationOne R G).symm r =
      Ideal.Quotient.mk (augmentationPower R G 1)
        (algebraMap R (MonoidAlgebra R G) r) := by
  apply (augmentationTruncationOne R G).injective
  simp [truncation_equiv_mk]

/-- Linear version of the canonical identification `R[G]/I ≃ R`. -/
noncomputable def augmentationLinearEquiv :
    augmentationTruncation R G 1 ≃ₗ[R] R where
  toFun := augmentationTruncationOne R G
  invFun := (augmentationTruncationOne R G).symm
  left_inv q := (augmentationTruncationOne R G).left_inv q
  right_inv r := (augmentationTruncationOne R G).right_inv r
  map_add' q q' := map_add (augmentationTruncationOne R G) q q'
  map_smul' r q := by
    refine Quotient.inductionOn' q ?_
    intro x
    change augmentationTruncationOne R G
        (r • Ideal.Quotient.mk (augmentationPower R G 1) x) =
      r • augmentationTruncationOne R G
        (Ideal.Quotient.mk (augmentationPower R G 1) x)
    rw [Algebra.smul_def]
    simp only [map_mul, truncation_equiv_mk]
    congr 1
    change augmentationTruncationOne R G
        (Ideal.Quotient.mk (augmentationPower R G 1) (algebraMap R (MonoidAlgebra R G) r)) = r
    simp [truncation_equiv_mk]

@[simp] theorem truncation_linear_equiv (q : augmentationTruncation R G 1) :
    augmentationLinearEquiv R G q = augmentationTruncationOne R G q := rfl

@[simp] theorem augmentation_linear_symm (r : R) :
    (augmentationLinearEquiv R G).symm r =
      (augmentationTruncationOne R G).symm r := rfl



/-- Representatives in `I^n` map linearly to the `(n+1)`st truncation.  This is
 the raw map whose quotient is the usual inclusion of the graded piece into the
 kernel of `R[G]/I^(n+1) → R[G]/I^n`. -/
def augmentationRepTruncation (n : ℕ) :
    augmentationPowerSubmodule R G n →ₗ[R] augmentationTruncation R G (n + 1) where
  toFun x := Ideal.Quotient.mk (augmentationPower R G (n + 1))
    (x : MonoidAlgebra R G)
  map_add' x y := by
    change Ideal.Quotient.mk _ ((x : MonoidAlgebra R G) + (y : MonoidAlgebra R G)) = _
    simp
  map_smul' r x := by
    change Ideal.Quotient.mk _ (r • (x : MonoidAlgebra R G)) = _
    simp [Algebra.smul_def, ← Ideal.Quotient.mk_algebraMap]

/-- The denominator `I^(n+1)` is killed by the representative-to-truncation map. -/
theorem denom_rep_truncation (n : ℕ) :
    augmentationLayerDenom R G n ≤
      LinearMap.ker (augmentationRepTruncation R G n) := by
  intro x hx
  rw [LinearMap.mem_ker]
  change Ideal.Quotient.mk (augmentationPower R G (n + 1))
      (x : MonoidAlgebra R G) = 0
  rw [Ideal.Quotient.eq_zero_iff_mem]
  exact hx

/-- The canonical injection of the graded piece `I^n/I^(n+1)` into the truncation
`R[G]/I^(n+1)`.  Its range is exactly the kernel of the transition to `R[G]/I^n`. -/
def layerTruncation (n : ℕ) :
    augmentationLayer R G n →ₗ[R] augmentationTruncation R G (n + 1) :=
  (augmentationLayerDenom R G n).liftQ (augmentationRepTruncation R G n)
    (denom_rep_truncation R G n)

@[simp] theorem layer_truncation_mk (n : ℕ)
    (x : augmentationPowerSubmodule R G n) :
    layerTruncation R G n (Submodule.Quotient.mk x) =
      Ideal.Quotient.mk (augmentationPower R G (n + 1))
        (x : MonoidAlgebra R G) := rfl

/-- In degree zero, the layer inclusion into the first truncation agrees with the
canonical augmentations on both sides. -/
@[simp] theorem augmentation_truncation_zero
    (x : augmentationLayer R G 0) :
    augmentationLinearEquiv R G
        (layerTruncation R G 0 x) =
      augmentationZeroEquiv R G x := by
  refine Quotient.inductionOn' x ?_
  intro a
  change augmentationLinearEquiv R G
      (layerTruncation R G 0 (Submodule.Quotient.mk a)) =
    augmentationZeroEquiv R G (Submodule.Quotient.mk a)
  rw [layer_truncation_mk, truncation_linear_equiv,
    truncation_equiv_mk, augmentation_layer_mk]
  rfl

/-- The inverse identifications are compatible with the degree-zero inclusion into
the first truncation. -/
@[simp] theorem truncation_zero_symm (r : R) :
    layerTruncation R G 0 ((augmentationZeroEquiv R G).symm r) =
      (augmentationLinearEquiv R G).symm r := by
  apply (augmentationLinearEquiv R G).injective
  rw [augmentation_truncation_zero]
  simp [augmentationZeroLinear]

/-- The distinguished degree-zero unit maps to the scalar unit in the first truncation. -/
@[simp] theorem augmentation_truncation_one :
    layerTruncation R G 0 (augmentationLayerOne R G) =
      (augmentationLinearEquiv R G).symm (1 : R) := by
  rw [← augmentation_symm_one (R := R) (G := G)]
  exact truncation_zero_symm (R := R) (G := G) (1 : R)

/-- The image of `I^n/I^(n+1)` inside `R[G]/I^(n+1)` is exactly the kernel of the
successive truncation map. -/
theorem range_augmentation_truncation (n : ℕ)
    (q : augmentationTruncation R G (n + 1)) :
    q ∈ LinearMap.range (layerTruncation R G n) ↔
      q ∈ RingHom.ker (augmentationTruncationMap R G (Nat.le_succ n)) := by
  constructor
  · rintro ⟨z, rfl⟩
    refine Quotient.inductionOn' z ?_
    intro x
    rw [RingHom.mem_ker]
    change augmentationTruncationMap R G (Nat.le_succ n)
        (Ideal.Quotient.mk (augmentationPower R G (n + 1))
          (x : MonoidAlgebra R G)) = 0
    rw [augmentation_truncation_mk]
    exact x.property
  · intro hq
    rcases (ker_augmentation_truncation (R := R) (G := G)
        (Nat.le_succ n) q).mp hq with ⟨x, hx, rfl⟩
    refine ⟨Submodule.Quotient.mk
      (⟨x, hx⟩ : augmentationPowerSubmodule R G n), ?_⟩
    simp [layer_truncation_mk]

/-- The canonical map from a graded piece into the next truncation is injective. -/
theorem layer_truncation_injective (n : ℕ) :
    Function.Injective (layerTruncation R G n) := by
  intro a
  refine Quotient.inductionOn' a ?_
  intro x b
  refine Quotient.inductionOn' b ?_
  intro y hab
  change layerTruncation R G n (Submodule.Quotient.mk x) =
      layerTruncation R G n (Submodule.Quotient.mk y) at hab
  change Ideal.Quotient.mk (augmentationPower R G (n + 1)) (x : MonoidAlgebra R G) =
      Ideal.Quotient.mk (augmentationPower R G (n + 1)) (y : MonoidAlgebra R G) at hab
  apply (Submodule.Quotient.eq (augmentationLayerDenom R G n)).mpr
  change (x : MonoidAlgebra R G) - (y : MonoidAlgebra R G) ∈
    augmentationPower R G (n + 1)
  exact (Ideal.Quotient.eq).mp hab
/-- The kernel of the successive truncation map, viewed as an `R`-submodule. -/
noncomputable def augmentationTruncationSubmodule (n : ℕ) :
    Submodule R (augmentationTruncation R G (n + 1)) :=
  (RingHom.ker (augmentationTruncationMap R G (Nat.le_succ n))).restrictScalars R

@[simp] theorem truncation_kernel_submodule (n : ℕ)
    (q : augmentationTruncation R G (n + 1)) :
    q ∈ augmentationTruncationSubmodule R G n ↔
      q ∈ RingHom.ker (augmentationTruncationMap R G (Nat.le_succ n)) := Iff.rfl

/-- The ring-kernel submodule agrees with the kernel of the underlying linear transition. -/
theorem truncation_submodule_ker (n : ℕ) :
    augmentationTruncationSubmodule R G n =
      LinearMap.ker (augmentationLinear R G (Nat.le_succ n)) := by
  ext q
  change q ∈ RingHom.ker (augmentationTruncationMap R G (Nat.le_succ n)) ↔
    q ∈ LinearMap.ker (augmentationLinear R G (Nat.le_succ n))
  rw [RingHom.mem_ker, LinearMap.mem_ker]
  rfl

/-- In degree zero the successive truncation kernel is the whole first truncation. -/
@[simp] theorem truncation_submodule_top :
    augmentationTruncationSubmodule R G 0 = ⊤ := by
  rw [truncation_submodule_ker]
  exact augmentation_truncation_top R G (Nat.zero_le 1)


/-- Submodule form of the range/kernel exactness for successive truncations. -/
theorem range_truncation_submodule (n : ℕ) :
    LinearMap.range (layerTruncation R G n) =
      augmentationTruncationSubmodule R G n := by
  ext q
  exact range_augmentation_truncation R G n q

/-- The degree-zero layer inclusion has full range in the first truncation. -/
@[simp] theorem range_truncation_top :
    LinearMap.range (layerTruncation R G 0) = ⊤ := by
  rw [range_truncation_submodule,
    truncation_submodule_top]

/-- In degree zero, the layer inclusion is a linear equivalence onto the first truncation. -/
noncomputable def augmentationTruncationLinear :
    augmentationLayer R G 0 ≃ₗ[R] augmentationTruncation R G 1 :=
  LinearEquiv.ofBijective (layerTruncation R G 0)
    ⟨layer_truncation_injective R G 0,
      LinearMap.range_eq_top.mp (range_truncation_top R G)⟩

@[simp] theorem augmentation_layer_truncation
    (z : augmentationLayer R G 0) :
    augmentationTruncationLinear R G z =
      layerTruncation R G 0 z := by
  rw [augmentationTruncationLinear, LinearEquiv.ofBijective_apply]

/-- The degree-zero inclusion equivalence followed by `R[G]/I ≃ₗ R` is the canonical
zeroth-layer equivalence. -/
@[simp] theorem augmentation_truncation_trans :
    (augmentationTruncationLinear R G).trans
        (augmentationLinearEquiv R G) =
      augmentationZeroEquiv R G := by
  ext z
  change augmentationLinearEquiv R G
      (augmentationTruncationLinear R G z) =
    augmentationZeroEquiv R G z
  rw [augmentation_layer_truncation]
  exact augmentation_truncation_zero (R := R) (G := G) z

/-- Inverse coordinate formula for the degree-zero inclusion equivalence. -/
@[simp] theorem truncation_linear_symm (q :
    augmentationTruncation R G 1) :
    (augmentationTruncationLinear R G).symm q =
      (augmentationZeroEquiv R G).symm (augmentationLinearEquiv R G q) := by
  apply (augmentationTruncationLinear R G).injective
  rw [LinearEquiv.apply_symm_apply, augmentation_layer_truncation]
  rw [truncation_zero_symm]
  simp


/-- Exactness phrased directly with the kernel of the linear transition map. -/
theorem range_truncation_ker (n : ℕ) :
    LinearMap.range (layerTruncation R G n) =
      LinearMap.ker (augmentationLinear R G (Nat.le_succ n)) := by
  rw [← truncation_submodule_ker]
  exact range_truncation_submodule R G n

/-- The graded piece is linearly equivalent to the kernel of the underlying linear
successive truncation map. -/
noncomputable def augmentationLinearKer (n : ℕ) :
    augmentationLayer R G n ≃ₗ[R]
      LinearMap.ker (augmentationLinear R G (Nat.le_succ n)) :=
  (LinearEquiv.ofInjective (layerTruncation R G n)
    (layer_truncation_injective R G n)).trans
    (LinearEquiv.ofEq _ _ (range_truncation_ker R G n))

@[simp] theorem augmentation_ker_coe (n : ℕ)
    (z : augmentationLayer R G n) :
    ((augmentationLinearKer R G n z :
        LinearMap.ker (augmentationLinear R G (Nat.le_succ n))) :
        augmentationTruncation R G (n + 1)) =
      layerTruncation R G n z := rfl

/-- Coercion formula for the inverse of the layer--linear-kernel equivalence.  This is
often the most convenient way to eliminate the packaged subtype equivalence. -/
@[simp] theorem augmentation_symm_truncation (n : ℕ)
    (q : LinearMap.ker (augmentationLinear R G (Nat.le_succ n))) :
    layerTruncation R G n
        ((augmentationLinearKer R G n).symm q) = q := by
  have h := (augmentationLinearKer R G n).apply_symm_apply q
  exact congrArg (fun x : LinearMap.ker
      (augmentationLinear R G (Nat.le_succ n)) =>
        (x : augmentationTruncation R G (n + 1))) h

/-- The graded piece is linearly equivalent to the kernel of the successive
truncation map. -/
noncomputable def augmentationLayerTruncation (n : ℕ) :
    augmentationLayer R G n ≃ₗ[R] augmentationTruncationSubmodule R G n :=
  (LinearEquiv.ofInjective (layerTruncation R G n)
    (layer_truncation_injective R G n)).trans
    (LinearEquiv.ofEq _ _ (range_truncation_submodule R G n))

/-- Underlying truncation representative of the layer-kernel equivalence. -/
@[simp] theorem layer_truncation_coe (n : ℕ)
    (z : augmentationLayer R G n) :
    ((augmentationLayerTruncation R G n z :
        augmentationTruncationSubmodule R G n) : augmentationTruncation R G (n + 1)) =
      layerTruncation R G n z := rfl

/-- Coercion formula for the inverse of the layer--successive-kernel equivalence. -/
@[simp] theorem layer_truncation_symm (n : ℕ)
    (q : augmentationTruncationSubmodule R G n) :
    layerTruncation R G n
        ((augmentationLayerTruncation R G n).symm q) = q := by
  have h := (augmentationLayerTruncation R G n).apply_symm_apply q
  exact congrArg (fun x : augmentationTruncationSubmodule R G n =>
        (x : augmentationTruncation R G (n + 1))) h

/-- The two subtype incarnations of the successive kernel (as a linear-map kernel and
as the restricted scalar submodule of the ring-hom kernel) are canonically linearly
equivalent. -/
noncomputable def augmentationLinearTruncation (n : ℕ) :
    LinearMap.ker (augmentationLinear R G (Nat.le_succ n)) ≃ₗ[R]
      augmentationTruncationSubmodule R G n :=
  LinearEquiv.ofEq _ _ (truncation_submodule_ker R G n).symm

@[simp] theorem augmentation_truncation_coe (n : ℕ)
    (q : LinearMap.ker (augmentationLinear R G (Nat.le_succ n))) :
    ((augmentationLinearTruncation R G n q :
        augmentationTruncationSubmodule R G n) : augmentationTruncation R G (n + 1)) = q := by
  simp [augmentationLinearTruncation]

@[simp] theorem truncation_symm_coe (n : ℕ)
    (q : augmentationTruncationSubmodule R G n) :
    (((augmentationLinearTruncation R G n).symm q :
        LinearMap.ker (augmentationLinear R G (Nat.le_succ n))) :
        augmentationTruncation R G (n + 1)) = q := by
  simp [augmentationLinearTruncation]

/-- The two layer-to-kernel equivalences differ only by the canonical identification of
kernel subtype presentations. -/
@[simp] theorem augmentation_trans_kernel (n : ℕ) :
    (augmentationLinearKer R G n).trans
        (augmentationLinearTruncation R G n) =
      augmentationLayerTruncation R G n := by
  ext z
  simp [LinearEquiv.trans_apply]


/-- If two successive augmentation-power submodules coincide, the denominator of
the corresponding layer is the whole numerator. -/
theorem denom_top_submodule {n : ℕ}
    (h : augmentationPowerSubmodule R G (n + 1) = augmentationPowerSubmodule R G n) :
    augmentationLayerDenom R G n = ⊤ := by
  ext x
  constructor
  · intro _
    trivial
  · intro _
    change (x : MonoidAlgebra R G) ∈ augmentationPowerSubmodule R G (n + 1)
    rw [h]
    exact x.property

/-- If two successive augmentation powers coincide, the corresponding layer is a
subsingleton quotient. -/
theorem subsingleton_augmentation_submodule {n : ℕ}
    (h : augmentationPowerSubmodule R G (n + 1) = augmentationPowerSubmodule R G n) :
    Subsingleton (augmentationLayer R G n) := by
  let D : Submodule R (augmentationPowerSubmodule R G n) := augmentationLayerDenom R G n
  have hD : D = ⊤ := denom_top_submodule (R := R) (G := G) h
  change Subsingleton ((augmentationPowerSubmodule R G n) ⧸ D)
  refine ⟨?_⟩
  intro x y
  have hx0 : x = 0 := by
    refine Submodule.Quotient.induction_on D x ?_
    intro z
    apply (Submodule.Quotient.mk_eq_zero D).2
    rw [hD]
    trivial
  have hy0 : y = 0 := by
    refine Submodule.Quotient.induction_on D y ?_
    intro z
    apply (Submodule.Quotient.mk_eq_zero D).2
    rw [hD]
    trivial
  rw [hx0, hy0]

/-- Once an augmentation-power submodule is zero, all later ones are zero. -/
theorem augmentation_submodule_bot {N n : ℕ}
    (hN : augmentationPowerSubmodule R G N = ⊥) (hNn : N ≤ n) :
    augmentationPowerSubmodule R G n = ⊥ := by
  apply le_antisymm
  · have hle := augmentation_submodule_antitone R G hNn
    rw [hN] at hle
    exact hle
  · exact bot_le

/-- Nilpotence at stage `N` makes every layer in degree at least `N` trivial. -/
theorem subsingleton_augmentation_bot {N n : ℕ}
    (hN : augmentationPowerSubmodule R G N = ⊥) (hNn : N ≤ n) :
    Subsingleton (augmentationLayer R G n) := by
  apply subsingleton_augmentation_submodule (R := R) (G := G)
  have hn : augmentationPowerSubmodule R G n = ⊥ :=
    augmentation_submodule_bot (R := R) (G := G) hN hNn
  have hsucc : augmentationPowerSubmodule R G (n + 1) = ⊥ :=
    augmentation_submodule_bot (R := R) (G := G) hN
      (le_trans hNn (Nat.le_succ n))
  rw [hn, hsucc]


/-! ### Functoriality under group homomorphisms -/

/-- A ring homomorphism sends a product of (two-sided) ideals into the product of the
image ideals.  This one-sided inclusion is enough for noncommutative group algebras. -/
theorem ideal_map_le {A B : Type*} [Semiring A] [Semiring B]
    (f : A →+* B) (I J : Ideal A) [I.IsTwoSided] :
    Ideal.map f (I * J) ≤ Ideal.map f I * Ideal.map f J := by
  rw [Ideal.map_le_iff_le_comap, Ideal.mul_le]
  intro a ha b hb
  change f (a * b) ∈ Ideal.map f I * Ideal.map f J
  rw [map_mul]
  exact Ideal.mul_mem_mul (Ideal.mem_map_of_mem f ha) (Ideal.mem_map_of_mem f hb)

/-- For a surjective ring homomorphism, mapping commutes with products of two-sided ideals. -/
theorem ideal_mul_surjective {A B : Type*} [Semiring A] [Semiring B]
    (f : A →+* B) (hf : Function.Surjective f) (I J : Ideal A)
    [I.IsTwoSided] [J.IsTwoSided] :
    Ideal.map f (I * J) = Ideal.map f I * Ideal.map f J := by
  apply le_antisymm
  · exact ideal_map_le f I J
  · rw [Ideal.mul_le]
    intro b hb c hc
    rcases (Ideal.mem_map_iff_of_surjective (f := f) (I := I) (y := b) hf).1 hb with
      ⟨a, ha, rfl⟩
    rcases (Ideal.mem_map_iff_of_surjective (f := f) (I := J) (y := c) hf).1 hc with
      ⟨d, hd, rfl⟩
    rw [← map_mul]
    exact Ideal.mem_map_of_mem f (Ideal.mul_mem_mul ha hd)

/-- For a surjective ring homomorphism, mapping commutes with powers of two-sided ideals. -/
theorem ideal_pow_surjective {A B : Type*} [Semiring A] [Semiring B]
    (f : A →+* B) (hf : Function.Surjective f) (I : Ideal A) [I.IsTwoSided]
    (n : ℕ) : Ideal.map f (I ^ n) = (Ideal.map f I) ^ n := by
  induction n with
  | zero =>
      rw [Submodule.pow_zero, Submodule.pow_zero]
      apply le_antisymm
      · simp
      · intro b hb
        rcases hf b with ⟨a, rfl⟩
        exact Ideal.mem_map_of_mem f (show a ∈ (1 : Ideal A) from by simp)
  | succ n ih =>
      rw [Submodule.pow_succ, Submodule.pow_succ]
      rw [ideal_mul_surjective f hf (I ^ n) I, ih]

/-- If a ring homomorphism sends `I` into `J`, it sends every power of `I` into the
corresponding power of `J`.  Stated as an inclusion to work in noncommutative rings. -/
theorem map_le_le {A B : Type*} [Semiring A] [Semiring B]
    (f : A →+* B) (I : Ideal A) (J : Ideal B) [I.IsTwoSided]
    (hIJ : Ideal.map f I ≤ J) (n : ℕ) : Ideal.map f (I ^ n) ≤ J ^ n := by
  induction n with
  | zero =>
      rw [Submodule.pow_zero, Submodule.pow_zero]
      simp
  | succ n ih =>
      rw [Submodule.pow_succ, Submodule.pow_succ]
      exact le_trans (ideal_map_le f (I ^ n) I) (mul_le_mul' ih hIJ)

variable {R G}
variable {H : Type*} [Group H]

/-- The algebra map induced by a group homomorphism commutes with augmentation. -/
theorem augmentation_domain (φ : G →* H) (x : MonoidAlgebra R G) :
    augmentation R H ((MonoidAlgebra.mapDomainAlgHom R R φ) x) = augmentation R G x := by
  have hhom : (augmentation R H).comp (MonoidAlgebra.mapDomainAlgHom R R φ) =
      augmentation R G := by
    apply MonoidAlgebra.algHom_ext
    intro g
    simp [MonoidAlgebra.mapDomainAlgHom]
  exact AlgHom.congr_fun hhom x

/-- The induced map on group algebras sends the augmentation ideal into the augmentation
ideal. -/
theorem augmentation_ideal_domain (φ : G →* H) :
    Ideal.map ((MonoidAlgebra.mapDomainAlgHom R R φ).toRingHom) (augmentationIdeal R G) ≤
      augmentationIdeal R H := by
  rw [Ideal.map_le_iff_le_comap]
  intro x hx
  change (MonoidAlgebra.mapDomainAlgHom R R φ) x ∈ augmentationIdeal R H
  rw [augmentationIdeal, RingHom.mem_ker] at hx ⊢
  change augmentation R H ((MonoidAlgebra.mapDomainAlgHom R R φ) x) = 0
  rw [augmentation_domain]
  exact hx

/-- A surjective group homomorphism induces a surjective map on group algebras. -/
theorem domain_hom_surjective (φ : G →* H) (hs : Function.Surjective φ) :
    Function.Surjective
      (MonoidAlgebra.mapDomainAlgHom R R φ : MonoidAlgebra R G →ₐ[R] MonoidAlgebra R H) := by
  intro y
  rcases Finsupp.mapDomain_surjective (M := R) hs y with ⟨x, hx⟩
  refine ⟨x, ?_⟩
  simpa [MonoidAlgebra.mapDomainAlgHom] using hx

/-- For a surjective group homomorphism, the augmentation ideal maps onto the target
augmentation ideal. -/
theorem ideal_domain_surjective (φ : G →* H)
    (hs : Function.Surjective φ) :
    Ideal.map ((MonoidAlgebra.mapDomainAlgHom R R φ).toRingHom) (augmentationIdeal R G) =
      augmentationIdeal R H := by
  apply le_antisymm
  · exact augmentation_ideal_domain (R := R) (G := G) φ
  · intro y hy
    rcases domain_hom_surjective (R := R) φ hs y with ⟨x, rfl⟩
    apply Ideal.mem_map_of_mem
    rw [augmentationIdeal, RingHom.mem_ker]
    rw [augmentationIdeal, RingHom.mem_ker] at hy
    change augmentation R G x = 0
    change augmentation R H ((MonoidAlgebra.mapDomainAlgHom R R φ) x) = 0 at hy
    rwa [augmentation_domain] at hy

/-- In degree one, a surjective group map sends the augmentation power onto the target. -/
theorem augmentation_domain_surjective (φ : G →* H)
    (hs : Function.Surjective φ) :
    Ideal.map ((MonoidAlgebra.mapDomainAlgHom R R φ).toRingHom) (augmentationPower R G 1) =
      augmentationPower R H 1 := by
  dsimp [augmentationPower]
  rw [Submodule.pow_one, Submodule.pow_one]
  exact ideal_domain_surjective (R := R) φ hs

/-- A surjective group homomorphism maps every augmentation power onto the target power. -/
theorem power_domain_surjective (φ : G →* H)
    (hs : Function.Surjective φ) (n : ℕ) :
    Ideal.map ((MonoidAlgebra.mapDomainAlgHom R R φ).toRingHom) (augmentationPower R G n) =
      augmentationPower R H n := by
  dsimp [augmentationPower]
  rw [ideal_pow_surjective]
  · change (Ideal.map ((MonoidAlgebra.mapDomainAlgHom R R φ).toRingHom)
        (augmentationIdeal R G)) ^ n = (augmentationIdeal R H) ^ n
    rw [ideal_domain_surjective (R := R) φ hs]
  · exact domain_hom_surjective (R := R) φ hs

/-- The ideal generated by the elementary relations `k - 1` for elements of the kernel
of a group homomorphism.  For quotient maps this is the expected kernel ideal of the
induced group-algebra map; we first record the easy containment needed downstream. -/
def kRIdeal (φ : G →* H) : Ideal (MonoidAlgebra R G) :=
  Ideal.span {x : MonoidAlgebra R G |
    ∃ k : G, k ∈ MonoidHom.ker φ ∧ x = _root_.MonoidAlgebra.of R G k - 1}

/-- If the kernel of a group homomorphism is cyclic, its relation ideal is generated
by the elementary relation for a single generator. -/
theorem span_singleton_zpowers
    (φ : G →* H) (c : G)
    (hker : MonoidHom.ker φ = Subgroup.zpowers c) :
    kRIdeal (R := R) φ =
      Ideal.span {(_root_.MonoidAlgebra.of R G c - 1 : MonoidAlgebra R G)} := by
  let J : Ideal (MonoidAlgebra R G) :=
    Ideal.span {(_root_.MonoidAlgebra.of R G c - 1 : MonoidAlgebra R G)}
  let K : Subgroup G :=
    { carrier := {k : G | (_root_.MonoidAlgebra.of R G k - 1 : MonoidAlgebra R G) ∈ J}
      one_mem' := by
        change (_root_.MonoidAlgebra.of R G 1 - 1 : MonoidAlgebra R G) ∈ J
        rw [map_one, sub_self]
        exact J.zero_mem
      mul_mem' := by
        intro a b ha hb
        change (_root_.MonoidAlgebra.of R G (a * b) - 1 : MonoidAlgebra R G) ∈ J
        have hmul :
            (_root_.MonoidAlgebra.of R G (a * b) - 1 : MonoidAlgebra R G) =
              _root_.MonoidAlgebra.of R G a *
                (_root_.MonoidAlgebra.of R G b - 1) +
              (_root_.MonoidAlgebra.of R G a - 1) := by
          rw [map_mul, mul_sub, mul_one]
          abel_nf
        rw [hmul]
        exact J.add_mem (Ideal.mul_mem_left J _ hb) ha
      inv_mem' := by
        intro a ha
        change (_root_.MonoidAlgebra.of R G a⁻¹ - 1 : MonoidAlgebra R G) ∈ J
        have hinv :
            (_root_.MonoidAlgebra.of R G a⁻¹ - 1 : MonoidAlgebra R G) =
              -(_root_.MonoidAlgebra.of R G a⁻¹ *
                (_root_.MonoidAlgebra.of R G a - 1)) := by
          rw [mul_sub, ← map_mul]
          simp [← MonoidAlgebra.one_def]
        rw [hinv]
        exact J.neg_mem (Ideal.mul_mem_left J _ ha) }
  have hcK : c ∈ K := by
    exact Ideal.subset_span (by simp)
  apply le_antisymm
  · apply Ideal.span_le.mpr
    intro x hx
    rcases hx with ⟨k, hk, rfl⟩
    change k ∈ K
    apply (Subgroup.zpowers_le.mpr hcK)
    rw [← hker]
    exact hk
  · apply Ideal.span_le.mpr
    intro x hx
    simp only [Set.mem_singleton_iff] at hx
    subst x
    apply Ideal.subset_span
    exact ⟨c, hker.symm ▸ Subgroup.mem_zpowers c, rfl⟩

/-- For the quotient by a cyclic normal subgroup, the relation ideal is the principal
ideal generated by the elementary relation for its chosen generator. -/
theorem zpowers_span_singleton
    (c : G) [(Subgroup.zpowers c).Normal] :
    kRIdeal (R := R)
        (QuotientGroup.mk' (Subgroup.zpowers c) : G →* G ⧸ Subgroup.zpowers c) =
      Ideal.span {(_root_.MonoidAlgebra.of R G c - 1 : MonoidAlgebra R G)} := by
  apply span_singleton_zpowers
  exact QuotientGroup.ker_mk' (Subgroup.zpowers c)

/-- A kernel group element gives an elementary relation in the kernel of the induced
map on group algebras. -/
theorem sub_domain_ker {φ : G →* H} {k : G}
    (hk : k ∈ MonoidHom.ker φ) :
    (_root_.MonoidAlgebra.of R G k - 1 : MonoidAlgebra R G) ∈
      RingHom.ker (MonoidAlgebra.mapDomainAlgHom R R φ).toRingHom := by
  rw [RingHom.mem_ker]
  change (MonoidAlgebra.mapDomainAlgHom R R φ)
      (_root_.MonoidAlgebra.of R G k - 1) = 0
  rw [map_sub, map_one]
  rw [MonoidAlgebra.mapDomainAlgHom_apply, MonoidAlgebra.of_apply,
    MonoidAlgebra.mapDomain_single]
  change _root_.MonoidAlgebra.single (φ k) (1 : R) - 1 = 0
  have hk1 : φ k = 1 := by simpa [MonoidHom.mem_ker] using hk
  rw [hk1]
  rw [← MonoidAlgebra.one_def]
  simp

/-- The kernel-relation ideal is contained in the kernel of the induced group-algebra map. -/
theorem relation_domain_ker (φ : G →* H) :
    kRIdeal (R := R) φ ≤
      RingHom.ker (MonoidAlgebra.mapDomainAlgHom R R φ).toRingHom := by
  apply Ideal.span_le.mpr
  intro x hx
  rcases hx with ⟨k, hk, rfl⟩
  exact sub_domain_ker (R := R) (φ := φ) hk

/-- Two basis group elements with the same image differ by a kernel relation.  This is
 the elementary fiber-identification step for describing kernels of maps of group
 algebras. -/
theorem sub_relation_ideal (φ : G →* H) {g g' : G}
    (h : φ g = φ g') :
    (_root_.MonoidAlgebra.of R G g - _root_.MonoidAlgebra.of R G g' : MonoidAlgebra R G) ∈
      kRIdeal (R := R) φ := by
  let k : G := g'⁻¹ * g
  have hk : k ∈ MonoidHom.ker φ := by
    rw [MonoidHom.mem_ker]
    dsimp [k]
    rw [map_mul, map_inv, h]
    simp
  have hgen : (_root_.MonoidAlgebra.of R G k - 1 : MonoidAlgebra R G) ∈
      kRIdeal (R := R) φ := by
    apply Ideal.subset_span
    exact ⟨k, hk, rfl⟩
  have hmul := Ideal.mul_mem_left (kRIdeal (R := R) φ)
      (_root_.MonoidAlgebra.of R G g') hgen
  have heq : (_root_.MonoidAlgebra.of R G g - _root_.MonoidAlgebra.of R G g' :
        MonoidAlgebra R G) =
      _root_.MonoidAlgebra.of R G g' * (_root_.MonoidAlgebra.of R G k - 1) := by
    calc
      (_root_.MonoidAlgebra.of R G g - _root_.MonoidAlgebra.of R G g' :
          MonoidAlgebra R G) =
          _root_.MonoidAlgebra.of R G (g' * k) - _root_.MonoidAlgebra.of R G g' := by
            dsimp [k]
            simp
      _ = _root_.MonoidAlgebra.of R G g' * _root_.MonoidAlgebra.of R G k -
          _root_.MonoidAlgebra.of R G g' := by rw [map_mul]
      _ = _root_.MonoidAlgebra.of R G g' * (_root_.MonoidAlgebra.of R G k - 1) := by
            rw [mul_sub, mul_one]
  rw [heq]
  exact hmul

/-- The coefficient-weighted version of `sub_relation_ideal`. -/
theorem single_relation_ideal (φ : G →* H) {g g' : G}
    (h : φ g = φ g') (r : R) :
    (Finsupp.single g r - Finsupp.single g' r : MonoidAlgebra R G) ∈
      kRIdeal (R := R) φ := by
  change (_root_.MonoidAlgebra.single g r - _root_.MonoidAlgebra.single g' r :
      MonoidAlgebra R G) ∈ kRIdeal (R := R) φ
  have hb := sub_relation_ideal (R := R) φ h
  have hs : r • ((_root_.MonoidAlgebra.of R G g - _root_.MonoidAlgebra.of R G g') :
        MonoidAlgebra R G) ∈ kRIdeal (R := R) φ := by
    rw [Algebra.smul_def]
    exact Ideal.mul_mem_left (kRIdeal (R := R) φ)
      (algebraMap R (MonoidAlgebra R G) r) hb
  convert hs using 1
  simp [MonoidAlgebra.of_apply, smul_sub]

/-- The kernel-relation ideal viewed as an `R`-submodule, for additive quotients. -/
def kernelRelationSubmodule (φ : G →* H) : Submodule R (MonoidAlgebra R G) where
  carrier := kRIdeal (R := R) φ
  zero_mem' := (kRIdeal (R := R) φ).zero_mem
  add_mem' := by
    intro x y hx hy
    exact (kRIdeal (R := R) φ).add_mem hx hy
  smul_mem' := by
    intro r x hx
    rw [Algebra.smul_def]
    exact Ideal.mul_mem_left (kRIdeal (R := R) φ)
      (algebraMap R (MonoidAlgebra R G) r) hx

/-- Given a set-theoretic section of `φ`, linearly send target basis elements to
its lifts modulo kernel relations. -/
def sectionQuotientLinear (φ : G →* H) (σ : H → G) :
    MonoidAlgebra R H →ₗ[R] (MonoidAlgebra R G ⧸ kernelRelationSubmodule (R := R) φ) :=
  Finsupp.linearCombination R (fun h : H =>
    Submodule.Quotient.mk (( _root_.MonoidAlgebra.of R G (σ h)) : MonoidAlgebra R G))

@[simp] theorem section_linear_single (φ : G →* H) (σ : H → G)
    (h : H) (r : R) :
    sectionQuotientLinear (R := R) φ σ (Finsupp.single h r : MonoidAlgebra R H) =
      r • Submodule.Quotient.mk
        ((_root_.MonoidAlgebra.of R G (σ h)) : MonoidAlgebra R G) := by
  exact Finsupp.linearCombination_single R r h

/-- Modulo kernel relations, the quotient map factors through any set-theoretic
section of a surjective homomorphism. -/
theorem q_section_domain (φ : G →* H) (σ : H → G)
    (hσ : ∀ h : H, φ (σ h) = h) :
    Submodule.mkQ (kernelRelationSubmodule (R := R) φ) =
      (sectionQuotientLinear (R := R) φ σ).comp
        (MonoidAlgebra.mapDomainAlgHom R R φ).toLinearMap := by
  apply Finsupp.lhom_ext
  intro g r
  change Submodule.Quotient.mk (Finsupp.single g r : MonoidAlgebra R G) =
    sectionQuotientLinear (R := R) φ σ
      ((MonoidAlgebra.mapDomainAlgHom R R φ)
        (Finsupp.single g r : MonoidAlgebra R G))
  rw [MonoidAlgebra.mapDomainAlgHom_apply, MonoidAlgebra.mapDomain_single,
    section_linear_single]
  change Submodule.Quotient.mk (Finsupp.single g r : MonoidAlgebra R G) =
    (Submodule.mkQ (kernelRelationSubmodule (R := R) φ))
      (r • (_root_.MonoidAlgebra.of R G (σ (φ g))))
  rw [Submodule.mkQ_apply]
  apply (Submodule.Quotient.eq (kernelRelationSubmodule (R := R) φ)).mpr
  have hsame : φ g = φ (σ (φ g)) := by rw [hσ]
  have hrel := single_relation_ideal (R := R) φ hsame r
  change (_root_.MonoidAlgebra.single g r -
      r • (_root_.MonoidAlgebra.of R G (σ (φ g))) : MonoidAlgebra R G) ∈
    kRIdeal (R := R) φ
  simpa [MonoidAlgebra.of_apply] using hrel

/-- The hard inclusion in the kernel-relation description, proved by choosing a
section and comparing basis fibers. -/
theorem domain_ker_surjective (φ : G →* H)
    (hs : Function.Surjective φ) :
    RingHom.ker (MonoidAlgebra.mapDomainAlgHom R R φ).toRingHom ≤
      kRIdeal (R := R) φ := by
  classical
  let σ : H → G := fun h => Classical.choose (hs h)
  have hσ : ∀ h : H, φ (σ h) = h := fun h => Classical.choose_spec (hs h)
  intro x hx
  have hx0 : (MonoidAlgebra.mapDomainAlgHom R R φ) x = 0 := by
    simpa [RingHom.mem_ker] using hx
  have hmaps := congrArg (fun (f : MonoidAlgebra R G →ₗ[R]
      (MonoidAlgebra R G ⧸ kernelRelationSubmodule (R := R) φ)) => f x)
    (q_section_domain (R := R) φ σ hσ)
  change (Submodule.mkQ (kernelRelationSubmodule (R := R) φ)) x =
      sectionQuotientLinear (R := R) φ σ
        ((MonoidAlgebra.mapDomainAlgHom R R φ) x) at hmaps
  rw [hx0, map_zero] at hmaps
  have hxq : Submodule.Quotient.mk x =
      (0 : MonoidAlgebra R G ⧸ kernelRelationSubmodule (R := R) φ) := by
    simpa [Submodule.mkQ_apply] using hmaps
  have hxsub := (Submodule.Quotient.mk_eq_zero (kernelRelationSubmodule (R := R) φ)).mp hxq
  exact hxsub

/-- For a surjective group homomorphism, the kernel of the induced group-algebra map
is exactly the ideal generated by the elementary kernel relations `k - 1`. -/
theorem domain_relation_surjective (φ : G →* H)
    (hs : Function.Surjective φ) :
    RingHom.ker (MonoidAlgebra.mapDomainAlgHom R R φ).toRingHom =
      kRIdeal (R := R) φ := by
  apply le_antisymm
  · exact domain_ker_surjective (R := R) φ hs
  · exact relation_domain_ker (R := R) φ

/-- Under a surjectivity hypothesis, the kernel-relation ideal is two-sided because it
is the kernel of the induced ring homomorphism. -/
theorem relation_sided_surjective (φ : G →* H)
    (hs : Function.Surjective φ) : (kRIdeal (R := R) φ).IsTwoSided := by
  rw [← domain_relation_surjective (R := R) φ hs]
  infer_instance

/-- Typeclass-friendly version of two-sidedness for a kernel-relation ideal. -/
instance kRIdeal.inst_two_sidedsurj (φ : G →* H)
    [hφ : Fact (Function.Surjective φ)] : (kRIdeal (R := R) φ).IsTwoSided :=
  relation_sided_surjective (R := R) φ hφ.out

/-- Preimage of an augmentation power under a surjective group-algebra map is the
source power plus the kernel-relation ideal.  This is the algebraic quotient formula
behind dimension-subgroup quotient arguments. -/
theorem comap_domain_sup
    (φ : G →* H) (hs : Function.Surjective φ) (n : ℕ) :
    Ideal.comap (MonoidAlgebra.mapDomainAlgHom R R φ).toRingHom
        (augmentationPower R H n) =
      augmentationPower R G n ⊔ kRIdeal (R := R) φ := by
  let f := (MonoidAlgebra.mapDomainAlgHom R R φ).toRingHom
  have hf : Function.Surjective f := by
    intro y
    rcases domain_hom_surjective (R := R) φ hs y with ⟨x, hx⟩
    exact ⟨x, hx⟩
  have hmap := power_domain_surjective (R := R) φ hs n
  change Ideal.comap f (augmentationPower R H n) = _
  rw [← hmap]
  rw [Ideal.comap_map_of_surjective f hf]
  change augmentationPower R G n ⊔ RingHom.ker f =
    augmentationPower R G n ⊔ kRIdeal (R := R) φ
  rw [domain_relation_surjective (R := R) φ hs]

/-- Membership form of the preimage formula for augmentation powers. -/
theorem domain_sup_surjective
    (φ : G →* H) (hs : Function.Surjective φ) (n : ℕ) (a : MonoidAlgebra R G) :
    (MonoidAlgebra.mapDomainAlgHom R R φ) a ∈ augmentationPower R H n ↔
      a ∈ augmentationPower R G n ⊔ kRIdeal (R := R) φ := by
  have h := comap_domain_sup
    (R := R) φ hs n
  change a ∈ Ideal.comap (MonoidAlgebra.mapDomainAlgHom R R φ).toRingHom
      (augmentationPower R H n) ↔ _
  rw [h]

/-- Kernel relations are augmentation relations. -/
theorem kernel_relation_augmentation (φ : G →* H) :
    kRIdeal (R := R) φ ≤ augmentationIdeal R G := by
  apply Ideal.span_le.mpr
  intro x hx
  rcases hx with ⟨k, _hk, rfl⟩
  exact sub_augmentation_ideal R G k

/-- The induced map on group algebras sends augmentation powers into augmentation powers. -/
theorem augmentation_power_domain (φ : G →* H) (n : ℕ) :
    Ideal.map ((MonoidAlgebra.mapDomainAlgHom R R φ).toRingHom) (augmentationPower R G n) ≤
      augmentationPower R H n := by
  dsimp [augmentationPower]
  exact map_le_le _ _ _ (augmentation_ideal_domain (R := R) (G := G) φ) n


/-- A group homomorphism induces a ring homomorphism on fixed-depth augmentation
truncations `R[G]/I^n → R[H]/I^n`. -/
def truncationDomain (φ : G →* H) (n : ℕ) :
    augmentationTruncation R G n →+* augmentationTruncation R H n :=
  Ideal.quotientMap (augmentationPower R H n)
    (MonoidAlgebra.mapDomainAlgHom R R φ).toRingHom (by
      intro x hx
      have hxmap : (MonoidAlgebra.mapDomainAlgHom R R φ).toRingHom x ∈
          Ideal.map (MonoidAlgebra.mapDomainAlgHom R R φ).toRingHom
            (augmentationPower R G n) := Ideal.mem_map_of_mem _ hx
      exact (augmentation_power_domain (R := R) (G := G) φ n) hxmap)

/-- The same map on truncations, as an `R`-algebra homomorphism.  This form is
useful when extracting linear maps on kernels and graded pieces. -/
def truncationDomainAlg (φ : G →* H) (n : ℕ) :
    augmentationTruncation R G n →ₐ[R] augmentationTruncation R H n :=
  Ideal.quotientMapₐ (augmentationPower R H n)
    (MonoidAlgebra.mapDomainAlgHom R R φ) (by
      intro x hx
      have hxmap : (MonoidAlgebra.mapDomainAlgHom R R φ).toRingHom x ∈
          Ideal.map (MonoidAlgebra.mapDomainAlgHom R R φ).toRingHom
            (augmentationPower R G n) := Ideal.mem_map_of_mem _ hx
      exact (augmentation_power_domain (R := R) (G := G) φ n) hxmap)

@[simp] theorem truncation_domain_mk (φ : G →* H) (n : ℕ)
    (x : MonoidAlgebra R G) :
    truncationDomainAlg (R := R) (G := G) φ n
        (Ideal.Quotient.mk (augmentationPower R G n) x) =
      Ideal.Quotient.mk (augmentationPower R H n)
        ((MonoidAlgebra.mapDomainAlgHom R R φ) x) := rfl

/-- The algebra-hom and ring-hom versions of functoriality on truncations agree. -/
@[simp] theorem truncation_domain_ring
    (φ : G →* H) (n : ℕ) :
    (truncationDomainAlg (R := R) (G := G) φ n).toRingHom =
      truncationDomain (R := R) (G := G) φ n := by
  apply RingHom.ext
  intro q
  refine Quotient.inductionOn' q ?_
  intro x
  change Ideal.Quotient.mk (augmentationPower R H n)
      ((MonoidAlgebra.mapDomainAlgHom R R φ) x) =
    Ideal.Quotient.mk (augmentationPower R H n)
      ((MonoidAlgebra.mapDomainAlgHom R R φ) x)
  rfl

/-- Linear-map form of functoriality on augmentation truncations. -/
def truncationDomainLinear (φ : G →* H) (n : ℕ) :
    augmentationTruncation R G n →ₗ[R] augmentationTruncation R H n :=
  (truncationDomainAlg (R := R) (G := G) φ n).toLinearMap

@[simp] theorem domain_linear (φ : G →* H) (n : ℕ)
    (q : augmentationTruncation R G n) :
    truncationDomainLinear (R := R) (G := G) φ n q =
      truncationDomain (R := R) (G := G) φ n q := by
  change ((truncationDomainAlg (R := R) (G := G) φ n).toRingHom) q = _
  rw [truncation_domain_ring]

/-- Every domain-induced map into the zeroth truncation is pointwise zero. -/
@[simp] theorem augmentation_domain_zero (φ : G →* H)
    (q : augmentationTruncation R G 0) :
    truncationDomain (R := R) (G := G) φ 0 q = 0 :=
  augmentation_zero R H _

/-- Linear-map form of the zeroth-truncation collapse for domain-induced maps. -/
@[simp] theorem truncation_domain_zero (φ : G →* H)
    (q : augmentationTruncation R G 0) :
    truncationDomainLinear (R := R) (G := G) φ 0 q = 0 := by
  rw [domain_linear]
  exact augmentation_domain_zero (R := R) (G := G) φ q

/-- As linear maps, all domain-induced maps on zeroth truncations are the zero map. -/
@[simp] theorem domain_linear_zero (φ : G →* H) :
    truncationDomainLinear (R := R) (G := G) φ 0 = 0 := by
  apply LinearMap.ext
  intro q
  exact truncation_domain_zero (R := R) (G := G) φ q

/-- Any two domain-induced maps on zeroth truncations agree. -/
theorem truncation_domain_ext (φ ψ : G →* H) :
    truncationDomain (R := R) (G := G) φ 0 =
      truncationDomain (R := R) (G := G) ψ 0 := by
  apply RingHom.ext
  intro q
  simp

@[simp] theorem augmentation_domain_mk (φ : G →* H) (n : ℕ)
    (x : MonoidAlgebra R G) :
    truncationDomain (R := R) (G := G) φ n
        (Ideal.Quotient.mk (augmentationPower R G n) x) =
      Ideal.Quotient.mk (augmentationPower R H n)
        ((MonoidAlgebra.mapDomainAlgHom R R φ) x) := by
  simp [truncationDomain, Ideal.quotientMap_mk]

/-- A surjective group homomorphism induces a surjective map on fixed-depth
augmentation truncations. -/
theorem augmentation_truncation_surjective (φ : G →* H)
    (hs : Function.Surjective φ) (n : ℕ) :
    Function.Surjective (truncationDomain (R := R) (G := G) φ n) := by
  intro q
  refine Quotient.inductionOn' q ?_
  intro y
  rcases domain_hom_surjective (R := R) φ hs y with ⟨x, hx⟩
  refine ⟨Ideal.Quotient.mk (augmentationPower R G n) x, ?_⟩
  rw [augmentation_domain_mk]
  exact congrArg (Ideal.Quotient.mk (augmentationPower R H n)) hx

/-- Linear-map version of surjectivity on augmentation truncations. -/
theorem domain_linear_surjective (φ : G →* H)
    (hs : Function.Surjective φ) (n : ℕ) :
    Function.Surjective (truncationDomainLinear (R := R) (G := G) φ n) := by
  intro q
  rcases augmentation_truncation_surjective (R := R) (G := G) φ hs n q with
    ⟨x, hx⟩
  exact ⟨x, by simpa [domain_linear] using hx⟩

/-- Range form of surjectivity for the linear truncation map. -/
theorem truncation_domain_surjective (φ : G →* H)
    (hs : Function.Surjective φ) (n : ℕ) :
    LinearMap.range (truncationDomainLinear (R := R) (G := G) φ n) = ⊤ :=
  LinearMap.range_eq_top.mpr
    (domain_linear_surjective (R := R) (G := G) φ hs n)

/-- Algebra-hom version of surjectivity on augmentation truncations. -/
theorem domain_alg_surjective (φ : G →* H)
    (hs : Function.Surjective φ) (n : ℕ) :
    Function.Surjective (truncationDomainAlg (R := R) (G := G) φ n) := by
  intro q
  rcases augmentation_truncation_surjective (R := R) (G := G) φ hs n q with
    ⟨x, hx⟩
  refine ⟨x, ?_⟩
  change (truncationDomainAlg (R := R) (G := G) φ n).toRingHom x = q
  rw [truncation_domain_ring]
  exact hx

@[simp] theorem domain_id (n : ℕ) :
    truncationDomain (R := R) (G := G) (MonoidHom.id G) n =
      RingHom.id (augmentationTruncation R G n) := by
  apply RingHom.ext
  intro q
  refine Quotient.inductionOn' q ?_
  intro x
  change truncationDomain (R := R) (G := G) (MonoidHom.id G) n
        (Ideal.Quotient.mk (augmentationPower R G n) x) =
      (RingHom.id (augmentationTruncation R G n))
        (Ideal.Quotient.mk (augmentationPower R G n) x)
  simp

@[simp] theorem domain_comp {L : Type*} [Group L]
    (φ : G →* H) (ψ : H →* L) (n : ℕ) :
    (truncationDomain (R := R) (G := H) ψ n).comp
        (truncationDomain (R := R) (G := G) φ n) =
      truncationDomain (R := R) (G := G) (ψ.comp φ) n := by
  apply RingHom.ext
  intro q
  refine Quotient.inductionOn' q ?_
  intro x
  change truncationDomain (R := R) (G := H) ψ n
        (truncationDomain (R := R) (G := G) φ n
          (Ideal.Quotient.mk (augmentationPower R G n) x)) =
      truncationDomain (R := R) (G := G) (ψ.comp φ) n
        (Ideal.Quotient.mk (augmentationPower R G n) x)
  simp [augmentation_domain_mk, MonoidAlgebra.mapDomainAlgHom]

@[simp] theorem domain_linear_id (n : ℕ) :
    truncationDomainLinear (R := R) (G := G) (MonoidHom.id G) n =
      LinearMap.id := by
  apply LinearMap.ext
  intro q
  simp [domain_linear]

@[simp] theorem domain_linear_comp {L : Type*} [Group L]
    (φ : G →* H) (ψ : H →* L) (n : ℕ) :
    (truncationDomainLinear (R := R) (G := H) ψ n).comp
        (truncationDomainLinear (R := R) (G := G) φ n) =
      truncationDomainLinear (R := R) (G := G) (ψ.comp φ) n := by
  apply LinearMap.ext
  intro q
  change truncationDomain (R := R) (G := H) ψ n
        (truncationDomain (R := R) (G := G) φ n q) =
      truncationDomain (R := R) (G := G) (ψ.comp φ) n q
  exact DFunLike.congr_fun
    (domain_comp (R := R) (G := G) φ ψ n) q

/-- Naturality of truncation transition maps with respect to group homomorphisms. -/
theorem augmentation_domain_naturality {m n : ℕ} (hmn : m ≤ n)
    (φ : G →* H) :
    (augmentationTruncationMap R H hmn).comp
        (truncationDomain (R := R) (G := G) φ n) =
      (truncationDomain (R := R) (G := G) φ m).comp
        (augmentationTruncationMap R G hmn) := by
  apply RingHom.ext
  intro q
  refine Quotient.inductionOn' q ?_
  intro x
  change augmentationTruncationMap R H hmn
        (truncationDomain (R := R) (G := G) φ n
          (Ideal.Quotient.mk (augmentationPower R G n) x)) =
      truncationDomain (R := R) (G := G) φ m
        (augmentationTruncationMap R G hmn
          (Ideal.Quotient.mk (augmentationPower R G n) x))
  simp [augmentation_domain_mk, truncation_mk]

/-- Linear-map form of naturality for truncation transitions. -/
theorem truncation_domain_naturality {m n : ℕ} (hmn : m ≤ n)
    (φ : G →* H) :
    (augmentationLinear R H hmn).comp
        (truncationDomainLinear (R := R) (G := G) φ n) =
      (truncationDomainLinear (R := R) (G := G) φ m).comp
        (augmentationLinear R G hmn) := by
  apply LinearMap.ext
  intro q
  change augmentationTruncationMap R H hmn
        (truncationDomain (R := R) (G := G) φ n q) =
      truncationDomain (R := R) (G := G) φ m
        (augmentationTruncationMap R G hmn q)
  exact DFunLike.congr_fun
    (augmentation_domain_naturality (R := R) (G := G) hmn φ) q




/-- Functoriality on the kernel of the underlying linear successive truncation map. -/
noncomputable def augmentationTruncationKernel (φ : G →* H) (n : ℕ) :
    LinearMap.ker (augmentationLinear R G (Nat.le_succ n)) →ₗ[R]
      LinearMap.ker (augmentationLinear R H (Nat.le_succ n)) where
  toFun q := by
    refine ⟨truncationDomainLinear (R := R) (G := G) φ (n + 1) q, ?_⟩
    rw [LinearMap.mem_ker]
    have hq : augmentationLinear R G (Nat.le_succ n)
        (q : augmentationTruncation R G (n + 1)) = 0 := LinearMap.mem_ker.mp q.property
    have hnat := congrArg (fun f : augmentationTruncation R G (n + 1) →ₗ[R]
        augmentationTruncation R H n => f (q : augmentationTruncation R G (n + 1)))
      (truncation_domain_naturality (R := R) (G := G)
        (Nat.le_succ n) φ)
    simpa [LinearMap.comp_apply, hq] using hnat
  map_add' q r := by ext; simp
  map_smul' a q := by ext; simp

@[simp] theorem augmentation_linear_coe (φ : G →* H) (n : ℕ)
    (q : LinearMap.ker (augmentationLinear R G (Nat.le_succ n))) :
    ((augmentationTruncationKernel (R := R) (G := G) φ n q :
        LinearMap.ker (augmentationLinear R H (Nat.le_succ n))) :
        augmentationTruncation R H (n + 1)) =
      truncationDomainLinear (R := R) (G := G) φ (n + 1) q := rfl

@[simp] theorem augmentation_truncation_id (n : ℕ) :
    augmentationTruncationKernel (R := R) (G := G) (MonoidHom.id G) n =
      LinearMap.id := by
  ext q
  simp [augmentation_linear_coe]

@[simp] theorem truncation_linear_comp {L : Type*} [Group L]
    (φ : G →* H) (ψ : H →* L) (n : ℕ) :
    augmentationTruncationKernel (R := R) (G := G) (ψ.comp φ) n =
      (augmentationTruncationKernel (R := R) (G := H) ψ n).comp
        (augmentationTruncationKernel (R := R) (G := G) φ n) := by
  ext q
  change truncationDomain (R := R) (G := G) (ψ.comp φ) (n + 1) q =
    truncationDomain (R := R) (G := H) ψ (n + 1)
      (truncationDomain (R := R) (G := G) φ (n + 1) q)
  have h := congrArg (fun f : augmentationTruncation R G (n + 1) →+*
      augmentationTruncation R L (n + 1) => f (q : augmentationTruncation R G (n + 1)))
    (domain_comp (R := R) (G := G) φ ψ (n + 1)).symm
  simpa only [RingHom.comp_apply] using h


/-- A group isomorphism induces a linear equivalence on the linear kernels of
successive truncation maps. -/
noncomputable def truncationLinearEquiv (e : G ≃* H) (n : ℕ) :
    LinearMap.ker (augmentationLinear R G (Nat.le_succ n)) ≃ₗ[R]
      LinearMap.ker (augmentationLinear R H (Nat.le_succ n)) where
  toFun := augmentationTruncationKernel (R := R) (G := G) e.toMonoidHom n
  invFun := augmentationTruncationKernel (R := R) (G := H) e.symm.toMonoidHom n
  left_inv q := by
    apply Subtype.ext
    change truncationDomainLinear (R := R) (G := H) e.symm.toMonoidHom (n + 1)
        (truncationDomainLinear (R := R) (G := G) e.toMonoidHom (n + 1) q) = q
    have h := congrArg (fun f : augmentationTruncation R G (n + 1) →ₗ[R]
        augmentationTruncation R G (n + 1) => f (q : augmentationTruncation R G (n + 1)))
      (domain_linear_comp (R := R) (G := G)
        e.toMonoidHom e.symm.toMonoidHom (n + 1))
    have hcomp : e.symm.toMonoidHom.comp e.toMonoidHom = MonoidHom.id G := by
      ext g; simp
    calc
      truncationDomainLinear (R := R) (G := H) e.symm.toMonoidHom (n + 1)
          (truncationDomainLinear (R := R) (G := G) e.toMonoidHom (n + 1) q) =
        truncationDomainLinear (R := R) (G := G)
          (e.symm.toMonoidHom.comp e.toMonoidHom) (n + 1) q := by
          simpa only [LinearMap.comp_apply] using h
      _ = q := by
          rw [hcomp, domain_linear_id]
          rfl
  right_inv q := by
    apply Subtype.ext
    change truncationDomainLinear (R := R) (G := G) e.toMonoidHom (n + 1)
        (truncationDomainLinear (R := R) (G := H) e.symm.toMonoidHom (n + 1) q) = q
    have h := congrArg (fun f : augmentationTruncation R H (n + 1) →ₗ[R]
        augmentationTruncation R H (n + 1) => f (q : augmentationTruncation R H (n + 1)))
      (domain_linear_comp (R := R) (G := H)
        e.symm.toMonoidHom e.toMonoidHom (n + 1))
    have hcomp : e.toMonoidHom.comp e.symm.toMonoidHom = MonoidHom.id H := by
      ext h; simp
    calc
      truncationDomainLinear (R := R) (G := G) e.toMonoidHom (n + 1)
          (truncationDomainLinear (R := R) (G := H) e.symm.toMonoidHom (n + 1) q) =
        truncationDomainLinear (R := R) (G := H)
          (e.toMonoidHom.comp e.symm.toMonoidHom) (n + 1) q := by
          simpa only [LinearMap.comp_apply] using h
      _ = q := by
          rw [hcomp, domain_linear_id]
          rfl
  map_add' q r := map_add _ q r
  map_smul' a q := map_smul _ a q

@[simp] theorem truncation_linear_coe (e : G ≃* H) (n : ℕ)
    (q : LinearMap.ker (augmentationLinear R G (Nat.le_succ n))) :
    ((truncationLinearEquiv (R := R) (G := G) e n q :
        LinearMap.ker (augmentationLinear R H (Nat.le_succ n))) :
        augmentationTruncation R H (n + 1)) =
      truncationDomainLinear (R := R) (G := G) e.toMonoidHom (n + 1) q := rfl


@[simp] theorem truncation_kernel_symm (e : G ≃* H) (n : ℕ) :
    (truncationLinearEquiv (R := R) (G := G) e n).symm =
      truncationLinearEquiv (R := R) (G := H) e.symm n := by
  ext q
  rfl

@[simp] theorem augmentation_truncation_refl (n : ℕ) :
    truncationLinearEquiv (R := R) (G := G) (MulEquiv.refl G) n =
      LinearEquiv.refl R (LinearMap.ker (augmentationLinear R G (Nat.le_succ n))) := by
  ext q
  simp [truncation_linear_coe]

@[simp] theorem truncation_linear_trans {K : Type*} [Group K]
    (e : G ≃* H) (f : H ≃* K) (n : ℕ) :
    (truncationLinearEquiv (R := R) (G := G) e n).trans
        (truncationLinearEquiv (R := R) (G := H) f n) =
      truncationLinearEquiv (R := R) (G := G) (e.trans f) n := by
  ext q
  change truncationDomainLinear (R := R) (G := H) f.toMonoidHom (n + 1)
      (truncationDomainLinear (R := R) (G := G) e.toMonoidHom (n + 1) q) =
    truncationDomainLinear (R := R) (G := G)
      (f.toMonoidHom.comp e.toMonoidHom) (n + 1) q
  exact DFunLike.congr_fun
    (domain_linear_comp (R := R) (G := G)
      e.toMonoidHom f.toMonoidHom (n + 1)) (q : augmentationTruncation R G (n + 1))

/-- Functoriality on the kernel of a successive truncation map. -/
def truncationKernel (φ : G →* H) (n : ℕ) :
    augmentationTruncationSubmodule R G n →ₗ[R]
      augmentationTruncationSubmodule R H n where
  toFun q := by
    refine ⟨truncationDomainLinear (R := R) (G := G) φ (n + 1) q, ?_⟩
    rw [truncation_kernel_submodule, RingHom.mem_ker]
    -- Rewrite the naturality square at `q`; the source transition kills `q`.
    change augmentationTruncationMap R H (Nat.le_succ n)
        (truncationDomain (R := R) (G := G) φ (n + 1) q) = 0
    have hq : augmentationTruncationMap R G (Nat.le_succ n)
        (q : augmentationTruncation R G (n + 1)) = 0 := by
      exact (RingHom.mem_ker.mp q.property)
    calc
      augmentationTruncationMap R H (Nat.le_succ n)
          (truncationDomain (R := R) (G := G) φ (n + 1) q)
          = truncationDomain (R := R) (G := G) φ n
              (augmentationTruncationMap R G (Nat.le_succ n) q) := by
            have hnat := augmentation_domain_naturality (R := R) (G := G)
              (Nat.le_succ n) φ
            have happ := congrArg (fun f : augmentationTruncation R G (n + 1) →+*
                augmentationTruncation R H n => f (q : augmentationTruncation R G (n + 1))) hnat
            simpa only [RingHom.comp_apply] using happ
      _ = 0 := by simp [hq]
  map_add' q r := by
    apply Subtype.ext
    simp [truncationDomainLinear]
  map_smul' a q := by
    apply Subtype.ext
    simp [truncationDomainLinear]

@[simp] theorem augmentation_kernel_coe (φ : G →* H) (n : ℕ)
    (q : augmentationTruncationSubmodule R G n) :
    ((truncationKernel (R := R) (G := G) φ n q :
        augmentationTruncationSubmodule R H n) : augmentationTruncation R H (n + 1)) =
      truncationDomain (R := R) (G := G) φ (n + 1) q := rfl

@[simp] theorem truncation_kernel_id (n : ℕ) :
    truncationKernel (R := R) (G := G) (MonoidHom.id G) n =
      LinearMap.id := by
  ext q
  simp [augmentation_kernel_coe]

@[simp] theorem truncation_kernel_comp {L : Type*} [Group L]
    (φ : G →* H) (ψ : H →* L) (n : ℕ) :
    truncationKernel (R := R) (G := G) (ψ.comp φ) n =
      (truncationKernel (R := R) (G := H) ψ n).comp
        (truncationKernel (R := R) (G := G) φ n) := by
  ext q
  change truncationDomain (R := R) (G := G) (ψ.comp φ) (n + 1) q =
    truncationDomain (R := R) (G := H) ψ (n + 1)
      (truncationDomain (R := R) (G := G) φ (n + 1) q)
  have h := congrArg (fun f : augmentationTruncation R G (n + 1) →+*
      augmentationTruncation R L (n + 1) => f (q : augmentationTruncation R G (n + 1)))
    (domain_comp (R := R) (G := G) φ ψ (n + 1)).symm
  simpa only [RingHom.comp_apply] using h

/-- The canonical identification between the linear-kernel and ring-kernel subtype
presentations is natural for arbitrary group-domain maps. -/
theorem ker_truncation_naturality (φ : G →* H) (n : ℕ)
    (q : LinearMap.ker (augmentationLinear R G (Nat.le_succ n))) :
    truncationKernel (R := R) (G := G) φ n
        (augmentationLinearTruncation R G n q) =
      augmentationLinearTruncation R H n
        (augmentationTruncationKernel (R := R) (G := G) φ n q) := by
  apply Subtype.ext
  simp [augmentation_kernel_coe, augmentation_linear_coe]

/-- Linear-map form of naturality for the canonical identification of successive-kernel
subtype presentations. -/
theorem augmentation_truncation_comp (φ : G →* H) (n : ℕ) :
    (truncationKernel (R := R) (G := G) φ n).comp
        (augmentationLinearTruncation R G n).toLinearMap =
      (augmentationLinearTruncation R H n).toLinearMap.comp
        (augmentationTruncationKernel (R := R) (G := G) φ n) := by
  ext q
  exact congrArg (fun x : augmentationTruncationSubmodule R H n =>
      (x : augmentationTruncation R H (n + 1)))
    (ker_truncation_naturality (R := R) (G := G) φ n q)


/-- A group isomorphism induces a linear equivalence on successive truncation kernels. -/
noncomputable def truncationKernelEquiv (e : G ≃* H) (n : ℕ) :
    augmentationTruncationSubmodule R G n ≃ₗ[R]
      augmentationTruncationSubmodule R H n where
  toFun := truncationKernel (R := R) (G := G) e.toMonoidHom n
  invFun := truncationKernel (R := R) (G := H) e.symm.toMonoidHom n
  left_inv q := by
    apply Subtype.ext
    change truncationDomain (R := R) (G := H) e.symm.toMonoidHom (n + 1)
        (truncationDomain (R := R) (G := G) e.toMonoidHom (n + 1) q) = q
    have h := congrArg (fun f : augmentationTruncation R G (n + 1) →+*
        augmentationTruncation R G (n + 1) => f (q : augmentationTruncation R G (n + 1)))
      (domain_comp (R := R) (G := G)
        e.toMonoidHom e.symm.toMonoidHom (n + 1))
    have hcomp : e.symm.toMonoidHom.comp e.toMonoidHom = MonoidHom.id G := by
      ext g; simp
    calc
      truncationDomain (R := R) (G := H) e.symm.toMonoidHom (n + 1)
          (truncationDomain (R := R) (G := G) e.toMonoidHom (n + 1) q) =
        truncationDomain (R := R) (G := G)
          (e.symm.toMonoidHom.comp e.toMonoidHom) (n + 1) q := by
          simpa only [RingHom.comp_apply] using h
      _ = q := by
          rw [hcomp, domain_id]
          rfl
  right_inv q := by
    apply Subtype.ext
    change truncationDomain (R := R) (G := G) e.toMonoidHom (n + 1)
        (truncationDomain (R := R) (G := H) e.symm.toMonoidHom (n + 1) q) = q
    have h := congrArg (fun f : augmentationTruncation R H (n + 1) →+*
        augmentationTruncation R H (n + 1) => f (q : augmentationTruncation R H (n + 1)))
      (domain_comp (R := R) (G := H)
        e.symm.toMonoidHom e.toMonoidHom (n + 1))
    have hcomp : e.toMonoidHom.comp e.symm.toMonoidHom = MonoidHom.id H := by
      ext h; simp
    calc
      truncationDomain (R := R) (G := G) e.toMonoidHom (n + 1)
          (truncationDomain (R := R) (G := H) e.symm.toMonoidHom (n + 1) q) =
        truncationDomain (R := R) (G := H)
          (e.toMonoidHom.comp e.symm.toMonoidHom) (n + 1) q := by
          simpa only [RingHom.comp_apply] using h
      _ = q := by
          rw [hcomp, domain_id]
          rfl
  map_add' q r := map_add _ q r
  map_smul' a q := map_smul _ a q

@[simp] theorem truncation_kernel_coe (e : G ≃* H) (n : ℕ)
    (q : augmentationTruncationSubmodule R G n) :
    ((truncationKernelEquiv (R := R) (G := G) e n q :
        augmentationTruncationSubmodule R H n) : augmentationTruncation R H (n + 1)) =
      truncationDomain (R := R) (G := G) e.toMonoidHom (n + 1) q := rfl


@[simp] theorem augmentation_kernel_symm (e : G ≃* H) (n : ℕ) :
    (truncationKernelEquiv (R := R) (G := G) e n).symm =
      truncationKernelEquiv (R := R) (G := H) e.symm n := by
  ext q
  rfl

@[simp] theorem truncation_kernel_refl (n : ℕ) :
    truncationKernelEquiv (R := R) (G := G) (MulEquiv.refl G) n =
      LinearEquiv.refl R (augmentationTruncationSubmodule R G n) := by
  ext q
  simp [truncation_kernel_coe]

@[simp] theorem truncation_kernel_trans {K : Type*} [Group K]
    (e : G ≃* H) (f : H ≃* K) (n : ℕ) :
    (truncationKernelEquiv (R := R) (G := G) e n).trans
        (truncationKernelEquiv (R := R) (G := H) f n) =
      truncationKernelEquiv (R := R) (G := G) (e.trans f) n := by
  ext q
  change truncationDomain (R := R) (G := H) f.toMonoidHom (n + 1)
      (truncationDomain (R := R) (G := G) e.toMonoidHom (n + 1) q) =
    truncationDomain (R := R) (G := G)
      (f.toMonoidHom.comp e.toMonoidHom) (n + 1) q
  exact DFunLike.congr_fun
    (domain_comp (R := R) (G := G)
      e.toMonoidHom f.toMonoidHom (n + 1)) (q : augmentationTruncation R G (n + 1))

/-- Equivalence-level naturality of the canonical bridge between the two successive-kernel
subtype presentations. -/
@[simp] theorem ker_truncation_trans
    (e : G ≃* H) (n : ℕ) :
    (augmentationLinearTruncation R G n).trans
        (truncationKernelEquiv (R := R) (G := G) e n) =
      (truncationLinearEquiv (R := R) (G := G) e n).trans
        (augmentationLinearTruncation R H n) := by
  ext q
  simp [LinearEquiv.trans_apply]

/-- The canonical identification `R[G]/I ≃ R` is natural in the group. -/
theorem truncation_one_naturality (φ : G →* H) :
    (augmentationTruncationOne R H).toRingHom.comp
        (truncationDomain (R := R) (G := G) φ 1) =
      (augmentationTruncationOne R G).toRingHom := by
  apply RingHom.ext
  intro q
  refine Quotient.inductionOn' q ?_
  intro x
  change augmentationTruncationOne R H
        (truncationDomain (R := R) (G := G) φ 1
          (Ideal.Quotient.mk (augmentationPower R G 1) x)) =
      augmentationTruncationOne R G
        (Ideal.Quotient.mk (augmentationPower R G 1) x)
  simp [augmentation_domain_mk]
  simpa [MonoidAlgebra.mapDomainAlgHom] using
    (augmentation_domain (R := R) (G := G) φ x)

/-- Pointwise naturality of the canonical first-truncation identification. -/
@[simp] theorem truncation_one_equiv (φ : G →* H)
    (q : augmentationTruncation R G 1) :
    augmentationTruncationOne R H
        (truncationDomain (R := R) (G := G) φ 1 q) =
      augmentationTruncationOne R G q := by
  have h := congrArg (fun f : augmentationTruncation R G 1 →+* R => f q)
    (truncation_one_naturality (R := R) (G := G) φ)
  simpa [RingHom.comp_apply] using h

/-- Linear-map form of naturality of the first-truncation identification. -/
theorem truncation_linear_naturality (φ : G →* H) :
    (augmentationLinearEquiv R H).toLinearMap.comp
        (truncationDomainLinear (R := R) (G := G) φ 1) =
      (augmentationLinearEquiv R G).toLinearMap := by
  apply LinearMap.ext
  intro q
  change augmentationTruncationOne R H
      (truncationDomain (R := R) (G := G) φ 1 q) =
    augmentationTruncationOne R G q
  exact truncation_one_equiv (R := R) (G := G) φ q

/-- Pointwise linear naturality of the first-truncation identification. -/
@[simp] theorem augmentation_linear_equiv (φ : G →* H)
    (q : augmentationTruncation R G 1) :
    augmentationLinearEquiv R H
        (truncationDomainLinear (R := R) (G := G) φ 1 q) =
      augmentationLinearEquiv R G q := by
  exact congrArg (fun f : augmentationTruncation R G 1 →ₗ[R] R => f q)
    (truncation_linear_naturality (R := R) (G := G) φ)


/-- Every group-domain map induces an injective map on first truncations. -/
theorem augmentation_truncation_injective (φ : G →* H) :
    Function.Injective (truncationDomain (R := R) (G := G) φ 1) := by
  intro x y hxy
  apply (augmentationTruncationOne R G).injective
  have h := congrArg (fun z => augmentationTruncationOne R H z) hxy
  simpa [truncation_one_equiv] using h

/-- Every group-domain map induces a surjective map on first truncations. -/
theorem domain_one_surjective (φ : G →* H) :
    Function.Surjective (truncationDomain (R := R) (G := G) φ 1) := by
  intro y
  refine ⟨(augmentationTruncationOne R G).symm
      (augmentationTruncationOne R H y), ?_⟩
  apply (augmentationTruncationOne R H).injective
  rw [truncation_one_equiv]
  exact (augmentationTruncationOne R G).apply_symm_apply
    (augmentationTruncationOne R H y)

/-- Bijective form of first-truncation functoriality. -/
theorem augmentation_truncation_bijective (φ : G →* H) :
    Function.Bijective (truncationDomain (R := R) (G := G) φ 1) :=
  ⟨augmentation_truncation_injective (R := R) (G := G) φ,
    domain_one_surjective (R := R) (G := G) φ⟩

/-- The canonical ring equivalence underlying any first-truncation domain map. -/
def truncationDomainEquiv (_φ : G →* H) :
    augmentationTruncation R G 1 ≃+* augmentationTruncation R H 1 :=
  (augmentationTruncationOne R G).trans (augmentationTruncationOne R H).symm

/-- Coordinate formula for the packaged first-truncation equivalence. -/
theorem augmentation_domain_equiv (φ : G →* H)
    (q : augmentationTruncation R G 1) :
    truncationDomainEquiv (R := R) (G := G) φ q =
      (augmentationTruncationOne R H).symm (augmentationTruncationOne R G q) := by
  rfl

/-- The packaged first-truncation equivalence agrees pointwise with the induced map. -/
@[simp] theorem truncation_domain_one (φ : G →* H)
    (q : augmentationTruncation R G 1) :
    truncationDomainEquiv (R := R) (G := G) φ q =
      truncationDomain (R := R) (G := G) φ 1 q := by
  apply (augmentationTruncationOne R H).injective
  rw [truncation_one_equiv]
  change (augmentationTruncationOne R H)
      ((augmentationTruncationOne R H).symm (augmentationTruncationOne R G q)) =
    augmentationTruncationOne R G q
  exact (augmentationTruncationOne R H).apply_symm_apply _

/-- The packaged first-truncation equivalence for the identity homomorphism is identity. -/
@[simp] theorem augmentation_domain_id :
    truncationDomainEquiv (R := R) (G := G) (MonoidHom.id G) =
      RingEquiv.refl (augmentationTruncation R G 1) := by
  ext q
  simp

/-- Packaged first-truncation equivalences compose functorially. -/
@[simp] theorem augmentation_domain_comp {L : Type*} [Group L]
    (φ : G →* H) (ψ : H →* L) :
    truncationDomainEquiv (R := R) (G := G) (ψ.comp φ) =
      (truncationDomainEquiv (R := R) (G := G) φ).trans
        (truncationDomainEquiv (R := R) (G := H) ψ) := by
  ext q
  simp only [RingEquiv.trans_apply, truncation_domain_one]
  have h := congrArg (fun f : augmentationTruncation R G 1 →+*
      augmentationTruncation R L 1 => f q)
    (domain_comp (R := R) (G := G) φ ψ 1)
  change (truncationDomain (R := R) (G := G) (ψ.comp φ) 1) q =
    (truncationDomain (R := R) (G := H) ψ 1)
      ((truncationDomain (R := R) (G := G) φ 1) q)
  change ((truncationDomain (R := R) (G := H) ψ 1).comp
      (truncationDomain (R := R) (G := G) φ 1)) q =
    (truncationDomain (R := R) (G := G) (ψ.comp φ) 1) q at h
  exact h.symm

/-- Any two group-domain maps induce the same map on first truncations. -/
theorem augmentation_domain_ext (φ ψ : G →* H) :
    truncationDomain (R := R) (G := G) φ 1 =
      truncationDomain (R := R) (G := G) ψ 1 := by
  apply RingHom.ext
  intro q
  apply (augmentationTruncationOne R H).injective
  simp [truncation_one_equiv]

/-- Scalar representatives in the first truncation are preserved by every group-domain map. -/
@[simp] theorem augmentation_truncation_scalar (φ : G →* H) (r : R) :
    truncationDomain (R := R) (G := G) φ 1
        ((augmentationTruncationOne R G).symm r) =
      (augmentationTruncationOne R H).symm r := by
  apply (augmentationTruncationOne R H).injective
  rw [truncation_one_equiv]
  rw [(augmentationTruncationOne R H).apply_symm_apply r]
  exact (augmentationTruncationOne R G).apply_symm_apply r

/-- The inverse packaged first-truncation equivalence preserves scalar representatives. -/
@[simp] theorem domain_symm_scalar (φ : G →* H) (r : R) :
    (truncationDomainEquiv (R := R) (G := G) φ).symm
        ((augmentationTruncationOne R H).symm r) =
      (augmentationTruncationOne R G).symm r := by
  change (augmentationTruncationOne R G).symm
      ((augmentationTruncationOne R H) ((augmentationTruncationOne R H).symm r)) =
    (augmentationTruncationOne R G).symm r
  rw [(augmentationTruncationOne R H).apply_symm_apply r]

/-- Linear injectivity form for first-truncation functoriality. -/
theorem truncation_domain_injective (φ : G →* H) :
    Function.Injective (truncationDomainLinear (R := R) (G := G) φ 1) := by
  intro x y hxy
  apply augmentation_truncation_injective (R := R) (G := G) φ
  simpa [domain_linear] using hxy

/-- Linear surjectivity form for first-truncation functoriality. -/
theorem truncation_linear_surjective (φ : G →* H) :
    Function.Surjective (truncationDomainLinear (R := R) (G := G) φ 1) := by
  intro y
  rcases domain_one_surjective (R := R) (G := G) φ y with ⟨x, hx⟩
  exact ⟨x, by simpa [domain_linear] using hx⟩

/-- Bijective linear-map form for first-truncation functoriality. -/
theorem truncation_domain_bijective (φ : G →* H) :
    Function.Bijective (truncationDomainLinear (R := R) (G := G) φ 1) :=
  ⟨truncation_domain_injective (R := R) (G := G) φ,
    truncation_linear_surjective (R := R) (G := G) φ⟩

/-- Packaged linear equivalence underlying any first-truncation domain map. -/
noncomputable def augmentationTruncationDomain (φ : G →* H) :
    augmentationTruncation R G 1 ≃ₗ[R] augmentationTruncation R H 1 :=
  LinearEquiv.ofBijective (truncationDomainLinear (R := R) (G := G) φ 1)
    (truncation_domain_bijective (R := R) (G := G) φ)

/-- The packaged first-truncation linear equivalence acts as the induced linear map. -/
@[simp] theorem augmentation_domain_linear (φ : G →* H)
    (q : augmentationTruncation R G 1) :
    augmentationTruncationDomain (R := R) (G := G) φ q =
      truncationDomainLinear (R := R) (G := G) φ 1 q := by
  rw [augmentationTruncationDomain, LinearEquiv.ofBijective_apply]

/-- Linear-map projection of the packaged first-truncation linear equivalence. -/
@[simp] theorem augmentation_truncation_domain (φ : G →* H) :
    (augmentationTruncationDomain (R := R) (G := G) φ).toLinearMap =
      truncationDomainLinear (R := R) (G := G) φ 1 := by
  apply LinearMap.ext
  intro q
  exact augmentation_domain_linear (R := R) (G := G) φ q

/-- Linear scalar representatives in the first truncation are preserved by every
 group-domain map. -/
@[simp] theorem augmentation_domain_scalar (φ : G →* H) (r : R) :
    truncationDomainLinear (R := R) (G := G) φ 1
        ((augmentationLinearEquiv R G).symm r) =
      (augmentationLinearEquiv R H).symm r := by
  change truncationDomain (R := R) (G := G) φ 1
        ((augmentationTruncationOne R G).symm r) =
      (augmentationTruncationOne R H).symm r
  exact augmentation_truncation_scalar (R := R) (G := G) φ r

/-- The packaged first-truncation linear equivalence for the identity homomorphism is
identity. -/
@[simp] theorem truncation_domain_id :
    augmentationTruncationDomain (R := R) (G := G) (MonoidHom.id G) =
      LinearEquiv.refl R (augmentationTruncation R G 1) := by
  ext q
  simp [augmentation_domain_linear]

/-- Packaged first-truncation linear equivalences compose functorially. -/
@[simp] theorem truncation_domain_comp {L : Type*} [Group L]
    (φ : G →* H) (ψ : H →* L) :
    augmentationTruncationDomain (R := R) (G := G) (ψ.comp φ) =
      (augmentationTruncationDomain (R := R) (G := G) φ).trans
        (augmentationTruncationDomain (R := R) (G := H) ψ) := by
  ext q
  simp only [LinearEquiv.trans_apply, augmentation_domain_linear]
  have h := congrArg (fun f : augmentationTruncation R G 1 →ₗ[R]
      augmentationTruncation R L 1 => f q)
    (domain_linear_comp (R := R) (G := G) φ ψ 1)
  change truncationDomainLinear (R := R) (G := G) (ψ.comp φ) 1 q =
    truncationDomainLinear (R := R) (G := H) ψ 1
      (truncationDomainLinear (R := R) (G := G) φ 1 q)
  exact h.symm

/-- The inverse packaged first-truncation linear equivalence preserves scalar representatives. -/
@[simp] theorem truncation_domain_scalar
    (φ : G →* H) (r : R) :
    (augmentationTruncationDomain (R := R) (G := G) φ).symm
        ((augmentationLinearEquiv R H).symm r) =
      (augmentationLinearEquiv R G).symm r := by
  apply (augmentationTruncationDomain (R := R) (G := G) φ).injective
  calc
    augmentationTruncationDomain (R := R) (G := G) φ
        ((augmentationTruncationDomain (R := R) (G := G) φ).symm
          ((augmentationLinearEquiv R H).symm r)) =
        (augmentationLinearEquiv R H).symm r := by simp
    _ = augmentationTruncationDomain (R := R) (G := G) φ
        ((augmentationLinearEquiv R G).symm r) := by
        rw [augmentation_domain_linear,
          augmentation_domain_scalar]

/-- Coordinate formula for the packaged first-truncation linear equivalence. -/
theorem truncation_domain_linear (φ : G →* H)
    (q : augmentationTruncation R G 1) :
    augmentationTruncationDomain (R := R) (G := G) φ q =
      (augmentationLinearEquiv R H).symm
        (augmentationLinearEquiv R G q) := by
  apply (augmentationLinearEquiv R H).injective
  rw [augmentation_domain_linear,
    augmentation_linear_equiv]
  simp

/-- Coordinate formula for the inverse packaged first-truncation linear equivalence. -/
theorem truncation_domain_symm (φ : G →* H)
    (q : augmentationTruncation R H 1) :
    (augmentationTruncationDomain (R := R) (G := G) φ).symm q =
      (augmentationLinearEquiv R G).symm
        (augmentationLinearEquiv R H q) := by
  calc
    (augmentationTruncationDomain (R := R) (G := G) φ).symm q =
        (augmentationTruncationDomain (R := R) (G := G) φ).symm
          ((augmentationLinearEquiv R H).symm
            (augmentationLinearEquiv R H q)) := by simp
    _ = (augmentationLinearEquiv R G).symm
        (augmentationLinearEquiv R H q) := by
        rw [truncation_domain_scalar]

/-- Kernel form of first-truncation linear injectivity. -/
theorem truncation_domain_bot (φ : G →* H) :
    LinearMap.ker (truncationDomainLinear (R := R) (G := G) φ 1) = ⊥ :=
  LinearMap.ker_eq_bot_of_injective
    (truncation_domain_injective (R := R) (G := G) φ)

/-- Range form of first-truncation linear surjectivity. -/
theorem truncation_domain_top (φ : G →* H) :
    LinearMap.range (truncationDomainLinear (R := R) (G := G) φ 1) = ⊤ :=
  LinearMap.range_eq_top.mpr
    (truncation_linear_surjective (R := R) (G := G) φ)

/-- A group isomorphism induces a ring equivalence on fixed-depth augmentation truncations. -/
noncomputable def augmentationTruncationEquiv (e : G ≃* H) (n : ℕ) :
    augmentationTruncation R G n ≃+* augmentationTruncation R H n where
  toFun := truncationDomain (R := R) (G := G) e.toMonoidHom n
  invFun := truncationDomain (R := R) (G := H) e.symm.toMonoidHom n
  left_inv := by
    intro q
    change ((truncationDomain (R := R) (G := H) e.symm.toMonoidHom n).comp
      (truncationDomain (R := R) (G := G) e.toMonoidHom n)) q = q
    rw [domain_comp]
    have hcomp : e.symm.toMonoidHom.comp e.toMonoidHom = MonoidHom.id G := by
      ext g; simp
    rw [hcomp, domain_id]
    rfl
  right_inv := by
    intro q
    change ((truncationDomain (R := R) (G := G) e.toMonoidHom n).comp
      (truncationDomain (R := R) (G := H) e.symm.toMonoidHom n)) q = q
    rw [domain_comp]
    have hcomp : e.toMonoidHom.comp e.symm.toMonoidHom = MonoidHom.id H := by
      ext h; simp
    rw [hcomp, domain_id]
    rfl
  map_mul' := by
    intro x y
    exact map_mul _ x y
  map_add' := by
    intro x y
    exact map_add _ x y

@[simp] theorem augmentation_equiv_mk (e : G ≃* H) (n : ℕ)
    (x : MonoidAlgebra R G) :
    augmentationTruncationEquiv (R := R) (G := G) e n
        (Ideal.Quotient.mk (augmentationPower R G n) x) =
      Ideal.Quotient.mk (augmentationPower R H n)
        ((MonoidAlgebra.mapDomainAlgHom R R e.toMonoidHom) x) := by
  rfl

/-- In degree one, the arbitrary-hom packaged equivalence agrees with the usual
isomorphism-induced truncation equivalence. -/
theorem truncation_domain_equiv (e : G ≃* H) :
    truncationDomainEquiv (R := R) (G := G) e.toMonoidHom =
      augmentationTruncationEquiv (R := R) (G := G) e 1 := by
  ext q
  change truncationDomainEquiv (R := R) (G := G) e.toMonoidHom q =
    truncationDomain (R := R) (G := G) e.toMonoidHom 1 q
  exact truncation_domain_one (R := R) (G := G) e.toMonoidHom q

/-- The truncation map induced by a group isomorphism is bijective. -/
theorem augmentation_domain_bijective (e : G ≃* H) (n : ℕ) :
    Function.Bijective (truncationDomain (R := R) (G := G) e.toMonoidHom n) := by
  simpa [augmentationTruncationEquiv] using
    (augmentationTruncationEquiv (R := R) (G := G) e n).bijective

/-- Injectivity of the truncation map induced by a group isomorphism. -/
theorem augmentation_domain_injective (e : G ≃* H) (n : ℕ) :
    Function.Injective (truncationDomain (R := R) (G := G) e.toMonoidHom n) :=
  (augmentation_domain_bijective (R := R) (G := G) e n).1

/-- Surjectivity of the truncation map induced by a group isomorphism. -/
theorem domain_surjective_equiv (e : G ≃* H) (n : ℕ) :
    Function.Surjective (truncationDomain (R := R) (G := G) e.toMonoidHom n) :=
  (augmentation_domain_bijective (R := R) (G := G) e n).2

@[simp] theorem truncation_symm (e : G ≃* H) (n : ℕ) :
    (augmentationTruncationEquiv (R := R) (G := G) e n).symm =
      augmentationTruncationEquiv (R := R) (G := H) e.symm n := by
  ext q
  refine Quotient.inductionOn' q ?_
  intro x
  rfl

@[simp] theorem truncation_equiv_refl (n : ℕ) :
    augmentationTruncationEquiv (R := R) (G := G) (MulEquiv.refl G) n =
      RingEquiv.refl (augmentationTruncation R G n) := by
  ext q
  refine Quotient.inductionOn' q ?_
  intro x
  change truncationDomain (R := R) (G := G) (MonoidHom.id G) n
      (Ideal.Quotient.mk (augmentationPower R G n) x) =
    Ideal.Quotient.mk (augmentationPower R G n) x
  simp

@[simp] theorem truncation_equiv_trans {K : Type*} [Group K]
    (e : G ≃* H) (f : H ≃* K) (n : ℕ) :
    (augmentationTruncationEquiv (R := R) (G := G) e n).trans
        (augmentationTruncationEquiv (R := R) (G := H) f n) =
      augmentationTruncationEquiv (R := R) (G := G) (e.trans f) n := by
  ext q
  change ((truncationDomain (R := R) (G := H) f.toMonoidHom n).comp
        (truncationDomain (R := R) (G := G) e.toMonoidHom n)) q =
      truncationDomain (R := R) (G := G)
        (f.toMonoidHom.comp e.toMonoidHom) n q
  exact DFunLike.congr_fun
    (domain_comp (R := R) (G := G)
      e.toMonoidHom f.toMonoidHom n) q

/-- Isomorphism-induced truncation equivalences commute with transition maps. -/
theorem augmentation_equiv_naturality {m n : ℕ} (hmn : m ≤ n)
    (e : G ≃* H) :
    (augmentationTruncationMap R H hmn).comp
        (augmentationTruncationEquiv (R := R) (G := G) e n).toRingHom =
      (augmentationTruncationEquiv (R := R) (G := G) e m).toRingHom.comp
        (augmentationTruncationMap R G hmn) := by
  simpa [augmentationTruncationEquiv]
    using augmentation_domain_naturality (R := R) (G := G) hmn e.toMonoidHom

/-- A group isomorphism induces an `R`-linear equivalence on fixed-depth
augmentation truncations. -/
noncomputable def truncationLinear (e : G ≃* H) (n : ℕ) :
    augmentationTruncation R G n ≃ₗ[R] augmentationTruncation R H n where
  toFun := truncationDomainLinear (R := R) (G := G) e.toMonoidHom n
  invFun := truncationDomainLinear (R := R) (G := H) e.symm.toMonoidHom n
  left_inv := by
    intro q
    change ((truncationDomainLinear (R := R) (G := H) e.symm.toMonoidHom n).comp
      (truncationDomainLinear (R := R) (G := G) e.toMonoidHom n)) q = q
    rw [domain_linear_comp]
    have hcomp : e.symm.toMonoidHom.comp e.toMonoidHom = MonoidHom.id G := by
      ext g; simp
    rw [hcomp, domain_linear_id]
    rfl
  right_inv := by
    intro q
    change ((truncationDomainLinear (R := R) (G := G) e.toMonoidHom n).comp
      (truncationDomainLinear (R := R) (G := H) e.symm.toMonoidHom n)) q = q
    rw [domain_linear_comp]
    have hcomp : e.toMonoidHom.comp e.symm.toMonoidHom = MonoidHom.id H := by
      ext h; simp
    rw [hcomp, domain_linear_id]
    rfl
  map_add' x y := map_add _ x y
  map_smul' r x := map_smul _ r x

@[simp] theorem augmentation_truncation (e : G ≃* H) (n : ℕ)
    (q : augmentationTruncation R G n) :
    truncationLinear (R := R) (G := G) e n q =
      truncationDomainLinear (R := R) (G := G) e.toMonoidHom n q := rfl

@[simp] theorem truncation_linear_mk (e : G ≃* H) (n : ℕ)
    (x : MonoidAlgebra R G) :
    truncationLinear (R := R) (G := G) e n
        (Ideal.Quotient.mk (augmentationPower R G n) x) =
      Ideal.Quotient.mk (augmentationPower R H n)
        ((MonoidAlgebra.mapDomainAlgHom R R e.toMonoidHom) x) := by
  rfl

@[simp] theorem linear_equiv_symm (e : G ≃* H) (n : ℕ) :
    (truncationLinear (R := R) (G := G) e n).symm =
      truncationLinear (R := R) (G := H) e.symm n := by
  ext q
  refine Quotient.inductionOn' q ?_
  intro x
  rfl

@[simp] theorem truncation_linear_refl (n : ℕ) :
    truncationLinear (R := R) (G := G) (MulEquiv.refl G) n =
      LinearEquiv.refl R (augmentationTruncation R G n) := by
  ext q
  refine Quotient.inductionOn' q ?_
  intro x
  change truncationDomainLinear (R := R) (G := G) (MonoidHom.id G) n
      (Ideal.Quotient.mk (augmentationPower R G n) x) =
    Ideal.Quotient.mk (augmentationPower R G n) x
  simp

@[simp] theorem augmentation_linear_trans {K : Type*} [Group K]
    (e : G ≃* H) (f : H ≃* K) (n : ℕ) :
    (truncationLinear (R := R) (G := G) e n).trans
        (truncationLinear (R := R) (G := H) f n) =
      truncationLinear (R := R) (G := G) (e.trans f) n := by
  ext q
  change ((truncationDomainLinear (R := R) (G := H) f.toMonoidHom n).comp
        (truncationDomainLinear (R := R) (G := G) e.toMonoidHom n)) q =
      truncationDomainLinear (R := R) (G := G)
        (f.toMonoidHom.comp e.toMonoidHom) n q
  exact DFunLike.congr_fun
    (domain_linear_comp (R := R) (G := G)
      e.toMonoidHom f.toMonoidHom n) q

/-- Linear equivariance of truncation transition maps under group isomorphisms. -/
theorem truncation_equiv_naturality {m n : ℕ} (hmn : m ≤ n)
    (e : G ≃* H) :
    (augmentationLinear R H hmn).comp
        (truncationLinear (R := R) (G := G) e n).toLinearMap =
      (truncationLinear (R := R) (G := G) e m).toLinearMap.comp
        (augmentationLinear R G hmn) := by
  simpa [truncationLinear]
    using truncation_domain_naturality (R := R) (G := G) hmn e.toMonoidHom

/-- The induced linear map on the `n`th augmentation-power submodules. -/
def augmentationPowerMap (φ : G →* H) (n : ℕ) :
    augmentationPowerSubmodule R G n →ₗ[R] augmentationPowerSubmodule R H n :=
  ((MonoidAlgebra.mapDomainAlgHom R R φ).toLinearMap.domRestrict
    (augmentationPowerSubmodule R G n)).codRestrict
      (augmentationPowerSubmodule R H n) (by
        intro x
        change (MonoidAlgebra.mapDomainAlgHom R R φ) (x : MonoidAlgebra R G) ∈
          augmentationPowerSubmodule R H n
        have hxI : (x : MonoidAlgebra R G) ∈ augmentationPower R G n := x.property
        exact augmentation_power_domain (R := R) (G := G) φ n
          (Ideal.mem_map_of_mem _ hxI))

/-- Coercion formula for the induced map on augmentation powers. -/
@[simp] theorem augmentation_coe (φ : G →* H) (n : ℕ)
    (x : augmentationPowerSubmodule R G n) :
    ((augmentationPowerMap (R := R) (G := G) φ n x : augmentationPowerSubmodule R H n) :
      MonoidAlgebra R H) =
      (MonoidAlgebra.mapDomainAlgHom R R φ) (x : MonoidAlgebra R G) := rfl


/-- A surjective group homomorphism induces surjective maps on augmentation powers. -/
theorem augmentation_power_surjective (φ : G →* H)
    (hs : Function.Surjective φ) (n : ℕ) :
    Function.Surjective (augmentationPowerMap (R := R) (G := G) φ n) := by
  intro y
  have hy : (y : MonoidAlgebra R H) ∈ augmentationPower R H n := y.property
  let f := (MonoidAlgebra.mapDomainAlgHom R R φ).toRingHom
  have hf : Function.Surjective f := by
    intro z
    rcases domain_hom_surjective (R := R) φ hs z with ⟨x, hx⟩
    exact ⟨x, hx⟩
  have hmap := power_domain_surjective (R := R) (G := G) φ hs n
  have hy' : (y : MonoidAlgebra R H) ∈ Ideal.map f (augmentationPower R G n) := by
    rw [hmap]
    exact hy
  rcases (Ideal.mem_map_iff_of_surjective f hf).mp hy' with ⟨x, hx, hxy⟩
  refine ⟨⟨x, hx⟩, ?_⟩
  apply Subtype.ext
  change f x = (y : MonoidAlgebra R H)
  simpa [f] using hxy

/-- Range form of surjectivity for augmentation-power maps. -/
theorem augmentation_top_surjective (φ : G →* H)
    (hs : Function.Surjective φ) (n : ℕ) :
    LinearMap.range (augmentationPowerMap (R := R) (G := G) φ n) = ⊤ :=
  LinearMap.range_eq_top.mpr
    (augmentation_power_surjective (R := R) (G := G) φ hs n)

/-- The induced linear map on successive augmentation layers. -/
def augmentationLayerMap (φ : G →* H) (n : ℕ) :
    augmentationLayer R G n →ₗ[R] augmentationLayer R H n :=
  Submodule.mapQ (augmentationLayerDenom R G n) (augmentationLayerDenom R H n)
    (augmentationPowerMap (R := R) (G := G) φ n) (by
      intro x hx
      change (augmentationPowerMap (R := R) (G := G) φ n x :
          augmentationPowerSubmodule R H n) ∈ augmentationLayerDenom R H n
      change ((augmentationPowerMap (R := R) (G := G) φ n x :
          augmentationPowerSubmodule R H n) : MonoidAlgebra R H) ∈
        augmentationPowerSubmodule R H (n + 1)
      change (x : MonoidAlgebra R G) ∈ augmentationPowerSubmodule R G (n + 1) at hx
      have hxI : (x : MonoidAlgebra R G) ∈ augmentationPower R G (n + 1) := hx
      simpa using (augmentation_power_domain (R := R) (G := G) φ (n + 1)
        (Ideal.mem_map_of_mem _ hxI)))

/-- Formula for `augmentationLayerMap` on quotient representatives. -/
@[simp] theorem augmentation_mk (φ : G →* H) (n : ℕ)
    (x : augmentationPowerSubmodule R G n) :
    augmentationLayerMap (R := R) (G := G) φ n (Submodule.Quotient.mk x) =
      Submodule.Quotient.mk (augmentationPowerMap (R := R) (G := G) φ n x) := by
  unfold augmentationLayerMap
  exact Submodule.mapQ_apply _ _ _ x

/-- A surjective group homomorphism induces surjective maps on augmentation layers. -/
theorem augmentation_layer_surjective (φ : G →* H)
    (hs : Function.Surjective φ) (n : ℕ) :
    Function.Surjective (augmentationLayerMap (R := R) (G := G) φ n) := by
  intro y
  refine Quotient.inductionOn' y ?_
  intro b
  rcases augmentation_power_surjective (R := R) (G := G) φ hs n b with
    ⟨a, ha⟩
  refine ⟨Submodule.Quotient.mk a, ?_⟩
  rw [augmentation_mk]
  exact congrArg Submodule.Quotient.mk ha

/-- Range form of surjectivity for augmentation-layer maps. -/
theorem range_top_surjective (φ : G →* H)
    (hs : Function.Surjective φ) (n : ℕ) :
    LinearMap.range (augmentationLayerMap (R := R) (G := G) φ n) = ⊤ :=
  LinearMap.range_eq_top.mpr
    (augmentation_layer_surjective (R := R) (G := G) φ hs n)

/-- The identity homomorphism induces the identity on augmentation powers. -/
@[simp] theorem augmentation_power_id (n : ℕ) :
    augmentationPowerMap (R := R) (G := G) (MonoidHom.id G) n = LinearMap.id := by
  ext x : 1
  apply Subtype.ext
  simp [augmentationPowerMap]

/-- The identity homomorphism induces the identity on augmentation layers. -/
@[simp] theorem augmentation_id (n : ℕ) :
    augmentationLayerMap (R := R) (G := G) (MonoidHom.id G) n = LinearMap.id := by
  ext x
  change Submodule.Quotient.mk
      (augmentationPowerMap (R := R) (G := G) (MonoidHom.id G) n x) =
    Submodule.Quotient.mk x
  congr 1
  apply Subtype.ext
  simp [augmentationPowerMap]

/-- Augmentation-power maps compose functorially. -/
@[simp] theorem augmentation_power_comp {L : Type*} [Group L]
    (φ : G →* H) (ψ : H →* L) (n : ℕ) :
    augmentationPowerMap (R := R) (G := G) (ψ.comp φ) n =
      (augmentationPowerMap (R := R) (G := H) ψ n).comp
        (augmentationPowerMap (R := R) (G := G) φ n) := by
  ext x : 1
  apply Subtype.ext
  simp [augmentationPowerMap, MonoidAlgebra.mapDomainAlgHom]

/-- Augmentation-layer maps compose functorially. -/
@[simp] theorem augmentation_comp {L : Type*} [Group L]
    (φ : G →* H) (ψ : H →* L) (n : ℕ) :
    augmentationLayerMap (R := R) (G := G) (ψ.comp φ) n =
      (augmentationLayerMap (R := R) (G := H) ψ n).comp
        (augmentationLayerMap (R := R) (G := G) φ n) := by
  ext x
  change Submodule.Quotient.mk
      (augmentationPowerMap (R := R) (G := G) (ψ.comp φ) n x) =
    Submodule.Quotient.mk
      (augmentationPowerMap (R := R) (G := H) ψ n
        (augmentationPowerMap (R := R) (G := G) φ n x))
  congr 1
  apply Subtype.ext
  simp [augmentationPowerMap, MonoidAlgebra.mapDomainAlgHom]


/-- The canonical inclusion of a layer into the next truncation is natural for group
homomorphisms. -/
theorem augmentation_layer_naturality (φ : G →* H) (n : ℕ)
    (z : augmentationLayer R G n) :
    truncationDomain (R := R) (G := G) φ (n + 1)
        (layerTruncation R G n z) =
      layerTruncation R H n
        (augmentationLayerMap (R := R) (G := G) φ n z) := by
  refine Quotient.inductionOn' z ?_
  intro x
  change truncationDomain (R := R) (G := G) φ (n + 1)
      (Ideal.Quotient.mk (augmentationPower R G (n + 1))
        (x : MonoidAlgebra R G)) =
    Ideal.Quotient.mk (augmentationPower R H (n + 1))
      ((augmentationPowerMap (R := R) (G := G) φ n x :
          augmentationPowerSubmodule R H n) : MonoidAlgebra R H)
  rw [augmentation_domain_mk]
  rfl

/-- Degree-zero form of layer-to-truncation naturality using the packaged first-truncation
linear equivalence. -/
@[simp] theorem augmentation_truncation_equiv (φ : G →* H)
    (z : augmentationLayer R G 0) :
    augmentationTruncationDomain (R := R) (G := G) φ
        (layerTruncation R G 0 z) =
      layerTruncation R H 0
        (augmentationLayerMap (R := R) (G := G) φ 0 z) := by
  rw [augmentation_domain_linear]
  change truncationDomain (R := R) (G := G) φ 1
      (layerTruncation R G 0 z) =
    layerTruncation R H 0
      (augmentationLayerMap (R := R) (G := G) φ 0 z)
  exact augmentation_layer_naturality (R := R) (G := G) φ 0 z

/-- The direct layer-to-linear-kernel equivalence is natural for group homomorphisms. -/
theorem augmentation_linear_naturality (φ : G →* H) (n : ℕ)
    (z : augmentationLayer R G n) :
    augmentationTruncationKernel (R := R) (G := G) φ n
        (augmentationLinearKer R G n z) =
      augmentationLinearKer R H n
        (augmentationLayerMap (R := R) (G := G) φ n z) := by
  apply Subtype.ext
  change truncationDomainLinear (R := R) (G := G) φ (n + 1)
      (layerTruncation R G n z) =
    layerTruncation R H n
      (augmentationLayerMap (R := R) (G := G) φ n z)
  change truncationDomain (R := R) (G := G) φ (n + 1)
      (layerTruncation R G n z) =
    layerTruncation R H n
      (augmentationLayerMap (R := R) (G := G) φ n z)
  exact augmentation_layer_naturality (R := R) (G := G) φ n z

/-- The layer-to-successive-kernel equivalence is natural for group homomorphisms. -/
theorem layer_truncation_naturality (φ : G →* H) (n : ℕ)
    (z : augmentationLayer R G n) :
    truncationKernel (R := R) (G := G) φ n
        (augmentationLayerTruncation R G n z) =
      augmentationLayerTruncation R H n
        (augmentationLayerMap (R := R) (G := G) φ n z) := by
  apply Subtype.ext
  change truncationDomain (R := R) (G := G) φ (n + 1)
      (layerTruncation R G n z) =
    layerTruncation R H n
      (augmentationLayerMap (R := R) (G := G) φ n z)
  exact augmentation_layer_naturality (R := R) (G := G) φ n z

/-- A group isomorphism induces a linear equivalence on each augmentation power. -/
noncomputable def augmentationPowerEquiv (e : G ≃* H) (n : ℕ) :
    augmentationPowerSubmodule R G n ≃ₗ[R] augmentationPowerSubmodule R H n where
  toLinearMap := augmentationPowerMap (R := R) (G := G) e.toMonoidHom n
  invFun := augmentationPowerMap (R := R) (G := H) e.symm.toMonoidHom n
  left_inv := by
    intro x
    change augmentationPowerMap (R := R) (G := H) e.symm.toMonoidHom n
        (augmentationPowerMap (R := R) (G := G) e.toMonoidHom n x) = x
    have h := congrArg (fun (f : augmentationPowerSubmodule R G n →ₗ[R]
        augmentationPowerSubmodule R G n) => f x)
      (augmentation_power_comp (R := R) (G := G) e.toMonoidHom e.symm.toMonoidHom n)
    -- The composite homomorphism is extensionally the identity.
    have hcomp : e.symm.toMonoidHom.comp e.toMonoidHom = MonoidHom.id G := by
      ext g; simp
    simpa [hcomp] using h.symm
  right_inv := by
    intro y
    change augmentationPowerMap (R := R) (G := G) e.toMonoidHom n
        (augmentationPowerMap (R := R) (G := H) e.symm.toMonoidHom n y) = y
    have h := congrArg (fun (f : augmentationPowerSubmodule R H n →ₗ[R]
        augmentationPowerSubmodule R H n) => f y)
      (augmentation_power_comp (R := R) (G := H) e.symm.toMonoidHom e.toMonoidHom n)
    have hcomp : e.toMonoidHom.comp e.symm.toMonoidHom = MonoidHom.id H := by
      ext h; simp
    simpa [hcomp] using h.symm

@[simp] theorem augmentation_power_equiv (e : G ≃* H) (n : ℕ)
    (x : augmentationPowerSubmodule R G n) :
    augmentationPowerEquiv (R := R) (G := G) e n x =
      augmentationPowerMap (R := R) (G := G) e.toMonoidHom n x := rfl


/-- The augmentation-power map induced by a group isomorphism is bijective. -/
theorem augmentation_bijective_equiv (e : G ≃* H) (n : ℕ) :
    Function.Bijective (augmentationPowerMap (R := R) (G := G) e.toMonoidHom n) := by
  simpa [augmentationPowerEquiv] using
    (augmentationPowerEquiv (R := R) (G := G) e n).bijective

/-- Injectivity of the augmentation-power map induced by a group isomorphism. -/
theorem augmentation_injective_equiv (e : G ≃* H) (n : ℕ) :
    Function.Injective (augmentationPowerMap (R := R) (G := G) e.toMonoidHom n) :=
  (augmentation_bijective_equiv (R := R) (G := G) e n).1

/-- Surjectivity of the augmentation-power map induced by a group isomorphism. -/
theorem power_surjective_equiv (e : G ≃* H) (n : ℕ) :
    Function.Surjective (augmentationPowerMap (R := R) (G := G) e.toMonoidHom n) :=
  (augmentation_bijective_equiv (R := R) (G := G) e n).2

@[simp] theorem augmentation_power_coe (e : G ≃* H) (n : ℕ)
    (x : augmentationPowerSubmodule R G n) :
    ((augmentationPowerEquiv (R := R) (G := G) e n x :
        augmentationPowerSubmodule R H n) : MonoidAlgebra R H) =
      (MonoidAlgebra.mapDomainAlgHom R R e.toMonoidHom) (x : MonoidAlgebra R G) := rfl

/-- Coercion formula for the inverse of an augmentation-power equivalence. -/
@[simp] theorem augmentation_symm_coe (e : G ≃* H) (n : ℕ)
    (y : augmentationPowerSubmodule R H n) :
    (((augmentationPowerEquiv (R := R) (G := G) e n).symm y :
        augmentationPowerSubmodule R G n) : MonoidAlgebra R G) =
      (MonoidAlgebra.mapDomainAlgHom R R e.symm.toMonoidHom) (y : MonoidAlgebra R H) := by
  rfl

@[simp] theorem augmentation_power_symm (e : G ≃* H) (n : ℕ) :
    (augmentationPowerEquiv (R := R) (G := G) e n).symm =
      augmentationPowerEquiv (R := R) (G := H) e.symm n := by
  ext x : 1
  rfl

@[simp] theorem augmentation_power_refl (n : ℕ) :
    augmentationPowerEquiv (R := R) (G := G) (MulEquiv.refl G) n =
      LinearEquiv.refl R (augmentationPowerSubmodule R G n) := by
  ext x : 1
  change augmentationPowerMap (R := R) (G := G) (MonoidHom.id G) n x = x
  exact congrArg (fun f : augmentationPowerSubmodule R G n →ₗ[R]
      augmentationPowerSubmodule R G n => f x)
    (augmentation_power_id (R := R) (G := G) n)

@[simp] theorem augmentation_power_trans {K : Type*} [Group K]
    (e : G ≃* H) (f : H ≃* K) (n : ℕ) :
    (augmentationPowerEquiv (R := R) (G := G) e n).trans
        (augmentationPowerEquiv (R := R) (G := H) f n) =
      augmentationPowerEquiv (R := R) (G := G) (e.trans f) n := by
  ext x : 1
  change augmentationPowerMap (R := R) (G := H) f.toMonoidHom n
        (augmentationPowerMap (R := R) (G := G) e.toMonoidHom n x) =
      augmentationPowerMap (R := R) (G := G) (f.toMonoidHom.comp e.toMonoidHom) n x
  have h := congrArg (fun u : augmentationPowerSubmodule R G n →ₗ[R]
      augmentationPowerSubmodule R K n => u x)
    (augmentation_power_comp (R := R) (G := G) e.toMonoidHom f.toMonoidHom n)
  simpa only using h.symm

/-- A group isomorphism induces a linear equivalence on successive augmentation layers. -/
noncomputable def augmentationLayerEquiv (e : G ≃* H) (n : ℕ) :
    augmentationLayer R G n ≃ₗ[R] augmentationLayer R H n where
  toLinearMap := augmentationLayerMap (R := R) (G := G) e.toMonoidHom n
  invFun := augmentationLayerMap (R := R) (G := H) e.symm.toMonoidHom n
  left_inv := by
    intro x
    change augmentationLayerMap (R := R) (G := H) e.symm.toMonoidHom n
        (augmentationLayerMap (R := R) (G := G) e.toMonoidHom n x) = x
    have h := congrArg (fun (f : augmentationLayer R G n →ₗ[R]
        augmentationLayer R G n) => f x)
      (augmentation_comp (R := R) (G := G) e.toMonoidHom e.symm.toMonoidHom n)
    have hcomp : e.symm.toMonoidHom.comp e.toMonoidHom = MonoidHom.id G := by
      ext g; simp
    simpa [hcomp] using h.symm
  right_inv := by
    intro y
    change augmentationLayerMap (R := R) (G := G) e.toMonoidHom n
        (augmentationLayerMap (R := R) (G := H) e.symm.toMonoidHom n y) = y
    have h := congrArg (fun (f : augmentationLayer R H n →ₗ[R]
        augmentationLayer R H n) => f y)
      (augmentation_comp (R := R) (G := H) e.symm.toMonoidHom e.toMonoidHom n)
    have hcomp : e.toMonoidHom.comp e.symm.toMonoidHom = MonoidHom.id H := by
      ext h; simp
    simpa [hcomp] using h.symm

@[simp] theorem layer_equiv_mk (e : G ≃* H) (n : ℕ)
    (x : augmentationPowerSubmodule R G n) :
    augmentationLayerEquiv (R := R) (G := G) e n (Submodule.Quotient.mk x) =
      Submodule.Quotient.mk
        (augmentationPowerMap (R := R) (G := G) e.toMonoidHom n x) := by
  rfl






/-- The augmentation-layer map induced by a group isomorphism is bijective. -/
theorem augmentation_layer_bijective (e : G ≃* H) (n : ℕ) :
    Function.Bijective (augmentationLayerMap (R := R) (G := G) e.toMonoidHom n) := by
  simpa [augmentationLayerEquiv] using
    (augmentationLayerEquiv (R := R) (G := G) e n).bijective

/-- Injectivity of the augmentation-layer map induced by a group isomorphism. -/
theorem augmentation_layer_injective (e : G ≃* H) (n : ℕ) :
    Function.Injective (augmentationLayerMap (R := R) (G := G) e.toMonoidHom n) :=
  (augmentation_layer_bijective (R := R) (G := G) e n).1

/-- Surjectivity of the augmentation-layer map induced by a group isomorphism. -/
theorem augmentation_surjective_equiv (e : G ≃* H) (n : ℕ) :
    Function.Surjective (augmentationLayerMap (R := R) (G := G) e.toMonoidHom n) :=
  (augmentation_layer_bijective (R := R) (G := G) e n).2

@[simp] theorem augmentation_symm_mk (e : G ≃* H) (n : ℕ)
    (x : augmentationPowerSubmodule R H n) :
    (augmentationLayerEquiv (R := R) (G := G) e n).symm (Submodule.Quotient.mk x) =
      Submodule.Quotient.mk
        (augmentationPowerMap (R := R) (G := H) e.symm.toMonoidHom n x) := by
  rfl

@[simp] theorem layer_symm (e : G ≃* H) (n : ℕ) :
    (augmentationLayerEquiv (R := R) (G := G) e n).symm =
      augmentationLayerEquiv (R := R) (G := H) e.symm n := by
  ext x
  refine Submodule.Quotient.induction_on (augmentationLayerDenom R H n) x ?_
  intro a
  rfl

/-- The inverse layer equivalence cancels the layer map induced by an isomorphism. -/
@[simp] theorem augmentation_equiv_symm (e : G ≃* H) (n : ℕ)
    (x : augmentationLayer R G n) :
    (augmentationLayerEquiv (R := R) (G := G) e n).symm
        (augmentationLayerMap (R := R) (G := G) e.toMonoidHom n x) = x := by
  change (augmentationLayerEquiv (R := R) (G := G) e n).symm
      (augmentationLayerEquiv (R := R) (G := G) e n x) = x
  exact (augmentationLayerEquiv (R := R) (G := G) e n).left_inv x

/-- The layer map induced by an isomorphism cancels the inverse layer equivalence. -/
@[simp] theorem augmentation_symm (e : G ≃* H) (n : ℕ)
    (y : augmentationLayer R H n) :
    augmentationLayerMap (R := R) (G := G) e.toMonoidHom n
        ((augmentationLayerEquiv (R := R) (G := G) e n).symm y) = y := by
  change augmentationLayerEquiv (R := R) (G := G) e n
      ((augmentationLayerEquiv (R := R) (G := G) e n).symm y) = y
  exact (augmentationLayerEquiv (R := R) (G := G) e n).right_inv y

@[simp] theorem augmentation_layer_refl (n : ℕ) :
    augmentationLayerEquiv (R := R) (G := G) (MulEquiv.refl G) n =
      LinearEquiv.refl R (augmentationLayer R G n) := by
  ext x
  change augmentationLayerMap (R := R) (G := G) (MonoidHom.id G) n x = x
  exact congrArg (fun f : augmentationLayer R G n →ₗ[R] augmentationLayer R G n => f x)
    (augmentation_id (R := R) (G := G) n)

@[simp] theorem augmentation_layer_trans {K : Type*} [Group K]
    (e : G ≃* H) (f : H ≃* K) (n : ℕ) :
    (augmentationLayerEquiv (R := R) (G := G) e n).trans
        (augmentationLayerEquiv (R := R) (G := H) f n) =
      augmentationLayerEquiv (R := R) (G := G) (e.trans f) n := by
  ext x
  change augmentationLayerMap (R := R) (G := H) f.toMonoidHom n
        (augmentationLayerMap (R := R) (G := G) e.toMonoidHom n x) =
      augmentationLayerMap (R := R) (G := G) (f.toMonoidHom.comp e.toMonoidHom) n x
  have h := congrArg (fun u : augmentationLayer R G n →ₗ[R] augmentationLayer R K n => u x)
    (augmentation_comp (R := R) (G := G) e.toMonoidHom f.toMonoidHom n)
  simpa only using h.symm

/-- The layer-to-linear-kernel equivalence is equivariant for group isomorphisms. -/
theorem augmentation_linear_equivariance (e : G ≃* H) (n : ℕ)
    (z : augmentationLayer R G n) :
    truncationLinearEquiv (R := R) (G := G) e n
        (augmentationLinearKer R G n z) =
      augmentationLinearKer R H n
        (augmentationLayerEquiv (R := R) (G := G) e n z) := by
  simpa [truncationLinearEquiv, augmentationLayerEquiv]
    using augmentation_linear_naturality (R := R) (G := G)
      e.toMonoidHom n z

/-- The layer-to-truncation-kernel equivalence is equivariant for group isomorphisms. -/
theorem augmentation_truncation_equivariance (e : G ≃* H) (n : ℕ)
    (z : augmentationLayer R G n) :
    truncationKernelEquiv (R := R) (G := G) e n
        (augmentationLayerTruncation R G n z) =
      augmentationLayerTruncation R H n
        (augmentationLayerEquiv (R := R) (G := G) e n z) := by
  simpa [truncationKernelEquiv, augmentationLayerEquiv]
    using layer_truncation_naturality (R := R) (G := G)
      e.toMonoidHom n z

/-- Layer maps commute with reindexing along an equality of degrees. -/
theorem augmentation_layer (φ : G →* H) {m n : ℕ} (h : m = n)
    (x : augmentationLayer R G m) :
    augmentationLayerMap (R := R) (G := G) φ n (augmentationLayerReindex R G h x) =
      augmentationLayerReindex R H h
        (augmentationLayerMap (R := R) (G := G) φ m x) := by
  subst n
  rfl

/-- Linear-map form of layer-map compatibility with degree reindexing. -/
theorem augmentation_reindex_linear (φ : G →* H) {m n : ℕ} (h : m = n) :
    (augmentationLayerMap (R := R) (G := G) φ n).comp
        (augmentationLayerReindex R G h).toLinearMap =
      (augmentationLayerReindex R H h).toLinearMap.comp
        (augmentationLayerMap (R := R) (G := G) φ m) := by
  apply LinearMap.ext
  intro x
  exact augmentation_layer (R := R) (G := G) φ h x

/-- Isomorphism-induced layer equivalences commute with reindexing along an equality
of degrees. -/
theorem augmentation_equiv_reindex (e : G ≃* H) {m n : ℕ} (h : m = n)
    (x : augmentationLayer R G m) :
    augmentationLayerEquiv (R := R) (G := G) e n (augmentationLayerReindex R G h x) =
      augmentationLayerReindex R H h
        (augmentationLayerEquiv (R := R) (G := G) e m x) := by
  exact augmentation_layer (R := R) (G := G) e.toMonoidHom h x

/-- Inverse isomorphism-induced layer equivalences commute with degree reindexing. -/
theorem augmentation_symm_reindex (e : G ≃* H) {m n : ℕ} (h : m = n)
    (x : augmentationLayer R H m) :
    (augmentationLayerEquiv (R := R) (G := G) e n).symm
        (augmentationLayerReindex R H h x) =
      augmentationLayerReindex R G h
        ((augmentationLayerEquiv (R := R) (G := G) e m).symm x) := by
  simpa [layer_symm] using
    augmentation_equiv_reindex (R := R) (G := H) (H := G) e.symm h x

/-- Homomorphisms preserve the distinguished degree-zero unit class. -/
@[simp] theorem layer_one (φ : G →* H) :
    augmentationLayerMap (R := R) (G := G) φ 0 (augmentationLayerOne R G) =
      augmentationLayerOne R H := by
  change Submodule.Quotient.mk (augmentationPowerMap (R := R) (G := G) φ 0
    (⟨(1 : MonoidAlgebra R G), by simp [augmentationPowerSubmodule]⟩ :
      augmentationPowerSubmodule R G 0)) = _
  apply congrArg Submodule.Quotient.mk
  apply Subtype.ext
  simp [augmentation_coe]

/-- Isomorphism-induced layer equivalences preserve the degree-zero unit class. -/
@[simp] theorem augmentation_equiv_one (e : G ≃* H) :
    augmentationLayerEquiv (R := R) (G := G) e 0 (augmentationLayerOne R G) =
      augmentationLayerOne R H := by
  exact layer_one (R := R) (G := G) e.toMonoidHom

/-- The inverse of an isomorphism-induced layer equivalence preserves the degree-zero unit class. -/
@[simp] theorem layer_symm_one (e : G ≃* H) :
    (augmentationLayerEquiv (R := R) (G := G) e 0).symm (augmentationLayerOne R H) =
      augmentationLayerOne R G := by
  rw [layer_symm]
  exact augmentation_equiv_one (R := R) (G := H) e.symm

/-- Functoriality of the associated-graded multiplication: a group homomorphism preserves
products of augmentation-layer classes. -/
@[simp] theorem layer_mul (φ : G →* H) (m n : ℕ)
    (x : augmentationLayer R G m) (y : augmentationLayer R G n) :
    augmentationLayerMap (R := R) (G := G) φ (m + n)
        ((augmentationLayerMul R G m n x) y) =
      (augmentationLayerMul R H m n
        (augmentationLayerMap (R := R) (G := G) φ m x))
        (augmentationLayerMap (R := R) (G := G) φ n y) := by
  refine Quotient.inductionOn' x ?_
  intro a
  refine Quotient.inductionOn' y ?_
  intro b
  change augmentationLayerMap (R := R) (G := G) φ (m + n)
      ((augmentationLayerMul R G m n (Submodule.Quotient.mk a))
        (Submodule.Quotient.mk b)) = _
  rw [augmentation_mul_mk]
  rw [augmentation_mk]
  change _ = (augmentationLayerMul R H m n
      (augmentationLayerMap (R := R) (G := G) φ m (Submodule.Quotient.mk a)))
      (augmentationLayerMap (R := R) (G := G) φ n (Submodule.Quotient.mk b))
  rw [augmentation_mk, augmentation_mk]
  rw [augmentation_mul_mk]
  apply congrArg Submodule.Quotient.mk
  apply Subtype.ext
  simp [augmentation_coe, map_mul]

/-- Tensor product of the two augmentation-layer maps in degrees `m` and `n`.
This is a named wrapper around `TensorProduct.map` for the associated graded API. -/
noncomputable def augmentationTensor (φ : G →* H) (m n : ℕ) :
    TensorProduct R (augmentationLayer R G m) (augmentationLayer R G n) →ₗ[R]
      TensorProduct R (augmentationLayer R H m) (augmentationLayer R H n) :=
  TensorProduct.map
    (augmentationLayerMap (R := R) (G := G) φ m)
    (augmentationLayerMap (R := R) (G := G) φ n)

/-- The named tensor map agrees with `TensorProduct.map`. -/
@[simp] theorem layer_tensor_tmul (φ : G →* H) (m n : ℕ)
    (x : augmentationLayer R G m) (y : augmentationLayer R G n) :
    augmentationTensor (R := R) (G := G) φ m n (TensorProduct.tmul R x y) =
      TensorProduct.tmul R
        (augmentationLayerMap (R := R) (G := G) φ m x)
        (augmentationLayerMap (R := R) (G := G) φ n y) := rfl

/-- Tensor maps commute with simultaneous reindexing of the two degrees. -/
theorem augmentation_reindex (φ : G →* H) {m m' n n' : ℕ}
    (hm : m = m') (hn : n = n')
    (z : TensorProduct R (augmentationLayer R G m) (augmentationLayer R G n)) :
    augmentationTensor (R := R) (G := G) φ m' n'
        (augmentationTensorReindex R G hm hn z) =
      augmentationTensorReindex R H hm hn
        (augmentationTensor (R := R) (G := G) φ m n z) := by
  subst m'
  subst n'
  simp [augmentationTensorReindex]

/-- Linear-map form of tensor-map compatibility with degree reindexing. -/
theorem tensor_reindex_linear (φ : G →* H) {m m' n n' : ℕ}
    (hm : m = m') (hn : n = n') :
    (augmentationTensor (R := R) (G := G) φ m' n').comp
        (augmentationTensorReindex R G hm hn).toLinearMap =
      (augmentationTensorReindex R H hm hn).toLinearMap.comp
        (augmentationTensor (R := R) (G := G) φ m n) := by
  apply LinearMap.ext
  intro z
  exact augmentation_reindex (R := R) (G := G) φ hm hn z

/-- The identity homomorphism induces the identity tensor map on a pair of layers. -/
@[simp] theorem layer_tensor_id (m n : ℕ) :
    augmentationTensor (R := R) (G := G) (MonoidHom.id G) m n = LinearMap.id := by
  apply TensorProduct.ext'
  intro x y
  simp [augmentationTensor]

/-- Tensor maps for augmentation layers compose functorially. -/
@[simp] theorem layer_tensor_comp {L : Type*} [Group L]
    (φ : G →* H) (ψ : H →* L) (m n : ℕ) :
    augmentationTensor (R := R) (G := G) (ψ.comp φ) m n =
      (augmentationTensor (R := R) (G := H) ψ m n).comp
        (augmentationTensor (R := R) (G := G) φ m n) := by
  apply TensorProduct.ext'
  intro x y
  simp [augmentationTensor, augmentation_comp]

/-- Pointwise form of tensor-map composition. -/
@[simp] theorem augmentation_tensor_comp {L : Type*} [Group L]
    (φ : G →* H) (ψ : H →* L) (m n : ℕ)
    (z : TensorProduct R (augmentationLayer R G m) (augmentationLayer R G n)) :
    augmentationTensor (R := R) (G := G) (ψ.comp φ) m n z =
      augmentationTensor (R := R) (G := H) ψ m n
        (augmentationTensor (R := R) (G := G) φ m n z) := by
  have h := congrArg (fun f : TensorProduct R (augmentationLayer R G m)
        (augmentationLayer R G n) →ₗ[R]
        TensorProduct R (augmentationLayer R L m) (augmentationLayer R L n) => f z)
    (layer_tensor_comp (R := R) (G := G) φ ψ m n)
  exact h

/-- Pointwise identity form for tensor maps. -/
@[simp] theorem augmentation_tensor_id (m n : ℕ)
    (z : TensorProduct R (augmentationLayer R G m) (augmentationLayer R G n)) :
    augmentationTensor (R := R) (G := G) (MonoidHom.id G) m n z = z := by
  have h := congrArg (fun f : TensorProduct R (augmentationLayer R G m)
        (augmentationLayer R G n) →ₗ[R]
        TensorProduct R (augmentationLayer R G m) (augmentationLayer R G n) => f z)
    (layer_tensor_id (R := R) (G := G) m n)
  exact h

/-- Tensor maps induced by an isomorphism and its inverse cancel on the left. -/
@[simp] theorem tensor_symm (e : G ≃* H) (m n : ℕ)
    (z : TensorProduct R (augmentationLayer R G m) (augmentationLayer R G n)) :
    augmentationTensor (R := R) (G := H) e.symm.toMonoidHom m n
        (augmentationTensor (R := R) (G := G) e.toMonoidHom m n z) = z := by
  have hcomp : e.symm.toMonoidHom.comp e.toMonoidHom = MonoidHom.id G := by
    ext g; simp
  have h := augmentation_tensor_comp (R := R) (G := G)
    e.toMonoidHom e.symm.toMonoidHom m n z
  rw [← h, hcomp]
  exact augmentation_tensor_id (R := R) (G := G) m n z

/-- Tensor maps induced by an isomorphism and its inverse cancel on the right. -/
@[simp] theorem augmentation_layer_symm (e : G ≃* H) (m n : ℕ)
    (z : TensorProduct R (augmentationLayer R H m) (augmentationLayer R H n)) :
    augmentationTensor (R := R) (G := G) e.toMonoidHom m n
        (augmentationTensor (R := R) (G := H) e.symm.toMonoidHom m n z) = z := by
  have hcomp : e.toMonoidHom.comp e.symm.toMonoidHom = MonoidHom.id H := by
    ext h; simp
  have h := augmentation_tensor_comp (R := R) (G := H)
    e.symm.toMonoidHom e.toMonoidHom m n z
  rw [← h, hcomp]
  exact augmentation_tensor_id (R := R) (G := H) m n z

/-- A group isomorphism induces a linear equivalence on tensor products of two
augmentation layers. -/
noncomputable def augmentationLayerTensor (e : G ≃* H) (m n : ℕ) :
    TensorProduct R (augmentationLayer R G m) (augmentationLayer R G n) ≃ₗ[R]
      TensorProduct R (augmentationLayer R H m) (augmentationLayer R H n) :=
  TensorProduct.congr
    (augmentationLayerEquiv (R := R) (G := G) e m)
    (augmentationLayerEquiv (R := R) (G := G) e n)

/-- On pure tensors, the tensor equivalence is given by the two layer equivalences. -/
@[simp] theorem augmentation_layer_tmul (e : G ≃* H) (m n : ℕ)
    (x : augmentationLayer R G m) (y : augmentationLayer R G n) :
    augmentationLayerTensor (R := R) (G := G) e m n (TensorProduct.tmul R x y) =
      TensorProduct.tmul R
        (augmentationLayerEquiv (R := R) (G := G) e m x)
        (augmentationLayerEquiv (R := R) (G := G) e n y) := rfl

/-- On pure tensors, the inverse tensor equivalence applies the inverse layer equivalences. -/
@[simp] theorem tensor_symm_tmul (e : G ≃* H) (m n : ℕ)
    (x : augmentationLayer R H m) (y : augmentationLayer R H n) :
    (augmentationLayerTensor (R := R) (G := G) e m n).symm (TensorProduct.tmul R x y) =
      TensorProduct.tmul R
        ((augmentationLayerEquiv (R := R) (G := G) e m).symm x)
        ((augmentationLayerEquiv (R := R) (G := G) e n).symm y) := rfl

/-- The underlying linear map of the tensor equivalence is the named tensor map. -/
@[simp] theorem augmentation_tensor_linear (e : G ≃* H) (m n : ℕ) :
    (augmentationLayerTensor (R := R) (G := G) e m n).toLinearMap =
      augmentationTensor (R := R) (G := G) e.toMonoidHom m n := by
  rfl

/-- The inverse tensor equivalence cancels the tensor map induced by an isomorphism. -/
@[simp] theorem augmentation_tensor_symm (e : G ≃* H) (m n : ℕ)
    (z : TensorProduct R (augmentationLayer R G m) (augmentationLayer R G n)) :
    (augmentationLayerTensor (R := R) (G := G) e m n).symm
        (augmentationTensor (R := R) (G := G) e.toMonoidHom m n z) = z := by
  change (augmentationLayerTensor (R := R) (G := G) e m n).symm
      (augmentationLayerTensor (R := R) (G := G) e m n z) = z
  exact (augmentationLayerTensor (R := R) (G := G) e m n).left_inv z

/-- The tensor map induced by an isomorphism cancels the inverse tensor equivalence. -/
@[simp] theorem layer_tensor_symm (e : G ≃* H) (m n : ℕ)
    (z : TensorProduct R (augmentationLayer R H m) (augmentationLayer R H n)) :
    augmentationTensor (R := R) (G := G) e.toMonoidHom m n
        ((augmentationLayerTensor (R := R) (G := G) e m n).symm z) = z := by
  change augmentationLayerTensor (R := R) (G := G) e m n
      ((augmentationLayerTensor (R := R) (G := G) e m n).symm z) = z
  exact (augmentationLayerTensor (R := R) (G := G) e m n).right_inv z

/-- Tensor equivalences commute with simultaneous reindexing of the two degrees. -/
theorem layer_tensor_reindex (e : G ≃* H) {m m' n n' : ℕ}
    (hm : m = m') (hn : n = n')
    (z : TensorProduct R (augmentationLayer R G m) (augmentationLayer R G n)) :
    augmentationLayerTensor (R := R) (G := G) e m' n'
        (augmentationTensorReindex R G hm hn z) =
      augmentationTensorReindex R H hm hn
        (augmentationLayerTensor (R := R) (G := G) e m n z) := by
  simpa [augmentation_tensor_linear] using
    augmentation_reindex (R := R) (G := G) e.toMonoidHom hm hn z

/-- The underlying linear map of the inverse tensor equivalence is the
inverse-induced tensor map. -/
@[simp] theorem tensor_symm_linear (e : G ≃* H) (m n : ℕ) :
    ((augmentationLayerTensor (R := R) (G := G) e m n).symm).toLinearMap =
      augmentationTensor (R := R) (G := H) e.symm.toMonoidHom m n := by
  rfl

/-- Inverse tensor equivalences commute with simultaneous degree reindexing. -/
theorem tensor_symm_reindex (e : G ≃* H) {m m' n n' : ℕ}
    (hm : m = m') (hn : n = n')
    (z : TensorProduct R (augmentationLayer R H m) (augmentationLayer R H n)) :
    (augmentationLayerTensor (R := R) (G := G) e m' n').symm
        (augmentationTensorReindex R H hm hn z) =
      augmentationTensorReindex R G hm hn
        ((augmentationLayerTensor (R := R) (G := G) e m n).symm z) := by
  simpa [augmentationLayerTensor] using
    layer_tensor_reindex (R := R) (G := H) (H := G) e.symm hm hn z

/-- The inverse tensor equivalence is induced by the inverse group isomorphism. -/
@[simp] theorem tensor_equiv_symm (e : G ≃* H) (m n : ℕ) :
    (augmentationLayerTensor (R := R) (G := G) e m n).symm =
      augmentationLayerTensor (R := R) (G := H) e.symm m n := by
  rfl

/-- The tensor map induced by a group isomorphism is bijective. -/
theorem augmentation_tensor_bijective (e : G ≃* H) (m n : ℕ) :
    Function.Bijective (augmentationTensor (R := R) (G := G) e.toMonoidHom m n) := by
  simpa [augmentation_tensor_linear] using
    (augmentationLayerTensor (R := R) (G := G) e m n).bijective

/-- The tensor map induced by a group isomorphism is injective. -/
theorem augmentation_tensor_injective (e : G ≃* H) (m n : ℕ) :
    Function.Injective (augmentationTensor (R := R) (G := G) e.toMonoidHom m n) :=
  (augmentation_tensor_bijective (R := R) (G := G) e m n).1

/-- The tensor map induced by a group isomorphism is surjective. -/
theorem tensor_surjective_equiv (e : G ≃* H) (m n : ℕ) :
    Function.Surjective (augmentationTensor (R := R) (G := G) e.toMonoidHom m n) :=
  (augmentation_tensor_bijective (R := R) (G := G) e m n).2

/-- Range form for tensor maps induced by group isomorphisms. -/
theorem tensor_range_top (e : G ≃* H) (m n : ℕ) :
    LinearMap.range (augmentationTensor (R := R) (G := G) e.toMonoidHom m n) = ⊤ :=
  LinearMap.range_eq_top.mpr
    (tensor_surjective_equiv (R := R) (G := G) e m n)

/-- The tensor equivalence for the identity group isomorphism is the identity. -/
@[simp] theorem augmentation_tensor_refl (m n : ℕ) :
    augmentationLayerTensor (R := R) (G := G) (MulEquiv.refl G) m n =
      LinearEquiv.refl R (TensorProduct R (augmentationLayer R G m) (augmentationLayer R G n)) := by
  apply LinearEquiv.toLinearMap_injective
  simp [augmentationLayerTensor]

/-- Tensor equivalences compose functorially. -/
@[simp] theorem augmentation_tensor_trans {K : Type*} [Group K]
    (e : G ≃* H) (f : H ≃* K) (m n : ℕ) :
    (augmentationLayerTensor (R := R) (G := G) e m n).trans
        (augmentationLayerTensor (R := R) (G := H) f m n) =
      augmentationLayerTensor (R := R) (G := G) (e.trans f) m n := by
  apply LinearEquiv.toLinearMap_injective
  apply TensorProduct.ext'
  intro x y
  have hx : (augmentationLayerEquiv (R := R) (G := H) f m)
        ((augmentationLayerEquiv (R := R) (G := G) e m) x) =
      (augmentationLayerEquiv (R := R) (G := G) (e.trans f) m) x := by
    change ((augmentationLayerEquiv (R := R) (G := G) e m).trans
        (augmentationLayerEquiv (R := R) (G := H) f m)) x =
      (augmentationLayerEquiv (R := R) (G := G) (e.trans f) m) x
    exact congrArg (fun u : augmentationLayer R G m ≃ₗ[R] augmentationLayer R K m => u x)
      (augmentation_layer_trans (R := R) (G := G) e f m)
  have hy : (augmentationLayerEquiv (R := R) (G := H) f n)
        ((augmentationLayerEquiv (R := R) (G := G) e n) y) =
      (augmentationLayerEquiv (R := R) (G := G) (e.trans f) n) y := by
    change ((augmentationLayerEquiv (R := R) (G := G) e n).trans
        (augmentationLayerEquiv (R := R) (G := H) f n)) y =
      (augmentationLayerEquiv (R := R) (G := G) (e.trans f) n) y
    exact congrArg (fun u : augmentationLayer R G n ≃ₗ[R] augmentationLayer R K n => u y)
      (augmentation_layer_trans (R := R) (G := G) e f n)
  change TensorProduct.tmul R
        ((augmentationLayerEquiv (R := R) (G := H) f m)
          ((augmentationLayerEquiv (R := R) (G := G) e m) x))
        ((augmentationLayerEquiv (R := R) (G := H) f n)
          ((augmentationLayerEquiv (R := R) (G := G) e n) y)) =
      TensorProduct.tmul R
        ((augmentationLayerEquiv (R := R) (G := G) (e.trans f) m) x)
        ((augmentationLayerEquiv (R := R) (G := G) (e.trans f) n) y)
  rw [hx, hy]

/-- Tensor-product form of functoriality for associated-graded multiplication. -/
@[simp] theorem layer_tensor_mul (φ : G →* H) (m n : ℕ) :
    (augmentationLayerMap (R := R) (G := G) φ (m + n)).comp
        (augmentationTensorMul R G m n) =
      (augmentationTensorMul R H m n).comp
        (augmentationTensor (R := R) (G := G) φ m n) := by
  apply TensorProduct.ext'
  intro x y
  simp [LinearMap.comp_apply, augmentationTensor, layer_mul]

/-- If the two component layer maps are bijective, so is their tensor-product map. -/
theorem augmentation_bijective_maps (φ : G →* H)
    (m n : ℕ)
    (hm : Function.Bijective (augmentationLayerMap (R := R) (G := G) φ m))
    (hn : Function.Bijective (augmentationLayerMap (R := R) (G := G) φ n)) :
    Function.Bijective (augmentationTensor (R := R) (G := G) φ m n) :=
  TensorProduct.map_bijective hm hn

/-- Injectivity of a tensor map from bijectivity of the component layer maps. -/
theorem injective_bijective_maps (φ : G →* H)
    (m n : ℕ)
    (hm : Function.Bijective (augmentationLayerMap (R := R) (G := G) φ m))
    (hn : Function.Bijective (augmentationLayerMap (R := R) (G := G) φ n)) :
    Function.Injective (augmentationTensor (R := R) (G := G) φ m n) :=
  (augmentation_bijective_maps (R := R) (G := G) φ m n hm hn).1

/-- Surjectivity of a tensor map from bijectivity of the component layer maps. -/
theorem surjective_bijective_maps (φ : G →* H)
    (m n : ℕ)
    (hm : Function.Bijective (augmentationLayerMap (R := R) (G := G) φ m))
    (hn : Function.Bijective (augmentationLayerMap (R := R) (G := G) φ n)) :
    Function.Surjective (augmentationTensor (R := R) (G := G) φ m n) :=
  (augmentation_bijective_maps (R := R) (G := G) φ m n hm hn).2

/-- Range form for tensor maps whose component layer maps are bijective. -/
theorem tensor_bijective_maps (φ : G →* H)
    (m n : ℕ)
    (hm : Function.Bijective (augmentationLayerMap (R := R) (G := G) φ m))
    (hn : Function.Bijective (augmentationLayerMap (R := R) (G := G) φ n)) :
    LinearMap.range (augmentationTensor (R := R) (G := G) φ m n) = ⊤ :=
  LinearMap.range_eq_top.mpr
    (surjective_bijective_maps (R := R) (G := G) φ m n hm hn)

/-- If the two component layer maps are surjective, so is their tensor-product map. -/
theorem tensor_surjective_maps (φ : G →* H)
    (m n : ℕ)
    (hm : Function.Surjective (augmentationLayerMap (R := R) (G := G) φ m))
    (hn : Function.Surjective (augmentationLayerMap (R := R) (G := G) φ n)) :
    Function.Surjective (augmentationTensor (R := R) (G := G) φ m n) :=
  TensorProduct.map_surjective hm hn

/-- Range form of tensor-product surjectivity from surjective component layer maps. -/
theorem tensor_top_maps (φ : G →* H)
    (m n : ℕ)
    (hm : Function.Surjective (augmentationLayerMap (R := R) (G := G) φ m))
    (hn : Function.Surjective (augmentationLayerMap (R := R) (G := G) φ n)) :
    LinearMap.range (augmentationTensor (R := R) (G := G) φ m n) = ⊤ :=
  LinearMap.range_eq_top.mpr
    (tensor_surjective_maps (R := R) (G := G) φ m n hm hn)

/-- Pointwise form of tensor-product functoriality for associated-graded multiplication. -/
theorem augmentation_tensor_mul (φ : G →* H) (m n : ℕ)
    (z : TensorProduct R (augmentationLayer R G m) (augmentationLayer R G n)) :
    augmentationLayerMap (R := R) (G := G) φ (m + n)
        (augmentationTensorMul R G m n z) =
      augmentationTensorMul R H m n
        (augmentationTensor (R := R) (G := G) φ m n z) := by
  change ((augmentationLayerMap (R := R) (G := G) φ (m + n)).comp
        (augmentationTensorMul R G m n)) z =
      ((augmentationTensorMul R H m n).comp
        (augmentationTensor (R := R) (G := G) φ m n)) z
  exact congrArg (fun f : TensorProduct R (augmentationLayer R G m)
        (augmentationLayer R G n) →ₗ[R] augmentationLayer R H (m + n) => f z)
    (layer_tensor_mul (R := R) (G := G) φ m n)

/-- A surjective group homomorphism induces a surjective map on tensor products of
augmentation layers. -/
theorem augmentation_tensor_surjective (φ : G →* H)
    (hs : Function.Surjective φ) (m n : ℕ) :
    Function.Surjective (augmentationTensor (R := R) (G := G) φ m n) :=
  TensorProduct.map_surjective
    (augmentation_layer_surjective (R := R) (G := G) φ hs m)
    (augmentation_layer_surjective (R := R) (G := G) φ hs n)

/-- Range form of tensor-product surjectivity for augmentation layer maps. -/
theorem tensor_top_surjective (φ : G →* H)
    (hs : Function.Surjective φ) (m n : ℕ) :
    LinearMap.range (augmentationTensor (R := R) (G := G) φ m n) = ⊤ :=
  LinearMap.range_eq_top.mpr
    (augmentation_tensor_surjective (R := R) (G := G) φ hs m n)


/-- A group isomorphism preserves associated-graded multiplication. -/
@[simp] theorem augmentation_layer_mul (e : G ≃* H) (m n : ℕ)
    (x : augmentationLayer R G m) (y : augmentationLayer R G n) :
    augmentationLayerEquiv (R := R) (G := G) e (m + n)
        ((augmentationLayerMul R G m n x) y) =
      (augmentationLayerMul R H m n
        (augmentationLayerEquiv (R := R) (G := G) e m x))
        (augmentationLayerEquiv (R := R) (G := G) e n y) := by
  change augmentationLayerMap (R := R) (G := G) e.toMonoidHom (m + n)
      ((augmentationLayerMul R G m n x) y) = _
  change _ = (augmentationLayerMul R H m n
      (augmentationLayerMap (R := R) (G := G) e.toMonoidHom m x))
      (augmentationLayerMap (R := R) (G := G) e.toMonoidHom n y)
  exact layer_mul (R := R) (G := G) e.toMonoidHom m n x y

/-- Tensor-product form of multiplication compatibility for isomorphism-induced
augmentation layer equivalences. -/
@[simp] theorem layer_tensor_equiv (e : G ≃* H) (m n : ℕ) :
    (augmentationLayerEquiv (R := R) (G := G) e (m + n)).toLinearMap.comp
        (augmentationTensorMul R G m n) =
      (augmentationTensorMul R H m n).comp
        (TensorProduct.map
          (augmentationLayerEquiv (R := R) (G := G) e m).toLinearMap
          (augmentationLayerEquiv (R := R) (G := G) e n).toLinearMap) := by
  change (augmentationLayerMap (R := R) (G := G) e.toMonoidHom (m + n)).comp
        (augmentationTensorMul R G m n) = _
  change _ = (augmentationTensorMul R H m n).comp
        (TensorProduct.map
          (augmentationLayerMap (R := R) (G := G) e.toMonoidHom m)
          (augmentationLayerMap (R := R) (G := G) e.toMonoidHom n))
  exact layer_tensor_mul (R := R) (G := G) e.toMonoidHom m n



/-- Pointwise tensor-product multiplication compatibility for an isomorphism-induced
tensor equivalence. -/
theorem augmentation_layer_tensor (e : G ≃* H) (m n : ℕ)
    (z : TensorProduct R (augmentationLayer R G m) (augmentationLayer R G n)) :
    augmentationLayerEquiv (R := R) (G := G) e (m + n)
        (augmentationTensorMul R G m n z) =
      augmentationTensorMul R H m n
        (augmentationLayerTensor (R := R) (G := G) e m n z) := by
  change ((augmentationLayerMap (R := R) (G := G) e.toMonoidHom (m + n)).comp
        (augmentationTensorMul R G m n)) z =
      ((augmentationTensorMul R H m n).comp
        (augmentationTensor (R := R) (G := G) e.toMonoidHom m n)) z
  exact congrArg (fun f : TensorProduct R (augmentationLayer R G m)
        (augmentationLayer R G n) →ₗ[R] augmentationLayer R H (m + n) => f z)
    (layer_tensor_mul (R := R) (G := G) e.toMonoidHom m n)

/-- Linear-map form of tensor multiplication compatibility using the named tensor equivalence. -/
theorem augmentation_tensor_equiv (e : G ≃* H) (m n : ℕ) :
    (augmentationLayerEquiv (R := R) (G := G) e (m + n)).toLinearMap.comp
        (augmentationTensorMul R G m n) =
      (augmentationTensorMul R H m n).comp
        (augmentationLayerTensor (R := R) (G := G) e m n).toLinearMap := by
  apply LinearMap.ext
  intro z
  exact augmentation_layer_tensor (R := R) (G := G) e m n z

/-- The degree-zero layer equivalence is natural under arbitrary group homomorphisms. -/
@[simp] theorem layer_zero_equiv (φ : G →* H)
    (x : augmentationLayer R G 0) :
    augmentationZeroEquiv R H
        (augmentationLayerMap (R := R) (G := G) φ 0 x) =
      augmentationZeroEquiv R G x := by
  refine Quotient.inductionOn' x ?_
  intro a
  change augmentationZeroEquiv R H
      (augmentationLayerMap (R := R) (G := G) φ 0 (Submodule.Quotient.mk a)) =
    augmentationZeroEquiv R G (Submodule.Quotient.mk a)
  rw [augmentation_mk]
  change augmentation R H
      ((MonoidAlgebra.mapDomainAlgHom R R φ) (a : MonoidAlgebra R G)) =
    augmentation R G (a : MonoidAlgebra R G)
  exact augmentation_domain (R := R) (G := G) φ (a : MonoidAlgebra R G)

/-- Coordinate-free degree-zero square: the layer inclusion, packaged first-truncation
map, and the two scalar identifications commute. -/
@[simp] theorem layer_truncation_equiv (φ : G →* H)
    (z : augmentationLayer R G 0) :
    (augmentationLinearEquiv R H)
      (augmentationTruncationDomain (R := R) (G := G) φ
        (layerTruncation R G 0 z)) =
      augmentationZeroEquiv R G z := by
  rw [augmentation_truncation_equiv]
  rw [augmentation_truncation_zero]
  exact layer_zero_equiv (R := R) (G := G) φ z


/-- In degree zero, every group-domain map induces an injective map on augmentation
layers: both sides are canonically the coefficient ring. -/
theorem augmentation_zero_injective (φ : G →* H) :
    Function.Injective (augmentationLayerMap (R := R) (G := G) φ 0) := by
  intro x y hxy
  apply (augmentationZeroEquiv R G).injective
  have h := congrArg (fun z => augmentationZeroEquiv R H z) hxy
  simpa [layer_zero_equiv] using h

/-- In degree zero, every group-domain map is surjective on augmentation layers. -/
theorem augmentation_zero_surjective (φ : G →* H) :
    Function.Surjective (augmentationLayerMap (R := R) (G := G) φ 0) := by
  intro y
  refine ⟨(augmentationZeroEquiv R G).symm (augmentationZeroEquiv R H y), ?_⟩
  apply (augmentationZeroEquiv R H).injective
  rw [layer_zero_equiv]
  exact (augmentationZeroEquiv R G).apply_symm_apply (augmentationZeroEquiv R H y)

/-- Bijective form of the degree-zero layer map fact. -/
theorem augmentation_zero_bijective (φ : G →* H) :
    Function.Bijective (augmentationLayerMap (R := R) (G := G) φ 0) :=
  ⟨augmentation_zero_injective (R := R) (G := G) φ,
    augmentation_zero_surjective (R := R) (G := G) φ⟩

/-- Kernel form of degree-zero injectivity. -/
theorem augmentation_ker_bot (φ : G →* H) :
    LinearMap.ker (augmentationLayerMap (R := R) (G := G) φ 0) = ⊥ :=
  LinearMap.ker_eq_bot_of_injective
    (augmentation_zero_injective (R := R) (G := G) φ)

/-- Range form of degree-zero surjectivity. -/
theorem augmentation_range_top (φ : G →* H) :
    LinearMap.range (augmentationLayerMap (R := R) (G := G) φ 0) = ⊤ :=
  LinearMap.range_eq_top.mpr
    (augmentation_zero_surjective (R := R) (G := G) φ)

/-- Any two group-domain maps induce the same map on the degree-zero augmentation layer. -/
theorem augmentation_layer_ext (φ ψ : G →* H) :
    augmentationLayerMap (R := R) (G := G) φ 0 =
      augmentationLayerMap (R := R) (G := G) ψ 0 := by
  apply LinearMap.ext
  intro x
  apply (augmentationZeroEquiv R H).injective
  simp [layer_zero_equiv]

/-- The canonical linear equivalence underlying any degree-zero group-domain map.
It is written with a `φ` argument so it can be used as a drop-in equivalence for
`augmentationLayerMap φ 0`; propositionally it is independent of `φ`. -/
def augmentationLayerZero (_φ : G →* H) :
    augmentationLayer R G 0 ≃ₗ[R] augmentationLayer R H 0 :=
  (augmentationZeroEquiv R G).trans (augmentationZeroEquiv R H).symm

/-- The packaged degree-zero equivalence has the same pointwise action as the induced
augmentation-layer map. -/
@[simp] theorem augmentation_zero_equiv (φ : G →* H)
    (x : augmentationLayer R G 0) :
    augmentationLayerZero (R := R) (G := G) φ x =
      augmentationLayerMap (R := R) (G := G) φ 0 x := by
  apply (augmentationZeroEquiv R H).injective
  rw [layer_zero_equiv]
  change (augmentationZeroEquiv R H)
      ((augmentationZeroEquiv R H).symm ((augmentationZeroEquiv R G) x)) =
    augmentationZeroEquiv R G x
  exact (augmentationZeroEquiv R H).apply_symm_apply _

/-- Linear-map form of the packaged degree-zero equivalence. -/
@[simp] theorem augmentation_layer_linear (φ : G →* H) :
    (augmentationLayerZero (R := R) (G := G) φ).toLinearMap =
      augmentationLayerMap (R := R) (G := G) φ 0 := by
  apply LinearMap.ext
  intro x
  exact augmentation_zero_equiv (R := R) (G := G) φ x

/-- Coordinate formula for the packaged degree-zero equivalence. -/
theorem augmentation_layer_zero (φ : G →* H)
    (x : augmentationLayer R G 0) :
    augmentationLayerZero (R := R) (G := G) φ x =
      (augmentationZeroEquiv R H).symm (augmentationZeroEquiv R G x) := by
  rfl

/-- Coordinate formula for the inverse of the packaged degree-zero equivalence. -/
theorem augmentation_zero_symm (φ : G →* H)
    (y : augmentationLayer R H 0) :
    (augmentationLayerZero (R := R) (G := G) φ).symm y =
      (augmentationZeroEquiv R G).symm (augmentationZeroEquiv R H y) := by
  rfl

/-- The packaged equivalence for the identity homomorphism is the identity equivalence. -/
@[simp] theorem augmentation_layer_id :
    augmentationLayerZero (R := R) (G := G) (MonoidHom.id G) =
      LinearEquiv.refl R (augmentationLayer R G 0) := by
  ext x
  simp

/-- Packaged degree-zero equivalences compose functorially. -/
@[simp] theorem augmentation_zero_comp {L : Type*} [Group L]
    (φ : G →* H) (ψ : H →* L) :
    augmentationLayerZero (R := R) (G := G) (ψ.comp φ) =
      (augmentationLayerZero (R := R) (G := G) φ).trans
        (augmentationLayerZero (R := R) (G := H) ψ) := by
  ext x
  simp [LinearEquiv.trans_apply]

/-- Naturality square for the packaged degree-zero inclusion equivalence and the packaged
first-truncation/domain equivalence. -/
@[simp] theorem augmentation_truncation_naturality
    (φ : G →* H) :
    (augmentationTruncationLinear R G).trans
        (augmentationTruncationDomain (R := R) (G := G) φ) =
      (augmentationLayerZero (R := R) (G := G) φ).trans
        (augmentationTruncationLinear R H) := by
  ext z
  change augmentationTruncationDomain (R := R) (G := G) φ
      (augmentationTruncationLinear R G z) =
    augmentationTruncationLinear R H
      (augmentationLayerZero (R := R) (G := G) φ z)
  rw [augmentation_layer_truncation,
    augmentation_zero_equiv, augmentation_layer_truncation]
  exact augmentation_truncation_equiv (R := R) (G := G) φ z

/-- Inverse form of the packaged degree-zero inclusion naturality square. -/
@[simp] theorem truncation_naturality_symm
    (φ : G →* H) :
    (augmentationTruncationDomain (R := R) (G := G) φ).symm.trans
        (augmentationTruncationLinear R G).symm =
      (augmentationTruncationLinear R H).symm.trans
        (augmentationLayerZero (R := R) (G := G) φ).symm := by
  ext q
  simp only [LinearEquiv.trans_apply]
  rw [truncation_domain_symm,
    truncation_linear_symm,
    truncation_linear_symm,
    augmentation_zero_symm]
  simp [augmentationZeroLinear]

/-- For an isomorphism, the packaged degree-zero equivalence agrees with the existing
isomorphism-induced layer equivalence. -/
theorem augmentation_layer_equiv (e : G ≃* H) :
    augmentationLayerZero (R := R) (G := G) e.toMonoidHom =
      augmentationLayerEquiv (R := R) (G := G) e 0 := by
  ext x
  change augmentationLayerZero (R := R) (G := G) e.toMonoidHom x =
    augmentationLayerMap (R := R) (G := G) e.toMonoidHom 0 x
  exact augmentation_zero_equiv (R := R) (G := G) e.toMonoidHom x

/-- The inverse of the packaged degree-zero equivalence is the corresponding packaged
 equivalence for the opposite canonical zero-layer identification. -/
@[simp] theorem augmentation_symm_scalar (φ : G →* H) (r : R) :
    (augmentationLayerZero (R := R) (G := G) φ).symm
        ((augmentationZeroEquiv R H).symm r) =
      (augmentationZeroEquiv R G).symm r := by
  change (augmentationZeroEquiv R G).symm
      ((augmentationZeroEquiv R H) ((augmentationZeroEquiv R H).symm r)) =
    (augmentationZeroEquiv R G).symm r
  rw [(augmentationZeroEquiv R H).apply_symm_apply r]

/-- Scalar representatives in degree zero are preserved by every group-domain map. -/
@[simp] theorem layer_zero_scalar (φ : G →* H) (r : R) :
    augmentationLayerMap (R := R) (G := G) φ 0
        ((augmentationZeroEquiv R G).symm r) =
      (augmentationZeroEquiv R H).symm r := by
  apply (augmentationZeroEquiv R H).injective
  rw [layer_zero_equiv]
  rw [(augmentationZeroEquiv R H).apply_symm_apply r]
  exact (augmentationZeroEquiv R G).apply_symm_apply r

/-- Group isomorphism-induced layer equivalences preserve the canonical scalar class in
 degree zero.  This is the equivalence-specialized form of
 `layer_zero_scalar`, useful when rewriting through `LinearEquiv`s. -/
@[simp] theorem augmentation_zero_scalar (e : G ≃* H) (r : R) :
    augmentationLayerEquiv (R := R) (G := G) e 0
        ((augmentationZeroEquiv R G).symm r) =
      (augmentationZeroEquiv R H).symm r := by
  exact layer_zero_scalar (R := R) (G := G) e.toMonoidHom r

/-- The inverse of an isomorphism-induced degree-zero layer equivalence also preserves
 the canonical scalar class. -/
@[simp] theorem layer_symm_scalar (e : G ≃* H) (r : R) :
    (augmentationLayerEquiv (R := R) (G := G) e 0).symm
        ((augmentationZeroEquiv R H).symm r) =
      (augmentationZeroEquiv R G).symm r := by
  rw [layer_symm]
  exact augmentation_zero_scalar (R := R) (G := H) e.symm r

/-- The degree-zero layer equivalence is natural under group isomorphisms. -/
@[simp] theorem augmentation_zero_naturality (e : G ≃* H)
    (x : augmentationLayer R G 0) :
    augmentationZeroEquiv R H (augmentationLayerEquiv (R := R) (G := G) e 0 x) =
      augmentationZeroEquiv R G x := by
  refine Submodule.Quotient.induction_on (augmentationLayerDenom R G 0) x ?_
  intro y
  change augmentation R H
      ((MonoidAlgebra.mapDomainAlgHom R R e.toMonoidHom) (y : MonoidAlgebra R G)) =
    augmentation R G (y : MonoidAlgebra R G)
  exact augmentation_domain (R := R) (G := G) e.toMonoidHom (y : MonoidAlgebra R G)


/-- Inverse form of degree-zero naturality for isomorphism-induced layer equivalences. -/
@[simp] theorem augmentation_symm_naturality (e : G ≃* H)
    (y : augmentationLayer R H 0) :
    augmentationZeroEquiv R G
        ((augmentationLayerEquiv (R := R) (G := G) e 0).symm y) =
      augmentationZeroEquiv R H y := by
  rw [layer_symm]
  exact augmentation_zero_naturality (R := R) (G := H) e.symm y

/-- Linear-map form of degree-zero naturality. -/
theorem augmentation_layer_comp (e : G ≃* H) :
    (augmentationZeroEquiv R H).toLinearMap.comp
        (augmentationLayerEquiv (R := R) (G := G) e 0).toLinearMap =
      (augmentationZeroEquiv R G).toLinearMap := by
  apply LinearMap.ext
  intro x
  exact augmentation_zero_naturality (R := R) (G := G) e x

/-- Linear-map form of inverse degree-zero naturality. -/
theorem augmentation_comp_symm (e : G ≃* H) :
    (augmentationZeroEquiv R G).toLinearMap.comp
        (augmentationLayerEquiv (R := R) (G := G) e 0).symm.toLinearMap =
      (augmentationZeroEquiv R H).toLinearMap := by
  apply LinearMap.ext
  intro y
  exact augmentation_symm_naturality (R := R) (G := G) e y

end
end GroupAlgebra
end Submission

