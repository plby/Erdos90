namespace Submission
namespace Theorems

universe u v w x

/-- Every group element gives an augmentation-ideal element `g - 1`. -/
theorem gMinusLies (R : Type u) (G : Type v) [CommRing R] [Group G]
    (g : G) :
    (MonoidAlgebra.of R G g - 1 : MonoidAlgebra R G) ∈
      Submission.GroupAlgebra.augmentationIdeal R G
  := by
  exact Submission.GroupAlgebra.sub_augmentation_ideal R G g

