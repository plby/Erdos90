    M M.firstCoordinateAdditive F_U R hFU hR x y k

/--
Polynomial tuple for Cant--Eick's display `(*)` using only the lower-rank
`U(T)` multiplication data for the non-leading coordinates.
-/
def multiplicationDisplayProduct {n : ℕ}
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ) :
    Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ :=
  Fin.cases
    (MvPolynomial.X (MulVar.left 0) + MvPolynomial.X (MulVar.right 0))
    (fun k => multiplicationDisplayU F_U R k)

theorem eval_multiplication_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hMul : ∀ a b : M.G,
      M.coord a 0 = 0 → M.coord b 0 = 0 → M.coord (a * b) 0 = 0)
    (hInv : ∀ a : M.G, M.coord a 0 = 0 → M.coord a⁻¹ 0 = 0)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication
      (M.firstConsistentPresentation hMul hInv) F_U)
    (hR : RepresentsConjugation M R)
    (x y : Fin (n + 1) → ℤ) (k : Fin (n + 1)) :
    evalMulPolynomial T x y (multiplicationDisplayProduct F_U R k) =
      (M.coord (M.gen 0 ^ (x 0 + y 0) *
        (M.firstConjugatedProduct x (y 0) *
          M.normalWord (withoutFirstCoord y))) k : ℚ) := by
  let tailProduct :=
    M.firstConjugatedProduct x (y 0) * M.normalWord (withoutFirstCoord y)
  have htailZero : M.coord tailProduct 0 = 0 := by
    exact multiplication_tail_represents M hMul R hR x y
  cases k using Fin.cases with
  | zero =>
      change MvPolynomial.eval (evalMulVar T x y)
          (MvPolynomial.X (MulVar.left 0) + MvPolynomial.X (MulVar.right 0)) =
        (M.coord (M.gen 0 ^ (x 0 + y 0) * tailProduct) 0 : ℚ)
      rw [M.coord_gen_mul (x 0 + y 0) tailProduct htailZero]
      simp [evalMulVar, mulVarQ, Int.cast_add]
  | succ k =>
      change evalMulPolynomial T x y
          (multiplicationDisplayU F_U R k) =
        (M.coord (M.gen 0 ^ (x 0 + y 0) * tailProduct) (Fin.succ k) : ℚ)
      exact multiplication_u_represents
        M hMul hInv F_U R hFU hR x y k

theorem display_u_additive
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hAdd : CPres.CoordinateAdditive M 0)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication
      (M.firstConsistentAdditive hAdd) F_U)
    (hR : RepresentsConjugation M R)
    (x y : Fin (n + 1) → ℤ) (k : Fin (n + 1)) :
    evalMulPolynomial T x y (multiplicationDisplayProduct F_U R k) =
      (M.coord (M.gen 0 ^ (x 0 + y 0) *
        (M.firstConjugatedProduct x (y 0) *
          M.normalWord (withoutFirstCoord y))) k : ℚ) := by
  let hClosed := CPres.coordinate_closed_additive M 0 hAdd
  simpa [CPres.firstConsistentAdditive,
    hClosed] using
    eval_multiplication_represents
      M hClosed.1 hClosed.2 F_U R hFU hR x y k

theorem eval_display_u
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hR : RepresentsConjugation M R)
    (x y : Fin (n + 1) → ℤ) (k : Fin (n + 1)) :
    evalMulPolynomial T x y (multiplicationDisplayProduct F_U R k) =
      (M.coord (M.gen 0 ^ (x 0 + y 0) *
        (M.firstConjugatedProduct x (y 0) *
          M.normalWord (withoutFirstCoord y))) k : ℚ) :=
  display_u_additive
    M M.firstCoordinateAdditive F_U R hFU hR x y k

/--
Any represented ambient multiplication coordinate agrees on integer inputs
with the lower-rank `U(T)` displayed multiplication product.
-/
theorem multiplication_display_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hR : RepresentsConjugation M R)
    (x y : Fin (n + 1) → ℤ) (k : Fin (n + 1)) :
    evalMulPolynomial T x y (F k) =
      evalMulPolynomial T x y (multiplicationDisplayProduct F_U R k) := by
  rw [hF x y k, eval_display_u M F_U R hFU hR x y k]
  have hprod :
      M.gen 0 ^ (x 0 + y 0) *
          (M.firstConjugatedProduct x (y 0) *
            M.normalWord (withoutFirstCoord y)) =
        M.normalWord x * M.normalWord y := by
    rw [M.normal_conjugated_tail x y]
    group
  have hcoord :
      M.coord (M.normalWord x * M.normalWord y) k =
        M.coord
          (M.gen 0 ^ (x 0 + y 0) *
            (M.firstConjugatedProduct x (y 0) *
              M.normalWord (withoutFirstCoord y))) k := by
    exact (congrFun (congrArg M.coord hprod) k).symm
  exact_mod_cast hcoord

/--
Specialized polynomial identity form of the lower-rank `U(T)` multiplication
display against any represented ambient multiplication family.
-/
theorem specialize_multiplication_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hR : RepresentsConjugation M R) (k : Fin (n + 1)) :
    specializeMul T (F k) =
      specializeMul T (multiplicationDisplayProduct F_U R k) := by
  exact specialize_mul_eval (F k) (multiplicationDisplayProduct F_U R k)
    (fun x y =>
      multiplication_display_represents
        M F F_U R hF hFU hR x y k)

/--
Bundled Hall-polynomial wrapper for the specialized lower-rank `U(T)`
multiplication display identity.
-/
theorem specialize_display_polynomials
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (k : Fin (n + 1)) :
    specializeMul T (F k) =
      specializeMul T (multiplicationDisplayProduct F_U R k) :=
  specialize_multiplication_represents
    M F F_U R hHall.1 hHallU.1 hHall.2.2 k

/--
Section 3.3 as a construction: using multiplication in the concrete `U(T)`
presentation and ambient conjugation coordinates, the displayed polynomial
tuple represents ambient multiplication.
-/
theorem represents_display_u
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hR : RepresentsConjugation M R) :
    RepresentsMultiplication M (multiplicationDisplayProduct F_U R) := by
  intro x y k
  rw [eval_display_u M F_U R hFU hR x y k]
  have hprod :
      M.gen 0 ^ (x 0 + y 0) *
          (M.firstConjugatedProduct x (y 0) *
            M.normalWord (withoutFirstCoord y)) =
        M.normalWord x * M.normalWord y := by
    rw [M.normal_conjugated_tail x y]
    group
  exact_mod_cast congrFun (congrArg M.coord hprod) k

theorem polynomials_multiplication_u
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hK : RepresentsPowering M K)
    (hR : RepresentsConjugation M R) :
    RepresentsHallPolynomials M (multiplicationDisplayProduct F_U R) K R :=
  ⟨represents_display_u
      M F_U R hFU hR,
    hK, hR⟩

/--
Section 3.3 induction-step package for the multiplication component: a
represented Hall-polynomial family on the canonical `U(T)` presentation
supplies the lower-rank multiplication polynomials needed by the displayed
ambient multiplication construction.
-/
theorem multiplication_display_u
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hR : RepresentsConjugation M R) :
    ∃ F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ,
      RepresentsMultiplication M F :=
  ⟨multiplicationDisplayProduct F_U R,
    represents_display_u
      M F_U R hHallU.1 hR⟩

/--
Split Section 3.3 multiplication-component package: only multiplication in
the canonical `U(T)` presentation is needed for the displayed ambient
multiplication construction.
-/
theorem multiplication_display_delete
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hR : RepresentsConjugation M R) :
    ∃ F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ,
      RepresentsMultiplication M F :=
  ⟨multiplicationDisplayProduct F_U R,
    represents_display_u
      M F_U R hFU hR⟩

/--
Section 3.3 induction-step package for the multiplication component with the
lower-rank Hall family left existential, matching the shape of an induction
hypothesis.
-/
theorem represents_multiplication_first
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHallU :
      ∃ (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
        (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
        (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
          RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hR : RepresentsConjugation M R) :
    ∃ F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ,
      RepresentsMultiplication M F := by
  rcases hHallU with ⟨F_U, K_U, R_U, hHallU⟩
  exact multiplication_display_u
    M F_U K_U R_U R hHallU hR

/--
Section 3.3 multiplication-component package with the lower-rank multiplication
family left existential.
-/
theorem represents_multiplication_u
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU :
      ∃ F_U : Fin n → MvPolynomial (MulVar n) ℚ,
        RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hR : RepresentsConjugation M R) :
    ∃ F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ,
      RepresentsMultiplication M F := by
  rcases hFU with ⟨F_U, hFU⟩
  exact multiplication_display_delete
    M F_U R hFU hR

/--
Existential Section 3.3 induction-step package: if the canonical `U(T)`
presentation already has represented Hall polynomials, then any represented
ambient powering and conjugation families extend to a represented ambient Hall
bundle by the displayed multiplication construction.
-/
theorem polynomials_multiplication_display
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hK : RepresentsPowering M K)
    (hR : RepresentsConjugation M R) :
    ∃ F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ,
      RepresentsHallPolynomials M F K R :=
  ⟨multiplicationDisplayProduct F_U R,
    polynomials_multiplication_u
      M F_U K R hHallU.1 hK hR⟩

/--
Split Section 3.3 Hall-bundle package: lower-rank `U(T)` multiplication,
ambient powering, and ambient conjugation suffice for the displayed ambient
Hall bundle.
-/
theorem represents_multiplication_display
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hK : RepresentsPowering M K)
    (hR : RepresentsConjugation M R) :
    ∃ F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ,
      RepresentsHallPolynomials M F K R :=
  ⟨multiplicationDisplayProduct F_U R,
    polynomials_multiplication_u
      M F_U K R hFU hK hR⟩

/--
Existential Section 3.3 induction-step package with the lower-rank Hall family
left existential, matching the shape of an induction hypothesis.
-/
theorem polynomials_display_first
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHallU :
      ∃ (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
        (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
        (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
          RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hK : RepresentsPowering M K)
    (hR : RepresentsConjugation M R) :
    ∃ F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ,
      RepresentsHallPolynomials M F K R := by
  rcases hHallU with ⟨F_U, K_U, R_U, hHallU⟩
  exact
    polynomials_multiplication_display
      M F_U K_U R_U K R hHallU hK hR

/--
Existential Section 3.3 Hall-bundle package with only the lower-rank
multiplication family left existential.
-/
theorem represents_polynomials_display
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU :
      ∃ F_U : Fin n → MvPolynomial (MulVar n) ℚ,
        RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hK : RepresentsPowering M K)
    (hR : RepresentsConjugation M R) :
    ∃ F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ,
      RepresentsHallPolynomials M F K R := by
  rcases hFU with ⟨F_U, hFU⟩
  exact
    represents_multiplication_display
      M F_U K R hFU hK hR

/--
Existential lower-rank `U(T)` display replacement, retaining the specialized
polynomial identities back to the input ambient multiplication family.
-/
theorem multiplication_u_polynomials
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U) :
    ∃ F' : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ,
      RepresentsHallPolynomials M F' K R ∧
        ∀ k, specializeMul T (F k) = specializeMul T (F' k) := by
  refine ⟨multiplicationDisplayProduct F_U R, ?_, ?_⟩
  · exact polynomials_multiplication_u
      M F_U K R hHallU.1 hHall.2.1 hHall.2.2
  · intro k
    exact specialize_display_polynomials
      M F K R F_U K_U R_U hHall hHallU k

/--
Split lower-rank `U(T)` display replacement, retaining specialized identities
back to the input ambient multiplication family.
-/
theorem multiplication_product_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U) :
    ∃ F' : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ,
      RepresentsHallPolynomials M F' K R ∧
        ∀ k, specializeMul T (F k) = specializeMul T (F' k) := by
  refine ⟨multiplicationDisplayProduct F_U R, ?_, ?_⟩
  · exact polynomials_multiplication_u
      M F_U K R hFU hHall.2.1 hHall.2.2
  · intro k
    exact specialize_multiplication_represents
      M F F_U R hHall.1 hFU hHall.2.2 k

/--
Induction-hypothesis-shaped lower-rank `U(T)` display replacement, retaining
the specialized polynomial identities back to the input ambient multiplication
family.
-/
theorem multiplication_delete_first
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (hHallU :
      ∃ (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
        (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
        (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
          RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U) :
    ∃ F' : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ,
      RepresentsHallPolynomials M F' K R ∧
        ∀ k, specializeMul T (F k) = specializeMul T (F' k) := by
  rcases hHallU with ⟨F_U, K_U, R_U, hHallU⟩
  exact multiplication_u_polynomials
    M F K R F_U K_U R_U hHall hHallU

/--
Lower-rank `U(T)` display replacement with an existential lower-rank
multiplication family.
-/
theorem multiplication_display_first
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (hFU :
      ∃ F_U : Fin n → MvPolynomial (MulVar n) ℚ,
        RepresentsMultiplication M.deleteFirstConsistent F_U) :
    ∃ F' : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ,
      RepresentsHallPolynomials M F' K R ∧
        ∀ k, specializeMul T (F k) = specializeMul T (F' k) := by
  rcases hFU with ⟨F_U, hFU⟩
  exact multiplication_product_represents
    M F K R F_U hHall hFU

/-- Polynomial tuple for the tail part of the multiplication display after the leading factor. -/
def multiplicationDisplayPolynomial {n : ℕ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ) :
    Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ :=
  fun k =>
    mulComposePolynomial F mulParameterPolynomial
      (firstConjugatedTail F R)
      multiplicationDisplayRight k

theorem multiplication_display_polynomial
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (x y : Fin (n + 1) → ℤ) (k : Fin (n + 1))
    (hTail : ∀ i,
      evalMulPolynomial T x y (firstConjugatedTail F R i) =
        (M.coord (M.firstConjugatedProduct x (y 0)) i : ℚ))
    (hF :
      evalMulPolynomial T (M.coord (M.firstConjugatedProduct x (y 0)))
          (withoutFirstCoord y) (F k) =
        (M.multiplicationTuple
          (M.coord (M.firstConjugatedProduct x (y 0)))
          (withoutFirstCoord y) k : ℚ)) :
    evalMulPolynomial T x y (multiplicationDisplayPolynomial F R k) =
      (M.multiplicationTuple
        (M.coord (M.firstConjugatedProduct x (y 0)))
        (withoutFirstCoord y) k : ℚ) := by
  rw [multiplicationDisplayPolynomial]
  exact compose_multiplication_tuple
    M F mulParameterPolynomial (firstConjugatedTail F R)
    multiplicationDisplayRight (evalMulVar T x y)
    (by intro I; simp [mulParameterPolynomial, evalMulVar, mulVarQ])
    (M.coord (M.firstConjugatedProduct x (y 0))) (withoutFirstCoord y)
    hTail
    (by intro i
        exact multiplication_display_right T x y i)
    k hF

theorem multiplication_display_tail
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hR : RepresentsConjugation M R)
    (x y : Fin (n + 1) → ℤ) (k : Fin (n + 1)) :
    evalMulPolynomial T x y (multiplicationDisplayPolynomial F R k) =
      (M.multiplicationTuple
        (M.coord (M.firstConjugatedProduct x (y 0)))
        (withoutFirstCoord y) k : ℚ) := by
  exact multiplication_display_polynomial M F R x y k
    (fun i =>
      first_conjugated_represents M F R hF hR x y i)
    (hF (M.coord (M.firstConjugatedProduct x (y 0))) (withoutFirstCoord y) k)

/-- Polynomial tuple for the entire right-hand side of Cant--Eick's display `(*)`. -/
def multiplicationProductPolynomial {n : ℕ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ) :
    Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ :=
  fun k =>
    mulComposePolynomial F mulParameterPolynomial
      multiplicationDisplayFirst
      (multiplicationDisplayPolynomial F R) k

theorem eval_multiplication_polynomial
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (x y : Fin (n + 1) → ℤ) (k : Fin (n + 1))
    (hTail : ∀ i,
      evalMulPolynomial T x y (multiplicationDisplayPolynomial F R i) =
        (M.multiplicationTuple
          (M.coord (M.firstConjugatedProduct x (y 0)))
          (withoutFirstCoord y) i : ℚ))
    (hF :
      evalMulPolynomial T (singleCoord (0 : Fin (n + 1)) (x 0 + y 0))
          (M.multiplicationTuple
            (M.coord (M.firstConjugatedProduct x (y 0)))
            (withoutFirstCoord y)) (F k) =
        (M.multiplicationTuple
          (singleCoord (0 : Fin (n + 1)) (x 0 + y 0))
          (M.multiplicationTuple
            (M.coord (M.firstConjugatedProduct x (y 0)))
            (withoutFirstCoord y)) k : ℚ)) :
    evalMulPolynomial T x y (multiplicationProductPolynomial F R k) =
      (M.coord (M.gen 0 ^ (x 0 + y 0) *
        M.firstConjugatedProduct x (y 0) *
          M.normalWord (withoutFirstCoord y)) k : ℚ) := by
  let first := singleCoord (0 : Fin (n + 1)) (x 0 + y 0)
  let tail := M.coord (M.firstConjugatedProduct x (y 0))
  let right := withoutFirstCoord y
  let tailProduct := M.multiplicationTuple tail right
  rw [multiplicationProductPolynomial]
  change MvPolynomial.eval (evalMulVar T x y)
      (mulComposePolynomial F mulParameterPolynomial multiplicationDisplayFirst
        (multiplicationDisplayPolynomial F R) k) =
    (M.coord (M.gen 0 ^ (x 0 + y 0) *
      M.firstConjugatedProduct x (y 0) *
        M.normalWord (withoutFirstCoord y)) k : ℚ)
  rw [compose_multiplication_tuple
    M F mulParameterPolynomial multiplicationDisplayFirst
    (multiplicationDisplayPolynomial F R) (evalMulVar T x y)
    (by intro I; simp [mulParameterPolynomial, evalMulVar, mulVarQ])
    first tailProduct]
  · change (M.coord (M.normalWord first * M.normalWord tailProduct) k : ℚ) =
      (M.coord (M.gen 0 ^ (x 0 + y 0) *
        M.firstConjugatedProduct x (y 0) *
          M.normalWord (withoutFirstCoord y)) k : ℚ)
    have htailProduct :
        M.normalWord tailProduct =
          M.firstConjugatedProduct x (y 0) * M.normalWord right := by
      change M.normalWord (M.multiplicationTuple tail right) =
        M.firstConjugatedProduct x (y 0) * M.normalWord right
      rw [M.normal_multiplication_tuple, M.normalWord_coord]
    rw [htailProduct]
    simp [first, right, M.normal_single_coord]
    group
  · intro i
    exact multiplication_display_factor T x y i
  · intro i
    exact hTail i
  · exact hF

theorem eval_display_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hR : RepresentsConjugation M R)
    (x y : Fin (n + 1) → ℤ) (k : Fin (n + 1)) :
    evalMulPolynomial T x y (multiplicationProductPolynomial F R k) =
      (M.coord (M.gen 0 ^ (x 0 + y 0) *
        M.firstConjugatedProduct x (y 0) *
          M.normalWord (withoutFirstCoord y)) k : ℚ) := by
  exact eval_multiplication_polynomial M F R x y k
    (fun i => multiplication_display_tail
      M F R hF hR x y i)
    (hF (singleCoord (0 : Fin (n + 1)) (x 0 + y 0))
      (M.multiplicationTuple
        (M.coord (M.firstConjugatedProduct x (y 0)))
        (withoutFirstCoord y)) k)

theorem multiplication_display_product
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (x y : Fin (n + 1) → ℤ) (k : Fin (n + 1))
    (hF :
      evalMulPolynomial T x y (F k) =
        (M.coord (M.gen 0 ^ (x 0 + y 0) *
          M.firstConjugatedProduct x (y 0) *
            M.normalWord (withoutFirstCoord y)) k : ℚ))
    (hDisplay :
      evalMulPolynomial T x y (multiplicationProductPolynomial F R k) =
        (M.coord (M.gen 0 ^ (x 0 + y 0) *
          M.firstConjugatedProduct x (y 0) *
            M.normalWord (withoutFirstCoord y)) k : ℚ)) :
    evalMulPolynomial T x y (F k) =
      evalMulPolynomial T x y (multiplicationProductPolynomial F R k) := by
  rw [hF, hDisplay]

theorem eval_multiplication_display
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hR : RepresentsConjugation M R)
    (x y : Fin (n + 1) → ℤ) (k : Fin (n + 1)) :
    evalMulPolynomial T x y (F k) =
      evalMulPolynomial T x y (multiplicationProductPolynomial F R k) := by
  exact multiplication_display_product
    M F R x y k
    (coord_conjugated_represents M F hF x y k)
    (eval_display_represents M F R hF hR x y k)

/--
Replacing every represented ambient multiplication coordinate by the Section
3.3 displayed product preserves the multiplication representation predicate.
-/
theorem represents_display_polynomial
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hR : RepresentsConjugation M R) :
    RepresentsMultiplication M (multiplicationProductPolynomial F R) := by
  intro x y k
  rw [← eval_multiplication_display
    M F R hF hR x y k]
  exact hF x y k

/--
Replacing one represented ambient multiplication coordinate by the Section
3.3 displayed product preserves the multiplication representation predicate.
-/
theorem multiplication_update_display
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hR : RepresentsConjugation M R)
    (k : Fin (n + 1)) :
    RepresentsMultiplication M
      (Function.update F k (multiplicationProductPolynomial F R k)) := by
  intro x y i
  by_cases hik : i = k
  · subst i
    rw [Function.update_self]
    rw [← eval_multiplication_display
      M F R hF hR x y k]
    exact hF x y k
  · rw [Function.update_of_ne hik]
    exact hF x y i

theorem specialize_multiplication_eval
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (k : Fin (n + 1))
    (hEval : ∀ x y,
      evalMulPolynomial T x y (F k) =
        evalMulPolynomial T x y (multiplicationProductPolynomial F R k)) :
    specializeMul T (F k) =
      specializeMul T (multiplicationProductPolynomial F R k) := by
  apply MvPolynomial.funext_set
    (s := fun _ : MulInputVar (n + 1) => Set.range fun z : ℤ => (z : ℚ))
  · intro w
    exact Set.infinite_range_of_injective Int.cast_injective
  · intro q hq
    choose z hz using fun w => hq w (Set.mem_univ w)
    let x : Fin (n + 1) → ℤ := fun i => z (MulInputVar.left i)
    let y : Fin (n + 1) → ℤ := fun i => z (MulInputVar.right i)
    have hq_eq : q = mulInputVar x y := by
      funext w
      cases w <;> exact (hz _).symm
    rw [hq_eq, eval_specializeMul, eval_specializeMul]
    exact hEval x y

/--
Polynomial identity form of the Section 3.3 multiplication display after
specializing the parameters to a represented presentation.
-/
theorem specialize_display_product
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hR : RepresentsConjugation M R) (k : Fin (n + 1)) :
    specializeMul T (F k) =
      specializeMul T (multiplicationProductPolynomial F R k) := by
  exact specialize_multiplication_eval F R k
    (fun x y =>
      eval_multiplication_display
        M F R hF hR x y k)

/--
Product form of Section 3.2 Lemma `step2`: after increasing the conjugating
exponent, the new left-conjugation tuple is the coordinate tuple of the
ordered product of the individually conjugated tail factors.
-/
theorem tuple_v_conjugated
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (v : ℤ) :
    M.leftConjugationTuple 0 j 1 (v + 1) =
      M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1) := by
  let c := M.leftConjugationTuple 0 j 1 v
  have hc0 : c 0 = 0 := by
    simpa [c] using
      M.conjugation_tuple_coordinate j h0j 1 v
  exact M.conjugation_v_conjugated j v hc0

/--
Compatibility wrapper for the older represented-conjugation form of the
Section 3.2 product identity.
-/
theorem v_conjugated_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (_hR : RepresentsConjugation M R)
    (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (v : ℤ) :
    M.leftConjugationTuple 0 j 1 (v + 1) =
      M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1) :=
  tuple_v_conjugated M j h0j v

/--
The auxiliary first-generator conjugations used in the `step2` product all stay
inside the canonical delete-first subgroup; their first coordinate is zero
without any polynomial representation hypothesis.
-/
theorem conjugation_tuple_step
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T) :
    ∀ j v r,
      M.leftConjugationTuple 0 (Fin.succ r)
        (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ r)) 1 0 = 0 := by
  intro j v r
  exact M.conjugation_tuple_coordinate
    (Fin.succ r) (Fin.succ_pos r)
    (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ r)) 1

/--
Tail-coordinate form of Section 3.1 Lemma `step1`: for conjugation by the
first generator, the represented conjugation polynomial is the corresponding
left-conjugation coordinate.
-/
theorem conjugation_tail_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hR : RepresentsConjugation M R)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k) (u v : ℤ) :
    evalConjPolynomial T u v (R ⟨(0, j, k), h0j, hjk⟩) =
      (M.leftConjugationTuple 0 j u v k : ℚ) := by
  rw [tail_coordinate_represents M R hR 0 j k h0j hjk u v]
  have hleft := conjugation_tuple_without M R hR j h0j u v
  have hk0 : k ≠ (0 : Fin (n + 1)) := ne_of_gt (h0j.trans hjk)
  rw [hleft]
  simp [withoutFirstCoord, hk0]

/--
Evaluation form of the displayed Section 3.2 product: the next value
`R_{0,j,k}(T;1,v+1)` is the `k`th coordinate of the ordered product of
tail factors conjugated once by the first generator.
-/
theorem conjugated_tail_coordinate
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k) (v : ℤ)
    (hEval :
      evalConjPolynomial T 1 (v + 1) (R ⟨(0, j, k), h0j, hjk⟩) =
        (M.leftConjugationTuple 0 j 1 (v + 1) k : ℚ))
    (hProduct :
      M.leftConjugationTuple 0 j 1 (v + 1) =
        M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1)) :
    evalConjPolynomial T 1 (v + 1) (R ⟨(0, j, k), h0j, hjk⟩) =
      (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1) k :
        ℚ) := by
  rw [hEval, hProduct]

theorem conjugated_tail_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hR : RepresentsConjugation M R)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k) (v : ℤ) :
    evalConjPolynomial T 1 (v + 1) (R ⟨(0, j, k), h0j, hjk⟩) =
      (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1) k :
        ℚ) := by
  exact conjugated_tail_coordinate
    M R j k h0j hjk v
    (conjugation_tail_represents
      M R hR j k h0j hjk 1 (v + 1))
    (v_conjugated_represents
      M R hR j h0j v)

/--
Coordinate form of the Section 3.2 recursion: the forward difference at
`u = 1` is the `k`th coordinate gained when the previous conjugated tail
word is conjugated once more by the first generator.
-/
theorem forward_conjugated_delta
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k) (v : ℤ)
    (hSucc :
      evalConjPolynomial T 1 (v + 1) (R ⟨(0, j, k), h0j, hjk⟩) =
        (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1) k :
          ℚ))
    (hCurrent :
      evalConjPolynomial T 1 v (R ⟨(0, j, k), h0j, hjk⟩) =
        (M.leftConjugationTuple 0 j 1 v k : ℚ)) :
    conjOnePolynomial T v
        (forwardDifferenceV R ⟨(0, j, k), h0j, hjk⟩) =
      (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1) k :
          ℚ) -
        (M.leftConjugationTuple 0 j 1 v k : ℚ) := by
  rw [forward_difference_v]
  rw [hSucc, hCurrent]

theorem conjugated_delta_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hR : RepresentsConjugation M R)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k) (v : ℤ) :
    conjOnePolynomial T v
        (forwardDifferenceV R ⟨(0, j, k), h0j, hjk⟩) =
      (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1) k :
          ℚ) -
        (M.leftConjugationTuple 0 j 1 v k : ℚ) := by
  exact forward_conjugated_delta
    M R j k h0j hjk v
    (conjugated_tail_represents
      M R hR j k h0j hjk v)
    (conjugation_tail_represents
      M R hR j k h0j hjk 1 v)

/--
If the current first-generator conjugation coordinate is represented for every
integer exponent, then the exact `step2` forward-difference delta follows
without a separate hypothesis.
-/
theorem forward_conjugated_current
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j i : Fin n) (hji : j < i) (v : ℤ)
    (hCurrent : ∀ v : ℤ,
      evalConjPolynomial T 1 v
          (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
            Fin.succ_lt_succ_iff.mpr hji⟩) =
        (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ i) : ℚ)) :
    conjOnePolynomial T v
        (forwardDifferenceV R
          ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
            Fin.succ_lt_succ_iff.mpr hji⟩) =
      (M.coord (M.firstConjugatedProduct
          (M.leftConjugationTuple 0 (Fin.succ j) 1 v) 1) (Fin.succ i) : ℚ) -
        (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ i) : ℚ) := by
  have hProduct :=
    tuple_v_conjugated
      M (Fin.succ j) (Fin.succ_pos j) v
  have hSucc :
      evalConjPolynomial T 1 (v + 1)
          (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
            Fin.succ_lt_succ_iff.mpr hji⟩) =
        (M.coord (M.firstConjugatedProduct
            (M.leftConjugationTuple 0 (Fin.succ j) 1 v) 1) (Fin.succ i) : ℚ) := by
    rw [hCurrent (v + 1), hProduct]
  exact forward_conjugated_delta
    M R (Fin.succ j) (Fin.succ i) (Fin.succ_pos j)
    (Fin.succ_lt_succ_iff.mpr hji) v hSucc (hCurrent v)

/--
If the current first-generator tail coordinate is represented for every integer
exponent, then the exact `step2` forward-difference delta follows without a
separate hypothesis.  Unlike the successor-index helper above, this version
works for any positive tail index.
-/
theorem conjugated_delta_current
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k) (v : ℤ)
    (hCurrent : ∀ v : ℤ,
      evalConjPolynomial T 1 v (R ⟨(0, j, k), h0j, hjk⟩) =
        (M.leftConjugationTuple 0 j 1 v k : ℚ)) :
    conjOnePolynomial T v
        (forwardDifferenceV R ⟨(0, j, k), h0j, hjk⟩) =
      (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1) k :
          ℚ) -
        (M.leftConjugationTuple 0 j 1 v k : ℚ) := by
  have hProduct :=
    tuple_v_conjugated M j h0j v
  have hSucc :
      evalConjPolynomial T 1 (v + 1) (R ⟨(0, j, k), h0j, hjk⟩) =
        (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1) k :
          ℚ) := by
    rw [hCurrent (v + 1), hProduct]
  exact forward_conjugated_delta
    M R j k h0j hjk v hSucc (hCurrent v)

/--
Polynomial form of the constructive Section 3.2 recursion: the forward
difference `R_{0,j,k}(T;1,v+1)-R_{0,j,k}(T;1,v)` is represented by the
displayed product polynomial from the proof of Lemma `step2`, after
subtracting the previous value.
-/
theorem forward_difference_2
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k)
    (v : ℤ)
    (hDelta :
      conjOnePolynomial T v
          (forwardDifferenceV R ⟨(0, j, k), h0j, hjk⟩) =
        (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1) k :
            ℚ) -
          (M.leftConjugationTuple 0 j 1 v k : ℚ))
    (hProduct :
      conjOnePolynomial T v (conjStep2 F R j h0j k) =
        (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1) k :
          ℚ))
    (hCurrent :
      evalConjPolynomial T 1 v (R ⟨(0, j, k), h0j, hjk⟩) =
        (M.leftConjugationTuple 0 j 1 v k : ℚ)) :
    conjOnePolynomial T v
        (forwardDifferenceV R ⟨(0, j, k), h0j, hjk⟩) =
      conjOnePolynomial T v
        (conjForwardDifference F R j h0j k hjk) := by
  rw [conjForwardDifference]
  change
    conjOnePolynomial T v
        (forwardDifferenceV R ⟨(0, j, k), h0j, hjk⟩) =
      MvPolynomial.eval (conjOneVar T v)
        (conjStep2 F R j h0j k -
          conjUPolynomial (R ⟨(0, j, k), h0j, hjk⟩))
  rw [map_sub]
  change
    conjOnePolynomial T v
        (forwardDifferenceV R ⟨(0, j, k), h0j, hjk⟩) =
      conjOnePolynomial T v (conjStep2 F R j h0j k) -
        conjOnePolynomial T v
          (conjUPolynomial (R ⟨(0, j, k), h0j, hjk⟩))
  rw [hDelta, hProduct, conj_u_polynomial, hCurrent]

/--
Pointwise exact-premise forward-difference identity with the delta premise
derived from the current-coordinate identity.
-/
theorem conj_forward_delta
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k)
    (v : ℤ)
    (hCurrentAll : ∀ v : ℤ,
      evalConjPolynomial T 1 v (R ⟨(0, j, k), h0j, hjk⟩) =
        (M.leftConjugationTuple 0 j 1 v k : ℚ))
    (hProduct :
      conjOnePolynomial T v (conjStep2 F R j h0j k) =
        (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1) k :
          ℚ)) :
    conjOnePolynomial T v
        (forwardDifferenceV R ⟨(0, j, k), h0j, hjk⟩) =
      conjOnePolynomial T v
        (conjForwardDifference F R j h0j k hjk) :=
  forward_difference_2
    M F R j k h0j hjk v
    (conjugated_delta_current
      M R j k h0j hjk v hCurrentAll)
    hProduct (hCurrentAll v)

theorem conj_forward_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hR : RepresentsConjugation M R)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k)
    (v : ℤ) :
    conjOnePolynomial T v
        (forwardDifferenceV R ⟨(0, j, k), h0j, hjk⟩) =
      conjOnePolynomial T v
        (conjForwardDifference F R j h0j k hjk) := by
  exact forward_difference_2
    M F R j k h0j hjk v
    (conjugated_delta_represents
      M R hR j k h0j hjk v)
    (eval_conj_represents M F R hF hR j h0j v k)
    (conjugation_tail_represents
      M R hR j k h0j hjk 1 v)

/--
Lower-rank version of the constructive Section 3.2 recursion: the same
forward difference is represented using the product polynomial built from
`U(T)` multiplication data.
-/
theorem conj_forward_u
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k)
    (v : ℤ)
    (hDelta :
      conjOnePolynomial T v
          (forwardDifferenceV R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
        (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1)
            (Fin.succ k) : ℚ) -
          (M.leftConjugationTuple 0 j 1 v (Fin.succ k) : ℚ))
    (hProduct :
      conjOnePolynomial T v (conj2U F_U R j h0j k) =
        (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1)
          (Fin.succ k) : ℚ))
    (hCurrent :
      evalConjPolynomial T 1 v (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
        (M.leftConjugationTuple 0 j 1 v (Fin.succ k) : ℚ)) :
    conjOnePolynomial T v
        (forwardDifferenceV R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
      conjOnePolynomial T v
        (forwardDifferenceU F_U R j h0j k hjk) := by
  rw [forwardDifferenceU]
  change
    conjOnePolynomial T v
        (forwardDifferenceV R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
      MvPolynomial.eval (conjOneVar T v)
        (conj2U F_U R j h0j k -
          conjUPolynomial (R ⟨(0, j, Fin.succ k), h0j, hjk⟩))
  rw [map_sub]
  change
    conjOnePolynomial T v
        (forwardDifferenceV R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
      conjOnePolynomial T v (conj2U F_U R j h0j k) -
        conjOnePolynomial T v
          (conjUPolynomial (R ⟨(0, j, Fin.succ k), h0j, hjk⟩))
  rw [hDelta, hProduct, conj_u_polynomial, hCurrent]

/--
Exact-premise lower-rank step-2 forward-difference identity, with the
displayed product supplied by the exact `U(T)` product hook instead of by a
represented ambient conjugation family.
-/
theorem forward_difference_product
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hMul : ∀ a b : M.G,
      M.coord a 0 = 0 → M.coord b 0 = 0 → M.coord (a * b) 0 = 0)
    (hInv : ∀ a : M.G, M.coord a 0 = 0 → M.coord a⁻¹ 0 = 0)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication
      (M.firstConsistentPresentation hMul hInv) F_U)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k)
    (v : ℤ)
    (hDelta :
      conjOnePolynomial T v
          (forwardDifferenceV R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
        (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1)
            (Fin.succ k) : ℚ) -
          (M.leftConjugationTuple 0 j 1 v (Fin.succ k) : ℚ))
    (hCurrent :
      evalConjPolynomial T 1 v (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
        (M.leftConjugationTuple 0 j 1 v (Fin.succ k) : ℚ))
    (hSubst : ∀ w,
      MvPolynomial.eval (conjOneVar T v) (conjStepSubst R j h0j w) =
        evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1) w)
    (hFactor : ∀ i k,
      MvPolynomial.eval
          (evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1))
          (firstConjugatedPolynomial R i k) =
        (M.leftConjugationTuple 0 (Fin.succ i)
          (M.leftConjugationTuple 0 j 1 v (Fin.succ i)) 1 (Fin.succ k) : ℚ))
    (hZero : ∀ i,
      M.leftConjugationTuple 0 (Fin.succ i)
        (M.leftConjugationTuple 0 j 1 v (Fin.succ i)) 1 0 = 0) :
    conjOnePolynomial T v
        (forwardDifferenceV R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
      conjOnePolynomial T v
        (forwardDifferenceU F_U R j h0j k hjk) := by
  exact conj_forward_u
    M F_U R j k h0j hjk v hDelta
    (eval_conj_u
      M hMul hInv F_U R hFU j h0j v k hSubst hFactor hZero)
    hCurrent

/--
Lower-rank product-evaluation forward-difference identity with the delta and
tail-zero premises discharged semantically.
-/
theorem forward_difference_delta
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hMul : ∀ a b : M.G,
      M.coord a 0 = 0 → M.coord b 0 = 0 → M.coord (a * b) 0 = 0)
    (hInv : ∀ a : M.G, M.coord a 0 = 0 → M.coord a⁻¹ 0 = 0)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication
      (M.firstConsistentPresentation hMul hInv) F_U)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k) (v : ℤ)
    (hCurrent : ∀ v : ℤ,
      evalConjPolynomial T 1 v
          (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
        (M.leftConjugationTuple 0 j 1 v (Fin.succ k) : ℚ))
    (hSubst : ∀ w,
      MvPolynomial.eval (conjOneVar T v) (conjStepSubst R j h0j w) =
        evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1) w)
    (hFactor : ∀ r s,
      MvPolynomial.eval
          (evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1))
          (firstConjugatedPolynomial R r s) =
        (M.leftConjugationTuple 0 (Fin.succ r)
          (M.leftConjugationTuple 0 j 1 v (Fin.succ r)) 1 (Fin.succ s) : ℚ)) :
    conjOnePolynomial T v
        (forwardDifferenceV R
          ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
      conjOnePolynomial T v
        (forwardDifferenceU F_U R j h0j k hjk) :=
  forward_difference_product
    M hMul hInv F_U R hFU j k h0j hjk v
    (conjugated_delta_current
      M R j (Fin.succ k) h0j hjk v hCurrent)
    (hCurrent v) hSubst hFactor
    (fun r =>
      M.conjugation_tuple_coordinate (Fin.succ r)
        (Fin.succ_pos r) (M.leftConjugationTuple 0 j 1 v (Fin.succ r)) 1)

/--
Canonical delete-first form of the exact product-evaluation lower-rank
forward-difference identity.
-/
theorem forward_no_delta
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k) (v : ℤ)
    (hCurrent : ∀ v : ℤ,
      evalConjPolynomial T 1 v
          (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
        (M.leftConjugationTuple 0 j 1 v (Fin.succ k) : ℚ))
    (hSubst : ∀ w,
      MvPolynomial.eval (conjOneVar T v) (conjStepSubst R j h0j w) =
        evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1) w)
    (hFactor : ∀ r s,
      MvPolynomial.eval
          (evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1))
          (firstConjugatedPolynomial R r s) =
        (M.leftConjugationTuple 0 (Fin.succ r)
          (M.leftConjugationTuple 0 j 1 v (Fin.succ r)) 1 (Fin.succ s) : ℚ)) :
    conjOnePolynomial T v
        (forwardDifferenceV R
          ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
      conjOnePolynomial T v
