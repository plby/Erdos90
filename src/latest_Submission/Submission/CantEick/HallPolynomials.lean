        (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
          Fin.succ_lt_succ_iff.mpr hji⟩) = 0)
    (hDelta : ∀ (j i : Fin n) (hji : j < i) (v : ℤ),
      conjOnePolynomial T v
          (forwardDifferenceV R
            ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
              Fin.succ_lt_succ_iff.mpr hji⟩) =
        (M.coord (M.firstConjugatedProduct
            (M.leftConjugationTuple 0 (Fin.succ j) 1 v) 1) (Fin.succ i) : ℚ) -
          (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ i) : ℚ))
    (hCurrent : ∀ (j i : Fin n) (hji : j < i) (v : ℤ),
      evalConjPolynomial T 1 v
          (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
            Fin.succ_lt_succ_iff.mpr hji⟩) =
        (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ i) : ℚ))
    (hSubst : ∀ j v w,
      MvPolynomial.eval (conjOneVar T v)
          (conjStepSubst R (Fin.succ j) (Fin.succ_pos j) w) =
        evalMulVar T (M.leftConjugationTuple 0 (Fin.succ j) 1 v) (singleCoord 0 1) w)
    (hFactor : ∀ j v r s,
      MvPolynomial.eval
          (evalMulVar T (M.leftConjugationTuple 0 (Fin.succ j) 1 v) (singleCoord 0 1))
          (firstConjugatedPolynomial R r s) =
        (M.leftConjugationTuple 0 (Fin.succ r)
          (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ r)) 1 (Fin.succ s) : ℚ))
    (hTailZero : ∀ j v r,
      M.leftConjugationTuple 0 (Fin.succ r)
        (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ r)) 1 0 = 0) :
    RepresentsHallPolynomials M
      (displayMultiplicationFamily F_U K_U R)
      (uwPoweringFamily F_U K_U R K_W K_seed)
      (conj1U F_U K_U R_U R) := by
  let R' := conjFamilyU F_U K_U R
  let F' := displayMultiplicationFamily F_U K_U R
  let hClosed :=
    CPres.coordinate_closed_additive M 0 M.firstCoordinateAdditive
  have hFU0 :
      RepresentsMultiplication (M.firstConsistentPresentation hClosed.1 hClosed.2)
        F_U := by
    simpa [CPres.deleteFirstConsistent,
      CPres.firstConsistentAdditive,
      hClosed] using hFU
  have hR' : RepresentsConjugation M R' :=
    represents_conjugation_family
      M hClosed.1 hClosed.2 F_U K_U R hFU0 hKU hR
      hZeroInit hDelta hCurrent hSubst hFactor hTailZero
  have hRfull :
      RepresentsConjugation M
        (conj1U F_U K_U R_U R) :=
    represents_conjugation_delete
      M hClosed.1 hClosed.2 F_U K_U R_U R hFU0 hKU hR_U hR
      hZeroInit hDelta hCurrent hSubst hFactor hTailZero
  have hF' : RepresentsMultiplication M F' := by
    simpa [F', R', displayMultiplicationFamily] using
      represents_display_u
        M F_U R' hFU hR'
  have hK' :
      RepresentsPowering M
        (uwPoweringFamily F_U K_U R K_W K_seed) := by
    simpa [uwPoweringFamily, F'] using
      powering_delete_solution
        M F' F_W K_W R_W K_seed hF' hHallW hLast
  exact ⟨hF', hK', hRfull⟩

