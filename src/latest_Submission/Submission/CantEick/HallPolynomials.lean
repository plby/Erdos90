/--
Projection from an existential Hall-polynomial bundle to the multiplication
component.
-/
theorem multiplication_hall_polynomials
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (hHall :
      ∃ (F : Fin n → MvPolynomial (MulVar n) ℚ)
        (K : Fin n → MvPolynomial (PowerVar n) ℚ)
        (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
          RepresentsHallPolynomials M F K R) :
    ∃ F : Fin n → MvPolynomial (MulVar n) ℚ,
      RepresentsMultiplication M F := by
  rcases hHall with ⟨F, K, R, hHall⟩
  exact ⟨F, hHall.1⟩

/--
Projection from an existential Hall-polynomial bundle to the powering
component.
-/
