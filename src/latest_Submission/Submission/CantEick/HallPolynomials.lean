import Submission.CantEick.Consistency
import Submission.CantEick.Operations
import Submission.CantEick.Recursions

/-!
# Hall polynomial specifications

This file records the semantic specifications for the multiplication,
powering, and conjugation polynomials in Cant--Eick Section 3.  It also proves
the basic powering recursion used in Section 3.4: once multiplication and
powering polynomials represent the group operations, powering at `z+1` is
obtained by multiplying the coordinate tuple for the `z`th power by the
original element.
-/

namespace Submission
namespace CantEick

noncomputable section

variable {n : ℕ}

/--
Substitute generic parameter and coordinate polynomials into a multiplication
polynomial.  This is the reusable form of "use the multiplication polynomials
to evaluate a product" from Cant--Eick Section 3.
-/
def mulComposeSubst {σ : Type*}
    (τ : ParameterIndex n → MvPolynomial σ ℚ)
    (x y : Fin n → MvPolynomial σ ℚ) :
    MulVar n → MvPolynomial σ ℚ
  | MulVar.param I => τ I
  | MulVar.left i => x i
  | MulVar.right i => y i

/-- The `i`th coordinate polynomial obtained by multiplying two polynomial tuples. -/
def mulComposePolynomial {σ : Type*}
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (τ : ParameterIndex n → MvPolynomial σ ℚ)
    (x y : Fin n → MvPolynomial σ ℚ) (i : Fin n) :
    MvPolynomial σ ℚ :=
  MvPolynomial.eval₂Hom MvPolynomial.C (mulComposeSubst τ x y) (F i)

lemma mul_compose_polynomial {σ : Type*}
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (τ : ParameterIndex n → MvPolynomial σ ℚ)
    (x y : Fin n → MvPolynomial σ ℚ) (e : σ → ℚ) (i : Fin n) :
    MvPolynomial.eval e (mulComposePolynomial F τ x y i) =
      evalMulQ (fun I => MvPolynomial.eval e (τ I))
        (fun j => MvPolynomial.eval e (x j))
        (fun j => MvPolynomial.eval e (y j)) (F i) := by
  change
    MvPolynomial.eval e
        (MvPolynomial.eval₂ MvPolynomial.C (mulComposeSubst τ x y) (F i)) =
      MvPolynomial.eval
        (mulVarQ (fun I => MvPolynomial.eval e (τ I))
          (fun j => MvPolynomial.eval e (x j))
          (fun j => MvPolynomial.eval e (y j))) (F i)
  rw [← MvPolynomial.eval_assoc]
  apply congrArg (fun f : MulVar n → ℚ => MvPolynomial.eval f (F i))
  funext v
  cases v <;> simp [mulComposeSubst, mulVarQ]

theorem compose_multiplication_tuple
    {T : ParameterIndex n → ℤ} {σ : Type*}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (τ : ParameterIndex n → MvPolynomial σ ℚ)
    (X Y : Fin n → MvPolynomial σ ℚ) (e : σ → ℚ)
    (hτ : ∀ I, MvPolynomial.eval e (τ I) = (T I : ℚ))
    (x y : Fin n → ℤ)
    (hX : ∀ i, MvPolynomial.eval e (X i) = (x i : ℚ))
    (hY : ∀ i, MvPolynomial.eval e (Y i) = (y i : ℚ))
    (i : Fin n)
    (hF :
      evalMulPolynomial T x y (F i) = (M.multiplicationTuple x y i : ℚ)) :
    MvPolynomial.eval e (mulComposePolynomial F τ X Y i) =
      (M.multiplicationTuple x y i : ℚ) := by
  rw [mul_compose_polynomial]
  have hassign :
      mulVarQ (fun I => MvPolynomial.eval e (τ I))
          (fun j => MvPolynomial.eval e (X j))
          (fun j => MvPolynomial.eval e (Y j)) =
        evalMulVar T x y := by
    funext v
    cases v <;> simp [evalMulVar, mulVarQ, hτ, hX, hY]
  rw [show
    evalMulQ (fun I => MvPolynomial.eval e (τ I))
        (fun j => MvPolynomial.eval e (X j))
        (fun j => MvPolynomial.eval e (Y j)) (F i) =
      evalMulPolynomial T x y (F i) by
        change MvPolynomial.eval
            (mulVarQ (fun I => MvPolynomial.eval e (τ I))
              (fun j => MvPolynomial.eval e (X j))
              (fun j => MvPolynomial.eval e (Y j))) (F i) =
          MvPolynomial.eval (evalMulVar T x y) (F i)
        rw [hassign]]
  rw [hF]

theorem compose_multiplication_represents
    {T : ParameterIndex n → ℤ} {σ : Type*}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (τ : ParameterIndex n → MvPolynomial σ ℚ)
    (X Y : Fin n → MvPolynomial σ ℚ) (e : σ → ℚ)
    (hτ : ∀ I, MvPolynomial.eval e (τ I) = (T I : ℚ))
    (x y : Fin n → ℤ)
    (hX : ∀ i, MvPolynomial.eval e (X i) = (x i : ℚ))
    (hY : ∀ i, MvPolynomial.eval e (Y i) = (y i : ℚ))
    (i : Fin n) :
    MvPolynomial.eval e (mulComposePolynomial F τ X Y i) =
      (M.multiplicationTuple x y i : ℚ) := by
  exact compose_multiplication_tuple
    M F τ X Y e hτ x y hX hY i (hF x y i)

/--
Fold multiplication polynomials over a list of coordinate-polynomial tuples.
The empty product is the zero coordinate tuple, i.e. the identity normal word.
-/
def normalProductPolynomial {σ : Type*}
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (τ : ParameterIndex n → MvPolynomial σ ℚ) :
    List (Fin n → MvPolynomial σ ℚ) → Fin n → MvPolynomial σ ℚ
  | [] => fun _ => 0
  | P :: Ps => fun i =>
      mulComposePolynomial F τ P (normalProductPolynomial F τ Ps) i

/--
Evaluation theorem for `normalProductPolynomial`: when each factor tuple
evaluates to an integer coordinate tuple, the folded polynomial tuple
evaluates to the coordinates of the corresponding ordered product.
-/
theorem coord_prod_represents
    {T : ParameterIndex n → ℤ} {σ : Type*}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (τ : ParameterIndex n → MvPolynomial σ ℚ) (e : σ → ℚ)
    (hτ : ∀ I, MvPolynomial.eval e (τ I) = (T I : ℚ))
    (items : List ((Fin n → MvPolynomial σ ℚ) × (Fin n → ℤ)))
    (hitems : ∀ item ∈ items, ∀ i, MvPolynomial.eval e (item.1 i) = (item.2 i : ℚ))
    (i : Fin n) :
    MvPolynomial.eval e (normalProductPolynomial F τ (items.map Prod.fst) i) =
      (M.coord ((items.map fun item => M.normalWord item.2).prod) i : ℚ) := by
  revert hitems i
  induction items with
  | nil =>
      intro hitems i
      simp only [List.map_nil, List.prod_nil, normalProductPolynomial]
      have hcoord : M.coord 1 i = 0 := by
        have htuple := M.coord_normalWord (fun _ : Fin n => 0)
        exact congrFun (by simpa [M.normalWord_zero] using htuple) i
      rw [hcoord]
      norm_num
  | cons item items ih =>
      intro hitems i
      rcases item with ⟨P, x⟩
      simp only [List.map_cons, List.prod_cons, normalProductPolynomial]
      let tail : M.G := (items.map fun item => M.normalWord item.2).prod
      rw [compose_multiplication_represents
        M F hF τ P (normalProductPolynomial F τ (items.map Prod.fst)) e
        hτ x (M.coord tail)]
      · change
          (M.coord (M.normalWord x * M.normalWord (M.coord tail)) i : ℚ) =
            (M.coord (M.normalWord x * tail) i : ℚ)
        rw [M.normalWord_coord]
      · intro j
        exact hitems (P, x) (by simp) j
      · intro j
        exact ih (fun item hitem => hitems item (by simp [hitem])) j

/-- Variables for a powering polynomial `K_i(T; x, z)`. -/
inductive PowerVar (n : ℕ) where
  | param : ParameterIndex n → PowerVar n
  | coord : Fin n → PowerVar n
  | exponent : PowerVar n
deriving DecidableEq

/-- The non-parameter variables in a powering polynomial. -/
inductive PowerInputVar (n : ℕ) where
  | coord : Fin n → PowerInputVar n
  | exponent : PowerInputVar n
deriving DecidableEq

/-- Variables for a conjugation polynomial `R_{i,j,k}(T; u, v)`. -/
inductive ConjVar (n : ℕ) where
  | param : ParameterIndex n → ConjVar n
  | u : ConjVar n
  | v : ConjVar n
deriving DecidableEq

/-- The non-parameter variables in a conjugation polynomial. -/
inductive ConjInputVar (n : ℕ) where
  | u : ConjInputVar n
  | v : ConjInputVar n
deriving DecidableEq

/-- Rational evaluation assignment for powering variables. -/
def evalVarQ (T : ParameterIndex n → ℚ) (x : Fin n → ℚ) (z : ℚ) :
    PowerVar n → ℚ
  | PowerVar.param I => T I
  | PowerVar.coord i => x i
  | PowerVar.exponent => z

/-- Integer-specialized evaluation assignment for powering variables. -/
def evalPowerVar (T : ParameterIndex n → ℤ) (x : Fin n → ℤ) (z : ℤ) :
    PowerVar n → ℚ :=
  evalVarQ (fun I => (T I : ℚ)) (fun i => (x i : ℚ)) (z : ℚ)

/-- Evaluation assignment for the pure powering variables `x,z`. -/
def evalInputVar (x : Fin n → ℤ) (z : ℤ) : PowerInputVar n → ℚ
  | PowerInputVar.coord i => x i
  | PowerInputVar.exponent => z

/-- Evaluate a powering polynomial at rational data. -/
def evalPowerQ (T : ParameterIndex n → ℚ) (x : Fin n → ℚ) (z : ℚ)
    (p : MvPolynomial (PowerVar n) ℚ) : ℚ :=
  MvPolynomial.eval (evalVarQ T x z) p

/-- Evaluate a powering polynomial at integer data. -/
def evalPowerPolynomial (T : ParameterIndex n → ℤ) (x : Fin n → ℤ) (z : ℤ)
    (p : MvPolynomial (PowerVar n) ℚ) : ℚ :=
  MvPolynomial.eval (evalPowerVar T x z) p

/-- Replace parameters by a fixed integer tuple, keeping `x,z` as variables. -/
def powerSpecialization (T : ParameterIndex n → ℤ) :
    PowerVar n → MvPolynomial (PowerInputVar n) ℚ
  | PowerVar.param I => MvPolynomial.C (T I : ℚ)
  | PowerVar.coord i => MvPolynomial.X (PowerInputVar.coord i)
  | PowerVar.exponent => MvPolynomial.X PowerInputVar.exponent

/-- Specialize the parameter variables in a powering polynomial. -/
def specializePower (T : ParameterIndex n → ℤ)
    (p : MvPolynomial (PowerVar n) ℚ) :
    MvPolynomial (PowerInputVar n) ℚ :=
  MvPolynomial.eval₂Hom MvPolynomial.C (powerSpecialization T) p

lemma eval_specializePower (T : ParameterIndex n → ℤ) (x : Fin n → ℤ)
    (z : ℤ) (p : MvPolynomial (PowerVar n) ℚ) :
    MvPolynomial.eval (evalInputVar x z) (specializePower T p) =
      evalPowerPolynomial T x z p := by
  change
    MvPolynomial.eval (evalInputVar x z)
        (MvPolynomial.eval₂ MvPolynomial.C (powerSpecialization T) p) =
      MvPolynomial.eval (evalPowerVar T x z) p
  rw [← MvPolynomial.eval_assoc]
  apply congrArg (fun f : PowerVar n → ℚ => MvPolynomial.eval f p)
  funext v
  cases v <;> simp [powerSpecialization, evalInputVar,
    evalPowerVar, evalVarQ]

/-- Split powering variables into the pure input variables and the parameters. -/
def powerVarSum (n : ℕ) : PowerVar n ≃ (PowerInputVar n ⊕ ParameterIndex n) where
  toFun
    | PowerVar.param I => Sum.inr I
    | PowerVar.coord i => Sum.inl (PowerInputVar.coord i)
    | PowerVar.exponent => Sum.inl PowerInputVar.exponent
  invFun
    | Sum.inr I => PowerVar.param I
    | Sum.inl (PowerInputVar.coord i) => PowerVar.coord i
    | Sum.inl PowerInputVar.exponent => PowerVar.exponent
  left_inv := by
    intro v
    cases v <;> rfl
  right_inv := by
    intro v
    cases v with
    | inl t => cases t <;> rfl
    | inr I => rfl

/--
View a powering polynomial as a polynomial in `x,z` with
parameter-polynomial coefficients.
-/
def inputRingHom (n : ℕ) :
    MvPolynomial (PowerVar n) ℚ →+*
      MvPolynomial (PowerInputVar n) (MvPolynomial (ParameterIndex n) ℚ) :=
  ((MvPolynomial.sumAlgEquiv ℚ (PowerInputVar n) (ParameterIndex n)).toRingEquiv.toRingHom).comp
    ((MvPolynomial.renameEquiv ℚ (powerVarSum n)).toRingEquiv.toRingHom)

/--
View a powering polynomial as a polynomial in `x,z` with
parameter-polynomial coefficients.
-/
def powerInputPolynomial (p : MvPolynomial (PowerVar n) ℚ) :
    MvPolynomial (PowerInputVar n) (MvPolynomial (ParameterIndex n) ℚ) :=
  inputRingHom n p

/--
Degree of a multiplication polynomial in the input variables `x,y`, treating
the parameter variables as coefficients.  This is the degree convention used
in Cant--Eick Section 5.
-/
def mulInputTotal (p : MvPolynomial (MulVar n) ℚ) : ℕ :=
  (mulInputPolynomial p).totalDegree

/--
Degree of a powering polynomial in the input variables `x,z`, treating the
parameter variables as coefficients.  This is the degree convention used in
Cant--Eick Section 5.
-/
def inputTotalDegree (p : MvPolynomial (PowerVar n) ℚ) : ℕ :=
  (powerInputPolynomial p).totalDegree

/--
Section 5 Conjecture `degconj` for supplied reduced top-coordinate
polynomials `\hat F_n` and `\hat K_n`.
-/
def hallDegreeConjecture
    (Fhat : MvPolynomial (MulVar n) ℚ)
    (Khat : MvPolynomial (PowerVar n) ℚ) : Prop :=
  mulInputTotal Fhat = n - 1 ∧
    inputTotalDegree Khat = 2 * (n - 1)

/--
Family form of Section 5 Conjecture `degconj`, for a choice of reduced
top-coordinate polynomials in every positive Hirsch length.
-/
def polynomialDegreeConjecture
    (Fhat : (n : ℕ) → MvPolynomial (MulVar n) ℚ)
    (Khat : (n : ℕ) → MvPolynomial (PowerVar n) ℚ) : Prop :=
  ∀ n, 0 < n → hallDegreeConjecture (Fhat n) (Khat n)

theorem power_parameter_evaluation
    (T : ParameterIndex n → ℤ) (p : MvPolynomial (PowerVar n) ℚ) :
    MvPolynomial.map (parameterEvaluation T) (powerInputPolynomial p) =
      specializePower T p := by
  have hhom :
      ((MvPolynomial.map (parameterEvaluation T)).comp (inputRingHom n)) =
        (MvPolynomial.eval₂Hom MvPolynomial.C (powerSpecialization T) :
          MvPolynomial (PowerVar n) ℚ →+* MvPolynomial (PowerInputVar n) ℚ) := by
    apply MvPolynomial.ringHom_ext
    · intro a
      simp [inputRingHom, parameterEvaluation]
    · intro v
      cases v <;>
        simp [inputRingHom, powerVarSum, powerSpecialization,
          parameterEvaluation]
  change (((MvPolynomial.map (parameterEvaluation T)).comp (inputRingHom n)) p) =
    (MvPolynomial.eval₂Hom MvPolynomial.C (powerSpecialization T)) p
  rw [hhom]

theorem input_parameter_evaluation
    (T : ParameterIndex n → ℤ) (x : Fin n → ℤ) (z : ℤ)
    (p : MvPolynomial (PowerVar n) ℚ) :
    MvPolynomial.eval (evalInputVar x z)
        (MvPolynomial.map (parameterEvaluation T) (powerInputPolynomial p)) =
      evalPowerPolynomial T x z p := by
  rw [power_parameter_evaluation, eval_specializePower]

/--
Section 4 corollary for powering polynomials: reducing each
parameter-coefficient of a powering polynomial modulo the obstruction ideal
does not change its value at a consistent parameter tuple.
-/
theorem remainder_consistency_ideal
    {T : ParameterIndex n → ℤ}
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (hEval : ∀ i x y w,
      evalAssocPolynomial T x y w (associatorPolynomial F i) = 0)
    {p r : MvPolynomial (PowerVar n) ℚ}
    (h : coefficientwiseSubMem (consistencyObstructionIdeal F)
      (powerInputPolynomial p) (powerInputPolynomial r))
    (x : Fin n → ℤ) (z : ℤ) :
    evalPowerPolynomial T x z r = evalPowerPolynomial T x z p := by
  have hmap :=
    remainder_coefficientwise_eval
      F hEval h
  have heval := congrArg (MvPolynomial.eval (evalInputVar x z)) hmap
  rw [input_parameter_evaluation,
    input_parameter_evaluation] at heval
  exact heval

/--
Section 4 corollary for powering polynomials, as equality of the
parameter-specialized polynomials.
-/
theorem specialize_remainder_sub
    {T : ParameterIndex n → ℤ}
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (hEval : ∀ i x y w,
      evalAssocPolynomial T x y w (associatorPolynomial F i) = 0)
    {p r : MvPolynomial (PowerVar n) ℚ}
    (h : coefficientwiseSubMem (consistencyObstructionIdeal F)
      (powerInputPolynomial p) (powerInputPolynomial r)) :
    specializePower T r = specializePower T p := by
  have hmap :=
    remainder_coefficientwise_eval
      F hEval h
  simpa [power_parameter_evaluation] using hmap

theorem remainder_coeff_ideal
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    {p r : MvPolynomial (PowerVar n) ℚ}
    (h : coefficientwiseSubMem (consistencyObstructionIdeal F)
      (powerInputPolynomial p) (powerInputPolynomial r))
    (x : Fin n → ℤ) (z : ℤ) :
    evalPowerPolynomial T x z r = evalPowerPolynomial T x z p := by
  exact remainder_consistency_ideal
    F (fun i x y w => associator_polynomial_zero M F hF x y w i) h x z

/--
Represented form of the Section 4 powering-remainder corollary, as equality
of parameter-specialized polynomials.
-/
theorem specialize_remainder_ideal
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    {p r : MvPolynomial (PowerVar n) ℚ}
    (h : coefficientwiseSubMem (consistencyObstructionIdeal F)
      (powerInputPolynomial p) (powerInputPolynomial r)) :
    specializePower T r = specializePower T p :=
  specialize_remainder_sub
    F (fun i x y w => associator_polynomial_zero M F hF x y w i) h

/-- Substitute generic parameter, coordinate, and exponent polynomials into `K_i`. -/
def powerComposeSubst {σ : Type*}
    (τ : ParameterIndex n → MvPolynomial σ ℚ)
    (x : Fin n → MvPolynomial σ ℚ) (z : MvPolynomial σ ℚ) :
    PowerVar n → MvPolynomial σ ℚ
  | PowerVar.param I => τ I
  | PowerVar.coord i => x i
  | PowerVar.exponent => z

/-- The `i`th coordinate polynomial obtained by powering a polynomial tuple. -/
def powerComposePolynomial {σ : Type*}
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (τ : ParameterIndex n → MvPolynomial σ ℚ)
    (x : Fin n → MvPolynomial σ ℚ) (z : MvPolynomial σ ℚ) (i : Fin n) :
    MvPolynomial σ ℚ :=
  MvPolynomial.eval₂Hom MvPolynomial.C (powerComposeSubst τ x z) (K i)

lemma eval_compose_polynomial {σ : Type*}
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (τ : ParameterIndex n → MvPolynomial σ ℚ)
    (x : Fin n → MvPolynomial σ ℚ) (z : MvPolynomial σ ℚ)
    (e : σ → ℚ) (i : Fin n) :
    MvPolynomial.eval e (powerComposePolynomial K τ x z i) =
      evalPowerQ (fun I => MvPolynomial.eval e (τ I))
        (fun j => MvPolynomial.eval e (x j)) (MvPolynomial.eval e z) (K i) := by
  change
    MvPolynomial.eval e
        (MvPolynomial.eval₂ MvPolynomial.C (powerComposeSubst τ x z) (K i)) =
      MvPolynomial.eval
        (evalVarQ (fun I => MvPolynomial.eval e (τ I))
          (fun j => MvPolynomial.eval e (x j)) (MvPolynomial.eval e z)) (K i)
  rw [← MvPolynomial.eval_assoc]
  apply congrArg (fun f : PowerVar n → ℚ => MvPolynomial.eval f (K i))
  funext v
  cases v <;> simp [powerComposeSubst, evalVarQ]

/-- Specialize all powering variables except the exponent, leaving a polynomial in `z`. -/
def powerUnivariateQ (T : ParameterIndex n → ℚ) (x : Fin n → ℚ)
    (p : MvPolynomial (PowerVar n) ℚ) : Polynomial ℚ :=
  MvPolynomial.eval₂Hom Polynomial.C
    (fun v =>
      match v with
      | PowerVar.param I => Polynomial.C (T I)
      | PowerVar.coord i => Polynomial.C (x i)
      | PowerVar.exponent => Polynomial.X) p

/-- Integer-specialized univariate view of a powering polynomial. -/
def powerUnivariatePolynomial (T : ParameterIndex n → ℤ) (x : Fin n → ℤ)
    (p : MvPolynomial (PowerVar n) ℚ) : Polynomial ℚ :=
  powerUnivariateQ (fun I => (T I : ℚ)) (fun i => (x i : ℚ)) p

/-- Split powering variables into the exponent and the coefficient variables `T,x`. -/
def powerVarOption (n : ℕ) :
    PowerVar n ≃ Option (ParameterIndex n ⊕ Fin n) where
  toFun
    | PowerVar.param I => some (Sum.inl I)
    | PowerVar.coord i => some (Sum.inr i)
    | PowerVar.exponent => none
  invFun
    | some (Sum.inl I) => PowerVar.param I
    | some (Sum.inr i) => PowerVar.coord i
    | none => PowerVar.exponent
  left_inv := by
    intro w
    cases w <;> rfl
  right_inv := by
    intro w
    cases w with
    | none => rfl
    | some s => cases s <;> rfl

/--
View a powering polynomial as a univariate polynomial in the exponent `z`,
with coefficients polynomial in the parameters and coordinates `T,x`.
-/
def parameterCoordRing (n : ℕ) :
    MvPolynomial (PowerVar n) ℚ ≃+*
      Polynomial (MvPolynomial (ParameterIndex n ⊕ Fin n) ℚ) :=
  ((MvPolynomial.renameEquiv ℚ (powerVarOption n)).trans
    (MvPolynomial.optionEquivLeft ℚ (ParameterIndex n ⊕ Fin n))).toRingEquiv

/--
View a powering polynomial as an element of `Q[T,x][z]`.
-/
def parameterCoordPolynomial (p : MvPolynomial (PowerVar n) ℚ) :
    Polynomial (MvPolynomial (ParameterIndex n ⊕ Fin n) ℚ) :=
  parameterCoordRing n p

/-- Evaluation of coefficient polynomials in `Q[T,x]` at integer `T,x`. -/
def parameterCoordEvaluation (T : ParameterIndex n → ℤ) (x : Fin n → ℤ) :
    MvPolynomial (ParameterIndex n ⊕ Fin n) ℚ →+* ℚ :=
  MvPolynomial.eval fun w =>
    match w with
    | Sum.inl I => (T I : ℚ)
    | Sum.inr i => (x i : ℚ)

theorem parameter_coord_evaluation
    (T : ParameterIndex n → ℤ) (x : Fin n → ℤ)
    (p : MvPolynomial (PowerVar n) ℚ) :
    Polynomial.map (parameterCoordEvaluation T x)
        (parameterCoordPolynomial p) =
      powerUnivariatePolynomial T x p := by
  have hhom :
      ((Polynomial.mapRingHom (parameterCoordEvaluation T x)).comp
          (parameterCoordRing n).toRingHom) =
        (MvPolynomial.eval₂Hom Polynomial.C
          (fun w =>
            match w with
            | PowerVar.param I => Polynomial.C (T I : ℚ)
            | PowerVar.coord i => Polynomial.C (x i : ℚ)
            | PowerVar.exponent => Polynomial.X) :
          MvPolynomial (PowerVar n) ℚ →+* Polynomial ℚ) := by
    apply MvPolynomial.ringHom_ext
    · intro a
      simp [parameterCoordRing, parameterCoordEvaluation]
    · intro w
      cases w <;>
        simp [parameterCoordRing, powerVarOption,
          parameterCoordEvaluation]
  change (((Polynomial.mapRingHom (parameterCoordEvaluation T x)).comp
      (parameterCoordRing n).toRingHom) p) =
    (MvPolynomial.eval₂Hom Polynomial.C
      (fun w =>
        match w with
        | PowerVar.param I => Polynomial.C (T I : ℚ)
        | PowerVar.coord i => Polynomial.C (x i : ℚ)
        | PowerVar.exponent => Polynomial.X) p)
  rw [hhom]

theorem univariate_parameter_coord
    (T : ParameterIndex n → ℤ) (x : Fin n → ℤ)
    (p : Polynomial (MvPolynomial (ParameterIndex n ⊕ Fin n) ℚ)) :
    powerUnivariatePolynomial T x
        ((parameterCoordRing n).symm p) =
      Polynomial.map (parameterCoordEvaluation T x) p := by
  have h := parameter_coord_evaluation T x
    ((parameterCoordRing n).symm p)
  simpa [parameterCoordPolynomial] using h.symm

theorem antiderivative_parameter_evaluation
    (T : ParameterIndex n → ℤ) (x : Fin n → ℤ)
    (f₀ : MvPolynomial (ParameterIndex n ⊕ Fin n) ℚ)
    (g : Polynomial (MvPolynomial (ParameterIndex n ⊕ Fin n) ℚ)) :
    Polynomial.map (parameterCoordEvaluation T x) (polynomialForwardAntiderivative f₀ g) =
      polynomialForwardAntiderivative (parameterCoordEvaluation T x f₀)
        (Polynomial.map (parameterCoordEvaluation T x) g) := by
  apply polynomial_antiderivative_solves (R := ℚ)
  · have h0 := congrArg (parameterCoordEvaluation T x)
      (forward_antiderivative_zero f₀ g)
    rw [Polynomial.eval_map]
    rw [show (0 : ℚ) =
      parameterCoordEvaluation T x
        (0 : MvPolynomial (ParameterIndex n ⊕ Fin n) ℚ) by simp]
    rw [Polynomial.eval₂_hom]
    simpa using h0
  · intro z
    let zR : MvPolynomial (ParameterIndex n ⊕ Fin n) ℚ := MvPolynomial.C (z : ℚ)
    have hrec := congrArg (parameterCoordEvaluation T x)
      (polynomial_forward_antiderivative f₀ g zR)
    rw [Polynomial.eval_map, Polynomial.eval_map, Polynomial.eval_map]
    rw [show ((z : ℚ) + 1) = parameterCoordEvaluation T x (zR + 1) by simp [zR]]
    rw [show (z : ℚ) = parameterCoordEvaluation T x zR by simp [zR]]
    rw [Polynomial.eval₂_hom, Polynomial.eval₂_hom, Polynomial.eval₂_hom]
    simpa using hrec

/--
Zero-initial Bernoulli antiderivative of a powering increment in the
unspecialized ring `Q[T,x][z]`, returned as a powering polynomial.
-/
def forwardAntiderivativePolynomial
    (g : MvPolynomial (PowerVar n) ℚ) : MvPolynomial (PowerVar n) ℚ :=
  (parameterCoordRing n).symm
    (polynomialForwardAntiderivative
      (0 : MvPolynomial (ParameterIndex n ⊕ Fin n) ℚ)
      (parameterCoordPolynomial g))

theorem forward_antiderivative_polynomial
    (T : ParameterIndex n → ℤ) (x : Fin n → ℤ)
    (g : MvPolynomial (PowerVar n) ℚ) :
    powerUnivariatePolynomial T x (forwardAntiderivativePolynomial g) =
      polynomialForwardAntiderivative (0 : ℚ) (powerUnivariatePolynomial T x g) := by
  rw [forwardAntiderivativePolynomial,
    univariate_parameter_coord,
    antiderivative_parameter_evaluation,
    parameter_coord_evaluation]
  simp [parameterCoordEvaluation]

lemma eval_univariate_q
    (T : ParameterIndex n → ℚ) (x : Fin n → ℚ) (z : ℚ)
    (p : MvPolynomial (PowerVar n) ℚ) :
    (powerUnivariateQ T x p).eval z =
      evalPowerQ T x z p := by
  change
    (Polynomial.eval₂RingHom (RingHom.id ℚ) z)
        (MvPolynomial.eval₂ Polynomial.C
          (fun v =>
            match v with
            | PowerVar.param I => Polynomial.C (T I)
            | PowerVar.coord i => Polynomial.C (x i)
            | PowerVar.exponent => Polynomial.X) p) =
      MvPolynomial.eval₂ (RingHom.id ℚ) (evalVarQ T x z) p
  rw [MvPolynomial.eval₂_comp_left]
  apply congrArg₂ (fun f g => MvPolynomial.eval₂ f g p)
  · ext a
    simp
  · funext v
    cases v <;> simp [evalVarQ]

lemma eval_univariate_polynomial
    (T : ParameterIndex n → ℤ) (x : Fin n → ℤ) (z : ℤ)
    (p : MvPolynomial (PowerVar n) ℚ) :
    (powerUnivariatePolynomial T x p).eval (z : ℚ) =
      evalPowerPolynomial T x z p := by
  rw [powerUnivariatePolynomial, eval_univariate_q]
  rfl

/-- Rational evaluation assignment for conjugation variables. -/
def varQ (T : ParameterIndex n → ℚ) (u v : ℚ) :
    ConjVar n → ℚ
  | ConjVar.param I => T I
  | ConjVar.u => u
  | ConjVar.v => v

/-- Integer-specialized evaluation assignment for conjugation variables. -/
def evalConjVar (T : ParameterIndex n → ℤ) (u v : ℤ) :
    ConjVar n → ℚ :=
  varQ (fun I => (T I : ℚ)) (u : ℚ) (v : ℚ)

/-- Evaluate a conjugation polynomial at integer data. -/
def evalConjPolynomial (T : ParameterIndex n → ℤ) (u v : ℤ)
    (p : MvPolynomial (ConjVar n) ℚ) : ℚ :=
  MvPolynomial.eval (evalConjVar T u v) p

/-- The central-tail conjugation monomial `T_I u v`. -/
def centralTailConjugation (I : ParameterIndex n) :
    MvPolynomial (ConjVar n) ℚ :=
  MvPolynomial.X (ConjVar.param I) *
    MvPolynomial.X ConjVar.u * MvPolynomial.X ConjVar.v

@[simp]
lemma tail_conjugation_polynomial
    (T : ParameterIndex n → ℤ) (u v : ℤ) (I : ParameterIndex n) :
    evalConjPolynomial T u v (centralTailConjugation I) =
      (T I : ℚ) * (u : ℚ) * (v : ℚ) := by
  simp [centralTailConjugation, evalConjPolynomial, evalConjVar,
    varQ]

/-- Evaluation assignment for the pure conjugation variables `u,v`. -/
def conjInputVar (u v : ℤ) : ConjInputVar n → ℚ
  | ConjInputVar.u => u
  | ConjInputVar.v => v

/-- Replace parameters by a fixed integer tuple, keeping `u,v` as variables. -/
def conjSpecialization (T : ParameterIndex n → ℤ) :
    ConjVar n → MvPolynomial (ConjInputVar n) ℚ
  | ConjVar.param I => MvPolynomial.C (T I : ℚ)
  | ConjVar.u => MvPolynomial.X ConjInputVar.u
  | ConjVar.v => MvPolynomial.X ConjInputVar.v

/-- Specialize the parameter variables in a conjugation polynomial. -/
def specializeConj (T : ParameterIndex n → ℤ)
    (p : MvPolynomial (ConjVar n) ℚ) :
    MvPolynomial (ConjInputVar n) ℚ :=
  MvPolynomial.eval₂Hom MvPolynomial.C (conjSpecialization T) p

lemma eval_specializeConj (T : ParameterIndex n → ℤ) (u v : ℤ)
    (p : MvPolynomial (ConjVar n) ℚ) :
    MvPolynomial.eval (conjInputVar u v) (specializeConj T p) =
      evalConjPolynomial T u v p := by
  change
    MvPolynomial.eval (conjInputVar u v)
        (MvPolynomial.eval₂ MvPolynomial.C (conjSpecialization T) p) =
      MvPolynomial.eval (evalConjVar T u v) p
  rw [← MvPolynomial.eval_assoc]
  apply congrArg (fun f : ConjVar n → ℚ => MvPolynomial.eval f p)
  funext w
  cases w <;> simp [conjSpecialization, conjInputVar,
    evalConjVar, varQ]

/-- Substitute `v + 1` for the second conjugation variable. -/
def conjVSubst : ConjVar n → MvPolynomial (ConjVar n) ℚ
  | ConjVar.param I => MvPolynomial.X (ConjVar.param I)
  | ConjVar.u => MvPolynomial.X ConjVar.u
  | ConjVar.v => MvPolynomial.X ConjVar.v + MvPolynomial.C 1

/-- The polynomial `R(T; u, v + 1)`. -/
def conjSuccV
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ) (I : ParameterIndex n) :
    MvPolynomial (ConjVar n) ℚ :=
  MvPolynomial.eval₂Hom MvPolynomial.C conjVSubst (R I)

/-- The forward difference `R(T; u, v + 1) - R(T; u, v)`. -/
def conjForwardV
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ) (I : ParameterIndex n) :
    MvPolynomial (ConjVar n) ℚ :=
  conjSuccV R I - R I

lemma conj_succ_v
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (T : ParameterIndex n → ℤ) (u v : ℤ) (I : ParameterIndex n) :
    evalConjPolynomial T u v (conjSuccV R I) =
      evalConjPolynomial T u (v + 1) (R I) := by
  change
    MvPolynomial.eval (evalConjVar T u v)
        (MvPolynomial.eval₂ MvPolynomial.C conjVSubst (R I)) =
      MvPolynomial.eval (evalConjVar T u (v + 1)) (R I)
  rw [← MvPolynomial.eval_assoc]
  apply congrArg (fun f : ConjVar n → ℚ => MvPolynomial.eval f (R I))
  funext w
  cases w <;> simp [conjVSubst, evalConjVar, varQ, Int.cast_add]

lemma difference_v_polynomial
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (T : ParameterIndex n → ℤ) (u v : ℤ) (I : ParameterIndex n) :
    evalConjPolynomial T u v (conjForwardV R I) =
      evalConjPolynomial T u (v + 1) (R I) - evalConjPolynomial T u v (R I) := by
  unfold conjForwardV evalConjPolynomial
  rw [map_sub]
  have h := conj_succ_v R T u v I
  change
    MvPolynomial.eval (evalConjVar T u v) (conjSuccV R I) =
      MvPolynomial.eval (evalConjVar T u (v + 1)) (R I) at h
  rw [h]

lemma conj_succ_difference
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (T : ParameterIndex n → ℤ) (u v : ℤ) (I : ParameterIndex n) :
    evalConjPolynomial T u (v + 1) (R I) =
      evalConjPolynomial T u v (R I) +
        evalConjPolynomial T u v (conjForwardV R I) := by
  rw [difference_v_polynomial]
  ring

/-- Substitute `u = 1` while keeping the result as a polynomial in `T,u,v`. -/
def conjSetSubst : ConjVar n → MvPolynomial (ConjVar n) ℚ
  | ConjVar.param I => MvPolynomial.X (ConjVar.param I)
  | ConjVar.u => MvPolynomial.C 1
  | ConjVar.v => MvPolynomial.X ConjVar.v

/-- Specialize a conjugation polynomial at `u = 1`, retaining the same variables. -/
def conjSetU (p : MvPolynomial (ConjVar n) ℚ) :
    MvPolynomial (ConjVar n) ℚ :=
  MvPolynomial.eval₂Hom MvPolynomial.C conjSetSubst p

lemma set_u_polynomial
    (T : ParameterIndex n → ℤ) (u v : ℤ)
    (p : MvPolynomial (ConjVar n) ℚ) :
    evalConjPolynomial T u v (conjSetU p) =
      evalConjPolynomial T 1 v p := by
  change
    MvPolynomial.eval (evalConjVar T u v)
        (MvPolynomial.eval₂ MvPolynomial.C conjSetSubst p) =
      MvPolynomial.eval (evalConjVar T 1 v) p
  rw [← MvPolynomial.eval_assoc]
  apply congrArg (fun f : ConjVar n → ℚ => MvPolynomial.eval f p)
  funext w
  cases w <;> simp [conjSetSubst, evalConjVar, varQ]

/-- Variables for the polynomial `g(T;v)` obtained by setting `u = 1`. -/
inductive ConjOneVar (n : ℕ) where
  | param : ParameterIndex n → ConjOneVar n
  | v : ConjOneVar n
deriving DecidableEq

/-- Rational evaluation assignment for the variables `T,v`. -/
def conjVarQ (T : ParameterIndex n → ℚ) (v : ℚ) : ConjOneVar n → ℚ
  | ConjOneVar.param I => T I
  | ConjOneVar.v => v

/-- Evaluate a polynomial in parameters and `v` at rational data. -/
def evalConjQ (T : ParameterIndex n → ℚ) (v : ℚ)
    (p : MvPolynomial (ConjOneVar n) ℚ) : ℚ :=
  MvPolynomial.eval (conjVarQ T v) p

/-- Integer-specialized evaluation assignment for the variables `T,v`. -/
def conjOneVar (T : ParameterIndex n → ℤ) (v : ℤ) : ConjOneVar n → ℚ :=
  conjVarQ (fun I => (T I : ℚ)) (v : ℚ)

/-- Evaluate a polynomial in parameters and the single variable `v`. -/
def conjOnePolynomial (T : ParameterIndex n → ℤ) (v : ℤ)
    (p : MvPolynomial (ConjOneVar n) ℚ) : ℚ :=
  MvPolynomial.eval (conjOneVar T v) p

/--
Embed a polynomial in the parameters and `v` into the full conjugation
polynomial ring by making it independent of `u`.
-/
def conjLiftSubst : ConjOneVar n → MvPolynomial (ConjVar n) ℚ
  | ConjOneVar.param I => MvPolynomial.X (ConjVar.param I)
  | ConjOneVar.v => MvPolynomial.X ConjVar.v

/-- Lift a `Q[T,v]` polynomial to `Q[T,u,v]`, independent of `u`. -/
def conjLiftPolynomial (p : MvPolynomial (ConjOneVar n) ℚ) :
    MvPolynomial (ConjVar n) ℚ :=
  MvPolynomial.eval₂Hom MvPolynomial.C conjLiftSubst p

lemma conj_lift_polynomial
    (T : ParameterIndex n → ℤ) (u v : ℤ)
    (p : MvPolynomial (ConjOneVar n) ℚ) :
    evalConjPolynomial T u v (conjLiftPolynomial p) =
      conjOnePolynomial T v p := by
  change
    MvPolynomial.eval (evalConjVar T u v)
        (MvPolynomial.eval₂ MvPolynomial.C conjLiftSubst p) =
      MvPolynomial.eval (conjOneVar T v) p
  rw [← MvPolynomial.eval_assoc]
  apply congrArg (fun f : ConjOneVar n → ℚ => MvPolynomial.eval f p)
  funext w
  cases w <;> simp [conjLiftSubst, conjOneVar, conjVarQ,
    evalConjVar, varQ]

/-- Specialize all conjugation-one variables except `v`. -/
def conjUnivariateQ (T : ParameterIndex n → ℚ)
    (p : MvPolynomial (ConjOneVar n) ℚ) : Polynomial ℚ :=
  MvPolynomial.eval₂Hom Polynomial.C
    (fun w =>
      match w with
      | ConjOneVar.param I => Polynomial.C (T I)
      | ConjOneVar.v => Polynomial.X) p

/-- Integer-specialized univariate view of a polynomial in parameters and `v`. -/
def conjUnivariatePolynomial (T : ParameterIndex n → ℤ)
    (p : MvPolynomial (ConjOneVar n) ℚ) : Polynomial ℚ :=
  conjUnivariateQ (fun I => (T I : ℚ)) p

/-- Split `u = 1` conjugation variables into the input variable `v` and parameters. -/
def conjVarOption (n : ℕ) :
    ConjOneVar n ≃ Option (ParameterIndex n) where
  toFun
    | ConjOneVar.param I => some I
    | ConjOneVar.v => none
  invFun
    | some I => ConjOneVar.param I
    | none => ConjOneVar.v
  left_inv := by
    intro w
    cases w <;> rfl
  right_inv := by
    intro w
    cases w <;> rfl

/--
View a polynomial in the parameters and `v` as a univariate polynomial in `v`
with parameter-polynomial coefficients.
-/
def conjParameterRing (n : ℕ) :
    MvPolynomial (ConjOneVar n) ℚ ≃+*
      Polynomial (MvPolynomial (ParameterIndex n) ℚ) :=
  ((MvPolynomial.renameEquiv ℚ (conjVarOption n)).trans
    (MvPolynomial.optionEquivLeft ℚ (ParameterIndex n))).toRingEquiv

/--
View a polynomial in the parameters and `v` as a univariate polynomial in `v`
with parameter-polynomial coefficients.
-/
def conjParameterPolynomial (p : MvPolynomial (ConjOneVar n) ℚ) :
    Polynomial (MvPolynomial (ParameterIndex n) ℚ) :=
  conjParameterRing n p

theorem conj_parameter_evaluation
    (T : ParameterIndex n → ℤ) (p : MvPolynomial (ConjOneVar n) ℚ) :
    Polynomial.map (parameterEvaluation T) (conjParameterPolynomial p) =
      conjUnivariatePolynomial T p := by
  have hhom :
      ((Polynomial.mapRingHom (parameterEvaluation T)).comp
          (conjParameterRing n).toRingHom) =
        (MvPolynomial.eval₂Hom Polynomial.C
          (fun w =>
            match w with
            | ConjOneVar.param I => Polynomial.C (T I : ℚ)
            | ConjOneVar.v => Polynomial.X) :
          MvPolynomial (ConjOneVar n) ℚ →+* Polynomial ℚ) := by
    apply MvPolynomial.ringHom_ext
    · intro a
      simp [conjParameterRing, parameterEvaluation]
    · intro w
      cases w <;>
        simp [conjParameterRing, conjVarOption,
          parameterEvaluation]
  change (((Polynomial.mapRingHom (parameterEvaluation T)).comp
      (conjParameterRing n).toRingHom) p) =
    (MvPolynomial.eval₂Hom Polynomial.C
      (fun w =>
        match w with
        | ConjOneVar.param I => Polynomial.C (T I : ℚ)
        | ConjOneVar.v => Polynomial.X) p)
  rw [hhom]

theorem conj_univariate_parameter
    (T : ParameterIndex n → ℤ)
    (p : Polynomial (MvPolynomial (ParameterIndex n) ℚ)) :
    conjUnivariatePolynomial T
        ((conjParameterRing n).symm p) =
      Polynomial.map (parameterEvaluation T) p := by
  have h := conj_parameter_evaluation T
    ((conjParameterRing n).symm p)
  simpa [conjParameterPolynomial] using h.symm

theorem forward_antiderivative_evaluation
    (T : ParameterIndex n → ℤ)
    (f₀ : MvPolynomial (ParameterIndex n) ℚ)
    (g : Polynomial (MvPolynomial (ParameterIndex n) ℚ)) :
    Polynomial.map (parameterEvaluation T) (polynomialForwardAntiderivative f₀ g) =
      polynomialForwardAntiderivative (parameterEvaluation T f₀)
        (Polynomial.map (parameterEvaluation T) g) := by
  apply polynomial_antiderivative_solves (R := ℚ)
  · have h0 := congrArg (parameterEvaluation T)
      (forward_antiderivative_zero f₀ g)
    rw [Polynomial.eval_map]
    rw [show (0 : ℚ) =
      parameterEvaluation T (0 : MvPolynomial (ParameterIndex n) ℚ) by simp]
    rw [Polynomial.eval₂_hom]
    simpa using h0
  · intro x
    let xR : MvPolynomial (ParameterIndex n) ℚ := MvPolynomial.C (x : ℚ)
    have hrec := congrArg (parameterEvaluation T)
      (polynomial_forward_antiderivative f₀ g xR)
    rw [Polynomial.eval_map, Polynomial.eval_map, Polynomial.eval_map]
    rw [show ((x : ℚ) + 1) = parameterEvaluation T (xR + 1) by simp [xR]]
    rw [show (x : ℚ) = parameterEvaluation T xR by simp [xR]]
    rw [Polynomial.eval₂_hom, Polynomial.eval₂_hom, Polynomial.eval₂_hom]
    simpa using hrec

/--
Zero-initial Bernoulli antiderivative of a polynomial in the parameters and
`v`, returned again as a polynomial in the parameters and `v`.
-/
def conjForwardAntiderivative
    (g : MvPolynomial (ConjOneVar n) ℚ) : MvPolynomial (ConjOneVar n) ℚ :=
  (conjParameterRing n).symm
    (polynomialForwardAntiderivative
      (0 : MvPolynomial (ParameterIndex n) ℚ) (conjParameterPolynomial g))

theorem univariate_antiderivative_polynomial
    (T : ParameterIndex n → ℤ) (g : MvPolynomial (ConjOneVar n) ℚ) :
    conjUnivariatePolynomial T (conjForwardAntiderivative g) =
      polynomialForwardAntiderivative (0 : ℚ)
        (conjUnivariatePolynomial T g) := by
  rw [conjForwardAntiderivative,
    conj_univariate_parameter,
    forward_antiderivative_evaluation,
    conj_parameter_evaluation]
  simp [parameterEvaluation]

lemma conj_univariate_q
    (T : ParameterIndex n → ℚ) (z : ℚ)
    (p : MvPolynomial (ConjOneVar n) ℚ) :
    (conjUnivariateQ T p).eval z =
      evalConjQ T z p := by
  change
    (Polynomial.eval₂RingHom (RingHom.id ℚ) z)
        (MvPolynomial.eval₂ Polynomial.C
          (fun w =>
            match w with
            | ConjOneVar.param I => Polynomial.C (T I)
            | ConjOneVar.v => Polynomial.X) p) =
      MvPolynomial.eval₂ (RingHom.id ℚ) (conjVarQ T z) p
  rw [MvPolynomial.eval₂_comp_left]
  apply congrArg₂ (fun f g => MvPolynomial.eval₂ f g p)
  · ext a
    simp
  · funext w
    cases w <;> simp [conjVarQ]

lemma conj_univariate_polynomial
    (T : ParameterIndex n → ℤ) (v : ℤ)
    (p : MvPolynomial (ConjOneVar n) ℚ) :
    (conjUnivariatePolynomial T p).eval (v : ℚ) =
      conjOnePolynomial T v p := by
  rw [conjUnivariatePolynomial, conj_univariate_q]
  rfl

/-- Substitute `u = 1`, leaving the parameters and `v` as variables. -/
def conjUSubst : ConjVar n → MvPolynomial (ConjOneVar n) ℚ
  | ConjVar.param I => MvPolynomial.X (ConjOneVar.param I)
  | ConjVar.u => MvPolynomial.C 1
  | ConjVar.v => MvPolynomial.X ConjOneVar.v

/-- Specialize a conjugation polynomial at `u = 1`. -/
def conjUPolynomial (p : MvPolynomial (ConjVar n) ℚ) :
    MvPolynomial (ConjOneVar n) ℚ :=
  MvPolynomial.eval₂Hom MvPolynomial.C conjUSubst p

lemma conj_u_polynomial
    (T : ParameterIndex n → ℤ) (v : ℤ)
    (p : MvPolynomial (ConjVar n) ℚ) :
    conjOnePolynomial T v (conjUPolynomial p) =
      evalConjPolynomial T 1 v p := by
  change
    MvPolynomial.eval (conjOneVar T v)
        (MvPolynomial.eval₂ MvPolynomial.C conjUSubst p) =
      MvPolynomial.eval (evalConjVar T 1 v) p
  rw [← MvPolynomial.eval_assoc]
  apply congrArg (fun f : ConjVar n → ℚ => MvPolynomial.eval f p)
  funext w
  cases w <;> simp [conjUSubst, conjOneVar, conjVarQ,
    evalConjVar, varQ]

/--
The polynomial `g(T;v) = R(T;1,v+1) - R(T;1,v)` from Section 3.2,
represented as a polynomial in the parameters and `v`.
-/
def forwardDifferenceV
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ) (I : ParameterIndex n) :
    MvPolynomial (ConjOneVar n) ℚ :=
  conjUPolynomial (conjForwardV R I)

lemma forward_difference_v
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (T : ParameterIndex n → ℤ) (v : ℤ) (I : ParameterIndex n) :
    conjOnePolynomial T v (forwardDifferenceV R I) =
      evalConjPolynomial T 1 (v + 1) (R I) -
        evalConjPolynomial T 1 v (R I) := by
  rw [forwardDifferenceV, conj_u_polynomial,
    difference_v_polynomial]

/-- Polynomial form of the Section 3.2 forward recursion at `u = 1`. -/
lemma eval_forward_difference
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (T : ParameterIndex n → ℤ) (v : ℤ) (I : ParameterIndex n) :
    evalConjPolynomial T 1 (v + 1) (R I) =
      evalConjPolynomial T 1 v (R I) +
        conjOnePolynomial T v (forwardDifferenceV R I) := by
  rw [forward_difference_v]
  ring

/-- Polynomial identity form of the Section 3.2 forward recursion at `u = 1`. -/
theorem u_forward_difference
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ) (I : ParameterIndex n) :
    conjUPolynomial (conjSuccV R I) =
      conjUPolynomial (R I) + forwardDifferenceV R I := by
  unfold forwardDifferenceV conjForwardV conjUPolynomial
  rw [map_sub]
  ring

/--
Univariate specialized form of the Section 3.2 forward recursion at `u = 1`.
-/
theorem univariate_succ_difference
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (T : ParameterIndex n → ℤ) (I : ParameterIndex n) :
    conjUnivariatePolynomial T (conjUPolynomial (conjSuccV R I)) =
      conjUnivariatePolynomial T (conjUPolynomial (R I)) +
        conjUnivariatePolynomial T (forwardDifferenceV R I) := by
  rw [u_forward_difference]
  simp [conjUnivariatePolynomial, conjUnivariateQ]

/--
Paper-style form of Section 3.2 Lemma `step2`: for every conjugation
polynomial there is a polynomial in the parameters and `v` that gives its
forward difference at `u = 1`.
-/
theorem forward_recursion_polynomial
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ) (I : ParameterIndex n) :
    ∃ g : MvPolynomial (ConjOneVar n) ℚ,
      ∀ (T : ParameterIndex n → ℤ) (v : ℤ),
        evalConjPolynomial T 1 (v + 1) (R I) =
          evalConjPolynomial T 1 v (R I) + conjOnePolynomial T v g := by
  exact ⟨forwardDifferenceV R I,
    fun T v => eval_forward_difference R T v I⟩

/--
Substitution for Section 3.1 Lemma `step1`: the powering coordinate variables
are replaced by the coordinate tuple `r` with `r_j = 1` and
`r_i = R_{0,j,i}(T;1,v)` for `j < i`.
-/
def conj1Subst {n : ℕ}
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) :
    PowerVar (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ
  | PowerVar.param I => MvPolynomial.X (ConjVar.param I)
  | PowerVar.coord i =>
      if i = j then
        MvPolynomial.C 1
      else if hji : j < i then
        conjSetU (R ⟨(0, j, i), h0j, hji⟩)
      else
        0
  | PowerVar.exponent => MvPolynomial.X ConjVar.u

/-- The composed polynomial `K_k(T; r, u)` from Section 3.1 Lemma `step1`. -/
def conjStep1 {n : ℕ}
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (k : Fin (n + 1)) :
    MvPolynomial (ConjVar (n + 1)) ℚ :=
  MvPolynomial.eval₂Hom MvPolynomial.C (conj1Subst R j h0j) (K k)

/--
Family-level version of Section 3.2 Lemma `step1`: every conjugation
coordinate whose lower generator is `0` is replaced by the powering
construction `K_k(T;r,u)`, while all other coordinates are left unchanged.
-/
def conj1Family {n : ℕ}
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ) :
    ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ :=
  fun I =>
    if h0 : I.1.1 = (0 : Fin (n + 1)) then
      conjStep1 R K I.1.2.1 (by simpa [h0] using I.2.1) I.1.2.2
    else
      R I

/--
Lower-rank coordinate tuple `r` for Section 3.2 Lemma `step1`, expressed in
the canonical `U(T)` coordinates.  The coordinate at `j` is `1`; coordinates
above `j` are supplied by the ambient conjugation polynomials at `u = 1`;
coordinates below `j` are zero.
-/
def stepCoordU {n : ℕ}
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j : Fin n) (i : Fin n) :
    MvPolynomial (ConjVar (n + 1)) ℚ :=
  if i = j then
    MvPolynomial.C 1
  else if hji : j < i then
    conjSetU
      (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
        Fin.succ_lt_succ_iff.mpr hji⟩)
  else
    0

/--
Paper-style lower-rank version of Section 3.2 Lemma `step1`: compose the
`U(T)` powering polynomial with the tuple `r` and exponent `u`.
-/
def step1U {n : ℕ}
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (j k : Fin n) :
    MvPolynomial (ConjVar (n + 1)) ℚ :=
  powerComposePolynomial K_U
    (fun I => MvPolynomial.X (ConjVar.param (parameterSuccAbove 0 I)))
    (stepCoordU R j)
    (MvPolynomial.X ConjVar.u) k

/--
Family-level lower-rank `U(T)` version of Section 3.2 Lemma `step1`: every
conjugation coordinate `(0, succ j, succ k)` is replaced by the polynomial
constructed from the canonical lower-rank powering family; all other
coordinates are left unchanged.
-/
def stepFamilyU {n : ℕ}
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ) :
    ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ :=
  fun I =>
    match I with
    | ⟨(i, j, k), hij, hjk⟩ =>
      Fin.cases
        (R ⟨(i, j, k), hij, hjk⟩)
        (fun j' =>
          Fin.cases
            (R ⟨(i, j, k), hij, hjk⟩)
            (fun k' =>
              if i = 0 then
                step1U R K_U j' k'
              else
                R ⟨(i, j, k), hij, hjk⟩)
            k)
        j

/-- Substitute `z + 1` for the exponent variable in a powering polynomial. -/
def powerSuccSubst : PowerVar n → MvPolynomial (PowerVar n) ℚ
  | PowerVar.param I => MvPolynomial.X (PowerVar.param I)
  | PowerVar.coord i => MvPolynomial.X (PowerVar.coord i)
  | PowerVar.exponent => MvPolynomial.X PowerVar.exponent + MvPolynomial.C 1

/-- The polynomial `K_i(T; x, z + 1)`. -/
def powerSuccPolynomial (K : Fin n → MvPolynomial (PowerVar n) ℚ) (i : Fin n) :
    MvPolynomial (PowerVar n) ℚ :=
  MvPolynomial.eval₂Hom MvPolynomial.C powerSuccSubst (K i)

/-- Substitute `K(T;x,z)` and `x` into a multiplication polynomial. -/
def powerMulSubst (K : Fin n → MvPolynomial (PowerVar n) ℚ) :
    MulVar n → MvPolynomial (PowerVar n) ℚ
  | MulVar.param I => MvPolynomial.X (PowerVar.param I)
  | MulVar.left i => K i
  | MulVar.right i => MvPolynomial.X (PowerVar.coord i)

/-- The polynomial coordinate of `F(T; K(T;x,z), x)`. -/
def powerMulPolynomial
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ) (i : Fin n) :
    MvPolynomial (PowerVar n) ℚ :=
  MvPolynomial.eval₂Hom MvPolynomial.C (powerMulSubst K) (F i)

/-- The forward difference used in the powering recursion. -/
def forwardDifferencePolynomial
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ) (i : Fin n) :
    MvPolynomial (PowerVar n) ℚ :=
  powerMulPolynomial F K i - K i

lemma eval_succ_polynomial
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (T : ParameterIndex n → ℤ) (x : Fin n → ℤ) (z : ℤ) (i : Fin n) :
    evalPowerPolynomial T x z (powerSuccPolynomial K i) =
      evalPowerPolynomial T x (z + 1) (K i) := by
  change
    MvPolynomial.eval (evalPowerVar T x z)
        (MvPolynomial.eval₂ MvPolynomial.C powerSuccSubst (K i)) =
      MvPolynomial.eval (evalPowerVar T x (z + 1)) (K i)
  rw [← MvPolynomial.eval_assoc]
  apply congrArg (fun f : PowerVar n → ℚ => MvPolynomial.eval f (K i))
  funext v
  cases v <;> simp [powerSuccSubst, evalPowerVar, evalVarQ, Int.cast_add]

lemma eval_mul_polynomial
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (T : ParameterIndex n → ℤ) (x : Fin n → ℤ) (z : ℤ) (i : Fin n) :
    evalPowerPolynomial T x z (powerMulPolynomial F K i) =
      evalMulQ (fun I => (T I : ℚ))
        (fun j => evalPowerPolynomial T x z (K j))
        (fun j => (x j : ℚ)) (F i) := by
  change
    MvPolynomial.eval (evalPowerVar T x z)
        (MvPolynomial.eval₂ MvPolynomial.C (powerMulSubst K) (F i)) =
      MvPolynomial.eval
        (mulVarQ (fun I => (T I : ℚ))
          (fun j => evalPowerPolynomial T x z (K j))
          (fun j => (x j : ℚ))) (F i)
  rw [← MvPolynomial.eval_assoc]
  apply congrArg (fun f : MulVar n → ℚ => MvPolynomial.eval f (F i))
  funext v
  cases v <;> simp [powerMulSubst, evalPowerPolynomial, evalPowerVar,
    evalVarQ, mulVarQ]

lemma power_forward_difference
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (T : ParameterIndex n → ℤ) (x : Fin n → ℤ) (z : ℤ) (i : Fin n) :
    evalPowerPolynomial T x z (forwardDifferencePolynomial F K i) =
      evalPowerPolynomial T x z (powerMulPolynomial F K i) -
        evalPowerPolynomial T x z (K i) := by
  simp [forwardDifferencePolynomial, evalPowerPolynomial]

lemma eval_left_represents {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (y : Fin n → ℤ) (i : Fin n) :
    evalMulPolynomial T (fun _ => 0) y (F i) = (y i : ℚ) := by
  rw [hF (fun _ => 0) y i]
  change (M.multiplicationTuple (fun _ => 0) y i : ℚ) = (y i : ℚ)
  simp

lemma eval_right_represents {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (x : Fin n → ℤ) (i : Fin n) :
    evalMulPolynomial T x (fun _ => 0) (F i) = (x i : ℚ) := by
  rw [hF x (fun _ => 0) i]
  change (M.multiplicationTuple x (fun _ => 0) i : ℚ) = (x i : ℚ)
  simp

/--
If a represented multiplication polynomial has the additive coordinate formula
`F_i(T;x,y)=x_i+y_i`, then the corresponding semantic coordinate is additive.
-/
theorem additive_represents_multiplication
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (hF : RepresentsMultiplication M F) (i : Fin n)
    (hAdd :
      ∀ x y : Fin n → ℤ,
        evalMulPolynomial T x y (F i) = ((x i + y i : ℤ) : ℚ)) :
    CPres.CoordinateAdditive M i := by
  rw [M.additive_multiplication_tuple i]
  intro x y
  have hq : (M.multiplicationTuple x y i : ℚ) = ((x i + y i : ℤ) : ℚ) :=
    (hF x y i).symm.trans (hAdd x y)
  exact_mod_cast hq

/--
If `F_U` represents multiplication in the concrete `U(T)` presentation, then
its evaluations compute the ambient coordinates of products of first-tail
normal words.  This is the lower-rank multiplication datum needed for the
paper's induction, separated from any full ambient multiplication family.
-/
theorem multiplication_coord_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hMul : ∀ a b : M.G,
      M.coord a 0 = 0 → M.coord b 0 = 0 → M.coord (a * b) 0 = 0)
    (hInv : ∀ a : M.G, M.coord a 0 = 0 → M.coord a⁻¹ 0 = 0)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (hFU : RepresentsMultiplication
      (M.firstConsistentPresentation hMul hInv) F_U)
    (x y : Fin n → ℤ) (i : Fin n) :
    evalMulPolynomial (firstParameterTuple T) x y (F_U i) =
      (M.coord (M.tailNormalWord x * M.tailNormalWord y) (Fin.succ i) : ℚ) := by
  let MU := M.firstConsistentPresentation hMul hInv
  have hcoord :=
    M.first_consistent_coord hMul hInv
      ((show M.firstCoordinateSubgroup hMul hInv from
        MU.normalWord x * MU.normalWord y))
  have hcoe :
      (((show M.firstCoordinateSubgroup hMul hInv from
        MU.normalWord x * MU.normalWord y)) : M.G) =
        M.tailNormalWord x * M.tailNormalWord y := by
    rw [show (((show M.firstCoordinateSubgroup hMul hInv from
        MU.normalWord x * MU.normalWord y)) : M.G) =
        ((show M.firstCoordinateSubgroup hMul hInv from MU.normalWord x) : M.G) *
          ((show M.firstCoordinateSubgroup hMul hInv from MU.normalWord y) : M.G) by rfl]
    rw [M.first_consistent_coe hMul hInv x,
      M.first_consistent_coe hMul hInv y]
  have hi := congrFun hcoord i
  rw [hFU x y i]
  change (MU.coord (MU.normalWord x * MU.normalWord y) i : ℚ) =
    (M.coord (M.tailNormalWord x * M.tailNormalWord y) (Fin.succ i) : ℚ)
  rw [hi]
  rw [hcoe]
  rfl

theorem multiplication_coord_additive
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hAdd : CPres.CoordinateAdditive M 0)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (hFU : RepresentsMultiplication
      (M.firstConsistentAdditive hAdd) F_U)
    (x y : Fin n → ℤ) (i : Fin n) :
    evalMulPolynomial (firstParameterTuple T) x y (F_U i) =
      (M.coord (M.tailNormalWord x * M.tailNormalWord y) (Fin.succ i) : ℚ) := by
  let hClosed := CPres.coordinate_closed_additive M 0 hAdd
  simpa [CPres.firstConsistentAdditive,
    hClosed] using
    multiplication_coord_represents
      M hClosed.1 hClosed.2 F_U hFU x y i

theorem delete_multiplication_coord
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (x y : Fin n → ℤ) (i : Fin n) :
    evalMulPolynomial (firstParameterTuple T) x y (F_U i) =
      (M.coord (M.tailNormalWord x * M.tailNormalWord y) (Fin.succ i) : ℚ) :=
  multiplication_coord_additive
    M M.firstCoordinateAdditive F_U hFU x y i

/--
Represented-polynomial form of the Section 3.1 `U(T)` step: if the first
multiplication coordinate is the additive polynomial `x_0+y_0`, then deleting
the first generator gives a consistent parameter tuple.
-/
theorem parameter_locus_multiplication
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hFirst :
      ∀ x y : Fin (n + 1) → ℤ,
        evalMulPolynomial T x y (F 0) = ((x 0 + y 0 : ℤ) : ℚ)) :
    firstParameterTuple T ∈ CPres.consistencyLocus n :=
  CPres.tuple_consistency_locus M
    (additive_represents_multiplication M F hF 0 hFirst)

/--
If `F_V` represents multiplication in the concrete `V(T)` presentation, then
its evaluations compute the ambient coordinates of products of
second-tail normal words, with the second generator skipped.
-/
theorem second_multiplication_represents
    {n : ℕ} {T : ParameterIndex (n + 2) → ℤ}
    (M : CPres (n + 2) T)
    (hMul : ∀ a b : M.G,
      M.coord a 1 = 0 → M.coord b 1 = 0 → M.coord (a * b) 1 = 0)
    (hInv : ∀ a : M.G, M.coord a 1 = 0 → M.coord a⁻¹ 1 = 0)
    (F_V : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (hFV : RepresentsMultiplication
      (M.secondConsistentPresentation hMul hInv) F_V)
    (x y : Fin (n + 1) → ℤ) (i : Fin (n + 1)) :
    evalMulPolynomial (secondParameterTuple T) x y (F_V i) =
      (M.coord (M.secondTailNormal x * M.secondTailNormal y)
        ((1 : Fin (n + 2)).succAbove i) : ℚ) := by
  let MV := M.secondConsistentPresentation hMul hInv
  have hcoord :=
    M.second_consistent_coord hMul hInv
      ((show M.secondCoordinateSubgroup hMul hInv from
        MV.normalWord x * MV.normalWord y))
  have hcoe :
      (((show M.secondCoordinateSubgroup hMul hInv from
        MV.normalWord x * MV.normalWord y)) : M.G) =
        M.secondTailNormal x * M.secondTailNormal y := by
    rw [show (((show M.secondCoordinateSubgroup hMul hInv from
        MV.normalWord x * MV.normalWord y)) : M.G) =
        ((show M.secondCoordinateSubgroup hMul hInv from MV.normalWord x) : M.G) *
          ((show M.secondCoordinateSubgroup hMul hInv from MV.normalWord y) : M.G) by rfl]
    rw [M.consistent_presentation_coe hMul hInv x,
      M.consistent_presentation_coe hMul hInv y]
  have hi := congrFun hcoord i
  rw [hFV x y i]
  change (MV.coord (MV.normalWord x * MV.normalWord y) i : ℚ) =
    (M.coord (M.secondTailNormal x * M.secondTailNormal y)
      ((1 : Fin (n + 2)).succAbove i) : ℚ)
  rw [hi]
  rw [hcoe]
  rfl

theorem second_multiplication_additive
    {n : ℕ} {T : ParameterIndex (n + 2) → ℤ}
    (M : CPres (n + 2) T)
    (hAdd : CPres.CoordinateAdditive M 1)
    (F_V : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (hFV : RepresentsMultiplication
      (M.consistentPresentationAdditive hAdd) F_V)
    (x y : Fin (n + 1) → ℤ) (i : Fin (n + 1)) :
    evalMulPolynomial (secondParameterTuple T) x y (F_V i) =
      (M.coord (M.secondTailNormal x * M.secondTailNormal y)
        ((1 : Fin (n + 2)).succAbove i) : ℚ) := by
  let hClosed := CPres.coordinate_closed_additive M 1 hAdd
  simpa [CPres.consistentPresentationAdditive,
    hClosed] using
    second_multiplication_represents
      M hClosed.1 hClosed.2 F_V hFV x y i

theorem second_multiplication_coord
    {n : ℕ} {T : ParameterIndex (n + 2) → ℤ}
    (M : CPres (n + 2) T)
    (F_V : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (hFV : RepresentsMultiplication M.deleteSecondConsistent F_V)
    (x y : Fin (n + 1) → ℤ) (i : Fin (n + 1)) :
    evalMulPolynomial (secondParameterTuple T) x y (F_V i) =
      (M.coord (M.secondTailNormal x * M.secondTailNormal y)
        ((1 : Fin (n + 2)).succAbove i) : ℚ) :=
  second_multiplication_additive
    M M.secondCoordinateAdditive F_V hFV x y i

/--
Represented-polynomial form of the Section 3.1 `V(T)` step: if the second
multiplication coordinate is the additive polynomial `x_1+y_1`, then deleting
the second generator gives a consistent parameter tuple.
-/
theorem consistency_locus_multiplication
    {n : ℕ} {T : ParameterIndex (n + 2) → ℤ}
    (M : CPres (n + 2) T)
    (F : Fin (n + 2) → MvPolynomial (MulVar (n + 2)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hSecond :
      ∀ x y : Fin (n + 2) → ℤ,
        evalMulPolynomial T x y (F 1) = ((x 1 + y 1 : ℤ) : ℚ)) :
    secondParameterTuple T ∈ CPres.consistencyLocus (n + 1) :=
  CPres.parameter_locus_additive M
    (additive_represents_multiplication M F hF 1 hSecond)

/--
If `F_W` represents multiplication in the concrete quotient presentation
`W(T)`, then its evaluations compute the quotient coordinates of products of
ambient normal words with last coordinate zero.
-/
theorem last_multiplication_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_W : Fin n → MvPolynomial (MulVar n) ℚ)
    (hFW : RepresentsMultiplication M.deleteConsistentPresentation F_W)
    (x y : Fin n → ℤ) (i : Fin n) :
    evalMulPolynomial (lastParameterTuple T) x y (F_W i) =
      ((M.deleteConsistentPresentation).coord
        (QuotientGroup.mk' (Subgroup.zpowers (M.gen (Fin.last n)))
          (M.normalWord (Fin.snoc x 0) * M.normalWord (Fin.snoc y 0))) i : ℚ) := by
  let MW := M.deleteConsistentPresentation
  rw [hFW x y i]
  change (MW.coord (MW.normalWord x * MW.normalWord y) i : ℚ) =
    (MW.coord
      (QuotientGroup.mk' (Subgroup.zpowers (M.gen (Fin.last n)))
        (M.normalWord (Fin.snoc x 0) * M.normalWord (Fin.snoc y 0))) i : ℚ)
  congr 1
  rw [M.last_consistent_presentation x,
    M.last_consistent_presentation y]
  exact congrArg (fun q => MW.coord q i)
    (map_mul (QuotientGroup.mk' (Subgroup.zpowers (M.gen (Fin.last n))))
      (M.normalWord (Fin.snoc x 0)) (M.normalWord (Fin.snoc y 0))).symm

/--
Section 3.3 multiplication display, represented-polynomial form: evaluating
`F_i` gives the `i`th coordinate of the displayed product `(*)`.
-/
theorem coord_conjugated_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (x y : Fin (n + 1) → ℤ) (i : Fin (n + 1)) :
    evalMulPolynomial T x y (F i) =
      (M.coord (M.gen 0 ^ (x 0 + y 0) *
        M.firstConjugatedProduct x (y 0) *
          M.normalWord (withoutFirstCoord y)) i : ℚ) := by
  rw [hF x y i]
  exact congrArg (fun z : ℤ => (z : ℚ))
    (congrFun (M.multiplication_coord_conjugated x y) i)

/-- Substitute `0` for the last left and right variables in multiplication polynomials. -/
def withoutLastSubst {n : ℕ} : MulVar (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ
  | MulVar.param I => MvPolynomial.X (MulVar.param I)
  | MulVar.left i =>
      if i = Fin.last n then 0 else MvPolynomial.X (MulVar.left i)
  | MulVar.right i =>
      if i = Fin.last n then 0 else MvPolynomial.X (MulVar.right i)

/-- The polynomial `H` from Remark `formF`, represented by setting `x_n=y_n=0`. -/
def multiplicationLastTruncation {n : ℕ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ) :
    MvPolynomial (MulVar (n + 1)) ℚ :=
  MvPolynomial.eval₂Hom MvPolynomial.C withoutLastSubst (F (Fin.last n))

lemma multiplication_last_truncation {n : ℕ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (T : ParameterIndex (n + 1) → ℤ) (x y : Fin (n + 1) → ℤ) :
    evalMulPolynomial T x y (multiplicationLastTruncation F) =
      evalMulPolynomial T (withoutLastCoord x) (withoutLastCoord y) (F (Fin.last n)) := by
  change
    MvPolynomial.eval (evalMulVar T x y)
        (MvPolynomial.eval₂ MvPolynomial.C withoutLastSubst (F (Fin.last n))) =
      MvPolynomial.eval (evalMulVar T (withoutLastCoord x) (withoutLastCoord y))
        (F (Fin.last n))
  rw [← MvPolynomial.eval_assoc]
  apply congrArg (fun f : MulVar (n + 1) → ℚ =>
    MvPolynomial.eval f (F (Fin.last n)))
  funext v
  cases v with
  | param I =>
      simp [withoutLastSubst, evalMulVar, mulVarQ]
  | left i =>
      by_cases hi : i = Fin.last n
      · subst i
        simp [withoutLastSubst, evalMulVar, mulVarQ]
      · simp [withoutLastSubst, withoutLastCoord, evalMulVar, mulVarQ, hi]
  | right i =>
      by_cases hi : i = Fin.last n
      · subst i
        simp [withoutLastSubst, evalMulVar, mulVarQ]
      · simp [withoutLastSubst, withoutLastCoord, evalMulVar, mulVarQ, hi]

/--
Rational-evaluation version of `multiplication_last_truncation`:
the truncated last multiplication polynomial ignores the last left and right
inputs.
-/
lemma multiplication_last_q {n : ℕ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (Tq : ParameterIndex (n + 1) → ℚ)
    (x y : Fin (n + 1) → ℚ) :
    evalMulQ Tq x y (multiplicationLastTruncation F) =
      evalMulQ Tq
        (fun i => if i = Fin.last n then 0 else x i)
        (fun i => if i = Fin.last n then 0 else y i)
        (F (Fin.last n)) := by
  change
    MvPolynomial.eval (mulVarQ Tq x y)
        (MvPolynomial.eval₂ MvPolynomial.C withoutLastSubst (F (Fin.last n))) =
      MvPolynomial.eval
        (mulVarQ Tq
          (fun i => if i = Fin.last n then 0 else x i)
          (fun i => if i = Fin.last n then 0 else y i))
        (F (Fin.last n))
  rw [← MvPolynomial.eval_assoc]
  apply congrArg (fun f : MulVar (n + 1) → ℚ =>
    MvPolynomial.eval f (F (Fin.last n)))
  funext v
  cases v with
  | param I =>
      simp [withoutLastSubst, mulVarQ]
  | left i =>
      by_cases hi : i = Fin.last n
      · subst i
        simp [withoutLastSubst, mulVarQ]
      · simp [withoutLastSubst, mulVarQ, hi]
  | right i =>
      by_cases hi : i = Fin.last n
      · subst i
        simp [withoutLastSubst, mulVarQ]
      · simp [withoutLastSubst, mulVarQ, hi]

/--
Exact-premise polynomial form of Cant--Eick Remark `formF`: to split the last
coordinate, it is enough that the last multiplication polynomial represents
the two products appearing in the semantic truncation formula.
-/
theorem last_truncation_add
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (x y : Fin (n + 1) → ℤ)
    (hxy :
      evalMulPolynomial T x y (F (Fin.last n)) =
        (M.multiplicationTuple x y (Fin.last n) : ℚ))
    (htrunc :
      evalMulPolynomial T (withoutLastCoord x) (withoutLastCoord y) (F (Fin.last n)) =
        (M.multiplicationTuple (withoutLastCoord x) (withoutLastCoord y) (Fin.last n) :
          ℚ)) :
    evalMulPolynomial T x y (F (Fin.last n)) =
      evalMulPolynomial T x y (multiplicationLastTruncation F) +
        (x (Fin.last n) : ℚ) + (y (Fin.last n) : ℚ) := by
  rw [multiplication_last_truncation]
  rw [hxy, htrunc]
  rw [M.multiplication_tuple_last x y]
  norm_num [Int.cast_add]

/--
Polynomial form of Cant--Eick Remark `formF`: for represented multiplication,
the last coordinate splits as `x_n + y_n` plus a polynomial evaluated with
the last left and right variables set to zero.
-/
theorem last_truncation_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (x y : Fin (n + 1) → ℤ) :
    evalMulPolynomial T x y (F (Fin.last n)) =
      evalMulPolynomial T x y (multiplicationLastTruncation F) +
        (x (Fin.last n) : ℚ) + (y (Fin.last n) : ℚ) :=
  last_truncation_add M F x y
    (hF x y (Fin.last n))
    (hF (withoutLastCoord x) (withoutLastCoord y) (Fin.last n))

/-- Compose the truncated last multiplication polynomial with `K(T;x,z)` and `x`. -/
def lastTruncationPolynomial {n : ℕ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ) :
    MvPolynomial (PowerVar (n + 1)) ℚ :=
  MvPolynomial.eval₂Hom MvPolynomial.C (powerMulSubst K)
    (multiplicationLastTruncation F)

/--
The paper-style increment for the last powering coordinate:
`x_n + H(T;K(T;x,z),x)`.
-/
def lastForwardDifference {n : ℕ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ) :
    MvPolynomial (PowerVar (n + 1)) ℚ :=
  lastTruncationPolynomial F K + MvPolynomial.X (PowerVar.coord (Fin.last n))

/--
The zero-initial Bernoulli solution of the generic Section 3.4 powering
recursion, as a polynomial in `Q[T,x][z]`.
-/
def forwardSolutionPolynomial {n : ℕ}
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ) (i : Fin n) :
    MvPolynomial (PowerVar n) ℚ :=
  forwardAntiderivativePolynomial (forwardDifferencePolynomial F K i)

/--
The zero-initial Bernoulli solution of the paper-style last-coordinate
Section 3.4 recursion, using the increment `x_n + H(T;K(T;x,z),x)`.
-/
def lastSolutionPolynomial {n : ℕ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ) :
    MvPolynomial (PowerVar (n + 1)) ℚ :=
  forwardAntiderivativePolynomial (lastForwardDifference F K)

lemma last_truncation_polynomial {n : ℕ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (T : ParameterIndex (n + 1) → ℤ) (x : Fin (n + 1) → ℤ) (z : ℤ) :
    evalPowerPolynomial T x z (lastTruncationPolynomial F K) =
      evalMulQ (fun I => (T I : ℚ))
        (fun j => evalPowerPolynomial T x z (K j))
        (fun j => (x j : ℚ)) (multiplicationLastTruncation F) := by
  change
    MvPolynomial.eval (evalPowerVar T x z)
        (MvPolynomial.eval₂ MvPolynomial.C (powerMulSubst K)
          (multiplicationLastTruncation F)) =
      MvPolynomial.eval
        (mulVarQ (fun I => (T I : ℚ))
          (fun j => evalPowerPolynomial T x z (K j))
          (fun j => (x j : ℚ))) (multiplicationLastTruncation F)
  rw [← MvPolynomial.eval_assoc]
  apply congrArg (fun f : MulVar (n + 1) → ℚ =>
    MvPolynomial.eval f (multiplicationLastTruncation F))
  funext v
  cases v <;> simp [powerMulSubst, evalPowerPolynomial, evalPowerVar,
    evalVarQ, mulVarQ]

lemma forward_difference_polynomial {n : ℕ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (T : ParameterIndex (n + 1) → ℤ) (x : Fin (n + 1) → ℤ) (z : ℤ) :
    evalPowerPolynomial T x z (lastForwardDifference F K) =
      evalPowerPolynomial T x z (lastTruncationPolynomial F K) +
        (x (Fin.last n) : ℚ) := by
  simp [lastForwardDifference, evalPowerPolynomial, evalPowerVar,
    evalVarQ]

/-- `K` represents powering in the coordinate system of `M`. -/
def RepresentsPowering {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ) : Prop :=
  ∀ x z i,
    evalPowerPolynomial T x z (K i) =
      (M.coord (M.normalWord x ^ z) i : ℚ)

/--
Exact-premise form of the Section 3.4 last-coordinate increment that only
needs the non-last powering coordinates.  The last coordinate of `K` is
irrelevant because `multiplicationLastTruncation` sets the last
left/right multiplication variables to zero.
-/
theorem last_forward_nonlast
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (x : Fin (n + 1) → ℤ) (z : ℤ)
    (hKnonlast : ∀ i : Fin n,
      evalPowerPolynomial T x z (K (Fin.castSucc i)) =
        (M.poweringTuple x z (Fin.castSucc i) : ℚ)) :
    evalPowerPolynomial T x z (lastForwardDifference F K) =
      (M.multiplicationTuple (withoutLastCoord (M.poweringTuple x z))
        (withoutLastCoord x) (Fin.last n) : ℚ) + (x (Fin.last n) : ℚ) := by
  rw [forward_difference_polynomial, last_truncation_polynomial]
  rw [multiplication_last_q]
  have hleft :
      (fun i : Fin (n + 1) =>
          if i = Fin.last n then 0 else evalPowerPolynomial T x z (K i)) =
        fun i => (withoutLastCoord (M.poweringTuple x z) i : ℚ) := by
    funext i
    cases i using Fin.lastCases with
    | last =>
        simp [withoutLastCoord]
    | cast i =>
        simp [withoutLastCoord, hKnonlast i]
  have hright :
      (fun i : Fin (n + 1) => if i = Fin.last n then 0 else (x i : ℚ)) =
        fun i => (withoutLastCoord x i : ℚ) := by
    funext i
    cases i using Fin.lastCases with
    | last =>
        simp [withoutLastCoord]
    | cast i =>
        simp [withoutLastCoord]
  rw [hleft, hright]
  change
    evalMulPolynomial T (withoutLastCoord (M.poweringTuple x z))
        (withoutLastCoord x) (F (Fin.last n)) +
        (x (Fin.last n) : ℚ) =
      (M.multiplicationTuple (withoutLastCoord (M.poweringTuple x z))
        (withoutLastCoord x) (Fin.last n) : ℚ) + (x (Fin.last n) : ℚ)
  rw [hF (withoutLastCoord (M.poweringTuple x z)) (withoutLastCoord x) (Fin.last n)]
  simp [CPres.multiplicationTuple]

/--
The paper-style last-coordinate increment computes the semantic forward
difference of the last powering coordinate, assuming only non-last powering
coordinates for `K`.
-/
theorem forward_difference_nonlast
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (x : Fin (n + 1) → ℤ) (z : ℤ)
    (hKnonlast : ∀ i : Fin n,
      evalPowerPolynomial T x z (K (Fin.castSucc i)) =
        (M.poweringTuple x z (Fin.castSucc i) : ℚ)) :
    evalPowerPolynomial T x z (lastForwardDifference F K) =
      (M.poweringTuple x (z + 1) (Fin.last n) -
        M.poweringTuple x z (Fin.last n) : ℚ) := by
  rw [last_forward_nonlast
    M F K hF x z hKnonlast]
  rw [show
      (M.poweringTuple x (z + 1) (Fin.last n) : ℚ) -
          (M.poweringTuple x z (Fin.last n) : ℚ) =
        (x (Fin.last n) : ℚ) +
          (M.multiplicationTuple (withoutLastCoord (M.poweringTuple x z))
            (withoutLastCoord x) (Fin.last n) : ℚ) by
    have h := congrArg (fun a : ℤ => (a : ℚ))
      (M.powering_forward_difference x z)
    simpa [Int.cast_sub, Int.cast_add] using h]
  ring

theorem compose_tuple_represents
    {T : ParameterIndex n → ℤ} {σ : Type*}
    (M : CPres n T)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hK : RepresentsPowering M K)
    (τ : ParameterIndex n → MvPolynomial σ ℚ)
    (X : Fin n → MvPolynomial σ ℚ) (Z : MvPolynomial σ ℚ) (e : σ → ℚ)
    (hτ : ∀ I, MvPolynomial.eval e (τ I) = (T I : ℚ))
    (x : Fin n → ℤ) (z : ℤ)
    (hX : ∀ i, MvPolynomial.eval e (X i) = (x i : ℚ))
    (hZ : MvPolynomial.eval e Z = (z : ℚ)) (i : Fin n) :
    MvPolynomial.eval e (powerComposePolynomial K τ X Z i) =
      (M.poweringTuple x z i : ℚ) := by
  rw [eval_compose_polynomial]
  have hassign :
      evalVarQ (fun I => MvPolynomial.eval e (τ I))
          (fun j => MvPolynomial.eval e (X j)) (MvPolynomial.eval e Z) =
        evalPowerVar T x z := by
    funext v
    cases v <;> simp [evalPowerVar, evalVarQ, hτ, hX, hZ]
  rw [show
    evalPowerQ (fun I => MvPolynomial.eval e (τ I))
        (fun j => MvPolynomial.eval e (X j)) (MvPolynomial.eval e Z) (K i) =
      evalPowerPolynomial T x z (K i) by
        change MvPolynomial.eval
            (evalVarQ (fun I => MvPolynomial.eval e (τ I))
              (fun j => MvPolynomial.eval e (X j)) (MvPolynomial.eval e Z)) (K i) =
          MvPolynomial.eval (evalPowerVar T x z) (K i)
        rw [hassign]]
  rw [hK x z i]
  rfl

lemma eval_zero_represents {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hK : RepresentsPowering M K)
    (x : Fin n → ℤ) (i : Fin n) :
    evalPowerPolynomial T x 0 (K i) = 0 := by
  rw [hK x 0 i]
  change (M.poweringTuple x 0 i : ℚ) = 0
  simp

lemma eval_power_represents {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hK : RepresentsPowering M K)
    (x : Fin n → ℤ) (i : Fin n) :
    evalPowerPolynomial T x 1 (K i) = (x i : ℚ) := by
  rw [hK x 1 i]
  change (M.poweringTuple x 1 i : ℚ) = (x i : ℚ)
  simp

/--
The expected coordinate tuple for
`a_j^u a_i^v = a_i^v a_j^u a_{j+1}^{R_{i,j,j+1}} ... a_n^{R_{i,j,n}}`.
-/
def conjugationCoordinateQ (T : ParameterIndex n → ℤ)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (i j : Fin n) (hij : i < j) (u v : ℤ) (k : Fin n) : ℚ :=
  if _hki : k = i then
    (v : ℚ)
  else if _hkj : k = j then
    (u : ℚ)
  else if hjk : j < k then
    evalConjPolynomial T u v (R ⟨(i, j, k), hij, hjk⟩)
  else
    0

@[simp]
lemma conjugation_q_left
    (T : ParameterIndex n → ℤ)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (i j : Fin n) (hij : i < j) (u v : ℤ) :
    conjugationCoordinateQ T R i j hij u v i = (v : ℚ) := by
  simp [conjugationCoordinateQ]

@[simp]
lemma conjugation_q_middle
    (T : ParameterIndex n → ℤ)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (i j : Fin n) (hij : i < j) (u v : ℤ) :
    conjugationCoordinateQ T R i j hij u v j = (u : ℚ) := by
  simp [conjugationCoordinateQ, ne_of_gt hij]

lemma conjugation_q_tail
    (T : ParameterIndex n → ℤ)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (i j k : Fin n) (hij : i < j) (hjk : j < k) (u v : ℤ) :
    conjugationCoordinateQ T R i j hij u v k =
      evalConjPolynomial T u v (R ⟨(i, j, k), hij, hjk⟩) := by
  simp [conjugationCoordinateQ, ne_of_gt (hij.trans hjk), ne_of_gt hjk, hjk]

lemma conjugation_q_position
    (T : ParameterIndex n → ℤ)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (i j k : Fin n) (hij : i < j)
    (hki : k ≠ i) (hkj : k ≠ j) (hjk : ¬ j < k) (u v : ℤ) :
    conjugationCoordinateQ T R i j hij u v k = 0 := by
  simp [conjugationCoordinateQ, hki, hkj, hjk]

lemma conjugation_q_last
    (T : ParameterIndex (n + 1) → ℤ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (i k : Fin (n + 1)) (hi : i < Fin.last n) (u v : ℤ) :
    conjugationCoordinateQ T R i (Fin.last n) hi u v k =
      if k = i then (v : ℚ) else if k = Fin.last n then (u : ℚ) else 0 := by
  by_cases hki : k = i
  · simp [conjugationCoordinateQ, hki]
  · by_cases hklast : k = Fin.last n
    · simp [conjugationCoordinateQ, hklast, ne_of_gt hi]
    · simp [conjugationCoordinateQ, hki, hklast, not_lt_of_ge (Fin.le_last k)]

/-- `R` represents the conjugation polynomials in the coordinate system of `M`. -/
def RepresentsConjugation {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ) : Prop :=
  ∀ (i j : Fin n) (hij : i < j) (u v : ℤ) (k : Fin n),
    (M.coord (M.gen j ^ u * M.gen i ^ v) k : ℚ) =
      conjugationCoordinateQ T R i j hij u v k

/--
For product conjugation by the last generator, the represented-conjugation
coordinate equation is unconditional and does not use the polynomial family.
-/
theorem represents_conjugation_last
    {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (i k : Fin (n + 1)) (hi : i < Fin.last n) (u v : ℤ) :
    (M.coord (M.gen (Fin.last n) ^ u * M.gen i ^ v) k : ℚ) =
      conjugationCoordinateQ T R i (Fin.last n) hi u v k := by
  change (M.conjugationTuple i (Fin.last n) u v k : ℚ) =
    conjugationCoordinateQ T R i (Fin.last n) hi u v k
  rw [M.conjugation_last i k hi u v]
  rw [conjugation_q_last]
  split_ifs <;> norm_num

/--
For product conjugation by the penultimate generator, the represented
coordinate equation is unconditional for the central-tail monomial family.
-/
theorem conjugation_penultimate_coordinate
    {T : ParameterIndex (n + 2) → ℤ}
    (M : CPres (n + 2) T)
    (i k : Fin (n + 2)) (hi : i < Fin.castSucc (Fin.last n))
    (u v : ℤ) :
    (M.coord (M.gen (Fin.castSucc (Fin.last n)) ^ u * M.gen i ^ v) k : ℚ) =
      conjugationCoordinateQ T centralTailConjugation
        i (Fin.castSucc (Fin.last n)) hi u v k := by
  let j : Fin (n + 2) := Fin.castSucc (Fin.last n)
  let last : Fin (n + 2) := Fin.last (n + 1)
  change (M.conjugationTuple i j u v k : ℚ) =
    conjugationCoordinateQ T centralTailConjugation i j hi u v k
  rw [M.conjugation_tuple_penultimate i k hi u v]
  by_cases hki : k = i
  · simp [conjugationCoordinateQ, hki]
  · by_cases hkj : k = j
    · subst k
      have hji : j ≠ i := ne_of_gt hi
      simp [conjugationCoordinateQ, hji, j]
    · by_cases hjk : j < k
      · have hklast : k = last := by
          have hjkval : n < k.val := by
            simpa [j] using hjk
          have hklt : k.val < n + 2 := k.isLt
          apply Fin.ext
          simp [last]
          omega
        subst k
        have hjlast : j < last := by simp [j, last]
        have hilast : last ≠ i := ne_of_gt (hi.trans hjlast)
        have hlastj : last ≠ j := ne_of_gt hjlast
        simp [conjugationCoordinateQ, centralTailConjugation,
          evalConjPolynomial, evalConjVar, varQ, hilast, hlastj,
          hjlast, j, last]
        ring
      · have hklast : k ≠ last := by
          intro hk
          subst k
          exact hjk (by simp [j, last])
        simp [conjugationCoordinateQ, hki, hkj, hjk, hklast, j, last]

/--
Bundled representation predicate for the three Hall-polynomial families used
in Section 3.
-/
def RepresentsHallPolynomials {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ) : Prop :=
  RepresentsMultiplication M F ∧ RepresentsPowering M K ∧ RepresentsConjugation M R

/--
Rank-zero Hall-polynomial existence.  All component specifications are empty
in length zero, so arbitrary empty polynomial families represent the
operations.
-/
theorem represents_polynomials_zero
    {T : ParameterIndex 0 → ℤ} (M : CPres 0 T) :
    ∃ (F : Fin 0 → MvPolynomial (MulVar 0) ℚ)
      (K : Fin 0 → MvPolynomial (PowerVar 0) ℚ)
      (R : ParameterIndex 0 → MvPolynomial (ConjVar 0) ℚ),
        RepresentsHallPolynomials M F K R := by
  refine
    ⟨(fun i => Fin.elim0 i), (fun i => Fin.elim0 i),
      (fun I => ?_), ?_⟩
  · rcases I with ⟨⟨i, _j, _k⟩, _hij, _hjk⟩
    exact Fin.elim0 i
  · constructor
    · intro _x _y i
      exact Fin.elim0 i
    · constructor
      · intro _x _z i
        exact Fin.elim0 i
      · intro i
        exact Fin.elim0 i

/--
Section 6 multiplication-method predicate before parameter specialization: the
polynomial family evaluates to integer normal coordinates for every input
pair.
-/
def MulEvaluationMethod {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ) : Prop :=
  ∀ x y : Fin n → ℤ,
    ∃ z : Fin n → ℤ,
      (∀ i, evalMulPolynomial T x y (F i) = (z i : ℚ)) ∧
        M.normalWord x * M.normalWord y = M.normalWord z

/--
Section 6 multiplication-method predicate after precomputing the parameters.
-/
def SpecializedMulMethod {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ) : Prop :=
  ∀ x y : Fin n → ℤ,
    ∃ z : Fin n → ℤ,
      (∀ i,
        MvPolynomial.eval (mulInputVar x y) (specializeMul T (F i)) =
          (z i : ℚ)) ∧
        M.normalWord x * M.normalWord y = M.normalWord z

/--
Powering-method analogue before parameter specialization.
-/
def PowerEvaluationMethod {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ) : Prop :=
  ∀ (x : Fin n → ℤ) (e : ℤ),
    ∃ z : Fin n → ℤ,
      (∀ i, evalPowerPolynomial T x e (K i) = (z i : ℚ)) ∧
        M.normalWord x ^ e = M.normalWord z

/--
Powering-method analogue after precomputing the parameters.
-/
def SpecializedEvaluationMethod {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ) : Prop :=
  ∀ (x : Fin n → ℤ) (e : ℤ),
    ∃ z : Fin n → ℤ,
      (∀ i,
        MvPolynomial.eval (evalInputVar x e) (specializePower T (K i)) =
          (z i : ℚ)) ∧
        M.normalWord x ^ e = M.normalWord z

/--
Section 6 multiplication method, semantic form: if a represented multiplication
family evaluates to the integer tuple `z`, then `z` is the normal coordinate
tuple of the product.
-/
theorem normal_word_polynomial
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (x y z : Fin n → ℤ)
    (hz : ∀ i, evalMulPolynomial T x y (F i) = (z i : ℚ)) :
    M.normalWord x * M.normalWord y = M.normalWord z := by
  rw [← M.normalWord_coord (M.normalWord x * M.normalWord y)]
  apply congrArg M.normalWord
  funext i
  have hcoord :
      (M.coord (M.normalWord x * M.normalWord y) i : ℚ) = (z i : ℚ) := by
    rw [← hF x y i, hz i]
  exact_mod_cast hcoord

/--
Section 6 multiplication method after parameter precomputation: evaluating the
specialized multiplication polynomials gives the normal form of the product.
-/
theorem normal_mul_specialize
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (x y z : Fin n → ℤ)
    (hz : ∀ i,
      MvPolynomial.eval (mulInputVar x y) (specializeMul T (F i)) =
        (z i : ℚ)) :
    M.normalWord x * M.normalWord y = M.normalWord z := by
  exact normal_word_polynomial M F hF x y z
    (fun i => by
      rw [← eval_specializeMul T x y (F i)]
      exact hz i)

/--
A represented multiplication family always evaluates to an integer coordinate
tuple, and that tuple is the normal form of the product.
-/
theorem int_normal_word
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (x y : Fin n → ℤ) :
    ∃ z : Fin n → ℤ,
      (∀ i, evalMulPolynomial T x y (F i) = (z i : ℚ)) ∧
        M.normalWord x * M.normalWord y = M.normalWord z := by
  refine ⟨M.multiplicationTuple x y, ?_, ?_⟩
  · intro i
    simpa [CPres.multiplicationTuple] using hF x y i
  · exact (M.normal_multiplication_tuple x y).symm

/--
After parameter precomputation, a represented multiplication family evaluates
to integer coordinates giving the normal form of the product.
-/
theorem specialize_int_normal
    {T : ParameterIndex n → ℤ}
