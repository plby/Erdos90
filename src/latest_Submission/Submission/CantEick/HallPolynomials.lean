    M F R hHall.1 hHall.2.2 j k h0j hjk

/--
Bundled Hall-polynomial form of the Bernoulli solution of Section 3.2 using
the product-derived increment polynomial from Lemma `step2`.
-/
theorem univariate_antiderivative_step
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
