      (K : Fin n → MvPolynomial (PowerVar n) ℚ)
      (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
        RepresentsHallPolynomials M F K R :=
  polynomials_conjugation_step
    (fun {m} {U} N hHallU => by
      rcases hTailStep N hHallU with ⟨R, hTail⟩
      exact ⟨R, represents_conjugation_tail N R hTail⟩)
    M

/--
Section 6 consequence of the tail-only first-generator reduction.  Once the
local Cant--Eick Step 1/Step 2 constructor supplies only polynomial tail
coordinates for `a_j^u a_0^v`, strong induction gives multiplication and
