      ∀ I u v,
        evalConjPolynomial T u v (R I) =
          evalConjPolynomial T u v (R' I) :=
  conj_u_data
    M F K R hHall
    (represents_components_polynomials
      M.deleteFirstConsistent hHallU)

/--
Identity-retaining package for the exact-premise combined lower-rank `U(T)`
display assembly.  The lower-rank `U(T)` input is split into represented
multiplication and powering, while the `step2` substitutions are supplied as
explicit product-evaluation premises.
-/
theorem display_families_eval
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hKU : RepresentsPowering M.deleteFirstConsistent K_U)
    (hZeroInit : ∀ (j i : Fin n) (hji : j < i),
      evalConjPolynomial T 1 0
        (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
          Fin.succ_lt_succ_iff.mpr hji⟩) = 0)
    (hDelta : ∀ (j i : Fin n) (hji : j < i) (v : ℤ),
      conjOnePolynomial T v
          (forwardDifferenceV R
            ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
              Fin.succ_lt_succ_iff.mpr hji⟩) =
        (M.coord (M.firstConjugatedProduct
            (M.leftConjugationTuple 0 (Fin.succ j) 1 v) 1) (Fin.succ i) : ℚ) -
          (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ i) : ℚ))
    (hCurrent : ∀ (j i : Fin n) (hji : j < i) (v : ℤ),
      evalConjPolynomial T 1 v
          (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
            Fin.succ_lt_succ_iff.mpr hji⟩) =
        (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ i) : ℚ))
    (hSubst : ∀ j v w,
      MvPolynomial.eval (conjOneVar T v)
          (conjStepSubst R (Fin.succ j) (Fin.succ_pos j) w) =
        evalMulVar T (M.leftConjugationTuple 0 (Fin.succ j) 1 v) (singleCoord 0 1) w)
    (hFactor : ∀ j v r s,
      MvPolynomial.eval
          (evalMulVar T (M.leftConjugationTuple 0 (Fin.succ j) 1 v) (singleCoord 0 1))
          (firstConjugatedPolynomial R r s) =
        (M.leftConjugationTuple 0 (Fin.succ r)
          (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ r)) 1 (Fin.succ s) : ℚ))
    (hTailZero : ∀ j v r,
      M.leftConjugationTuple 0 (Fin.succ r)
        (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ r)) 1 0 = 0) :
    ∃ (F' : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
      (K' : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
      (R' : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ),
        RepresentsHallPolynomials M F' K' R' ∧
        (∀ i, specializeMul T (F i) = specializeMul T (F' i)) ∧
        (∀ i, specializePower T (K i) = specializePower T (K' i)) ∧
        (∀ I, specializeConj T (R I) = specializeConj T (R' I)) ∧
        (∀ (x y : Fin (n + 1) → ℤ) i,
          evalMulPolynomial T x y (F i) = evalMulPolynomial T x y (F' i)) ∧
        (∀ (x : Fin (n + 1) → ℤ) (z : ℤ) i,
          evalPowerPolynomial T x z (K i) = evalPowerPolynomial T x z (K' i)) ∧
        ∀ I u v,
          evalConjPolynomial T u v (R I) = evalConjPolynomial T u v (R' I) := by
  let hClosed :=
    CPres.coordinate_closed_additive M 0 M.firstCoordinateAdditive
  have hFU0 :
      RepresentsMultiplication (M.firstConsistentPresentation hClosed.1 hClosed.2)
        F_U := by
    simpa [CPres.deleteFirstConsistent,
      CPres.firstConsistentAdditive,
      hClosed] using hFU
  refine
    ⟨displayMultiplicationFamily F_U K_U R,
      displayPoweringFamily F_U K_U K R,
      conjFamilyU F_U K_U R, ?_, ?_, ?_, ?_, ?_, ?_, ?_⟩
  · exact represents_u_families
      M K R F_U K_U hHall.2.1 hHall.2.2 hFU hKU
      hZeroInit hDelta hCurrent hSubst hFactor hTailZero
  · intro i
    exact specialize_multiplication_family
      M F R F_U K_U hHall.1 hHall.2.2 hFU hKU
      hZeroInit hDelta hCurrent hSubst hFactor hTailZero i
  · intro i
    exact specialize_display_family
      M K R F_U K_U hHall.2.1 hHall.2.2 hFU hKU
      hZeroInit hDelta hCurrent hSubst hFactor hTailZero i
  · intro I
    exact specialize_family_u
      M hClosed.1 hClosed.2 F_U K_U R hFU0 hKU hHall.2.2
      hZeroInit hDelta hCurrent hSubst hFactor hTailZero I
  · intro x y i
    exact display_multiplication_product
      M F R F_U K_U hHall.1 hHall.2.2 hFU hKU
      hZeroInit hDelta hCurrent hSubst hFactor hTailZero x y i
  · intro x z i
    exact display_powering_product
      M K R F_U K_U hHall.2.1 hHall.2.2 hFU hKU
      hZeroInit hDelta hCurrent hSubst hFactor hTailZero x z i
  · intro I u v
    exact family_u_product
      M hClosed.1 hClosed.2 F_U K_U R hFU0 hKU hHall.2.2
      hZeroInit hDelta hCurrent hSubst hFactor hTailZero I u v

