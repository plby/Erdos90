/--
Replacing all first-generator Section 3.2 conjugation coordinates by the
combined lower-rank `step1`/`step2` construction preserves ambient conjugation
representation.
-/
theorem represents_conjugation_conj
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hR : RepresentsConjugation M R) :
    RepresentsConjugation M (conjFamilyU F_U K_U R) :=
  represents_conjugation_polynomial M R
    (conjFamilyU F_U K_U R) hR
    (u_delete_first
      M F_U K_U R_U R hHallU hR)

/--
Tail-only form of the existing lower-rank Step 1/Step 2 replacement.  This
does not yet remove the ambient conjugation seed; it records that the current
Hall formalization already supplies the new tail predicate once that seed is
available.
-/
theorem represents_conjugation_u
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
