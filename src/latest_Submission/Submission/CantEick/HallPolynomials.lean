    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R) :
    RepresentsHallPolynomials M F K (conj1Family R K) :=
  ⟨hHall.1, hHall.2.1,
    represents_1_family M R K hHall.2.2 hHall.2.1⟩

/--
Bundled Hall-polynomial form of the Section 3.3 multiplication display.
-/
theorem multiplication_display_polynomials
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (x y : Fin (n + 1) → ℤ) (k : Fin (n + 1)) :
    evalMulPolynomial T x y (F k) =
      evalMulPolynomial T x y (multiplicationProductPolynomial F R k) :=
  eval_multiplication_display
    M F R hHall.1 hHall.2.2 x y k

/--
Bundled Hall-polynomial identity form of the Section 3.3 multiplication
display, after specializing the parameters to a represented presentation.
-/
theorem specialize_multiplication_display
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R) (k : Fin (n + 1)) :
    specializeMul T (F k) =
      specializeMul T (multiplicationProductPolynomial F R k) :=
  specialize_display_product
    M F R hHall.1 hHall.2.2 k

/--
Bundled Hall-polynomial form: replacing every ambient multiplication
coordinate by the Section 3.3 displayed product preserves Hall representation.
-/
theorem polynomials_display_polynomial
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R) :
    RepresentsHallPolynomials M (multiplicationProductPolynomial F R) K R :=
  ⟨represents_display_polynomial
      M F R hHall.1 hHall.2.2,
    hHall.2.1, hHall.2.2⟩

/--
Bundled Hall-polynomial form: replacing one ambient multiplication coordinate
by the Section 3.3 displayed product preserves Hall representation.
-/
theorem update_multiplication_display
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (k : Fin (n + 1)) :
    RepresentsHallPolynomials M
      (Function.update F k (multiplicationProductPolynomial F R k)) K R :=
  ⟨multiplication_update_display
      M F R hHall.1 hHall.2.2 k,
    hHall.2.1, hHall.2.2⟩

/--
Bundled Hall-polynomial identity form of the paper-style last-coordinate
powering recursion from Section 3.4.
-/
theorem specialize_recursion_polynomials
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R) :
    specializePower T (powerSuccPolynomial K (Fin.last n)) =
      specializePower T (K (Fin.last n)) +
        specializePower T (lastForwardDifference F K) :=
  specialize_last_difference
    M F K hHall.1 hHall.2.1

/--
Bundled Hall-polynomial evaluation form of the Bernoulli solution for the
last powering coordinate using the Section 3.4 paper-style increment.
-/
theorem forward_antiderivative_polynomials
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (x : Fin (n + 1) → ℤ) (z : ℤ) :
    evalPowerPolynomial T x z (K (Fin.last n)) =
      (polynomialForwardAntiderivative (0 : ℚ)
        (powerUnivariatePolynomial T x (lastForwardDifference F K))).eval
          (z : ℚ) :=
  forward_antiderivative_represents
    M F K hHall.1 hHall.2.1 x z

/--
Bundled Hall-polynomial evaluation form of the constructed generic Section
3.4 powering solution polynomial.
-/
theorem forward_solution_polynomials
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (x : Fin n → ℤ) (i : Fin n) (z : ℤ) :
    evalPowerPolynomial T x z (K i) =
      evalPowerPolynomial T x z (forwardSolutionPolynomial F K i) :=
  int_forward_solution
    M F K hHall.1 hHall.2.1 x i z

/--
Bundled Hall-polynomial evaluation form of the constructed Section 3.4
last-coordinate solution polynomial using the paper-style increment.
-/
theorem last_solution_polynomials
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (x : Fin (n + 1) → ℤ) (z : ℤ) :
    evalPowerPolynomial T x z (K (Fin.last n)) =
      evalPowerPolynomial T x z (lastSolutionPolynomial F K) :=
  last_int_solution
    M F K hHall.1 hHall.2.1 x z

/--
Bundled Hall-polynomial specialized identity for the constructed generic
Section 3.4 powering solution.
-/
theorem specialize_forward_polynomials
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hHall : RepresentsHallPolynomials M F K R) (i : Fin n) :
    specializePower T (K i) =
      specializePower T (forwardSolutionPolynomial F K i) :=
  specialize_forward_represents
    M F K hHall.1 hHall.2.1 i

/--
Bundled Hall-polynomial specialized identity for the constructed paper-style
last-coordinate Section 3.4 powering solution.
-/
theorem specialize_solution_polynomials
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R) :
    specializePower T (K (Fin.last n)) =
      specializePower T (lastSolutionPolynomial F K) :=
  specialize_last_solution
    M F K hHall.1 hHall.2.1

/--
Bundled Hall-polynomial package for the constructed generic Section 3.4
powering solution.
-/
theorem solution_represents_polynomials
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hHall : RepresentsHallPolynomials M F K R) (i : Fin n) :
    ∃ p : MvPolynomial (PowerVar n) ℚ,
      (∀ x : Fin n → ℤ,
        powerUnivariatePolynomial T x (K i) =
          powerUnivariatePolynomial T x p) ∧
      (∀ (x : Fin n → ℤ) (z : ℤ),
        evalPowerPolynomial T x z (K i) = evalPowerPolynomial T x z p) ∧
      (∀ x : Fin n → ℤ, evalPowerPolynomial T x 0 p = 0) ∧
      ∀ (x : Fin n → ℤ) (z : ℤ),
        evalPowerPolynomial T x (z + 1) p =
          evalPowerPolynomial T x z p +
            evalPowerPolynomial T x z (forwardDifferencePolynomial F K i) :=
  forward_solution_represents
    M F K hHall.1 hHall.2.1 i

/--
Bundled Hall-polynomial package for the constructed paper-style last-coordinate
Section 3.4 powering solution.
-/
theorem last_represents_polynomials
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R) :
    ∃ p : MvPolynomial (PowerVar (n + 1)) ℚ,
      (∀ x : Fin (n + 1) → ℤ,
        powerUnivariatePolynomial T x (K (Fin.last n)) =
          powerUnivariatePolynomial T x p) ∧
      (∀ (x : Fin (n + 1) → ℤ) (z : ℤ),
        evalPowerPolynomial T x z (K (Fin.last n)) =
          evalPowerPolynomial T x z p) ∧
      (∀ x : Fin (n + 1) → ℤ, evalPowerPolynomial T x 0 p = 0) ∧
      ∀ (x : Fin (n + 1) → ℤ) (z : ℤ),
        evalPowerPolynomial T x (z + 1) p =
          evalPowerPolynomial T x z p +
            evalPowerPolynomial T x z (lastForwardDifference F K) :=
  power_solution_represents
    M F K hHall.1 hHall.2.1

/--
Bundled Hall-polynomial form: replacing every powering coordinate by its
constructed generic Section 3.4 solution preserves the Hall representation.
-/
theorem polynomials_forward_solution
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hHall : RepresentsHallPolynomials M F K R) :
    RepresentsHallPolynomials M F
      (fun i => forwardSolutionPolynomial F K i) R :=
  ⟨hHall.1,
    represents_forward_solution M F K hHall.1 hHall.2.1,
    hHall.2.2⟩

/--
Bundled Hall-polynomial form: replacing one powering coordinate by its
constructed generic Section 3.4 solution preserves the Hall representation.
-/
theorem polynomials_update_solution
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (i : Fin n) :
    RepresentsHallPolynomials M F
      (Function.update K i (forwardSolutionPolynomial F K i)) R :=
  ⟨hHall.1,
    represents_powering_update
      M F K hHall.1 hHall.2.1 i,
    hHall.2.2⟩

/--
Bundled Hall-polynomial form: replacing the last powering coordinate by the
paper-style constructed Section 3.4 solution preserves the Hall representation.
-/
theorem represents_update_solution
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R) :
    RepresentsHallPolynomials M F
      (Function.update K (Fin.last n) (lastSolutionPolynomial F K)) R :=
  ⟨hHall.1,
    powering_update_solution
      M F K hHall.1 hHall.2.1,
    hHall.2.2⟩

/--
Bundled Hall-polynomial form: replacing every powering coordinate by a
constructed Section 3.4 solution, with the last coordinate using the
paper-style increment, preserves the Hall representation.
-/
theorem polynomials_update_last
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R) :
    RepresentsHallPolynomials M F
      (Function.update (fun i => forwardSolutionPolynomial F K i)
        (Fin.last n) (lastSolutionPolynomial F K)) R :=
  ⟨hHall.1,
    forward_update_last
      M F K hHall.1 hHall.2.1,
    hHall.2.2⟩

/--
The represented powering family and the Section 3.4 family-level constructed
powering replacement have the same integer evaluations.
-/
theorem solution_update_polynomials
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (x : Fin (n + 1) → ℤ) (z : ℤ) (i : Fin (n + 1)) :
    evalPowerPolynomial T x z (K i) =
      evalPowerPolynomial T x z
        ((Function.update (fun i => forwardSolutionPolynomial F K i)
          (Fin.last n) (lastSolutionPolynomial F K)) i) := by
  by_cases hi : i = Fin.last n
  · subst i
    rw [Function.update_self]
    exact last_int_solution
      M F K hHall.1 hHall.2.1 x z
  · rw [Function.update_of_ne hi]
    exact int_forward_solution
      M F K hHall.1 hHall.2.1 x i z

/--
Specialized polynomial identity for the Section 3.4 family-level constructed
powering replacement.
-/
theorem specialize_update_polynomials
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R) (i : Fin (n + 1)) :
    specializePower T (K i) =
      specializePower T
        ((Function.update (fun i => forwardSolutionPolynomial F K i)
          (Fin.last n) (lastSolutionPolynomial F K)) i) :=
  specialize_power_eval (K i)
    ((Function.update (fun i => forwardSolutionPolynomial F K i)
      (Fin.last n) (lastSolutionPolynomial F K)) i)
    (fun x z =>
      solution_update_polynomials
        M F K R hHall x z i)

/--
Existential package for the family-level Section 3.4 powering replacement:
the constructed family preserves Hall representation and remains
parameter-specialized/evaluation-equal to the original represented powering
family.
-/
theorem forward_update_polynomials
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R) :
    ∃ K' : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ,
      RepresentsHallPolynomials M F K' R ∧
      (∀ i, specializePower T (K i) = specializePower T (K' i)) ∧
      ∀ (x : Fin (n + 1) → ℤ) (z : ℤ) (i : Fin (n + 1)),
        evalPowerPolynomial T x z (K i) = evalPowerPolynomial T x z (K' i) := by
  refine
    ⟨Function.update (fun i => forwardSolutionPolynomial F K i)
      (Fin.last n) (lastSolutionPolynomial F K), ?_, ?_, ?_⟩
  · exact polynomials_update_last
      M F K R hHall
  · intro i
    exact specialize_update_polynomials
      M F K R hHall i
  · intro x z i
    exact solution_update_polynomials
      M F K R hHall x z i

/--
Powering family obtained by lifting the quotient `W(T)` powering coordinates
for all non-last coordinates, then constructing the last coordinate by the
Section 3.4 paper-style Bernoulli solution.
-/
def deleteLastSolution {n : ℕ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (K_seed : MvPolynomial (PowerVar (n + 1)) ℚ) :
    Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ :=
  let K0 := deletePoweringFamily K_W K_seed
  deletePoweringFamily K_W (lastSolutionPolynomial F K0)

lemma delete_solution_update {n : ℕ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (K_seed : MvPolynomial (PowerVar (n + 1)) ℚ) :
    deleteLastSolution F K_W K_seed =
      Function.update (deletePoweringFamily K_W K_seed) (Fin.last n)
        (lastSolutionPolynomial F (deletePoweringFamily K_W K_seed)) := by
  funext i
  cases i using Fin.lastCases with
  | last =>
      simp [deleteLastSolution, deletePoweringFamily]
  | cast i =>
      simp [deleteLastSolution, deletePoweringFamily]

/--
If quotient `W(T)` powering is represented and the seed polynomial represents
the ambient last powering coordinate, the quotient-lifted family with the
constructed last-coordinate solution represents ambient powering.
-/
theorem powering_delete_solution
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (F_W : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_W : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (K_seed : MvPolynomial (PowerVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hHallW :
      RepresentsHallPolynomials M.deleteConsistentPresentation F_W K_W R_W)
    (hLast : ∀ x z,
      evalPowerPolynomial T x z K_seed =
        (M.poweringTuple x z (Fin.last n) : ℚ)) :
    RepresentsPowering M
      (deleteLastSolution F K_W K_seed) := by
  let K0 := deletePoweringFamily K_W K_seed
  have hK0 : RepresentsPowering M K0 := by
    simpa [K0] using
      represents_powering_delete
        M F_W K_W R_W K_seed hHallW hLast
  have hUpdate :
      RepresentsPowering M
        (Function.update K0 (Fin.last n) (lastSolutionPolynomial F K0)) :=
    powering_update_solution M F K0 hF hK0
  simpa [delete_solution_update, K0] using hUpdate

/--
Split version of `powering_delete_solution`:
the quotient side only needs represented powering.
-/
theorem represents_powering_solution
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (K_seed : MvPolynomial (PowerVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hKW : RepresentsPowering M.deleteConsistentPresentation K_W)
    (hLast : ∀ x z,
      evalPowerPolynomial T x z K_seed =
        (M.poweringTuple x z (Fin.last n) : ℚ)) :
    RepresentsPowering M
      (deleteLastSolution F K_W K_seed) := by
  let K0 := deletePoweringFamily K_W K_seed
  have hK0 : RepresentsPowering M K0 := by
    simpa [K0] using
      powering_last_family M K_W K_seed hKW hLast
  have hUpdate :
      RepresentsPowering M
        (Function.update K0 (Fin.last n) (lastSolutionPolynomial F K0)) :=
    powering_update_solution M F K0 hF hK0
  simpa [delete_solution_update, K0] using hUpdate

/--
Version of
`powering_delete_solution` seeded by an
already represented ambient powering family.
-/
theorem powering_last_solution
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (F_W : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_W : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (hHallW :
      RepresentsHallPolynomials M.deleteConsistentPresentation F_W K_W R_W) :
    RepresentsPowering M
      (deleteLastSolution F K_W (K (Fin.last n))) :=
  powering_delete_solution
    M F F_W K_W R_W (K (Fin.last n)) hF hHallW
    (fun x z => hK x z (Fin.last n))

/--
Split version of
`powering_last_solution`.
-/
theorem represents_last_solution
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (hKW : RepresentsPowering M.deleteConsistentPresentation K_W) :
    RepresentsPowering M
      (deleteLastSolution F K_W (K (Fin.last n))) :=
  represents_powering_solution
    M F K_W (K (Fin.last n)) hF hKW
    (fun x z => hK x z (Fin.last n))

/--
Bundled Hall-polynomial form of the quotient-lifted powering family with the
constructed Section 3.4 last coordinate.
-/
theorem polynomials_delete_solution
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (F_W : Fin n → MvPolynomial (MulVar n) ℚ)
