The first-generator `step1`/`step2` part only needs delete-first
multiplication and powering, while the successor-tail lift needs delete-first
conjugation.
-/
theorem delete_u_data
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hKU : RepresentsPowering M.deleteFirstConsistent K_U)
    (hR_U : RepresentsConjugation M.deleteFirstConsistent R_U)
    (hR : RepresentsConjugation M R)
    (I : ParameterIndex (n + 1)) (u v : ℤ) :
    evalConjPolynomial T u v (R I) =
      evalConjPolynomial T u v
        (conj1U F_U K_U R_U R I) := by
  let Rstep := conjFamilyU F_U K_U R
  have hstep :
      evalConjPolynomial T u v (R I) =
        evalConjPolynomial T u v (Rstep I) :=
    u_delete_powering
      M F_U K_U R hFU hKU hR I u v
  have hRstep : RepresentsConjugation M Rstep :=
    represents_u_powering
      M F_U K_U R hFU hKU hR
  have htail :
      evalConjPolynomial T u v (Rstep I) =
        evalConjPolynomial T u v (deleteConjFamily R_U Rstep I) :=
    delete_family_represents
      M R_U Rstep hR_U hRstep I u v
  simpa [conj1U, Rstep] using hstep.trans htail

/--
Specialized polynomial identity for the split lower-rank-data delete-first
conjugation lift.
-/
theorem specialize_u_data
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hKU : RepresentsPowering M.deleteFirstConsistent K_U)
    (hR_U : RepresentsConjugation M.deleteFirstConsistent R_U)
    (hR : RepresentsConjugation M R)
    (I : ParameterIndex (n + 1)) :
    specializeConj T (R I) =
      specializeConj T (conj1U F_U K_U R_U R I) :=
  specialize_conj_eval (R I)
    (conj1U F_U K_U R_U R I)
    (fun u v =>
      delete_u_data
        M F_U K_U R_U R hFU hKU hR_U hR I u v)

/--
The split lower-rank data suffices to make the combined delete-first
conjugation lift represent ambient conjugation.
-/
theorem represents_conjugation_data
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hKU : RepresentsPowering M.deleteFirstConsistent K_U)
    (hR_U : RepresentsConjugation M.deleteFirstConsistent R_U)
    (hR : RepresentsConjugation M R) :
    RepresentsConjugation M (conj1U F_U K_U R_U R) :=
  represents_conjugation_polynomial M R
    (conj1U F_U K_U R_U R) hR
    (delete_u_data
      M F_U K_U R_U R hFU hKU hR_U hR)

/--
Bundled replacement form of the split lower-rank-data delete-first
conjugation lift.
-/
theorem represents_polynomials_data
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hKU : RepresentsPowering M.deleteFirstConsistent K_U)
    (hR_U : RepresentsConjugation M.deleteFirstConsistent R_U) :
    RepresentsHallPolynomials M F K
      (conj1U F_U K_U R_U R) :=
  ⟨hHall.1, hHall.2.1,
    represents_conjugation_data
