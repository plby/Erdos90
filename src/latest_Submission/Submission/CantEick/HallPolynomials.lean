/--
Constructed-polynomial lower-rank `U(T)` form of Section 3.2 Lemma `step2`.
The right-hand side is a single polynomial in the parameters and `v`, not a
new antiderivative recomputed after parameter specialization.
-/
theorem univariate_step_u
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hR : RepresentsConjugation M R)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k) :
    conjUnivariatePolynomial T
        (conjUPolynomial (R ⟨(0, j, Fin.succ k), h0j, hjk⟩)) =
      conjUnivariatePolynomial T
        (conjSolutionU F_U R j h0j k hjk) := by
  rw [conjSolutionU, univariate_antiderivative_polynomial]
  exact univariate_2_u
    M F_U R hFU hR j k h0j hjk

/--
Split constructed-polynomial lower-rank `U(T)` form of Section 3.2 step2:
only delete-first multiplication is needed.
-/
theorem univariate_solution_u
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hR : RepresentsConjugation M R)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k) :
    conjUnivariatePolynomial T
