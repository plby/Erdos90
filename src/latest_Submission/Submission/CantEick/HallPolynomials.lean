/--
Constructed-polynomial form of the exact-premise lower-rank `U(T)` Section 3.2
step-2 solution.
-/
theorem conj_univariate_u
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hMul : ∀ a b : M.G,
      M.coord a 0 = 0 → M.coord b 0 = 0 → M.coord (a * b) 0 = 0)
    (hInv : ∀ a : M.G, M.coord a 0 = 0 → M.coord a⁻¹ 0 = 0)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication
      (M.firstConsistentPresentation hMul hInv) F_U)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k)
    (hZeroInit : evalConjPolynomial T 1 0
      (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) = 0)
    (hDelta : ∀ v : ℤ,
      conjOnePolynomial T v
          (forwardDifferenceV R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
        (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1)
            (Fin.succ k) : ℚ) -
          (M.leftConjugationTuple 0 j 1 v (Fin.succ k) : ℚ))
    (hCurrent : ∀ v : ℤ,
      evalConjPolynomial T 1 v (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
        (M.leftConjugationTuple 0 j 1 v (Fin.succ k) : ℚ))
    (hSubst : ∀ v w,
      MvPolynomial.eval (conjOneVar T v) (conjStepSubst R j h0j w) =
        evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1) w)
    (hFactor : ∀ v i k,
      MvPolynomial.eval
          (evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1))
          (firstConjugatedPolynomial R i k) =
        (M.leftConjugationTuple 0 (Fin.succ i)
          (M.leftConjugationTuple 0 j 1 v (Fin.succ i)) 1 (Fin.succ k) : ℚ))
    (hTailZero : ∀ v i,
      M.leftConjugationTuple 0 (Fin.succ i)
        (M.leftConjugationTuple 0 j 1 v (Fin.succ i)) 1 0 = 0) :
    conjUnivariatePolynomial T
        (conjUPolynomial (R ⟨(0, j, Fin.succ k), h0j, hjk⟩)) =
      conjUnivariatePolynomial T
        (conjSolutionU F_U R j h0j k hjk) := by
  rw [conjSolutionU, univariate_antiderivative_polynomial]
  exact univariate_antiderivative_2
    M hMul hInv F_U R hFU j k h0j hjk hZeroInit hDelta hCurrent hSubst hFactor hTailZero

