/--
Section 4 obstruction package obtained from any existential represented Hall
bundle.  This packages the standard consequences of `RepresentsHallPolynomials`
without requiring callers to destruct the Hall family themselves.
-/
theorem obstruction_package_polynomials
    {n : ℕ} {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (hHall :
      ∃ (F : Fin n → MvPolynomial (MulVar n) ℚ)
        (K : Fin n → MvPolynomial (PowerVar n) ℚ)
        (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
          RepresentsHallPolynomials M F K R) :
    ∃ (F : Fin n → MvPolynomial (MulVar n) ℚ)
      (K : Fin n → MvPolynomial (PowerVar n) ℚ)
      (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
        RepresentsHallPolynomials M F K R ∧
        consistencyObstructionLocus F T ∧
        consistencyObstructionIdeal F ≤ vanishingIdealAt T ∧
        (∀ {p r : MvPolynomial (ParameterIndex n) ℚ},
          p - r ∈ consistencyObstructionIdeal F →
            parameterEvaluation T r = parameterEvaluation T p) ∧
        (∀ {p r : MvPolynomial (MulVar n) ℚ},
          coefficientwiseSubMem (consistencyObstructionIdeal F)
            (mulInputPolynomial p) (mulInputPolynomial r) →
            specializeMul T r = specializeMul T p) ∧
        (∀ {p r : MvPolynomial (MulVar n) ℚ},
          coefficientwiseSubMem (consistencyObstructionIdeal F)
            (mulInputPolynomial p) (mulInputPolynomial r) →
            ∀ x y, evalMulPolynomial T x y r = evalMulPolynomial T x y p) ∧
        (∀ {p r : MvPolynomial (PowerVar n) ℚ},
          coefficientwiseSubMem (consistencyObstructionIdeal F)
            (powerInputPolynomial p) (powerInputPolynomial r) →
            specializePower T r = specializePower T p) ∧
        ∀ {p r : MvPolynomial (PowerVar n) ℚ},
          coefficientwiseSubMem (consistencyObstructionIdeal F)
            (powerInputPolynomial p) (powerInputPolynomial r) →
          ∀ x z, evalPowerPolynomial T x z r =
            evalPowerPolynomial T x z p := by
  rcases hHall with ⟨F, K, R, hHall⟩
  refine
    ⟨F, K, R, hHall, ?_, ?_, ?_, ?_, ?_, ?_, ?_⟩
  · exact consistency_locus_polynomials
      M F K R hHall
  · exact
      consistency_vanishing_polynomials
        M F K R hHall
  · intro p r h
    exact
      remainder_obstruction_polynomials
        M F K R hHall h
  · intro p r h
    exact
      specialize_remainder_consistency
        M F K R hHall h
  · intro p r h x y
    exact
      remainder_coeff_polynomials
        M F K R hHall h x y
  · intro p r h
    exact
      specialize_remainder_polynomials
        M F K R hHall h
  · intro p r h x z
    exact
      remainder_consistency_polynomials
        M F K R hHall h x z

/--
Section 4 obstruction package obtained from the successor-rank conjugation
reduction.  The produced Hall multiplication family has vanishing obstruction
coefficients at the current parameter tuple, and all parameter, multiplication,
and powering remainders modulo its obstruction ideal evaluate unchanged.
-/
theorem package_successor_conjugation
    (hConj :
      ∀ {m : ℕ} {U : ParameterIndex (m + 1) → ℤ}
        (N : CPres (m + 1) U),
          ∃ R : ParameterIndex (m + 1) → MvPolynomial (ConjVar (m + 1)) ℚ,
            RepresentsConjugation N R)
    {n : ℕ} {T : ParameterIndex n → ℤ}
    (M : CPres n T) :
    ∃ (F : Fin n → MvPolynomial (MulVar n) ℚ)
      (K : Fin n → MvPolynomial (PowerVar n) ℚ)
      (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
        RepresentsHallPolynomials M F K R ∧
        consistencyObstructionLocus F T ∧
        consistencyObstructionIdeal F ≤ vanishingIdealAt T ∧
        (∀ {p r : MvPolynomial (ParameterIndex n) ℚ},
          p - r ∈ consistencyObstructionIdeal F →
            parameterEvaluation T r = parameterEvaluation T p) ∧
        (∀ {p r : MvPolynomial (MulVar n) ℚ},
          coefficientwiseSubMem (consistencyObstructionIdeal F)
            (mulInputPolynomial p) (mulInputPolynomial r) →
            specializeMul T r = specializeMul T p) ∧
        (∀ {p r : MvPolynomial (MulVar n) ℚ},
          coefficientwiseSubMem (consistencyObstructionIdeal F)
            (mulInputPolynomial p) (mulInputPolynomial r) →
            ∀ x y, evalMulPolynomial T x y r = evalMulPolynomial T x y p) ∧
        (∀ {p r : MvPolynomial (PowerVar n) ℚ},
          coefficientwiseSubMem (consistencyObstructionIdeal F)
            (powerInputPolynomial p) (powerInputPolynomial r) →
            specializePower T r = specializePower T p) ∧
        ∀ {p r : MvPolynomial (PowerVar n) ℚ},
          coefficientwiseSubMem (consistencyObstructionIdeal F)
            (powerInputPolynomial p) (powerInputPolynomial r) →
          ∀ x z, evalPowerPolynomial T x z r =
            evalPowerPolynomial T x z p := by
  rcases polynomials_successor_conjugation hConj M with
    ⟨F, K, R, hHall⟩
  refine
    ⟨F, K, R, hHall, ?_, ?_, ?_, ?_, ?_, ?_, ?_⟩
  · exact consistency_locus_polynomials
      M F K R hHall
  · exact
      consistency_vanishing_polynomials
        M F K R hHall
  · intro p r h
    exact
      remainder_obstruction_polynomials
        M F K R hHall h
  · intro p r h
    exact
      specialize_remainder_consistency
        M F K R hHall h
  · intro p r h x y
    exact
      remainder_coeff_polynomials
        M F K R hHall h x y
  · intro p r h
    exact
      specialize_remainder_polynomials
        M F K R hHall h
  · intro p r h x z
    exact
      remainder_consistency_polynomials
        M F K R hHall h x z

/--
Compatibility form of the Section 4 obstruction package using a represented
conjugation family in every rank.
-/
theorem package_global_conjugation
    (hConj :
      ∀ {m : ℕ} {U : ParameterIndex m → ℤ}
        (N : CPres m U),
          ∃ R : ParameterIndex m → MvPolynomial (ConjVar m) ℚ,
            RepresentsConjugation N R)
    {n : ℕ} {T : ParameterIndex n → ℤ}
    (M : CPres n T) :
    ∃ (F : Fin n → MvPolynomial (MulVar n) ℚ)
      (K : Fin n → MvPolynomial (PowerVar n) ℚ)
      (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
        RepresentsHallPolynomials M F K R ∧
        consistencyObstructionLocus F T ∧
        consistencyObstructionIdeal F ≤ vanishingIdealAt T ∧
        (∀ {p r : MvPolynomial (ParameterIndex n) ℚ},
          p - r ∈ consistencyObstructionIdeal F →
            parameterEvaluation T r = parameterEvaluation T p) ∧
        (∀ {p r : MvPolynomial (MulVar n) ℚ},
          coefficientwiseSubMem (consistencyObstructionIdeal F)
            (mulInputPolynomial p) (mulInputPolynomial r) →
            specializeMul T r = specializeMul T p) ∧
        (∀ {p r : MvPolynomial (MulVar n) ℚ},
          coefficientwiseSubMem (consistencyObstructionIdeal F)
            (mulInputPolynomial p) (mulInputPolynomial r) →
            ∀ x y, evalMulPolynomial T x y r = evalMulPolynomial T x y p) ∧
        (∀ {p r : MvPolynomial (PowerVar n) ℚ},
          coefficientwiseSubMem (consistencyObstructionIdeal F)
            (powerInputPolynomial p) (powerInputPolynomial r) →
            specializePower T r = specializePower T p) ∧
        ∀ {p r : MvPolynomial (PowerVar n) ℚ},
          coefficientwiseSubMem (consistencyObstructionIdeal F)
            (powerInputPolynomial p) (powerInputPolynomial r) →
          ∀ x z, evalPowerPolynomial T x z r =
            evalPowerPolynomial T x z p :=
