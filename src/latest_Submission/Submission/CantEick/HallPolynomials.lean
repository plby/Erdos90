    (fun N => hConj N) M

/--
Induction-hypothesis-shaped combined `U(T)`/`W(T)` local assembly.  This
version asks for lower-rank Hall-polynomial existence for both subquotients,
represented ambient conjugation, and a single last-coordinate powering seed,
but no represented ambient multiplication or full powering family.
-/
theorem represents_polynomials_uw
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (K_seed : MvPolynomial (PowerVar (n + 1)) ℚ)
    (hHallU :
      ∃ (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
        (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
        (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
          RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hHallW :
      ∃ (F_W : Fin n → MvPolynomial (MulVar n) ℚ)
        (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
        (R_W : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
          RepresentsHallPolynomials M.deleteConsistentPresentation
            F_W K_W R_W)
    (hR : RepresentsConjugation M R)
    (hLast : ∀ x z,
      evalPowerPolynomial T x z K_seed =
        (M.poweringTuple x z (Fin.last n) : ℚ)) :
    ∃ (F' : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
      (K' : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
      (R' : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ),
        RepresentsHallPolynomials M F' K' R' := by
  rcases hHallU with ⟨F_U, K_U, R_U, hHallU⟩
  rcases hHallW with ⟨F_W, K_W, R_W, hHallW⟩
  exact
    ⟨displayMultiplicationFamily F_U K_U R,
      uwPoweringFamily F_U K_U R K_W K_seed,
      conjFamilyU F_U K_U R,
      polynomials_delete_last
        M R F_U K_U R_U F_W K_W R_W K_seed hR hHallU hHallW hLast⟩

/--
Induction-hypothesis-shaped combined `U(T)`/`W(T)` local assembly with a
single last-coordinate seed and only represented quotient powering.
-/
theorem represents_polynomials_w
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
