    (hK : RepresentsPowering M K)
    (hR : RepresentsConjugation M R) :
    ∃ (F' : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
      (K' : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
      (R' : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ),
        RepresentsHallPolynomials M F' K' R' := by
  rcases hHallU with ⟨F_U, K_U, R_U, hHallU⟩
  exact
    ⟨displayMultiplicationFamily F_U K_U R,
      displayPoweringFamily F_U K_U K R,
      conjFamilyU F_U K_U R,
      represents_families_first
        M K R F_U K_U R_U hK hR hHallU⟩

