/--
Family-level exact-premise form of the combined lower-rank Section 3.2
construction, with the forward-difference delta and tail-zero premises
discharged semantically.
-/
theorem family_no_delta
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hMul : ∀ a b : M.G,
      M.coord a 0 = 0 → M.coord b 0 = 0 → M.coord (a * b) 0 = 0)
