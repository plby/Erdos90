    RepresentsHallPolynomials M
      (displayMultiplicationFamily F_U K_U R)
      (uwPoweringFamily F_U K_U R K_W K_seed)
      (conjFamilyU F_U K_U R) :=
  represents_1_w
    M R F_U K_U K_W K_seed hR hFU hKU hKW hLast hZeroInit
    (fun j i hji v =>
      forward_conjugated_current
        M R j i hji v (hCurrent j i hji))
    hCurrent hSubst hFactor
    (conjugation_tuple_step M)

/--
