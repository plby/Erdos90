/--
Combined lower-rank `U(T)`/`W(T)` assembly theorem.  Lower-rank Hall data for
`U(T)` builds the conjugation and multiplication families; lower-rank Hall
data for `W(T)` supplies all non-last powering coordinates; and a single
last-coordinate seed is replaced by the constructed Section 3.4 solution.
This removes the represented ambient multiplication and powering hypotheses
from the local combined assembly.
-/
theorem polynomials_delete_last
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (F_W : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_W : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (K_seed : MvPolynomial (PowerVar (n + 1)) ℚ)
    (hR : RepresentsConjugation M R)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hHallW :
      RepresentsHallPolynomials M.deleteConsistentPresentation F_W K_W R_W)
    (hLast : ∀ x z,
      evalPowerPolynomial T x z K_seed =
        (M.poweringTuple x z (Fin.last n) : ℚ)) :
    RepresentsHallPolynomials M
      (displayMultiplicationFamily F_U K_U R)
      (uwPoweringFamily F_U K_U R K_W K_seed)
      (conjFamilyU F_U K_U R) := by
  let R' := conjFamilyU F_U K_U R
  let F' := displayMultiplicationFamily F_U K_U R
  have hR' : RepresentsConjugation M R' :=
    represents_conjugation_conj
      M F_U K_U R_U R hHallU hR
  have hF' : RepresentsMultiplication M F' := by
    simpa [F', R', displayMultiplicationFamily] using
      represents_display_u
        M F_U R' hHallU.1 hR'
  have hK' :
      RepresentsPowering M
        (uwPoweringFamily F_U K_U R K_W K_seed) := by
    simpa [uwPoweringFamily, F'] using
      powering_delete_solution
        M F' F_W K_W R_W K_seed hF' hHallW hLast
  exact ⟨hF', hK', hR'⟩

