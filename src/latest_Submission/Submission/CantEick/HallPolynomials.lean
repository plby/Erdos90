/--
Combined lower-rank `U(T)` conjugation family: first-generator coordinates are
supplied by the Section 3.2 `step1`/`step2` construction, while all successor
tail coordinates are supplied by the delete-first conjugation lift.
-/
noncomputable def conj1U {n : ℕ}
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ) :
    ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ :=
  deleteConjFamily R_U (conjFamilyU F_U K_U R)

theorem delete_first_u
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hR : RepresentsConjugation M R)
    (I : ParameterIndex (n + 1)) (u v : ℤ) :
    evalConjPolynomial T u v (R I) =
      evalConjPolynomial T u v
        (conj1U F_U K_U R_U R I) := by
  let Rstep := conjFamilyU F_U K_U R
  have hstep :
      evalConjPolynomial T u v (R I) =
        evalConjPolynomial T u v (Rstep I) :=
    u_delete_first
      M F_U K_U R_U R hHallU hR I u v
  have hRstep : RepresentsConjugation M Rstep :=
    represents_conjugation_conj
      M F_U K_U R_U R hHallU hR
  have htail :
      evalConjPolynomial T u v (Rstep I) =
        evalConjPolynomial T u v (deleteConjFamily R_U Rstep I) :=
    delete_family_represents
      M R_U Rstep hHallU.2.2 hRstep I u v
  simpa [conj1U, Rstep] using hstep.trans htail

