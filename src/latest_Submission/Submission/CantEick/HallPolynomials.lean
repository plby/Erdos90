          ∃ R : ParameterIndex (m + 1) →
              MvPolynomial (ConjVar (m + 1)) ℚ,
            RepresentsTailConjugation N R)
    {n : ℕ} {T : ParameterIndex n → ℤ}
    (M : CPres n T) :
