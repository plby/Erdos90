/--
Global Hall-polynomial induction, reduced to the remaining positive-rank
ambient conjugation input.  If every already-consistent successor-rank
presentation admits represented conjugation polynomials, then the seed-free
`U(T)`/`W(T)` assembly builds represented multiplication, powering, and
conjugation families in every rank.
-/
theorem polynomials_successor_conjugation
    (hConj :
      ∀ {m : ℕ} {U : ParameterIndex (m + 1) → ℤ}
        (N : CPres (m + 1) U),
          ∃ R : ParameterIndex (m + 1) → MvPolynomial (ConjVar (m + 1)) ℚ,
            RepresentsConjugation N R)
    {n : ℕ} {T : ParameterIndex n → ℤ}
    (M : CPres n T) :
    ∃ (F : Fin n → MvPolynomial (MulVar n) ℚ)
      (K : Fin n → MvPolynomial (PowerVar n) ℚ)
      (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
        RepresentsHallPolynomials M F K R := by
  revert T
  induction n using Nat.strong_induction_on with
  | h n ih =>
      intro T M
      cases n with
      | zero =>
          exact represents_polynomials_zero M
      | succ n =>
          rcases hConj M with ⟨R, hR⟩
          have hHallU :
              ∃ (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
                (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
                (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
                  RepresentsHallPolynomials M.deleteFirstConsistent
                    F_U K_U R_U :=
            ih n (Nat.lt_succ_self n) M.deleteFirstConsistent
          have hHallW :
              ∃ (F_W : Fin n → MvPolynomial (MulVar n) ℚ)
                (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
                (R_W : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
                  RepresentsHallPolynomials M.deleteConsistentPresentation
                    F_W K_W R_W :=
            ih n (Nat.lt_succ_self n) M.deleteConsistentPresentation
          exact
            uw_solution_delete
              M R hHallU hHallW hR

/--
Sharper global Hall-polynomial induction, reduced to the local Cant--Eick
conjugation step.  The remaining constructor only has to build ambient
conjugation polynomials for a successor-rank presentation from Hall
polynomials on the canonical delete-first presentation `U(T)`.  The
delete-last quotient `W(T)` is still produced by the induction hypothesis, but
it is only used by the subsequent U/W Hall assembly for powering.
-/
theorem represents_conjugation_step
    (hConjStep :
      ∀ {m : ℕ} {U : ParameterIndex (m + 1) → ℤ}
        (N : CPres (m + 1) U),
          (∃ (F_U : Fin m → MvPolynomial (MulVar m) ℚ)
            (K_U : Fin m → MvPolynomial (PowerVar m) ℚ)
            (R_U : ParameterIndex m → MvPolynomial (ConjVar m) ℚ),
              RepresentsHallPolynomials N.deleteFirstConsistent
                F_U K_U R_U) →
          ∃ R : ParameterIndex (m + 1) →
              MvPolynomial (ConjVar (m + 1)) ℚ,
            RepresentsConjugation N R)
    {n : ℕ} {T : ParameterIndex n → ℤ}
    (M : CPres n T) :
    ∃ (F : Fin n → MvPolynomial (MulVar n) ℚ)
      (K : Fin n → MvPolynomial (PowerVar n) ℚ)
      (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
        RepresentsHallPolynomials M F K R := by
  revert T
  induction n using Nat.strong_induction_on with
  | h n ih =>
      intro T M
      cases n with
      | zero =>
          exact represents_polynomials_zero M
      | succ n =>
          have hHallU :
              ∃ (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
                (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
                (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
                  RepresentsHallPolynomials M.deleteFirstConsistent
                    F_U K_U R_U :=
            ih n (Nat.lt_succ_self n) M.deleteFirstConsistent
          have hHallW :
              ∃ (F_W : Fin n → MvPolynomial (MulVar n) ℚ)
                (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
                (R_W : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
                  RepresentsHallPolynomials
                    M.deleteConsistentPresentation F_W K_W R_W :=
            ih n (Nat.lt_succ_self n) M.deleteConsistentPresentation
          rcases hConjStep M hHallU with ⟨R, hR⟩
          exact
            uw_solution_delete
              M R hHallU hHallW hR

/--
Section 6 consequence of the sharper delete-first conjugation-step reduction.
Once the local constructor supplies ambient conjugation from `U(T)` Hall data,
the same strong induction provides multiplication and powering methods in
every consistent presentation.
-/
theorem operation_methods_delete
    (hConjStep :
      ∀ {m : ℕ} {U : ParameterIndex (m + 1) → ℤ}
        (N : CPres (m + 1) U),
          (∃ (F_U : Fin m → MvPolynomial (MulVar m) ℚ)
            (K_U : Fin m → MvPolynomial (PowerVar m) ℚ)
            (R_U : ParameterIndex m → MvPolynomial (ConjVar m) ℚ),
              RepresentsHallPolynomials N.deleteFirstConsistent
                F_U K_U R_U) →
          ∃ R : ParameterIndex (m + 1) →
              MvPolynomial (ConjVar (m + 1)) ℚ,
            RepresentsConjugation N R)
    {n : ℕ} {T : ParameterIndex n → ℤ}
    (M : CPres n T) :
    ∃ (F : Fin n → MvPolynomial (MulVar n) ℚ)
      (K : Fin n → MvPolynomial (PowerVar n) ℚ),
        MulEvaluationMethod M F ∧
        SpecializedMulMethod M F ∧
        PowerEvaluationMethod M K ∧
        SpecializedEvaluationMethod M K :=
  operation_methods_polynomials M
    (represents_conjugation_step
      hConjStep M)

/--
Sharper global Hall-polynomial induction reduced to first-generator
conjugation.  The delete-first presentation supplies all successor-indexed
conjugation coordinates; the local constructor only has to build the
conjugation equations whose lower generator is `0`.
-/
theorem polynomials_conjugation_step
    (hFirstStep :
      ∀ {m : ℕ} {U : ParameterIndex (m + 1) → ℤ}
        (N : CPres (m + 1) U),
          (∃ (F_U : Fin m → MvPolynomial (MulVar m) ℚ)
            (K_U : Fin m → MvPolynomial (PowerVar m) ℚ)
            (R_U : ParameterIndex m → MvPolynomial (ConjVar m) ℚ),
              RepresentsHallPolynomials N.deleteFirstConsistent
                F_U K_U R_U) →
          ∃ R : ParameterIndex (m + 1) →
              MvPolynomial (ConjVar (m + 1)) ℚ,
            RepresentsFirstConjugation N R)
    {n : ℕ} {T : ParameterIndex n → ℤ}
    (M : CPres n T) :
    ∃ (F : Fin n → MvPolynomial (MulVar n) ℚ)
      (K : Fin n → MvPolynomial (PowerVar n) ℚ)
      (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
        RepresentsHallPolynomials M F K R :=
  represents_conjugation_step
    (fun {m} {U} N hHallU => by
      rcases hHallU with ⟨F_U, K_U, R_U, hHallU⟩
      exact
        conjugation_first_delete
          N R_U hHallU.2.2
          (hFirstStep N ⟨F_U, K_U, R_U, hHallU⟩))
    M

/--
Section 6 consequence of the first-generator conjugation-step reduction.
Once the local Cant--Eick Step 1/Step 2 constructor supplies only the
first-generator conjugation equations, the delete-first split and strong
induction give multiplication and powering methods in every consistent
presentation.
-/
theorem operation_methods_step
    (hFirstStep :
      ∀ {m : ℕ} {U : ParameterIndex (m + 1) → ℤ}
        (N : CPres (m + 1) U),
          (∃ (F_U : Fin m → MvPolynomial (MulVar m) ℚ)
            (K_U : Fin m → MvPolynomial (PowerVar m) ℚ)
            (R_U : ParameterIndex m → MvPolynomial (ConjVar m) ℚ),
