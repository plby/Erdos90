/--
The input represented powering family and the quotient-lifted family with the
constructed last-coordinate solution have the same integer evaluations.
-/
theorem last_solution_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (F_W : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_W : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (hHallW :
      RepresentsHallPolynomials M.deleteConsistentPresentation F_W K_W R_W)
    (x : Fin (n + 1) → ℤ) (z : ℤ) (i : Fin (n + 1)) :
    evalPowerPolynomial T x z (K i) =
      evalPowerPolynomial T x z
        (deleteLastSolution F K_W (K (Fin.last n)) i) := by
  let K0 := deletePoweringFamily K_W (K (Fin.last n))
  have hK0 : RepresentsPowering M K0 := by
    simpa [K0] using
      represents_last_family
        M K F_W K_W R_W hK hHallW
  cases i using Fin.lastCases with
  | last =>
      simpa [deleteLastSolution, deletePoweringFamily, K0] using
        last_int_solution
          M F K0 hF hK0 x z
  | cast i =>
      simpa [deleteLastSolution, deletePoweringFamily, K0] using
        delete_powering_represents
          M K F_W K_W R_W hK hHallW x z (Fin.castSucc i)

/--
The input represented powering family and the quotient-lifted family with the
constructed last-coordinate solution have the same integer evaluations, with
quotient input split to represented powering.
-/
theorem powering_solution_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (hKW : RepresentsPowering M.deleteConsistentPresentation K_W)
    (x : Fin (n + 1) → ℤ) (z : ℤ) (i : Fin (n + 1)) :
    evalPowerPolynomial T x z (K i) =
      evalPowerPolynomial T x z
        (deleteLastSolution F K_W (K (Fin.last n)) i) := by
  let K0 := deletePoweringFamily K_W (K (Fin.last n))
  have hK0 : RepresentsPowering M K0 := by
    simpa [K0] using
      represents_powering_family
        M K K_W hK hKW
  cases i using Fin.lastCases with
  | last =>
      simpa [deleteLastSolution, deletePoweringFamily, K0] using
        last_int_solution
          M F K0 hF hK0 x z
  | cast i =>
      simpa [deleteLastSolution, deletePoweringFamily, K0] using
        delete_last_represents
          M K K_W hK hKW x z (Fin.castSucc i)

/--
Specialized polynomial identity for the quotient-lifted powering family with
the constructed Section 3.4 last coordinate.
-/
theorem specialize_powering_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (F_W : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_W : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (hHallW :
      RepresentsHallPolynomials M.deleteConsistentPresentation F_W K_W R_W)
    (i : Fin (n + 1)) :
    specializePower T (K i) =
      specializePower T
        (deleteLastSolution F K_W (K (Fin.last n)) i) :=
  specialize_power_eval (K i)
    (deleteLastSolution F K_W (K (Fin.last n)) i)
    (fun x z =>
      last_solution_represents
        M F K F_W K_W R_W hF hK hHallW x z i)

/--
Specialized polynomial identity for the quotient-lifted powering family with
the constructed Section 3.4 last coordinate, with quotient input split to
represented powering.
-/
theorem specialize_solution_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (hKW : RepresentsPowering M.deleteConsistentPresentation K_W)
    (i : Fin (n + 1)) :
    specializePower T (K i) =
      specializePower T
        (deleteLastSolution F K_W (K (Fin.last n)) i) :=
  specialize_power_eval (K i)
    (deleteLastSolution F K_W (K (Fin.last n)) i)
    (fun x z =>
      powering_solution_represents
        M F K K_W hF hK hKW x z i)

/--
Induction-hypothesis-shaped quotient-lifted powering replacement whose
non-last coordinates come from `W(T)` and whose last coordinate is the
constructed Section 3.4 solution.
-/
theorem delete_last_solution
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (hHallW :
      ∃ (F_W : Fin n → MvPolynomial (MulVar n) ℚ)
        (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
        (R_W : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
          RepresentsHallPolynomials M.deleteConsistentPresentation
            F_W K_W R_W) :
    ∃ K' : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ,
      RepresentsHallPolynomials M F K' R ∧
      (∀ i, specializePower T (K i) = specializePower T (K' i)) ∧
      ∀ (x : Fin (n + 1) → ℤ) (z : ℤ) i,
        evalPowerPolynomial T x z (K i) =
          evalPowerPolynomial T x z (K' i) := by
  rcases hHallW with ⟨F_W, K_W, R_W, hHallW⟩
  refine
    ⟨deleteLastSolution F K_W (K (Fin.last n)), ?_, ?_, ?_⟩
  · exact polynomials_last_solution
      M F K R F_W K_W R_W hHall hHallW
  · intro i
    exact specialize_powering_represents
      M F K F_W K_W R_W hHall.1 hHall.2.1 hHallW i
  · intro x z i
    exact last_solution_represents
      M F K F_W K_W R_W hHall.1 hHall.2.1 hHallW x z i

/--
Constructed-last quotient powering replacement from an existential represented
quotient powering family, without requiring quotient multiplication or
conjugation data.
-/
theorem delete_powering_solution
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (hKW :
      ∃ K_W : Fin n → MvPolynomial (PowerVar n) ℚ,
        RepresentsPowering M.deleteConsistentPresentation K_W) :
    ∃ K' : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ,
      RepresentsHallPolynomials M F K' R ∧
      (∀ i, specializePower T (K i) = specializePower T (K' i)) ∧
      ∀ (x : Fin (n + 1) → ℤ) (z : ℤ) i,
        evalPowerPolynomial T x z (K i) =
          evalPowerPolynomial T x z (K' i) := by
  rcases hKW with ⟨K_W, hKW⟩
  refine
    ⟨deleteLastSolution F K_W (K (Fin.last n)), ?_, ?_, ?_⟩
  · exact polynomials_powering_solution
      M F K R K_W hHall hKW
  · intro i
    exact specialize_solution_represents
      M F K K_W hHall.1 hHall.2.1 hKW i
  · intro x z i
    exact powering_solution_represents
      M F K K_W hHall.1 hHall.2.1 hKW x z i

/--
Seed-free quotient-lifted powering family: non-last coordinates are lifted
from quotient `W(T)`, and the last coordinate is the constructed Section 3.4
solution.  The dummy seed is `0`; the correctness theorem below shows the
constructed last coordinate does not depend on a represented seed.
-/
def poweringSolutionFamily {n : ℕ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ) :
    Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ :=
  deleteLastSolution F K_W 0

/--
Seed-free version of
`powering_delete_solution`: any seed gives
a represented family because the constructed last coordinate is determined by
the semantic recurrence and the quotient-lifted non-last coordinates.
-/
theorem represents_powering_last
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (F_W : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_W : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (K_seed : MvPolynomial (PowerVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hHallW :
      RepresentsHallPolynomials M.deleteConsistentPresentation F_W K_W R_W) :
    RepresentsPowering M
      (deleteLastSolution F K_W K_seed) := by
  let K0 := deletePoweringFamily K_W K_seed
  have hKnonlast : ∀ (x : Fin (n + 1) → ℤ) (z : ℤ) (i : Fin n),
      evalPowerPolynomial T x z (K0 (Fin.castSucc i)) =
        (M.poweringTuple x z (Fin.castSucc i) : ℚ) := by
    intro x z i
    simpa [K0, deletePoweringFamily] using
      powering_tuple_represents
        M K_W hHallW.2.1 x z i
  have hLast : ∀ x z,
      evalPowerPolynomial T x z (lastSolutionPolynomial F K0) =
        (M.poweringTuple x z (Fin.last n) : ℚ) := by
    intro x z
    exact last_solution_nonlast
      M F K0 hF hKnonlast x z
  simpa [deleteLastSolution, K0] using
    powering_last_family M K_W
      (lastSolutionPolynomial F K0) hHallW.2.1 hLast

/--
Seed-free version of
`powering_delete_solution`, with quotient
input split to represented powering.
-/
theorem solution_seed_free
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (K_seed : MvPolynomial (PowerVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hKW : RepresentsPowering M.deleteConsistentPresentation K_W) :
    RepresentsPowering M
      (deleteLastSolution F K_W K_seed) := by
  let K0 := deletePoweringFamily K_W K_seed
  have hKnonlast : ∀ (x : Fin (n + 1) → ℤ) (z : ℤ) (i : Fin n),
      evalPowerPolynomial T x z (K0 (Fin.castSucc i)) =
        (M.poweringTuple x z (Fin.castSucc i) : ℚ) := by
    intro x z i
    simpa [K0, deletePoweringFamily] using
      powering_tuple_represents
        M K_W hKW x z i
  have hLast : ∀ x z,
      evalPowerPolynomial T x z (lastSolutionPolynomial F K0) =
        (M.poweringTuple x z (Fin.last n) : ℚ) := by
    intro x z
    exact last_solution_nonlast
      M F K0 hF hKnonlast x z
  simpa [deleteLastSolution, K0] using
    powering_last_family M K_W
      (lastSolutionPolynomial F K0) hKW hLast

/--
Seed-free quotient-lifted powering family represents ambient powering.
-/
theorem last_solution_family
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (F_W : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_W : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hHallW :
      RepresentsHallPolynomials M.deleteConsistentPresentation F_W K_W R_W) :
    RepresentsPowering M (poweringSolutionFamily F K_W) := by
  simpa [poweringSolutionFamily] using
    represents_powering_last
      M F F_W K_W R_W 0 hF hHallW

/--
Seed-free quotient-lifted powering family represents ambient powering from
represented quotient powering alone.
-/
theorem represents_solution_family
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hKW : RepresentsPowering M.deleteConsistentPresentation K_W) :
    RepresentsPowering M (poweringSolutionFamily F K_W) := by
  simpa [poweringSolutionFamily] using
    solution_seed_free
      M F K_W 0 hF hKW

/--
Hall-polynomial bundle for the seed-free quotient-lifted powering family.
-/
theorem polynomials_solution_family
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (F_W : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_W : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hR : RepresentsConjugation M R)
    (hHallW :
      RepresentsHallPolynomials M.deleteConsistentPresentation F_W K_W R_W) :
    RepresentsHallPolynomials M F (poweringSolutionFamily F K_W) R :=
  ⟨hF,
    last_solution_family M F F_W K_W R_W hF hHallW,
    hR⟩

/--
Hall-polynomial bundle for the seed-free quotient-lifted powering family from
represented quotient powering alone.
-/
theorem powering_solution_family
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hR : RepresentsConjugation M R)
    (hKW : RepresentsPowering M.deleteConsistentPresentation K_W) :
    RepresentsHallPolynomials M F (poweringSolutionFamily F K_W) R :=
  ⟨hF,
    represents_solution_family
      M F K_W hF hKW,
    hR⟩

/--
The input represented powering family and the seed-free quotient-lifted
solution family have the same integer evaluations.
-/
theorem delete_solution_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (F_W : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_W : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (hHallW :
      RepresentsHallPolynomials M.deleteConsistentPresentation F_W K_W R_W)
    (x : Fin (n + 1) → ℤ) (z : ℤ) (i : Fin (n + 1)) :
    evalPowerPolynomial T x z (K i) =
      evalPowerPolynomial T x z (poweringSolutionFamily F K_W i) := by
  have hK' :=
    last_solution_family M F F_W K_W R_W hF hHallW
  rw [hK x z i, hK' x z i]

/--
The input represented powering family and the seed-free quotient-lifted
solution family have the same integer evaluations from represented quotient
powering alone.
-/
theorem last_powering_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
