        ∀ I u v,
          evalConjPolynomial T u v (R I) = evalConjPolynomial T u v (R' I) := by
  rcases hFKU with ⟨F_U, K_U, hFU, hKU⟩
  refine
    ⟨displayMultiplicationFamily F_U K_U R,
      displayPoweringFamily F_U K_U K R,
      conjFamilyU F_U K_U R, ?_, ?_, ?_, ?_, ?_, ?_, ?_⟩
  · exact polynomials_u_families
      M K R F_U K_U hHall.2.1 hHall.2.2 hFU hKU
  · intro i
    exact specialize_u_display
      M F R F_U K_U hHall.1 hHall.2.2 hFU hKU i
  · intro i
    exact specialize_display_powering
      M K R F_U K_U hHall.2.1 hHall.2.2 hFU hKU i
  · intro I
    exact specialize_u_powering
      M F_U K_U R hFU hKU hHall.2.2 I
  · intro x y i
    exact u_display_multiplication
      M F R F_U K_U hHall.1 hHall.2.2 hFU hKU x y i
  · intro x z i
    exact u_display_powering
