    (hFactor : ∀ v i k,
      MvPolynomial.eval
          (evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1))
          (firstConjugatedPolynomial R i k) =
        (M.leftConjugationTuple 0 (Fin.succ i)
          (M.leftConjugationTuple 0 j 1 v (Fin.succ i)) 1 (Fin.succ k) : ℚ)) :
    ∃ p : MvPolynomial (ConjVar (n + 1)) ℚ,
      ∃ g : MvPolynomial (ConjOneVar (n + 1)) ℚ,
        specializeConj T
            (conjSetU (R ⟨(0, j, Fin.succ k), h0j, hjk⟩)) =
          specializeConj T p ∧
        (∀ u v,
          evalConjPolynomial T u v
              (conjSetU (R ⟨(0, j, Fin.succ k), h0j, hjk⟩)) =
            evalConjPolynomial T u v p) ∧
        evalConjPolynomial T 1 0 p = 0 ∧
        ∀ v : ℤ,
          evalConjPolynomial T 1 (v + 1) p =
            evalConjPolynomial T 1 v p + conjOnePolynomial T v g := by
  refine
    ⟨setUSolution F_U R j h0j k hjk,
      forwardDifferenceU F_U R j h0j k hjk, ?_, ?_, ?_, ?_⟩
  · exact specialize_solution_delta
      M F_U R hFU j k h0j hjk hZeroInit hCurrent hSubst hFactor
  · intro u v
    exact solution_no_delta
      M F_U R hFU j k h0j hjk hZeroInit hCurrent hSubst hFactor u v
  · rw [setUSolution, conj_lift_polynomial]
    exact eval_solution_u F_U R j h0j k hjk
  · intro v
    rw [setUSolution, conj_lift_polynomial,
      conj_lift_polynomial]
    exact succ_solution_u F_U R j h0j k hjk v

/--
Induction-hypothesis-shaped lifted lower-rank `U(T)` package for Section 3.2
step2.
-/
theorem conj_solution_first
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHallU :
      ∃ (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
        (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
        (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
          RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hR : RepresentsConjugation M R)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k) :
    ∃ p : MvPolynomial (ConjVar (n + 1)) ℚ,
      ∃ g : MvPolynomial (ConjOneVar (n + 1)) ℚ,
        specializeConj T
            (conjSetU (R ⟨(0, j, Fin.succ k), h0j, hjk⟩)) =
          specializeConj T p ∧
        (∀ u v,
          evalConjPolynomial T u v
              (conjSetU (R ⟨(0, j, Fin.succ k), h0j, hjk⟩)) =
            evalConjPolynomial T u v p) ∧
        evalConjPolynomial T 1 0 p = 0 ∧
        ∀ v : ℤ,
          evalConjPolynomial T 1 (v + 1) p =
            evalConjPolynomial T 1 v p + conjOnePolynomial T v g := by
  rcases hHallU with ⟨F_U, K_U, R_U, hHallU⟩
  exact conj_u_solution
    M F_U K_U R_U R hHallU hR j k h0j hjk

/--
Existential lifted lower-rank `U(T)` package for Section 3.2 step2, consuming
only existence of a represented delete-first multiplication family.
-/
theorem conj_set_solution
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU :
      ∃ F_U : Fin n → MvPolynomial (MulVar n) ℚ,
        RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hR : RepresentsConjugation M R)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k) :
    ∃ p : MvPolynomial (ConjVar (n + 1)) ℚ,
      ∃ g : MvPolynomial (ConjOneVar (n + 1)) ℚ,
        specializeConj T
            (conjSetU (R ⟨(0, j, Fin.succ k), h0j, hjk⟩)) =
          specializeConj T p ∧
        (∀ u v,
          evalConjPolynomial T u v
              (conjSetU (R ⟨(0, j, Fin.succ k), h0j, hjk⟩)) =
            evalConjPolynomial T u v p) ∧
        evalConjPolynomial T 1 0 p = 0 ∧
        ∀ v : ℤ,
          evalConjPolynomial T 1 (v + 1) p =
            evalConjPolynomial T 1 v p + conjOnePolynomial T v g := by
  rcases hFU with ⟨F_U, hFU⟩
  exact conj_solution_delete
    M F_U R hFU hR j k h0j hjk

/--
Each coordinate input in lower-rank `step1` agrees, after evaluation, with the
same coordinate input after replacing `R(T;1,v)` by the lifted `step2`
solution.
-/
theorem coord_u_delete
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hR : RepresentsConjugation M R)
    (j i : Fin n) (u v : ℤ) :
    evalConjPolynomial T u v (stepCoordU R j i) =
      evalConjPolynomial T u v (conjCoordU F_U R j i) := by
  by_cases hij : i = j
  · subst i
    simp [stepCoordU, conjCoordU]
  · by_cases hji : j < i
    · have hstep :
        evalConjPolynomial T u v
            (conjSetU
              (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
                Fin.succ_lt_succ_iff.mpr hji⟩)) =
          evalConjPolynomial T u v
            (setUSolution F_U R (Fin.succ j) (Fin.succ_pos j)
              i (Fin.succ_lt_succ_iff.mpr hji)) :=
        set_u_solution
          M F_U K_U R_U R hHallU hR (Fin.succ j) i (Fin.succ_pos j)
          (Fin.succ_lt_succ_iff.mpr hji) u v
      simpa [stepCoordU, conjCoordU, hij, hji]
        using hstep
    · simp [stepCoordU, conjCoordU, hij, hji]

/--
Split version of the coordinate replacement used in the combined lower-rank
`step1`/`step2` construction: only delete-first multiplication is needed.
-/
theorem coord_delete_first
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hR : RepresentsConjugation M R)
    (j i : Fin n) (u v : ℤ) :
    evalConjPolynomial T u v (stepCoordU R j i) =
      evalConjPolynomial T u v (conjCoordU F_U R j i) := by
  by_cases hij : i = j
  · subst i
    simp [stepCoordU, conjCoordU]
  · by_cases hji : j < i
    · have hstep :
        evalConjPolynomial T u v
            (conjSetU
              (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
                Fin.succ_lt_succ_iff.mpr hji⟩)) =
          evalConjPolynomial T u v
            (setUSolution F_U R (Fin.succ j) (Fin.succ_pos j)
              i (Fin.succ_lt_succ_iff.mpr hji)) :=
        set_solution_delete
          M F_U R hFU hR (Fin.succ j) i (Fin.succ_pos j)
          (Fin.succ_lt_succ_iff.mpr hji) u v
      simpa [stepCoordU, conjCoordU, hij, hji]
        using hstep
    · simp [stepCoordU, conjCoordU, hij, hji]

/--
Exact-premise product-evaluation version of the coordinate replacement used in
the combined lower-rank `step1`/`step2` construction.
-/
theorem coord_u_product
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hMul : ∀ a b : M.G,
      M.coord a 0 = 0 → M.coord b 0 = 0 → M.coord (a * b) 0 = 0)
    (hInv : ∀ a : M.G, M.coord a 0 = 0 → M.coord a⁻¹ 0 = 0)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication
      (M.firstConsistentPresentation hMul hInv) F_U)
    (j i : Fin n) (u v : ℤ)
    (hZeroInit : ∀ hji : j < i,
      evalConjPolynomial T 1 0
        (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
          Fin.succ_lt_succ_iff.mpr hji⟩) = 0)
    (hDelta : ∀ (hji : j < i) (v : ℤ),
      conjOnePolynomial T v
          (forwardDifferenceV R
            ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
              Fin.succ_lt_succ_iff.mpr hji⟩) =
        (M.coord (M.firstConjugatedProduct
            (M.leftConjugationTuple 0 (Fin.succ j) 1 v) 1) (Fin.succ i) : ℚ) -
          (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ i) : ℚ))
    (hCurrent : ∀ (hji : j < i) (v : ℤ),
      evalConjPolynomial T 1 v
          (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
            Fin.succ_lt_succ_iff.mpr hji⟩) =
        (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ i) : ℚ))
    (hSubst : ∀ v w,
      MvPolynomial.eval (conjOneVar T v)
          (conjStepSubst R (Fin.succ j) (Fin.succ_pos j) w) =
        evalMulVar T (M.leftConjugationTuple 0 (Fin.succ j) 1 v) (singleCoord 0 1) w)
    (hFactor : ∀ v r s,
      MvPolynomial.eval
          (evalMulVar T (M.leftConjugationTuple 0 (Fin.succ j) 1 v) (singleCoord 0 1))
          (firstConjugatedPolynomial R r s) =
        (M.leftConjugationTuple 0 (Fin.succ r)
          (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ r)) 1 (Fin.succ s) : ℚ))
    (hTailZero : ∀ v r,
      M.leftConjugationTuple 0 (Fin.succ r)
        (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ r)) 1 0 = 0) :
    evalConjPolynomial T u v (stepCoordU R j i) =
      evalConjPolynomial T u v (conjCoordU F_U R j i) := by
  by_cases hij : i = j
  · subst i
    simp [stepCoordU, conjCoordU]
  · by_cases hji : j < i
    · have hstep :
        evalConjPolynomial T u v
            (conjSetU
              (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
                Fin.succ_lt_succ_iff.mpr hji⟩)) =
          evalConjPolynomial T u v
            (setUSolution F_U R (Fin.succ j) (Fin.succ_pos j)
              i (Fin.succ_lt_succ_iff.mpr hji)) :=
        set_solution_product
          M hMul hInv F_U R hFU (Fin.succ j) i (Fin.succ_pos j)
          (Fin.succ_lt_succ_iff.mpr hji) (hZeroInit hji) (hDelta hji)
          (hCurrent hji) hSubst hFactor hTailZero u v
      simpa [stepCoordU, conjCoordU, hij, hji]
        using hstep
    · simp [stepCoordU, conjCoordU, hij, hji]

/--
Exact-premise product-evaluation version of the coordinate replacement used in
the combined lower-rank `step1`/`step2` construction, with the
forward-difference delta and tail-zero premises discharged semantically.
-/
theorem u_no_delta
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hMul : ∀ a b : M.G,
      M.coord a 0 = 0 → M.coord b 0 = 0 → M.coord (a * b) 0 = 0)
    (hInv : ∀ a : M.G, M.coord a 0 = 0 → M.coord a⁻¹ 0 = 0)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication
      (M.firstConsistentPresentation hMul hInv) F_U)
    (j i : Fin n) (u v : ℤ)
    (hZeroInit : ∀ hji : j < i,
      evalConjPolynomial T 1 0
        (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
          Fin.succ_lt_succ_iff.mpr hji⟩) = 0)
    (hCurrent : ∀ (hji : j < i) (v : ℤ),
      evalConjPolynomial T 1 v
          (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
            Fin.succ_lt_succ_iff.mpr hji⟩) =
        (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ i) : ℚ))
    (hSubst : ∀ v w,
      MvPolynomial.eval (conjOneVar T v)
          (conjStepSubst R (Fin.succ j) (Fin.succ_pos j) w) =
        evalMulVar T (M.leftConjugationTuple 0 (Fin.succ j) 1 v) (singleCoord 0 1) w)
    (hFactor : ∀ v r s,
      MvPolynomial.eval
          (evalMulVar T (M.leftConjugationTuple 0 (Fin.succ j) 1 v) (singleCoord 0 1))
          (firstConjugatedPolynomial R r s) =
        (M.leftConjugationTuple 0 (Fin.succ r)
          (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ r)) 1 (Fin.succ s) : ℚ)) :
    evalConjPolynomial T u v (stepCoordU R j i) =
      evalConjPolynomial T u v (conjCoordU F_U R j i) :=
  coord_u_product
    M hMul hInv F_U R hFU j i u v hZeroInit
    (fun hji v =>
      forward_conjugated_current
        M R j i hji v (hCurrent hji))
    hCurrent hSubst hFactor
    (fun v r => conjugation_tuple_step M j v r)

/--
Canonical delete-first exact-premise version of the coordinate replacement
used in the combined lower-rank `step1`/`step2` construction.
-/
theorem coord_no_delta
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (j i : Fin n) (u v : ℤ)
    (hZeroInit : ∀ hji : j < i,
      evalConjPolynomial T 1 0
        (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
          Fin.succ_lt_succ_iff.mpr hji⟩) = 0)
    (hCurrent : ∀ (hji : j < i) (v : ℤ),
      evalConjPolynomial T 1 v
          (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
            Fin.succ_lt_succ_iff.mpr hji⟩) =
        (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ i) : ℚ))
    (hSubst : ∀ v w,
      MvPolynomial.eval (conjOneVar T v)
          (conjStepSubst R (Fin.succ j) (Fin.succ_pos j) w) =
        evalMulVar T (M.leftConjugationTuple 0 (Fin.succ j) 1 v) (singleCoord 0 1) w)
    (hFactor : ∀ v r s,
      MvPolynomial.eval
          (evalMulVar T (M.leftConjugationTuple 0 (Fin.succ j) 1 v) (singleCoord 0 1))
          (firstConjugatedPolynomial R r s) =
        (M.leftConjugationTuple 0 (Fin.succ r)
          (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ r)) 1 (Fin.succ s) :
            ℚ)) :
    evalConjPolynomial T u v (stepCoordU R j i) =
      evalConjPolynomial T u v (conjCoordU F_U R j i) := by
  by_cases hij : i = j
  · subst i
    simp [stepCoordU, conjCoordU]
  · by_cases hji : j < i
    · have hstep :
        evalConjPolynomial T u v
            (conjSetU
              (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
                Fin.succ_lt_succ_iff.mpr hji⟩)) =
          evalConjPolynomial T u v
            (setUSolution F_U R (Fin.succ j) (Fin.succ_pos j)
              i (Fin.succ_lt_succ_iff.mpr hji)) :=
        solution_no_delta
          M F_U R hFU (Fin.succ j) i (Fin.succ_pos j)
          (Fin.succ_lt_succ_iff.mpr hji) (hZeroInit hji) (hCurrent hji)
          hSubst hFactor u v
      simpa [stepCoordU, conjCoordU, hij, hji]
        using hstep
    · simp [stepCoordU, conjCoordU, hij, hji]

/--
The lower-rank `step1` polynomial is evaluation-equal to the combined
`step1`/`step2` construction that uses the lifted `step2` solutions as the
`R(T;1,v)` inputs.
-/
theorem u_2_delete
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hR : RepresentsConjugation M R)
    (j k : Fin n) (u v : ℤ) :
    evalConjPolynomial T u v (step1U R K_U j k) =
      evalConjPolynomial T u v (conjStepU F_U K_U R j k) := by
  change
    MvPolynomial.eval (evalConjVar T u v) (step1U R K_U j k) =
      MvPolynomial.eval (evalConjVar T u v)
        (conjStepU F_U K_U R j k)
  rw [step1U, conjStepU,
    eval_compose_polynomial, eval_compose_polynomial]
  apply congrArg
    (fun coords : Fin n → ℚ =>
      evalPowerQ
        (fun I => MvPolynomial.eval (evalConjVar T u v)
          (MvPolynomial.X (ConjVar.param (parameterSuccAbove 0 I))))
        coords (MvPolynomial.eval (evalConjVar T u v) (MvPolynomial.X ConjVar.u))
        (K_U k))
  funext i
  exact
    coord_u_delete
      M F_U K_U R_U R hHallU hR j i u v

/--
Split version of `u_2_delete`:
only delete-first multiplication is needed to replace the `R(T;1,v)` inputs
by the lifted step-2 solutions.
-/
theorem step_1_u
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hR : RepresentsConjugation M R)
    (j k : Fin n) (u v : ℤ) :
    evalConjPolynomial T u v (step1U R K_U j k) =
      evalConjPolynomial T u v (conjStepU F_U K_U R j k) := by
  change
    MvPolynomial.eval (evalConjVar T u v) (step1U R K_U j k) =
      MvPolynomial.eval (evalConjVar T u v)
        (conjStepU F_U K_U R j k)
  rw [step1U, conjStepU,
    eval_compose_polynomial, eval_compose_polynomial]
  apply congrArg
    (fun coords : Fin n → ℚ =>
      evalPowerQ
        (fun I => MvPolynomial.eval (evalConjVar T u v)
          (MvPolynomial.X (ConjVar.param (parameterSuccAbove 0 I))))
        coords (MvPolynomial.eval (evalConjVar T u v) (MvPolynomial.X ConjVar.u))
        (K_U k))
  funext i
  exact
    coord_delete_first
      M F_U R hFU hR j i u v

/--
Exact-premise product-evaluation version of
`u_2_delete`.
-/
theorem u_2_product
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hMul : ∀ a b : M.G,
      M.coord a 0 = 0 → M.coord b 0 = 0 → M.coord (a * b) 0 = 0)
    (hInv : ∀ a : M.G, M.coord a 0 = 0 → M.coord a⁻¹ 0 = 0)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication
      (M.firstConsistentPresentation hMul hInv) F_U)
    (j k : Fin n) (u v : ℤ)
    (hZeroInit : ∀ (i : Fin n) (hji : j < i),
      evalConjPolynomial T 1 0
        (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
          Fin.succ_lt_succ_iff.mpr hji⟩) = 0)
    (hDelta : ∀ (i : Fin n) (hji : j < i) (v : ℤ),
      conjOnePolynomial T v
          (forwardDifferenceV R
            ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
              Fin.succ_lt_succ_iff.mpr hji⟩) =
        (M.coord (M.firstConjugatedProduct
            (M.leftConjugationTuple 0 (Fin.succ j) 1 v) 1) (Fin.succ i) : ℚ) -
          (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ i) : ℚ))
    (hCurrent : ∀ (i : Fin n) (hji : j < i) (v : ℤ),
      evalConjPolynomial T 1 v
          (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
            Fin.succ_lt_succ_iff.mpr hji⟩) =
        (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ i) : ℚ))
    (hSubst : ∀ v w,
      MvPolynomial.eval (conjOneVar T v)
          (conjStepSubst R (Fin.succ j) (Fin.succ_pos j) w) =
        evalMulVar T (M.leftConjugationTuple 0 (Fin.succ j) 1 v) (singleCoord 0 1) w)
    (hFactor : ∀ v r s,
      MvPolynomial.eval
          (evalMulVar T (M.leftConjugationTuple 0 (Fin.succ j) 1 v) (singleCoord 0 1))
          (firstConjugatedPolynomial R r s) =
        (M.leftConjugationTuple 0 (Fin.succ r)
          (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ r)) 1 (Fin.succ s) : ℚ))
    (hTailZero : ∀ v r,
      M.leftConjugationTuple 0 (Fin.succ r)
        (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ r)) 1 0 = 0) :
    evalConjPolynomial T u v (step1U R K_U j k) =
      evalConjPolynomial T u v (conjStepU F_U K_U R j k) := by
  change
    MvPolynomial.eval (evalConjVar T u v) (step1U R K_U j k) =
      MvPolynomial.eval (evalConjVar T u v)
        (conjStepU F_U K_U R j k)
  rw [step1U, conjStepU,
    eval_compose_polynomial, eval_compose_polynomial]
