theorem conj_recursion_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hR : RepresentsConjugation M R)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k) :
    ∃ g : MvPolynomial (ConjOneVar (n + 1)) ℚ,
      ∀ v : ℤ,
        evalConjPolynomial T 1 (v + 1) (R ⟨(0, j, k), h0j, hjk⟩) =
          evalConjPolynomial T 1 v (R ⟨(0, j, k), h0j, hjk⟩) +
            conjOnePolynomial T v g := by
  exact ⟨conjForwardDifference F R j h0j k hjk,
    fun v =>
      conj_difference_represents
        M F R hF hR j k h0j hjk v⟩

/--
Exact-data existential form of Cant--Eick Section 3.2 Lemma `step2`: the
increment polynomial is built from the displayed product, and the successor
and delta premises are derived from the current-coordinate identity.
-/
theorem conj_recursion_delta
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k)
    (hCurrent : ∀ v : ℤ,
      evalConjPolynomial T 1 v (R ⟨(0, j, k), h0j, hjk⟩) =
        (M.leftConjugationTuple 0 j 1 v k : ℚ))
    (hProduct : ∀ v : ℤ,
      conjOnePolynomial T v (conjStep2 F R j h0j k) =
        (M.coord
          (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1) k : ℚ)) :
    ∃ g : MvPolynomial (ConjOneVar (n + 1)) ℚ,
      ∀ v : ℤ,
        evalConjPolynomial T 1 (v + 1) (R ⟨(0, j, k), h0j, hjk⟩) =
          evalConjPolynomial T 1 v (R ⟨(0, j, k), h0j, hjk⟩) +
            conjOnePolynomial T v g := by
  exact ⟨conjForwardDifference F R j h0j k hjk,
    fun v =>
      succ_no_delta
        M F R j k h0j hjk v hCurrent (hProduct v)⟩

/--
Existential form of Cant--Eick Section 3.2 Lemma `step2` using lower-rank
`U(T)` multiplication data for the displayed product.
-/
theorem forward_recursion_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hMul : ∀ a b : M.G,
      M.coord a 0 = 0 → M.coord b 0 = 0 → M.coord (a * b) 0 = 0)
    (hInv : ∀ a : M.G, M.coord a 0 = 0 → M.coord a⁻¹ 0 = 0)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication
      (M.firstConsistentPresentation hMul hInv) F_U)
    (hR : RepresentsConjugation M R)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k) :
    ∃ g : MvPolynomial (ConjOneVar (n + 1)) ℚ,
      ∀ v : ℤ,
        evalConjPolynomial T 1 (v + 1) (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
          evalConjPolynomial T 1 v (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) +
            conjOnePolynomial T v g := by
  exact ⟨forwardDifferenceU F_U R j h0j k hjk,
    fun v =>
      difference_u_represents
        M hMul hInv F_U R hFU hR j k h0j hjk v⟩

/--
Exact-data lower-rank `U(T)` existential form of Cant--Eick Section 3.2
Lemma `step2`, with the product-evaluation delta and tail-zero premises
discharged internally.
-/
theorem forward_recursion_delta
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hMul : ∀ a b : M.G,
      M.coord a 0 = 0 → M.coord b 0 = 0 → M.coord (a * b) 0 = 0)
    (hInv : ∀ a : M.G, M.coord a 0 = 0 → M.coord a⁻¹ 0 = 0)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication
      (M.firstConsistentPresentation hMul hInv) F_U)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k)
    (hCurrent : ∀ v : ℤ,
      evalConjPolynomial T 1 v (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
        (M.leftConjugationTuple 0 j 1 v (Fin.succ k) : ℚ))
    (hSubst : ∀ v w,
      MvPolynomial.eval (conjOneVar T v) (conjStepSubst R j h0j w) =
        evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1) w)
    (hFactor : ∀ v i k,
      MvPolynomial.eval
          (evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1))
          (firstConjugatedPolynomial R i k) =
        (M.leftConjugationTuple 0 (Fin.succ i)
          (M.leftConjugationTuple 0 j 1 v (Fin.succ i)) 1 (Fin.succ k) : ℚ)) :
    ∃ g : MvPolynomial (ConjOneVar (n + 1)) ℚ,
      ∀ v : ℤ,
        evalConjPolynomial T 1 (v + 1) (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
          evalConjPolynomial T 1 v (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) +
            conjOnePolynomial T v g := by
  exact ⟨forwardDifferenceU F_U R j h0j k hjk,
    fun v =>
      forward_difference_no
        M hMul hInv F_U R hFU j k h0j hjk v hCurrent (hSubst v) (hFactor v)⟩

/--
Canonical delete-first form of the exact-data lower-rank existential
recursion package.
-/
theorem recursion_no_delta
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k)
    (hCurrent : ∀ v : ℤ,
      evalConjPolynomial T 1 v (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
        (M.leftConjugationTuple 0 j 1 v (Fin.succ k) : ℚ))
    (hSubst : ∀ v w,
      MvPolynomial.eval (conjOneVar T v) (conjStepSubst R j h0j w) =
        evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1) w)
    (hFactor : ∀ v i k,
      MvPolynomial.eval
          (evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1))
          (firstConjugatedPolynomial R i k) =
        (M.leftConjugationTuple 0 (Fin.succ i)
          (M.leftConjugationTuple 0 j 1 v (Fin.succ i)) 1 (Fin.succ k) : ℚ)) :
    ∃ g : MvPolynomial (ConjOneVar (n + 1)) ℚ,
      ∀ v : ℤ,
        evalConjPolynomial T 1 (v + 1) (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
          evalConjPolynomial T 1 v (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) +
            conjOnePolynomial T v g := by
  exact ⟨forwardDifferenceU F_U R j h0j k hjk,
    fun v =>
      difference_no_delta
        M F_U R hFU j k h0j hjk v hCurrent (hSubst v) (hFactor v)⟩

