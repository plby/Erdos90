/--
Pointwise equality on all integer inputs preserves the multiplication
representation predicate.
-/
theorem represents_multiplication_polynomial
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F G : Fin n → MvPolynomial (MulVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hEval : ∀ x y i, evalMulPolynomial T x y (F i) = evalMulPolynomial T x y (G i)) :
    RepresentsMultiplication M G := by
  intro x y i
  rw [← hEval x y i]
  exact hF x y i

/--
Pointwise equality on all integer inputs preserves the powering
representation predicate.
-/
theorem represents_powering_polynomial
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (K L : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hK : RepresentsPowering M K)
    (hEval : ∀ x z i, evalPowerPolynomial T x z (K i) = evalPowerPolynomial T x z (L i)) :
    RepresentsPowering M L := by
  intro x z i
  rw [← hEval x z i]
  exact hK x z i

/--
Pointwise equality on all integer conjugation inputs preserves the conjugation
representation predicate.
-/
theorem represents_conjugation_polynomial
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (R S : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hR : RepresentsConjugation M R)
    (hEval : ∀ I u v, evalConjPolynomial T u v (R I) = evalConjPolynomial T u v (S I)) :
    RepresentsConjugation M S := by
  intro i j hij u v k
  by_cases hki : k = i
  · subst k
    simpa [conjugationCoordinateQ] using hR i j hij u v i
  · by_cases hkj : k = j
    · subst k
      simpa [conjugationCoordinateQ, ne_of_gt hij] using hR i j hij u v j
    · by_cases hjk : j < k
      · rw [conjugation_q_tail T S i j k hij hjk u v]
        have hbase := hR i j hij u v k
        rw [conjugation_q_tail T R i j k hij hjk u v] at hbase
        exact hbase.trans (hEval ⟨(i, j, k), hij, hjk⟩ u v)
      · simpa [conjugationCoordinateQ, hki, hkj, hjk] using hR i j hij u v k

/--
Pointwise equality on all integer inputs for all three Hall-polynomial
families preserves the bundled representation predicate.
-/
theorem represents_polynomials_eval
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F G : Fin n → MvPolynomial (MulVar n) ℚ)
    (K L : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R S : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (hF : ∀ x y i, evalMulPolynomial T x y (F i) = evalMulPolynomial T x y (G i))
    (hK : ∀ x z i, evalPowerPolynomial T x z (K i) = evalPowerPolynomial T x z (L i))
    (hR : ∀ I u v, evalConjPolynomial T u v (R I) = evalConjPolynomial T u v (S I)) :
    RepresentsHallPolynomials M G L S :=
  ⟨represents_multiplication_polynomial M F G hHall.1 hF,
    represents_powering_polynomial M K L hHall.2.1 hK,
    represents_conjugation_polynomial M R S hHall.2.2 hR⟩

/--
Lift a conjugation polynomial for the delete-first presentation `U(T)` to the
ambient presentation by reindexing parameters and keeping the same `u,v`
variables.
-/
def deleteConjSubst {n : ℕ} :
    ConjVar n → MvPolynomial (ConjVar (n + 1)) ℚ
  | ConjVar.param I =>
      MvPolynomial.X (ConjVar.param (parameterSuccAbove (0 : Fin (n + 1)) I))
  | ConjVar.u => MvPolynomial.X ConjVar.u
  | ConjVar.v => MvPolynomial.X ConjVar.v

/-- A `U(T)` conjugation polynomial, viewed in the ambient conjugation variables. -/
def deleteFirstConj {n : ℕ}
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (I : ParameterIndex n) :
    MvPolynomial (ConjVar (n + 1)) ℚ :=
  MvPolynomial.eval₂Hom MvPolynomial.C deleteConjSubst (R_U I)

lemma delete_first_conj {n : ℕ}
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (T : ParameterIndex (n + 1) → ℤ) (u v : ℤ) (I : ParameterIndex n) :
    evalConjPolynomial T u v (deleteFirstConj R_U I) =
      evalConjPolynomial (firstParameterTuple T) u v (R_U I) := by
  change
    MvPolynomial.eval (evalConjVar T u v)
        (MvPolynomial.eval₂ MvPolynomial.C deleteConjSubst (R_U I)) =
      MvPolynomial.eval (evalConjVar (firstParameterTuple T) u v) (R_U I)
  rw [← MvPolynomial.eval_assoc]
  apply congrArg (fun f : ConjVar n → ℚ => MvPolynomial.eval f (R_U I))
  funext w
  cases w <;> simp [deleteConjSubst, evalConjVar, varQ,
    firstParameterTuple, deleteParameterTuple]

/--
If lower-rank conjugation polynomials represent `U(T)`, then their lifted
polynomials compute the ambient conjugation tail coordinates
`(succ i, succ j, succ k)`.
-/
theorem conjugation_coord_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hR_U : RepresentsConjugation M.deleteFirstConsistent R_U)
    (i j k : Fin n) (hij : i < j) (hjk : j < k) (u v : ℤ) :
    evalConjPolynomial T u v
        (deleteFirstConj R_U ⟨(i, j, k), hij, hjk⟩) =
      (M.coord (M.gen (Fin.succ j) ^ u * M.gen (Fin.succ i) ^ v)
        (Fin.succ k) : ℚ) := by
  rw [delete_first_conj]
  have hrep := hR_U i j hij u v k
  rw [conjugation_q_tail (firstParameterTuple T) R_U i j k hij hjk u v]
    at hrep
  have hcoord :
      (M.deleteFirstConsistent.coord
          (M.deleteFirstConsistent.gen j ^ u *
            M.deleteFirstConsistent.gen i ^ v) k : ℚ) =
        (M.coord (M.gen (Fin.succ j) ^ u * M.gen (Fin.succ i) ^ v)
          (Fin.succ k) : ℚ) := by
    have htail := congrFun
      (M.consistent_presentation_conjugation i j u v) k
    change
      M.deleteFirstConsistent.coord
          (M.deleteFirstConsistent.gen j ^ u *
            M.deleteFirstConsistent.gen i ^ v) k =
        M.coord (M.gen (Fin.succ j) ^ u * M.gen (Fin.succ i) ^ v)
          (Fin.succ k) at htail
    exact_mod_cast htail
  exact hrep.symm.trans hcoord

/--
The lifted `U(T)` conjugation polynomial agrees with any represented ambient
conjugation polynomial on the corresponding successor-indexed parameter.
-/
theorem delete_first_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hR_U : RepresentsConjugation M.deleteFirstConsistent R_U)
    (hR : RepresentsConjugation M R)
    (I : ParameterIndex n) (u v : ℤ) :
    evalConjPolynomial T u v (R (parameterSuccAbove (0 : Fin (n + 1)) I)) =
      evalConjPolynomial T u v (deleteFirstConj R_U I) := by
  rcases I with ⟨⟨i, j, k⟩, hij, hjk⟩
  change
    evalConjPolynomial T u v
        (R ⟨(Fin.succ i, Fin.succ j, Fin.succ k),
          Fin.succ_lt_succ_iff.mpr hij, Fin.succ_lt_succ_iff.mpr hjk⟩) =
      evalConjPolynomial T u v
        (deleteFirstConj R_U ⟨(i, j, k), hij, hjk⟩)
  have hambient :
      evalConjPolynomial T u v
          (R ⟨(Fin.succ i, Fin.succ j, Fin.succ k),
            Fin.succ_lt_succ_iff.mpr hij, Fin.succ_lt_succ_iff.mpr hjk⟩) =
        (M.coord (M.gen (Fin.succ j) ^ u * M.gen (Fin.succ i) ^ v)
          (Fin.succ k) : ℚ) := by
    have h :=
      hR (Fin.succ i) (Fin.succ j) (Fin.succ_lt_succ_iff.mpr hij)
        u v (Fin.succ k)
    rw [conjugation_q_tail T R
      (Fin.succ i) (Fin.succ j) (Fin.succ k)
      (Fin.succ_lt_succ_iff.mpr hij) (Fin.succ_lt_succ_iff.mpr hjk) u v] at h
    exact h.symm
  rw [hambient]
  exact
    (conjugation_coord_represents
      M R_U hR_U i j k hij hjk u v).symm

/--
Replace all ambient conjugation coordinates whose parameter triple avoids the
first generator by lifted `U(T)` conjugation polynomials.  Coordinates involving
the first generator are left unchanged.
-/
noncomputable def deleteConjFamily {n : ℕ}
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ) :
    ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ :=
  fun I => by
    classical
    exact
    if h : ParameterIndexAvoids (0 : Fin (n + 1)) I then
      deleteFirstConj R_U
        (Classical.choose
          ((parameter_above_avoids (0 : Fin (n + 1)) I).mpr h))
    else
      R I

/--
The part of ambient conjugation involving the first generator.  This is the
local data that Section 3.2 Step 1/Step 2 must construct; the successor-tail
conjugation coordinates are supplied separately by the delete-first induction
step.
-/
def RepresentsFirstConjugation {n : ℕ}
    {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ) : Prop :=
  ∀ (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j)
    (u v : ℤ) (k : Fin (n + 1)),
      (M.coord (M.gen j ^ u * M.gen 0 ^ v) k : ℚ) =
        conjugationCoordinateQ T R 0 j h0j u v k

/--
Tail-only first-generator conjugation data.  The structural coordinates
`k = 0`, `k = j`, and `k ≤ j` are supplied unconditionally by
`conjugation_tuple_structural`; the local Hall-polynomial
constructor only has to produce the polynomial tail coordinates `j < k`.
-/
def RepresentsTailConjugation {n : ℕ}
    {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ) : Prop :=
  ∀ (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k)
    (u v : ℤ),
      (M.coord (M.gen j ^ u * M.gen 0 ^ v) k : ℚ) =
        evalConjPolynomial T u v (R ⟨(0, j, k), h0j, hjk⟩)

theorem represents_tail_conjugation {n : ℕ}
    {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hR : RepresentsConjugation M R) :
    RepresentsTailConjugation M R := by
  intro j k h0j hjk u v
  have h := hR 0 j h0j u v k
  rw [conjugation_q_tail T R 0 j k h0j hjk u v] at h
  exact h

theorem represents_conjugation_tail {n : ℕ}
    {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hTail : RepresentsTailConjugation M R) :
    RepresentsFirstConjugation M R := by
  intro j h0j u v k
  by_cases hjk : j < k
  · rw [conjugation_q_tail T R 0 j k h0j hjk u v]
    exact hTail j k h0j hjk u v
  · change (M.conjugationTuple 0 j u v k : ℚ) =
      conjugationCoordinateQ T R 0 j h0j u v k
    rw [CPres.conjugation_tuple_structural
      M 0 j k h0j hjk u v]
    by_cases hk0 : k = 0
    · subst k
      simp [conjugationCoordinateQ]
    · by_cases hkj : k = j
      · subst k
        simp [conjugationCoordinateQ, ne_of_gt h0j]
      · simp [conjugationCoordinateQ, hk0, hkj, hjk]

lemma delete_parameter_above {n : ℕ}
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (I : ParameterIndex n) :
    deleteConjFamily R_U R
        (parameterSuccAbove (0 : Fin (n + 1)) I) =
      deleteFirstConj R_U I := by
  classical
  unfold deleteConjFamily
  have havoid :
      ParameterIndexAvoids (0 : Fin (n + 1))
        (parameterSuccAbove (0 : Fin (n + 1)) I) :=
    parameter_index_avoids (0 : Fin (n + 1)) I
  rw [dif_pos havoid]
  let J : ParameterIndex n :=
    Classical.choose
      ((parameter_above_avoids (0 : Fin (n + 1))
        (parameterSuccAbove (0 : Fin (n + 1)) I)).mpr havoid)
  change deleteFirstConj R_U J = deleteFirstConj R_U I
  have hJ :
      parameterSuccAbove (0 : Fin (n + 1)) J =
        parameterSuccAbove (0 : Fin (n + 1)) I :=
    Classical.choose_spec
      ((parameter_above_avoids (0 : Fin (n + 1))
        (parameterSuccAbove (0 : Fin (n + 1)) I)).mpr havoid)
  rw [parameter_above_injective (0 : Fin (n + 1)) hJ]

lemma conjugation_q_family {n : ℕ}
    {T : ParameterIndex (n + 1) → ℤ}
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (u v : ℤ) :
    conjugationCoordinateQ T (deleteConjFamily R_U R) 0 j h0j u v k =
      conjugationCoordinateQ T R 0 j h0j u v k := by
  by_cases hk0 : k = 0
  · subst k
    simp [conjugationCoordinateQ]
  · by_cases hkj : k = j
    · subst k
      simp [conjugationCoordinateQ, ne_of_gt h0j]
    · by_cases hjk : j < k
      · rw [conjugation_q_tail T (deleteConjFamily R_U R)
          0 j k h0j hjk u v]
        rw [conjugation_q_tail T R 0 j k h0j hjk u v]
        have hnot :
            ¬ ParameterIndexAvoids (0 : Fin (n + 1))
              ⟨(0, j, k), h0j, hjk⟩ := by
          intro h
          exact h.1 rfl
        simp [deleteConjFamily, hnot]
      · simp [conjugationCoordinateQ, hk0, hkj, hjk]

lemma conjugation_q_succ {n : ℕ}
    {T : ParameterIndex (n + 1) → ℤ}
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (i j k : Fin n) (hij : i < j) (u v : ℤ) :
    conjugationCoordinateQ T (deleteConjFamily R_U R)
        (Fin.succ i) (Fin.succ j) (Fin.succ_lt_succ_iff.mpr hij)
        u v (Fin.succ k) =
      conjugationCoordinateQ (firstParameterTuple T) R_U i j hij u v k := by
  by_cases hki : k = i
  · subst k
    simp [conjugationCoordinateQ]
  · by_cases hkj : k = j
    · subst k
      simp [conjugationCoordinateQ, hki]
    · by_cases hjk : j < k
      · rw [conjugation_q_tail T (deleteConjFamily R_U R)
          (Fin.succ i) (Fin.succ j) (Fin.succ k)
          (Fin.succ_lt_succ_iff.mpr hij)
          (Fin.succ_lt_succ_iff.mpr hjk) u v]
        rw [conjugation_q_tail (firstParameterTuple T) R_U
          i j k hij hjk u v]
        have hidx :
            (⟨(Fin.succ i, Fin.succ j, Fin.succ k),
              Fin.succ_lt_succ_iff.mpr hij,
              Fin.succ_lt_succ_iff.mpr hjk⟩ :
                ParameterIndex (n + 1)) =
              parameterSuccAbove (0 : Fin (n + 1))
                ⟨(i, j, k), hij, hjk⟩ := by
          apply Subtype.ext
          simp [parameterSuccAbove]
        rw [hidx, delete_parameter_above,
          delete_first_conj]
      · simp [conjugationCoordinateQ, hki, hkj, hjk, Fin.succ_lt_succ_iff]

theorem represents_conjugation_generator {n : ℕ}
    {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hR_U : RepresentsConjugation M.deleteFirstConsistent R_U)
    (hFirst : RepresentsFirstConjugation M R) :
    RepresentsConjugation M (deleteConjFamily R_U R) := by
  intro i j hij u v k
  rcases Fin.eq_zero_or_eq_succ i with rfl | ⟨i', rfl⟩
  · exact (hFirst j hij u v k).trans
      (conjugation_q_family R_U R
        j k hij u v).symm
  · rcases Fin.eq_zero_or_eq_succ j with rfl | ⟨j', rfl⟩
    · exact False.elim ((Fin.not_lt_zero (Fin.succ i')) hij)
    · have hij' : i' < j' := Fin.succ_lt_succ_iff.mp hij
      rcases Fin.eq_zero_or_eq_succ k with rfl | ⟨k', rfl⟩
      · have hleft :
            (M.coord (M.gen (Fin.succ j') ^ u *
              M.gen (Fin.succ i') ^ v) 0 : ℚ) = 0 := by
          change
            (M.conjugationTuple (Fin.succ i') (Fin.succ j') u v 0 : ℚ) = 0
          have hzero :
              M.conjugationTuple (Fin.succ i') (Fin.succ j') u v 0 = 0 := by
            change
              M.coord (M.gen (Fin.succ j') ^ u *
                M.gen (Fin.succ i') ^ v) 0 = 0
            rw [M.firstCoordinateAdditive
              (M.gen (Fin.succ j') ^ u) (M.gen (Fin.succ i') ^ v)]
            rw [M.coord_gen_zpow, M.coord_gen_zpow]
            simp [singleCoord, (Fin.succ_ne_zero i').symm,
              (Fin.succ_ne_zero j').symm]
          exact_mod_cast hzero
        have hright :
            conjugationCoordinateQ T (deleteConjFamily R_U R)
              (Fin.succ i') (Fin.succ j')
              (Fin.succ_lt_succ_iff.mpr hij') u v 0 = 0 := by
          simp [conjugationCoordinateQ, (Fin.succ_ne_zero i').symm,
            (Fin.succ_ne_zero j').symm]
        rw [hleft, hright]
      · have hcoord :
            (M.deleteFirstConsistent.coord
                (M.deleteFirstConsistent.gen j' ^ u *
                  M.deleteFirstConsistent.gen i' ^ v) k' : ℚ) =
              (M.coord (M.gen (Fin.succ j') ^ u *
                M.gen (Fin.succ i') ^ v) (Fin.succ k') : ℚ) := by
          have htail :=
            congrFun
              (M.consistent_presentation_conjugation
                i' j' u v) k'
          change
            M.deleteFirstConsistent.coord
                (M.deleteFirstConsistent.gen j' ^ u *
                  M.deleteFirstConsistent.gen i' ^ v) k' =
              M.coord (M.gen (Fin.succ j') ^ u *
                M.gen (Fin.succ i') ^ v) (Fin.succ k') at htail
          exact_mod_cast htail
        have hLower := hR_U i' j' hij' u v k'
        exact (hcoord.symm.trans hLower).trans
          (conjugation_q_succ
            R_U R i' j' k' hij' u v).symm

theorem conjugation_first_delete {n : ℕ}
    {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hR_U : RepresentsConjugation M.deleteFirstConsistent R_U)
    (hFirst :
      ∃ R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ,
        RepresentsFirstConjugation M R) :
    ∃ R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ,
      RepresentsConjugation M R := by
  rcases hFirst with ⟨R, hRFirst⟩
  exact
    ⟨deleteConjFamily R_U R,
      represents_conjugation_generator
        M R_U R hR_U hRFirst⟩

theorem delete_family_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hR_U : RepresentsConjugation M.deleteFirstConsistent R_U)
    (hR : RepresentsConjugation M R)
    (I : ParameterIndex (n + 1)) (u v : ℤ) :
    evalConjPolynomial T u v (R I) =
      evalConjPolynomial T u v (deleteConjFamily R_U R I) := by
  classical
  unfold deleteConjFamily
  by_cases havoid : ParameterIndexAvoids (0 : Fin (n + 1)) I
  · rw [dif_pos havoid]
    let J : ParameterIndex n :=
      Classical.choose
        ((parameter_above_avoids (0 : Fin (n + 1)) I).mpr havoid)
    have hJ : parameterSuccAbove (0 : Fin (n + 1)) J = I :=
      Classical.choose_spec
        ((parameter_above_avoids (0 : Fin (n + 1)) I).mpr havoid)
    change evalConjPolynomial T u v (R I) =
      evalConjPolynomial T u v (deleteFirstConj R_U J)
    rw [← hJ]
    exact delete_first_represents
      M R_U R hR_U hR J u v
  · rw [dif_neg havoid]

theorem conjugation_delete_family
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hR_U : RepresentsConjugation M.deleteFirstConsistent R_U)
    (hR : RepresentsConjugation M R) :
    RepresentsConjugation M (deleteConjFamily R_U R) :=
  represents_conjugation_polynomial M R
    (deleteConjFamily R_U R) hR
    (delete_family_represents
      M R_U R hR_U hR)

theorem represents_polynomials_family
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hR_U : RepresentsConjugation M.deleteFirstConsistent R_U)
    (hHall : RepresentsHallPolynomials M F K R) :
    RepresentsHallPolynomials M F K (deleteConjFamily R_U R) :=
  ⟨hHall.1, hHall.2.1,
    conjugation_delete_family
      M R_U R hR_U hHall.2.2⟩

/--
All-integer equality of multiplication polynomial evaluations implies equality
after specializing the parameters.
-/
theorem specialize_mul_eval
    {T : ParameterIndex n → ℤ}
    (p q : MvPolynomial (MulVar n) ℚ)
    (hEval : ∀ x y, evalMulPolynomial T x y p = evalMulPolynomial T x y q) :
    specializeMul T p = specializeMul T q := by
  apply MvPolynomial.funext_set
    (s := fun _ : MulInputVar n => Set.range fun z : ℤ => (z : ℚ))
  · intro w
    exact Set.infinite_range_of_injective Int.cast_injective
  · intro qval hq
    choose z hz using fun w => hq w (Set.mem_univ w)
    let x : Fin n → ℤ := fun i => z (MulInputVar.left i)
    let y : Fin n → ℤ := fun i => z (MulInputVar.right i)
    have hq_eq : qval = mulInputVar x y := by
      funext w
      cases w <;> exact (hz _).symm
    rw [hq_eq, eval_specializeMul, eval_specializeMul]
    exact hEval x y

/--
All-integer equality of powering polynomial evaluations implies equality after
specializing the parameters.
-/
theorem specialize_power_eval
    {T : ParameterIndex n → ℤ}
    (p q : MvPolynomial (PowerVar n) ℚ)
    (hEval : ∀ x z, evalPowerPolynomial T x z p = evalPowerPolynomial T x z q) :
    specializePower T p = specializePower T q := by
  apply MvPolynomial.funext_set
    (s := fun _ : PowerInputVar n => Set.range fun z : ℤ => (z : ℚ))
  · intro v
    exact Set.infinite_range_of_injective Int.cast_injective
  · intro qval hq
    choose z hz using fun v => hq v (Set.mem_univ v)
    let x : Fin n → ℤ := fun j => z (PowerInputVar.coord j)
    let e : ℤ := z PowerInputVar.exponent
    have hq_eq : qval = evalInputVar x e := by
      funext v
      cases v <;> exact (hz _).symm
    rw [hq_eq, eval_specializePower, eval_specializePower]
    exact hEval x e

/--
All-integer equality of conjugation polynomial evaluations implies equality
after specializing the parameters.
-/
theorem specialize_conj_eval
    {T : ParameterIndex n → ℤ}
    (p q : MvPolynomial (ConjVar n) ℚ)
    (hEval : ∀ u v, evalConjPolynomial T u v p = evalConjPolynomial T u v q) :
    specializeConj T p = specializeConj T q := by
  apply MvPolynomial.funext_set
    (s := fun _ : ConjInputVar n => Set.range fun z : ℤ => (z : ℚ))
  · intro w
    exact Set.infinite_range_of_injective Int.cast_injective
  · intro qval hq
    choose z hz using fun w => hq w (Set.mem_univ w)
    let u : ℤ := z ConjInputVar.u
    let v : ℤ := z ConjInputVar.v
    have hq_eq : qval = conjInputVar u v := by
      funext w
      cases w <;> exact (hz _).symm
    rw [hq_eq, eval_specializeConj, eval_specializeConj]
    exact hEval u v

/--
If `K_W` represents powering in the concrete quotient presentation `W(T)`,
then its evaluations compute quotient coordinates of ambient powers.
-/
theorem powering_coord_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hKW : RepresentsPowering M.deleteConsistentPresentation K_W)
    (x : Fin n → ℤ) (z : ℤ) (i : Fin n) :
    evalPowerPolynomial (lastParameterTuple T) x z (K_W i) =
      ((M.deleteConsistentPresentation).coord
        (QuotientGroup.mk' (Subgroup.zpowers (M.gen (Fin.last n)))
          (M.normalWord (Fin.snoc x 0) ^ z)) i : ℚ) := by
  let MW := M.deleteConsistentPresentation
  rw [hKW x z i]
  change (MW.coord (MW.normalWord x ^ z) i : ℚ) =
    (MW.coord
      (QuotientGroup.mk' (Subgroup.zpowers (M.gen (Fin.last n)))
        (M.normalWord (Fin.snoc x 0) ^ z)) i : ℚ)
  congr 1
  rw [M.last_consistent_presentation x]
  exact congrArg (fun q => MW.coord q i)
    (map_zpow (QuotientGroup.mk' (Subgroup.zpowers (M.gen (Fin.last n))))
      (M.normalWord (Fin.snoc x 0)) z).symm

/--
Lift powering variables for the quotient `W(T)` to ambient powering variables
by skipping the last generator.
-/
def deleteLastSubst {n : ℕ} :
    PowerVar n → MvPolynomial (PowerVar (n + 1)) ℚ
  | PowerVar.param I =>
      MvPolynomial.X (PowerVar.param (parameterSuccAbove (Fin.last n) I))
  | PowerVar.coord i => MvPolynomial.X (PowerVar.coord (Fin.castSucc i))
  | PowerVar.exponent => MvPolynomial.X PowerVar.exponent

/-- The ambient non-last powering polynomial obtained from quotient `W(T)`. -/
def deleteLastPowering {n : ℕ}
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ) (i : Fin n) :
    MvPolynomial (PowerVar (n + 1)) ℚ :=
  MvPolynomial.eval₂Hom MvPolynomial.C deleteLastSubst (K_W i)

lemma last_powering_polynomial {n : ℕ}
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (T : ParameterIndex (n + 1) → ℤ) (x : Fin (n + 1) → ℤ) (z : ℤ)
    (i : Fin n) :
    evalPowerPolynomial T x z (deleteLastPowering K_W i) =
      evalPowerPolynomial (lastParameterTuple T) (Fin.init x) z (K_W i) := by
  change
    MvPolynomial.eval (evalPowerVar T x z)
        (MvPolynomial.eval₂ MvPolynomial.C deleteLastSubst (K_W i)) =
      MvPolynomial.eval (evalPowerVar (lastParameterTuple T) (Fin.init x) z)
        (K_W i)
  rw [← MvPolynomial.eval_assoc]
  apply congrArg (fun f : PowerVar n → ℚ => MvPolynomial.eval f (K_W i))
  funext v
  cases v <;> simp [deleteLastSubst, lastParameterTuple,
    deleteParameterTuple, evalPowerVar, evalVarQ, Fin.init_def]

/--
The lifted quotient powering polynomial computes the corresponding non-last
ambient powering coordinate.
-/
theorem powering_tuple_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hKW : RepresentsPowering M.deleteConsistentPresentation K_W)
    (x : Fin (n + 1) → ℤ) (z : ℤ) (i : Fin n) :
    evalPowerPolynomial T x z (deleteLastPowering K_W i) =
      (M.poweringTuple x z (Fin.castSucc i) : ℚ) := by
  rw [last_powering_polynomial]
  rw [hKW (Fin.init x) z i]
  have hcoord :=
    congrFun (M.delete_consistent_tuple x z) i
  simpa [Fin.init_def] using congrArg (fun a : ℤ => (a : ℚ)) hcoord

/--
Ambient powering family obtained from quotient `W(T)` for all non-last
coordinates and a supplied polynomial for the last coordinate.
-/
def deletePoweringFamily {n : ℕ}
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (K_last : MvPolynomial (PowerVar (n + 1)) ℚ) :
    Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ :=
  Fin.lastCases K_last (deleteLastPowering K_W)

/--
If quotient powering is represented and the supplied last-coordinate
polynomial represents the ambient last powering coordinate, the combined
ambient family represents powering.
-/
theorem powering_last_family
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (K_last : MvPolynomial (PowerVar (n + 1)) ℚ)
    (hKW : RepresentsPowering M.deleteConsistentPresentation K_W)
    (hLast : ∀ x z,
      evalPowerPolynomial T x z K_last =
        (M.poweringTuple x z (Fin.last n) : ℚ)) :
    RepresentsPowering M (deletePoweringFamily K_W K_last) := by
  intro x z i
  cases i using Fin.lastCases with
  | last =>
      simpa [deletePoweringFamily] using hLast x z
  | cast i =>
      simpa [deletePoweringFamily] using
        powering_tuple_represents
          M K_W hKW x z i

/--
Version of `powering_last_family` consuming a
lower-rank Hall-polynomial bundle for `W(T)`.
-/
theorem represents_powering_delete
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_W : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_W : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (K_last : MvPolynomial (PowerVar (n + 1)) ℚ)
    (hHallW :
      RepresentsHallPolynomials M.deleteConsistentPresentation F_W K_W R_W)
    (hLast : ∀ x z,
      evalPowerPolynomial T x z K_last =
        (M.poweringTuple x z (Fin.last n) : ℚ)) :
    RepresentsPowering M (deletePoweringFamily K_W K_last) :=
  powering_last_family M K_W K_last hHallW.2.1 hLast

/--
Replacing the non-last coordinates of an already represented ambient powering
family by quotient `W(T)` powering polynomials preserves powering
representation.
-/
theorem represents_last_family
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (F_W : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_W : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hK : RepresentsPowering M K)
    (hHallW :
      RepresentsHallPolynomials M.deleteConsistentPresentation F_W K_W R_W) :
    RepresentsPowering M (deletePoweringFamily K_W (K (Fin.last n))) :=
  represents_powering_delete
    M F_W K_W R_W (K (Fin.last n)) hHallW
    (fun x z => hK x z (Fin.last n))

/--
Split version of `represents_last_family`:
only quotient powering is needed for the non-last replacement.
-/
theorem represents_powering_family
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hK : RepresentsPowering M K)
    (hKW : RepresentsPowering M.deleteConsistentPresentation K_W) :
    RepresentsPowering M (deletePoweringFamily K_W (K (Fin.last n))) :=
  powering_last_family M K_W (K (Fin.last n)) hKW
    (fun x z => hK x z (Fin.last n))

/--
The represented ambient powering family and the quotient-lifted replacement
agree on all integer inputs.
-/
theorem delete_powering_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (F_W : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_W : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hK : RepresentsPowering M K)
    (hHallW :
      RepresentsHallPolynomials M.deleteConsistentPresentation F_W K_W R_W)
    (x : Fin (n + 1) → ℤ) (z : ℤ) (i : Fin (n + 1)) :
    evalPowerPolynomial T x z (K i) =
      evalPowerPolynomial T x z (deletePoweringFamily K_W (K (Fin.last n)) i) := by
  cases i using Fin.lastCases with
  | last =>
      simp [deletePoweringFamily]
  | cast i =>
      rw [hK x z (Fin.castSucc i)]
      simpa [deletePoweringFamily] using
        (powering_tuple_represents
          M K_W hHallW.2.1 x z i).symm

/--
The represented ambient powering family and the quotient-lifted replacement
agree on all integer inputs, assuming only represented quotient powering.
-/
theorem delete_last_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hK : RepresentsPowering M K)
    (hKW : RepresentsPowering M.deleteConsistentPresentation K_W)
    (x : Fin (n + 1) → ℤ) (z : ℤ) (i : Fin (n + 1)) :
    evalPowerPolynomial T x z (K i) =
      evalPowerPolynomial T x z (deletePoweringFamily K_W (K (Fin.last n)) i) := by
  cases i using Fin.lastCases with
  | last =>
      simp [deletePoweringFamily]
  | cast i =>
      rw [hK x z (Fin.castSucc i)]
      simpa [deletePoweringFamily] using
        (powering_tuple_represents
          M K_W hKW x z i).symm

/--
Specialized polynomial identity for the quotient-lifted non-last powering
replacement.
-/
theorem specialize_delete_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (F_W : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_W : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hK : RepresentsPowering M K)
    (hHallW :
      RepresentsHallPolynomials M.deleteConsistentPresentation F_W K_W R_W)
    (i : Fin (n + 1)) :
    specializePower T (K i) =
      specializePower T (deletePoweringFamily K_W (K (Fin.last n)) i) :=
  specialize_power_eval (K i) (deletePoweringFamily K_W (K (Fin.last n)) i)
    (fun x z =>
      delete_powering_represents
        M K F_W K_W R_W hK hHallW x z i)

/--
Specialized polynomial identity for the quotient-lifted non-last powering
replacement, assuming only represented quotient powering.
-/
theorem specialize_last_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hK : RepresentsPowering M K)
    (hKW : RepresentsPowering M.deleteConsistentPresentation K_W)
    (i : Fin (n + 1)) :
    specializePower T (K i) =
      specializePower T (deletePoweringFamily K_W (K (Fin.last n)) i) :=
  specialize_power_eval (K i) (deletePoweringFamily K_W (K (Fin.last n)) i)
    (fun x z =>
      delete_last_represents
        M K K_W hK hKW x z i)

/--
Bundled Hall-polynomial form of the quotient-lifted powering replacement.
-/
theorem polynomials_last_powering
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (F_W : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_W : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (hHallW :
      RepresentsHallPolynomials M.deleteConsistentPresentation F_W K_W R_W) :
    RepresentsHallPolynomials M F (deletePoweringFamily K_W (K (Fin.last n))) R :=
  ⟨hHall.1,
    represents_last_family
      M K F_W K_W R_W hHall.2.1 hHallW,
    hHall.2.2⟩

/--
Bundled Hall-polynomial form of the quotient-lifted powering replacement,
with quotient input split to represented powering.
-/
theorem polynomials_powering_family
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (hKW : RepresentsPowering M.deleteConsistentPresentation K_W) :
    RepresentsHallPolynomials M F (deletePoweringFamily K_W (K (Fin.last n))) R :=
  ⟨hHall.1,
    represents_powering_family
      M K K_W hHall.2.1 hKW,
    hHall.2.2⟩

/--
Induction-hypothesis-shaped quotient-lifted powering replacement, retaining
specialized and all-integer identities back to the input powering family.
-/
theorem delete_last_polynomials
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (hHallW :
      ∃ (F_W : Fin n → MvPolynomial (MulVar n) ℚ)
        (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
        (R_W : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
          RepresentsHallPolynomials M.deleteConsistentPresentation
            F_W K_W R_W) :
    ∃ K' : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ,
      RepresentsHallPolynomials M F K' R ∧
      (∀ i, specializePower T (K i) = specializePower T (K' i)) ∧
      ∀ (x : Fin (n + 1) → ℤ) (z : ℤ) i,
        evalPowerPolynomial T x z (K i) =
          evalPowerPolynomial T x z (K' i) := by
  rcases hHallW with ⟨F_W, K_W, R_W, hHallW⟩
  refine ⟨deletePoweringFamily K_W (K (Fin.last n)), ?_, ?_, ?_⟩
  · exact polynomials_last_powering
      M F K R F_W K_W R_W hHall hHallW
  · intro i
    exact specialize_delete_represents
      M K F_W K_W R_W hHall.2.1 hHallW i
  · intro x z i
    exact delete_powering_represents
      M K F_W K_W R_W hHall.2.1 hHallW x z i

/--
Quotient-lifted powering replacement from an existential represented quotient
powering family, without requiring quotient multiplication or conjugation data.
-/
theorem delete_last_powering
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (hKW :
      ∃ K_W : Fin n → MvPolynomial (PowerVar n) ℚ,
        RepresentsPowering M.deleteConsistentPresentation K_W) :
    ∃ K' : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ,
      RepresentsHallPolynomials M F K' R ∧
      (∀ i, specializePower T (K i) = specializePower T (K' i)) ∧
      ∀ (x : Fin (n + 1) → ℤ) (z : ℤ) i,
        evalPowerPolynomial T x z (K i) =
          evalPowerPolynomial T x z (K' i) := by
  rcases hKW with ⟨K_W, hKW⟩
  refine ⟨deletePoweringFamily K_W (K (Fin.last n)), ?_, ?_, ?_⟩
  · exact polynomials_powering_family
      M F K R K_W hHall hKW
  · intro i
    exact specialize_last_represents
      M K K_W hHall.2.1 hKW i
  · intro x z i
    exact delete_last_represents
      M K K_W hHall.2.1 hKW x z i

/--
If a replacement conjugation polynomial agrees with a represented coordinate
on all integer inputs, then updating that coordinate preserves the
conjugation representation predicate.
-/
theorem conjugation_update_conj
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hR : RepresentsConjugation M R)
    (I : ParameterIndex n) (p : MvPolynomial (ConjVar n) ℚ)
    (hEval : ∀ u v,
      evalConjPolynomial T u v (R I) = evalConjPolynomial T u v p) :
    RepresentsConjugation M (Function.update R I p) := by
  intro i j hij u v k
  by_cases hki : k = i
  · subst k
    simpa [conjugationCoordinateQ] using hR i j hij u v i
  · by_cases hkj : k = j
    · subst k
      simpa [conjugationCoordinateQ, ne_of_gt hij] using hR i j hij u v j
    · by_cases hjk : j < k
      · rw [conjugation_q_tail T (Function.update R I p) i j k hij hjk u v]
        by_cases hI : (⟨(i, j, k), hij, hjk⟩ : ParameterIndex n) = I
        · rw [hI, Function.update_self]
          have hbase := hR i j hij u v k
          rw [conjugation_q_tail T R i j k hij hjk u v] at hbase
          rw [hI] at hbase
          exact hbase.trans (hEval u v)
        · rw [Function.update_of_ne hI]
          simpa [conjugationCoordinateQ, hki, hkj, hjk] using hR i j hij u v k
      · simpa [conjugationCoordinateQ, hki, hkj, hjk] using hR i j hij u v k

/--
Bundled Hall-polynomial form of Section 4's specialized associator theorem:
the associator polynomial vanishes after specializing the parameters.
-/
theorem specialized_associator_represents
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hHall : RepresentsHallPolynomials M F K R) (i : Fin n) :
    specializeAssoc T (associatorPolynomial F i) = 0 :=
  specialized_zero M F hHall.1 i

/--
Bundled Hall-polynomial coefficient form of Section 4's associator theorem.
-/
theorem specialized_associator_polynomials
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hHall : RepresentsHallPolynomials M F K R) (i : Fin n)
    (m : TripleVar n →₀ ℕ) :
    (specializeAssoc T (associatorPolynomial F i)).coeff m = 0 :=
  specialized_coeff_zero M F hHall.1 i m

/--
Bundled Hall-polynomial parameter-coefficient form of Section 4's associator
theorem.
-/
theorem associator_vanishes_polynomials
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hHall : RepresentsHallPolynomials M F K R) (i : Fin n)
    (m : TripleVar n →₀ ℕ) :
    parameterEvaluation T (associatorCoefficientPolynomial F i m) = 0 :=
  associator_polynomial_vanishes M F hHall.1 i m

theorem consistency_locus_polynomials
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hHall : RepresentsHallPolynomials M F K R) :
    consistencyObstructionLocus F T :=
  consistency_locus_represents M F hHall.1

theorem consistency_vanishing_polynomials
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hHall : RepresentsHallPolynomials M F K R) :
    consistencyObstructionIdeal F ≤ vanishingIdealAt T :=
  consistency_ideal_vanishing M F hHall.1

theorem remainder_obstruction_polynomials
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    {p r : MvPolynomial (ParameterIndex n) ℚ}
    (h : p - r ∈ consistencyObstructionIdeal F) :
    parameterEvaluation T r = parameterEvaluation T p :=
  remainder_obstruction_ideal M F hHall.1 h

theorem
    remainder_represents_polynomials
    {T : ParameterIndex n → ℤ} {σ : Type*}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    {p r : MvPolynomial σ (MvPolynomial (ParameterIndex n) ℚ)}
    (h : coefficientwiseSubMem (consistencyObstructionIdeal F) p r) :
    MvPolynomial.map (parameterEvaluation T) r =
      MvPolynomial.map (parameterEvaluation T) p :=
  coefficientwise_sub_consistency M F hHall.1 h

theorem remainder_coeff_polynomials
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    {p r : MvPolynomial (MulVar n) ℚ}
    (h : coefficientwiseSubMem (consistencyObstructionIdeal F)
      (mulInputPolynomial p) (mulInputPolynomial r))
    (x y : Fin n → ℤ) :
    evalMulPolynomial T x y r = evalMulPolynomial T x y p :=
  remainder_coefficientwise_sub
    M F hHall.1 h x y

/--
Bundled Hall-polynomial Section 4 corollary as a specialized multiplication
polynomial identity.
-/
theorem specialize_remainder_consistency
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    {p r : MvPolynomial (MulVar n) ℚ}
    (h : coefficientwiseSubMem (consistencyObstructionIdeal F)
      (mulInputPolynomial p) (mulInputPolynomial r)) :
    specializeMul T r = specializeMul T p :=
  specialize_coefficientwise_ideal
    M F hHall.1 h

theorem remainder_consistency_polynomials
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    {p r : MvPolynomial (PowerVar n) ℚ}
    (h : coefficientwiseSubMem (consistencyObstructionIdeal F)
      (powerInputPolynomial p) (powerInputPolynomial r))
    (x : Fin n → ℤ) (z : ℤ) :
    evalPowerPolynomial T x z r = evalPowerPolynomial T x z p :=
  remainder_coeff_ideal
    M F hHall.1 h x z

/--
Bundled Hall-polynomial Section 4 corollary as a specialized powering
polynomial identity.
-/
theorem specialize_remainder_polynomials
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    {p r : MvPolynomial (PowerVar n) ℚ}
    (h : coefficientwiseSubMem (consistencyObstructionIdeal F)
      (powerInputPolynomial p) (powerInputPolynomial r)) :
    specializePower T r = specializePower T p :=
  specialize_remainder_ideal M F hHall.1 h

lemma represents_conjugation_left
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hR : RepresentsConjugation M R)
    (i j : Fin n) (hij : i < j) (u v : ℤ) :
    (M.conjugationTuple i j u v i : ℚ) = (v : ℚ) := by
  simpa [CPres.conjugationTuple] using hR i j hij u v i

lemma conjugation_coordinate_represents
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hR : RepresentsConjugation M R)
    (i j : Fin n) (hij : i < j) (u v : ℤ) :
    M.conjugationTuple i j u v i = v := by
  have hq := represents_conjugation_left M R hR i j hij u v
  exact_mod_cast hq

lemma represents_conjugation_middle
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hR : RepresentsConjugation M R)
    (i j : Fin n) (hij : i < j) (u v : ℤ) :
    (M.conjugationTuple i j u v j : ℚ) = (u : ℚ) := by
  simpa [CPres.conjugationTuple] using hR i j hij u v j

lemma tail_coordinate_represents
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hR : RepresentsConjugation M R)
    (i j k : Fin n) (hij : i < j) (hjk : j < k) (u v : ℤ) :
    evalConjPolynomial T u v (R ⟨(i, j, k), hij, hjk⟩) =
      (M.conjugationTuple i j u v k : ℚ) := by
  have h := hR i j hij u v k
  rw [conjugation_q_tail T R i j k hij hjk u v] at h
  simpa [CPres.conjugationTuple] using h.symm

lemma forward_difference_tail
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hR : RepresentsConjugation M R)
    (i j k : Fin n) (hij : i < j) (hjk : j < k) (u v : ℤ) :
    evalConjPolynomial T u v
        (conjForwardV R ⟨(i, j, k), hij, hjk⟩) =
      (M.conjugationTuple i j u (v + 1) k : ℚ) -
        (M.conjugationTuple i j u v k : ℚ) := by
  rw [difference_v_polynomial,
    tail_coordinate_represents M R hR i j k hij hjk u (v + 1),
    tail_coordinate_represents M R hR i j k hij hjk u v]

lemma difference_tail_represents
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hR : RepresentsConjugation M R)
    (i j k : Fin n) (hij : i < j) (hjk : j < k) (v : ℤ) :
    conjOnePolynomial T v
        (forwardDifferenceV R ⟨(i, j, k), hij, hjk⟩) =
      (M.conjugationTuple i j 1 (v + 1) k : ℚ) -
        (M.conjugationTuple i j 1 v k : ℚ) := by
  rw [forward_difference_v,
    tail_coordinate_represents M R hR i j k hij hjk 1 (v + 1),
    tail_coordinate_represents M R hR i j k hij hjk 1 v]

lemma conj_right_represents
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hR : RepresentsConjugation M R)
    (i j k : Fin n) (hij : i < j) (hjk : j < k) (u : ℤ) :
    evalConjPolynomial T u 0 (R ⟨(i, j, k), hij, hjk⟩) = 0 := by
  rw [tail_coordinate_represents M R hR i j k hij hjk u 0]
  rw [M.conjugation_tuple_right i j u]
  simp [singleCoord, ne_of_gt hjk]

lemma conj_left_represents
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hR : RepresentsConjugation M R)
    (i j k : Fin n) (hij : i < j) (hjk : j < k) (v : ℤ) :
    evalConjPolynomial T 0 v (R ⟨(i, j, k), hij, hjk⟩) = 0 := by
  rw [tail_coordinate_represents M R hR i j k hij hjk 0 v]
  rw [M.conjugation_tuple_left i j v]
  simp [singleCoord, ne_of_gt (hij.trans hjk)]

/--
For conjugation by the first generator, left conjugation removes the first
coordinate from the normal form supplied by the conjugation polynomials.
-/
theorem conjugation_tuple_without
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hR : RepresentsConjugation M R)
    (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (u v : ℤ) :
    M.leftConjugationTuple 0 j u v =
      withoutFirstCoord (M.conjugationTuple 0 j u v) := by
  exact M.conjugation_without_coord
    j u v (conjugation_coordinate_represents M R hR 0 j h0j u v)

lemma conjugation_tuple_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hR : RepresentsConjugation M R)
    (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (u v : ℤ) :
    M.leftConjugationTuple 0 j u v 0 = 0 := by
  exact M.left_conjugation_coord j u v
    (conjugation_coordinate_represents M R hR 0 j h0j u v)

lemma conjugation_middle_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hR : RepresentsConjugation M R)
    (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (u v : ℤ) :
    (M.leftConjugationTuple 0 j u v j : ℚ) = (u : ℚ) := by
  rw [M.conjugation_tuple_coord j j u v
    (conjugation_coordinate_represents M R hR 0 j h0j u v) (ne_of_gt h0j)]
  exact represents_conjugation_middle M R hR 0 j h0j u v

lemma left_conjugation_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hR : RepresentsConjugation M R)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k) (u v : ℤ) :
    (M.leftConjugationTuple 0 j u v k : ℚ) =
      evalConjPolynomial T u v (R ⟨(0, j, k), h0j, hjk⟩) := by
  rw [M.conjugation_tuple_coord j k u v
    (conjugation_coordinate_represents M R hR 0 j h0j u v)
    (ne_of_gt (h0j.trans hjk))]
  exact (tail_coordinate_represents M R hR 0 j k h0j hjk u v).symm

lemma conjugation_position_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hR : RepresentsConjugation M R)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j)
    (hk0 : k ≠ 0) (hkj : k ≠ j) (hjk : ¬ j < k) (u v : ℤ) :
    (M.leftConjugationTuple 0 j u v k : ℚ) = 0 := by
  rw [M.conjugation_tuple_coord j k u v
    (conjugation_coordinate_represents M R hR 0 j h0j u v) hk0]
  have h := hR 0 j h0j u v k
  simpa [CPres.conjugationTuple, conjugationCoordinateQ, hk0, hkj, hjk]
    using h

/--
Substitution used in the multiplication display `(*)`: evaluate a conjugation
polynomial at `u = x_j` and `v = y_0`.
-/
def conjMulSubst {n : ℕ} (j : Fin (n + 1)) :
    ConjVar (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ
  | ConjVar.param I => MvPolynomial.X (MulVar.param I)
  | ConjVar.u => MvPolynomial.X (MulVar.left j)
  | ConjVar.v => MvPolynomial.X (MulVar.right 0)

lemma eval_conj_polynomial {n : ℕ}
    (j : Fin (n + 1)) (T : ParameterIndex (n + 1) → ℤ)
    (x y : Fin (n + 1) → ℤ) (p : MvPolynomial (ConjVar (n + 1)) ℚ) :
    MvPolynomial.eval (evalMulVar T x y)
        (MvPolynomial.eval₂Hom MvPolynomial.C (conjMulSubst j) p) =
      evalConjPolynomial T (x j) (y 0) p := by
  change
    MvPolynomial.eval (evalMulVar T x y)
        (MvPolynomial.eval₂ MvPolynomial.C (conjMulSubst j) p) =
      MvPolynomial.eval (evalConjVar T (x j) (y 0)) p
  rw [← MvPolynomial.eval_assoc]
  apply congrArg (fun f : ConjVar (n + 1) → ℚ => MvPolynomial.eval f p)
  funext w
  cases w <;> simp [conjMulSubst, evalMulVar, mulVarQ,
    evalConjVar, varQ]

/--
The coordinate-polynomial tuple for the displayed factor
`a_j^{x_j} a_{j+1}^{R_{0,j,j+1}(T;x_j,y_0)} ... a_n^{R_{0,j,n}(T;x_j,y_0)}`
inside Cant--Eick's multiplication formula `(*)`.
-/
def firstConjugatedFactor {n : ℕ}
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) :
    Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ :=
  fun k =>
    if k = j then
      MvPolynomial.X (MulVar.left j)
    else if h : j < k then
      MvPolynomial.eval₂Hom MvPolynomial.C (conjMulSubst j)
        (R ⟨(0, j, k), h0j, h⟩)
      else
        0

theorem first_conjugated_factor
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j)
    (x y : Fin (n + 1) → ℤ) (k : Fin (n + 1))
    (hMiddle :
      (M.leftConjugationTuple 0 j (x j) (y 0) j : ℚ) = (x j : ℚ))
    (hTail : ∀ l (hjl : j < l),
      evalConjPolynomial T (x j) (y 0) (R ⟨(0, j, l), h0j, hjl⟩) =
        (M.leftConjugationTuple 0 j (x j) (y 0) l : ℚ))
    (hFirst :
      (M.leftConjugationTuple 0 j (x j) (y 0) 0 : ℚ) = 0)
    (hZero : ∀ l,
      l ≠ 0 → l ≠ j → ¬ j < l →
        (M.leftConjugationTuple 0 j (x j) (y 0) l : ℚ) = 0) :
    MvPolynomial.eval (evalMulVar T x y)
        (firstConjugatedFactor R j h0j k) =
      (M.leftConjugationTuple 0 j (x j) (y 0) k : ℚ) := by
  by_cases hkj : k = j
  · subst k
    simpa [firstConjugatedFactor, evalMulVar, mulVarQ]
      using hMiddle.symm
  · by_cases hjk : j < k
    · rw [show firstConjugatedFactor R j h0j k =
          MvPolynomial.eval₂Hom MvPolynomial.C (conjMulSubst j)
            (R ⟨(0, j, k), h0j, hjk⟩) by
        simp [firstConjugatedFactor, hkj, hjk]]
      rw [eval_conj_polynomial]
      exact hTail k hjk
    · by_cases hk0 : k = 0
      · subst k
        have h0ne : ¬ (0 : Fin (n + 1)) = j := ne_of_lt h0j
        have hnotlt : ¬ j < (0 : Fin (n + 1)) := not_lt_of_ge (le_of_lt h0j)
        simp [firstConjugatedFactor, h0ne, hnotlt, hFirst]
      · simpa [firstConjugatedFactor, hkj, hjk] using
          (hZero k hk0 hkj hjk).symm

theorem conjugated_factor_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hR : RepresentsConjugation M R)
    (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j)
    (x y : Fin (n + 1) → ℤ) (k : Fin (n + 1)) :
    MvPolynomial.eval (evalMulVar T x y)
        (firstConjugatedFactor R j h0j k) =
      (M.leftConjugationTuple 0 j (x j) (y 0) k : ℚ) := by
  exact first_conjugated_factor M R j h0j x y k
    (conjugation_middle_represents
      M R hR j h0j (x j) (y 0))
    (fun l hjl =>
      (left_conjugation_represents
        M R hR j l h0j hjl (x j) (y 0)).symm)
    (by
      exact_mod_cast
        (conjugation_tuple_represents
          M R hR j h0j (x j) (y 0)))
    (fun l hl0 hlj hnot =>
      conjugation_position_represents
        M R hR j l h0j hl0 hlj hnot (x j) (y 0))

/-- Parameter variables as multiplication-variable polynomials. -/
def mulParameterPolynomial {n : ℕ} :
    ParameterIndex n → MvPolynomial (MulVar n) ℚ :=
  fun I => MvPolynomial.X (MulVar.param I)

/--
Parameter variables for the lower-rank `U(T)` multiplication polynomials,
viewed as polynomials in the ambient length-`n+1` multiplication variables.
-/
def deleteFirstParameter {n : ℕ} :
    ParameterIndex n → MvPolynomial (MulVar (n + 1)) ℚ :=
  fun I => MvPolynomial.X (MulVar.param (parameterSuccAbove (0 : Fin (n + 1)) I))

/--
The `U(T)` tail-coordinate tuple of one conjugated factor in the Section 3.3
display, viewed as ambient multiplication-variable polynomials.
-/
def firstConjugatedPolynomial {n : ℕ}
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j : Fin n) :
    Fin n → MvPolynomial (MulVar (n + 1)) ℚ :=
  fun k =>
    firstConjugatedFactor R (Fin.succ j) (by exact Nat.succ_pos j.val)
      (Fin.succ k)

/--
Lower-rank version of `firstConjugatedTail`: it multiplies
the conjugated tail factors using multiplication polynomials for `U(T)`, not
the ambient length-`n+1` multiplication family.
-/
def firstConjugatedU {n : ℕ}
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ) :
    Fin n → MvPolynomial (MulVar (n + 1)) ℚ :=
  normalProductPolynomial F_U deleteFirstParameter
    ((List.finRange n).map fun i => firstConjugatedPolynomial R i)

/--
Exact-premise lower-rank form of the displayed tail product.  It needs only
the evaluations of the individual first-conjugated tail factors and the fact
that those factors have zero first ambient coordinate; no represented ambient
conjugation family is required.
-/
theorem conjugated_tail_u
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hMul : ∀ a b : M.G,
      M.coord a 0 = 0 → M.coord b 0 = 0 → M.coord (a * b) 0 = 0)
    (hInv : ∀ a : M.G, M.coord a 0 = 0 → M.coord a⁻¹ 0 = 0)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication
      (M.firstConsistentPresentation hMul hInv) F_U)
    (x y : Fin (n + 1) → ℤ) (k : Fin n)
    (hFactor : ∀ i k,
      MvPolynomial.eval (evalMulVar T x y) (firstConjugatedPolynomial R i k) =
        (M.leftConjugationTuple 0 (Fin.succ i) (x (Fin.succ i)) (y 0)
          (Fin.succ k) : ℚ))
    (hZero : ∀ i,
      M.leftConjugationTuple 0 (Fin.succ i) (x (Fin.succ i)) (y 0) 0 = 0) :
    evalMulPolynomial T x y (firstConjugatedU F_U R k) =
      (M.coord (M.firstConjugatedProduct x (y 0)) (Fin.succ k) : ℚ) := by
  let MU := M.firstConsistentPresentation hMul hInv
  let items : List
      ((Fin n → MvPolynomial (MulVar (n + 1)) ℚ) × (Fin n → ℤ)) :=
    (List.finRange n).map fun i =>
      (firstConjugatedPolynomial R i,
        Fin.tail (M.leftConjugationTuple 0 (Fin.succ i) (x (Fin.succ i)) (y 0)))
  have hitems :
      ∀ item ∈ items, ∀ k,
        MvPolynomial.eval (evalMulVar T x y) (item.1 k) = (item.2 k : ℚ) := by
    intro item hitem k
    rcases List.mem_map.mp hitem with ⟨i, _hi, rfl⟩
    change
      MvPolynomial.eval (evalMulVar T x y) (firstConjugatedPolynomial R i k) =
        (Fin.tail (M.leftConjugationTuple 0 (Fin.succ i) (x (Fin.succ i)) (y 0))
          k : ℚ)
    simpa [Fin.tail] using hFactor i k
  have hprod :=
    coord_prod_represents
      MU F_U hFU deleteFirstParameter (evalMulVar T x y)
      (by
        intro I
        simp [deleteFirstParameter, firstParameterTuple,
          deleteParameterTuple, evalMulVar, mulVarQ])
      items hitems k
  let tailProd : M.firstCoordinateSubgroup hMul hInv :=
    show M.firstCoordinateSubgroup hMul hInv from
      (items.map fun item => MU.normalWord item.2).prod
  have hcoe :
      (tailProd : M.G) = M.firstConjugatedProduct x (y 0) := by
    change ((show M.firstCoordinateSubgroup hMul hInv from
          (items.map fun item => MU.normalWord item.2).prod) : M.G) =
        M.firstConjugatedProduct x (y 0)
    have hvalprod :
        ((show M.firstCoordinateSubgroup hMul hInv from
            (items.map fun item => MU.normalWord item.2).prod) : M.G) =
          ((items.map fun item =>
            ((show M.firstCoordinateSubgroup hMul hInv from
              MU.normalWord item.2) : M.G))).prod := by
      change (((items.map fun item =>
            (show M.firstCoordinateSubgroup hMul hInv from
              MU.normalWord item.2)).prod :
          M.firstCoordinateSubgroup hMul hInv) : M.G) =
        ((items.map fun item =>
          ((show M.firstCoordinateSubgroup hMul hInv from
            MU.normalWord item.2) : M.G))).prod
      rw [Subgroup.val_list_prod]
      rw [List.map_map]
      rfl
    rw [hvalprod]
    unfold items CPres.firstConjugatedProduct
    simp only [List.map_map]
    apply congrArg List.prod
    apply List.map_congr_left
    intro i _hi
    have hzero := hZero i
    change ((show M.firstCoordinateSubgroup hMul hInv from
        MU.normalWord
          (Fin.tail (M.leftConjugationTuple 0 (Fin.succ i) (x (Fin.succ i)) (y 0)))) :
        M.G) =
      M.normalWord (M.leftConjugationTuple 0 (Fin.succ i) (x (Fin.succ i)) (y 0))
    rw [M.first_consistent_coe hMul hInv]
    exact (M.normal_tail_first
      (M.leftConjugationTuple 0 (Fin.succ i) (x (Fin.succ i)) (y 0)) hzero).symm
  have hcoord :=
    M.first_consistent_coord hMul hInv tailProd
  have hk := congrFun hcoord k
  calc
    evalMulPolynomial T x y (firstConjugatedU F_U R k)
        =
          MvPolynomial.eval (evalMulVar T x y)
            (normalProductPolynomial F_U deleteFirstParameter
              (items.map Prod.fst) k) := by
            change
              MvPolynomial.eval (evalMulVar T x y)
                  (normalProductPolynomial F_U deleteFirstParameter
                    ((List.finRange n).map fun i => firstConjugatedPolynomial R i)
                    k) =
                MvPolynomial.eval (evalMulVar T x y)
                  (normalProductPolynomial F_U deleteFirstParameter
                    (items.map Prod.fst) k)
            rw [show items.map Prod.fst =
                (List.finRange n).map (fun i => firstConjugatedPolynomial R i) by
              simp [items]]
    _ = (MU.coord (show MU.G from tailProd) k : ℚ) := by
          simpa [tailProd] using hprod
    _ = (M.coord (tailProd : M.G) (Fin.succ k) : ℚ) := by
          exact_mod_cast hk
    _ = (M.coord (M.firstConjugatedProduct x (y 0)) (Fin.succ k) : ℚ) := by
          rw [hcoe]

theorem conjugated_u_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hMul : ∀ a b : M.G,
      M.coord a 0 = 0 → M.coord b 0 = 0 → M.coord (a * b) 0 = 0)
    (hInv : ∀ a : M.G, M.coord a 0 = 0 → M.coord a⁻¹ 0 = 0)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication
      (M.firstConsistentPresentation hMul hInv) F_U)
    (hR : RepresentsConjugation M R)
    (x y : Fin (n + 1) → ℤ) (k : Fin n) :
    evalMulPolynomial T x y (firstConjugatedU F_U R k) =
      (M.coord (M.firstConjugatedProduct x (y 0)) (Fin.succ k) : ℚ) := by
  let MU := M.firstConsistentPresentation hMul hInv
  let items : List
      ((Fin n → MvPolynomial (MulVar (n + 1)) ℚ) × (Fin n → ℤ)) :=
    (List.finRange n).map fun i =>
      (firstConjugatedPolynomial R i,
        Fin.tail (M.leftConjugationTuple 0 (Fin.succ i) (x (Fin.succ i)) (y 0)))
  have hitems :
      ∀ item ∈ items, ∀ k,
        MvPolynomial.eval (evalMulVar T x y) (item.1 k) = (item.2 k : ℚ) := by
    intro item hitem k
    rcases List.mem_map.mp hitem with ⟨i, _hi, rfl⟩
    change
      MvPolynomial.eval (evalMulVar T x y)
          (firstConjugatedFactor R (Fin.succ i)
            (by exact Nat.succ_pos i.val) (Fin.succ k)) =
        (M.leftConjugationTuple 0 (Fin.succ i) (x (Fin.succ i)) (y 0)
          (Fin.succ k) : ℚ)
    exact conjugated_factor_represents
      M R hR (Fin.succ i) (by exact Nat.succ_pos i.val) x y (Fin.succ k)
  have hprod :=
    coord_prod_represents
      MU F_U hFU deleteFirstParameter (evalMulVar T x y)
      (by
        intro I
        simp [deleteFirstParameter, firstParameterTuple,
          deleteParameterTuple, evalMulVar, mulVarQ])
      items hitems k
  let tailProd : M.firstCoordinateSubgroup hMul hInv :=
    show M.firstCoordinateSubgroup hMul hInv from
      (items.map fun item => MU.normalWord item.2).prod
  have hcoe :
      (tailProd : M.G) = M.firstConjugatedProduct x (y 0) := by
    change ((show M.firstCoordinateSubgroup hMul hInv from
          (items.map fun item => MU.normalWord item.2).prod) : M.G) =
        M.firstConjugatedProduct x (y 0)
    have hvalprod :
        ((show M.firstCoordinateSubgroup hMul hInv from
            (items.map fun item => MU.normalWord item.2).prod) : M.G) =
          ((items.map fun item =>
            ((show M.firstCoordinateSubgroup hMul hInv from
              MU.normalWord item.2) : M.G))).prod := by
      change (((items.map fun item =>
            (show M.firstCoordinateSubgroup hMul hInv from
              MU.normalWord item.2)).prod :
          M.firstCoordinateSubgroup hMul hInv) : M.G) =
        ((items.map fun item =>
          ((show M.firstCoordinateSubgroup hMul hInv from
            MU.normalWord item.2) : M.G))).prod
      rw [Subgroup.val_list_prod]
      rw [List.map_map]
      rfl
    rw [hvalprod]
    unfold items CPres.firstConjugatedProduct
    simp only [List.map_map]
    apply congrArg List.prod
    apply List.map_congr_left
    intro i _hi
    have hzero :=
      conjugation_tuple_represents
        M R hR (Fin.succ i) (by exact Nat.succ_pos i.val) (x (Fin.succ i)) (y 0)
    change ((show M.firstCoordinateSubgroup hMul hInv from
        MU.normalWord
          (Fin.tail (M.leftConjugationTuple 0 (Fin.succ i) (x (Fin.succ i)) (y 0)))) :
        M.G) =
      M.normalWord (M.leftConjugationTuple 0 (Fin.succ i) (x (Fin.succ i)) (y 0))
    rw [M.first_consistent_coe hMul hInv]
    exact (M.normal_tail_first
      (M.leftConjugationTuple 0 (Fin.succ i) (x (Fin.succ i)) (y 0)) hzero).symm
  have hcoord :=
    M.first_consistent_coord hMul hInv tailProd
  have hk := congrFun hcoord k
  calc
    evalMulPolynomial T x y (firstConjugatedU F_U R k)
        =
          MvPolynomial.eval (evalMulVar T x y)
            (normalProductPolynomial F_U deleteFirstParameter
              (items.map Prod.fst) k) := by
            change
              MvPolynomial.eval (evalMulVar T x y)
                  (normalProductPolynomial F_U deleteFirstParameter
                    ((List.finRange n).map fun i => firstConjugatedPolynomial R i)
                    k) =
                MvPolynomial.eval (evalMulVar T x y)
                  (normalProductPolynomial F_U deleteFirstParameter
                    (items.map Prod.fst) k)
            rw [show items.map Prod.fst =
                (List.finRange n).map (fun i => firstConjugatedPolynomial R i) by
              simp [items]]
    _ = (MU.coord (show MU.G from tailProd) k : ℚ) := by
          simpa [tailProd] using hprod
    _ = (M.coord (tailProd : M.G) (Fin.succ k) : ℚ) := by
          exact_mod_cast hk
    _ = (M.coord (M.firstConjugatedProduct x (y 0)) (Fin.succ k) : ℚ) := by
          rw [hcoe]

theorem conjugated_u_additive
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hAdd : CPres.CoordinateAdditive M 0)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication
      (M.firstConsistentAdditive hAdd) F_U)
    (hR : RepresentsConjugation M R)
    (x y : Fin (n + 1) → ℤ) (k : Fin n) :
    evalMulPolynomial T x y (firstConjugatedU F_U R k) =
      (M.coord (M.firstConjugatedProduct x (y 0)) (Fin.succ k) : ℚ) := by
  let hClosed := CPres.coordinate_closed_additive M 0 hAdd
  simpa [CPres.firstConsistentAdditive,
    hClosed] using
    conjugated_u_represents
      M hClosed.1 hClosed.2 F_U R hFU hR x y k

theorem first_conjugated_u
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hR : RepresentsConjugation M R)
    (x y : Fin (n + 1) → ℤ) (k : Fin n) :
    evalMulPolynomial T x y (firstConjugatedU F_U R k) =
      (M.coord (M.firstConjugatedProduct x (y 0)) (Fin.succ k) : ℚ) :=
  conjugated_u_additive
    M M.firstCoordinateAdditive F_U R hFU hR x y k

lemma conjugated_coord_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hMul : ∀ a b : M.G,
      M.coord a 0 = 0 → M.coord b 0 = 0 → M.coord (a * b) 0 = 0)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hR : RepresentsConjugation M R)
    (x : Fin (n + 1) → ℤ) (v : ℤ) :
    M.coord (M.firstConjugatedProduct x v) 0 = 0 := by
  exact M.first_conjugated_factors hMul x v
    (fun i =>
      conjugation_tuple_represents
        M R hR (Fin.succ i) (by exact Nat.succ_pos i.val) (x (Fin.succ i)) v)

lemma multiplication_tail_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hMul : ∀ a b : M.G,
      M.coord a 0 = 0 → M.coord b 0 = 0 → M.coord (a * b) 0 = 0)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hR : RepresentsConjugation M R)
    (x y : Fin (n + 1) → ℤ) :
    M.coord (M.firstConjugatedProduct x (y 0) *
      M.normalWord (withoutFirstCoord y)) 0 = 0 := by
  exact M.multiplication_display_conjugated
    hMul x y (conjugated_coord_represents M hMul R hR x (y 0))

lemma multiplication_display_coord
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hAdd : CPres.CoordinateAdditive M 0)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hR : RepresentsConjugation M R)
    (x y : Fin (n + 1) → ℤ) :
    M.coord (M.firstConjugatedProduct x (y 0) *
      M.normalWord (withoutFirstCoord y)) 0 = 0 := by
  let hClosed := CPres.coordinate_closed_additive M 0 hAdd
  exact multiplication_tail_represents M hClosed.1 R hR x y

lemma multiplication_display_zero
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (x y : Fin (n + 1) → ℤ) :
    M.coord (M.firstConjugatedProduct x (y 0) *
      M.normalWord (withoutFirstCoord y)) 0 = 0 :=
  M.firstDisplayTail x y

/--
The polynomial tuple obtained by multiplying all conjugated-tail factors in
the Section 3.3 display `(*)`.
-/
def firstConjugatedTail {n : ℕ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ) :
    Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ :=
  normalProductPolynomial F mulParameterPolynomial
    ((List.finRange n).map fun i =>
      firstConjugatedFactor R (Fin.succ i) (by
        exact Nat.succ_pos i.val))

theorem first_conjugated_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hR : RepresentsConjugation M R)
    (x y : Fin (n + 1) → ℤ) (k : Fin (n + 1)) :
    evalMulPolynomial T x y (firstConjugatedTail F R k) =
      (M.coord (M.firstConjugatedProduct x (y 0)) k : ℚ) := by
  let items : List
      ((Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ) × (Fin (n + 1) → ℤ)) :=
    (List.finRange n).map fun i =>
      (firstConjugatedFactor R (Fin.succ i) (by
          exact Nat.succ_pos i.val),
        M.leftConjugationTuple 0 (Fin.succ i) (x (Fin.succ i)) (y 0))
  have hitems :
      ∀ item ∈ items, ∀ k,
        MvPolynomial.eval (evalMulVar T x y) (item.1 k) = (item.2 k : ℚ) := by
    intro item hitem k
    rcases List.mem_map.mp hitem with ⟨i, _hi, rfl⟩
    exact conjugated_factor_represents
      M R hR (Fin.succ i) (by exact Nat.succ_pos i.val) x y k
  have hprod :=
    coord_prod_represents
      M F hF mulParameterPolynomial (evalMulVar T x y)
      (by intro I; simp [mulParameterPolynomial, evalMulVar, mulVarQ])
      items hitems k
  simpa [firstConjugatedTail, items,
    CPres.firstConjugatedProduct]
    using hprod

/--
Substitution for the Section 3.2 product recursion.  It evaluates the
multiplication display variables at the current tuple
`a_1^{-v} a_j a_1^v` and at one extra conjugation by `a_1`.
-/
def conjStepSubst {n : ℕ}
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) :
    MulVar (n + 1) → MvPolynomial (ConjOneVar (n + 1)) ℚ
  | MulVar.param I => MvPolynomial.X (ConjOneVar.param I)
  | MulVar.left i =>
      if i = j then
        MvPolynomial.C 1
      else if hji : j < i then
        conjUPolynomial (R ⟨(0, j, i), h0j, hji⟩)
      else
        0
  | MulVar.right i => if i = 0 then MvPolynomial.C 1 else 0

/--
The coordinate polynomial of the displayed Section 3.2 product that computes
the next `R_{0,j,k}(T;1,v+1)` value before subtracting the previous value.
-/
def conjStep2 {n : ℕ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j)
    (k : Fin (n + 1)) :
    MvPolynomial (ConjOneVar (n + 1)) ℚ :=
  MvPolynomial.eval₂Hom MvPolynomial.C (conjStepSubst R j h0j)
    (firstConjugatedTail F R k)

/--
Lower-rank version of `conjStep2`: the tail product is
computed with multiplication polynomials for `U(T)` instead of the ambient
length-`n+1` multiplication family.
-/
def conj2U {n : ℕ}
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j)
    (k : Fin n) :
    MvPolynomial (ConjOneVar (n + 1)) ℚ :=
  MvPolynomial.eval₂Hom MvPolynomial.C (conjStepSubst R j h0j)
    (firstConjugatedU F_U R k)

/--
The product-derived forward-difference polynomial from Cant--Eick's
constructive proof of Section 3.2 Lemma `step2`.
-/
def conjForwardDifference {n : ℕ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j)
    (k : Fin (n + 1)) (hjk : j < k) :
    MvPolynomial (ConjOneVar (n + 1)) ℚ :=
  conjStep2 F R j h0j k -
    conjUPolynomial (R ⟨(0, j, k), h0j, hjk⟩)

/-- Lower-rank `U(T)` version of the Section 3.2 step-2 forward difference. -/
def forwardDifferenceU {n : ℕ}
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j)
    (k : Fin n) (hjk : j < Fin.succ k) :
    MvPolynomial (ConjOneVar (n + 1)) ℚ :=
  conj2U F_U R j h0j k -
    conjUPolynomial (R ⟨(0, j, Fin.succ k), h0j, hjk⟩)

/--
The zero-initial Bernoulli solution of the product-derived Section 3.2
step-2 recursion, as a polynomial in the parameters and `v`.
-/
def conjSolutionPolynomial {n : ℕ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j)
    (k : Fin (n + 1)) (hjk : j < k) :
    MvPolynomial (ConjOneVar (n + 1)) ℚ :=
  conjForwardAntiderivative
    (conjForwardDifference F R j h0j k hjk)

/--
Lower-rank `U(T)` version of `conjSolutionPolynomial`, using
multiplication polynomials for the canonical `U(T)` presentation.
-/
def conjSolutionU {n : ℕ}
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j)
    (k : Fin n) (hjk : j < Fin.succ k) :
    MvPolynomial (ConjOneVar (n + 1)) ℚ :=
  conjForwardAntiderivative
    (forwardDifferenceU F_U R j h0j k hjk)

/--
Lower-rank `U(T)` Section 3.2 step-2 solution, lifted from `Q[T,v]` to the
full conjugation polynomial ring `Q[T,u,v]` by making it independent of `u`.
-/
def setUSolution {n : ℕ}
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j)
    (k : Fin n) (hjk : j < Fin.succ k) :
    MvPolynomial (ConjVar (n + 1)) ℚ :=
  conjLiftPolynomial (conjSolutionU F_U R j h0j k hjk)

/--
The coordinate tuple for Section 3.2 `step1`, with every `R(T;1,v)` input
above `j` replaced by the lifted lower-rank `U(T)` `step2` solution.
-/
def conjCoordU {n : ℕ}
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j : Fin n) (i : Fin n) :
    MvPolynomial (ConjVar (n + 1)) ℚ :=
  if i = j then
    MvPolynomial.C 1
  else if hji : j < i then
    setUSolution F_U R (Fin.succ j) (Fin.succ_pos j) i
      (Fin.succ_lt_succ_iff.mpr hji)
  else
    0

/--
Combined Section 3.2 `step1`/`step2` lower-rank polynomial: compute the
`step1` powering expression after replacing the `u = 1` conjugation-coordinate
inputs by the lifted `step2` Bernoulli solutions.
-/
def conjStepU {n : ℕ}
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j k : Fin n) :
    MvPolynomial (ConjVar (n + 1)) ℚ :=
  powerComposePolynomial K_U
    (fun I => MvPolynomial.X (ConjVar.param (parameterSuccAbove 0 I)))
    (conjCoordU F_U R j)
    (MvPolynomial.X ConjVar.u) k

/--
Family-level combined Section 3.2 `step1`/`step2` construction: every
coordinate `(0, succ j, succ k)` is replaced by the lower-rank `step1`
powering polynomial whose `R(T;1,v)` inputs have already been supplied by the
lifted `step2` solutions; all other coordinates are left unchanged.
-/
def conjFamilyU {n : ℕ}
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ) :
    ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ :=
  fun I =>
    match I with
    | ⟨(i, j, k), hij, hjk⟩ =>
      Fin.cases
        (R ⟨(i, j, k), hij, hjk⟩)
        (fun j' =>
          Fin.cases
            (R ⟨(i, j, k), hij, hjk⟩)
            (fun k' =>
              if i = 0 then
                conjStepU F_U K_U R j' k'
              else
                R ⟨(i, j, k), hij, hjk⟩)
            k)
        j

/--
Exact-premise form of the Section 3.2 step-2 multiplication substitution:
it only needs the local first-generator conjugation evaluations used by the
substitution, not a represented ambient conjugation family.
-/
lemma eval_conj_subst
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j)
    (v : ℤ)
    (hMiddle : (M.leftConjugationTuple 0 j 1 v j : ℚ) = 1)
    (hTail : ∀ i (hji : j < i),
      evalConjPolynomial T 1 v (R ⟨(0, j, i), h0j, hji⟩) =
        (M.leftConjugationTuple 0 j 1 v i : ℚ))
    (hFirst : (M.leftConjugationTuple 0 j 1 v 0 : ℚ) = 0)
    (hZero : ∀ i,
      i ≠ 0 → i ≠ j → ¬ j < i →
        (M.leftConjugationTuple 0 j 1 v i : ℚ) = 0)
    (w : MulVar (n + 1)) :
    MvPolynomial.eval (conjOneVar T v) (conjStepSubst R j h0j w) =
      evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1) w := by
  cases w with
  | param I =>
      simp [conjStepSubst, conjOneVar, conjVarQ,
        evalMulVar, mulVarQ]
  | left i =>
      by_cases hij : i = j
      · subst i
        simpa [conjStepSubst, evalMulVar, mulVarQ] using hMiddle.symm
      · by_cases hji : j < i
        · rw [show conjStepSubst R j h0j (MulVar.left i) =
              conjUPolynomial (R ⟨(0, j, i), h0j, hji⟩) by
            simp [conjStepSubst, hij, hji]]
          change conjOnePolynomial T v
              (conjUPolynomial (R ⟨(0, j, i), h0j, hji⟩)) =
            (M.leftConjugationTuple 0 j 1 v i : ℚ)
          rw [conj_u_polynomial]
          exact hTail i hji
        · by_cases hi0 : i = 0
          · subst i
            have h0ne : ¬ (0 : Fin (n + 1)) = j := ne_of_lt h0j
            have hnotlt : ¬ j < (0 : Fin (n + 1)) :=
              not_lt_of_ge (le_of_lt h0j)
            simpa [conjStepSubst, h0ne, hnotlt, evalMulVar, mulVarQ]
              using hFirst.symm
          · simpa [conjStepSubst, hij, hji, evalMulVar, mulVarQ]
              using (hZero i hi0 hij hji).symm
  | right i =>
      simp [conjStepSubst, evalMulVar, mulVarQ, singleCoord]

lemma conj_subst_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hR : RepresentsConjugation M R)
    (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j)
    (v : ℤ) (w : MulVar (n + 1)) :
    MvPolynomial.eval (conjOneVar T v) (conjStepSubst R j h0j w) =
      evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1) w := by
  cases w with
  | param I =>
      simp [conjStepSubst, conjOneVar, conjVarQ,
        evalMulVar, mulVarQ]
  | left i =>
      by_cases hij : i = j
      · subst i
        have hmid :=
          conjugation_middle_represents
            M R hR j h0j 1 v
        simpa [conjStepSubst, evalMulVar, mulVarQ] using hmid.symm
      · by_cases hji : j < i
        · have htail :=
            left_conjugation_represents
              M R hR j i h0j hji 1 v
          rw [show conjStepSubst R j h0j (MulVar.left i) =
              conjUPolynomial (R ⟨(0, j, i), h0j, hji⟩) by
            simp [conjStepSubst, hij, hji]]
          change conjOnePolynomial T v
              (conjUPolynomial (R ⟨(0, j, i), h0j, hji⟩)) =
            (M.leftConjugationTuple 0 j 1 v i : ℚ)
          rw [conj_u_polynomial]
          exact htail.symm
        · by_cases hi0 : i = 0
          · subst i
            have hzero :=
              conjugation_tuple_represents
                M R hR j h0j 1 v
            have hzeroq : (M.leftConjugationTuple 0 j 1 v 0 : ℚ) = 0 := by
              exact_mod_cast hzero
            have h0ne : ¬ (0 : Fin (n + 1)) = j := ne_of_lt h0j
            have hnotlt : ¬ j < (0 : Fin (n + 1)) :=
              not_lt_of_ge (le_of_lt h0j)
            simpa [conjStepSubst, h0ne, hnotlt, evalMulVar, mulVarQ]
              using hzeroq.symm
          · have hzero :=
              conjugation_position_represents
                M R hR j i h0j hi0 hij hji 1 v
            simpa [conjStepSubst, hij, hji, evalMulVar, mulVarQ]
              using hzero.symm
  | right i =>
      simp [conjStepSubst, evalMulVar, mulVarQ, singleCoord]

theorem eval_conj_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hR : RepresentsConjugation M R)
    (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j)
    (v : ℤ) (k : Fin (n + 1)) :
    conjOnePolynomial T v (conjStep2 F R j h0j k) =
      (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1) k :
        ℚ) := by
  change
    MvPolynomial.eval (conjOneVar T v)
        (MvPolynomial.eval₂ MvPolynomial.C (conjStepSubst R j h0j)
          (firstConjugatedTail F R k)) =
      (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1) k :
        ℚ)
  rw [← MvPolynomial.eval_assoc]
  have hassign :
      (fun w : MulVar (n + 1) =>
          MvPolynomial.eval (conjOneVar T v) (conjStepSubst R j h0j w)) =
        evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1) := by
    funext w
    exact conj_subst_represents M R hR j h0j v w
  change
    MvPolynomial.eval
        (fun w : MulVar (n + 1) =>
          MvPolynomial.eval (conjOneVar T v) (conjStepSubst R j h0j w))
        (firstConjugatedTail F R k) =
      (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1) k :
        ℚ)
  rw [hassign]
  simpa [singleCoord] using
    first_conjugated_represents
      M F R hF hR (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1) k

/--
Exact-premise lower-rank form of the Section 3.2 step-2 product polynomial.
The substitution and tail-product evaluations are supplied directly, so this
does not require represented ambient conjugation.
-/
theorem eval_conj_u
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hMul : ∀ a b : M.G,
      M.coord a 0 = 0 → M.coord b 0 = 0 → M.coord (a * b) 0 = 0)
    (hInv : ∀ a : M.G, M.coord a 0 = 0 → M.coord a⁻¹ 0 = 0)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication
      (M.firstConsistentPresentation hMul hInv) F_U)
    (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j)
    (v : ℤ) (k : Fin n)
    (hSubst : ∀ w,
      MvPolynomial.eval (conjOneVar T v) (conjStepSubst R j h0j w) =
        evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1) w)
    (hFactor : ∀ i k,
      MvPolynomial.eval
          (evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1))
          (firstConjugatedPolynomial R i k) =
        (M.leftConjugationTuple 0 (Fin.succ i)
          (M.leftConjugationTuple 0 j 1 v (Fin.succ i)) 1 (Fin.succ k) : ℚ))
    (hZero : ∀ i,
      M.leftConjugationTuple 0 (Fin.succ i)
        (M.leftConjugationTuple 0 j 1 v (Fin.succ i)) 1 0 = 0) :
    conjOnePolynomial T v (conj2U F_U R j h0j k) =
      (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1)
        (Fin.succ k) : ℚ) := by
  change
    MvPolynomial.eval (conjOneVar T v)
        (MvPolynomial.eval₂ MvPolynomial.C (conjStepSubst R j h0j)
          (firstConjugatedU F_U R k)) =
      (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1)
        (Fin.succ k) : ℚ)
  rw [← MvPolynomial.eval_assoc]
  have hassign :
      (fun w : MulVar (n + 1) =>
          MvPolynomial.eval (conjOneVar T v) (conjStepSubst R j h0j w)) =
        evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1) := by
    funext w
    exact hSubst w
  change
    MvPolynomial.eval
        (fun w : MulVar (n + 1) =>
          MvPolynomial.eval (conjOneVar T v) (conjStepSubst R j h0j w))
        (firstConjugatedU F_U R k) =
      (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1)
        (Fin.succ k) : ℚ)
  rw [hassign]
  simpa [singleCoord] using
    conjugated_tail_u
      M hMul hInv F_U R hFU
      (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1) k
      (fun i k => by
        simpa [singleCoord] using hFactor i k)
      (fun i => by
        simpa [singleCoord] using hZero i)

theorem step_u_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hMul : ∀ a b : M.G,
      M.coord a 0 = 0 → M.coord b 0 = 0 → M.coord (a * b) 0 = 0)
    (hInv : ∀ a : M.G, M.coord a 0 = 0 → M.coord a⁻¹ 0 = 0)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication
      (M.firstConsistentPresentation hMul hInv) F_U)
    (hR : RepresentsConjugation M R)
    (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j)
    (v : ℤ) (k : Fin n) :
    conjOnePolynomial T v (conj2U F_U R j h0j k) =
      (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1)
        (Fin.succ k) : ℚ) := by
  change
    MvPolynomial.eval (conjOneVar T v)
        (MvPolynomial.eval₂ MvPolynomial.C (conjStepSubst R j h0j)
          (firstConjugatedU F_U R k)) =
      (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1)
        (Fin.succ k) : ℚ)
  rw [← MvPolynomial.eval_assoc]
  have hassign :
      (fun w : MulVar (n + 1) =>
          MvPolynomial.eval (conjOneVar T v) (conjStepSubst R j h0j w)) =
        evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1) := by
    funext w
    exact conj_subst_represents M R hR j h0j v w
  change
    MvPolynomial.eval
        (fun w : MulVar (n + 1) =>
          MvPolynomial.eval (conjOneVar T v) (conjStepSubst R j h0j w))
        (firstConjugatedU F_U R k) =
      (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1)
        (Fin.succ k) : ℚ)
  rw [hassign]
  simpa [singleCoord] using
    conjugated_u_represents
      M hMul hInv F_U R hFU hR
      (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1) k

theorem u_coordinate_additive
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hAdd : CPres.CoordinateAdditive M 0)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication
      (M.firstConsistentAdditive hAdd) F_U)
    (hR : RepresentsConjugation M R)
    (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j)
    (v : ℤ) (k : Fin n) :
    conjOnePolynomial T v (conj2U F_U R j h0j k) =
      (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1)
        (Fin.succ k) : ℚ) := by
  let hClosed := CPres.coordinate_closed_additive M 0 hAdd
  simpa [CPres.firstConsistentAdditive,
    hClosed] using
    step_u_represents
      M hClosed.1 hClosed.2 F_U R hFU hR j h0j v k

/-- Coordinate-polynomial tuple for the leading factor `a_0^(x_0 + y_0)` in `(*)`. -/
def multiplicationDisplayFirst {n : ℕ} :
    Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ :=
  fun k =>
    if k = 0 then
      MvPolynomial.X (MulVar.left 0) + MvPolynomial.X (MulVar.right 0)
    else
      0

lemma multiplication_display_factor {n : ℕ}
    (T : ParameterIndex (n + 1) → ℤ) (x y : Fin (n + 1) → ℤ)
    (k : Fin (n + 1)) :
    MvPolynomial.eval (evalMulVar T x y) (multiplicationDisplayFirst k) =
      (singleCoord 0 (x 0 + y 0) k : ℚ) := by
  by_cases hk : k = 0
  · subst k
    simp [multiplicationDisplayFirst, evalMulVar, mulVarQ,
      singleCoord, Int.cast_add]
  · simp [multiplicationDisplayFirst, evalMulVar, singleCoord, hk]

/-- Coordinate-polynomial tuple for the trailing factor `a_1^{y_1}...a_n^{y_n}` in `(*)`. -/
def multiplicationDisplayRight {n : ℕ} :
    Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ :=
  fun k => if k = 0 then 0 else MvPolynomial.X (MulVar.right k)

lemma multiplication_display_right {n : ℕ}
    (T : ParameterIndex (n + 1) → ℤ) (x y : Fin (n + 1) → ℤ)
    (k : Fin (n + 1)) :
    MvPolynomial.eval (evalMulVar T x y) (multiplicationDisplayRight k) =
      (withoutFirstCoord y k : ℚ) := by
  by_cases hk : k = 0
  · subst k
    simp [multiplicationDisplayRight]
  · simp [multiplicationDisplayRight, withoutFirstCoord,
      evalMulVar, mulVarQ, hk]

/-- Lower-rank `U(T)` coordinates for the trailing factor `a_1^{y_1}...a_n^{y_n}`. -/
def multiplicationDisplayTail {n : ℕ} :
    Fin n → MvPolynomial (MulVar (n + 1)) ℚ :=
  fun k => MvPolynomial.X (MulVar.right (Fin.succ k))

lemma eval_multiplication_u {n : ℕ}
    (T : ParameterIndex (n + 1) → ℤ) (x y : Fin (n + 1) → ℤ)
    (k : Fin n) :
    MvPolynomial.eval (evalMulVar T x y) (multiplicationDisplayTail k) =
      (Fin.tail y k : ℚ) := by
  simp [multiplicationDisplayTail, evalMulVar, mulVarQ,
    Fin.tail_def]

/--
Lower-rank `U(T)` polynomial tuple for the tail product in the multiplication
display, using multiplication polynomials for `U(T)` rather than the ambient
presentation.
-/
def multiplicationDisplayU {n : ℕ}
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ) :
    Fin n → MvPolynomial (MulVar (n + 1)) ℚ :=
  fun k =>
    mulComposePolynomial F_U deleteFirstParameter
      (firstConjugatedU F_U R)
      multiplicationDisplayTail k

theorem display_u_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hMul : ∀ a b : M.G,
      M.coord a 0 = 0 → M.coord b 0 = 0 → M.coord (a * b) 0 = 0)
    (hInv : ∀ a : M.G, M.coord a 0 = 0 → M.coord a⁻¹ 0 = 0)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication
      (M.firstConsistentPresentation hMul hInv) F_U)
    (hR : RepresentsConjugation M R)
    (x y : Fin (n + 1) → ℤ) (k : Fin n) :
    evalMulPolynomial T x y (multiplicationDisplayU F_U R k) =
      (M.coord (M.firstConjugatedProduct x (y 0) *
        M.normalWord (withoutFirstCoord y)) (Fin.succ k) : ℚ) := by
  let MU := M.firstConsistentPresentation hMul hInv
  let firstSub : M.firstCoordinateSubgroup hMul hInv :=
    ⟨M.firstConjugatedProduct x (y 0),
      conjugated_coord_represents M hMul R hR x (y 0)⟩
  let rightSub : M.firstCoordinateSubgroup hMul hInv :=
    ⟨M.normalWord (withoutFirstCoord y), by
      change M.coord (M.normalWord (withoutFirstCoord y)) 0 = 0
      rw [M.coord_normalWord]
      simp⟩
  have hfirstCoord := M.first_consistent_coord hMul hInv firstSub
  have hrightCoord := M.first_consistent_coord hMul hInv rightSub
  rw [multiplicationDisplayU]
  change MvPolynomial.eval (evalMulVar T x y)
      (mulComposePolynomial F_U deleteFirstParameter
        (firstConjugatedU F_U R)
        multiplicationDisplayTail k) =
    (M.coord (M.firstConjugatedProduct x (y 0) *
      M.normalWord (withoutFirstCoord y)) (Fin.succ k) : ℚ)
  have hcompose :=
    compose_multiplication_represents
      MU F_U hFU deleteFirstParameter
      (firstConjugatedU F_U R)
      multiplicationDisplayTail (evalMulVar T x y)
      (by
        intro I
        simp [deleteFirstParameter, firstParameterTuple,
          deleteParameterTuple, evalMulVar, mulVarQ])
      (MU.coord firstSub) (MU.coord rightSub)
      (by
        intro i
        rw [hfirstCoord]
        change MvPolynomial.eval (evalMulVar T x y)
            (firstConjugatedU F_U R i) =
          (M.coord (M.firstConjugatedProduct x (y 0)) (Fin.succ i) : ℚ)
        exact conjugated_u_represents
          M hMul hInv F_U R hFU hR x y i)
      (by
        intro i
        rw [hrightCoord]
        change MvPolynomial.eval (evalMulVar T x y)
            (multiplicationDisplayTail i) =
          (M.coord (M.normalWord (withoutFirstCoord y)) (Fin.succ i) : ℚ)
        rw [M.coord_normalWord]
        simp [eval_multiplication_u, withoutFirstCoord,
          Fin.succ_ne_zero, Fin.tail_def])
      k
  rw [hcompose]
  change (MU.coord (MU.normalWord (MU.coord firstSub) *
      MU.normalWord (MU.coord rightSub)) k : ℚ) =
    (M.coord (M.firstConjugatedProduct x (y 0) *
      M.normalWord (withoutFirstCoord y)) (Fin.succ k) : ℚ)
  rw [MU.normalWord_coord firstSub, MU.normalWord_coord rightSub]
  have hcoord :=
    M.first_consistent_coord hMul hInv
      (firstSub * rightSub)
  have hk := congrFun hcoord k
  change (MU.coord (firstSub * rightSub) k : ℚ) =
    (M.coord ((firstSub * rightSub : M.firstCoordinateSubgroup hMul hInv) : M.G)
      (Fin.succ k) : ℚ)
  exact_mod_cast hk

theorem multiplication_u_additive
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hAdd : CPres.CoordinateAdditive M 0)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication
      (M.firstConsistentAdditive hAdd) F_U)
    (hR : RepresentsConjugation M R)
    (x y : Fin (n + 1) → ℤ) (k : Fin n) :
    evalMulPolynomial T x y (multiplicationDisplayU F_U R k) =
      (M.coord (M.firstConjugatedProduct x (y 0) *
        M.normalWord (withoutFirstCoord y)) (Fin.succ k) : ℚ) := by
  let hClosed := CPres.coordinate_closed_additive M 0 hAdd
  simpa [CPres.firstConsistentAdditive,
    hClosed] using
    display_u_represents
      M hClosed.1 hClosed.2 F_U R hFU hR x y k

theorem display_tail_u
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hR : RepresentsConjugation M R)
    (x y : Fin (n + 1) → ℤ) (k : Fin n) :
    evalMulPolynomial T x y (multiplicationDisplayU F_U R k) =
      (M.coord (M.firstConjugatedProduct x (y 0) *
        M.normalWord (withoutFirstCoord y)) (Fin.succ k) : ℚ) :=
  multiplication_u_additive
    M M.firstCoordinateAdditive F_U R hFU hR x y k

theorem multiplication_u_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hMul : ∀ a b : M.G,
      M.coord a 0 = 0 → M.coord b 0 = 0 → M.coord (a * b) 0 = 0)
    (hInv : ∀ a : M.G, M.coord a 0 = 0 → M.coord a⁻¹ 0 = 0)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication
      (M.firstConsistentPresentation hMul hInv) F_U)
    (hR : RepresentsConjugation M R)
    (x y : Fin (n + 1) → ℤ) (k : Fin n) :
    evalMulPolynomial T x y (multiplicationDisplayU F_U R k) =
      (M.coord (M.gen 0 ^ (x 0 + y 0) *
        (M.firstConjugatedProduct x (y 0) *
          M.normalWord (withoutFirstCoord y))) (Fin.succ k) : ℚ) := by
  let tailProduct :=
    M.firstConjugatedProduct x (y 0) * M.normalWord (withoutFirstCoord y)
  have htailZero : M.coord tailProduct 0 = 0 := by
    exact multiplication_tail_represents M hMul R hR x y
  calc
    evalMulPolynomial T x y (multiplicationDisplayU F_U R k)
        = (M.coord tailProduct (Fin.succ k) : ℚ) := by
          exact display_u_represents
            M hMul hInv F_U R hFU hR x y k
    _ = (M.coord (M.gen 0 ^ (x 0 + y 0) * tailProduct) (Fin.succ k) : ℚ) := by
          exact_mod_cast
            (M.coord_gen_succ
              (x 0 + y 0) tailProduct htailZero k).symm
    _ = (M.coord (M.gen 0 ^ (x 0 + y 0) *
          (M.firstConjugatedProduct x (y 0) *
            M.normalWord (withoutFirstCoord y))) (Fin.succ k) : ℚ) := by
          rfl

theorem multiplication_display_additive
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hAdd : CPres.CoordinateAdditive M 0)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication
      (M.firstConsistentAdditive hAdd) F_U)
    (hR : RepresentsConjugation M R)
    (x y : Fin (n + 1) → ℤ) (k : Fin n) :
    evalMulPolynomial T x y (multiplicationDisplayU F_U R k) =
      (M.coord (M.gen 0 ^ (x 0 + y 0) *
        (M.firstConjugatedProduct x (y 0) *
          M.normalWord (withoutFirstCoord y))) (Fin.succ k) : ℚ) := by
  let hClosed := CPres.coordinate_closed_additive M 0 hAdd
  simpa [CPres.firstConsistentAdditive,
    hClosed] using
    multiplication_u_represents
      M hClosed.1 hClosed.2 F_U R hFU hR x y k

theorem multiplication_tail_u
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
