        (M.poweringTuple x z (Fin.last n) : ℚ)) :
    RepresentsHallPolynomials M F
      (deleteLastSolution F K_W K_seed) R :=
  ⟨hF,
    powering_delete_solution
      M F F_W K_W R_W K_seed hF hHallW hLast,
    hR⟩

/--
Bundled Hall-polynomial form of the quotient-lifted powering family with the
