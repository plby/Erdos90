/--
Induction-hypothesis-shaped family-level package for the combined lower-rank
Section 3.2 construction.
-/
theorem polynomials_delete_first
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (hHallU :
      ∃ (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
        (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
        (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
          RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U) :
    ∃ R' : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ,
      RepresentsHallPolynomials M F K R' ∧
      (∀ I, specializeConj T (R I) = specializeConj T (R' I)) ∧
      ∀ I u v,
        evalConjPolynomial T u v (R I) =
          evalConjPolynomial T u v (R' I) := by
  rcases hHallU with ⟨F_U, K_U, R_U, hHallU⟩
  refine ⟨conjFamilyU F_U K_U R, ?_, ?_, ?_⟩
  · exact represents_polynomials_first
      M F K R F_U K_U R_U hHall hHallU
  · intro I
    exact specialize_u_delete
      M F_U K_U R_U R hHallU hHall.2.2 I
  · intro I u v
    exact u_delete_first
      M F_U K_U R_U R hHallU hHall.2.2 I u v

/--
Exact-premise Section 3.4 recursion: to identify the coordinate polynomial
for a power at `z+1` with multiplication of the `z`th-power coordinates by
`x`, it is enough to know the relevant evaluated `K` coordinates and the one
evaluated multiplication coordinate.
-/
theorem power_succ_mul {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (x : Fin n → ℤ) (z : ℤ) (i : Fin n)
    (hKsucc :
      evalPowerPolynomial T x (z + 1) (K i) =
        (M.poweringTuple x (z + 1) i : ℚ))
    (hKz : ∀ j, evalPowerPolynomial T x z (K j) =
      (M.poweringTuple x z j : ℚ))
    (hF :
      evalMulPolynomial T (M.poweringTuple x z) x (F i) =
        (M.multiplicationTuple (M.poweringTuple x z) x i : ℚ)) :
    evalPowerPolynomial T x (z + 1) (K i) =
      evalMulQ (fun I => (T I : ℚ))
        (fun j => evalPowerPolynomial T x z (K j))
        (fun j => (x j : ℚ)) (F i) := by
  let xz : Fin n → ℤ := M.poweringTuple x z
  rw [hKsucc]
  have hassign :
      mulVarQ (fun I => (T I : ℚ))
          (fun j => evalPowerPolynomial T x z (K j))
          (fun j => (x j : ℚ)) =
        evalMulVar T xz x := by
    funext v
    cases v with
    | param I => rfl
    | left j => exact hKz j
    | right j => rfl
  rw [show
    evalMulQ (fun I => (T I : ℚ))
        (fun j => evalPowerPolynomial T x z (K j))
        (fun j => (x j : ℚ)) (F i) =
      evalMulPolynomial T xz x (F i) by
        change MvPolynomial.eval
            (mulVarQ (fun I => (T I : ℚ))
              (fun j => evalPowerPolynomial T x z (K j))
              (fun j => (x j : ℚ))) (F i) =
          MvPolynomial.eval (evalMulVar T xz x) (F i)
        rw [hassign]]
  rw [hF]
  rw [M.poweringTuple_succ x z]

/--
Section 3.4 recursion, semantic form.  If `F` and `K` represent
multiplication and powering, then the coordinate polynomial for a power at
`z+1` agrees with multiplication of the `z`th-power coordinates by `x`.
-/
theorem succ_mul_represents {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (x : Fin n → ℤ) (z : ℤ) (i : Fin n) :
    evalPowerPolynomial T x (z + 1) (K i) =
      evalMulQ (fun I => (T I : ℚ))
        (fun j => evalPowerPolynomial T x z (K j))
        (fun j => (x j : ℚ)) (F i) := by
  exact power_succ_mul M F K x z i
    (hK x (z + 1) i)
    (fun j => hK x z j)
    (hF (M.poweringTuple x z) x i)

/--
Exact-premise paper-style form of Section 3.4 Lemma `step3`: the evaluated
powering coordinate satisfies the forward recursion with the generic
forward-difference polynomial once the needed `K` and multiplication
coordinates are known.
-/
theorem add_forward_difference
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (x : Fin n → ℤ) (z : ℤ) (i : Fin n)
    (hKsucc :
      evalPowerPolynomial T x (z + 1) (K i) =
        (M.poweringTuple x (z + 1) i : ℚ))
    (hKz : ∀ j, evalPowerPolynomial T x z (K j) =
      (M.poweringTuple x z j : ℚ))
    (hF :
      evalMulPolynomial T (M.poweringTuple x z) x (F i) =
        (M.multiplicationTuple (M.poweringTuple x z) x i : ℚ)) :
    evalPowerPolynomial T x (z + 1) (K i) =
      evalPowerPolynomial T x z (K i) +
        evalPowerPolynomial T x z (forwardDifferencePolynomial F K i) := by
  rw [power_forward_difference]
  rw [power_succ_mul M F K x z i hKsucc hKz hF]
  rw [eval_mul_polynomial]
  ring

/--
Paper-style form of Section 3.4 Lemma `step3`: the represented powering
polynomial satisfies a forward recursion with polynomial increment.
-/
theorem succ_difference_represents
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (x : Fin n → ℤ) (z : ℤ) (i : Fin n) :
    evalPowerPolynomial T x (z + 1) (K i) =
      evalPowerPolynomial T x z (K i) +
        evalPowerPolynomial T x z (forwardDifferencePolynomial F K i) :=
  add_forward_difference M F K x z i
    (hK x (z + 1) i)
    (fun j => hK x z j)
    (hF (M.poweringTuple x z) x i)

/--
Exact-premise form of the last-coordinate forward-difference comparison:
after evaluating the powering polynomials at `z` to a tuple `xz`, it is enough
that the last multiplication polynomial satisfies the `formF` split at
`(xz, x)`.
-/
theorem forward_difference_last
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (x xz : Fin (n + 1) → ℤ) (z : ℤ)
    (hKz : ∀ j, evalPowerPolynomial T x z (K j) = (xz j : ℚ))
    (hmul :
      evalMulPolynomial T xz x (F (Fin.last n)) =
        evalMulPolynomial T xz x (multiplicationLastTruncation F) +
          (xz (Fin.last n) : ℚ) + (x (Fin.last n) : ℚ)) :
    evalPowerPolynomial T x z (forwardDifferencePolynomial F K (Fin.last n)) =
      evalPowerPolynomial T x z (lastForwardDifference F K) := by
  have hassign :
      mulVarQ (fun I => (T I : ℚ))
          (fun j => evalPowerPolynomial T x z (K j))
          (fun j => (x j : ℚ)) =
        evalMulVar T xz x := by
    funext v
    cases v with
    | param I => rfl
    | left j => exact hKz j
    | right j => rfl
  rw [power_forward_difference, forward_difference_polynomial,
    last_truncation_polynomial, eval_mul_polynomial]
  change
    MvPolynomial.eval
          (mulVarQ (fun I => (T I : ℚ))
            (fun j => evalPowerPolynomial T x z (K j)) (fun j => (x j : ℚ)))
          (F (Fin.last n)) - evalPowerPolynomial T x z (K (Fin.last n)) =
      MvPolynomial.eval
          (mulVarQ (fun I => (T I : ℚ))
            (fun j => evalPowerPolynomial T x z (K j)) (fun j => (x j : ℚ)))
          (multiplicationLastTruncation F) +
        (x (Fin.last n) : ℚ)
  rw [hassign]
  change evalMulPolynomial T xz x (F (Fin.last n)) -
      evalPowerPolynomial T x z (K (Fin.last n)) =
    evalMulPolynomial T xz x (multiplicationLastTruncation F) +
      (x (Fin.last n) : ℚ)
  rw [hmul, hKz (Fin.last n)]
  ring

/--
For the last coordinate, the generic forward-difference polynomial agrees
with the paper-style increment `x_n + H(T;K(T;x,z),x)`.
-/
theorem difference_last_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (x : Fin (n + 1) → ℤ) (z : ℤ) :
    evalPowerPolynomial T x z (forwardDifferencePolynomial F K (Fin.last n)) =
      evalPowerPolynomial T x z (lastForwardDifference F K) := by
  let xz : Fin (n + 1) → ℤ := M.poweringTuple x z
  have hmul := last_truncation_represents M F hF xz x
  exact forward_difference_last
    F K x xz z (fun j => hK x z j) hmul

/--
Paper-style Section 3.4 recursion for the last powering coordinate, using
the increment coming from Remark `formF`.
-/
theorem last_forward_difference
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (x : Fin (n + 1) → ℤ) (z : ℤ)
    (hKsucc :
      evalPowerPolynomial T x (z + 1) (K (Fin.last n)) =
        (M.poweringTuple x (z + 1) (Fin.last n) : ℚ))
    (hKz : ∀ j, evalPowerPolynomial T x z (K j) =
      (M.poweringTuple x z j : ℚ))
    (hF :
      evalMulPolynomial T (M.poweringTuple x z) x (F (Fin.last n)) =
        (M.multiplicationTuple (M.poweringTuple x z) x (Fin.last n) : ℚ))
    (hLast :
      evalPowerPolynomial T x z (forwardDifferencePolynomial F K (Fin.last n)) =
        evalPowerPolynomial T x z (lastForwardDifference F K)) :
    evalPowerPolynomial T x (z + 1) (K (Fin.last n)) =
      evalPowerPolynomial T x z (K (Fin.last n)) +
        evalPowerPolynomial T x z (lastForwardDifference F K) := by
  rw [add_forward_difference
    M F K x z (Fin.last n) hKsucc hKz hF, hLast]

theorem last_difference_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (x : Fin (n + 1) → ℤ) (z : ℤ) :
    evalPowerPolynomial T x (z + 1) (K (Fin.last n)) =
      evalPowerPolynomial T x z (K (Fin.last n)) +
        evalPowerPolynomial T x z (lastForwardDifference F K) := by
  exact last_forward_difference
    M F K x z
    (hK x (z + 1) (Fin.last n))
    (fun j => hK x z j)
    (hF (M.poweringTuple x z) x (Fin.last n))
    (difference_last_represents
      M F K hF hK x z)

/--
Existential version of the paper-style Section 3.4 recursion for the last
powering coordinate.
-/
theorem last_forward_recursion
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K) :
    ∃ h : MvPolynomial (PowerVar (n + 1)) ℚ,
      ∀ x z,
        evalPowerPolynomial T x (z + 1) (K (Fin.last n)) =
          evalPowerPolynomial T x z (K (Fin.last n)) + evalPowerPolynomial T x z h := by
  exact ⟨lastForwardDifference F K,
    fun x z =>
      last_difference_represents
        M F K hF hK x z⟩

/-- Existential version of the Section 3.4 powering recursion. -/
theorem power_forward_recursion
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K) (i : Fin n) :
    ∃ h : MvPolynomial (PowerVar n) ℚ,
      ∀ x z,
        evalPowerPolynomial T x (z + 1) (K i) =
          evalPowerPolynomial T x z (K i) + evalPowerPolynomial T x z h := by
  exact ⟨forwardDifferencePolynomial F K i,
    fun x z => succ_difference_represents M F K hF hK x z i⟩

/--
Bernoulli-polynomial solution of the Section 3.4 powering recursion, after
specializing the parameters and input coordinates.  For natural exponents,
the represented powering polynomial is the unique zero-initial polynomial
antiderivative of its forward difference.
-/
theorem nat_forward_antiderivative
    {T : ParameterIndex n → ℤ}
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (x : Fin n → ℤ) (i : Fin n)
    (hZero : evalPowerPolynomial T x 0 (K i) = 0)
    (hRec : ∀ z : ℕ,
      evalPowerPolynomial T x ((z : ℤ) + 1) (K i) =
        evalPowerPolynomial T x (z : ℤ) (K i) +
          evalPowerPolynomial T x (z : ℤ) (forwardDifferencePolynomial F K i))
    (z : ℕ) :
    evalPowerPolynomial T x (z : ℤ) (K i) =
      (polynomialForwardAntiderivative (0 : ℚ)
        (powerUnivariatePolynomial T x (forwardDifferencePolynomial F K i))).eval
          (z : ℚ) := by
  let f := powerUnivariatePolynomial T x (K i)
  let g := powerUnivariatePolynomial T x (forwardDifferencePolynomial F K i)
  have h0 : f.eval 0 = (0 : ℚ) := by
    change (powerUnivariatePolynomial T x (K i)).eval (0 : ℚ) = (0 : ℚ)
    rw [show (0 : ℚ) = ((0 : ℤ) : ℚ) by norm_num,
      eval_univariate_polynomial]
    exact hZero
  have hrec : ∀ z : ℕ, f.eval ((z : ℚ) + 1) = f.eval (z : ℚ) + g.eval (z : ℚ) := by
    intro z
    change
      (powerUnivariatePolynomial T x (K i)).eval ((z : ℚ) + 1) =
        (powerUnivariatePolynomial T x (K i)).eval (z : ℚ) +
          (powerUnivariatePolynomial T x
            (forwardDifferencePolynomial F K i)).eval (z : ℚ)
    rw [show ((z : ℚ) + 1) = (((z : ℤ) + 1 : ℤ) : ℚ) by
        norm_num [Int.cast_add, Nat.cast_add, Nat.cast_one],
      show (z : ℚ) = ((z : ℤ) : ℚ) by norm_num]
    rw [eval_univariate_polynomial T x ((z : ℤ) + 1),
      eval_univariate_polynomial T x (z : ℤ),
      eval_univariate_polynomial T x (z : ℤ)]
    exact hRec z
  have hunique :=
    forward_antiderivative_solves
      (R := ℚ) (f := f) (g := g) (f₀ := 0) h0 hrec z
  rw [← hunique]
  change evalPowerPolynomial T x (z : ℤ) (K i) =
    (powerUnivariatePolynomial T x (K i)).eval (z : ℚ)
  rw [show (z : ℚ) = ((z : ℤ) : ℚ) by norm_num,
    eval_univariate_polynomial]

theorem nat_antiderivative_represents
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (x : Fin n → ℤ) (i : Fin n) (z : ℕ) :
    evalPowerPolynomial T x (z : ℤ) (K i) =
      (polynomialForwardAntiderivative (0 : ℚ)
        (powerUnivariatePolynomial T x (forwardDifferencePolynomial F K i))).eval
          (z : ℚ) := by
  exact nat_forward_antiderivative
    F K x i
    (eval_zero_represents M K hK x i)
    (fun z =>
      succ_difference_represents M F K hF hK x (z : ℤ) i)
    z

/--
Polynomial identity form of the Bernoulli solution for represented powering,
after specializing the parameters and input coordinates.
-/
theorem power_univariate_antiderivative
    {T : ParameterIndex n → ℤ}
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (x : Fin n → ℤ) (i : Fin n)
    (hZero : evalPowerPolynomial T x 0 (K i) = 0)
    (hRec : ∀ z : ℕ,
      evalPowerPolynomial T x ((z : ℤ) + 1) (K i) =
        evalPowerPolynomial T x (z : ℤ) (K i) +
          evalPowerPolynomial T x (z : ℤ) (forwardDifferencePolynomial F K i)) :
    powerUnivariatePolynomial T x (K i) =
      polynomialForwardAntiderivative (0 : ℚ)
        (powerUnivariatePolynomial T x (forwardDifferencePolynomial F K i)) := by
  let f := powerUnivariatePolynomial T x (K i)
  let g := powerUnivariatePolynomial T x (forwardDifferencePolynomial F K i)
  have h0 : f.eval 0 = (0 : ℚ) := by
    change (powerUnivariatePolynomial T x (K i)).eval (0 : ℚ) = (0 : ℚ)
    rw [show (0 : ℚ) = ((0 : ℤ) : ℚ) by norm_num,
      eval_univariate_polynomial]
    exact hZero
  have hrec : ∀ z : ℕ, f.eval ((z : ℚ) + 1) = f.eval (z : ℚ) + g.eval (z : ℚ) := by
    intro z
    change
      (powerUnivariatePolynomial T x (K i)).eval ((z : ℚ) + 1) =
        (powerUnivariatePolynomial T x (K i)).eval (z : ℚ) +
          (powerUnivariatePolynomial T x
            (forwardDifferencePolynomial F K i)).eval (z : ℚ)
    rw [show ((z : ℚ) + 1) = (((z : ℤ) + 1 : ℤ) : ℚ) by
        norm_num [Int.cast_add, Nat.cast_add, Nat.cast_one],
      show (z : ℚ) = ((z : ℤ) : ℚ) by norm_num]
    rw [eval_univariate_polynomial T x ((z : ℤ) + 1),
      eval_univariate_polynomial T x (z : ℤ),
      eval_univariate_polynomial T x (z : ℤ)]
    exact hRec z
  change f = polynomialForwardAntiderivative (0 : ℚ) g
  exact polynomial_antiderivative_solves (R := ℚ) (f := f) (g := g)
    (f₀ := 0) h0 hrec

theorem univariate_forward_represents
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (x : Fin n → ℤ) (i : Fin n) :
    powerUnivariatePolynomial T x (K i) =
      polynomialForwardAntiderivative (0 : ℚ)
        (powerUnivariatePolynomial T x (forwardDifferencePolynomial F K i)) := by
  exact power_univariate_antiderivative
    F K x i
    (eval_zero_represents M K hK x i)
    (fun z =>
      succ_difference_represents M F K hF hK x (z : ℤ) i)

/-- All-integer evaluation form of the Bernoulli solution for represented powering. -/
theorem power_forward_antiderivative
    {T : ParameterIndex n → ℤ}
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (x : Fin n → ℤ) (i : Fin n)
    (hZero : evalPowerPolynomial T x 0 (K i) = 0)
    (hRec : ∀ z : ℕ,
      evalPowerPolynomial T x ((z : ℤ) + 1) (K i) =
        evalPowerPolynomial T x (z : ℤ) (K i) +
          evalPowerPolynomial T x (z : ℤ) (forwardDifferencePolynomial F K i))
    (z : ℤ) :
    evalPowerPolynomial T x z (K i) =
      (polynomialForwardAntiderivative (0 : ℚ)
        (powerUnivariatePolynomial T x (forwardDifferencePolynomial F K i))).eval
          (z : ℚ) := by
  rw [← power_univariate_antiderivative
    F K x i hZero hRec]
  rw [eval_univariate_polynomial]

theorem eval_antiderivative_represents
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (x : Fin n → ℤ) (i : Fin n) (z : ℤ) :
    evalPowerPolynomial T x z (K i) =
      (polynomialForwardAntiderivative (0 : ℚ)
        (powerUnivariatePolynomial T x (forwardDifferencePolynomial F K i))).eval
          (z : ℚ) := by
  exact power_forward_antiderivative
    F K x i
    (eval_zero_represents M K hK x i)
    (fun z =>
      succ_difference_represents M F K hF hK x (z : ℤ) i)
    z

/--
Constructed-polynomial form of the generic Section 3.4 powering recursion:
after parameter and coordinate specialization, the represented powering
coordinate agrees with the canonical zero-initial solution in `Q[T,x][z]`.
-/
theorem univariate_forward_solution
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (x : Fin n → ℤ) (i : Fin n) :
    powerUnivariatePolynomial T x (K i) =
      powerUnivariatePolynomial T x (forwardSolutionPolynomial F K i) := by
  rw [forwardSolutionPolynomial, forward_antiderivative_polynomial]
  exact univariate_forward_represents
    M F K hF hK x i

/-- Evaluation form of `univariate_forward_solution`. -/
theorem int_forward_solution
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (x : Fin n → ℤ) (i : Fin n) (z : ℤ) :
    evalPowerPolynomial T x z (K i) =
      evalPowerPolynomial T x z (forwardSolutionPolynomial F K i) := by
  have hpoly :=
    univariate_forward_solution
      M F K hF hK x i
  have hval := congrArg (fun p : Polynomial ℚ => p.eval (z : ℚ)) hpoly
  simpa [eval_univariate_polynomial] using hval

/--
Specialized polynomial identity for the constructed generic Section 3.4
powering solution.
-/
theorem specialize_forward_represents
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K) (i : Fin n) :
    specializePower T (K i) =
      specializePower T (forwardSolutionPolynomial F K i) := by
  exact specialize_power_eval (K i) (forwardSolutionPolynomial F K i)
    (fun x z => int_forward_solution
      M F K hF hK x i z)

/--
The constructed generic Section 3.4 solution is zero-initial, before assuming
that any powering family represents the presentation.
-/
theorem eval_forward_solution
    {T : ParameterIndex n → ℤ}
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (x : Fin n → ℤ) (i : Fin n) :
    evalPowerPolynomial T x 0 (forwardSolutionPolynomial F K i) = 0 := by
  rw [← eval_univariate_polynomial T x (0 : ℤ)
    (forwardSolutionPolynomial F K i)]
  rw [forwardSolutionPolynomial, forward_antiderivative_polynomial]
  simpa using forward_antiderivative_zero (0 : ℚ)
    (powerUnivariatePolynomial T x (forwardDifferencePolynomial F K i))

/--
The constructed generic Section 3.4 solution satisfies the forward recursion
with increment `forwardDifferencePolynomial`, before any representation
hypothesis is used.
-/
theorem succ_forward_solution
    {T : ParameterIndex n → ℤ}
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (x : Fin n → ℤ) (i : Fin n) (z : ℤ) :
    evalPowerPolynomial T x (z + 1) (forwardSolutionPolynomial F K i) =
      evalPowerPolynomial T x z (forwardSolutionPolynomial F K i) +
        evalPowerPolynomial T x z (forwardDifferencePolynomial F K i) := by
  rw [← eval_univariate_polynomial T x (z + 1)
    (forwardSolutionPolynomial F K i)]
  rw [← eval_univariate_polynomial T x z
    (forwardSolutionPolynomial F K i)]
  rw [← eval_univariate_polynomial T x z
    (forwardDifferencePolynomial F K i)]
  rw [forwardSolutionPolynomial, forward_antiderivative_polynomial]
  rw [show (((z + 1 : ℤ) : ℚ)) = (z : ℚ) + 1 by norm_num [Int.cast_add]]
  exact polynomial_forward_antiderivative (0 : ℚ)
    (powerUnivariatePolynomial T x (forwardDifferencePolynomial F K i)) (z : ℚ)

/--
Existential package for the constructed generic Section 3.4 powering solution:
the polynomial is zero-initial, satisfies the forward recursion, and computes
the represented powering coordinate.
-/
theorem forward_solution_represents
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K) (i : Fin n) :
    ∃ p : MvPolynomial (PowerVar n) ℚ,
      (∀ x : Fin n → ℤ,
        powerUnivariatePolynomial T x (K i) =
          powerUnivariatePolynomial T x p) ∧
      (∀ (x : Fin n → ℤ) (z : ℤ),
        evalPowerPolynomial T x z (K i) = evalPowerPolynomial T x z p) ∧
      (∀ x : Fin n → ℤ, evalPowerPolynomial T x 0 p = 0) ∧
      ∀ (x : Fin n → ℤ) (z : ℤ),
        evalPowerPolynomial T x (z + 1) p =
          evalPowerPolynomial T x z p +
            evalPowerPolynomial T x z (forwardDifferencePolynomial F K i) := by
  refine ⟨forwardSolutionPolynomial F K i, ?_, ?_, ?_, ?_⟩
  · intro x
    exact univariate_forward_solution
      M F K hF hK x i
  · intro x z
    exact int_forward_solution
      M F K hF hK x i z
  · intro x
    exact eval_forward_solution F K x i
  · intro x z
    exact succ_forward_solution F K x i z

/--
Replacing every represented powering coordinate by its constructed generic
Section 3.4 solution preserves the representation predicate.
-/
theorem represents_forward_solution
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K) :
    RepresentsPowering M (fun i => forwardSolutionPolynomial F K i) := by
  intro x z i
  rw [← int_forward_solution M F K hF hK x i z]
  exact hK x z i

/--
Replacing one represented powering coordinate by its constructed generic
Section 3.4 solution preserves the representation predicate.
-/
theorem represents_powering_update
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (i : Fin n) :
    RepresentsPowering M
      (Function.update K i (forwardSolutionPolynomial F K i)) := by
  intro x z j
  by_cases hji : j = i
  · subst j
    rw [Function.update_self]
    rw [← int_forward_solution M F K hF hK x i z]
    exact hK x z i
  · rw [Function.update_of_ne hji]
    exact hK x z j

/--
After specializing parameters and input coordinates, the generic last-coordinate
powering increment and the paper-style increment are the same polynomial in
the exponent.
-/
theorem univariate_difference_last
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (x : Fin (n + 1) → ℤ)
    (hEval : ∀ z : ℤ,
      evalPowerPolynomial T x z (forwardDifferencePolynomial F K (Fin.last n)) =
        evalPowerPolynomial T x z (lastForwardDifference F K)) :
    powerUnivariatePolynomial T x
        (forwardDifferencePolynomial F K (Fin.last n)) =
      powerUnivariatePolynomial T x (lastForwardDifference F K) := by
  apply Polynomial.eq_of_infinite_eval_eq
  apply Set.infinite_of_injective_forall_mem (f := fun z : ℕ => (z : ℚ))
  · exact Nat.cast_injective
  · intro z
    change
      (powerUnivariatePolynomial T x
          (forwardDifferencePolynomial F K (Fin.last n))).eval (z : ℚ) =
        (powerUnivariatePolynomial T x
          (lastForwardDifference F K)).eval (z : ℚ)
    rw [show (z : ℚ) = ((z : ℤ) : ℚ) by norm_num]
    rw [eval_univariate_polynomial T x (z : ℤ),
      eval_univariate_polynomial T x (z : ℤ)]
    exact hEval (z : ℤ)

theorem univariate_forward_last
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (x : Fin (n + 1) → ℤ) :
    powerUnivariatePolynomial T x
        (forwardDifferencePolynomial F K (Fin.last n)) =
      powerUnivariatePolynomial T x (lastForwardDifference F K) := by
  exact univariate_difference_last
    F K x
    (difference_last_represents
      M F K hF hK x)

/--
All-integer Bernoulli solution for the last powering coordinate using the
paper-style increment `x_n + H(T;K(T;x,z),x)`.
-/
theorem last_forward_antiderivative
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (x : Fin (n + 1) → ℤ)
    (hZero : evalPowerPolynomial T x 0 (K (Fin.last n)) = 0)
    (hRec : ∀ z : ℕ,
      evalPowerPolynomial T x ((z : ℤ) + 1) (K (Fin.last n)) =
        evalPowerPolynomial T x (z : ℤ) (K (Fin.last n)) +
          evalPowerPolynomial T x (z : ℤ)
            (forwardDifferencePolynomial F K (Fin.last n)))
    (hForward :
      powerUnivariatePolynomial T x
          (forwardDifferencePolynomial F K (Fin.last n)) =
        powerUnivariatePolynomial T x (lastForwardDifference F K))
    (z : ℤ) :
    evalPowerPolynomial T x z (K (Fin.last n)) =
      (polynomialForwardAntiderivative (0 : ℚ)
        (powerUnivariatePolynomial T x (lastForwardDifference F K))).eval
          (z : ℚ) := by
  rw [power_forward_antiderivative
    F K x (Fin.last n) hZero hRec z]
  rw [hForward]

theorem forward_antiderivative_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (x : Fin (n + 1) → ℤ) (z : ℤ) :
    evalPowerPolynomial T x z (K (Fin.last n)) =
      (polynomialForwardAntiderivative (0 : ℚ)
        (powerUnivariatePolynomial T x (lastForwardDifference F K))).eval
          (z : ℚ) := by
  exact last_forward_antiderivative
    F K x
    (eval_zero_represents M K hK x (Fin.last n))
    (fun z =>
      succ_difference_represents
        M F K hF hK x (z : ℤ) (Fin.last n))
    (univariate_forward_last
      M F K hF hK x)
    z

/--
Constructed-polynomial form of Cant--Eick Section 3.4 Lemma `step3` for the
last powering coordinate, using the paper-style increment
`x_n + H(T;K(T;x,z),x)` before specializing `T` and `x`.
-/
theorem univariate_last_solution
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (x : Fin (n + 1) → ℤ) :
    powerUnivariatePolynomial T x (K (Fin.last n)) =
      powerUnivariatePolynomial T x (lastSolutionPolynomial F K) := by
  rw [lastSolutionPolynomial, forward_antiderivative_polynomial]
  rw [← univariate_forward_last
    M F K hF hK x]
  exact univariate_forward_represents
    M F K hF hK x (Fin.last n)

/-- Evaluation form of `univariate_last_solution`. -/
theorem last_int_solution
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (x : Fin (n + 1) → ℤ) (z : ℤ) :
    evalPowerPolynomial T x z (K (Fin.last n)) =
      evalPowerPolynomial T x z (lastSolutionPolynomial F K) := by
  have hpoly :=
    univariate_last_solution
      M F K hF hK x
  have hval := congrArg (fun p : Polynomial ℚ => p.eval (z : ℚ)) hpoly
  simpa [eval_univariate_polynomial] using hval

/--
Specialized polynomial identity for the constructed paper-style last-coordinate
Section 3.4 powering solution.
-/
theorem specialize_last_solution
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K) :
    specializePower T (K (Fin.last n)) =
      specializePower T (lastSolutionPolynomial F K) := by
  exact specialize_power_eval (K (Fin.last n)) (lastSolutionPolynomial F K)
    (fun x z => last_int_solution
      M F K hF hK x z)

/--
The constructed paper-style last-coordinate Section 3.4 solution is
zero-initial, before any representation hypothesis is used.
-/
theorem eval_last_solution
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (x : Fin (n + 1) → ℤ) :
    evalPowerPolynomial T x 0 (lastSolutionPolynomial F K) = 0 := by
  rw [← eval_univariate_polynomial T x (0 : ℤ)
    (lastSolutionPolynomial F K)]
  rw [lastSolutionPolynomial, forward_antiderivative_polynomial]
  simpa using forward_antiderivative_zero (0 : ℚ)
    (powerUnivariatePolynomial T x (lastForwardDifference F K))

/--
The constructed paper-style last-coordinate Section 3.4 solution satisfies
the forward recursion with increment `lastForwardDifference`,
before any representation hypothesis is used.
-/
theorem succ_last_solution
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (x : Fin (n + 1) → ℤ) (z : ℤ) :
    evalPowerPolynomial T x (z + 1) (lastSolutionPolynomial F K) =
      evalPowerPolynomial T x z (lastSolutionPolynomial F K) +
        evalPowerPolynomial T x z (lastForwardDifference F K) := by
  rw [← eval_univariate_polynomial T x (z + 1)
    (lastSolutionPolynomial F K)]
  rw [← eval_univariate_polynomial T x z
    (lastSolutionPolynomial F K)]
  rw [← eval_univariate_polynomial T x z
    (lastForwardDifference F K)]
  rw [lastSolutionPolynomial, forward_antiderivative_polynomial]
  rw [show (((z + 1 : ℤ) : ℚ)) = (z : ℚ) + 1 by norm_num [Int.cast_add]]
  exact polynomial_forward_antiderivative (0 : ℚ)
    (powerUnivariatePolynomial T x (lastForwardDifference F K)) (z : ℚ)

/--
Two integer-indexed rational functions are equal if they agree at zero and
have the same forward differences everywhere.
-/
lemma function_forward_difference
    {f g : ℤ → ℚ}
    (h0 : f 0 = g 0)
    (hstep : ∀ z : ℤ, f (z + 1) - f z = g (z + 1) - g z) :
    ∀ z : ℤ, f z = g z := by
  intro z
  induction z using Int.induction_on with
  | zero =>
      exact h0
  | succ z ih =>
      have hs : f ((z : ℤ) + 1) =
          f (z : ℤ) + (g ((z : ℤ) + 1) - g (z : ℤ)) := by
        rw [← hstep (z : ℤ)]
        ring
      calc
        f ((z : ℤ) + 1)
            = f (z : ℤ) + (g ((z : ℤ) + 1) - g (z : ℤ)) := hs
        _ = g (z : ℤ) + (g ((z : ℤ) + 1) - g (z : ℤ)) := by rw [ih]
        _ = g ((z : ℤ) + 1) := by ring
  | pred z ih =>
      let w : ℤ := -(z : ℤ) - 1
      have hw : w + 1 = -(z : ℤ) := by
        simp [w]
      have hs : f w = f (w + 1) - (g (w + 1) - g w) := by
        rw [← hstep w]
        ring
      calc
        f w = f (w + 1) - (g (w + 1) - g w) := hs
        _ = f (-(z : ℤ)) - (g (w + 1) - g w) := by rw [hw]
        _ = g (-(z : ℤ)) - (g (w + 1) - g w) := by rw [ih]
        _ = g (w + 1) - (g (w + 1) - g w) := by rw [hw]
        _ = g w := by ring

/--
Seed-free version of the Section 3.4 last-coordinate solution theorem.  To
prove the constructed paper-style last solution represents the semantic last
powering coordinate, it is enough to know multiplication and the non-last
powering coordinates.
-/
theorem last_solution_nonlast
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hKnonlast : ∀ (x : Fin (n + 1) → ℤ) (z : ℤ) (i : Fin n),
      evalPowerPolynomial T x z (K (Fin.castSucc i)) =
        (M.poweringTuple x z (Fin.castSucc i) : ℚ))
    (x : Fin (n + 1) → ℤ) (z : ℤ) :
    evalPowerPolynomial T x z (lastSolutionPolynomial F K) =
      (M.poweringTuple x z (Fin.last n) : ℚ) := by
  let f : ℤ → ℚ := fun z => evalPowerPolynomial T x z (lastSolutionPolynomial F K)
  let g : ℤ → ℚ := fun z => (M.poweringTuple x z (Fin.last n) : ℚ)
  change f z = g z
  apply function_forward_difference
  · simp [f, g, eval_last_solution,
      M.poweringTuple_zero]
  · intro z
    have hsucc :=
      @succ_last_solution n T F K x z
    have hinc :=
      forward_difference_nonlast
        M F K hF x z (hKnonlast x z)
    dsimp [f, g]
    rw [hsucc, hinc]
    norm_num [Int.cast_sub]

/--
Existential package for the constructed paper-style last-coordinate Section
3.4 powering solution.
-/
theorem power_solution_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K) :
    ∃ p : MvPolynomial (PowerVar (n + 1)) ℚ,
      (∀ x : Fin (n + 1) → ℤ,
        powerUnivariatePolynomial T x (K (Fin.last n)) =
          powerUnivariatePolynomial T x p) ∧
      (∀ (x : Fin (n + 1) → ℤ) (z : ℤ),
        evalPowerPolynomial T x z (K (Fin.last n)) =
          evalPowerPolynomial T x z p) ∧
      (∀ x : Fin (n + 1) → ℤ, evalPowerPolynomial T x 0 p = 0) ∧
      ∀ (x : Fin (n + 1) → ℤ) (z : ℤ),
        evalPowerPolynomial T x (z + 1) p =
          evalPowerPolynomial T x z p +
            evalPowerPolynomial T x z (lastForwardDifference F K) := by
  refine ⟨lastSolutionPolynomial F K, ?_, ?_, ?_, ?_⟩
  · intro x
    exact univariate_last_solution
      M F K hF hK x
  · intro x z
    exact last_int_solution
      M F K hF hK x z
  · intro x
    exact eval_last_solution F K x
  · intro x z
    exact succ_last_solution F K x z

/--
Replacing the last represented powering coordinate by the constructed
paper-style Section 3.4 solution preserves the representation predicate.
-/
theorem powering_update_solution
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K) :
    RepresentsPowering M
      (Function.update K (Fin.last n) (lastSolutionPolynomial F K)) := by
  intro x z j
  by_cases hji : j = Fin.last n
  · subst j
    rw [Function.update_self]
    rw [← last_int_solution M F K hF hK x z]
    exact hK x z (Fin.last n)
  · rw [Function.update_of_ne hji]
    exact hK x z j

/--
Replacing all powering coordinates by generic constructed solutions and the
last coordinate by the paper-style solution preserves representation.
-/
theorem forward_update_last
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K) :
    RepresentsPowering M
      (Function.update (fun i => forwardSolutionPolynomial F K i)
        (Fin.last n) (lastSolutionPolynomial F K)) := by
  intro x z j
  by_cases hji : j = Fin.last n
  · subst j
    rw [Function.update_self]
    rw [← last_int_solution M F K hF hK x z]
    exact hK x z (Fin.last n)
  · rw [Function.update_of_ne hji]
    rw [← int_forward_solution M F K hF hK x j z]
    exact hK x z j

/--
Polynomial form of the Section 3.4 recursion:
`K_i(T;x,z+1)` and `F_i(T;K(T;x,z),x)` agree on all integer inputs whenever
`F` and `K` represent multiplication and powering in the presentation.
-/
theorem eval_succ_mul
    {T : ParameterIndex n → ℤ}
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (x : Fin n → ℤ) (z : ℤ) (i : Fin n)
    (hEval :
      evalPowerPolynomial T x (z + 1) (K i) =
        evalMulQ (fun I => (T I : ℚ))
          (fun j => evalPowerPolynomial T x z (K j))
          (fun j => (x j : ℚ)) (F i)) :
    evalPowerPolynomial T x z (powerSuccPolynomial K i) =
      evalPowerPolynomial T x z (powerMulPolynomial F K i) := by
  rw [eval_succ_polynomial, eval_mul_polynomial]
  exact hEval

theorem eval_succ_represents
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (x : Fin n → ℤ) (z : ℤ) (i : Fin n) :
    evalPowerPolynomial T x z (powerSuccPolynomial K i) =
      evalPowerPolynomial T x z (powerMulPolynomial F K i) := by
  exact eval_succ_mul F K x z i
    (succ_mul_represents M F K hF hK x z i)

/--
Polynomial identity form of the Section 3.4 recursion after specializing the
parameters to a represented presentation.
-/
theorem specialize_succ_eval
    {T : ParameterIndex n → ℤ}
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ) (i : Fin n)
    (hEval : ∀ (x : Fin n → ℤ) (z : ℤ),
      evalPowerPolynomial T x z (powerSuccPolynomial K i) =
        evalPowerPolynomial T x z (powerMulPolynomial F K i)) :
    specializePower T (powerSuccPolynomial K i) =
      specializePower T (powerMulPolynomial F K i) := by
  apply MvPolynomial.funext_set
    (s := fun _ : PowerInputVar n => Set.range fun z : ℤ => (z : ℚ))
  · intro v
    exact Set.infinite_range_of_injective Int.cast_injective
  · intro q hq
    choose z hz using fun v => hq v (Set.mem_univ v)
    let x : Fin n → ℤ := fun j => z (PowerInputVar.coord j)
    let e : ℤ := z PowerInputVar.exponent
    have hq_eq : q = evalInputVar x e := by
      funext v
      cases v <;> exact (hz _).symm
    rw [hq_eq, eval_specializePower, eval_specializePower]
    exact hEval x e

theorem specialize_succ_represents
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K) (i : Fin n) :
    specializePower T (powerSuccPolynomial K i) =
      specializePower T (powerMulPolynomial F K i) := by
  exact specialize_succ_eval F K i
    (fun x e =>
      eval_succ_represents M F K hF hK x e i)

/--
Polynomial identity form of the Section 3.4 forward recursion after
specializing the parameters to a represented presentation.
-/
theorem specialize_difference_represents
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (K : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K) (i : Fin n) :
    specializePower T (powerSuccPolynomial K i) =
      specializePower T (K i) + specializePower T (forwardDifferencePolynomial F K i) := by
  rw [specialize_succ_represents
    M F K hF hK i]
  unfold specializePower forwardDifferencePolynomial
  rw [map_sub]
  ring

/--
Polynomial identity form of the last-coordinate increment used in Cant--Eick
Section 3.4: after specializing parameters, the generic forward difference
for `K_n` is the paper-style polynomial `x_n + H(T;K(T;x,z),x)`.
-/
theorem specialize_forward_difference
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (hEval : ∀ (x : Fin (n + 1) → ℤ) (z : ℤ),
      evalPowerPolynomial T x z (forwardDifferencePolynomial F K (Fin.last n)) =
        evalPowerPolynomial T x z (lastForwardDifference F K)) :
    specializePower T (forwardDifferencePolynomial F K (Fin.last n)) =
      specializePower T (lastForwardDifference F K) := by
  apply MvPolynomial.funext_set
    (s := fun _ : PowerInputVar (n + 1) => Set.range fun z : ℤ => (z : ℚ))
  · intro v
    exact Set.infinite_range_of_injective Int.cast_injective
  · intro q hq
    choose z hz using fun v => hq v (Set.mem_univ v)
    let x : Fin (n + 1) → ℤ := fun j => z (PowerInputVar.coord j)
    let e : ℤ := z PowerInputVar.exponent
    have hq_eq : q = evalInputVar x e := by
      funext v
      cases v <;> exact (hz _).symm
    rw [hq_eq, eval_specializePower, eval_specializePower]
    exact hEval x e

theorem specialize_difference_last
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K) :
    specializePower T (forwardDifferencePolynomial F K (Fin.last n)) =
      specializePower T (lastForwardDifference F K) := by
  exact specialize_forward_difference F K
    (difference_last_represents
      M F K hF hK)

/--
Polynomial identity form of the paper-style last-coordinate powering recursion
from Section 3.4.
-/
theorem specialize_last_difference
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K) :
    specializePower T (powerSuccPolynomial K (Fin.last n)) =
      specializePower T (K (Fin.last n)) +
        specializePower T (lastForwardDifference F K) := by
  rw [specialize_difference_represents
    M F K hF hK (Fin.last n)]
  rw [specialize_difference_last
    M F K hF hK]

/--
Bundled Hall-polynomial form of the Section 3.2 recursion with the increment
polynomial constructed from the displayed product in Lemma `step2`.
-/
theorem forward_difference_polynomials
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k)
    (v : ℤ) :
    evalConjPolynomial T 1 (v + 1) (R ⟨(0, j, k), h0j, hjk⟩) =
      evalConjPolynomial T 1 v (R ⟨(0, j, k), h0j, hjk⟩) +
        conjOnePolynomial T v
          (conjForwardDifference F R j h0j k hjk) :=
  conj_difference_represents
    M F R hHall.1 hHall.2.2 j k h0j hjk v

/--
Bundled Hall-polynomial existential form of Cant--Eick Section 3.2 Lemma
`step2`, using the displayed product to construct the increment polynomial.
