/--
Existential Section 3.2 `U(T)` recursion, packaged to consume a represented
Hall-polynomial family on the canonical lower-rank presentation.
-/
theorem forward_recursion_u
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hR : RepresentsConjugation M R)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k) :
    ∃ g : MvPolynomial (ConjOneVar (n + 1)) ℚ,
      ∀ v : ℤ,
        evalConjPolynomial T 1 (v + 1) (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
          evalConjPolynomial T 1 v (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) +
            conjOnePolynomial T v g :=
  conj_recursion_u
    M F_U R hHallU.1 hR j k h0j hjk

/--
Induction-hypothesis-shaped lower-rank `U(T)` package for Cant--Eick Section
3.2 Lemma `step2`: consume existential Hall polynomials for the canonical
delete-first presentation and return the product-derived forward-difference
polynomial.
-/
theorem forward_recursion_first
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHallU :
      ∃ (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
        (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
        (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
          RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hR : RepresentsConjugation M R)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k) :
    ∃ g : MvPolynomial (ConjOneVar (n + 1)) ℚ,
      ∀ v : ℤ,
        evalConjPolynomial T 1 (v + 1) (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
          evalConjPolynomial T 1 v (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) +
            conjOnePolynomial T v g := by
  rcases hHallU with ⟨F_U, K_U, R_U, hHallU⟩
  exact forward_recursion_u
    M F_U K_U R_U R hHallU hR j k h0j hjk

/--
Split lower-rank-multiplication form of Cant--Eick Section 3.2 Lemma `step2`:
the product-derived forward-difference polynomial only needs multiplication
for the canonical delete-first presentation.
-/
theorem conj_forward_recursion
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU :
      ∃ F_U : Fin n → MvPolynomial (MulVar n) ℚ,
        RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hR : RepresentsConjugation M R)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k) :
    ∃ g : MvPolynomial (ConjOneVar (n + 1)) ℚ,
      ∀ v : ℤ,
        evalConjPolynomial T 1 (v + 1) (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
          evalConjPolynomial T 1 v (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) +
            conjOnePolynomial T v g := by
  rcases hFU with ⟨F_U, hFU⟩
  exact conj_recursion_u
    M F_U R hFU hR j k h0j hjk

/--
After specializing the parameters, Cant--Eick's product-derived Section 3.2
increment is the same univariate polynomial as the abstract forward
difference `R(T;1,v+1)-R(T;1,v)`.
-/
theorem conj_univariate_difference
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k)
    (hEval : ∀ v : ℤ,
      conjOnePolynomial T v
          (forwardDifferenceV R ⟨(0, j, k), h0j, hjk⟩) =
        conjOnePolynomial T v
          (conjForwardDifference F R j h0j k hjk)) :
    conjUnivariatePolynomial T
        (forwardDifferenceV R ⟨(0, j, k), h0j, hjk⟩) =
      conjUnivariatePolynomial T
        (conjForwardDifference F R j h0j k hjk) := by
  apply Polynomial.eq_of_infinite_eval_eq
  apply Set.infinite_of_injective_forall_mem (f := fun v : ℕ => (v : ℚ))
  · exact Nat.cast_injective
  · intro v
    change
      (conjUnivariatePolynomial T
          (forwardDifferenceV R ⟨(0, j, k), h0j, hjk⟩)).eval
          (v : ℚ) =
        (conjUnivariatePolynomial T
          (conjForwardDifference F R j h0j k hjk)).eval (v : ℚ)
    rw [show (v : ℚ) = ((v : ℤ) : ℚ) by norm_num]
    rw [conj_univariate_polynomial, conj_univariate_polynomial]
    exact hEval (v : ℤ)

/--
Univariate ambient step-2 forward-difference identity with the pointwise delta
premise derived from the current-coordinate identity.
-/
theorem univariate_forward_delta
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k)
    (hCurrent : ∀ v : ℤ,
      evalConjPolynomial T 1 v (R ⟨(0, j, k), h0j, hjk⟩) =
        (M.leftConjugationTuple 0 j 1 v k : ℚ))
    (hProduct : ∀ v : ℤ,
      conjOnePolynomial T v (conjStep2 F R j h0j k) =
        (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1) k :
          ℚ)) :
    conjUnivariatePolynomial T
        (forwardDifferenceV R ⟨(0, j, k), h0j, hjk⟩) =
      conjUnivariatePolynomial T
        (conjForwardDifference F R j h0j k hjk) :=
  conj_univariate_difference
    F R j k h0j hjk
    (fun v =>
      conj_forward_delta
        M F R j k h0j hjk v hCurrent (hProduct v))

theorem univariate_difference_2
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hR : RepresentsConjugation M R)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k) :
    conjUnivariatePolynomial T
        (forwardDifferenceV R ⟨(0, j, k), h0j, hjk⟩) =
      conjUnivariatePolynomial T
        (conjForwardDifference F R j h0j k hjk) := by
  exact conj_univariate_difference
    F R j k h0j hjk
    (conj_forward_represents
      M F R hF hR j k h0j hjk)

/--
Lower-rank `U(T)` version: after specializing the parameters, the abstract
forward difference equals the displayed-product increment polynomial.
-/
theorem univariate_forward_u
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k)
    (hEval : ∀ v : ℤ,
      conjOnePolynomial T v
          (forwardDifferenceV R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
        conjOnePolynomial T v
          (forwardDifferenceU F_U R j h0j k hjk)) :
    conjUnivariatePolynomial T
        (forwardDifferenceV R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
      conjUnivariatePolynomial T
        (forwardDifferenceU F_U R j h0j k hjk) := by
  apply Polynomial.eq_of_infinite_eval_eq
  apply Set.infinite_of_injective_forall_mem (f := fun v : ℕ => (v : ℚ))
  · exact Nat.cast_injective
  · intro v
    change
      (conjUnivariatePolynomial T
          (forwardDifferenceV R
            ⟨(0, j, Fin.succ k), h0j, hjk⟩)).eval (v : ℚ) =
        (conjUnivariatePolynomial T
          (forwardDifferenceU F_U R j h0j k hjk)).eval
          (v : ℚ)
    rw [show (v : ℚ) = ((v : ℤ) : ℚ) by norm_num]
    rw [conj_univariate_polynomial, conj_univariate_polynomial]
    exact hEval (v : ℤ)

/--
Univariate polynomial form of the exact-premise lower-rank `U(T)` step-2
forward-difference identity.  This packages the product-evaluation hook for
all integer `v`, giving the polynomial equality used by the Bernoulli
antiderivative step without assuming represented ambient conjugation.
-/
theorem conj_univariate_forward
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hMul : ∀ a b : M.G,
      M.coord a 0 = 0 → M.coord b 0 = 0 → M.coord (a * b) 0 = 0)
    (hInv : ∀ a : M.G, M.coord a 0 = 0 → M.coord a⁻¹ 0 = 0)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication
      (M.firstConsistentPresentation hMul hInv) F_U)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k)
    (hDelta : ∀ v : ℤ,
      conjOnePolynomial T v
          (forwardDifferenceV R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
        (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1)
            (Fin.succ k) : ℚ) -
          (M.leftConjugationTuple 0 j 1 v (Fin.succ k) : ℚ))
    (hCurrent : ∀ v : ℤ,
      evalConjPolynomial T 1 v (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
        (M.leftConjugationTuple 0 j 1 v (Fin.succ k) : ℚ))
    (hSubst : ∀ v w,
      MvPolynomial.eval (conjOneVar T v) (conjStepSubst R j h0j w) =
        evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1) w)
    (hFactor : ∀ v i k,
      MvPolynomial.eval
          (evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1))
          (firstConjugatedPolynomial R i k) =
        (M.leftConjugationTuple 0 (Fin.succ i)
          (M.leftConjugationTuple 0 j 1 v (Fin.succ i)) 1 (Fin.succ k) : ℚ))
    (hZero : ∀ v i,
      M.leftConjugationTuple 0 (Fin.succ i)
        (M.leftConjugationTuple 0 j 1 v (Fin.succ i)) 1 0 = 0) :
    conjUnivariatePolynomial T
        (forwardDifferenceV R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
      conjUnivariatePolynomial T
        (forwardDifferenceU F_U R j h0j k hjk) :=
  univariate_forward_u
    F_U R j k h0j hjk
    (fun v =>
      forward_difference_product
        M hMul hInv F_U R hFU j k h0j hjk v
        (hDelta v) (hCurrent v) (hSubst v) (hFactor v) (hZero v))

/--
Product-evaluation lower-rank `U(T)` step-2 forward-difference identity with
the exact forward-difference delta and tail-zero premises discharged
semantically from the current-coordinate identity.
-/
theorem fwd_diff_delta
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hMul : ∀ a b : M.G,
      M.coord a 0 = 0 → M.coord b 0 = 0 → M.coord (a * b) 0 = 0)
    (hInv : ∀ a : M.G, M.coord a 0 = 0 → M.coord a⁻¹ 0 = 0)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication
      (M.firstConsistentPresentation hMul hInv) F_U)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k)
    (hCurrent : ∀ v : ℤ,
      evalConjPolynomial T 1 v (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
        (M.leftConjugationTuple 0 j 1 v (Fin.succ k) : ℚ))
    (hSubst : ∀ v w,
      MvPolynomial.eval (conjOneVar T v) (conjStepSubst R j h0j w) =
        evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1) w)
    (hFactor : ∀ v i k,
      MvPolynomial.eval
          (evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1))
          (firstConjugatedPolynomial R i k) =
        (M.leftConjugationTuple 0 (Fin.succ i)
          (M.leftConjugationTuple 0 j 1 v (Fin.succ i)) 1 (Fin.succ k) : ℚ)) :
    conjUnivariatePolynomial T
        (forwardDifferenceV R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
      conjUnivariatePolynomial T
        (forwardDifferenceU F_U R j h0j k hjk) :=
  univariate_forward_u
    F_U R j k h0j hjk
    (fun v =>
      forward_difference_delta
        M hMul hInv F_U R hFU j k h0j hjk v
        hCurrent (hSubst v) (hFactor v))

/--
Canonical delete-first form of the univariate lower-rank product-evaluation
forward-difference identity.
-/
theorem univariate_fwd_diff
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k)
    (hCurrent : ∀ v : ℤ,
      evalConjPolynomial T 1 v (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
        (M.leftConjugationTuple 0 j 1 v (Fin.succ k) : ℚ))
    (hSubst : ∀ v w,
      MvPolynomial.eval (conjOneVar T v) (conjStepSubst R j h0j w) =
        evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1) w)
    (hFactor : ∀ v i k,
      MvPolynomial.eval
          (evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1))
          (firstConjugatedPolynomial R i k) =
        (M.leftConjugationTuple 0 (Fin.succ i)
          (M.leftConjugationTuple 0 j 1 v (Fin.succ i)) 1 (Fin.succ k) : ℚ)) :
    conjUnivariatePolynomial T
        (forwardDifferenceV R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
      conjUnivariatePolynomial T
        (forwardDifferenceU F_U R j h0j k hjk) :=
  univariate_forward_u
    F_U R j k h0j hjk
    (fun v =>
      forward_no_delta
        M F_U R hFU j k h0j hjk v hCurrent (hSubst v) (hFactor v))

theorem univariate_difference_u
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hR : RepresentsConjugation M R)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k) :
    conjUnivariatePolynomial T
        (forwardDifferenceV R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
      conjUnivariatePolynomial T
        (forwardDifferenceU F_U R j h0j k hjk) :=
  univariate_forward_u
    F_U R j k h0j hjk
    (forward_2_u
      M F_U R hFU hR j k h0j hjk)

theorem univariate_forward_difference
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hR : RepresentsConjugation M R)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k) :
    conjUnivariatePolynomial T
        (forwardDifferenceV R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
      conjUnivariatePolynomial T
        (forwardDifferenceU F_U R j h0j k hjk) :=
  univariate_difference_u
    M F_U R hHallU.1 hR j k h0j hjk

/--
Represented-polynomial form of Section 3.1 Lemma `step1`: the tail
conjugation polynomial for conjugation by the first generator is obtained by
evaluating the powering polynomial on the coordinate tuple for the `u = 1`
left conjugation.
-/
lemma conj_coord_u
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hR : RepresentsConjugation M R)
    (j i : Fin n) (u v : ℤ) :
    MvPolynomial.eval (evalConjVar T u v) (stepCoordU R j i) =
      (Fin.tail (M.leftConjugationTuple 0 (Fin.succ j) 1 v) i : ℚ) := by
  change evalConjPolynomial T u v (stepCoordU R j i) =
    (Fin.tail (M.leftConjugationTuple 0 (Fin.succ j) 1 v) i : ℚ)
  by_cases hij : i = j
  · subst i
    have hmiddle :=
      conjugation_middle_represents
        M R hR (Fin.succ j) (Fin.succ_pos j) 1 v
    simpa [stepCoordU, evalConjPolynomial] using hmiddle.symm
  · by_cases hji : j < i
    · have htail :=
        left_conjugation_represents
          M R hR (Fin.succ j) (Fin.succ i) (Fin.succ_pos j)
          (Fin.succ_lt_succ_iff.mpr hji) 1 v
      simpa [stepCoordU, hij, hji, set_u_polynomial]
        using htail.symm
    · have hne : Fin.succ i ≠ Fin.succ j := by
        intro h
        exact hij ((Fin.succ_injective n) h)
      have hnot : ¬ Fin.succ j < Fin.succ i := by
        intro h
        exact hji (Fin.succ_lt_succ_iff.mp h)
      have hzero :=
        conjugation_position_represents
          M R hR (Fin.succ j) (Fin.succ i) (Fin.succ_pos j)
          (Fin.succ_ne_zero i) hne hnot 1 v
      simpa [stepCoordU, hij, hji, evalConjPolynomial] using hzero.symm

theorem conj_u_conjugation
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hR : RepresentsConjugation M R)
    (j k : Fin n) (u v : ℤ) :
    evalConjPolynomial T u v (step1U R K_U j k) =
      evalPowerPolynomial (firstParameterTuple T)
        (Fin.tail (M.leftConjugationTuple 0 (Fin.succ j) 1 v)) u (K_U k) := by
  change MvPolynomial.eval (evalConjVar T u v) (step1U R K_U j k) =
    evalPowerPolynomial (firstParameterTuple T)
      (Fin.tail (M.leftConjugationTuple 0 (Fin.succ j) 1 v)) u (K_U k)
  rw [step1U, eval_compose_polynomial]
  apply congrArg (fun f : PowerVar n → ℚ => MvPolynomial.eval f (K_U k))
  funext w
  cases w with
  | param I =>
      simp [evalConjVar, varQ, evalPowerVar, evalVarQ,
        firstParameterTuple, deleteParameterTuple]
  | coord i =>
      simp [evalPowerVar, evalVarQ,
        conj_coord_u M R hR j i u v]
  | exponent =>
      simp [evalConjVar, varQ, evalPowerVar, evalVarQ]

theorem eval_u_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hR : RepresentsConjugation M R)
    (hKU : RepresentsPowering M.deleteFirstConsistent K_U)
    (j k : Fin n) (hjk : j < k) (u v : ℤ) :
    evalConjPolynomial T u v
        (R ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
          Fin.succ_lt_succ_iff.mpr hjk⟩) =
      evalConjPolynomial T u v (step1U R K_U j k) := by
  rw [conj_u_conjugation M R K_U hR]
  rw [hKU (Fin.tail (M.leftConjugationTuple 0 (Fin.succ j) 1 v)) u k]
  change evalConjPolynomial T u v
      (R ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
        Fin.succ_lt_succ_iff.mpr hjk⟩) =
    (M.deleteFirstConsistent.poweringTuple
      (Fin.tail (M.leftConjugationTuple 0 (Fin.succ j) 1 v)) u k : ℚ)
  rw [M.consistent_presentation_powering
    (M.leftConjugationTuple 0 (Fin.succ j) 1 v)
    (M.conjugation_tuple_coordinate (Fin.succ j) (Fin.succ_pos j) 1 v) u]
  change evalConjPolynomial T u v
      (R ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
        Fin.succ_lt_succ_iff.mpr hjk⟩) =
    (M.poweringTuple (M.leftConjugationTuple 0 (Fin.succ j) 1 v) u (Fin.succ k) : ℚ)
  rw [← M.left_conjugation_powering 0 (Fin.succ j) u v]
  exact
    (left_conjugation_represents
      M R hR (Fin.succ j) (Fin.succ k) (Fin.succ_pos j)
        (Fin.succ_lt_succ_iff.mpr hjk) u v).symm

/--
Section 3.2 Lemma `step1` in its lower-rank `U(T)` form, packaged to consume
a represented Hall-polynomial family on the canonical `U(T)` presentation.
-/
theorem conj_u_delete
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hR : RepresentsConjugation M R)
    (j k : Fin n) (hjk : j < k) (u v : ℤ) :
    evalConjPolynomial T u v
        (R ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
          Fin.succ_lt_succ_iff.mpr hjk⟩) =
      evalConjPolynomial T u v (step1U R K_U j k) :=
  eval_u_represents
    M R K_U hR hHallU.2.1 j k hjk u v

/--
Family-level lower-rank `U(T)` form of Section 3.2 Lemma `step1`: replacing
all first-generator tail conjugation coordinates by their lower-rank powering
constructions preserves every integer evaluation.
-/
theorem family_u_delete
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hR : RepresentsConjugation M R)
    (I : ParameterIndex (n + 1)) (u v : ℤ) :
    evalConjPolynomial T u v (R I) =
      evalConjPolynomial T u v (stepFamilyU R K_U I) := by
  rcases I with ⟨⟨i, j, k⟩, hij, hjk⟩
  cases j using Fin.cases with
  | zero =>
      simp [stepFamilyU]
  | succ j' =>
      cases k using Fin.cases with
      | zero =>
          simp [stepFamilyU]
      | succ k' =>
          by_cases hi0 : i = 0
          · subst i
            have hjk' : j' < k' := by
              simpa using (Fin.succ_lt_succ_iff.mp hjk)
            change evalConjPolynomial T u v
                (R ⟨(0, Fin.succ j', Fin.succ k'), hij, hjk⟩) =
              evalConjPolynomial T u v (step1U R K_U j' k')
            exact conj_u_delete
              M F_U K_U R_U R hHallU hR j' k' hjk' u v
          · simp [stepFamilyU, hi0]

/--
Specialized polynomial identity for the family-level lower-rank `U(T)` step1
replacement.
-/
theorem specialize_delete_first
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hR : RepresentsConjugation M R)
    (I : ParameterIndex (n + 1)) :
    specializeConj T (R I) =
      specializeConj T (stepFamilyU R K_U I) :=
  specialize_conj_eval (R I) (stepFamilyU R K_U I)
    (fun u v =>
      family_u_delete
        M F_U K_U R_U R hHallU hR I u v)

/--
Replacing all lower-rank Section 3.2 `step1` coordinates at once by their
`U(T)` powering constructions preserves ambient conjugation representation.
-/
theorem represents_conjugation_first
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hR : RepresentsConjugation M R) :
    RepresentsConjugation M (stepFamilyU R K_U) :=
  represents_conjugation_polynomial M R (stepFamilyU R K_U) hR
    (family_u_delete
      M F_U K_U R_U R hHallU hR)

/--
Family-level lower-rank `U(T)` form of Section 3.2 Lemma `step1`, with the
lower-rank input split down to the powering representation actually used by
the construction.
-/
theorem u_represents_powering
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hKU : RepresentsPowering M.deleteFirstConsistent K_U)
    (hR : RepresentsConjugation M R)
    (I : ParameterIndex (n + 1)) (u v : ℤ) :
    evalConjPolynomial T u v (R I) =
      evalConjPolynomial T u v (stepFamilyU R K_U I) := by
  rcases I with ⟨⟨i, j, k⟩, hij, hjk⟩
  cases j using Fin.cases with
  | zero =>
      simp [stepFamilyU]
  | succ j' =>
      cases k using Fin.cases with
      | zero =>
          simp [stepFamilyU]
      | succ k' =>
          by_cases hi0 : i = 0
          · subst i
            have hjk' : j' < k' := by
              simpa using (Fin.succ_lt_succ_iff.mp hjk)
            change evalConjPolynomial T u v
                (R ⟨(0, Fin.succ j', Fin.succ k'), hij, hjk⟩) =
              evalConjPolynomial T u v (step1U R K_U j' k')
            exact eval_u_represents
              M R K_U hR hKU j' k' hjk' u v
          · simp [stepFamilyU, hi0]

/--
Specialized polynomial identity for the family-level lower-rank `U(T)` step1
replacement, assuming only represented lower-rank powering.
-/
theorem specialize_represents_powering
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hKU : RepresentsPowering M.deleteFirstConsistent K_U)
    (hR : RepresentsConjugation M R)
    (I : ParameterIndex (n + 1)) :
    specializeConj T (R I) =
      specializeConj T (stepFamilyU R K_U I) :=
  specialize_conj_eval (R I) (stepFamilyU R K_U I)
    (fun u v =>
      u_represents_powering
        M K_U R hKU hR I u v)

/--
Replacing all lower-rank Section 3.2 `step1` coordinates at once preserves
ambient conjugation representation from represented lower-rank powering alone.
-/
theorem conjugation_u_powering
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hKU : RepresentsPowering M.deleteFirstConsistent K_U)
    (hR : RepresentsConjugation M R) :
    RepresentsConjugation M (stepFamilyU R K_U) :=
  represents_conjugation_polynomial M R (stepFamilyU R K_U) hR
    (u_represents_powering
      M K_U R hKU hR)

/--
Replacing the Section 3.2 `step1` conjugation coordinate by the lower-rank
`U(T)` powering construction preserves the ambient conjugation representation.
-/
theorem conjugation_update_u
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hR : RepresentsConjugation M R)
    (hKU : RepresentsPowering M.deleteFirstConsistent K_U)
    (j k : Fin n) (hjk : j < k) :
    RepresentsConjugation M
      (Function.update R
        ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
          Fin.succ_lt_succ_iff.mpr hjk⟩
        (step1U R K_U j k)) := by
  exact conjugation_update_conj M R hR
    ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
      Fin.succ_lt_succ_iff.mpr hjk⟩
    (step1U R K_U j k)
    (fun u v =>
      eval_u_represents
        M R K_U hR hKU j k hjk u v)

/--
Version of `conjugation_update_u` packaged
to consume a represented Hall-polynomial family on canonical `U(T)`.
-/
theorem represents_conjugation_update
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hR : RepresentsConjugation M R)
    (j k : Fin n) (hjk : j < k) :
    RepresentsConjugation M
      (Function.update R
        ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
          Fin.succ_lt_succ_iff.mpr hjk⟩
        (step1U R K_U j k)) :=
  conjugation_update_u
    M R K_U hR hHallU.2.1 j k hjk

/--
Induction-hypothesis-shaped Section 3.2 `step1` update package: consume
existential Hall polynomials for canonical `U(T)` and return the updated
ambient conjugation family, together with the specialized and all-integer
identities at the replaced coordinate.
-/
theorem represents_update_first
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHallU :
      ∃ (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
        (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
        (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
          RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hR : RepresentsConjugation M R)
    (j k : Fin n) (hjk : j < k) :
    ∃ R' : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ,
      RepresentsConjugation M R' ∧
      (∀ I, I ≠
        ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
          Fin.succ_lt_succ_iff.mpr hjk⟩ → R' I = R I) ∧
      specializeConj T
          (R ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
            Fin.succ_lt_succ_iff.mpr hjk⟩) =
        specializeConj T
          (R' ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
            Fin.succ_lt_succ_iff.mpr hjk⟩) ∧
      ∀ u v,
        evalConjPolynomial T u v
            (R ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
              Fin.succ_lt_succ_iff.mpr hjk⟩) =
          evalConjPolynomial T u v
            (R' ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
              Fin.succ_lt_succ_iff.mpr hjk⟩) := by
  rcases hHallU with ⟨F_U, K_U, R_U, hHallU⟩
  let I : ParameterIndex (n + 1) :=
    ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
      Fin.succ_lt_succ_iff.mpr hjk⟩
  let R' := Function.update R I (step1U R K_U j k)
  refine ⟨R', ?_, ?_, ?_, ?_⟩
  · exact represents_conjugation_update
      M F_U K_U R_U R hHallU hR j k hjk
  · intro J hJ
    exact Function.update_of_ne hJ (step1U R K_U j k) R
  · change specializeConj T (R I) = specializeConj T (R' I)
    change specializeConj T (R I) =
      specializeConj T ((Function.update R I (step1U R K_U j k)) I)
    rw [Function.update_self]
    exact specialize_conj_eval (R I) (step1U R K_U j k)
      (fun u v =>
        conj_u_delete
          M F_U K_U R_U R hHallU hR j k hjk u v)
  · intro u v
    change evalConjPolynomial T u v (R I) = evalConjPolynomial T u v (R' I)
    change evalConjPolynomial T u v (R I) =
      evalConjPolynomial T u v
        ((Function.update R I (step1U R K_U j k)) I)
    rw [Function.update_self]
    exact conj_u_delete
      M F_U K_U R_U R hHallU hR j k hjk u v

/--
Section 3.2 `step1` update package with the lower-rank input split down to the
represented powering family used by the coordinate replacement.
-/
theorem step_update_powering
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hKU : RepresentsPowering M.deleteFirstConsistent K_U)
    (hR : RepresentsConjugation M R)
    (j k : Fin n) (hjk : j < k) :
    ∃ R' : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ,
      RepresentsConjugation M R' ∧
      (∀ I, I ≠
        ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
          Fin.succ_lt_succ_iff.mpr hjk⟩ → R' I = R I) ∧
      specializeConj T
          (R ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
            Fin.succ_lt_succ_iff.mpr hjk⟩) =
        specializeConj T
          (R' ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
            Fin.succ_lt_succ_iff.mpr hjk⟩) ∧
      ∀ u v,
        evalConjPolynomial T u v
            (R ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
              Fin.succ_lt_succ_iff.mpr hjk⟩) =
          evalConjPolynomial T u v
            (R' ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
              Fin.succ_lt_succ_iff.mpr hjk⟩) := by
  let I : ParameterIndex (n + 1) :=
    ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
      Fin.succ_lt_succ_iff.mpr hjk⟩
  let R' := Function.update R I (step1U R K_U j k)
  refine ⟨R', ?_, ?_, ?_, ?_⟩
  · exact conjugation_update_u
      M R K_U hR hKU j k hjk
  · intro J hJ
    exact Function.update_of_ne hJ (step1U R K_U j k) R
  · change specializeConj T (R I) = specializeConj T (R' I)
    change specializeConj T (R I) =
      specializeConj T ((Function.update R I (step1U R K_U j k)) I)
    rw [Function.update_self]
    exact specialize_conj_eval (R I) (step1U R K_U j k)
      (fun u v =>
        eval_u_represents
          M R K_U hR hKU j k hjk u v)
  · intro u v
    change evalConjPolynomial T u v (R I) = evalConjPolynomial T u v (R' I)
    change evalConjPolynomial T u v (R I) =
      evalConjPolynomial T u v
        ((Function.update R I (step1U R K_U j k)) I)
    rw [Function.update_self]
    exact eval_u_represents
      M R K_U hR hKU j k hjk u v

/--
Existential lower-rank-powering version of the Section 3.2 `step1`
conjugation update package.
-/
theorem conjugation_update_powering
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hKU :
      ∃ K_U : Fin n → MvPolynomial (PowerVar n) ℚ,
        RepresentsPowering M.deleteFirstConsistent K_U)
    (hR : RepresentsConjugation M R)
    (j k : Fin n) (hjk : j < k) :
    ∃ R' : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ,
      RepresentsConjugation M R' ∧
      (∀ I, I ≠
        ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
          Fin.succ_lt_succ_iff.mpr hjk⟩ → R' I = R I) ∧
      specializeConj T
          (R ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
            Fin.succ_lt_succ_iff.mpr hjk⟩) =
        specializeConj T
          (R' ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
            Fin.succ_lt_succ_iff.mpr hjk⟩) ∧
      ∀ u v,
        evalConjPolynomial T u v
            (R ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
              Fin.succ_lt_succ_iff.mpr hjk⟩) =
          evalConjPolynomial T u v
            (R' ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
              Fin.succ_lt_succ_iff.mpr hjk⟩) := by
  rcases hKU with ⟨K_U, hKU⟩
  exact step_update_powering
    M R K_U hKU hR j k hjk

/--
Specialized polynomial identity form of the lower-rank `U(T)` version of
Cant--Eick Section 3.2 Lemma `step1`.
-/
theorem specialize_u_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hR : RepresentsConjugation M R)
    (hKU : RepresentsPowering M.deleteFirstConsistent K_U)
    (j k : Fin n) (hjk : j < k) :
    specializeConj T
        (R ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
          Fin.succ_lt_succ_iff.mpr hjk⟩) =
      specializeConj T (step1U R K_U j k) := by
  apply MvPolynomial.funext_set
    (s := fun _ : ConjInputVar (n + 1) => Set.range fun z : ℤ => (z : ℚ))
  · intro w
    exact Set.infinite_range_of_injective Int.cast_injective
  · intro q hq
    choose z hz using fun w => hq w (Set.mem_univ w)
    let u : ℤ := z ConjInputVar.u
    let v : ℤ := z ConjInputVar.v
    have hq_eq : q = conjInputVar u v := by
      funext w
      cases w <;> exact (hz _).symm
    rw [hq_eq, eval_specializeConj, eval_specializeConj]
    exact eval_u_represents
      M R K_U hR hKU j k hjk u v

/--
Specialized polynomial identity form of lower-rank `step1`, packaged to
consume a represented Hall-polynomial family on canonical `U(T)`.
-/
theorem specialize_conj_delete
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hR : RepresentsConjugation M R)
    (j k : Fin n) (hjk : j < k) :
    specializeConj T
        (R ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
          Fin.succ_lt_succ_iff.mpr hjk⟩) =
      specializeConj T (step1U R K_U j k) :=
  specialize_u_represents
    M R K_U hR hHallU.2.1 j k hjk

/-- Existential wrapper for the lower-rank `U(T)` polynomial in Section 3.2 `step1`. -/
theorem conj_step_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hR : RepresentsConjugation M R)
    (hKU : RepresentsPowering M.deleteFirstConsistent K_U)
    (j k : Fin n) (hjk : j < k) :
    ∃ p : MvPolynomial (ConjVar (n + 1)) ℚ,
      ∀ u v,
        evalConjPolynomial T u v
            (R ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
              Fin.succ_lt_succ_iff.mpr hjk⟩) =
          evalConjPolynomial T u v p :=
  ⟨step1U R K_U j k,
    fun u v =>
      eval_u_represents
        M R K_U hR hKU j k hjk u v⟩

/--
Existential wrapper for lower-rank `step1`, packaged to consume a represented
Hall-polynomial family on canonical `U(T)`.
-/
theorem conj_1_delete
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hR : RepresentsConjugation M R)
    (j k : Fin n) (hjk : j < k) :
    ∃ p : MvPolynomial (ConjVar (n + 1)) ℚ,
      ∀ u v,
        evalConjPolynomial T u v
            (R ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
              Fin.succ_lt_succ_iff.mpr hjk⟩) =
          evalConjPolynomial T u v p :=
  conj_step_represents
    M R K_U hR hHallU.2.1 j k hjk

/--
Induction-hypothesis-shaped lower-rank `U(T)` wrapper for Section 3.2
`step1`: consume existential Hall polynomials for the canonical delete-first
presentation and return the constructed ambient conjugation polynomial together
with its specialized polynomial identity.
-/
theorem conj_1_first
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHallU :
      ∃ (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
        (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
        (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
          RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hR : RepresentsConjugation M R)
    (j k : Fin n) (hjk : j < k) :
    ∃ p : MvPolynomial (ConjVar (n + 1)) ℚ,
      specializeConj T
          (R ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
            Fin.succ_lt_succ_iff.mpr hjk⟩) =
        specializeConj T p ∧
      ∀ u v,
        evalConjPolynomial T u v
            (R ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
              Fin.succ_lt_succ_iff.mpr hjk⟩) =
          evalConjPolynomial T u v p := by
  rcases hHallU with ⟨F_U, K_U, R_U, hHallU⟩
  refine ⟨step1U R K_U j k, ?_, ?_⟩
  · exact specialize_conj_delete
      M F_U K_U R_U R hHallU hR j k hjk
  · exact conj_u_delete
      M F_U K_U R_U R hHallU hR j k hjk

/--
Existential lower-rank-powering wrapper for the constructed lower-rank
`step1` polynomial.
-/
theorem conj_first_powering
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hKU :
      ∃ K_U : Fin n → MvPolynomial (PowerVar n) ℚ,
        RepresentsPowering M.deleteFirstConsistent K_U)
    (hR : RepresentsConjugation M R)
    (j k : Fin n) (hjk : j < k) :
    ∃ p : MvPolynomial (ConjVar (n + 1)) ℚ,
      specializeConj T
          (R ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
            Fin.succ_lt_succ_iff.mpr hjk⟩) =
        specializeConj T p ∧
      ∀ u v,
        evalConjPolynomial T u v
            (R ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
              Fin.succ_lt_succ_iff.mpr hjk⟩) =
          evalConjPolynomial T u v p := by
  rcases hKU with ⟨K_U, hKU⟩
  refine ⟨step1U R K_U j k, ?_, ?_⟩
  · exact specialize_u_represents
      M R K_U hR hKU j k hjk
  · exact eval_u_represents
      M R K_U hR hKU j k hjk

theorem powering_conjugation_first
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k) (u v : ℤ)
    (hConj :
      evalConjPolynomial T u v (R ⟨(0, j, k), h0j, hjk⟩) =
        (M.leftConjugationTuple 0 j u v k : ℚ))
    (hPower :
      evalPowerPolynomial T (M.leftConjugationTuple 0 j 1 v) u (K k) =
        (M.poweringTuple (M.leftConjugationTuple 0 j 1 v) u k : ℚ)) :
    evalConjPolynomial T u v (R ⟨(0, j, k), h0j, hjk⟩) =
      evalPowerPolynomial T (M.leftConjugationTuple 0 j 1 v) u (K k) := by
  rw [hConj, hPower]
  rw [M.left_conjugation_powering 0 j u v]

theorem powering_conjugation_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (hR : RepresentsConjugation M R)
    (hK : RepresentsPowering M K)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k) (u v : ℤ) :
    evalConjPolynomial T u v (R ⟨(0, j, k), h0j, hjk⟩) =
      evalPowerPolynomial T (M.leftConjugationTuple 0 j 1 v) u (K k) := by
  exact powering_conjugation_first
    M R K j k h0j hjk u v
    (conjugation_tail_represents
      M R hR j k h0j hjk u v)
    (hK (M.leftConjugationTuple 0 j 1 v) u k)

lemma conj_conjugation_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (hR : RepresentsConjugation M R)
    (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j)
    (k : Fin (n + 1)) (u v : ℤ) :
    evalConjPolynomial T u v (conjStep1 R K j h0j k) =
      evalPowerPolynomial T (M.leftConjugationTuple 0 j 1 v) u (K k) := by
  change
    MvPolynomial.eval (evalConjVar T u v)
        (MvPolynomial.eval₂ MvPolynomial.C (conj1Subst R j h0j) (K k)) =
      MvPolynomial.eval (evalPowerVar T (M.leftConjugationTuple 0 j 1 v) u) (K k)
  rw [← MvPolynomial.eval_assoc]
  apply congrArg (fun f : PowerVar (n + 1) → ℚ => MvPolynomial.eval f (K k))
  funext w
  cases w with
  | param I =>
      simp [conj1Subst, evalConjVar, varQ, evalPowerVar, evalVarQ]
  | exponent =>
      simp [conj1Subst, evalConjVar, varQ, evalPowerVar, evalVarQ]
  | coord i =>
      have hleft := conjugation_tuple_without M R hR j h0j 1 v
      rw [hleft]
      by_cases hi0 : i = (0 : Fin (n + 1))
      · subst i
        have h0ne : (0 : Fin (n + 1)) ≠ j := ne_of_lt h0j
        simp [conj1Subst, evalConjVar, evalPowerVar, evalVarQ, h0ne]
      · by_cases hij : i = j
        · subst i
          have hmid := represents_conjugation_middle M R hR 0 j h0j 1 v
          simp [conj1Subst, evalConjVar, evalPowerVar,
            evalVarQ, withoutFirstCoord, hi0, hmid]
        · by_cases hji : j < i
          · have htail := conjugation_tail_represents
              M R hR j i h0j hji 1 v
            rw [hleft] at htail
            simp [withoutFirstCoord, hi0] at htail
            simp only [Function.comp_apply, conj1Subst, hij, hji,
              ↓reduceIte, evalPowerVar, evalVarQ]
            change evalConjPolynomial T u v
                (conjSetU (R ⟨(0, j, i), h0j, hji⟩)) =
              (withoutFirstCoord (M.conjugationTuple 0 j 1 v) i : ℚ)
            rw [set_u_polynomial]
            simpa [withoutFirstCoord, hi0] using htail
          · have hzeroq : (M.conjugationTuple 0 j 1 v i : ℚ) = 0 := by
              have h := hR 0 j h0j 1 v i
              have hi0' : i ≠ (0 : Fin (n + 1)) := hi0
              have hij' : i ≠ j := hij
              simpa [CPres.conjugationTuple, conjugationCoordinateQ,
                hi0', hij', hji] using h
            simp [conj1Subst, evalConjVar, evalPowerVar,
              evalVarQ, withoutFirstCoord, hi0, hij, hji, hzeroq]

/--
Fully polynomial form of Section 3.1 Lemma `step1`: under represented
conjugation and powering, `R_{0,j,k}(T;u,v)` and the composed polynomial
`K_k(T;r,u)` agree on all integer evaluations.
-/
theorem step_1_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (hR : RepresentsConjugation M R)
    (hK : RepresentsPowering M K)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k) (u v : ℤ) :
    evalConjPolynomial T u v (R ⟨(0, j, k), h0j, hjk⟩) =
      evalConjPolynomial T u v (conjStep1 R K j h0j k) := by
  rw [powering_conjugation_represents
    M R K hR hK j k h0j hjk u v]
  rw [conj_conjugation_represents
    M R K hR j h0j k u v]

/--
Replacing the Section 3.2 `step1` conjugation coordinate by the ambient
powering construction preserves the conjugation representation predicate.
-/
theorem conjugation_update_1
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (hR : RepresentsConjugation M R)
    (hK : RepresentsPowering M K)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k) :
    RepresentsConjugation M
      (Function.update R ⟨(0, j, k), h0j, hjk⟩
        (conjStep1 R K j h0j k)) := by
  exact conjugation_update_conj M R hR
    ⟨(0, j, k), h0j, hjk⟩ (conjStep1 R K j h0j k)
    (fun u v =>
      step_1_represents
        M R K hR hK j k h0j hjk u v)

/--
The family-level Section 3.2 `step1` replacement agrees with the represented
conjugation family on every integer input.
-/
theorem conj_family_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (hR : RepresentsConjugation M R)
    (hK : RepresentsPowering M K)
    (I : ParameterIndex (n + 1)) (u v : ℤ) :
    evalConjPolynomial T u v (R I) =
      evalConjPolynomial T u v (conj1Family R K I) := by
  rcases I with ⟨⟨i, j, k⟩, hij, hjk⟩
  by_cases hi0 : i = (0 : Fin (n + 1))
  · have h0j : (0 : Fin (n + 1)) < j := by
      simpa [hi0] using hij
    subst i
    simpa [conj1Family] using
      step_1_represents
        M R K hR hK j k h0j hjk u v
  · simp [conj1Family, hi0]

/--
Replacing all first-generator Section 3.2 `step1` conjugation coordinates by
their ambient powering constructions preserves `RepresentsConjugation`.
-/
theorem represents_1_family
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (hR : RepresentsConjugation M R)
    (hK : RepresentsPowering M K) :
    RepresentsConjugation M (conj1Family R K) := by
  exact represents_conjugation_polynomial M R
    (conj1Family R K) hR
    (conj_family_represents M R K hR hK)

/--
Polynomial identity form of Cant--Eick Lemma `step1` after specializing the
parameters to a represented presentation.
-/
theorem specialize_conj_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (hR : RepresentsConjugation M R)
    (hK : RepresentsPowering M K)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k) :
    specializeConj T (R ⟨(0, j, k), h0j, hjk⟩) =
      specializeConj T (conjStep1 R K j h0j k) := by
  apply MvPolynomial.funext_set
    (s := fun _ : ConjInputVar (n + 1) => Set.range fun z : ℤ => (z : ℚ))
  · intro w
    exact Set.infinite_range_of_injective Int.cast_injective
  · intro q hq
    choose z hz using fun w => hq w (Set.mem_univ w)
    let u : ℤ := z ConjInputVar.u
    let v : ℤ := z ConjInputVar.v
    have hq_eq : q = conjInputVar u v := by
      funext w
      cases w <;> exact (hz _).symm
    rw [hq_eq, eval_specializeConj, eval_specializeConj]
    exact step_1_represents
      M R K hR hK j k h0j hjk u v

/-- Existential wrapper for the composed polynomial in Section 3.1 Lemma `step1`. -/
theorem conj_polynomial_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (hR : RepresentsConjugation M R)
    (hK : RepresentsPowering M K)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k) :
    ∃ p : MvPolynomial (ConjVar (n + 1)) ℚ,
      ∀ u v,
        evalConjPolynomial T u v (R ⟨(0, j, k), h0j, hjk⟩) =
          evalConjPolynomial T u v p := by
  exact ⟨conjStep1 R K j h0j k,
    fun u v =>
      step_1_represents
        M R K hR hK j k h0j hjk u v⟩

/--
Bernoulli-polynomial solution of the Section 3.2 conjugation recursion at
`u = 1`, after specializing the parameters.  For natural `v`, the represented
tail coordinate is the unique zero-initial polynomial antiderivative of the
forward difference `R(T;1,v+1)-R(T;1,v)`.
-/
theorem conj_antiderivative_represents
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hR : RepresentsConjugation M R)
    (i j k : Fin n) (hij : i < j) (hjk : j < k) (v : ℕ) :
    evalConjPolynomial T 1 (v : ℤ) (R ⟨(i, j, k), hij, hjk⟩) =
      (polynomialForwardAntiderivative (0 : ℚ)
        (conjUnivariatePolynomial T
          (forwardDifferenceV R ⟨(i, j, k), hij, hjk⟩))).eval
          (v : ℚ) := by
  let I : ParameterIndex n := ⟨(i, j, k), hij, hjk⟩
  let f := conjUnivariatePolynomial T (conjUPolynomial (R I))
  let g := conjUnivariatePolynomial T (forwardDifferenceV R I)
  have h0 : f.eval 0 = (0 : ℚ) := by
    change
      (conjUnivariatePolynomial T (conjUPolynomial (R I))).eval (0 : ℚ) =
        (0 : ℚ)
    rw [show (0 : ℚ) = ((0 : ℤ) : ℚ) by norm_num,
      conj_univariate_polynomial, conj_u_polynomial]
    exact conj_right_represents M R hR i j k hij hjk 1
  have hrec : ∀ v : ℕ, f.eval ((v : ℚ) + 1) = f.eval (v : ℚ) + g.eval (v : ℚ) := by
    intro v
    change
      (conjUnivariatePolynomial T (conjUPolynomial (R I))).eval
          ((v : ℚ) + 1) =
        (conjUnivariatePolynomial T (conjUPolynomial (R I))).eval
            (v : ℚ) +
          (conjUnivariatePolynomial T
            (forwardDifferenceV R I)).eval (v : ℚ)
    rw [show ((v : ℚ) + 1) = (((v : ℤ) + 1 : ℤ) : ℚ) by
        norm_num [Int.cast_add, Nat.cast_add, Nat.cast_one],
      show (v : ℚ) = ((v : ℤ) : ℚ) by norm_num]
    rw [conj_univariate_polynomial T ((v : ℤ) + 1),
      conj_univariate_polynomial T (v : ℤ),
      conj_univariate_polynomial T (v : ℤ),
      conj_u_polynomial, conj_u_polynomial]
    exact eval_forward_difference R T (v : ℤ) I
  have hunique :=
    forward_antiderivative_solves
      (R := ℚ) (f := f) (g := g) (f₀ := 0) h0 hrec v
  rw [← hunique]
  change evalConjPolynomial T 1 (v : ℤ) (R I) =
    (conjUnivariatePolynomial T (conjUPolynomial (R I))).eval (v : ℚ)
  rw [show (v : ℚ) = ((v : ℤ) : ℚ) by norm_num,
    conj_univariate_polynomial, conj_u_polynomial]

/--
Polynomial identity form of the Bernoulli solution for the represented
conjugation recursion at `u = 1`, after specializing the parameters.
-/
theorem univariate_polynomial_antiderivative
    {T : ParameterIndex n → ℤ}
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (I : ParameterIndex n)
    (hZero : evalConjPolynomial T 1 0 (R I) = 0) :
    conjUnivariatePolynomial T (conjUPolynomial (R I)) =
      polynomialForwardAntiderivative (0 : ℚ)
        (conjUnivariatePolynomial T (forwardDifferenceV R I)) := by
  let f := conjUnivariatePolynomial T (conjUPolynomial (R I))
  let g := conjUnivariatePolynomial T (forwardDifferenceV R I)
  have h0 : f.eval 0 = (0 : ℚ) := by
    change
      (conjUnivariatePolynomial T (conjUPolynomial (R I))).eval (0 : ℚ) =
        (0 : ℚ)
    rw [show (0 : ℚ) = ((0 : ℤ) : ℚ) by norm_num,
      conj_univariate_polynomial, conj_u_polynomial]
    exact hZero
  have hrec : ∀ v : ℕ, f.eval ((v : ℚ) + 1) = f.eval (v : ℚ) + g.eval (v : ℚ) := by
    intro v
    change
      (conjUnivariatePolynomial T (conjUPolynomial (R I))).eval
          ((v : ℚ) + 1) =
        (conjUnivariatePolynomial T (conjUPolynomial (R I))).eval
            (v : ℚ) +
          (conjUnivariatePolynomial T
            (forwardDifferenceV R I)).eval (v : ℚ)
    rw [show ((v : ℚ) + 1) = (((v : ℤ) + 1 : ℤ) : ℚ) by
        norm_num [Int.cast_add, Nat.cast_add, Nat.cast_one],
      show (v : ℚ) = ((v : ℤ) : ℚ) by norm_num]
    rw [conj_univariate_polynomial T ((v : ℤ) + 1),
      conj_univariate_polynomial T (v : ℤ),
      conj_univariate_polynomial T (v : ℤ),
      conj_u_polynomial, conj_u_polynomial]
    exact eval_forward_difference R T (v : ℤ) I
  change f = polynomialForwardAntiderivative (0 : ℚ) g
  exact polynomial_antiderivative_solves (R := ℚ) (f := f) (g := g)
    (f₀ := 0) h0 hrec

theorem univariate_antiderivative_represents
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hR : RepresentsConjugation M R)
    (i j k : Fin n) (hij : i < j) (hjk : j < k) :
    conjUnivariatePolynomial T
        (conjUPolynomial (R ⟨(i, j, k), hij, hjk⟩)) =
      polynomialForwardAntiderivative (0 : ℚ)
        (conjUnivariatePolynomial T
          (forwardDifferenceV R ⟨(i, j, k), hij, hjk⟩)) := by
  exact univariate_polynomial_antiderivative
    R ⟨(i, j, k), hij, hjk⟩
    (conj_right_represents M R hR i j k hij hjk 1)

/-- All-integer evaluation form of the Bernoulli solution for represented conjugation. -/
theorem eval_forward_antiderivative
    {T : ParameterIndex n → ℤ}
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (I : ParameterIndex n)
    (hZero : evalConjPolynomial T 1 0 (R I) = 0)
    (v : ℤ) :
    evalConjPolynomial T 1 v (R I) =
      (polynomialForwardAntiderivative (0 : ℚ)
        (conjUnivariatePolynomial T
          (forwardDifferenceV R I))).eval (v : ℚ) := by
  rw [← univariate_polynomial_antiderivative
    R I hZero]
  rw [conj_univariate_polynomial, conj_u_polynomial]

theorem int_antiderivative_represents
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hR : RepresentsConjugation M R)
    (i j k : Fin n) (hij : i < j) (hjk : j < k) (v : ℤ) :
    evalConjPolynomial T 1 v (R ⟨(i, j, k), hij, hjk⟩) =
      (polynomialForwardAntiderivative (0 : ℚ)
        (conjUnivariatePolynomial T
          (forwardDifferenceV R ⟨(i, j, k), hij, hjk⟩))).eval
          (v : ℚ) := by
  exact eval_forward_antiderivative
    R ⟨(i, j, k), hij, hjk⟩
    (conj_right_represents M R hR i j k hij hjk 1) v

/--
Bernoulli solution of the Section 3.2 recursion using the increment
polynomial constructed from the displayed product in Lemma `step2`.
-/
theorem univariate_antiderivative_eval
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k)
    (hZero : evalConjPolynomial T 1 0 (R ⟨(0, j, k), h0j, hjk⟩) = 0)
    (hForward :
      conjUnivariatePolynomial T
          (forwardDifferenceV R ⟨(0, j, k), h0j, hjk⟩) =
        conjUnivariatePolynomial T
          (conjForwardDifference F R j h0j k hjk)) :
    conjUnivariatePolynomial T
        (conjUPolynomial (R ⟨(0, j, k), h0j, hjk⟩)) =
      polynomialForwardAntiderivative (0 : ℚ)
        (conjUnivariatePolynomial T
          (conjForwardDifference F R j h0j k hjk)) := by
  rw [← hForward]
  exact univariate_polynomial_antiderivative
    R ⟨(0, j, k), h0j, hjk⟩ hZero

/--
Bernoulli solution of the ambient step-2 recursion with the forward-difference
identity derived from current-coordinate and product-evaluation hypotheses.
-/
theorem antiderivative_no_delta
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k)
    (hZero : evalConjPolynomial T 1 0 (R ⟨(0, j, k), h0j, hjk⟩) = 0)
    (hCurrent : ∀ v : ℤ,
      evalConjPolynomial T 1 v (R ⟨(0, j, k), h0j, hjk⟩) =
        (M.leftConjugationTuple 0 j 1 v k : ℚ))
    (hProduct : ∀ v : ℤ,
      conjOnePolynomial T v (conjStep2 F R j h0j k) =
        (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1) k :
          ℚ)) :
    conjUnivariatePolynomial T
        (conjUPolynomial (R ⟨(0, j, k), h0j, hjk⟩)) =
      polynomialForwardAntiderivative (0 : ℚ)
        (conjUnivariatePolynomial T
          (conjForwardDifference F R j h0j k hjk)) :=
  univariate_antiderivative_eval
    F R j k h0j hjk hZero
    (univariate_forward_delta
      M F R j k h0j hjk hCurrent hProduct)

theorem univariate_forward_2
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hR : RepresentsConjugation M R)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k) :
    conjUnivariatePolynomial T
        (conjUPolynomial (R ⟨(0, j, k), h0j, hjk⟩)) =
      polynomialForwardAntiderivative (0 : ℚ)
        (conjUnivariatePolynomial T
          (conjForwardDifference F R j h0j k hjk)) := by
  exact univariate_antiderivative_eval
    F R j k h0j hjk
    (conj_right_represents M R hR 0 j k h0j hjk 1)
    (univariate_difference_2
      M F R hF hR j k h0j hjk)

/--
All-integer evaluation form of the Section 3.2 Bernoulli solution using the
product-derived increment polynomial from Lemma `step2`.
-/
theorem forward_antiderivative_2
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k)
    (hZero : evalConjPolynomial T 1 0 (R ⟨(0, j, k), h0j, hjk⟩) = 0)
    (hForward :
      conjUnivariatePolynomial T
          (forwardDifferenceV R ⟨(0, j, k), h0j, hjk⟩) =
        conjUnivariatePolynomial T
          (conjForwardDifference F R j h0j k hjk))
    (v : ℤ) :
    evalConjPolynomial T 1 v (R ⟨(0, j, k), h0j, hjk⟩) =
      (polynomialForwardAntiderivative (0 : ℚ)
        (conjUnivariatePolynomial T
          (conjForwardDifference F R j h0j k hjk))).eval
          (v : ℚ) := by
  rw [← univariate_antiderivative_eval
    F R j k h0j hjk hZero hForward]
  rw [conj_univariate_polynomial, conj_u_polynomial]

/--
All-integer evaluation form of the ambient step-2 Bernoulli solution with the
forward-difference identity derived from current-coordinate and product data.
-/
theorem forward_antiderivative_delta
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k)
    (hZero : evalConjPolynomial T 1 0 (R ⟨(0, j, k), h0j, hjk⟩) = 0)
    (hCurrent : ∀ v : ℤ,
      evalConjPolynomial T 1 v (R ⟨(0, j, k), h0j, hjk⟩) =
        (M.leftConjugationTuple 0 j 1 v k : ℚ))
    (hProduct : ∀ v : ℤ,
      conjOnePolynomial T v (conjStep2 F R j h0j k) =
        (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1) k :
          ℚ))
    (v : ℤ) :
    evalConjPolynomial T 1 v (R ⟨(0, j, k), h0j, hjk⟩) =
      (polynomialForwardAntiderivative (0 : ℚ)
        (conjUnivariatePolynomial T
          (conjForwardDifference F R j h0j k hjk))).eval
          (v : ℚ) :=
  forward_antiderivative_2
    F R j k h0j hjk hZero
    (univariate_forward_delta
      M F R j k h0j hjk hCurrent hProduct)
    v

theorem forward_antiderivative_step
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hR : RepresentsConjugation M R)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k)
    (v : ℤ) :
    evalConjPolynomial T 1 v (R ⟨(0, j, k), h0j, hjk⟩) =
      (polynomialForwardAntiderivative (0 : ℚ)
        (conjUnivariatePolynomial T
          (conjForwardDifference F R j h0j k hjk))).eval
          (v : ℚ) := by
  exact forward_antiderivative_2
    F R j k h0j hjk
    (conj_right_represents M R hR 0 j k h0j hjk 1)
    (univariate_difference_2
      M F R hF hR j k h0j hjk)
    v

/--
Constructed-polynomial form of Section 3.2 Lemma `step2`: after parameter
specialization, the represented `R(T;1,v)` agrees with the canonical
zero-initial solution of the product-derived forward recursion.
-/
theorem univariate_2_solution
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hR : RepresentsConjugation M R)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k) :
    conjUnivariatePolynomial T
        (conjUPolynomial (R ⟨(0, j, k), h0j, hjk⟩)) =
      conjUnivariatePolynomial T
        (conjSolutionPolynomial F R j h0j k hjk) := by
  rw [conjSolutionPolynomial, univariate_antiderivative_polynomial]
  exact univariate_forward_2
    M F R hF hR j k h0j hjk

/--
Constructed-polynomial form of Section 3.2 Lemma `step2`, with the
forward-difference identity derived from current-coordinate and product data.
-/
theorem conj_univariate_delta
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k)
    (hZero : evalConjPolynomial T 1 0 (R ⟨(0, j, k), h0j, hjk⟩) = 0)
    (hCurrent : ∀ v : ℤ,
      evalConjPolynomial T 1 v (R ⟨(0, j, k), h0j, hjk⟩) =
        (M.leftConjugationTuple 0 j 1 v k : ℚ))
    (hProduct : ∀ v : ℤ,
      conjOnePolynomial T v (conjStep2 F R j h0j k) =
        (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1) k :
          ℚ)) :
    conjUnivariatePolynomial T
        (conjUPolynomial (R ⟨(0, j, k), h0j, hjk⟩)) =
      conjUnivariatePolynomial T
        (conjSolutionPolynomial F R j h0j k hjk) := by
  rw [conjSolutionPolynomial, univariate_antiderivative_polynomial]
  exact
    antiderivative_no_delta
      M F R j k h0j hjk hZero hCurrent hProduct

/--
Evaluation form of `univariate_2_solution`.
-/
theorem conj_int_solution
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hR : RepresentsConjugation M R)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k)
    (v : ℤ) :
    evalConjPolynomial T 1 v (R ⟨(0, j, k), h0j, hjk⟩) =
      conjOnePolynomial T v
        (conjSolutionPolynomial F R j h0j k hjk) := by
  have hpoly :=
    univariate_2_solution
      M F R hF hR j k h0j hjk
  have hval := congrArg (fun p : Polynomial ℚ => p.eval (v : ℚ)) hpoly
  simpa [conj_univariate_polynomial, conj_u_polynomial] using hval

/--
Evaluation form of the exact-data ambient Section 3.2 constructed solution.
-/
theorem int_solution_delta
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k)
    (hZero : evalConjPolynomial T 1 0 (R ⟨(0, j, k), h0j, hjk⟩) = 0)
    (hCurrent : ∀ v : ℤ,
      evalConjPolynomial T 1 v (R ⟨(0, j, k), h0j, hjk⟩) =
        (M.leftConjugationTuple 0 j 1 v k : ℚ))
    (hProduct : ∀ v : ℤ,
      conjOnePolynomial T v (conjStep2 F R j h0j k) =
        (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1) k :
          ℚ))
    (v : ℤ) :
    evalConjPolynomial T 1 v (R ⟨(0, j, k), h0j, hjk⟩) =
      conjOnePolynomial T v
        (conjSolutionPolynomial F R j h0j k hjk) := by
  have hpoly :=
    conj_univariate_delta
      M F R j k h0j hjk hZero hCurrent hProduct
  have hval := congrArg (fun p : Polynomial ℚ => p.eval (v : ℚ)) hpoly
  simpa [conj_univariate_polynomial, conj_u_polynomial] using hval

/--
The constructed Section 3.2 step-2 solution is zero-initial, before assuming
that the conjugation family represents the presentation.
-/
theorem eval_conj_solution
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j)
    (k : Fin (n + 1)) (hjk : j < k) :
    conjOnePolynomial T 0 (conjSolutionPolynomial F R j h0j k hjk) = 0 := by
  rw [← conj_univariate_polynomial T (0 : ℤ)
    (conjSolutionPolynomial F R j h0j k hjk)]
  rw [conjSolutionPolynomial, univariate_antiderivative_polynomial]
  simpa using forward_antiderivative_zero (0 : ℚ)
    (conjUnivariatePolynomial T (conjForwardDifference F R j h0j k hjk))

/--
The constructed Section 3.2 step-2 solution satisfies the product-derived
forward recursion, before any representation hypothesis is used.
-/
theorem conj_succ_solution
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j)
    (k : Fin (n + 1)) (hjk : j < k) (v : ℤ) :
    conjOnePolynomial T (v + 1) (conjSolutionPolynomial F R j h0j k hjk) =
      conjOnePolynomial T v (conjSolutionPolynomial F R j h0j k hjk) +
        conjOnePolynomial T v (conjForwardDifference F R j h0j k hjk) := by
  rw [← conj_univariate_polynomial T (v + 1)
    (conjSolutionPolynomial F R j h0j k hjk)]
  rw [← conj_univariate_polynomial T v
    (conjSolutionPolynomial F R j h0j k hjk)]
  rw [← conj_univariate_polynomial T v
    (conjForwardDifference F R j h0j k hjk)]
  rw [conjSolutionPolynomial, univariate_antiderivative_polynomial]
  rw [show (((v + 1 : ℤ) : ℚ)) = (v : ℚ) + 1 by norm_num [Int.cast_add]]
  exact polynomial_forward_antiderivative (0 : ℚ)
    (conjUnivariatePolynomial T (conjForwardDifference F R j h0j k hjk))
    (v : ℚ)

/--
Existential package for the constructed ambient Section 3.2 step-2 solution:
the polynomial is zero-initial, satisfies the product-derived forward
recursion, and computes the represented coordinate `R(T;1,v)`.
-/
theorem conj_solution_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hR : RepresentsConjugation M R)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k) :
    ∃ p : MvPolynomial (ConjOneVar (n + 1)) ℚ,
      conjUnivariatePolynomial T
          (conjUPolynomial (R ⟨(0, j, k), h0j, hjk⟩)) =
        conjUnivariatePolynomial T p ∧
      (∀ v : ℤ,
        evalConjPolynomial T 1 v (R ⟨(0, j, k), h0j, hjk⟩) =
          conjOnePolynomial T v p) ∧
      conjOnePolynomial T 0 p = 0 ∧
      ∀ v : ℤ,
        conjOnePolynomial T (v + 1) p =
          conjOnePolynomial T v p +
            conjOnePolynomial T v
              (conjForwardDifference F R j h0j k hjk) := by
  refine ⟨conjSolutionPolynomial F R j h0j k hjk, ?_, ?_, ?_, ?_⟩
  · exact univariate_2_solution
      M F R hF hR j k h0j hjk
  · exact conj_int_solution
      M F R hF hR j k h0j hjk
  · exact eval_conj_solution F R j h0j k hjk
  · exact conj_succ_solution F R j h0j k hjk

/--
Exact-data existential package for the constructed ambient Section 3.2 step-2
solution.  It avoids represented-family hypotheses once the zero-initial,
current-coordinate, and product-evaluation facts are available.
-/
theorem step_solution_delta
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j k : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j) (hjk : j < k)
    (hZero : evalConjPolynomial T 1 0 (R ⟨(0, j, k), h0j, hjk⟩) = 0)
    (hCurrent : ∀ v : ℤ,
      evalConjPolynomial T 1 v (R ⟨(0, j, k), h0j, hjk⟩) =
        (M.leftConjugationTuple 0 j 1 v k : ℚ))
    (hProduct : ∀ v : ℤ,
      conjOnePolynomial T v (conjStep2 F R j h0j k) =
        (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1) k :
          ℚ)) :
    ∃ p : MvPolynomial (ConjOneVar (n + 1)) ℚ,
      conjUnivariatePolynomial T
          (conjUPolynomial (R ⟨(0, j, k), h0j, hjk⟩)) =
        conjUnivariatePolynomial T p ∧
      (∀ v : ℤ,
        evalConjPolynomial T 1 v (R ⟨(0, j, k), h0j, hjk⟩) =
          conjOnePolynomial T v p) ∧
      conjOnePolynomial T 0 p = 0 ∧
      ∀ v : ℤ,
        conjOnePolynomial T (v + 1) p =
          conjOnePolynomial T v p +
            conjOnePolynomial T v
              (conjForwardDifference F R j h0j k hjk) := by
  refine ⟨conjSolutionPolynomial F R j h0j k hjk, ?_, ?_, ?_, ?_⟩
  · exact conj_univariate_delta
      M F R j k h0j hjk hZero hCurrent hProduct
  · exact int_solution_delta
      M F R j k h0j hjk hZero hCurrent hProduct
  · exact eval_conj_solution F R j h0j k hjk
  · exact conj_succ_solution F R j h0j k hjk

/--
Lower-rank `U(T)` Bernoulli solution of the Section 3.2 recursion, using the
increment polynomial built from the displayed product.
-/
theorem one_univariate_antiderivative
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k)
    (hZero : evalConjPolynomial T 1 0
      (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) = 0)
    (hForward :
      conjUnivariatePolynomial T
          (forwardDifferenceV R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
        conjUnivariatePolynomial T
          (forwardDifferenceU F_U R j h0j k hjk)) :
    conjUnivariatePolynomial T
        (conjUPolynomial (R ⟨(0, j, Fin.succ k), h0j, hjk⟩)) =
      polynomialForwardAntiderivative (0 : ℚ)
        (conjUnivariatePolynomial T
          (forwardDifferenceU F_U R j h0j k hjk)) := by
  rw [← hForward]
  exact univariate_polynomial_antiderivative
    R ⟨(0, j, Fin.succ k), h0j, hjk⟩ hZero

/--
Bernoulli antiderivative form of the exact-premise lower-rank `U(T)` step-2
construction.  The represented ambient conjugation family is replaced by the
local product-evaluation data needed to identify the forward difference.
-/
theorem univariate_antiderivative_2
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hMul : ∀ a b : M.G,
      M.coord a 0 = 0 → M.coord b 0 = 0 → M.coord (a * b) 0 = 0)
    (hInv : ∀ a : M.G, M.coord a 0 = 0 → M.coord a⁻¹ 0 = 0)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication
      (M.firstConsistentPresentation hMul hInv) F_U)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k)
    (hZeroInit : evalConjPolynomial T 1 0
      (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) = 0)
    (hDelta : ∀ v : ℤ,
      conjOnePolynomial T v
          (forwardDifferenceV R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
        (M.coord (M.firstConjugatedProduct (M.leftConjugationTuple 0 j 1 v) 1)
            (Fin.succ k) : ℚ) -
          (M.leftConjugationTuple 0 j 1 v (Fin.succ k) : ℚ))
    (hCurrent : ∀ v : ℤ,
      evalConjPolynomial T 1 v (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
        (M.leftConjugationTuple 0 j 1 v (Fin.succ k) : ℚ))
    (hSubst : ∀ v w,
      MvPolynomial.eval (conjOneVar T v) (conjStepSubst R j h0j w) =
        evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1) w)
    (hFactor : ∀ v i k,
      MvPolynomial.eval
          (evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1))
          (firstConjugatedPolynomial R i k) =
        (M.leftConjugationTuple 0 (Fin.succ i)
          (M.leftConjugationTuple 0 j 1 v (Fin.succ i)) 1 (Fin.succ k) : ℚ))
    (hTailZero : ∀ v i,
      M.leftConjugationTuple 0 (Fin.succ i)
        (M.leftConjugationTuple 0 j 1 v (Fin.succ i)) 1 0 = 0) :
    conjUnivariatePolynomial T
        (conjUPolynomial (R ⟨(0, j, Fin.succ k), h0j, hjk⟩)) =
      polynomialForwardAntiderivative (0 : ℚ)
        (conjUnivariatePolynomial T
          (forwardDifferenceU F_U R j h0j k hjk)) :=
  one_univariate_antiderivative
    F_U R j k h0j hjk hZeroInit
    (conj_univariate_forward
      M hMul hInv F_U R hFU j k h0j hjk hDelta hCurrent hSubst hFactor hTailZero)

/--
Bernoulli antiderivative form of the lower-rank `U(T)` step-2 construction
with the product-evaluation delta and tail-zero premises derived internally.
-/
theorem univariate_forward_antiderivative
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hMul : ∀ a b : M.G,
      M.coord a 0 = 0 → M.coord b 0 = 0 → M.coord (a * b) 0 = 0)
    (hInv : ∀ a : M.G, M.coord a 0 = 0 → M.coord a⁻¹ 0 = 0)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication
      (M.firstConsistentPresentation hMul hInv) F_U)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k)
    (hZeroInit : evalConjPolynomial T 1 0
      (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) = 0)
    (hCurrent : ∀ v : ℤ,
      evalConjPolynomial T 1 v (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
        (M.leftConjugationTuple 0 j 1 v (Fin.succ k) : ℚ))
    (hSubst : ∀ v w,
      MvPolynomial.eval (conjOneVar T v) (conjStepSubst R j h0j w) =
        evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1) w)
    (hFactor : ∀ v i k,
      MvPolynomial.eval
          (evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1))
          (firstConjugatedPolynomial R i k) =
        (M.leftConjugationTuple 0 (Fin.succ i)
          (M.leftConjugationTuple 0 j 1 v (Fin.succ i)) 1 (Fin.succ k) : ℚ)) :
    conjUnivariatePolynomial T
        (conjUPolynomial (R ⟨(0, j, Fin.succ k), h0j, hjk⟩)) =
      polynomialForwardAntiderivative (0 : ℚ)
        (conjUnivariatePolynomial T
          (forwardDifferenceU F_U R j h0j k hjk)) :=
  one_univariate_antiderivative
    F_U R j k h0j hjk hZeroInit
    (fwd_diff_delta
      M hMul hInv F_U R hFU j k h0j hjk hCurrent hSubst hFactor)

/--
Canonical delete-first Bernoulli antiderivative form of the lower-rank
product-evaluation Section 3.2 step-2 construction.
-/
theorem univariate_antiderivative_delta
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k)
    (hZeroInit : evalConjPolynomial T 1 0
      (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) = 0)
    (hCurrent : ∀ v : ℤ,
      evalConjPolynomial T 1 v (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
        (M.leftConjugationTuple 0 j 1 v (Fin.succ k) : ℚ))
    (hSubst : ∀ v w,
      MvPolynomial.eval (conjOneVar T v) (conjStepSubst R j h0j w) =
        evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1) w)
    (hFactor : ∀ v i k,
      MvPolynomial.eval
          (evalMulVar T (M.leftConjugationTuple 0 j 1 v) (singleCoord 0 1))
          (firstConjugatedPolynomial R i k) =
        (M.leftConjugationTuple 0 (Fin.succ i)
          (M.leftConjugationTuple 0 j 1 v (Fin.succ i)) 1 (Fin.succ k) : ℚ)) :
    conjUnivariatePolynomial T
        (conjUPolynomial (R ⟨(0, j, Fin.succ k), h0j, hjk⟩)) =
      polynomialForwardAntiderivative (0 : ℚ)
        (conjUnivariatePolynomial T
          (forwardDifferenceU F_U R j h0j k hjk)) :=
  one_univariate_antiderivative
    F_U R j k h0j hjk hZeroInit
    (univariate_fwd_diff
      M F_U R hFU j k h0j hjk hCurrent hSubst hFactor)

theorem univariate_2_u
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hR : RepresentsConjugation M R)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k) :
    conjUnivariatePolynomial T
        (conjUPolynomial (R ⟨(0, j, Fin.succ k), h0j, hjk⟩)) =
      polynomialForwardAntiderivative (0 : ℚ)
        (conjUnivariatePolynomial T
          (forwardDifferenceU F_U R j h0j k hjk)) :=
  one_univariate_antiderivative
    F_U R j k h0j hjk
    (conj_right_represents
      M R hR 0 j (Fin.succ k) h0j hjk 1)
    (univariate_difference_u
      M F_U R hFU hR j k h0j hjk)

/--
Split lower-rank `U(T)` Section 3.2 step-2 antiderivative identity: the
delete-first input needed here is only multiplication.
-/
theorem univariate_antiderivative_u
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hR : RepresentsConjugation M R)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k) :
    conjUnivariatePolynomial T
        (conjUPolynomial (R ⟨(0, j, Fin.succ k), h0j, hjk⟩)) =
      polynomialForwardAntiderivative (0 : ℚ)
        (conjUnivariatePolynomial T
          (forwardDifferenceU F_U R j h0j k hjk)) :=
  univariate_2_u
    M F_U R hFU hR j k h0j hjk

theorem conj_univariate_antiderivative
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hR : RepresentsConjugation M R)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k) :
    conjUnivariatePolynomial T
        (conjUPolynomial (R ⟨(0, j, Fin.succ k), h0j, hjk⟩)) =
      polynomialForwardAntiderivative (0 : ℚ)
        (conjUnivariatePolynomial T
          (forwardDifferenceU F_U R j h0j k hjk)) :=
  univariate_antiderivative_u
    M F_U R hHallU.1 hR j k h0j hjk

/-- All-integer evaluation form of the lower-rank `U(T)` Section 3.2 solution. -/
theorem int_antiderivative_u
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k)
    (hZero : evalConjPolynomial T 1 0
      (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) = 0)
    (hForward :
      conjUnivariatePolynomial T
          (forwardDifferenceV R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
        conjUnivariatePolynomial T
          (forwardDifferenceU F_U R j h0j k hjk))
    (v : ℤ) :
    evalConjPolynomial T 1 v (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
      (polynomialForwardAntiderivative (0 : ℚ)
        (conjUnivariatePolynomial T
          (forwardDifferenceU F_U R j h0j k hjk))).eval
          (v : ℚ) := by
  rw [← one_univariate_antiderivative
    F_U R j k h0j hjk hZero hForward]
  rw [conj_univariate_polynomial, conj_u_polynomial]

theorem conj_antiderivative_u
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hR : RepresentsConjugation M R)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k)
    (v : ℤ) :
    evalConjPolynomial T 1 v (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
      (polynomialForwardAntiderivative (0 : ℚ)
        (conjUnivariatePolynomial T
          (forwardDifferenceU F_U R j h0j k hjk))).eval
          (v : ℚ) :=
  int_antiderivative_u
    F_U R j k h0j hjk
    (conj_right_represents
      M R hR 0 j (Fin.succ k) h0j hjk 1)
    (univariate_difference_u
      M F_U R hFU hR j k h0j hjk)
    v

/--
Split evaluation form of the lower-rank `U(T)` Section 3.2 antiderivative:
only delete-first multiplication is needed.
-/
theorem int_forward_antiderivative
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
