    (hK : RepresentsPowering M K)
    (hKW : RepresentsPowering M.deleteConsistentPresentation K_W)
    (x : Fin (n + 1) → ℤ) (z : ℤ) (i : Fin (n + 1)) :
    evalPowerPolynomial T x z (K i) =
      evalPowerPolynomial T x z (poweringSolutionFamily F K_W i) := by
  have hK' :=
    represents_solution_family
      M F K_W hF hKW
  rw [hK x z i, hK' x z i]

/--
Specialized polynomial identity for the seed-free quotient-lifted solution
family.
-/
theorem specialize_last_powering
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (F_W : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_W : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (hHallW :
      RepresentsHallPolynomials M.deleteConsistentPresentation F_W K_W R_W)
    (i : Fin (n + 1)) :
    specializePower T (K i) =
      specializePower T (poweringSolutionFamily F K_W i) :=
  specialize_power_eval (K i) (poweringSolutionFamily F K_W i)
    (fun x z =>
      delete_solution_represents
        M F K F_W K_W R_W hF hK hHallW x z i)

/--
Specialized polynomial identity for the seed-free quotient-lifted solution
family from represented quotient powering alone.
-/
theorem specialize_powering_solution
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (hKW : RepresentsPowering M.deleteConsistentPresentation K_W)
    (i : Fin (n + 1)) :
    specializePower T (K i) =
      specializePower T (poweringSolutionFamily F K_W i) :=
  specialize_power_eval (K i) (poweringSolutionFamily F K_W i)
    (fun x z =>
      last_powering_represents
        M F K K_W hF hK hKW x z i)

/--
Induction-hypothesis-shaped seed-free quotient powering replacement,
retaining specialized and all-integer identities back to the input powering
family.
-/
theorem powering_solution_polynomials
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (hHallW :
      ∃ (F_W : Fin n → MvPolynomial (MulVar n) ℚ)
        (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
        (R_W : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
          RepresentsHallPolynomials M.deleteConsistentPresentation
            F_W K_W R_W) :
    ∃ K' : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ,
      RepresentsHallPolynomials M F K' R ∧
      (∀ i, specializePower T (K i) = specializePower T (K' i)) ∧
      ∀ (x : Fin (n + 1) → ℤ) (z : ℤ) i,
        evalPowerPolynomial T x z (K i) =
          evalPowerPolynomial T x z (K' i) := by
  rcases hHallW with ⟨F_W, K_W, R_W, hHallW⟩
  refine ⟨poweringSolutionFamily F K_W, ?_, ?_, ?_⟩
  · exact polynomials_solution_family
      M F R F_W K_W R_W hHall.1 hHall.2.2 hHallW
  · intro i
    exact specialize_last_powering
      M F K F_W K_W R_W hHall.1 hHall.2.1 hHallW i
  · intro x z i
    exact delete_solution_represents
      M F K F_W K_W R_W hHall.1 hHall.2.1 hHallW x z i

/--
Seed-free quotient powering replacement from an existential represented
quotient powering family.
-/
theorem last_powering_solution
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (hKW :
      ∃ K_W : Fin n → MvPolynomial (PowerVar n) ℚ,
        RepresentsPowering M.deleteConsistentPresentation K_W) :
    ∃ K' : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ,
      RepresentsHallPolynomials M F K' R ∧
      (∀ i, specializePower T (K i) = specializePower T (K' i)) ∧
      ∀ (x : Fin (n + 1) → ℤ) (z : ℤ) i,
        evalPowerPolynomial T x z (K i) =
          evalPowerPolynomial T x z (K' i) := by
  rcases hKW with ⟨K_W, hKW⟩
  refine ⟨poweringSolutionFamily F K_W, ?_, ?_, ?_⟩
  · exact powering_solution_family
      M F R K_W hHall.1 hHall.2.2 hKW
  · intro i
    exact specialize_powering_solution
      M F K K_W hHall.1 hHall.2.1 hKW i
  · intro x z i
    exact last_powering_represents
      M F K K_W hHall.1 hHall.2.1 hKW x z i

/--
Bundled normalization of an already represented Hall-polynomial family:
replace multiplication by the Section 3.3 displayed product and powering by
the Section 3.4 constructed solutions, using the paper-style last coordinate.
-/
theorem solution_update_last
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R) :
    RepresentsHallPolynomials M (multiplicationProductPolynomial F R)
      (Function.update (fun i => forwardSolutionPolynomial F K i)
        (Fin.last n) (lastSolutionPolynomial F K)) R :=
  ⟨represents_display_polynomial
      M F R hHall.1 hHall.2.2,
    forward_update_last
      M F K hHall.1 hHall.2.1,
    hHall.2.2⟩

/--
Stronger bundled normalization: replace all first-generator Section 3.2
`step1` conjugation coordinates, build the Section 3.3 multiplication display
from that updated conjugation family, and then replace powering by the Section
3.4 constructed solutions using the displayed multiplication family.
-/
theorem display_update_last
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R) :
    RepresentsHallPolynomials M
      (multiplicationProductPolynomial F (conj1Family R K))
      (Function.update
        (fun i =>
          forwardSolutionPolynomial
            (multiplicationProductPolynomial F (conj1Family R K)) K i)
        (Fin.last n)
        (lastSolutionPolynomial
          (multiplicationProductPolynomial F (conj1Family R K)) K))
      (conj1Family R K) := by
  let R' := conj1Family R K
  let F' := multiplicationProductPolynomial F R'
  have hR' : RepresentsConjugation M R' :=
    represents_1_family M R K hHall.2.2 hHall.2.1
  have hF' : RepresentsMultiplication M F' :=
    represents_display_polynomial
      M F R' hHall.1 hR'
  have hK' :
      RepresentsPowering M
        (Function.update (fun i => forwardSolutionPolynomial F' K i)
          (Fin.last n) (lastSolutionPolynomial F' K)) :=
    forward_update_last
      M F' K hF' hHall.2.1
  exact ⟨hF', hK', hR'⟩

/--
Named multiplication family for the local Section 3.2/3.3 normalization:
first install all first-generator `step1` conjugation coordinates, then use
the Section 3.3 displayed multiplication product.
-/
def stepDisplayMultiplication {n : ℕ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ) :
    Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ :=
  multiplicationProductPolynomial F (conj1Family R K)

/--
Named powering family for the local Section 3.2/3.3/3.4 normalization: use the
displayed multiplication family in the Section 3.4 Bernoulli powering
construction, with the paper-style last coordinate.
-/
def stepDisplayPowering {n : ℕ}
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ) :
    Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ :=
  Function.update
    (fun i => forwardSolutionPolynomial (stepDisplayMultiplication F K R) K i)
    (Fin.last n)
    (lastSolutionPolynomial (stepDisplayMultiplication F K R) K)

/--
The represented multiplication family and the named local normalized
multiplication family have the same integer evaluations.
-/
theorem display_multiplication_polynomials
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (x y : Fin (n + 1) → ℤ) (i : Fin (n + 1)) :
    evalMulPolynomial T x y (F i) =
      evalMulPolynomial T x y (stepDisplayMultiplication F K R i) := by
  have hR' : RepresentsConjugation M (conj1Family R K) :=
    represents_1_family M R K hHall.2.2 hHall.2.1
  simpa [stepDisplayMultiplication] using
    eval_multiplication_display
      M F (conj1Family R K) hHall.1 hR' x y i

/--
The represented powering family and the named local normalized powering
family have the same integer evaluations.
-/
theorem display_powering_polynomials
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (x : Fin (n + 1) → ℤ) (z : ℤ) (i : Fin (n + 1)) :
    evalPowerPolynomial T x z (K i) =
      evalPowerPolynomial T x z (stepDisplayPowering F K R i) := by
  let F' := stepDisplayMultiplication F K R
  have hR' : RepresentsConjugation M (conj1Family R K) :=
    represents_1_family M R K hHall.2.2 hHall.2.1
  have hF' : RepresentsMultiplication M F' := by
    exact represents_display_polynomial
      M F (conj1Family R K) hHall.1 hR'
  by_cases hi : i = Fin.last n
  · subst i
    rw [stepDisplayPowering, Function.update_self]
    exact last_int_solution
      M F' K hF' hHall.2.1 x z
  · rw [stepDisplayPowering, Function.update_of_ne hi]
    exact int_forward_solution
      M F' K hF' hHall.2.1 x i z

/--
Specialized polynomial identity between a represented multiplication family
and the named local normalized multiplication family.
-/
theorem specialize_1_polynomials
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (i : Fin (n + 1)) :
    specializeMul T (F i) =
      specializeMul T (stepDisplayMultiplication F K R i) := by
  exact specialize_mul_eval (F i) (stepDisplayMultiplication F K R i)
    (fun x y =>
      display_multiplication_polynomials
        M F K R hHall x y i)

/--
Specialized polynomial identity between a represented powering family and the
named local normalized powering family.
-/
theorem specialize_powering_polynomials
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (i : Fin (n + 1)) :
    specializePower T (K i) =
      specializePower T (stepDisplayPowering F K R i) := by
  exact specialize_power_eval (K i) (stepDisplayPowering F K R i)
    (fun x z =>
      display_powering_polynomials
        M F K R hHall x z i)

/--
Specialized polynomial identity between a represented conjugation family and
the named local `step1` conjugation family.
-/
theorem specialize_conj_polynomials
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (I : ParameterIndex (n + 1)) :
    specializeConj T (R I) =
      specializeConj T (conj1Family R K I) := by
  exact specialize_conj_eval (R I) (conj1Family R K I)
    (fun u v =>
      conj_family_represents
        M R K hHall.2.2 hHall.2.1 I u v)

/--
Named-family version of the local Section 3.2/3.3/3.4 normalization theorem.
-/
theorem polynomials_step_families
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R) :
    RepresentsHallPolynomials M (stepDisplayMultiplication F K R)
      (stepDisplayPowering F K R) (conj1Family R K) := by
  exact represents_polynomials_eval M F
    (stepDisplayMultiplication F K R) K
    (stepDisplayPowering F K R) R (conj1Family R K) hHall
    (display_multiplication_polynomials
      M F K R hHall)
    (display_powering_polynomials
      M F K R hHall)
    (conj_family_represents
      M R K hHall.2.2 hHall.2.1)

/--
Existential package for the named local normalized families, retaining the
specialized polynomial identities back to the original represented families.
-/
theorem families_represents_polynomials
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R) :
    ∃ (F' : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
      (K' : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
      (R' : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ),
        RepresentsHallPolynomials M F' K' R' ∧
        (∀ i, specializeMul T (F i) = specializeMul T (F' i)) ∧
        (∀ i, specializePower T (K i) = specializePower T (K' i)) ∧
        (∀ I, specializeConj T (R I) = specializeConj T (R' I)) := by
  refine
    ⟨stepDisplayMultiplication F K R, stepDisplayPowering F K R,
      conj1Family R K, ?_, ?_, ?_, ?_⟩
  · exact polynomials_step_families M F K R hHall
  · intro i
    exact specialize_1_polynomials
      M F K R hHall i
  · intro i
    exact specialize_powering_polynomials
      M F K R hHall i
  · intro I
    exact specialize_conj_polynomials
      M F K R hHall I

/--
The represented multiplication family and the named local normalized
multiplication family have the same integer evaluations, with the input
representations split into multiplication, powering, and conjugation.
-/
theorem display_multiplication_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (hR : RepresentsConjugation M R)
    (x y : Fin (n + 1) → ℤ) (i : Fin (n + 1)) :
    evalMulPolynomial T x y (F i) =
      evalMulPolynomial T x y (stepDisplayMultiplication F K R i) := by
  have hR' : RepresentsConjugation M (conj1Family R K) :=
    represents_1_family M R K hR hK
  simpa [stepDisplayMultiplication] using
    eval_multiplication_display
      M F (conj1Family R K) hF hR' x y i

/--
The represented powering family and the named local normalized powering family
have the same integer evaluations, with the input representations split into
multiplication, powering, and conjugation.
-/
theorem display_powering_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (hR : RepresentsConjugation M R)
    (x : Fin (n + 1) → ℤ) (z : ℤ) (i : Fin (n + 1)) :
    evalPowerPolynomial T x z (K i) =
      evalPowerPolynomial T x z (stepDisplayPowering F K R i) := by
  let F' := stepDisplayMultiplication F K R
  have hR' : RepresentsConjugation M (conj1Family R K) :=
    represents_1_family M R K hR hK
  have hF' : RepresentsMultiplication M F' := by
    exact represents_display_polynomial
      M F (conj1Family R K) hF hR'
  by_cases hi : i = Fin.last n
  · subst i
    rw [stepDisplayPowering, Function.update_self]
    exact last_int_solution
      M F' K hF' hK x z
  · rw [stepDisplayPowering, Function.update_of_ne hi]
    exact int_forward_solution
      M F' K hF' hK x i z

/--
Specialized polynomial identity between a represented multiplication family
and the named local normalized multiplication family, from split
representation hypotheses.
-/
theorem specialize_display_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (hR : RepresentsConjugation M R)
    (i : Fin (n + 1)) :
    specializeMul T (F i) =
      specializeMul T (stepDisplayMultiplication F K R i) :=
  specialize_mul_eval (F i) (stepDisplayMultiplication F K R i)
    (fun x y =>
      display_multiplication_represents
        M F K R hF hK hR x y i)

/--
Specialized polynomial identity between a represented powering family and the
named local normalized powering family, from split representation hypotheses.
-/
theorem specialize_1_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (hR : RepresentsConjugation M R)
    (i : Fin (n + 1)) :
    specializePower T (K i) =
      specializePower T (stepDisplayPowering F K R i) :=
  specialize_power_eval (K i) (stepDisplayPowering F K R i)
    (fun x z =>
      display_powering_represents
        M F K R hF hK hR x z i)

/--
Specialized polynomial identity between a represented conjugation family and
the named local `step1` conjugation family, from split powering/conjugation
representation hypotheses.
-/
theorem specialize_family_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hK : RepresentsPowering M K)
    (hR : RepresentsConjugation M R)
    (I : ParameterIndex (n + 1)) :
    specializeConj T (R I) =
      specializeConj T (conj1Family R K I) :=
  specialize_conj_eval (R I) (conj1Family R K I)
    (fun u v =>
      conj_family_represents
        M R K hR hK I u v)

/--
Named-family version of the local Section 3.2/3.3/3.4 normalization theorem,
with the input Hall bundle split into its three representation components.
-/
theorem represents_1_families
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (hR : RepresentsConjugation M R) :
    RepresentsHallPolynomials M (stepDisplayMultiplication F K R)
      (stepDisplayPowering F K R) (conj1Family R K) := by
  let R' := conj1Family R K
  let F' := stepDisplayMultiplication F K R
  have hR' : RepresentsConjugation M R' :=
    represents_1_family M R K hR hK
  have hF' : RepresentsMultiplication M F' := by
    simpa [F', R', stepDisplayMultiplication] using
      represents_display_polynomial M F R' hF hR'
  have hK' : RepresentsPowering M (stepDisplayPowering F K R) := by
    simpa [stepDisplayPowering, F'] using
      forward_update_last
        M F' K hF' hK
  exact ⟨hF', hK', hR'⟩

/--
Existential package for the named local normalized families, retaining
specialized polynomial identities, from split representation hypotheses.
-/
theorem step_families_represents
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hF : RepresentsMultiplication M F)
    (hK : RepresentsPowering M K)
    (hR : RepresentsConjugation M R) :
    ∃ (F' : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
      (K' : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
      (R' : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ),
        RepresentsHallPolynomials M F' K' R' ∧
        (∀ i, specializeMul T (F i) = specializeMul T (F' i)) ∧
        (∀ i, specializePower T (K i) = specializePower T (K' i)) ∧
        (∀ I, specializeConj T (R I) = specializeConj T (R' I)) := by
  refine
    ⟨stepDisplayMultiplication F K R, stepDisplayPowering F K R,
      conj1Family R K, ?_, ?_, ?_, ?_⟩
  · exact represents_1_families
      M F K R hF hK hR
  · intro i
    exact specialize_display_represents
      M F K R hF hK hR i
  · intro i
    exact specialize_1_represents
      M F K R hF hK hR i
  · intro I
    exact specialize_family_represents
      M K R hK hR I

/--
Named lower-rank `U(T)` multiplication family for the local Section
3.2/3.3/3.4 assembly: first install all first-generator `step1` conjugation
coordinates using the canonical `U(T)` powering family, then build the Section
3.3 displayed multiplication product from the canonical `U(T)` multiplication
family.
-/
def uDisplayMultiplication {n : ℕ}
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ) :
    Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ :=
  multiplicationDisplayProduct F_U (stepFamilyU R K_U)

/--
Named lower-rank `U(T)` powering family for the local Section 3 assembly:
after the displayed multiplication family is built from canonical `U(T)` data,
replace powering by the Section 3.4 Bernoulli solutions, with the paper-style
last coordinate.
-/
def uDisplayPowering {n : ℕ}
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ) :
    Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ :=
  Function.update
    (fun i => forwardSolutionPolynomial
      (uDisplayMultiplication F_U K_U R) K i)
    (Fin.last n)
    (lastSolutionPolynomial (uDisplayMultiplication F_U K_U R) K)

/--
Lower-rank `U(T)` assembly theorem: represented Hall polynomials for the
canonical `U(T)` presentation, together with represented ambient powering and
conjugation, build a represented ambient Hall-polynomial family.  No ambient
multiplication family is required.
-/
theorem polynomials_1_families
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hK : RepresentsPowering M K)
    (hR : RepresentsConjugation M R)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U) :
    RepresentsHallPolynomials M (uDisplayMultiplication F_U K_U R)
      (uDisplayPowering F_U K_U K R) (stepFamilyU R K_U) := by
  let R' := stepFamilyU R K_U
  let F' := uDisplayMultiplication F_U K_U R
  have hR' : RepresentsConjugation M R' :=
    represents_conjugation_first
      M F_U K_U R_U R hHallU hR
  have hF' : RepresentsMultiplication M F' := by
    simpa [F', R', uDisplayMultiplication] using
      represents_display_u
        M F_U R' hHallU.1 hR'
  have hK' : RepresentsPowering M (uDisplayPowering F_U K_U K R) := by
    simpa [uDisplayPowering, F'] using
      forward_update_last
        M F' K hF' hK
  exact ⟨hF', hK', hR'⟩

/--
Induction-hypothesis-shaped version of
`polynomials_1_families`: if the
canonical `U(T)` presentation has some represented Hall-polynomial family,
then represented ambient powering and conjugation suffice to construct an
ambient Hall-polynomial family.
-/
theorem families_delete_first
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHallU :
      ∃ (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
        (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
        (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
          RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hK : RepresentsPowering M K)
    (hR : RepresentsConjugation M R) :
    ∃ (F' : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
      (K' : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
      (R' : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ),
        RepresentsHallPolynomials M F' K' R' := by
  rcases hHallU with ⟨F_U, K_U, R_U, hHallU⟩
  exact
    ⟨uDisplayMultiplication F_U K_U R,
      uDisplayPowering F_U K_U K R, stepFamilyU R K_U,
      polynomials_1_families
        M K R F_U K_U R_U hK hR hHallU⟩

/--
The represented multiplication family and the lower-rank `U(T)` assembled
display multiplication family have the same integer evaluations.
-/
theorem display_multiplication_first
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hR : RepresentsConjugation M R)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (x y : Fin (n + 1) → ℤ) (i : Fin (n + 1)) :
    evalMulPolynomial T x y (F i) =
      evalMulPolynomial T x y (uDisplayMultiplication F_U K_U R i) := by
  let R' := stepFamilyU R K_U
  have hR' : RepresentsConjugation M R' :=
    represents_conjugation_first
      M F_U K_U R_U R hHallU hR
  simpa [uDisplayMultiplication, R'] using
    multiplication_display_represents
      M F F_U R' hF hHallU.1 hR' x y i

/--
Specialized polynomial identity between a represented multiplication family
and the lower-rank `U(T)` assembled display multiplication family.
-/
theorem specialize_multiplication_delete
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hR : RepresentsConjugation M R)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (i : Fin (n + 1)) :
    specializeMul T (F i) =
      specializeMul T (uDisplayMultiplication F_U K_U R i) := by
  exact specialize_mul_eval (F i) (uDisplayMultiplication F_U K_U R i)
    (fun x y =>
      display_multiplication_first
        M F R F_U K_U R_U hF hR hHallU x y i)

/--
The represented powering family and the lower-rank `U(T)` assembled powering
family have the same integer evaluations.
-/
theorem display_powering_first
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hK : RepresentsPowering M K)
    (hR : RepresentsConjugation M R)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (x : Fin (n + 1) → ℤ) (z : ℤ) (i : Fin (n + 1)) :
    evalPowerPolynomial T x z (K i) =
      evalPowerPolynomial T x z (uDisplayPowering F_U K_U K R i) := by
  let R' := stepFamilyU R K_U
  let F' := uDisplayMultiplication F_U K_U R
  have hR' : RepresentsConjugation M R' :=
    represents_conjugation_first
      M F_U K_U R_U R hHallU hR
  have hF' : RepresentsMultiplication M F' := by
    simpa [F', R', uDisplayMultiplication] using
      represents_display_u
        M F_U R' hHallU.1 hR'
  have hHall' : RepresentsHallPolynomials M F' K R' := ⟨hF', hK, hR'⟩
  simpa [uDisplayPowering, F'] using
    solution_update_polynomials
      M F' K R' hHall' x z i

/--
Specialized polynomial identity between a represented powering family and the
lower-rank `U(T)` assembled powering family.
-/
theorem specialize_display_first
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hK : RepresentsPowering M K)
    (hR : RepresentsConjugation M R)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (i : Fin (n + 1)) :
    specializePower T (K i) =
      specializePower T (uDisplayPowering F_U K_U K R i) := by
  exact specialize_power_eval (K i) (uDisplayPowering F_U K_U K R i)
    (fun x z =>
      display_powering_first
        M K R F_U K_U R_U hK hR hHallU x z i)

/--
Lower-rank `U(T)` local assembly with the canonical lower-rank input split
into represented multiplication and powering, rather than bundled Hall data.
-/
theorem represents_families_delete
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hK : RepresentsPowering M K)
    (hR : RepresentsConjugation M R)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hKU : RepresentsPowering M.deleteFirstConsistent K_U) :
    RepresentsHallPolynomials M (uDisplayMultiplication F_U K_U R)
      (uDisplayPowering F_U K_U K R) (stepFamilyU R K_U) := by
  let R' := stepFamilyU R K_U
  let F' := uDisplayMultiplication F_U K_U R
  have hR' : RepresentsConjugation M R' :=
    conjugation_u_powering
      M K_U R hKU hR
  have hF' : RepresentsMultiplication M F' := by
    simpa [F', R', uDisplayMultiplication] using
      represents_display_u
        M F_U R' hFU hR'
  have hK' : RepresentsPowering M (uDisplayPowering F_U K_U K R) := by
    simpa [uDisplayPowering, F'] using
      forward_update_last
        M F' K hF' hK
  exact ⟨hF', hK', hR'⟩

/--
Split-data version of the lower-rank `U(T)` local assembly: represented
delete-first multiplication and powering suffice; delete-first conjugation is
not used by this `step1` display construction.
-/
theorem polynomials_families_delete
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFKU :
      ∃ (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
        (K_U : Fin n → MvPolynomial (PowerVar n) ℚ),
          RepresentsMultiplication M.deleteFirstConsistent F_U ∧
          RepresentsPowering M.deleteFirstConsistent K_U)
    (hK : RepresentsPowering M K)
    (hR : RepresentsConjugation M R) :
    ∃ (F' : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
      (K' : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
      (R' : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ),
        RepresentsHallPolynomials M F' K' R' := by
  rcases hFKU with ⟨F_U, K_U, hFU, hKU⟩
  exact
    ⟨uDisplayMultiplication F_U K_U R,
      uDisplayPowering F_U K_U K R, stepFamilyU R K_U,
      represents_families_delete
        M K R F_U K_U hK hR hFU hKU⟩

/--
The represented multiplication family and the lower-rank `U(T)` assembled
display multiplication family have the same integer evaluations from split
delete-first multiplication and powering hypotheses.
-/
theorem display_multiplication_family
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hR : RepresentsConjugation M R)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hKU : RepresentsPowering M.deleteFirstConsistent K_U)
    (x y : Fin (n + 1) → ℤ) (i : Fin (n + 1)) :
    evalMulPolynomial T x y (F i) =
      evalMulPolynomial T x y (uDisplayMultiplication F_U K_U R i) := by
  let R' := stepFamilyU R K_U
  have hR' : RepresentsConjugation M R' :=
    conjugation_u_powering
      M K_U R hKU hR
  simpa [uDisplayMultiplication, R'] using
    multiplication_display_represents
      M F F_U R' hF hFU hR' x y i

/--
Specialized polynomial identity between a represented multiplication family
and the lower-rank `U(T)` assembled display multiplication family from split
delete-first multiplication and powering hypotheses.
-/
theorem specialize_1_multiplication
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hF : RepresentsMultiplication M F)
    (hR : RepresentsConjugation M R)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hKU : RepresentsPowering M.deleteFirstConsistent K_U)
    (i : Fin (n + 1)) :
    specializeMul T (F i) =
      specializeMul T (uDisplayMultiplication F_U K_U R i) :=
  specialize_mul_eval (F i) (uDisplayMultiplication F_U K_U R i)
    (fun x y =>
      display_multiplication_family
        M F R F_U K_U hF hR hFU hKU x y i)

/--
The represented powering family and the lower-rank `U(T)` assembled powering
family have the same integer evaluations from split delete-first
multiplication and powering hypotheses.
-/
theorem display_powering_family
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hK : RepresentsPowering M K)
    (hR : RepresentsConjugation M R)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hKU : RepresentsPowering M.deleteFirstConsistent K_U)
    (x : Fin (n + 1) → ℤ) (z : ℤ) (i : Fin (n + 1)) :
    evalPowerPolynomial T x z (K i) =
      evalPowerPolynomial T x z (uDisplayPowering F_U K_U K R i) := by
  let F' := uDisplayMultiplication F_U K_U R
  have hHallLocal :
      RepresentsHallPolynomials M F'
        (uDisplayPowering F_U K_U K R) (stepFamilyU R K_U) :=
    represents_families_delete
      M K R F_U K_U hK hR hFU hKU
  have hHallSeed : RepresentsHallPolynomials M F' K (stepFamilyU R K_U) :=
    ⟨hHallLocal.1, hK, hHallLocal.2.2⟩
  simpa [uDisplayPowering, F'] using
    solution_update_polynomials
      M F' K (stepFamilyU R K_U) hHallSeed x z i

/--
Specialized polynomial identity between a represented powering family and the
lower-rank `U(T)` assembled powering family from split delete-first
multiplication and powering hypotheses.
-/
theorem specialize_display_delete
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hK : RepresentsPowering M K)
    (hR : RepresentsConjugation M R)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hKU : RepresentsPowering M.deleteFirstConsistent K_U)
    (i : Fin (n + 1)) :
    specializePower T (K i) =
      specializePower T (uDisplayPowering F_U K_U K R i) :=
  specialize_power_eval (K i) (uDisplayPowering F_U K_U K R i)
    (fun x z =>
      display_powering_family
        M K R F_U K_U hK hR hFU hKU x z i)

/--
Existential package for the lower-rank `U(T)` local assembly.  Starting from a
represented ambient Hall bundle and an induction-hypothesis-shaped lower-rank
Hall bundle, it returns the assembled families together with specialized and
integer-evaluation identities back to the original families.
-/
theorem families_polynomials_first
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (hHallU :
      ∃ (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
        (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
        (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
          RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U) :
    ∃ (F' : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
      (K' : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
      (R' : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ),
        RepresentsHallPolynomials M F' K' R' ∧
        (∀ i, specializeMul T (F i) = specializeMul T (F' i)) ∧
        (∀ i, specializePower T (K i) = specializePower T (K' i)) ∧
        (∀ I, specializeConj T (R I) = specializeConj T (R' I)) ∧
        (∀ (x y : Fin (n + 1) → ℤ) i,
          evalMulPolynomial T x y (F i) = evalMulPolynomial T x y (F' i)) ∧
        (∀ (x : Fin (n + 1) → ℤ) (z : ℤ) i,
          evalPowerPolynomial T x z (K i) = evalPowerPolynomial T x z (K' i)) ∧
        ∀ I u v,
          evalConjPolynomial T u v (R I) = evalConjPolynomial T u v (R' I) := by
  rcases hHallU with ⟨F_U, K_U, R_U, hHallU⟩
  refine
    ⟨uDisplayMultiplication F_U K_U R,
      uDisplayPowering F_U K_U K R, stepFamilyU R K_U,
      ?_, ?_, ?_, ?_, ?_, ?_, ?_⟩
  · exact polynomials_1_families
      M K R F_U K_U R_U hHall.2.1 hHall.2.2 hHallU
  · intro i
    exact specialize_multiplication_delete
      M F R F_U K_U R_U hHall.1 hHall.2.2 hHallU i
  · intro i
    exact specialize_display_first
      M K R F_U K_U R_U hHall.2.1 hHall.2.2 hHallU i
  · intro I
    exact specialize_delete_first
      M F_U K_U R_U R hHallU hHall.2.2 I
  · intro x y i
    exact display_multiplication_first
      M F R F_U K_U R_U hHall.1 hHall.2.2 hHallU x y i
  · intro x z i
    exact display_powering_first
      M K R F_U K_U R_U hHall.2.1 hHall.2.2 hHallU x z i
  · intro I u v
    exact family_u_delete
      M F_U K_U R_U R hHallU hHall.2.2 I u v

/--
Identity-retaining package for the lower-rank `U(T)` local assembly, consuming
only represented lower-rank multiplication and powering for the delete-first
presentation.
-/
theorem display_families_power
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHall : RepresentsHallPolynomials M F K R)
    (hFKU :
      ∃ (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
        (K_U : Fin n → MvPolynomial (PowerVar n) ℚ),
          RepresentsMultiplication M.deleteFirstConsistent F_U ∧
          RepresentsPowering M.deleteFirstConsistent K_U) :
    ∃ (F' : Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ)
      (K' : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
      (R' : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ),
        RepresentsHallPolynomials M F' K' R' ∧
        (∀ i, specializeMul T (F i) = specializeMul T (F' i)) ∧
        (∀ i, specializePower T (K i) = specializePower T (K' i)) ∧
        (∀ I, specializeConj T (R I) = specializeConj T (R' I)) ∧
        (∀ (x y : Fin (n + 1) → ℤ) i,
          evalMulPolynomial T x y (F i) = evalMulPolynomial T x y (F' i)) ∧
        (∀ (x : Fin (n + 1) → ℤ) (z : ℤ) i,
          evalPowerPolynomial T x z (K i) = evalPowerPolynomial T x z (K' i)) ∧
        ∀ I u v,
          evalConjPolynomial T u v (R I) = evalConjPolynomial T u v (R' I) := by
  rcases hFKU with ⟨F_U, K_U, hFU, hKU⟩
  refine
    ⟨uDisplayMultiplication F_U K_U R,
      uDisplayPowering F_U K_U K R, stepFamilyU R K_U,
      ?_, ?_, ?_, ?_, ?_, ?_, ?_⟩
  · exact represents_families_delete
      M K R F_U K_U hHall.2.1 hHall.2.2 hFU hKU
  · intro i
    exact specialize_1_multiplication
      M F R F_U K_U hHall.1 hHall.2.2 hFU hKU i
  · intro i
    exact specialize_display_delete
      M K R F_U K_U hHall.2.1 hHall.2.2 hFU hKU i
  · intro I
    exact specialize_represents_powering
      M K_U R hKU hHall.2.2 I
  · intro x y i
    exact display_multiplication_family
      M F R F_U K_U hHall.1 hHall.2.2 hFU hKU x y i
  · intro x z i
    exact display_powering_family
      M K R F_U K_U hHall.2.1 hHall.2.2 hFU hKU x z i
  · intro I u v
    exact u_represents_powering
      M K_U R hKU hHall.2.2 I u v

/--
Named lower-rank `U(T)` multiplication family for the combined local Section
3.2/3.3/3.4 assembly: first install the combined `step1`/`step2`
conjugation coordinates, then build the Section 3.3 displayed multiplication
product from the canonical `U(T)` multiplication family.
-/
def displayMultiplicationFamily {n : ℕ}
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ) :
    Fin (n + 1) → MvPolynomial (MulVar (n + 1)) ℚ :=
  multiplicationDisplayProduct F_U
    (conjFamilyU F_U K_U R)

/--
Named lower-rank `U(T)` powering family for the combined local Section 3
assembly: use the displayed multiplication family built from the combined
`step1`/`step2` conjugation family, with the paper-style last coordinate.
-/
def displayPoweringFamily {n : ℕ}
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ) :
    Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ :=
  Function.update
    (fun i => forwardSolutionPolynomial
      (displayMultiplicationFamily F_U K_U R) K i)
    (Fin.last n)
    (lastSolutionPolynomial
      (displayMultiplicationFamily F_U K_U R) K)

/--
Combined lower-rank `U(T)`/`W(T)` powering family for the local Section 3
assembly: build multiplication from the combined `U(T)` conjugation display,
lift non-last powering coordinates from quotient `W(T)`, and construct the
last coordinate by the Section 3.4 paper-style solution.
-/
def uwPoweringFamily {n : ℕ}
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (K_seed : MvPolynomial (PowerVar (n + 1)) ℚ) :
    Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ :=
  deleteLastSolution
    (displayMultiplicationFamily F_U K_U R) K_W K_seed

/--
Seed-free combined lower-rank `U(T)`/`W(T)` powering family: build the
displayed multiplication family from `U(T)` data, lift non-last powering
coordinates from `W(T)`, and construct the last coordinate from the Section
3.4 recurrence without a seed.
-/
def uwPoweringSolution {n : ℕ}
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ) :
    Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ :=
  poweringSolutionFamily
    (displayMultiplicationFamily F_U K_U R) K_W

/--
Combined lower-rank `U(T)` assembly theorem: represented Hall polynomials for
the canonical `U(T)` presentation, together with represented ambient powering
and conjugation, build a represented ambient Hall-polynomial family whose
conjugation coordinates use the combined `step1`/`step2` construction.
-/
theorem represents_families_first
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hK : RepresentsPowering M K)
    (hR : RepresentsConjugation M R)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U) :
    RepresentsHallPolynomials M
      (displayMultiplicationFamily F_U K_U R)
      (displayPoweringFamily F_U K_U K R)
      (conjFamilyU F_U K_U R) := by
  let R' := conjFamilyU F_U K_U R
  let F' := displayMultiplicationFamily F_U K_U R
  have hR' : RepresentsConjugation M R' :=
    represents_conjugation_conj
      M F_U K_U R_U R hHallU hR
  have hF' : RepresentsMultiplication M F' := by
    simpa [F', R', displayMultiplicationFamily] using
      represents_display_u
        M F_U R' hHallU.1 hR'
  have hK' :
      RepresentsPowering M
        (displayPoweringFamily F_U K_U K R) := by
    simpa [displayPoweringFamily, F'] using
      forward_update_last
        M F' K hF' hK
  exact ⟨hF', hK', hR'⟩

/--
Combined lower-rank `U(T)` assembly with split canonical lower-rank input:
lower-rank multiplication supplies the display product, and lower-rank
powering supplies the `step1` part of the combined conjugation family.
-/
theorem polynomials_u_families
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hK : RepresentsPowering M K)
    (hR : RepresentsConjugation M R)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hKU : RepresentsPowering M.deleteFirstConsistent K_U) :
    RepresentsHallPolynomials M
      (displayMultiplicationFamily F_U K_U R)
      (displayPoweringFamily F_U K_U K R)
      (conjFamilyU F_U K_U R) := by
  let R' := conjFamilyU F_U K_U R
  let F' := displayMultiplicationFamily F_U K_U R
  have hR' : RepresentsConjugation M R' :=
    represents_u_powering
      M F_U K_U R hFU hKU hR
  have hF' : RepresentsMultiplication M F' := by
    simpa [F', R', displayMultiplicationFamily] using
      represents_display_u
        M F_U R' hFU hR'
  have hK' :
      RepresentsPowering M
        (displayPoweringFamily F_U K_U K R) := by
    simpa [displayPoweringFamily, F'] using
      forward_update_last
        M F' K hF' hK
  exact ⟨hF', hK', hR'⟩

/--
Stronger combined lower-rank `U(T)` assembly theorem: in addition to using
the Section 3.2 `step1`/`step2` construction for first-generator conjugation
coordinates, the final conjugation family installs all successor-tail
coordinates from the delete-first `U(T)` conjugation family.
-/
theorem polynomials_full_families
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hK : RepresentsPowering M K)
    (hR : RepresentsConjugation M R)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U) :
    RepresentsHallPolynomials M
      (displayMultiplicationFamily F_U K_U R)
      (displayPoweringFamily F_U K_U K R)
      (conj1U F_U K_U R_U R) := by
  let R' := conjFamilyU F_U K_U R
  let F' := displayMultiplicationFamily F_U K_U R
  have hR' : RepresentsConjugation M R' :=
    represents_conjugation_conj
      M F_U K_U R_U R hHallU hR
  have hRfull :
      RepresentsConjugation M
        (conj1U F_U K_U R_U R) :=
    represents_conjugation_1
      M F_U K_U R_U R hHallU hR
  have hF' : RepresentsMultiplication M F' := by
    simpa [F', R', displayMultiplicationFamily] using
      represents_display_u
        M F_U R' hHallU.1 hR'
  have hK' :
      RepresentsPowering M
        (displayPoweringFamily F_U K_U K R) := by
    simpa [displayPoweringFamily, F'] using
      forward_update_last
        M F' K hF' hK
  exact ⟨hF', hK', hRfull⟩

/--
Stronger combined lower-rank `U(T)` assembly with full successor-tail
conjugation replacement, using only the represented delete-first components
that are actually needed.
-/
theorem represents_polynomials_families
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hK : RepresentsPowering M K)
    (hR : RepresentsConjugation M R)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hKU : RepresentsPowering M.deleteFirstConsistent K_U)
    (hR_U : RepresentsConjugation M.deleteFirstConsistent R_U) :
    RepresentsHallPolynomials M
      (displayMultiplicationFamily F_U K_U R)
      (displayPoweringFamily F_U K_U K R)
      (conj1U F_U K_U R_U R) := by
  let R' := conjFamilyU F_U K_U R
  let F' := displayMultiplicationFamily F_U K_U R
  have hR' : RepresentsConjugation M R' :=
    represents_u_powering
      M F_U K_U R hFU hKU hR
  have hRfull :
      RepresentsConjugation M
        (conj1U F_U K_U R_U R) :=
    represents_conjugation_data
      M F_U K_U R_U R hFU hKU hR_U hR
  have hF' : RepresentsMultiplication M F' := by
    simpa [F', R', displayMultiplicationFamily] using
      represents_display_u
        M F_U R' hFU hR'
  have hK' :
      RepresentsPowering M
        (displayPoweringFamily F_U K_U K R) := by
    simpa [displayPoweringFamily, F'] using
      forward_update_last
        M F' K hF' hK
  exact ⟨hF', hK', hRfull⟩

/--
Exact-premise version of
`represents_families_first`.
It keeps the canonical lower-rank multiplication and powering assumptions, but
replaces the lower-rank Hall-bundle dependency for the `step2` substitutions by
explicit product-evaluation premises.
-/
theorem represents_u_families
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hK : RepresentsPowering M K)
    (hR : RepresentsConjugation M R)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hKU : RepresentsPowering M.deleteFirstConsistent K_U)
    (hZeroInit : ∀ (j i : Fin n) (hji : j < i),
      evalConjPolynomial T 1 0
        (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
          Fin.succ_lt_succ_iff.mpr hji⟩) = 0)
    (hDelta : ∀ (j i : Fin n) (hji : j < i) (v : ℤ),
      conjOnePolynomial T v
          (forwardDifferenceV R
            ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
              Fin.succ_lt_succ_iff.mpr hji⟩) =
        (M.coord (M.firstConjugatedProduct
            (M.leftConjugationTuple 0 (Fin.succ j) 1 v) 1) (Fin.succ i) : ℚ) -
          (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ i) : ℚ))
    (hCurrent : ∀ (j i : Fin n) (hji : j < i) (v : ℤ),
      evalConjPolynomial T 1 v
          (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
            Fin.succ_lt_succ_iff.mpr hji⟩) =
        (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ i) : ℚ))
    (hSubst : ∀ j v w,
      MvPolynomial.eval (conjOneVar T v)
          (conjStepSubst R (Fin.succ j) (Fin.succ_pos j) w) =
        evalMulVar T (M.leftConjugationTuple 0 (Fin.succ j) 1 v) (singleCoord 0 1) w)
    (hFactor : ∀ j v r s,
      MvPolynomial.eval
          (evalMulVar T (M.leftConjugationTuple 0 (Fin.succ j) 1 v) (singleCoord 0 1))
          (firstConjugatedPolynomial R r s) =
        (M.leftConjugationTuple 0 (Fin.succ r)
          (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ r)) 1 (Fin.succ s) : ℚ))
    (hTailZero : ∀ j v r,
      M.leftConjugationTuple 0 (Fin.succ r)
        (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ r)) 1 0 = 0) :
    RepresentsHallPolynomials M
      (displayMultiplicationFamily F_U K_U R)
      (displayPoweringFamily F_U K_U K R)
      (conjFamilyU F_U K_U R) := by
  let R' := conjFamilyU F_U K_U R
  let F' := displayMultiplicationFamily F_U K_U R
  let hClosed :=
    CPres.coordinate_closed_additive M 0 M.firstCoordinateAdditive
  have hFU0 :
      RepresentsMultiplication (M.firstConsistentPresentation hClosed.1 hClosed.2)
        F_U := by
    simpa [CPres.deleteFirstConsistent,
      CPres.firstConsistentAdditive,
      hClosed] using hFU
  have hR' : RepresentsConjugation M R' :=
    represents_conjugation_family
      M hClosed.1 hClosed.2 F_U K_U R hFU0 hKU hR
      hZeroInit hDelta hCurrent hSubst hFactor hTailZero
  have hF' : RepresentsMultiplication M F' := by
    simpa [F', R', displayMultiplicationFamily] using
      represents_display_u
        M F_U R' hFU hR'
  have hK' :
      RepresentsPowering M
        (displayPoweringFamily F_U K_U K R) := by
    simpa [displayPoweringFamily, F'] using
      forward_update_last
        M F' K hF' hK
  exact ⟨hF', hK', hR'⟩

/--
Exact-premise full-conjugation version of the local `U(T)` display assembly.
-/
theorem represents_full_families
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hK : RepresentsPowering M K)
    (hR : RepresentsConjugation M R)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hKU : RepresentsPowering M.deleteFirstConsistent K_U)
    (hR_U : RepresentsConjugation M.deleteFirstConsistent R_U)
    (hZeroInit : ∀ (j i : Fin n) (hji : j < i),
      evalConjPolynomial T 1 0
        (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
          Fin.succ_lt_succ_iff.mpr hji⟩) = 0)
    (hDelta : ∀ (j i : Fin n) (hji : j < i) (v : ℤ),
      conjOnePolynomial T v
          (forwardDifferenceV R
            ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
              Fin.succ_lt_succ_iff.mpr hji⟩) =
        (M.coord (M.firstConjugatedProduct
            (M.leftConjugationTuple 0 (Fin.succ j) 1 v) 1) (Fin.succ i) : ℚ) -
          (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ i) : ℚ))
    (hCurrent : ∀ (j i : Fin n) (hji : j < i) (v : ℤ),
      evalConjPolynomial T 1 v
          (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
            Fin.succ_lt_succ_iff.mpr hji⟩) =
        (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ i) : ℚ))
    (hSubst : ∀ j v w,
      MvPolynomial.eval (conjOneVar T v)
          (conjStepSubst R (Fin.succ j) (Fin.succ_pos j) w) =
        evalMulVar T (M.leftConjugationTuple 0 (Fin.succ j) 1 v) (singleCoord 0 1) w)
    (hFactor : ∀ j v r s,
      MvPolynomial.eval
          (evalMulVar T (M.leftConjugationTuple 0 (Fin.succ j) 1 v) (singleCoord 0 1))
          (firstConjugatedPolynomial R r s) =
        (M.leftConjugationTuple 0 (Fin.succ r)
          (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ r)) 1 (Fin.succ s) : ℚ))
    (hTailZero : ∀ j v r,
      M.leftConjugationTuple 0 (Fin.succ r)
        (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ r)) 1 0 = 0) :
    RepresentsHallPolynomials M
      (displayMultiplicationFamily F_U K_U R)
      (displayPoweringFamily F_U K_U K R)
      (conj1U F_U K_U R_U R) := by
  let R' := conjFamilyU F_U K_U R
  let F' := displayMultiplicationFamily F_U K_U R
  let hClosed :=
    CPres.coordinate_closed_additive M 0 M.firstCoordinateAdditive
  have hFU0 :
      RepresentsMultiplication (M.firstConsistentPresentation hClosed.1 hClosed.2)
        F_U := by
    simpa [CPres.deleteFirstConsistent,
      CPres.firstConsistentAdditive,
      hClosed] using hFU
  have hR' : RepresentsConjugation M R' :=
    represents_conjugation_family
      M hClosed.1 hClosed.2 F_U K_U R hFU0 hKU hR
      hZeroInit hDelta hCurrent hSubst hFactor hTailZero
  have hRfull :
      RepresentsConjugation M
        (conj1U F_U K_U R_U R) :=
    represents_conjugation_delete
      M hClosed.1 hClosed.2 F_U K_U R_U R hFU0 hKU hR_U hR
      hZeroInit hDelta hCurrent hSubst hFactor hTailZero
  have hF' : RepresentsMultiplication M F' := by
    simpa [F', R', displayMultiplicationFamily] using
      represents_display_u
        M F_U R' hFU hR'
  have hK' :
      RepresentsPowering M
        (displayPoweringFamily F_U K_U K R) := by
    simpa [displayPoweringFamily, F'] using
      forward_update_last
        M F' K hF' hK
  exact ⟨hF', hK', hRfull⟩

/--
Exact-premise local `U(T)` display assembly with the forward-difference delta
and tail-zero premises discharged semantically.
-/
theorem polynomials_families_delta
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (hK : RepresentsPowering M K)
    (hR : RepresentsConjugation M R)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hKU : RepresentsPowering M.deleteFirstConsistent K_U)
    (hZeroInit : ∀ (j i : Fin n) (hji : j < i),
      evalConjPolynomial T 1 0
        (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
          Fin.succ_lt_succ_iff.mpr hji⟩) = 0)
    (hCurrent : ∀ (j i : Fin n) (hji : j < i) (v : ℤ),
      evalConjPolynomial T 1 v
          (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
            Fin.succ_lt_succ_iff.mpr hji⟩) =
        (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ i) : ℚ))
    (hSubst : ∀ j v w,
      MvPolynomial.eval (conjOneVar T v)
          (conjStepSubst R (Fin.succ j) (Fin.succ_pos j) w) =
        evalMulVar T (M.leftConjugationTuple 0 (Fin.succ j) 1 v) (singleCoord 0 1) w)
    (hFactor : ∀ j v r s,
      MvPolynomial.eval
          (evalMulVar T (M.leftConjugationTuple 0 (Fin.succ j) 1 v) (singleCoord 0 1))
          (firstConjugatedPolynomial R r s) =
        (M.leftConjugationTuple 0 (Fin.succ r)
          (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ r)) 1 (Fin.succ s) : ℚ)) :
    RepresentsHallPolynomials M
      (displayMultiplicationFamily F_U K_U R)
      (displayPoweringFamily F_U K_U K R)
      (conjFamilyU F_U K_U R) :=
  represents_u_families
    M K R F_U K_U hK hR hFU hKU hZeroInit
    (fun j i hji v =>
      forward_conjugated_current
        M R j i hji v (hCurrent j i hji))
    hCurrent hSubst hFactor
    (conjugation_tuple_step M)

/--
Exact-premise full-conjugation local `U(T)` display assembly with the
forward-difference delta and tail-zero premises discharged semantically.
-/
theorem display_families_delta
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (K : Fin (n + 1) → MvPolynomial (PowerVar (n + 1)) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hK : RepresentsPowering M K)
    (hR : RepresentsConjugation M R)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hKU : RepresentsPowering M.deleteFirstConsistent K_U)
    (hR_U : RepresentsConjugation M.deleteFirstConsistent R_U)
    (hZeroInit : ∀ (j i : Fin n) (hji : j < i),
      evalConjPolynomial T 1 0
        (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
          Fin.succ_lt_succ_iff.mpr hji⟩) = 0)
    (hCurrent : ∀ (j i : Fin n) (hji : j < i) (v : ℤ),
      evalConjPolynomial T 1 v
          (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
            Fin.succ_lt_succ_iff.mpr hji⟩) =
        (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ i) : ℚ))
    (hSubst : ∀ j v w,
      MvPolynomial.eval (conjOneVar T v)
          (conjStepSubst R (Fin.succ j) (Fin.succ_pos j) w) =
        evalMulVar T (M.leftConjugationTuple 0 (Fin.succ j) 1 v) (singleCoord 0 1) w)
    (hFactor : ∀ j v r s,
      MvPolynomial.eval
          (evalMulVar T (M.leftConjugationTuple 0 (Fin.succ j) 1 v) (singleCoord 0 1))
          (firstConjugatedPolynomial R r s) =
        (M.leftConjugationTuple 0 (Fin.succ r)
          (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ r)) 1 (Fin.succ s) : ℚ)) :
    RepresentsHallPolynomials M
      (displayMultiplicationFamily F_U K_U R)
      (displayPoweringFamily F_U K_U K R)
      (conj1U F_U K_U R_U R) :=
  represents_full_families
    M K R F_U K_U R_U hK hR hFU hKU hR_U hZeroInit
    (fun j i hji v =>
      forward_conjugated_current
        M R j i hji v (hCurrent j i hji))
    hCurrent hSubst hFactor
    (conjugation_tuple_step M)

/--
Seed-free combined lower-rank `U(T)`/`W(T)` assembly theorem.  Lower-rank Hall
data for `U(T)` builds the conjugation and multiplication families, while
lower-rank Hall data for `W(T)` supplies non-last powering coordinates; the
last powering coordinate is constructed by the Section 3.4 recurrence.
-/
theorem polynomials_uw_solution
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (F_W : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_W : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_W : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (hR : RepresentsConjugation M R)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hHallW :
      RepresentsHallPolynomials M.deleteConsistentPresentation F_W K_W R_W) :
    RepresentsHallPolynomials M
      (displayMultiplicationFamily F_U K_U R)
      (uwPoweringSolution F_U K_U R K_W)
      (conjFamilyU F_U K_U R) := by
  let R' := conjFamilyU F_U K_U R
  let F' := displayMultiplicationFamily F_U K_U R
  have hR' : RepresentsConjugation M R' :=
    represents_conjugation_conj
      M F_U K_U R_U R hHallU hR
  have hF' : RepresentsMultiplication M F' := by
    simpa [F', R', displayMultiplicationFamily] using
      represents_display_u
        M F_U R' hHallU.1 hR'
  have hK' :
      RepresentsPowering M
        (uwPoweringSolution F_U K_U R K_W) := by
    simpa [uwPoweringSolution, F'] using
      last_solution_family
        M F' F_W K_W R_W hF' hHallW
  exact ⟨hF', hK', hR'⟩

