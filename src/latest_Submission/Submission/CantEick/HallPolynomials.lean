/--
An existential Hall-polynomial bundle supplies a uniform multiplication method.
-/
theorem evaluation_method_represents
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (hHall :
      ∃ (F : Fin n → MvPolynomial (MulVar n) ℚ)
        (K : Fin n → MvPolynomial (PowerVar n) ℚ)
        (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
          RepresentsHallPolynomials M F K R) :
    ∃ F : Fin n → MvPolynomial (MulVar n) ℚ,
      MulEvaluationMethod M F := by
  rcases hHall with ⟨F, K, R, hHall⟩
  exact ⟨F, mul_evaluation_method M F K R hHall⟩

/--
An existential Hall-polynomial bundle supplies a uniform multiplication method
after parameter specialization.
-/
theorem specialized_method_polynomials
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (hHall :
      ∃ (F : Fin n → MvPolynomial (MulVar n) ℚ)
        (K : Fin n → MvPolynomial (PowerVar n) ℚ)
        (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
          RepresentsHallPolynomials M F K R) :
    ∃ F : Fin n → MvPolynomial (MulVar n) ℚ,
      SpecializedMulMethod M F := by
  rcases hHall with ⟨F, K, R, hHall⟩
  exact ⟨F, specialized_method_hall M F K R hHall⟩

/--
An existential Hall-polynomial bundle supplies a uniform powering method.
-/
theorem evaluation_method_polynomials
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (hHall :
      ∃ (F : Fin n → MvPolynomial (MulVar n) ℚ)
        (K : Fin n → MvPolynomial (PowerVar n) ℚ)
        (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
          RepresentsHallPolynomials M F K R) :
    ∃ K : Fin n → MvPolynomial (PowerVar n) ℚ,
      PowerEvaluationMethod M K := by
  rcases hHall with ⟨F, K, R, hHall⟩
  exact ⟨K, power_evaluation_method M F K R hHall⟩

/--
An existential Hall-polynomial bundle supplies a uniform powering method after
parameter specialization.
-/
theorem specialized_evaluation_method
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (hHall :
      ∃ (F : Fin n → MvPolynomial (MulVar n) ℚ)
        (K : Fin n → MvPolynomial (PowerVar n) ℚ)
        (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
          RepresentsHallPolynomials M F K R) :
    ∃ K : Fin n → MvPolynomial (PowerVar n) ℚ,
      SpecializedEvaluationMethod M K := by
  rcases hHall with ⟨F, K, R, hHall⟩
  exact ⟨K, specialized_method_represents M F K R hHall⟩

/--
Combined Section 6 operation-method consequence of an existential Hall bundle.
-/
theorem operation_methods_polynomials
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (hHall :
      ∃ (F : Fin n → MvPolynomial (MulVar n) ℚ)
        (K : Fin n → MvPolynomial (PowerVar n) ℚ)
        (R : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
          RepresentsHallPolynomials M F K R) :
    ∃ (F : Fin n → MvPolynomial (MulVar n) ℚ)
      (K : Fin n → MvPolynomial (PowerVar n) ℚ),
        MulEvaluationMethod M F ∧
        SpecializedMulMethod M F ∧
        PowerEvaluationMethod M K ∧
        SpecializedEvaluationMethod M K := by
  rcases hHall with ⟨F, K, R, hHall⟩
  exact
    ⟨F, K,
      mul_evaluation_method M F K R hHall,
      specialized_method_hall M F K R hHall,
      power_evaluation_method M F K R hHall,
      specialized_method_represents M F K R hHall⟩

/--
Named `U(T)` projection: lower-rank Hall existence supplies exactly the
multiplication/powering data required by the split delete-first wrappers.
-/
theorem delete_multiplication_powering
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hHallU :
      ∃ (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
        (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
        (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
          RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U) :
    ∃ (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
      (K_U : Fin n → MvPolynomial (PowerVar n) ℚ),
        RepresentsMultiplication M.deleteFirstConsistent F_U ∧
        RepresentsPowering M.deleteFirstConsistent K_U :=
  multiplication_powering_polynomials
    M.deleteFirstConsistent hHallU

/--
Named `U(T)` projection to the conjugation component used by full-conjugation
wrappers.
-/
theorem delete_first_conjugation
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hHallU :
      ∃ (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
        (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
        (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ),
          RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U) :
    ∃ R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ,
      RepresentsConjugation M.deleteFirstConsistent R_U :=
  represents_conjugation_polynomials
    M.deleteFirstConsistent hHallU

/--
Named `U(T)` projection to all represented components.
-/
theorem delete_first_components
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hHallU :
      ∃ (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
