/--
The lower-rank `U(T)` Section 3.2 step-2 constructed solution is
zero-initial, before any representation hypothesis is used.
-/
theorem eval_solution_u
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j)
    (k : Fin n) (hjk : j < Fin.succ k) :
    conjOnePolynomial T 0 (conjSolutionU F_U R j h0j k hjk) = 0 := by
  rw [← conj_univariate_polynomial T (0 : ℤ)
    (conjSolutionU F_U R j h0j k hjk)]
  rw [conjSolutionU, univariate_antiderivative_polynomial]
  simpa using forward_antiderivative_zero (0 : ℚ)
    (conjUnivariatePolynomial T (forwardDifferenceU F_U R j h0j k hjk))

/--
The lower-rank `U(T)` Section 3.2 step-2 constructed solution satisfies its
product-derived forward recursion, before any representation hypothesis is used.
-/
theorem succ_solution_u
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (j : Fin (n + 1)) (h0j : (0 : Fin (n + 1)) < j)
    (k : Fin n) (hjk : j < Fin.succ k) (v : ℤ) :
    conjOnePolynomial T (v + 1) (conjSolutionU F_U R j h0j k hjk) =
      conjOnePolynomial T v (conjSolutionU F_U R j h0j k hjk) +
        conjOnePolynomial T v (forwardDifferenceU F_U R j h0j k hjk) := by
  rw [← conj_univariate_polynomial T (v + 1)
    (conjSolutionU F_U R j h0j k hjk)]
  rw [← conj_univariate_polynomial T v
    (conjSolutionU F_U R j h0j k hjk)]
  rw [← conj_univariate_polynomial T v
    (forwardDifferenceU F_U R j h0j k hjk)]
  rw [conjSolutionU, univariate_antiderivative_polynomial]
  rw [show (((v + 1 : ℤ) : ℚ)) = (v : ℚ) + 1 by norm_num [Int.cast_add]]
  exact polynomial_forward_antiderivative (0 : ℚ)
    (conjUnivariatePolynomial T (forwardDifferenceU F_U R j h0j k hjk))
    (v : ℚ)

theorem solution_u_delete
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hR : RepresentsConjugation M R)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k)
    (v : ℤ) :
    evalConjPolynomial T 1 v (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
      conjOnePolynomial T v
        (conjSolutionU F_U R j h0j k hjk) :=
  int_solution_u
    M F_U R hHallU.1 hR j k h0j hjk v

/--
Existential lower-rank `U(T)` package for the constructed Section 3.2 step-2
solution, consuming Hall polynomials for the canonical delete-first
presentation.
-/
theorem conj_2_solution
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hR : RepresentsConjugation M R)
    (j : Fin (n + 1)) (k : Fin n)
    (h0j : (0 : Fin (n + 1)) < j) (hjk : j < Fin.succ k) :
    ∃ p : MvPolynomial (ConjOneVar (n + 1)) ℚ,
      conjUnivariatePolynomial T
          (conjUPolynomial (R ⟨(0, j, Fin.succ k), h0j, hjk⟩)) =
        conjUnivariatePolynomial T p ∧
      (∀ v : ℤ,
        evalConjPolynomial T 1 v (R ⟨(0, j, Fin.succ k), h0j, hjk⟩) =
          conjOnePolynomial T v p) ∧
      conjOnePolynomial T 0 p = 0 ∧
      ∀ v : ℤ,
        conjOnePolynomial T (v + 1) p =
          conjOnePolynomial T v p +
            conjOnePolynomial T v
              (forwardDifferenceU F_U R j h0j k hjk) := by
  refine ⟨conjSolutionU F_U R j h0j k hjk, ?_, ?_, ?_, ?_⟩
  · exact conj_univariate_solution
      M F_U K_U R_U R hHallU hR j k h0j hjk
  · exact solution_u_delete
      M F_U K_U R_U R hHallU hR j k h0j hjk
  · exact eval_solution_u F_U R j h0j k hjk
  · exact succ_solution_u F_U R j h0j k hjk

/--
Split lower-rank `U(T)` package for the constructed Section 3.2 step-2
solution.  The delete-first input needed for this package is only
multiplication.
