/-- Represented multiplication polynomials form a Section 6 method. -/
theorem evaluation_method_multiplication
    {T : ParameterIndex n → ℤ}
    (M : CPres n T)
    (F : Fin n → MvPolynomial (MulVar n) ℚ)
    (hF : RepresentsMultiplication M F) :
