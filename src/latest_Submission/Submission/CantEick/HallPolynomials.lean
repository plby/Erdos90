          RepresentsPowering M.deleteFirstConsistent K_U)
    (hR : RepresentsConjugation M R)
    (j k : Fin n) (hjk : j < k) :
    ∃ p : MvPolynomial (ConjVar (n + 1)) ℚ,
      specializeConj T
          (R ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
            Fin.succ_lt_succ_iff.mpr hjk⟩) =
        specializeConj T p ∧
      ∀ u v,
        evalConjPolynomial T u v
            (R ⟨(0, Fin.succ j, Fin.succ k), Fin.succ_pos j,
              Fin.succ_lt_succ_iff.mpr hjk⟩) =
          evalConjPolynomial T u v p := by
  rcases hFKU with ⟨F_U, K_U, hFU, hKU⟩
  refine ⟨conjStepU F_U K_U R j k, ?_, ?_⟩
  · exact specialize_1_powering
      M F_U K_U R hFU hKU hR j k hjk
  · exact delete_first_powering
      M F_U K_U R hFU hKU hR j k hjk

/--
Family-level form of the combined lower-rank Section 3.2 construction:
replacing all first-generator tail conjugation coordinates by the combined
`step1`/`step2` polynomials preserves every integer evaluation.
-/
theorem u_delete_first
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hR : RepresentsConjugation M R)
    (I : ParameterIndex (n + 1)) (u v : ℤ) :
    evalConjPolynomial T u v (R I) =
      evalConjPolynomial T u v (conjFamilyU F_U K_U R I) := by
  rcases I with ⟨⟨i, j, k⟩, hij, hjk⟩
  cases j using Fin.cases with
  | zero =>
      simp [conjFamilyU]
  | succ j' =>
      cases k using Fin.cases with
      | zero =>
          simp [conjFamilyU]
      | succ k' =>
          by_cases hi0 : i = 0
          · subst i
            have hjk' : j' < k' := by
              simpa using (Fin.succ_lt_succ_iff.mp hjk)
            change evalConjPolynomial T u v
                (R ⟨(0, Fin.succ j', Fin.succ k'), hij, hjk⟩) =
              evalConjPolynomial T u v
                (conjStepU F_U K_U R j' k')
            exact u_delete_hall
              M F_U K_U R_U R hHallU hR j' k' hjk' u v
          · simp [conjFamilyU, hi0]

/--
Specialized polynomial identity for the family-level combined lower-rank
Section 3.2 replacement.
-/
theorem specialize_u_delete
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R_U : ParameterIndex n → MvPolynomial (ConjVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hHallU :
      RepresentsHallPolynomials M.deleteFirstConsistent F_U K_U R_U)
    (hR : RepresentsConjugation M R)
    (I : ParameterIndex (n + 1)) :
    specializeConj T (R I) =
      specializeConj T (conjFamilyU F_U K_U R I) :=
  specialize_conj_eval (R I) (conjFamilyU F_U K_U R I)
    (fun u v =>
      u_delete_first
        M F_U K_U R_U R hHallU hR I u v)

