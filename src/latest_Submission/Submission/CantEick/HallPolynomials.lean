            change evalConjPolynomial T u v
                (R ⟨(0, Fin.succ j', Fin.succ k'), hij, hjk⟩) =
              evalConjPolynomial T u v
                (conjStepU F_U K_U R j' k')
            exact delete_first_powering
              M F_U K_U R hFU hKU hR j' k' hjk' u v
          · simp [conjFamilyU, hi0]

/--
Specialized polynomial identity for the family-level combined lower-rank
Section 3.2 replacement with split delete-first multiplication and powering
premises.
-/
theorem specialize_u_powering
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication M.deleteFirstConsistent F_U)
    (hKU : RepresentsPowering M.deleteFirstConsistent K_U)
    (hR : RepresentsConjugation M R)
    (I : ParameterIndex (n + 1)) :
    specializeConj T (R I) =
      specializeConj T (conjFamilyU F_U K_U R I) :=
  specialize_conj_eval (R I) (conjFamilyU F_U K_U R I)
    (fun u v =>
      u_delete_powering
        M F_U K_U R hFU hKU hR I u v)

/--
Family-level exact-premise form of the combined lower-rank Section 3.2
construction.
-/
theorem family_u_product
    {n : ℕ} {T : ParameterIndex (n + 1) → ℤ}
    (M : CPres (n + 1) T)
    (hMul : ∀ a b : M.G,
      M.coord a 0 = 0 → M.coord b 0 = 0 → M.coord (a * b) 0 = 0)
    (hInv : ∀ a : M.G, M.coord a 0 = 0 → M.coord a⁻¹ 0 = 0)
    (F_U : Fin n → MvPolynomial (MulVar n) ℚ)
    (K_U : Fin n → MvPolynomial (PowerVar n) ℚ)
    (R : ParameterIndex (n + 1) → MvPolynomial (ConjVar (n + 1)) ℚ)
    (hFU : RepresentsMultiplication
      (M.firstConsistentPresentation hMul hInv) F_U)
    (hKU : RepresentsPowering M.deleteFirstConsistent K_U)
    (hR : RepresentsConjugation M R)
    (hZeroInit : ∀ (j i : Fin n) (hji : j < i),
      evalConjPolynomial T 1 0
        (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
          Fin.succ_lt_succ_iff.mpr hji⟩) = 0)
    (hDelta : ∀ (j i : Fin n) (hji : j < i) (v : ℤ),
      conjOnePolynomial T v
          (forwardDifferenceV R
            ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
              Fin.succ_lt_succ_iff.mpr hji⟩) =
        (M.coord (M.firstConjugatedProduct
            (M.leftConjugationTuple 0 (Fin.succ j) 1 v) 1) (Fin.succ i) : ℚ) -
          (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ i) : ℚ))
    (hCurrent : ∀ (j i : Fin n) (hji : j < i) (v : ℤ),
      evalConjPolynomial T 1 v
          (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
            Fin.succ_lt_succ_iff.mpr hji⟩) =
        (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ i) : ℚ))
    (hSubst : ∀ j v w,
      MvPolynomial.eval (conjOneVar T v)
          (conjStepSubst R (Fin.succ j) (Fin.succ_pos j) w) =
        evalMulVar T (M.leftConjugationTuple 0 (Fin.succ j) 1 v) (singleCoord 0 1) w)
    (hFactor : ∀ j v r s,
      MvPolynomial.eval
          (evalMulVar T (M.leftConjugationTuple 0 (Fin.succ j) 1 v) (singleCoord 0 1))
          (firstConjugatedPolynomial R r s) =
        (M.leftConjugationTuple 0 (Fin.succ r)
          (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ r)) 1 (Fin.succ s) : ℚ))
    (hTailZero : ∀ j v r,
      M.leftConjugationTuple 0 (Fin.succ r)
        (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ r)) 1 0 = 0)
    (I : ParameterIndex (n + 1)) (u v : ℤ) :
    evalConjPolynomial T u v (R I) =
      evalConjPolynomial T u v (conjFamilyU F_U K_U R I) := by
  rcases I with ⟨⟨i, j, k⟩, hij, hjk⟩
  cases j using Fin.cases with
  | zero =>
      simp [conjFamilyU]
  | succ j' =>
      cases k using Fin.cases with
      | zero =>
          simp [conjFamilyU]
      | succ k' =>
          by_cases hi0 : i = 0
          · subst i
            have hjk' : j' < k' := by
              simpa using (Fin.succ_lt_succ_iff.mp hjk)
            change evalConjPolynomial T u v
                (R ⟨(0, Fin.succ j', Fin.succ k'), hij, hjk⟩) =
              evalConjPolynomial T u v
                (conjStepU F_U K_U R j' k')
            exact conj_u_product
              M hMul hInv F_U K_U R hFU hKU hR j' k' hjk' u v
              (fun i hji => hZeroInit j' i hji)
              (fun i hji v => hDelta j' i hji v)
              (fun i hji v => hCurrent j' i hji v)
              (hSubst j') (hFactor j') (hTailZero j')
          · simp [conjFamilyU, hi0]

/--
Specialized polynomial identity for the family-level exact-premise combined
lower-rank Section 3.2 replacement.
