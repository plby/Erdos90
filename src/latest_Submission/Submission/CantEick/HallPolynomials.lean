  · exact (M.normal_multiplication_tuple x y).symm

/--
Powering analogue of the Section 6 method: if a represented powering family
evaluates to the integer tuple `z`, then `z` is the normal coordinate tuple of
the power.
-/
theorem normal_zpow_polynomial
    {T : ParameterIndex n → ℤ}
