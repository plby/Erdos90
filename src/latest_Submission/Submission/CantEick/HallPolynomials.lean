      evalConjPolynomial T 1 v
          (R ⟨(0, Fin.succ j, Fin.succ i), Fin.succ_pos j,
            Fin.succ_lt_succ_iff.mpr hji⟩) =
        (M.leftConjugationTuple 0 (Fin.succ j) 1 v (Fin.succ i) : ℚ))
