import Submission.Group.Zassenhaus.ZassenhausRecursive
import Submission.Group.LowerCentralStrong


/-!
# Powers and commutators modulo third-level commutators

This file formalizes Lemma 7.2 of Efrat--Chapman.  The notation
`subgroupPower H a` denotes the normal subgroup generated by the `a`th powers
of elements of `H`.
-/

namespace EChapma

open Submission
open scoped commutatorElement

variable {G Q : Type*} [Group G] [Group Q]

private def powerGenerators (H : Subgroup G) (a : ℕ) : Set G :=
  {y | ∃ x ∈ H, x ^ a = y}

/-- For a normal subgroup, taking the ambient normal closure in
`subgroupPower` adds nothing to the ordinary subgroup generated by its
powers. -/
theorem subgroup_power_closure (H : Subgroup G) [H.Normal] (a : ℕ) :
    subgroupPower H a = Subgroup.closure (powerGenerators H a) := by
  apply le_antisymm
  · unfold subgroupPower
    let K : Subgroup G := Subgroup.closure (powerGenerators H a)
    haveI : K.Normal := by
      constructor
      intro x hx g
      induction hx using Subgroup.closure_induction with
      | mem x hx =>
          rcases hx with ⟨h, hh, rfl⟩
          apply Subgroup.subset_closure
          refine ⟨g * h * g⁻¹, (inferInstance : H.Normal).conj_mem h hh g, ?_⟩
          exact conj_pow (i := a) (a := g) (b := h)
      | one => simp
      | mul x y _ _ hx hy =>
          rw [← conj_mul]
          exact K.mul_mem hx hy
      | inv x _ hx =>
          rw [← conj_inv]
          exact K.inv_mem hx
    exact Subgroup.normalClosure_le_normal Subgroup.subset_closure
  · rw [Subgroup.closure_le]
    rintro y ⟨x, hx, rfl⟩
    exact pow_subgroup_power H a hx

/-- Surjective homomorphisms carry a relative power subgroup onto the
relative power subgroup of the image. -/
theorem subgroup_power_surjective
    (H : Subgroup G) (a : ℕ) (f : G →* Q)
    (hf : Function.Surjective f) :
    (subgroupPower H a).map f = subgroupPower (H.map f) a := by
  haveI : ((subgroupPower H a).map f).Normal :=
    (inferInstance : (subgroupPower H a).Normal).map f hf
  apply le_antisymm
  · rw [Subgroup.map_le_iff_le_comap]
    unfold subgroupPower
    apply Subgroup.normalClosure_le_normal
    rintro y ⟨x, hx, rfl⟩
    change f (x ^ a) ∈ subgroupPower (H.map f) a
    rw [map_pow]
    exact pow_subgroup_power (H.map f) a
      (Subgroup.mem_map_of_mem f hx)
  · change
      Subgroup.normalClosure {y : Q | ∃ x ∈ H.map f, x ^ a = y} ≤
        (subgroupPower H a).map f
    apply Subgroup.normalClosure_le_normal
    rintro y ⟨z, hz, rfl⟩
    rcases hz with ⟨x, hx, rfl⟩
    exact ⟨x ^ a, pow_subgroup_power H a hx, by simp⟩

/-- A normal subgroup containing the `f i`th powers of `H` for every
`i ∈ s` also contains the powers whose exponent is the finite gcd. -/
theorem subgroup_finset_gcd
    {ι : Type*} (H K : Subgroup G) [K.Normal]
    (s : Finset ι) (f : ι → ℕ)
    (h : ∀ i ∈ s, subgroupPower H (f i) ≤ K) :
    subgroupPower H (s.gcd f) ≤ K := by
  classical
  let q : G →* G ⧸ K := QuotientGroup.mk' K
  unfold subgroupPower
  apply Subgroup.normalClosure_le_normal
  rintro y ⟨x, hx, rfl⟩
  apply
    (QuotientGroup.eq_one_iff (N := K) (x ^ s.gcd f)).mp
  change q (x ^ s.gcd f) = 1
  rw [map_pow]
  induction s using Finset.induction_on with
  | empty =>
      simp
  | @insert i s hi ih =>
      rw [Finset.gcd_insert]
      apply (pow_gcd_eq_one (a := q x) (m := f i) (n := s.gcd f)).2
      constructor
      · rw [← map_pow q]
        apply
          (QuotientGroup.eq_one_iff (N := K) (x ^ f i)).mpr
        exact h i (Finset.mem_insert_self i s)
          (pow_subgroup_power H (f i) hx)
      · exact ih fun j hj =>
          h j (Finset.mem_insert_of_mem hj)

private theorem commute_commutator_bot
    {H : Subgroup G}
    (hcentral : ⁅⁅H, (⊤ : Subgroup G)⁆, (⊤ : Subgroup G)⁆ = ⊥)
    {c x : G} (hc : c ∈ ⁅H, (⊤ : Subgroup G)⁆) :
    Commute c x := by
  rw [← commutatorElement_eq_one_iff_commute]
  have hmem :
      ⁅c, x⁆ ∈ ⁅⁅H, (⊤ : Subgroup G)⁆, (⊤ : Subgroup G)⁆ :=
    Subgroup.commutator_mem_commutator hc trivial
  rw [hcentral] at hmem
  simpa using hmem

private theorem commutator_element_central
    {H : Subgroup G}
    (hcentral : ⁅⁅H, (⊤ : Subgroup G)⁆, (⊤ : Subgroup G)⁆ = ⊥)
    {h g : G} (hh : h ∈ H) (a : ℕ) :
    ⁅h ^ a, g⁆ = ⁅h, g⁆ ^ a := by
  apply Submission.element_left_commute
  exact
    (commute_commutator_bot hcentral
      (Subgroup.commutator_mem_commutator hh trivial)).symm

/-- In a group where `[H,G]` is central, powers pull through the subgroup
commutator exactly. -/
theorem commutator_subgroup_central
    (H : Subgroup G) [H.Normal] (a : ℕ)
    (hcentral : ⁅⁅H, (⊤ : Subgroup G)⁆, (⊤ : Subgroup G)⁆ = ⊥) :
    ⁅subgroupPower H a, (⊤ : Subgroup G)⁆ =
      subgroupPower ⁅H, (⊤ : Subgroup G)⁆ a := by
  let C : Subgroup G := ⁅H, (⊤ : Subgroup G)⁆
  let P : Subgroup G := subgroupPower C a
  have hCcentral : ∀ {c x : G}, c ∈ C → Commute c x := by
    intro c x hc
    exact commute_commutator_bot hcentral hc
  apply le_antisymm
  · rw [Subgroup.commutator_le]
    intro x hx g _
    rw [subgroup_power_closure H a] at hx
    induction hx using Subgroup.closure_induction with
    | mem x hx =>
        rcases hx with ⟨h, hh, rfl⟩
        rw [commutator_element_central hcentral hh]
        exact pow_subgroup_power C a
          (Subgroup.commutator_mem_commutator hh trivial)
    | one => simp []
    | mul x y _ _ hx hy =>
        rw [Submission.element_mul_left]
        exact P.mul_mem
          ((inferInstance : P.Normal).conj_mem _ hy x)
          hx
    | inv x _ hx =>
        have hq :
            QuotientGroup.mk' P ⁅x, g⁆ = 1 :=
          (QuotientGroup.eq_one_iff _).mpr hx
        have hcomm :
            Commute (QuotientGroup.mk' P x) (QuotientGroup.mk' P g) := by
          rw [← commutatorElement_eq_one_iff_commute,
            ← map_commutatorElement]
          exact hq
        apply (QuotientGroup.eq_one_iff _).mp
        simpa only [map_commutatorElement, map_inv] using
          (hcomm.inv_left).commutator_eq
  · unfold subgroupPower
    apply Subgroup.normalClosure_le_normal
    rintro y ⟨c, hc, rfl⟩
    rw [Subgroup.commutator_def] at hc
    induction hc using Subgroup.closure_induction with
    | mem c hc =>
        rcases hc with ⟨h, hh, g, _, rfl⟩
        rw [← commutator_element_central hcentral hh]
        exact Subgroup.commutator_mem_commutator
          (pow_subgroup_power H a hh) trivial
    | one => simp
    | mul x y _ _ hx hy =>
        rw [(hCcentral (c := x) (x := y) ‹x ∈ C›).mul_pow a]
        exact Subgroup.mul_mem _ hx hy
    | inv x _ hx =>
        rw [inv_pow]
        exact Subgroup.inv_mem _ hx

/-- Efrat--Chapman, Lemma 7.2(a):
`[H^a,G]` and `[H,G]^a` agree modulo `[[H,G],G]`. -/
theorem commutator_sup_nested
    (H : Subgroup G) [H.Normal] (a : ℕ) :
    ⁅subgroupPower H a, (⊤ : Subgroup G)⁆ ⊔
        ⁅⁅H, (⊤ : Subgroup G)⁆, (⊤ : Subgroup G)⁆ =
      subgroupPower ⁅H, (⊤ : Subgroup G)⁆ a ⊔
        ⁅⁅H, (⊤ : Subgroup G)⁆, (⊤ : Subgroup G)⁆ := by
  let N : Subgroup G := ⁅⁅H, (⊤ : Subgroup G)⁆, (⊤ : Subgroup G)⁆
  letI : N.Normal := by
    dsimp [N]
    infer_instance
  let q : G →* G ⧸ N := QuotientGroup.mk' N
  have hqtop : (⊤ : Subgroup G).map q = ⊤ :=
    Subgroup.map_top_of_surjective q (QuotientGroup.mk'_surjective N)
  have hqHnormal : (H.map q).Normal :=
    (inferInstance : H.Normal).map q (QuotientGroup.mk'_surjective N)
  letI : (H.map q).Normal := hqHnormal
  have hcentral :
      ⁅⁅H.map q, (⊤ : Subgroup (G ⧸ N))⁆,
          (⊤ : Subgroup (G ⧸ N))⁆ = ⊥ := by
    calc
      ⁅⁅H.map q, (⊤ : Subgroup (G ⧸ N))⁆,
          (⊤ : Subgroup (G ⧸ N))⁆ =
          (⁅⁅H, (⊤ : Subgroup G)⁆, (⊤ : Subgroup G)⁆).map q := by
            rw [Subgroup.map_commutator, Subgroup.map_commutator, hqtop]
      _ = N.map q := rfl
      _ = ⊥ := by
        simp [q]
  have himage :
      (⁅subgroupPower H a, (⊤ : Subgroup G)⁆).map q =
        (subgroupPower ⁅H, (⊤ : Subgroup G)⁆ a).map q := by
    rw [Subgroup.map_commutator, hqtop,
      subgroup_power_surjective H a q
        (QuotientGroup.mk'_surjective N),
      subgroup_power_surjective
        ⁅H, (⊤ : Subgroup G)⁆ a q
        (QuotientGroup.mk'_surjective N),
      Subgroup.map_commutator, hqtop]
    exact
      commutator_subgroup_central
        (H.map q) a hcentral
  calc
    ⁅subgroupPower H a, (⊤ : Subgroup G)⁆ ⊔ N =
        N ⊔ ⁅subgroupPower H a, (⊤ : Subgroup G)⁆ := sup_comm _ _
    _ = ((⁅subgroupPower H a, (⊤ : Subgroup G)⁆).map q).comap q :=
      (QuotientGroup.comap_map_mk' N _).symm
    _ = ((subgroupPower ⁅H, (⊤ : Subgroup G)⁆ a).map q).comap q := by
      rw [himage]
    _ = N ⊔ subgroupPower ⁅H, (⊤ : Subgroup G)⁆ a :=
      QuotientGroup.comap_map_mk' N _
    _ = subgroupPower ⁅H, (⊤ : Subgroup G)⁆ a ⊔ N := sup_comm _ _

/-- The relative power-commutator subgroup `L^n[L,G]`. -/
def relativePowerCommutator (L : Subgroup G) (n : ℕ) : Subgroup G :=
  subgroupPower L n ⊔ ⁅L, (⊤ : Subgroup G)⁆

instance relative_commutator_normal
    (L : Subgroup G) [L.Normal] (n : ℕ) :
    (relativePowerCommutator L n).Normal := by
  unfold relativePowerCommutator
  infer_instance

private theorem relative_commutator_swap
    (H : Subgroup G) [H.Normal] (a b : ℕ) :
    relativePowerCommutator
        (subgroupPower H a ⊔ ⁅H, (⊤ : Subgroup G)⁆) b ≤
      relativePowerCommutator
        (subgroupPower H b ⊔ ⁅H, (⊤ : Subgroup G)⁆) a := by
  let C : Subgroup G := ⁅H, (⊤ : Subgroup G)⁆
  let Ha : Subgroup G := subgroupPower H a
  let Hb : Subgroup G := subgroupPower H b
  let La : Subgroup G := Ha ⊔ C
  let Lb : Subgroup G := Hb ⊔ C
  let K : Subgroup G := relativePowerCommutator Lb a
  let q : G →* G ⧸ K := QuotientGroup.mk' K
  haveI : C.Normal := by
    dsimp [C]
    infer_instance
  haveI : Ha.Normal := by
    dsimp [Ha]
    infer_instance
  haveI : Hb.Normal := by
    dsimp [Hb]
    infer_instance
  haveI : La.Normal := by
    dsimp [La]
    infer_instance
  haveI : Lb.Normal := by
    dsimp [Lb]
    infer_instance
  haveI : K.Normal := by
    dsimp [K]
    infer_instance
  have hLb_commute
      {x : G} (hx : x ∈ Lb) (g : G) :
      Commute (q x) (q g) := by
    rw [← commutatorElement_eq_one_iff_commute,
      ← map_commutatorElement]
    apply (QuotientGroup.eq_one_iff _).mpr
    apply (show ⁅Lb, (⊤ : Subgroup G)⁆ ≤ K by
      simp [K, relativePowerCommutator])
    exact Subgroup.commutator_mem_commutator hx trivial
  have hLb_pow
      {x : G} (hx : x ∈ Lb) :
      (q x) ^ a = 1 := by
    rw [← map_pow]
    apply (QuotientGroup.eq_one_iff _).mpr
    apply (show subgroupPower Lb a ≤ K by
      simp [K, relativePowerCommutator])
    exact pow_subgroup_power Lb a hx
  have hC_commute
      {c : G} (hc : c ∈ C) (g : G) :
      Commute (q c) (q g) :=
    hLb_commute ((show C ≤ Lb by simp [Lb]) hc) g
  have hC_pow
      {c : G} (hc : c ∈ C) :
      (q c) ^ b = 1 := by
    dsimp [C] at hc
    rw [Subgroup.commutator_def] at hc
    induction hc using Subgroup.closure_induction with
    | mem c hc =>
        rcases hc with ⟨h, hh, g, _, rfl⟩
        have hbasic :
            ⁅h, g⁆ ∈ C := by
          exact Subgroup.commutator_mem_commutator hh trivial
        calc
          (q ⁅h, g⁆) ^ b =
              ⁅q h, q g⁆ ^ b := by rw [map_commutatorElement]
          _ = ⁅(q h) ^ b, q g⁆ := by
            symm
            apply Submission.element_left_commute
            exact (hC_commute hbasic h).symm
          _ = ⁅q (h ^ b), q g⁆ := by rw [map_pow]
          _ = 1 :=
            (hLb_commute
              ((show Hb ≤ Lb by simp [Lb])
                (pow_subgroup_power H b hh)) g).commutator_eq
    | one => simp
    | mul x y hxC hyC hx hy =>
        rw [map_mul, (hC_commute hxC y).mul_pow b, hx, hy, mul_one]
    | inv x _ hx =>
        rw [map_inv, inv_pow, hx, inv_one]
  have hHa_commute
      {x : G} (hx : x ∈ Ha) (g : G) :
      Commute (q x) (q g) := by
    have heq : Ha = Subgroup.closure (powerGenerators H a) := by
      simpa [Ha] using subgroup_power_closure H a
    rw [heq] at hx
    induction hx using Subgroup.closure_induction with
    | mem x hx =>
        rcases hx with ⟨h, hh, rfl⟩
        rw [← commutatorElement_eq_one_iff_commute]
        have hbasic :
            ⁅h, g⁆ ∈ C :=
          Subgroup.commutator_mem_commutator hh trivial
        calc
          ⁅q (h ^ a), q g⁆ =
              ⁅(q h) ^ a, q g⁆ := by rw [map_pow]
          _ = ⁅q h, q g⁆ ^ a :=
            Submission.element_left_commute
              (hC_commute hbasic h).symm a
          _ = (q ⁅h, g⁆) ^ a := by rw [map_commutatorElement]
          _ = 1 := hLb_pow ((show C ≤ Lb by simp [Lb]) hbasic)
    | one => exact Commute.one_left _
    | mul x y _ _ hx hy =>
        simpa only [map_mul] using hx.mul_left hy
    | inv x _ hx =>
        simpa only [map_inv] using hx.inv_left
  have hHa_pow
      {x : G} (hx : x ∈ Ha) :
      (q x) ^ b = 1 := by
    have heq : Ha = Subgroup.closure (powerGenerators H a) := by
      simpa [Ha] using subgroup_power_closure H a
    rw [heq] at hx
    induction hx using Subgroup.closure_induction with
    | mem x hx =>
        rcases hx with ⟨h, hh, rfl⟩
        calc
          (q (h ^ a)) ^ b = (q h) ^ (a * b) := by
            rw [map_pow, pow_mul]
          _ = (q h) ^ (b * a) := by rw [Nat.mul_comm a b]
          _ = (q (h ^ b)) ^ a := by rw [map_pow, pow_mul]
          _ = 1 :=
            hLb_pow ((show Hb ≤ Lb by simp [Lb])
              (pow_subgroup_power H b hh))
    | one => simp
    | mul x y hxHa hyHa hx hy =>
        have hxHa' : x ∈ Ha := by rwa [heq]
        rw [map_mul, (hHa_commute hxHa' y).mul_pow b, hx, hy, mul_one]
    | inv x _ hx =>
        rw [map_inv, inv_pow, hx, inv_one]
  have hLa_commute
      {x : G} (hx : x ∈ La) (g : G) :
      Commute (q x) (q g) := by
    rcases (Subgroup.mem_sup_of_normal_right.mp hx) with
      ⟨u, hu, c, hc, rfl⟩
    simpa only [map_mul] using
      (hHa_commute hu g).mul_left (hC_commute hc g)
  have hLa_pow
      {x : G} (hx : x ∈ La) :
      (q x) ^ b = 1 := by
    rcases (Subgroup.mem_sup_of_normal_right.mp hx) with
      ⟨u, hu, c, hc, rfl⟩
    rw [map_mul, (hHa_commute hu c).mul_pow b,
      hHa_pow hu, hC_pow hc, mul_one]
  change relativePowerCommutator La b ≤ K
  unfold relativePowerCommutator
  apply sup_le
  · unfold subgroupPower
    apply Subgroup.normalClosure_le_normal
    rintro y ⟨x, hx, rfl⟩
    apply (QuotientGroup.eq_one_iff _).mp
    simpa only [map_pow] using hLa_pow hx
  · rw [Subgroup.commutator_le]
    intro x hx g _
    apply (QuotientGroup.eq_one_iff _).mp
    simpa only [map_commutatorElement] using
      (hLa_commute hx g).commutator_eq

/-- Efrat--Chapman, Lemma 7.2(b). -/
theorem relative_power_swap
    (H : Subgroup G) [H.Normal] (a b : ℕ) :
    relativePowerCommutator
        (subgroupPower H a ⊔ ⁅H, (⊤ : Subgroup G)⁆) b =
      relativePowerCommutator
        (subgroupPower H b ⊔ ⁅H, (⊤ : Subgroup G)⁆) a := by
  apply le_antisymm
  · exact relative_commutator_swap H a b
  · exact relative_commutator_swap H b a

end EChapma
