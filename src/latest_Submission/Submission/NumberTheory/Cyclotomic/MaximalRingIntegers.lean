/-- Every element of `R[u]`, for a unit `u`, has a quadratic normal form over
`R[u + uвЃ»В№]`. -/
theorem adjoin_add_mul
    {R S : Type*} [CommRing R] [CommRing S] [Algebra R S]
    (u : SЛЈ) {x : S} (hx : x в€€ Algebra.adjoin R ({(u : S)} : Set S)) :
    в€ѓ a b : S,
      a в€€ Algebra.adjoin R ({(u : S) + (uвЃ»В№ : SЛЈ)} : Set S) в€§
      b в€€ Algebra.adjoin R ({(u : S) + (uвЃ»В№ : SЛЈ)} : Set S) в€§
      x = a + (u : S) * b := by
  let A : Subalgebra R S := Algebra.adjoin R {(u : S) + (uвЃ»В№ : SЛЈ)}
  have ht : (u : S) + (uвЃ»В№ : SЛЈ) в€€ A := Algebra.self_mem_adjoin_singleton R _
  have hquad : (u : S) ^ 2 = ((u : S) + (uвЃ»В№ : SЛЈ)) * u - 1 := by
    rw [add_mul]
    simp
    ring
  induction hx using Algebra.adjoin_induction with
  | mem y hy =>
      rw [Set.mem_singleton_iff] at hy
      subst y
      exact вџЁ0, 1, A.zero_mem, A.one_mem, by ringвџ©
  | algebraMap r =>
      exact вџЁalgebraMap R S r, 0, A.algebraMap_mem r, A.zero_mem, by ringвџ©
  | add x y _ _ hx hy =>
      obtain вџЁa, b, ha, hb, rflвџ© := hx
      obtain вџЁc, d, hc, hd, rflвџ© := hy
      exact вџЁa + c, b + d, A.add_mem ha hc, A.add_mem hb hd, by ringвџ©
  | mul x y _ _ hx hy =>
      obtain вџЁa, b, ha, hb, rflвџ© := hx
      obtain вџЁc, d, hc, hd, rflвџ© := hy
      refine вџЁa * c - b * d,
        a * d + b * c + ((u : S) + (uвЃ»В№ : SЛЈ)) * (b * d),
        A.sub_mem (A.mul_mem ha hc) (A.mul_mem hb hd),
        A.add_mem (A.add_mem (A.mul_mem ha hd) (A.mul_mem hb hc))
          (A.mul_mem ht (A.mul_mem hb hd)), ?_вџ©
      calc
        (a + (u : S) * b) * (c + (u : S) * d) =
            a * c + (u : S) * (a * d + b * c) + (u : S) ^ 2 * (b * d) := by ring
        _ = a * c - b * d + (u : S) *
            (a * d + b * c + ((u : S) + (uвЃ»В№ : SЛЈ)) * (b * d)) := by
          rw [hquad]
          ring

/-- The rescaled Chebyshev polynomial evaluates at `z + zвЃ»В№` to `z^n + zвЃ»вЃї`. -/
theorem chebyshev_c_inv
    {K : Type*} [Field K] {z : K} (hz : z в‰  0) (n : в„•) :
    (Chebyshev.C K n).eval (z + zвЃ»В№) = z ^ n + (zвЃ»В№) ^ n := by
  induction n using Nat.twoStepInduction with
  | zero => simp; ring
  | one => simp
  | more n hn hn1 =>
      rw [show ((n + 2 : в„•) : в„¤) = (n : в„¤) + 2 by omega, Chebyshev.C_add_two]
      have hn1' :
          (Chebyshev.C K ((n : в„¤) + 1)).eval (z + zвЃ»В№) =
            z ^ (n + 1) + (zвЃ»В№) ^ (n + 1) := by
        simpa using hn1
      simp only [eval_sub, eval_mul, eval_X, hn, hn1']
      have hcrossв‚Ѓ : z * (zвЃ»В№) ^ (n + 1) = (zвЃ»В№) ^ n := by
        rw [pow_succ]
        calc
          z * ((zвЃ»В№) ^ n * zвЃ»В№) = (zвЃ»В№) ^ n * (z * zвЃ»В№) := by ring
          _ = (zвЃ»В№) ^ n := by rw [mul_inv_cancelв‚Ђ hz, mul_one]
      have hcrossв‚‚ : zвЃ»В№ * z ^ (n + 1) = z ^ n := by
        rw [pow_succ]
        calc
          zвЃ»В№ * (z ^ n * z) = z ^ n * (zвЃ»В№ * z) := by ring
          _ = z ^ n := by rw [inv_mul_cancelв‚Ђ hz, mul_one]
      calc
        (z + zвЃ»В№) * (z ^ (n + 1) + (zвЃ»В№) ^ (n + 1)) -
              (z ^ n + (zвЃ»В№) ^ n) =
            z ^ (n + 1) * z + (zвЃ»В№) ^ (n + 1) * zвЃ»В№ +
              (z * (zвЃ»В№) ^ (n + 1) - (zвЃ»В№) ^ n) +
              (zвЃ»В№ * z ^ (n + 1) - z ^ n) := by ring
        _ = z ^ (n + 1) * z + (zвЃ»В№) ^ (n + 1) * zвЃ»В№ := by
          rw [hcrossв‚Ѓ, hcrossв‚‚]
          ring
        _ = z ^ (n + 2) + (zвЃ»В№) ^ (n + 2) := by
          apply congrArgв‚‚ (В· + В·)
          В· rw [show n + 2 = (n + 1) + 1 by omega]
            exact (pow_succ z (n + 1)).symm
          В· rw [show n + 2 = (n + 1) + 1 by omega]
            exact (pow_succ zвЃ»В№ (n + 1)).symm

/-- The induction step in the second solution of Exercise 6-2: every symmetric power of a
nonzero element belongs to the ring generated by `z + zвЃ»В№`. -/
theorem exercise_six_symmetric
    {K : Type*} [Field K] [CharZero K] {z : K} (hz : z в‰  0) (n : в„•) :
    z ^ n + (zвЃ»В№) ^ n в€€ Algebra.adjoin в„¤ ({z + zвЃ»В№} : Set K) := by
  have heval :
      aeval (z + zвЃ»В№) (Chebyshev.C в„¤ n) = z ^ n + (zвЃ»В№) ^ n := by
    rw [Chebyshev.aeval_C]
    exact chebyshev_c_inv hz n
  rw [в†ђ heval]
  exact Polynomial.aeval_mem_adjoin_singleton в„¤ (z + zвЃ»В№)

/-- Exercise 6-2 in fixed-subring form.  For a primitive `n`th root `О¶`,
`n > 2`, the image of the integers of the maximal real subfield inside the
cyclotomic integer ring is exactly the ring generated by `О¶ + О¶вЃ»В№`.

Combined with `maximal_real_subfield`, this is the
claim that the ring of integers of `в„љ(cos (2ПЂ/n))` is
`в„¤[2 cos (2ПЂ/n)]`. -/
theorem exercise_six_adjoin
    {n : в„•} {K : Type*} [Field K] [CharZero K] [NeZero n]
    [IsCyclotomicExtension {n} в„љ K] [NumberField K]
    [NumberField.IsCMField K]
    {О¶ : K} (hО¶ : IsPrimitiveRoot О¶ n) (hn : 2 < n) :
    Set.range (algebraMap (рќ“ћ (NumberField.maximalRealSubfield K)) (рќ“ћ K)) =
      в†‘(Algebra.adjoin в„¤
        ({(CMReal.rootUnit hО¶ : рќ“ћ K) +
          ((CMReal.rootUnit hО¶)вЃ»В№ : (рќ“ћ K)ЛЈ)} : Set (рќ“ћ K))) := by
  let u : (рќ“ћ K)ЛЈ := CMReal.rootUnit hО¶
  let c := NumberField.IsCMField.ringOfIntegersComplexConj K
  let A : Subalgebra в„¤ (рќ“ћ K) :=
    Algebra.adjoin в„¤ ({(u : рќ“ћ K) + (uвЃ»В№ : (рќ“ћ K)ЛЈ)} : Set (рќ“ћ K))
  have hcu : c (u : рќ“ћ K) = (uвЃ»В№ : (рќ“ћ K)ЛЈ) := by
    exact CMReal.ring_integers_complex hО¶
  have hcuinv : c ((uвЃ»В№ : (рќ“ћ K)ЛЈ) : рќ“ћ K) = (u : рќ“ћ K) := by
    apply RingOfIntegers.ext
    simp [c, u, NumberField.IsCMField.coe_ringOfIntegersComplexConj,
      CMReal.rootUnit_coe,
      CMReal.complexConj_zeta hО¶]
  have hgen_fixed : c ((u : рќ“ћ K) + (uвЃ»В№ : (рќ“ћ K)ЛЈ)) =
      (u : рќ“ћ K) + (uвЃ»В№ : (рќ“ћ K)ЛЈ) := by
    rw [map_add, hcu, hcuinv, add_comm]
  have hfixed {x : рќ“ћ K} (hx : x в€€ A) : c x = x := by
    induction hx using Algebra.adjoin_induction with
    | mem y hy =>
        rw [Set.mem_singleton_iff] at hy
        subst y
        exact hgen_fixed
    | algebraMap z => simp [c]
    | add x y _ _ hx hy => simp only [map_add, hx, hy]
    | mul x y _ _ hx hy => simp only [map_mul, hx, hy]
  have hadjoin : Algebra.adjoin в„¤ ({(u : рќ“ћ K)} : Set (рќ“ћ K)) = вЉ¤ := by
    rw [в†ђ hО¶.integralPowerBasis.adjoin_gen_eq_top,
      hО¶.integralPowerBasis_gen, CMReal.rootUnit_coe]
  have hu_ne_inv : (u : рќ“ћ K) в‰  (uвЃ»В№ : (рќ“ћ K)ЛЈ) := by
    intro hu
    have hzeta_inv : О¶ = О¶вЃ»В№ := by
      have hcoe := congrArg (fun x : рќ“ћ K в†¦ (x : K)) hu
      simpa [u, CMReal.rootUnit_coe] using hcoe
    have hzeta_sq : О¶ ^ 2 = 1 := by
      calc
        О¶ ^ 2 = О¶ * О¶ := pow_two О¶
        _ = О¶вЃ»В№ * О¶ := congrArg (fun z в†¦ z * О¶) hzeta_inv
        _ = 1 := inv_mul_cancelв‚Ђ (hО¶.ne_zero (NeZero.ne n))
    have hdiv : n в€Ј 2 := (hО¶.pow_eq_one_iff_dvd 2).mp hzeta_sq
    exact (Nat.not_le_of_gt hn) (Nat.le_of_dvd (by norm_num) hdiv)
  ext x
  change x в€€ Set.range (algebraMap (рќ“ћ (NumberField.maximalRealSubfield K)) (рќ“ћ K)) в†”
    x в€€ A
  constructor
  В· intro hx
    have hcx : c x = x :=
      (NumberField.IsCMField.ringOfIntegersComplexConj_eq_self_iff K x).2 hx
    have hx_top : x в€€ Algebra.adjoin в„¤ ({(u : рќ“ћ K)} : Set (рќ“ћ K)) := by
      rw [hadjoin]
      trivial
    obtain вџЁa, b, ha, hb, habвџ© := adjoin_add_mul u hx_top
    have hca : c a = a := hfixed ha
    have hcb : c b = b := hfixed hb
    have hub : (u : рќ“ћ K) * b = (uвЃ»В№ : (рќ“ћ K)ЛЈ) * b := by
      apply add_left_cancel (a := a)
      calc
        a + (u : рќ“ћ K) * b = x := hab.symm
        _ = c x := hcx.symm
        _ = c (a + (u : рќ“ћ K) * b) := congrArg c hab
        _ = a + (uвЃ»В№ : (рќ“ћ K)ЛЈ) * b := by
          rw [map_add, map_mul, hca, hcb, hcu]
    have hb_zero : b = 0 := by
      have hzero : ((u : рќ“ћ K) - (uвЃ»В№ : (рќ“ћ K)ЛЈ)) * b = 0 := by
        rw [sub_mul, hub, sub_self]
      rcases mul_eq_zero.mp hzero with h | h
      В· exact (sub_ne_zero.mpr hu_ne_inv) h |>.elim
      В· exact h
    rw [hb_zero, mul_zero, add_zero] at hab
    exact hab в–ё ha
  В· intro hx
    exact (NumberField.IsCMField.ringOfIntegersComplexConj_eq_self_iff K x).1
      (hfixed hx)

/-- Exercise 6-2 for a cyclotomic field, with its number-field and CM-field structures
constructed from the cyclotomic hypotheses.  Thus no auxiliary CM-field assumption appears in
the final statement. -/
theorem exercise_six_integers
    {n : в„•} {K : Type*} [Field K] [CharZero K] [NeZero n]
    [IsCyclotomicExtension {n} в„љ K]
    {О¶ : K} (hО¶ : IsPrimitiveRoot О¶ n) (hn : 2 < n) :
    Set.range (algebraMap (рќ“ћ (NumberField.maximalRealSubfield K)) (рќ“ћ K)) =
      в†‘(Algebra.adjoin в„¤
        ({(CMReal.rootUnit hО¶ : рќ“ћ K) +
          ((CMReal.rootUnit hО¶)вЃ»В№ : (рќ“ћ K)ЛЈ)} : Set (рќ“ћ K))) := by
  letI : NumberField K := IsCyclotomicExtension.numberField {n} в„љ K
  letI : NumberField.IsCMField K :=
    IsCyclotomicExtension.Rat.isCMField K вџЁn, Set.mem_singleton n, hnвџ©
  exact exercise_six_adjoin hО¶ hn

