import Mathlib.Algebra.Group.Subgroup.Defs
import Mathlib.Tactic

/-!
# Chapter VIII, Section 5, Proposition 5.12

The source first proves that the power-class group of the cyclotomic local
field is generated by `pi, zeta, eta 2, ..., eta p`, and then characterizes
the Hilbert pairing by three families of identities.  This file isolates that
presentation and proves the asserted uniqueness by the descending
`i+j` argument implicit in the text.
-/

namespace Submission.CField.HRecip

variable {G μ : Type*} [CommGroup G] [CommGroup μ]

/-- A bimultiplicative skew-symmetric pairing.  The explicit diagonal axiom
is included because “skew-symmetric” for the source's odd-order root group
also means alternating. -/
structure SMPairin (G μ : Type*) [CommGroup G] [CommGroup μ] where
  toMonoidHom : G →* (G →* μ)
  swap : ∀ a b, toMonoidHom b a = (toMonoidHom a b)⁻¹
  self : ∀ a, toMonoidHom a a = 1

namespace SMPairin

instance : CoeFun (SMPairin G μ) (fun _ ↦ G → G → μ) where
  coe h := fun a b ↦ h.toMonoidHom a b

@[simp] theorem map_mul_left (h : SMPairin G μ)
    (a b c : G) : h (a * b) c = h a c * h b c :=
  congrArg (fun f : G →* μ ↦ f c) (h.toMonoidHom.map_mul a b)

@[simp] theorem map_mul_right (h : SMPairin G μ)
    (a b c : G) : h a (b * c) = h a b * h a c :=
  (h.toMonoidHom a).map_mul b c

end SMPairin

/-- The generator statement immediately preceding Proposition 5.12.
`eta i` models `1 - pi^i`, and `principalUnits i` models `U_i`.
The extensionality field is precisely the assertion that
`pi, eta 1 (= zeta), eta 2, ..., eta p` generate the power-class group. -/
structure CyclotomicClassPresentation (p : ℕ) (G μ : Type*)
    [CommGroup G] [CommGroup μ] where
  pi : G
  eta : ℕ → G
  principalUnits : ℕ → Subgroup G
  eta_principal_units : ∀ i, 1 ≤ i → eta i ∈ principalUnits i
  pairing_ext : ∀ h₁ h₂ : SMPairin G μ,
    (∀ i j, 1 ≤ i → i ≤ p → 1 ≤ j → j ≤ p →
      h₁ (eta i) (eta j) = h₂ (eta i) (eta j)) →
    (∀ i, 1 ≤ i → i ≤ p → h₁ (eta i) pi = h₂ (eta i) pi) →
    h₁ = h₂

/-- The three displayed conditions (a), (b), and (c) of Proposition 5.12. -/
structure Relations {p : ℕ}
    (P : CyclotomicClassPresentation p G μ) (ζ : μ)
    (h : SMPairin G μ) : Prop where
  recurrence : ∀ i j, 1 ≤ i → 1 ≤ j →
    h (P.eta i) (P.eta j) =
      h (P.eta i) (P.eta (i + j)) *
        h (P.eta (i + j)) (P.eta j) *
          ((h (P.eta (i + j)) P.pi) ^ j)⁻¹
  eta_pi_low : ∀ i, 1 ≤ i → i ≤ p - 1 → h (P.eta i) P.pi = 1
  eta_pi_top : h (P.eta p) P.pi = ζ
  deep_units : ∀ i j (a b : G),
    a ∈ P.principalUnits i → b ∈ P.principalUnits j →
    p + 1 ≤ i + j → h a b = 1

namespace Relations

variable {p : ℕ} (P : CyclotomicClassPresentation p G μ) (ζ : μ)

/-- Clauses (a)--(c) determine all pairings on the generators.  This is the
algebraic uniqueness assertion in Proposition 5.12. -/
theorem unique_of_relations (hp : 1 ≤ p)
    {h₁ h₂ : SMPairin G μ}
    (R₁ : Relations P ζ h₁)
    (R₂ : Relations P ζ h₂) :
    h₁ = h₂ := by
  have hetaPi : ∀ i, 1 ≤ i → i ≤ p →
      h₁ (P.eta i) P.pi = h₂ (P.eta i) P.pi := by
    intro i hi hip
    by_cases hitop : i = p
    · subst i
      rw [R₁.eta_pi_top, R₂.eta_pi_top]
    · have hilow : i ≤ p - 1 := by omega
      rw [R₁.eta_pi_low i hi hilow, R₂.eta_pi_low i hi hilow]
  let Motive : ℕ → Prop := fun d ↦
    ∀ i j, 1 ≤ i → i ≤ p → 1 ≤ j → j ≤ p →
      p + 1 - (i + j) = d →
      h₁ (P.eta i) (P.eta j) = h₂ (P.eta i) (P.eta j)
  have hall : ∀ d, Motive d := by
    intro d
    induction d using Nat.strong_induction_on with
    | h d ih =>
        intro i j hi hip hj hjp hd
        by_cases hdeep : p + 1 ≤ i + j
        · rw [R₁.deep_units i j (P.eta i) (P.eta j)
              (P.eta_principal_units i hi)
              (P.eta_principal_units j hj) hdeep,
            R₂.deep_units i j (P.eta i) (P.eta j)
              (P.eta_principal_units i hi)
              (P.eta_principal_units j hj) hdeep]
        · have hijp : i + j ≤ p := by omega
          have hleftDeficit :
              p + 1 - (i + (i + j)) < d := by omega
          have hrightDeficit :
              p + 1 - ((i + j) + j) < d := by omega
          have hleft :
              h₁ (P.eta i) (P.eta (i + j)) =
                h₂ (P.eta i) (P.eta (i + j)) := by
            apply ih (p + 1 - (i + (i + j))) hleftDeficit
              i (i + j) hi hip (by omega) hijp rfl
          have hright :
              h₁ (P.eta (i + j)) (P.eta j) =
                h₂ (P.eta (i + j)) (P.eta j) := by
            apply ih (p + 1 - ((i + j) + j)) hrightDeficit
              (i + j) j (by omega) hijp hj hjp rfl
          rw [R₁.recurrence i j hi hj, R₂.recurrence i j hi hj,
            hleft, hright, hetaPi (i + j) (by omega) hijp]
  apply P.pairing_ext h₁ h₂
  · intro i j hi hip hj hjp
    exact hall (p + 1 - (i + j)) i j hi hip hj hjp rfl
  · exact hetaPi

end Relations

/-- Once the canonical Hilbert pairing is shown by the explicit local
calculation to satisfy (a)--(c), the uniqueness claimed in Proposition 5.12
is a theorem. -/
theorem of_relations {p : ℕ}
    (P : CyclotomicClassPresentation p G μ) (ζ : μ)
    (hp : 1 ≤ p) (hilbert : SMPairin G μ)
    (hrelations : Relations P ζ hilbert) :
    Relations P ζ hilbert ∧
    ∀ h : SMPairin G μ,
      Relations P ζ h → h = hilbert
  := by
  refine ⟨hrelations, ?_⟩
  intro h hh
  exact Relations.unique_of_relations P ζ hp hh hrelations

end Submission.CField.HRecip
