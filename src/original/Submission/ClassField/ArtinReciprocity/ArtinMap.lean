import Mathlib.Algebra.FreeAbelianGroup.Finsupp
import Submission.NumberTheory.Ideals.IdealNormCompatibility
import Submission.ClassField.RayClassGroups.Frobenius

/-!
# Chapter V, Section 3: the Artin map and norm compatibility

The global Artin map is first defined on the free abelian group generated by
unramified prime ideals.  A generator below is *pointed*: it includes a choice
of a prime upstairs.  In an abelian extension, `eq_under_eq`
proves that the resulting Frobenius element is independent of that choice.

`on_prime` is the prime-generator calculation in Proposition
3.3.  It combines the relative ideal-norm formula
`N(P') = p ^ f(P'/p)` with Statement 1.10, which says that Frobenius over the
intermediate field is the same power of Frobenius over the base.

Mathlib currently does not identify the group of nonzero fractional ideals of
a Dedekind domain with the free abelian group on its height-one primes in a
form compatible with `Ideal.relNorm`.  Consequently the extension of the
prime-generator map to the book's literal groups `I^S`, and hence Corollary
3.4 as a statement about fractional ideals, remains outside this file.
-/

namespace Submission.CField.ARecip

open Submission.NumberTheory.Milne
open IsDedekindDomain
open scoped Pointwise

noncomputable section

/-- A prime of `S`, together with the finiteness and unramifiedness hypotheses
needed to use its arithmetic Frobenius over `R`.

The contraction `P.prime.asIdeal.under R` is the corresponding prime of the
base ring. -/
structure PUPrime (R S : Type*) [CommRing R] [CommRing S]
    [Algebra R S] where
  prime : HeightOneSpectrum S
  finiteQuotient : Finite (S ⧸ prime.asIdeal)
  isUnramified : Algebra.IsUnramifiedAt R prime.asIdeal

namespace PUPrime

variable {R S G : Type*} [CommRing R] [CommRing S] [Algebra R S]

/-- Arithmetic Frobenius attached to a pointed unramified prime. -/
def frobenius [Group G] [Finite G] [MulSemiringAction G S]
    [IsGaloisGroup G R S] (P : PUPrime R S) : G := by
  letI := P.finiteQuotient
  exact arithFrobAt R G P.prime.asIdeal

/-- In an abelian extension, Frobenius depends only on the prime downstairs,
not on the chosen prime above it. -/
theorem eq_under_eq
    [CommGroup G] [Finite G] [MulSemiringAction G S] [IsGaloisGroup G R S]
    [IsDomain S] [IsNoetherianRing S]
    (P Q : PUPrime R S)
    (hPQ : P.prime.asIdeal.under R = Q.prime.asIdeal.under R) :
    frobenius (G := G) P = frobenius (G := G) Q := by
  letI := P.finiteQuotient
  letI := Q.finiteQuotient
  letI : Algebra.IsUnramifiedAt R P.prime.asIdeal := P.isUnramified
  let p := P.prime.asIdeal.under R
  letI : Q.prime.asIdeal.LiesOver p := ⟨hPQ⟩
  obtain ⟨tau, htau⟩ :=
    Ideal.exists_smul_eq_of_isGaloisGroup p P.prime.asIdeal Q.prime.asIdeal G
  letI : Finite (S ⧸ tau • P.prime.asIdeal) := by
    rw [htau]
    exact Q.finiteQuotient
  have hconj := arith_frob_conjugate
    (R := R) (G := G) P.prime.asIdeal tau
  have hconj' : arithFrobAt R G Q.prime.asIdeal =
      tau * arithFrobAt R G P.prime.asIdeal * tau⁻¹ := by
    simpa only [htau] using hconj
  change arithFrobAt R G P.prime.asIdeal = arithFrobAt R G Q.prime.asIdeal
  rw [hconj']
  simp

end PUPrime

/-- The free abelian group of divisors supported on pointed unramified primes. -/
abbrev UnramifiedPrimeDivisors (R S : Type*) [CommRing R] [CommRing S]
    [Algebra R S] :=
  FreeAbelianGroup (PUPrime R S)

/-- The global Artin homomorphism on formal unramified prime divisors.

The additive target `Additive G` records the book's multiplicative product of
Frobenius elements. -/
def artinMap
    {R S G : Type*} [CommRing R] [CommRing S] [Algebra R S]
    [CommGroup G] [Finite G] [MulSemiringAction G S] [IsGaloisGroup G R S] :
    UnramifiedPrimeDivisors R S →+ Additive G :=
  FreeAbelianGroup.lift fun P ↦
    Additive.ofMul (P.frobenius (G := G))

/-- The Artin map sends a prime generator to its arithmetic Frobenius. -/
@[simp]
theorem artinMap_of
    {R S G : Type*} [CommRing R] [CommRing S] [Algebra R S]
    [CommGroup G] [Finite G] [MulSemiringAction G S] [IsGaloisGroup G R S]
    (P : PUPrime R S) :
    artinMap (R := R) (S := S) (G := G) (FreeAbelianGroup.of P) =
      Additive.ofMul (P.frobenius (G := G)) :=
  FreeAbelianGroup.lift_apply_of _ _

/-- The Artin map has the same value on pointed generators lying over the
same base prime. -/
theorem of_under_eq
    {R S G : Type*} [CommRing R] [CommRing S] [Algebra R S]
    [CommGroup G] [Finite G] [MulSemiringAction G S] [IsGaloisGroup G R S]
    [IsDomain S] [IsNoetherianRing S]
    (P Q : PUPrime R S)
    (hPQ : P.prime.asIdeal.under R = Q.prime.asIdeal.under R) :
    artinMap (R := R) (S := S) (G := G) (FreeAbelianGroup.of P) =
      artinMap (R := R) (S := S) (G := G) (FreeAbelianGroup.of Q) := by
  simp only [artinMap_of]
  exact congrArg Additive.ofMul
    (PUPrime.eq_under_eq P Q hPQ)

/-- The prime-generator form of Proposition 3.3.

For `P` above the intermediate prime `P.under T` and base prime `P.under R`,
the two displayed equalities say respectively

* `N_{T/R}(P.under T) = (P.under R) ^ f`, and
* `Frob_{S/R}(P) ^ f = Frob_{S/T}(P)` inside the ambient Galois group.

Thus the ideal norm and the inclusion on Galois groups commute with the Artin
assignments on every prime generator. -/
theorem on_prime
    {R T S G H : Type*}
    [CommRing R] [IsDomain R] [IsIntegrallyClosed R] [IsDedekindDomain R]
    [CommRing T] [IsDomain T] [IsIntegrallyClosed T] [IsDedekindDomain T]
    [Algebra R T] [Module.Finite R T] [Module.IsTorsionFree R T]
    [PerfectField (FractionRing R)]
    [CommRing S] [Algebra R S] [Algebra T S] [IsScalarTower R T S]
    [Group G] [Finite G] [MulSemiringAction G S] [IsGaloisGroup G R S]
    [Group H] [Finite H] [MulSemiringAction H S] [IsGaloisGroup H T S]
    [IsDomain S] [IsNoetherianRing S]
    (P : Ideal S) [P.IsPrime] [Finite (S ⧸ P)]
    [(P.under R).IsMaximal] [(P.under T).IsMaximal]
    [(P.under T).LiesOver (P.under R)]
    [Finite (R ⧸ P.under R)] [Finite (T ⧸ P.under T)]
    [Algebra.IsUnramifiedAt R P]
    (embed : H →* G)
    (embed_smul : ∀ tau : H, ∀ x : S, embed tau • x = tau • x) :
    Ideal.relNorm R (P.under T) =
        (P.under R) ^ (P.under R).inertiaDeg (P.under T) ∧
      arithFrobAt R G P ^ (P.under R).inertiaDeg (P.under T) =
        embed (arithFrobAt T H P) := by
  constructor
  · exact rel_contraction_deg
      R T (P.under T) (P.under R)
  · exact Submission.CField.RCGroups.frobenius_tower_degree
      P embed embed_smul

end

end Submission.CField.ARecip
