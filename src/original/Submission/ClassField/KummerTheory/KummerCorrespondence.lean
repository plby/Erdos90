import Submission.ClassField.KummerTheory.KummerCyclic
import Submission.ClassField.KummerTheory.PowerClasses

/-!
# Chapter VII, Appendix A, Theorem A.3: Kummer correspondence

This file states the full correspondence inside a fixed algebraic closure.
Both sides are concrete: the extensions are actual intermediate fields and
the power-class objects are actual finite subgroups of `Kˣ / Kˣⁿ`.

The proof requires the multiradical Kummer theorem, which is stronger than
Mathlib's current cyclic Kummer API.  The definitions below isolate its exact
content without replacing fields or subgroups by abstract stand-ins.
-/

namespace Submission.CField.KTheory

noncomputable section

universe u

/-- A finite abelian subextension of exponent dividing `n` inside a fixed
algebraic closure. -/
structure AESubext
    (K Ω : Type u) [Field K] [Field Ω] [Algebra K Ω] (n : ℕ) where
  carrier : IntermediateField K Ω
  [finiteDimensional : FiniteDimensional K carrier]
  [isGalois : IsGalois K carrier]
  [isAbelian : IsMulCommutative Gal(carrier/K)]
  exponent_dvd : ∀ σ : Gal(carrier/K), σ ^ n = 1

attribute [instance]
  AESubext.finiteDimensional
  AESubext.isGalois
  AESubext.isAbelian

/-- An actual finite subgroup of the power-class group.  Finiteness is kept
as a proposition so no arbitrary `Fintype` enumeration enters the statement
of the correspondence. -/
structure PCSubgro (K : Type u) [Field K] (n : ℕ) where
  carrier : Subgroup (PowerClassGroup K n)
  finite_carrier : Set.Finite (carrier : Set (PowerClassGroup K n))

namespace PCSubgro

variable {K : Type u} [Field K] {n : ℕ}

/-- The order of a finite power-class subgroup. -/
def card (B : PCSubgro K n) : ℕ :=
  B.finite_carrier.toFinset.card

end PCSubgro

variable (K Ω : Type u) [Field K] [Field Ω] [Algebra K Ω]
  [IsAlgClosure K Ω]

/-- The subgroup of base-field units which become `n`th powers in `L`.
This is the numerator `Kˣ ∩ Lˣⁿ` in Milne's formula. -/
def radicalUnits (n : ℕ) (L : IntermediateField K Ω) : Subgroup Kˣ where
  carrier := {a | ∃ x : Lˣ, x ^ n = Units.map (algebraMap K L) a}
  one_mem' := ⟨1, by simp⟩
  mul_mem' := by
    rintro a b ⟨x, hx⟩ ⟨y, hy⟩
    refine ⟨x * y, ?_⟩
    rw [mul_pow, hx, hy, map_mul]
  inv_mem' := by
    rintro a ⟨x, hx⟩
    refine ⟨x⁻¹, ?_⟩
    rw [inv_pow, hx, map_inv]

/-- The radical power-class subgroup
`(Kˣ ∩ Lˣⁿ) / Kˣⁿ ≤ Kˣ / Kˣⁿ`. -/
def radicalPowerClasses (n : ℕ) (L : IntermediateField K Ω) :
    Subgroup (PowerClassGroup K n) :=
  (radicalUnits K Ω n L).map (powerClass n)

/-- A representative in `Kˣ` of a power class. -/
def powerClassRepresentative (n : ℕ) (b : PowerClassGroup K n) : Kˣ :=
  Quotient.out b

@[simp]
theorem power_class_representative (n : ℕ)
    (b : PowerClassGroup K n) :
    powerClass n (powerClassRepresentative K n b) = b :=
  Quotient.out_eq b

/-- A chosen `n`th root in the fixed algebraic closure of a representative
of `b`. -/
def kummerRoot (n : ℕ) (hn : 0 < n) (b : PowerClassGroup K n) : Ω :=
  by
    letI : IsAlgClosed Ω := IsAlgClosure.isAlgClosed K
    exact Classical.choose
      (IsAlgClosed.exists_pow_nat_eq
        (algebraMap K Ω ((powerClassRepresentative K n b : Kˣ) : K)) hn)

@[simp]
theorem kummerRoot_pow (n : ℕ) (hn : 0 < n)
    (b : PowerClassGroup K n) :
    kummerRoot K Ω n hn b ^ n =
      algebraMap K Ω ((powerClassRepresentative K n b : Kˣ) : K) :=
  by
    letI : IsAlgClosed Ω := IsAlgClosure.isAlgClosed K
    exact Classical.choose_spec
      (IsAlgClosed.exists_pow_nat_eq
        (algebraMap K Ω ((powerClassRepresentative K n b : Kˣ) : K)) hn)

/-- `K[B^(1/n)]`: the subfield generated by one chosen `n`th root of every
power class in `B`. -/
def kummerField (n : ℕ) (hn : 0 < n) (B : PCSubgro K n) :
    IntermediateField K Ω :=
  IntermediateField.adjoin K
    (Set.range fun b : B.carrier ↦ kummerRoot K Ω n hn b.1)

/-- Every selected radical is contained in the radical-generated field. -/
theorem kummer_root_field (n : ℕ) (hn : 0 < n)
    (B : PCSubgro K n) (b : B.carrier) :
    kummerRoot K Ω n hn b.1 ∈ kummerField K Ω n hn B :=
  IntermediateField.subset_adjoin K
    (Set.range fun c : B.carrier ↦ kummerRoot K Ω n hn c.1)
    (Set.mem_range_self b)

/-- Every power class used to generate a Kummer field becomes an `n`th
power in that field.  This is the easy inclusion in the radical
reconstruction assertion of Theorem A.3. -/
theorem radical_classes_kummer (n : ℕ) (hn : 0 < n)
    (B : PCSubgro K n) :
    B.carrier ≤ radicalPowerClasses K Ω n (kummerField K Ω n hn B) := by
  intro b hb
  let bB : B.carrier := ⟨b, hb⟩
  let r : Ω := kummerRoot K Ω n hn b
  have hrmem : r ∈ kummerField K Ω n hn B :=
    kummer_root_field K Ω n hn B bB
  let x0 : kummerField K Ω n hn B := ⟨r, hrmem⟩
  have hrne : r ≠ 0 := by
    have hbase :
        algebraMap K Ω
            ((powerClassRepresentative K n b : Kˣ) : K) ≠ 0 :=
      (map_ne_zero (algebraMap K Ω)).2
        (powerClassRepresentative K n b).ne_zero
    intro hr
    have hr' : kummerRoot K Ω n hn b = 0 := by simpa [r] using hr
    apply hbase
    rw [← kummerRoot_pow K Ω n hn b, hr', zero_pow hn.ne']
  have hx0 : x0 ≠ 0 := by
    intro hx
    apply hrne
    exact congrArg Subtype.val hx
  let x : (kummerField K Ω n hn B)ˣ := Units.mk0 x0 hx0
  refine ⟨powerClassRepresentative K n b, ?_, ?_⟩
  · refine ⟨x, ?_⟩
    apply Units.ext
    change x0 ^ n =
      algebraMap K (kummerField K Ω n hn B)
        ((powerClassRepresentative K n b : Kˣ) : K)
    apply Subtype.ext
    exact kummerRoot_pow K Ω n hn b
  · exact power_class_representative K n b

/-- **Theorem A.3 (full statement).**  If `K` contains a primitive `n`th
root of unity, finite abelian subextensions of exponent dividing `n` in the
fixed algebraic closure correspond bijectively to finite subgroups of
`Kˣ / Kˣⁿ`.  The two maps are the radical subgroup and radical generation,
and corresponding objects have equal degree and order. -/
def KummerCorrespondence (n : ℕ) : Prop :=
  ∀ hn : 0 < n, (primitiveRoots n K).Nonempty →
    ∃ e : AESubext K Ω n ≃
        PCSubgro K n,
      (∀ L, (e L).carrier = radicalPowerClasses K Ω n L.carrier) ∧
      (∀ B, (e.symm B).carrier = kummerField K Ω n hn B) ∧
      (∀ L, Module.finrank K L.carrier = (e L).card)

/-- The cubic reconstruction statement supplied by Theorem A.3.  It is
deliberately a specialization over a field already containing a primitive
cube root of unity; descent from `K(ζ₃)` to a smaller field is additional
Galois-descent data, not part of Kummer correspondence itself. -/
def CubicKummerReconstruction : Prop :=
  (primitiveRoots 3 K).Nonempty →
    ∀ B : PCSubgro K 3,
      ∃ L : AESubext K Ω 3,
        L.carrier = kummerField K Ω 3 (by norm_num) B ∧
        radicalPowerClasses K Ω 3 L.carrier = B.carrier ∧
        Module.finrank K L.carrier = B.card

/-- The full Kummer correspondence immediately supplies its cubic
specialization. -/
theorem implies_kummer_reconstruction
    (h : KummerCorrespondence K Ω 3) :
    CubicKummerReconstruction K Ω := by
  intro hζ B
  obtain ⟨e, hradical, hfield, hdegree⟩ := h (by norm_num) hζ
  refine ⟨e.symm B, hfield B, ?_, ?_⟩
  · rw [← hradical (e.symm B), e.apply_symm_apply]
  · rw [hdegree, e.apply_symm_apply]

end

end Submission.CField.KTheory
