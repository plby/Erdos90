import Mathlib.FieldTheory.KummerExtension

/-!
# Chapter VII, Appendix A: cyclic Kummer extensions

Proposition A.1 is already present in Mathlib in a slightly more invariant
form.  Instead of choosing a presentation `L = K[alpha]`, it says that the
simple generator `alpha` generates the top intermediate field.  The exponent
is the degree `finrank K L`, exactly as in the source.

Proposition A.2 requires further comparison of cyclic radical presentations.
The full statement of Theorem A.3, using actual intermediate fields in a fixed
algebraic closure, is recorded in `KummerCorrespondence.lean`; its proof needs
multiradical Kummer theory beyond Mathlib's current cyclic API.
-/

namespace Submission.CField.KTheory

open Module Polynomial

noncomputable section

variable (K L : Type*) [Field K] [Field L] [Algebra K L] [FiniteDimensional K L]

/-- **Proposition A.1.** Over a field containing a primitive root of unity of
order `[L : K]`, a finite extension is cyclic Galois if and only if it is
generated by an element whose `[L : K]`th power lies in the base field.

The middle member is the equivalent splitting-field presentation by an
irreducible polynomial `X ^ [L : K] - a`. -/
theorem kummer_cyclic_tfae
    (hK : (primitiveRoots (finrank K L) K).Nonempty) :
    List.TFAE [
      IsGalois K L ∧ IsCyclic Gal(L/K),
      ∃ a : K, Irreducible (X ^ (finrank K L) - C a) ∧
        IsSplittingField K L (X ^ (finrank K L) - C a),
      ∃ alpha : L, alpha ^ (finrank K L) ∈ Set.range (algebraMap K L) ∧
        IntermediateField.adjoin K {alpha} = ⊤] :=
  isCyclic_tfae K L hK

/-- The converse direction of Proposition A.1: a cyclic Galois extension has
a radical generator. -/
theorem exists_radical_generator
    (hK : (primitiveRoots (finrank K L) K).Nonempty)
    [IsGalois K L] [IsCyclic Gal(L/K)] :
    ∃ alpha : L, alpha ^ (finrank K L) ∈ Set.range (algebraMap K L) ∧
      IntermediateField.adjoin K {alpha} = ⊤ :=
  exists_root_adjoin_eq_top_of_isCyclic K L hK

/-- The forward direction of Proposition A.1, expressed with an explicit
radical generator and the degree of the extension. -/
theorem radical_generator_cyclic
    (hK : (primitiveRoots (finrank K L) K).Nonempty)
    {a : K} {alpha : L}
    (ha : alpha ^ (finrank K L) = algebraMap K L a)
    (halpha : IntermediateField.adjoin K {alpha} = ⊤) :
    IsGalois K L ∧ IsCyclic Gal(L/K) := by
  letI : NeZero (finrank K L) := NeZero.of_pos finrank_pos
  have hirr : Irreducible (X ^ (finrank K L) - C a) :=
    irreducible_X_pow_sub_C_of_root_adjoin_eq_top ha halpha
  letI : IsSplittingField K L (X ^ (finrank K L) - C a) :=
    isSplittingField_X_pow_sub_C_of_root_adjoin_eq_top hK ha halpha
  exact ⟨isGalois_of_isSplittingField_X_pow_sub_C hK hirr L,
    isCyclic_of_isSplittingField_X_pow_sub_C hK hirr L⟩

end

end Submission.CField.KTheory
