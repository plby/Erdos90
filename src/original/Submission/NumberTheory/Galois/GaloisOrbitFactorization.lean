import Mathlib.FieldTheory.Finite.GaloisField
import Mathlib.FieldTheory.Minpoly.IsConjRoot
import Mathlib.FieldTheory.Normal.Basic

/-!
# Milne, Chapter 8, Proposition 8.21 and Corollary 8.22

The irreducible factors of a separable polynomial correspond to the orbits of
its Galois group on its roots.  Over a finite field the Galois group is
generated by Frobenius, so these orbits are precisely the cycles of Frobenius.

The statements below record this correspondence rootwise.  This avoids choosing
an ordering of the irreducible factors or of the orbits: the orbit of a root is
literally the root set of its minimal polynomial, and its cardinality is the
degree of that irreducible factor.
-/

namespace Submission.NumberTheory.Milne

open Module Polynomial

noncomputable section

variable {K L : Type*} [Field K] [Field L] [Algebra K L]

/-- Milne, Proposition 8.21: in a finite Galois extension, the orbit of an
element is exactly the set of roots of its minimal polynomial. -/
theorem galois_minpoly_set [FiniteDimensional K L] [Normal K L]
    (x : L) :
    MulAction.orbit Gal(L/K) x = (minpoly K x).rootSet L := by
  ext y
  constructor
  · intro hy
    have hmin : minpoly K y = minpoly K x :=
      (Normal.minpoly_eq_iff_mem_orbit (F := K) (E := L)).2 hy
    exact (isConjRoot_iff_mem_minpoly_rootSet
      (Algebra.IsIntegral.isIntegral x)).1 hmin.symm
  · intro hy
    have hmin : minpoly K x = minpoly K y :=
      (isConjRoot_iff_mem_minpoly_rootSet
        (Algebra.IsIntegral.isIntegral x)).2 hy
    exact (Normal.minpoly_eq_iff_mem_orbit (F := K) (E := L)).1 hmin.symm

/-- The size of a Galois orbit is the degree of the corresponding irreducible
factor.  This is the degree assertion in Proposition 8.21. -/
theorem card_galois_minpoly [FiniteDimensional K L]
    [Normal K L] [Algebra.IsSeparable K L] (x : L) :
    Set.ncard (MulAction.orbit Gal(L/K) x) = (minpoly K x).natDegree := by
  rw [galois_minpoly_set (K := K) x]
  rw [← Nat.card_coe_set_eq, Nat.card_eq_fintype_card]
  exact
    card_rootSet_eq_natDegree (Algebra.IsSeparable.isSeparable K x)
      (Normal.splits (inferInstance : Normal K L) x)

/-- A root of `f` determines an irreducible factor of `f`; its degree is the
size of the root's Galois orbit. -/
theorem irreducible_galois_orbit [FiniteDimensional K L]
    [Normal K L] [Algebra.IsSeparable K L] {f : K[X]} {x : L}
    (hx : x ∈ f.rootSet L) :
    Irreducible (minpoly K x) ∧ minpoly K x ∣ f ∧
      (minpoly K x).natDegree = Set.ncard (MulAction.orbit Gal(L/K) x) := by
  refine ⟨minpoly.irreducible (Algebra.IsIntegral.isIntegral x),
    minpoly.dvd K x (mem_rootSet.mp hx).2, ?_⟩
  exact (card_galois_minpoly (K := K) x).symm

/-- The Galois orbit of a root of `f` stays inside the root set of `f`, so the
orbits above are genuinely the orbits of the permutation action on the roots. -/
theorem galois_subset_set {f : K[X]} {x : L}
    (hx : x ∈ f.rootSet L) :
    MulAction.orbit Gal(L/K) x ⊆ f.rootSet L := by
  rintro y ⟨g, rfl⟩
  simpa only [AlgEquiv.smul_def] using
    (rootSet_mapsTo (p := f) g.toAlgHom hx)

/-- Two roots determine the same irreducible factor exactly when they lie in
the same Galois orbit. -/
theorem same_irreducible_orbit [FiniteDimensional K L]
    [Normal K L] (x y : L) :
    minpoly K x = minpoly K y ↔ y ∈ MulAction.orbit Gal(L/K) x := by
  simpa only [eq_comm] using
    (Normal.minpoly_eq_iff_mem_orbit (F := K) (E := L)
      (x := y) (y := x))

/-- The set of Galois orbits on the roots of `f` in `L`. -/
abbrev GaloisRootOrbits (f : K[X]) :=
  MulAction.orbitRel.Quotient Gal(L/K) (f.rootSet L)

noncomputable instance galoisOrbitsFintype (f : K[X]) :
    Fintype (GaloisRootOrbits (L := L) f) :=
  Fintype.ofFinite (GaloisRootOrbits (L := L) f)

noncomputable instance galoisOrbitFintype (f : K[X])
    (q : GaloisRootOrbits (L := L) f) : Fintype q.orbit :=
  Fintype.ofFinite q.orbit

/-- The irreducible factor attached to an orbit of roots. -/
def galoisOrbitFactor (f : K[X]) (q : GaloisRootOrbits (L := L) f) : K[X] :=
  minpoly K (q.out : f.rootSet L).1

theorem galois_orbit_irreducible [FiniteDimensional K L]
    (f : K[X]) (q : GaloisRootOrbits (L := L) f) :
    Irreducible (galoisOrbitFactor (K := K) (L := L) f q) :=
  minpoly.irreducible (Algebra.IsIntegral.isIntegral (q.out : f.rootSet L).1)

theorem galois_orbit_monic [FiniteDimensional K L]
    (f : K[X]) (q : GaloisRootOrbits (L := L) f) :
    (galoisOrbitFactor (K := K) (L := L) f q).Monic :=
  minpoly.monic (Algebra.IsIntegral.isIntegral (q.out : f.rootSet L).1)

theorem galois_orbit_dvd [FiniteDimensional K L]
    (f : K[X]) (q : GaloisRootOrbits (L := L) f) :
    galoisOrbitFactor (K := K) (L := L) f q ∣ f := by
  exact minpoly.dvd K (q.out : f.rootSet L).1 (mem_rootSet.mp q.out.2).2

theorem galois_orbit_injective [FiniteDimensional K L] [Normal K L]
    (f : K[X]) :
    Function.Injective (galoisOrbitFactor (K := K) (L := L) f) := by
  intro q r hqr
  rw [← Quotient.out_eq' q, ← Quotient.out_eq' r, Quotient.eq'',
    MulAction.orbitRel_apply]
  have hxy : ((q.out : f.rootSet L) : L) ∈
      MulAction.orbit Gal(L/K) ((r.out : f.rootSet L) : L) :=
    (same_irreducible_orbit (K := K)
      ((r.out : f.rootSet L) : L) ((q.out : f.rootSet L) : L)).mp hqr.symm
  obtain ⟨g, hg⟩ := MulAction.mem_orbit_iff.mp hxy
  exact ⟨g, Subtype.ext hg⟩

theorem card_degree_factor [FiniteDimensional K L]
    [Normal K L] [Algebra.IsSeparable K L]
    (f : K[X]) (q : GaloisRootOrbits (L := L) f) :
    Nat.card q.orbit =
      (galoisOrbitFactor (K := K) (L := L) f q).natDegree := by
  change Nat.card q.orbit =
    (minpoly K ((q.out : f.rootSet L) : L)).natDegree
  rw [← card_galois_minpoly (K := K)
    ((q.out : f.rootSet L) : L)]
  rw [Nat.card_coe_set_eq]
  have himage :
      (fun z : f.rootSet L => (z : L)) '' q.orbit =
        MulAction.orbit Gal(L/K) ((q.out : f.rootSet L) : L) := by
    rw [MulAction.orbitRel.Quotient.orbit_eq_orbit_out q Quotient.out_eq']
    ext y
    constructor
    · rintro ⟨z, ⟨g, hg⟩, rfl⟩
      exact ⟨g, congrArg Subtype.val hg⟩
    · rintro ⟨g, hg⟩
      refine ⟨g • (q.out : f.rootSet L), ⟨g, rfl⟩, ?_⟩
      exact congrArg id hg
  rw [← himage, Set.ncard_image_of_injective _ Subtype.val_injective]

/-- Milne, Proposition 8.21, with the irreducible factors indexed by the
Galois orbits on the roots of `f`. -/
theorem prod_galois_factor [FiniteDimensional K L] [Normal K L]
    [Algebra.IsSeparable K L]
    (f : K[X]) (hmonic : f.Monic) (hsep : f.Separable)
    (hsplits : (f.map (algebraMap K L)).Splits) :
    ∏ q : GaloisRootOrbits (L := L) f,
      galoisOrbitFactor (K := K) (L := L) f q = f := by
  classical
  let fac := galoisOrbitFactor (K := K) (L := L) f
  have hirr : ∀ q, Irreducible (fac q) :=
    galois_orbit_irreducible f
  have hfacmonic : ∀ q, (fac q).Monic :=
    galois_orbit_monic f
  have hinj : Function.Injective fac :=
    galois_orbit_injective f
  have hcop : Pairwise fun q r => IsCoprime (fac q) (fac r) := by
    intro q r hqr
    rw [(hirr q).coprime_iff_not_dvd]
    intro hdvd
    have hassoc : Associated (fac q) (fac r) :=
      (hirr q).associated_of_dvd (hirr r) hdvd
    exact hqr (hinj (eq_of_monic_of_associated
      (hfacmonic q) (hfacmonic r) hassoc))
  have hdvd : (∏ q, fac q) ∣ f :=
    Fintype.prod_dvd_of_coprime hcop (galois_orbit_dvd f)
  have hdegree : f.natDegree ≤ (∏ q, fac q).natDegree := by
    rw [natDegree_prod_of_monic Finset.univ fac (fun q _ => hfacmonic q)]
    rw [show ∑ q, (fac q).natDegree =
        ∑ q : GaloisRootOrbits (L := L) f, Fintype.card q.orbit by
      apply Finset.sum_congr rfl
      intro q _
      rw [← Nat.card_eq_fintype_card]
      exact (card_degree_factor f q).symm]
    rw [← Fintype.card_sigma]
    rw [← Fintype.card_congr
      (MulAction.selfEquivSigmaOrbits' Gal(L/K) (f.rootSet L))]
    simpa only [Fintype.card_coe] using
      (card_rootSet_eq_natDegree hsep hsplits).ge
  exact (eq_of_monic_of_dvd_of_natDegree_le
    (monic_prod_of_monic Finset.univ fac fun q _ => hfacmonic q)
    hmonic hdvd hdegree).symm

/-- Milne, Proposition 8.21 in bundled form: the Galois orbits index a
factorization of `f` into monic irreducibles, and the degree of each factor is
the size of the corresponding orbit. -/
theorem galois_orbit_factorization [FiniteDimensional K L] [Normal K L]
    [Algebra.IsSeparable K L]
    (f : K[X]) (hmonic : f.Monic) (hsep : f.Separable)
    (hsplits : (f.map (algebraMap K L)).Splits) :
    ∃ g : GaloisRootOrbits (L := L) f → K[X],
      f = ∏ q, g q ∧
      (∀ q, Irreducible (g q)) ∧
      (∀ q, (g q).Monic) ∧
      (∀ q, g q ∣ f) ∧
      (∀ q, (g q).natDegree = Fintype.card q.orbit) := by
  refine ⟨galoisOrbitFactor (K := K) (L := L) f,
    (prod_galois_factor f hmonic hsep hsplits).symm,
    galois_orbit_irreducible f, galois_orbit_monic f,
    galois_orbit_dvd f, ?_⟩
  intro q
  rw [← Nat.card_eq_fintype_card]
  exact (card_degree_factor f q).symm

section FiniteField

variable (k l : Type*) [Field k] [Field l] [Fintype k] [Finite l]
  [Algebra k l]

/-- The cycle of `x` under arithmetic Frobenius, represented using one full
period of powers of Frobenius. -/
def frobeniusCycle (x : l) : Set l :=
  Set.range fun n : Fin (finrank k l) =>
    (FiniteField.frobeniusAlgEquivOfAlgebraic k l ^ n.1) x

/-- Over a finite field, the Frobenius cycle of an element is its full Galois
orbit. -/
theorem frobenius_cycle_orbit (x : l) :
    frobeniusCycle k l x = MulAction.orbit Gal(l/k) x := by
  ext y
  constructor
  · rintro ⟨n, rfl⟩
    exact MulAction.mem_orbit x
      (FiniteField.frobeniusAlgEquivOfAlgebraic k l ^ n.1)
  · intro hy
    obtain ⟨g, rfl⟩ := MulAction.mem_orbit_iff.mp hy
    obtain ⟨n, hn⟩ :=
      (FiniteField.bijective_frobeniusAlgEquivOfAlgebraic_pow k l).2 g
    refine ⟨n, ?_⟩
    simp only [AlgEquiv.smul_def, hn]

/-- Milne, Corollary 8.22: the length of the Frobenius cycle through a root is
the degree of its irreducible factor. -/
theorem frobenius_cycle_minpoly (x : l) :
    Set.ncard (frobeniusCycle k l x) = (minpoly k x).natDegree := by
  rw [frobenius_cycle_orbit]
  exact card_galois_minpoly (K := k) x

/-- Rootwise factor-cycle correspondence over finite fields: a root gives an
irreducible factor of `f`, and the factor degree is its Frobenius cycle length. -/
theorem irreducible_frobenius_cycle {f : k[X]} {x : l}
    (hx : x ∈ f.rootSet l) :
    Irreducible (minpoly k x) ∧ minpoly k x ∣ f ∧
      (minpoly k x).natDegree = Set.ncard (frobeniusCycle k l x) := by
  refine ⟨minpoly.irreducible (Algebra.IsIntegral.isIntegral x),
    minpoly.dvd k x (mem_rootSet.mp hx).2, ?_⟩
  exact (frobenius_cycle_minpoly k l x).symm

/-- A Frobenius cycle through a root of `f` consists entirely of roots of
`f`. -/
theorem frobenius_cycle_set {f : k[X]} {x : l}
    (hx : x ∈ f.rootSet l) :
    frobeniusCycle k l x ⊆ f.rootSet l := by
  rw [frobenius_cycle_orbit]
  exact galois_subset_set hx

/-- Two roots lie in the same Frobenius cycle exactly when they determine the
same irreducible factor. -/
theorem same_irreducible_cycle (x y : l) :
    minpoly k x = minpoly k y ↔ y ∈ frobeniusCycle k l x := by
  rw [frobenius_cycle_orbit]
  exact same_irreducible_orbit (K := k) x y

/-- A specified monic irreducible factor that splits in `l` supplies one
Frobenius cycle, whose length is exactly the degree of that factor. -/
theorem frobenius_cycle_irreducible {g : k[X]}
    (hirr : Irreducible g) (hmonic : g.Monic)
    (hsplits : (g.map (algebraMap k l)).Splits) :
    ∃ x : l, x ∈ g.rootSet l ∧ minpoly k x = g ∧
      Set.ncard (frobeniusCycle k l x) = g.natDegree := by
  have hdegree : (g.map (algebraMap k l)).degree ≠ 0 := by
    rw [degree_map_eq_of_injective (algebraMap k l).injective]
    exact (degree_pos_of_irreducible hirr).ne'
  obtain ⟨x, hx⟩ :=
    hsplits.exists_eval_eq_zero hdegree
  have hxroot : x ∈ g.rootSet l := by
    rw [hmonic.mem_rootSet]
    simpa only [aeval_def, eval_map] using hx
  have hmin : minpoly k x = g := by
    exact (minpoly.eq_of_irreducible_of_monic hirr
      (mem_rootSet.mp hxroot).2 hmonic).symm
  refine ⟨x, hxroot, hmin, ?_⟩
  rw [frobenius_cycle_minpoly, hmin]

/-- Milne, Corollary 8.22 with the irreducible factors explicitly indexed:
distinct monic irreducible factors give pairwise disjoint Frobenius cycles,
and each cycle length is the degree of its factor. -/
theorem pairwise_disjoint_cycles
    {ι : Type*} [Finite ι] (g : ι → k[X])
    (hirr : ∀ i, Irreducible (g i)) (hmonic : ∀ i, (g i).Monic)
    (hsplits : ∀ i, ((g i).map (algebraMap k l)).Splits)
    (hinj : Function.Injective g) :
    ∃ x : ι → l,
      (∀ i, x i ∈ (g i).rootSet l ∧ minpoly k (x i) = g i ∧
        Set.ncard (frobeniusCycle k l (x i)) = (g i).natDegree) ∧
      Pairwise fun i j => Disjoint
        (frobeniusCycle k l (x i)) (frobeniusCycle k l (x j)) := by
  classical
  choose x hxroot hmin hcard using fun i =>
    frobenius_cycle_irreducible k l
      (hirr i) (hmonic i) (hsplits i)
  refine ⟨x, fun i => ⟨hxroot i, hmin i, hcard i⟩, ?_⟩
  intro i j hij
  rw [Set.disjoint_left]
  intro z hzi hzj
  have hi : minpoly k (x i) = minpoly k z :=
    (same_irreducible_cycle k l (x i) z).mpr hzi
  have hj : minpoly k (x j) = minpoly k z :=
    (same_irreducible_cycle k l (x j) z).mpr hzj
  apply hij
  apply hinj
  rw [← hmin i, ← hmin j, hi, hj]

end FiniteField

end

end Submission.NumberTheory.Milne
