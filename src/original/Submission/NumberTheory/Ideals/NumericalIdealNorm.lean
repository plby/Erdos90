import Mathlib.NumberTheory.NumberField.FractionalIdeal
import Mathlib.RingTheory.Ideal.Norm.RelNorm

/-!
# Milne, Proposition 4.2: numerical ideal norms

For the ring of integers of a number field, the relative ideal norm to `ℤ` is generated by
the cardinality of the corresponding quotient.  We also identify the relative index of two
nonzero fractional ideals with the norm of their quotient.
-/

open Module
open scoped nonZeroDivisors NumberField

namespace Submission.NumberTheory.Milne

variable (K : Type*) [Field K] [NumberField K]

/-- Milne, Proposition 4.2(a): the ideal norm to `ℤ` is the principal ideal generated by the
numerical norm. -/
theorem relative_int_abs (a : Ideal (𝓞 K)) :
    Ideal.relNorm ℤ a = Ideal.span {(Ideal.absNorm a : ℤ)} :=
  Ideal.relNorm_int (S := 𝓞 K) a

/-- Milne, Proposition 4.2(a): numerical ideal norm is multiplicative. -/
theorem absNorm_mul (a b : Ideal (𝓞 K)) :
    Ideal.absNorm (a * b) = Ideal.absNorm a * Ideal.absNorm b := by
  exact map_mul Ideal.absNorm a b

/-- The additive-lattice index of `b` in `a`, for fractional ideals `b ≤ a`. -/
noncomputable def fractionalIdealIndex
    (a b : FractionalIdeal (𝓞 K)⁰ K) : ℕ :=
  b.coeToSubmodule.toAddSubgroup.relIndex a.coeToSubmodule.toAddSubgroup

/-- Milne, Proposition 4.2(b): if `b ≤ a` are nonzero fractional ideals, their lattice index is
the absolute norm of `a⁻¹ b`. -/
theorem fractional_abs_inv
    (a b : FractionalIdeal (𝓞 K)⁰ K) (ha : a ≠ 0) (hb : b ≠ 0) (hba : b ≤ a) :
    (fractionalIdealIndex K a b : ℚ) = FractionalIdeal.absNorm (a⁻¹ * b) := by
  let A : (FractionalIdeal (𝓞 K)⁰ K)ˣ := Units.mk0 a ha
  let B : (FractionalIdeal (𝓞 K)⁰ K)ˣ := Units.mk0 b hb
  let eA : Free.ChooseBasisIndex ℤ (𝓞 K) ≃ Free.ChooseBasisIndex ℤ A := by
    refine Fintype.equivOfCardEq ?_
    rw [← finrank_eq_card_chooseBasisIndex, ← finrank_eq_card_chooseBasisIndex,
      NumberField.fractionalIdeal_rank K A]
  let eB : Free.ChooseBasisIndex ℤ (𝓞 K) ≃ Free.ChooseBasisIndex ℤ B := by
    refine Fintype.equivOfCardEq ?_
    rw [← finrank_eq_card_chooseBasisIndex, ← finrank_eq_card_chooseBasisIndex,
      NumberField.fractionalIdeal_rank K B]
  let ba : Basis (Free.ChooseBasisIndex ℤ (𝓞 K)) ℚ K :=
    (NumberField.basisOfFractionalIdeal K A).reindex eA.symm
  let bb : Basis (Free.ChooseBasisIndex ℤ (𝓞 K)) ℚ K :=
    (NumberField.basisOfFractionalIdeal K B).reindex eB.symm
  have hspan_a :
      a.coeToSubmodule.toAddSubgroup = AddSubgroup.closure (Set.range ba) := by
    apply AddSubgroup.toIntSubmodule.injective
    rw [AddSubgroup.toIntSubmodule_closure, Submodule.toIntSubmodule_toAddSubgroup]
    ext x
    simpa [A, ba] using
      (NumberField.mem_span_basisOfFractionalIdeal (K := K) (I := A) (x := x)).symm
  have hspan_b :
      b.coeToSubmodule.toAddSubgroup = AddSubgroup.closure (Set.range bb) := by
    apply AddSubgroup.toIntSubmodule.injective
    rw [AddSubgroup.toIntSubmodule_closure, Submodule.toIntSubmodule_toAddSubgroup]
    ext x
    simpa [B, bb] using
      (NumberField.mem_span_basisOfFractionalIdeal (K := K) (I := B) (x := x)).symm
  have hindex :
      (fractionalIdealIndex K a b : ℚ) = |ba.det bb| := by
    exact_mod_cast AddSubgroup.relIndex_eq_abs_det
      b.coeToSubmodule.toAddSubgroup a.coeToSubmodule.toAddSubgroup
      (by simpa [Submodule.toAddSubgroup_le] using hba) bb ba hspan_b hspan_a
  have hnorm_a : |(NumberField.integralBasis K).det ba| = FractionalIdeal.absNorm a := by
    simpa [A, ba] using NumberField.det_basisOfFractionalIdeal_eq_absNorm K A eA
  have hnorm_b : |(NumberField.integralBasis K).det bb| = FractionalIdeal.absNorm b := by
    simpa [B, bb] using NumberField.det_basisOfFractionalIdeal_eq_absNorm K B eB
  have hdet :
      FractionalIdeal.absNorm a * |ba.det bb| = FractionalIdeal.absNorm b := by
    rw [← hnorm_a, ← hnorm_b, ← abs_mul, Basis.det_mul_det]
  rw [hindex, map_mul, map_inv₀]
  exact (eq_inv_mul_iff_mul_eq₀ (FractionalIdeal.absNorm_eq_zero_iff.not.mpr ha)).2 hdet

end Submission.NumberTheory.Milne
