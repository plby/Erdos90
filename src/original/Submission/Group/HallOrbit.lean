import Submission.Group.LowerCentralStrong
import Mathlib.Data.Nat.Choose.Sum

open scoped BigOperators commutatorElement

namespace Submission

/-- The subgroup generated by the iterated commutators
`c`, `[x,c]`, `[x,[x,c]]`, and so on. -/
def lIClos
    {G : Type*} [Group G]
    (x c : G) :
    Subgroup G :=
  Subgroup.closure (Set.range (leftIteratedElement x c))

/-- Every iterated commutator belongs to the subgroup that they generate. -/
lemma iterated_element_closure
    {G : Type*} [Group G]
    (x c : G)
    (n : ℕ) :
    leftIteratedElement x c n ∈
      lIClos x c :=
  Subgroup.subset_closure ⟨n, rfl⟩

namespace lIClos

/-- If the iterated commutators commute pairwise, their generated subgroup is a commutative
group. -/
@[reducible]
noncomputable def commPairwiseCommute
    {G : Type*} [Group G]
    (x c : G)
    (hcomm :
      ∀ r s : ℕ,
        Commute
          (leftIteratedElement x c r)
          (leftIteratedElement x c s)) :
    CommGroup (lIClos x c) :=
  letI : IsMulCommutative (lIClos x c) :=
    Subgroup.isMulCommutative_closure (by
    intro y hy z hz
    rcases hy with ⟨r, rfl⟩
    rcases hz with ⟨s, rfl⟩
    exact (hcomm r s).eq)
  { (inferInstance : Group (lIClos x c)) with
    mul_comm := mul_comm' }

/-- Conjugation by `x` preserves the subgroup generated by the iterated commutators with
left input `x`. -/
lemma conj_mem
    {G : Type*} [Group G]
    (x c : G)
    {z : G}
    (hz : z ∈ lIClos x c) :
    x * z * x⁻¹ ∈ lIClos x c := by
  induction hz using Subgroup.closure_induction with
  | mem z hz =>
      rcases hz with ⟨n, rfl⟩
      rw [conjugate_iterated_element]
      exact
        (lIClos x c).mul_mem
          (iterated_element_closure x c (n + 1))
          (iterated_element_closure x c n)
  | one =>
      simp
  | mul y z _hy _hz ihy ihz =>
      rw [show x * (y * z) * x⁻¹ =
          (x * y * x⁻¹) * (x * z * x⁻¹) by group]
      exact (lIClos x c).mul_mem ihy ihz
  | inv z _hz ih =>
      rw [show x * z⁻¹ * x⁻¹ = (x * z * x⁻¹)⁻¹ by group]
      exact (lIClos x c).inv_mem ih

/-- Conjugation by `x`, restricted to the subgroup generated by its iterated commutators. -/
noncomputable def conjMonoidHom
    {G : Type*} [Group G]
    (x c : G) :
    lIClos x c →*
      lIClos x c where
  toFun z := ⟨x * z * x⁻¹, conj_mem x c z.property⟩
  map_one' := by
    ext
    simp
  map_mul' y z := by
    ext
    simp only [Subgroup.coe_mul]
    group

@[simp]
lemma coe_monoid_hom
    {G : Type*} [Group G]
    (x c : G)
    (z : lIClos x c) :
    (conjMonoidHom x c z : G) = x * z * x⁻¹ :=
  rfl

end lIClos

/-- An iterated commutator, regarded as an element of the subgroup generated by all such
commutators. -/
def iteratedClosureGenerator
    {G : Type*} [Group G]
    (x c : G)
    (n : ℕ) :
    lIClos x c :=
  ⟨leftIteratedElement x c n,
    iterated_element_closure x c n⟩

@[simp]
lemma coe_iterated_generator
    {G : Type*} [Group G]
    (x c : G)
    (n : ℕ) :
    (iteratedClosureGenerator x c n : G) =
      leftIteratedElement x c n :=
  rfl

@[simp]
lemma iterated_monoid_generator
    {G : Type*} [Group G]
    (x c : G)
    (n : ℕ) :
    lIClos.conjMonoidHom x c
        (iteratedClosureGenerator x c n) =
      iteratedClosureGenerator x c (n + 1) *
        iteratedClosureGenerator x c n := by
  apply Subtype.ext
  exact conjugate_iterated_element x c n

/-- Pascal recursion for a product of binomially weighted commuting factors.

This is kept local because the bundled Mathlib object files do not yet expose the corresponding
source-level helper. -/
lemma prod_choose_local
    {M : Type*} [CommMonoid M]
    (f : ℕ → ℕ → M)
    (n : ℕ) :
    (∏ i ∈ Finset.range (n + 2), f i (n + 1 - i) ^ Nat.choose (n + 1) i) =
      (∏ i ∈ Finset.range (n + 1), f i (n + 1 - i) ^ Nat.choose n i) *
        ∏ i ∈ Finset.range (n + 1), f (i + 1) (n - i) ^ Nat.choose n i := by
  have hfirst :
      (∏ i ∈ Finset.range (n + 1),
          f (i + 1) (n - i) ^ Nat.choose n (i + 1)) * f 0 (n + 1) =
        ∏ i ∈ Finset.range (n + 1),
          f i (n + 1 - i) ^ Nat.choose n i := by
    rw [Finset.prod_range_succ, Finset.prod_range_succ']
    simp
  rw [Finset.prod_range_succ']
  simpa [Nat.choose_succ_succ, pow_add, Finset.prod_mul_distrib, hfirst,
    mul_assoc] using mul_comm
      (∏ i ∈ Finset.range (n + 1),
        f (i + 1) (n - i) ^ Nat.choose n i)
      (∏ i ∈ Finset.range (n + 1),
        f i (n + 1 - i) ^ Nat.choose n i)

/-- The binomial product describing `x^n c x^-n` when the iterated commutators commute
pairwise. -/
noncomputable def iteratedConjugateBinomial
    {G : Type*} [Group G]
    (x c : G)
    (hcomm :
      ∀ r s : ℕ,
        Commute
          (leftIteratedElement x c r)
          (leftIteratedElement x c s))
    (n : ℕ) :
    lIClos x c :=
  letI :
      CommGroup (lIClos x c) :=
    lIClos.commPairwiseCommute x c hcomm
  ∏ r ∈ Finset.range (n + 1),
    iteratedClosureGenerator x c r ^ Nat.choose n r

/-- Pascal recursion for the binomial product describing a conjugate. -/
lemma iterated_binomial_succ
    {G : Type*} [Group G]
    (x c : G)
    (hcomm :
      ∀ r s : ℕ,
        Commute
          (leftIteratedElement x c r)
          (leftIteratedElement x c s))
    (n : ℕ) :
    iteratedConjugateBinomial x c hcomm (n + 1) =
      lIClos.conjMonoidHom x c
        (iteratedConjugateBinomial x c hcomm n) := by
  letI :
      CommGroup (lIClos x c) :=
    lIClos.commPairwiseCommute x c hcomm
  simp only [iteratedConjugateBinomial, map_prod, map_pow,
    iterated_monoid_generator]
  rw [prod_choose_local
    (fun r _ => iteratedClosureGenerator x c r) n]
  have hsplit :
      (∏ r ∈ Finset.range (n + 1),
          (iteratedClosureGenerator x c (r + 1) *
              iteratedClosureGenerator x c r) ^ Nat.choose n r) =
        (∏ r ∈ Finset.range (n + 1),
          iteratedClosureGenerator x c (r + 1) ^ Nat.choose n r) *
          ∏ r ∈ Finset.range (n + 1),
            iteratedClosureGenerator x c r ^ Nat.choose n r := by
    simp only [mul_pow]
    exact Finset.prod_mul_distrib
  rw [hsplit]
  exact
    mul_comm
      (∏ r ∈ Finset.range (n + 1),
        iteratedClosureGenerator x c r ^ Nat.choose n r)
      (∏ r ∈ Finset.range (n + 1),
        iteratedClosureGenerator x c (r + 1) ^ Nat.choose n r)

/-- Under pairwise commutation of the iterated factors, conjugation by a natural power has
the expected binomial expansion. -/
lemma iterated_conjugate_binomial
    {G : Type*} [Group G]
    (x c : G)
    (hcomm :
      ∀ r s : ℕ,
        Commute
          (leftIteratedElement x c r)
          (leftIteratedElement x c s)) :
    ∀ n : ℕ,
      x ^ n * c * (x ^ n)⁻¹ =
        (iteratedConjugateBinomial x c hcomm n : G) := by
  intro n
  induction n with
  | zero =>
      simp [iteratedConjugateBinomial,
        iteratedClosureGenerator]
  | succ n ih =>
      calc
        x ^ (n + 1) * c * (x ^ (n + 1))⁻¹ =
            x * (x ^ n * c * (x ^ n)⁻¹) * x⁻¹ := by
              rw [pow_succ']
              group
        _ =
            x *
              (iteratedConjugateBinomial x c hcomm n : G) *
                x⁻¹ := by rw [ih]
        _ =
              (lIClos.conjMonoidHom x c
              (iteratedConjugateBinomial x c hcomm n) : G) := by
                rfl
        _ =
            (iteratedConjugateBinomial x c hcomm (n + 1) : G) := by
              rw [iterated_binomial_succ x c hcomm n]

/-- The binomial product describing the full conjugate orbit
`x^(n-1) c x^(-(n-1)) ... x c x^-1 c` when the iterated commutators commute pairwise. -/
noncomputable def iteratedBinomialProduct
    {G : Type*} [Group G]
    (x c : G)
    (hcomm :
      ∀ r s : ℕ,
        Commute
          (leftIteratedElement x c r)
          (leftIteratedElement x c s))
    (n : ℕ) :
    lIClos x c :=
  letI :
      CommGroup (lIClos x c) :=
    lIClos.commPairwiseCommute x c hcomm
  ∏ r ∈ Finset.range n,
    iteratedClosureGenerator x c r ^ Nat.choose n (r + 1)

/-- Pascal recursion for the binomial product describing the full conjugate orbit. -/
lemma left_iterated_binomial
    {G : Type*} [Group G]
    (x c : G)
    (hcomm :
      ∀ r s : ℕ,
        Commute
          (leftIteratedElement x c r)
          (leftIteratedElement x c s))
    (n : ℕ) :
    iteratedBinomialProduct x c hcomm (n + 1) =
      iteratedConjugateBinomial x c hcomm n *
        iteratedBinomialProduct x c hcomm n := by
  letI :
      CommGroup (lIClos x c) :=
    lIClos.commPairwiseCommute x c hcomm
  simp only [iteratedBinomialProduct,
    iteratedConjugateBinomial, Nat.choose_succ_succ,
    pow_add, Finset.prod_range_succ,
    Nat.choose_eq_zero_of_lt (Nat.lt_succ_self n), pow_zero, mul_one]
  have hsplit :
      (∏ r ∈ Finset.range n,
          iteratedClosureGenerator x c r ^ Nat.choose n r *
            iteratedClosureGenerator x c r ^ Nat.choose n (r + 1)) =
        (∏ r ∈ Finset.range n,
          iteratedClosureGenerator x c r ^ Nat.choose n r) *
          ∏ r ∈ Finset.range n,
            iteratedClosureGenerator x c r ^ Nat.choose n (r + 1) := by
    exact Finset.prod_mul_distrib
  rw [hsplit]
  let a : lIClos x c :=
    ∏ r ∈ Finset.range n,
      iteratedClosureGenerator x c r ^ Nat.choose n r
  let b : lIClos x c :=
    ∏ r ∈ Finset.range n,
      iteratedClosureGenerator x c r ^ Nat.choose n (r + 1)
  let d : lIClos x c :=
    iteratedClosureGenerator x c n ^ Nat.choose n n
  change (a * b) * d = (a * d) * b
  exact
    (mul_assoc a b d).trans
      ((congrArg (fun z => a * z) (mul_comm b d)).trans
        (mul_assoc a d b).symm)

/-- Under pairwise commutation of the iterated factors, the full conjugate orbit has the expected
binomial expansion. -/
lemma left_conjugate_binomial
    {G : Type*} [Group G]
    (x c : G)
    (hcomm :
      ∀ r s : ℕ,
        Commute
          (leftIteratedElement x c r)
          (leftIteratedElement x c s)) :
    ∀ n : ℕ,
      leftConjugateProduct x c n =
        (iteratedBinomialProduct x c hcomm n : G) := by
  intro n
  induction n with
  | zero =>
      rfl
  | succ n ih =>
      calc
        leftConjugateProduct x c (n + 1) =
            x ^ n * c * (x ^ n)⁻¹ * leftConjugateProduct x c n := by
              rw [left_conjugate_succ]
        _ =
            (iteratedConjugateBinomial x c hcomm n : G) *
              (iteratedBinomialProduct x c hcomm n : G) := by
                rw [
                  iterated_conjugate_binomial
                    x c hcomm n,
                  ih]
        _ =
            (iteratedBinomialProduct x c hcomm (n + 1) : G) := by
              rw [left_iterated_binomial x c hcomm n]
              rfl

/-- Iterated left commutators are natural under group homomorphisms. -/
lemma iterated_commutator_element
    {G H : Type*} [Group G] [Group H]
    (f : G →* H)
    (x c : G) :
    ∀ n : ℕ,
      f (leftIteratedElement x c n) =
        leftIteratedElement (f x) (f c) n := by
  intro n
  induction n with
  | zero =>
      rfl
  | succ n ih =>
      rw [iterated_element_succ,
        iterated_element_succ, map_commutatorElement, ih]

/-- The full left-conjugate orbit is natural under group homomorphisms. -/
lemma conjugate_orbit_product
    {G H : Type*} [Group G] [Group H]
    (f : G →* H)
    (x c : G) :
    ∀ n : ℕ,
      f (leftConjugateProduct x c n) =
        leftConjugateProduct (f x) (f c) n := by
  intro n
  induction n with
  | zero =>
      simp [left_conjugate_orbit]
  | succ n ih =>
      rw [left_conjugate_succ, left_conjugate_succ]
      simp only [map_mul, map_pow, map_inv, ih]

/-- The normal subgroup generated by unequal pairwise commutators among the iterated left
commutators. -/
def iteratedPairwiseComm
    {G : Type*} [Group G]
    (x c : G) :
    Subgroup G :=
  Subgroup.normalClosure
    { z | ∃ r s : ℕ, r ≠ s ∧
        z =
          ⁅leftIteratedElement x c r,
            leftIteratedElement x c s⁆ }

/-- The subgroup generated by the choose-powered factors in the collected left-conjugate
orbit. -/
def leftIteratedChoose
    {G : Type*} [Group G]
    (x c : G)
    (n : ℕ) :
    Subgroup G :=
  Subgroup.closure
    { z | ∃ r : ℕ, r < n ∧
        z = leftIteratedElement x c r ^ Nat.choose n (r + 1) }

/-- Before any lower-central estimate is imposed, split the full left-conjugate orbit into an
explicit error part generated by unequal pairwise commutators and a choose-powered part.

The factorization keeps the error witness available for recursive Hall collection instead of
immediately forgetting it inside a subgroup supremum. -/
lemma conjugate_pairwise_comm
    {G : Type*} [Group G]
    (x c : G)
    (n : ℕ) :
    ∃ e ∈ iteratedPairwiseComm x c,
      ∃ z ∈ leftIteratedChoose x c n,
        leftConjugateProduct x c n = e * z := by
  let K := iteratedPairwiseComm x c
  let C := leftIteratedChoose x c n
  letI : K.Normal := by
    dsimp [K, iteratedPairwiseComm]
    infer_instance
  let q : G →* G ⧸ K := QuotientGroup.mk' K
  have hcomm :
      ∀ r s : ℕ,
        Commute
          (leftIteratedElement (q x) (q c) r)
          (leftIteratedElement (q x) (q c) s) := by
    intro r s
    rw [← iterated_commutator_element q x c r,
      ← iterated_commutator_element q x c s,
      ← commutatorElement_eq_one_iff_commute,
      ← map_commutatorElement]
    apply (QuotientGroup.eq_one_iff _).mpr
    by_cases hrs : r = s
    · subst s
      simp
    · exact
        Subgroup.subset_normalClosure
          ⟨r, s, hrs, rfl⟩
  letI :
      CommGroup (lIClos (q x) (q c)) :=
    lIClos.commPairwiseCommute (q x) (q c) hcomm
  have horbit :
      q (leftConjugateProduct x c n) ∈ Subgroup.map q C := by
    rw [conjugate_orbit_product q x c n,
      left_conjugate_binomial (q x) (q c) hcomm n]
    simp only [iteratedBinomialProduct]
    letI :
        CommGroup (lIClos (q x) (q c)) :=
      lIClos.commPairwiseCommute
        (q x) (q c) hcomm
    have hprod :
        ∀ t : Finset ℕ,
          (∀ r ∈ t, r < n) →
          (↑(∏ r ∈ t,
              iteratedClosureGenerator (q x) (q c) r ^
                Nat.choose n (r + 1)) : G ⧸ K) ∈ Subgroup.map q C := by
      intro t ht
      induction t using Finset.induction_on with
      | empty =>
          rw [Finset.prod_empty]
          change (1 : G ⧸ K) ∈ Subgroup.map q C
          exact (Subgroup.map q C).one_mem
      | @insert r t hrt ih =>
          rw [Finset.prod_insert hrt]
          apply (Subgroup.map q C).mul_mem
          · have hfactor :
                leftIteratedElement x c r ^ Nat.choose n (r + 1) ∈ C :=
              Subgroup.subset_closure
                ⟨r, ht r (Finset.mem_insert_self r t), rfl⟩
            simpa only [Subgroup.coe_pow,
              coe_iterated_generator, map_pow,
              iterated_commutator_element q x c r] using
              Subgroup.mem_map_of_mem q hfactor
          · exact ih (fun s hs => ht s (Finset.mem_insert_of_mem hs))
    exact hprod (Finset.range n) (fun r hr => Finset.mem_range.mp hr)
  rcases Subgroup.mem_map.mp horbit with ⟨z, hzC, hz⟩
  have herr :
      leftConjugateProduct x c n * z⁻¹ ∈ K := by
    rw [mul_inv_quotient K]
    exact hz.symm
  refine ⟨leftConjugateProduct x c n * z⁻¹, herr, z, hzC, ?_⟩
  group

/-- Before any lower-central estimate is imposed, the full left-conjugate orbit is a product
of choose-powered iterated commutators up to the normal subgroup generated by unequal pairwise
commutators among those iterates. -/
lemma sup_pairwise_comm
    {G : Type*} [Group G]
    (x c : G)
    (n : ℕ) :
    leftConjugateProduct x c n ∈
      leftIteratedChoose x c n ⊔
        iteratedPairwiseComm x c := by
  rcases
      conjugate_pairwise_comm x c n with
    ⟨e, he, z, hz, horbit⟩
  rw [horbit]
  exact
    (leftIteratedChoose x c n ⊔
      iteratedPairwiseComm x c).mul_mem
        ((show
          iteratedPairwiseComm x c ≤
            leftIteratedChoose x c n ⊔
              iteratedPairwiseComm x c from le_sup_right) he)
        ((show
          leftIteratedChoose x c n ≤
            leftIteratedChoose x c n ⊔
              iteratedPairwiseComm x c from le_sup_left) hz)

end Submission
