        (mFQuot.prod_nestedright_trivialequiv (p := p) G H E x) =
      ((mFQuot.prodEquiv p G (H × E) x).1,
        mFQuot.prod_right_trivialequiv (p := p) H E
          ((mFQuot.prodEquiv p G (H × E) x).2)) := by
  refine QuotientGroup.induction_on x ?_
  intro a
  rcases a with ⟨g, he⟩
  rcases he with ⟨h, e⟩
  rfl

/-- Product coordinates for inserting a trivial right factor inside a right-nested
product. -/
theorem mFQuot.prodequiv_nestedright_trivialsymm
    (G H E : Type*) [Group G] [Group H] [Group E] [Subsingleton E]
    (x : mFQuot p (G × H)) :
    mFQuot.prodEquiv p G (H × E)
        ((mFQuot.prod_nestedright_trivialequiv (p := p) G H E).symm x) =
      ((mFQuot.prodEquiv p G H x).1,
        (mFQuot.prod_right_trivialequiv (p := p) H E).symm
          ((mFQuot.prodEquiv p G H x).2)) := by
  refine QuotientGroup.induction_on x ?_
  intro a
  rcases a with ⟨g, h⟩
  rfl

/-- Swapping the inner factors turns nested-left deletion into nested-right deletion. -/
theorem mFQuot.prodnested_trivialequiv_innerswap
    (G E H : Type*) [Group G] [Group E] [Group H] [Subsingleton E]
    (x : mFQuot p (G × (E × H))) :
    mFQuot.prod_nestedright_trivialequiv (p := p) G H E
        (mFQuot.map (p := p)
          (MonoidHom.prodMap (MonoidHom.id G)
            (MulEquiv.prodComm (M := E) (N := H)).toMonoidHom) x) =
      mFQuot.prod_nestedleft_trivialequiv (p := p) G E H x := by
  refine QuotientGroup.induction_on x ?_
  intro a
  rcases a with ⟨g, eh⟩
  rcases eh with ⟨e, h⟩
  rfl

/-- Inner swap also identifies the inverse nested-left and nested-right insertions. -/
theorem mFQuot.prodnested_trivialequiv_symminnerswap
    (G E H : Type*) [Group G] [Group E] [Group H] [Subsingleton E]
    (x : mFQuot p (G × H)) :
    mFQuot.map (p := p)
        (MonoidHom.prodMap (MonoidHom.id G)
          (MulEquiv.prodComm (M := E) (N := H)).toMonoidHom)
        ((mFQuot.prod_nestedleft_trivialequiv (p := p) G E H).symm x) =
      (mFQuot.prod_nestedright_trivialequiv (p := p) G H E).symm x := by
  refine QuotientGroup.induction_on x ?_
  intro a
  rcases a with ⟨g, h⟩
  rfl

/-- The reverse inner-swap form of nested-left/right deletion coherence. -/
theorem mFQuot.prodnested_trivialequiv_innerswaprev
    (G H E : Type*) [Group G] [Group H] [Group E] [Subsingleton E]
    (x : mFQuot p (G × (H × E))) :
    mFQuot.prod_nestedleft_trivialequiv (p := p) G E H
        (mFQuot.map (p := p)
          (MonoidHom.prodMap (MonoidHom.id G)
            (MulEquiv.prodComm (M := H) (N := E)).toMonoidHom) x) =
      mFQuot.prod_nestedright_trivialequiv (p := p) G H E x := by
  refine QuotientGroup.induction_on x ?_
  intro a
  rcases a with ⟨g, he⟩
  rcases he with ⟨h, e⟩
  rfl

/-- Reverse inner swap identifies inverse nested-right and nested-left insertions. -/
theorem mFQuot.prodnested_trivequisymm_innerswaprev
    (G H E : Type*) [Group G] [Group H] [Group E] [Subsingleton E]
    (x : mFQuot p (G × H)) :
    mFQuot.map (p := p)
        (MonoidHom.prodMap (MonoidHom.id G)
          (MulEquiv.prodComm (M := H) (N := E)).toMonoidHom)
        ((mFQuot.prod_nestedright_trivialequiv (p := p) G H E).symm x) =
      (mFQuot.prod_nestedleft_trivialequiv (p := p) G E H).symm x := by
  refine QuotientGroup.induction_on x ?_
  intro a
  rcases a with ⟨g, h⟩
  rfl

/-- Product coordinates for deleting a trivial middle factor before reassociating:
the first coordinate is obtained by the right-trivial unitor on `G × E`, and the
second coordinate is unchanged. -/
theorem mFQuot.prod_equivdelete_middleleft
    (G E H : Type*) [Group G] [Group E] [Group H] [Subsingleton E]
    (x : mFQuot p ((G × E) × H)) :
    mFQuot.prodEquiv p G H
      (mFQuot.map (p := p)
        (MonoidHom.prodMap (MonoidHom.fst G E) (MonoidHom.id H)) x) =
    (mFQuot.prod_right_trivialequiv (p := p) G E
        ((mFQuot.prodEquiv p (G × E) H x).1),
      (mFQuot.prodEquiv p (G × E) H x).2) := by
  refine QuotientGroup.induction_on x ?_
  intro a
  rcases a with ⟨ge, h⟩
  rcases ge with ⟨g, e⟩
  rfl

/-- Product coordinates for deleting a trivial middle factor after reassociating:
the first coordinate is unchanged, and the second is obtained by the left-trivial
unitor on `E × H`. -/
theorem mFQuot.prod_equivdelete_middleright
    (G E H : Type*) [Group G] [Group E] [Group H] [Subsingleton E]
    (x : mFQuot p ((G × E) × H)) :
    mFQuot.prodEquiv p G H
      (mFQuot.map (p := p)
        (MonoidHom.prodMap (MonoidHom.id G) (MonoidHom.snd E H))
        (mFQuot.prodAssocEquiv (p := p) G E H x)) =
    ((mFQuot.prodEquiv p G (E × H)
        (mFQuot.prodAssocEquiv (p := p) G E H x)).1,
      mFQuot.prod_left_trivialequiv (p := p) E H
        ((mFQuot.prodEquiv p G (E × H)
          (mFQuot.prodAssocEquiv (p := p) G E H x)).2)) := by
  refine QuotientGroup.induction_on x ?_
  intro a
  rcases a with ⟨ge, h⟩
  rcases ge with ⟨g, e⟩
  rfl



/-- First coordinate coherence between quotient product splittings and associator. -/
theorem mFQuot.prod_equiv_assocfst
    (G H K : Type*) [Group G] [Group H] [Group K]
    (x : mFQuot p ((G × H) × K)) :
    (mFQuot.prodEquiv p G (H × K)
        (mFQuot.prodAssocEquiv (p := p) G H K x)).1 =
      (mFQuot.prodEquiv p G H
        ((mFQuot.prodEquiv p (G × H) K x).1)).1 := by
  simpa using mFQuot.map_fst_prodassoc (p := p) G H K x

/-- Middle coordinate coherence between quotient product splittings and associator. -/
theorem mFQuot.prod_equiv_assocmid
    (G H K : Type*) [Group G] [Group H] [Group K]
    (x : mFQuot p ((G × H) × K)) :
    (mFQuot.prodEquiv p H K
      ((mFQuot.prodEquiv p G (H × K)
        (mFQuot.prodAssocEquiv (p := p) G H K x)).2)).1 =
      (mFQuot.prodEquiv p G H
        ((mFQuot.prodEquiv p (G × H) K x).1)).2 := by
  simpa using mFQuot.map_fstsnd_prodassoc (p := p) G H K x

/-- Last coordinate coherence between quotient product splittings and associator. -/
theorem mFQuot.prod_equiv_assocsnd
    (G H K : Type*) [Group G] [Group H] [Group K]
    (x : mFQuot p ((G × H) × K)) :
    (mFQuot.prodEquiv p H K
      ((mFQuot.prodEquiv p G (H × K)
        (mFQuot.prodAssocEquiv (p := p) G H K x)).2)).2 =
      (mFQuot.prodEquiv p (G × H) K x).2 := by
  simpa using mFQuot.map_sndsnd_prodassoc (p := p) G H K x

/-- First coordinate coherence for the inverse quotient associator. -/
theorem mFQuot.prod_equivassoc_symmfst
    (G H K : Type*) [Group G] [Group H] [Group K]
    (x : mFQuot p (G × H × K)) :
    (mFQuot.prodEquiv p G H
      ((mFQuot.prodEquiv p (G × H) K
        ((mFQuot.prodAssocEquiv (p := p) G H K).symm x)).1)).1 =
      (mFQuot.prodEquiv p G (H × K) x).1 := by
  simpa using mFQuot.mapfst_fstprod_assocsymm (p := p) G H K x

/-- Middle coordinate coherence for the inverse quotient associator. -/
theorem mFQuot.prod_equivassoc_symmmid
    (G H K : Type*) [Group G] [Group H] [Group K]
    (x : mFQuot p (G × H × K)) :
    (mFQuot.prodEquiv p G H
      ((mFQuot.prodEquiv p (G × H) K
        ((mFQuot.prodAssocEquiv (p := p) G H K).symm x)).1)).2 =
      (mFQuot.prodEquiv p H K
        ((mFQuot.prodEquiv p G (H × K) x).2)).1 := by
  simpa using mFQuot.mapsnd_fstprod_assocsymm (p := p) G H K x

/-- Last coordinate coherence for the inverse quotient associator. -/
theorem mFQuot.prod_equivassoc_symmsnd
    (G H K : Type*) [Group G] [Group H] [Group K]
    (x : mFQuot p (G × H × K)) :
    (mFQuot.prodEquiv p (G × H) K
        ((mFQuot.prodAssocEquiv (p := p) G H K).symm x)).2 =
      (mFQuot.prodEquiv p H K
        ((mFQuot.prodEquiv p G (H × K) x).2)).2 := by
  simpa using mFQuot.map_sndprod_assocsymm (p := p) G H K x

/-- Packaged hexagon coherence for moving a left factor past a binary product. -/
theorem mFQuot.prodcomm_equivassoc_hexagonleft
    (G H K : Type*) [Group G] [Group H] [Group K]
    (x : mFQuot p (G × H × K)) :
    mFQuot.prodCommEquiv (p := p) G (H × K) x =
      (mFQuot.prodAssocEquiv (p := p) H K G).symm
        (mFQuot.map (p := p)
          (MonoidHom.prodMap (MonoidHom.id H)
            (MulEquiv.prodComm (M := G) (N := K)).toMonoidHom)
          (mFQuot.prodAssocEquiv (p := p) H G K
            (mFQuot.map (p := p)
              (MonoidHom.prodMap
                (MulEquiv.prodComm (M := G) (N := H)).toMonoidHom
                (MonoidHom.id K))
              ((mFQuot.prodAssocEquiv (p := p) G H K).symm x)))) := by
  simpa using mFQuot.mapprod_commassoc_hexagonleft (p := p) G H K x

/-- Packaged hexagon coherence for moving a binary product past a right factor. -/
theorem mFQuot.prodcomm_equivassoc_hexagonright
    (G H K : Type*) [Group G] [Group H] [Group K]
    (x : mFQuot p ((G × H) × K)) :
    mFQuot.prodCommEquiv (p := p) (G × H) K x =
      mFQuot.prodAssocEquiv (p := p) K G H
        (mFQuot.map (p := p)
          (MonoidHom.prodMap
            (MulEquiv.prodComm (M := G) (N := K)).toMonoidHom
            (MonoidHom.id H))
          ((mFQuot.prodAssocEquiv (p := p) G K H).symm
            (mFQuot.map (p := p)
              (MonoidHom.prodMap (MonoidHom.id G)
                (MulEquiv.prodComm (M := H) (N := K)).toMonoidHom)
              (mFQuot.prodAssocEquiv (p := p) G H K x)))) := by
  simpa using mFQuot.mapprod_commassoc_hexagonright (p := p) G H K x


/-- Pentagon coherence for packaged quotient product associator equivalences. -/
theorem mFQuot.prod_assoc_equivpentagon
    (G H K L : Type*) [Group G] [Group H] [Group K] [Group L]
    (x : mFQuot p (((G × H) × K) × L)) :
    mFQuot.prodAssocEquiv (p := p) G H (K × L)
      (mFQuot.prodAssocEquiv (p := p) (G × H) K L x) =
    mFQuot.map (p := p)
      (MonoidHom.prodMap (MonoidHom.id G)
        (MulEquiv.prodAssoc (M := H) (N := K) (P := L)).toMonoidHom)
      (mFQuot.prodAssocEquiv (p := p) G (H × K) L
        (mFQuot.map (p := p)
          (MonoidHom.prodMap
            (MulEquiv.prodAssoc (M := G) (N := H) (P := K)).toMonoidHom
            (MonoidHom.id L)) x)) := by
  simpa using mFQuot.map_prod_assocpentagon (p := p) G H K L x

/-- Inverse pentagon coherence for packaged quotient product associator equivalences. -/
theorem mFQuot.prod_assocequiv_symmpentagon
    (G H K L : Type*) [Group G] [Group H] [Group K] [Group L]
    (x : mFQuot p (G × H × K × L)) :
    (mFQuot.prodAssocEquiv (p := p) (G × H) K L).symm
      ((mFQuot.prodAssocEquiv (p := p) G H (K × L)).symm x) =
    mFQuot.map (p := p)
      (MonoidHom.prodMap
        (MulEquiv.prodAssoc (M := G) (N := H) (P := K)).symm.toMonoidHom
        (MonoidHom.id L))
      ((mFQuot.prodAssocEquiv (p := p) G (H × K) L).symm
        (mFQuot.map (p := p)
          (MonoidHom.prodMap (MonoidHom.id G)
            (MulEquiv.prodAssoc (M := H) (N := K) (P := L)).symm.toMonoidHom) x)) := by
  simpa using mFQuot.map_prodassoc_symmpentagon (p := p) G H K L x



end Submission

namespace Submission

variable (p : ℕ) {G H : Type*} [Group G] [Group H]


/-- The additive Frattini quotient of a subsingleton group is subsingleton. -/
instance mFAdditi.inst_subsingleton_subsingleton
    (E : Type*) [Group E] [Subsingleton E] :
    Subsingleton (mFAdditi p E) := by
  refine ⟨?_⟩
  intro x y
  cases x using Additive.rec
  rename_i qx
  cases y using Additive.rec
  rename_i qy
  congr
  exact Subsingleton.elim qx qy

/-- Additive version of the induced quotient map. -/
def mFAdditi.mapAdd (f : G →* H) :
    mFAdditi p G →+ mFAdditi p H :=
  (mFQuot.map (p := p) f).toAdditive

@[simp] theorem mFAdditi.map_add_mul (f : G →* H)
    (q : mFQuot p G) :
    mFAdditi.mapAdd (p := p) f (Additive.ofMul q) =
      Additive.ofMul (mFQuot.map (p := p) f q) := rfl

/-- Representative formula for the additive induced Frattini map. -/
@[simp] theorem mFAdditi.mapAdd_mk (f : G →* H) (g : G) :
    mFAdditi.mapAdd (p := p) f
        (Additive.ofMul (mFQuot.mk p G g)) =
      Additive.ofMul (mFQuot.mk p H (f g)) := rfl

end Submission

namespace Submission

variable (p : ℕ) {G H : Type*} [Group G] [Group H]

/-- The induced `ZMod p`-linear map on additive mod-`p` Frattini quotients. -/
noncomputable def mFAdditi.mapLinear (f : G →* H) :
    mFAdditi p G →ₗ[ZMod p] mFAdditi p H :=
  (mFAdditi.mapAdd (p := p) f).toZModLinearMap p

@[simp] theorem mFAdditi.mapLinear_apply (f : G →* H)
    (x : mFAdditi p G) :
    mFAdditi.mapLinear (p := p) f x =
      mFAdditi.mapAdd (p := p) f x := rfl

@[simp] theorem mFAdditi.map_lin_mul (f : G →* H)
    (q : mFQuot p G) :
    mFAdditi.mapLinear (p := p) f (Additive.ofMul q) =
      Additive.ofMul (mFQuot.map (p := p) f q) := rfl

/-- Representative formula for the linear induced Frattini map. -/
@[simp] theorem mFAdditi.mapLinear_mk (f : G →* H) (g : G) :
    mFAdditi.mapLinear (p := p) f
        (Additive.ofMul (mFQuot.mk p G g)) =
      Additive.ofMul (mFQuot.mk p H (f g)) := rfl

end Submission

namespace Submission

variable (p : ℕ) {G H K : Type*} [Group G] [Group H] [Group K]

@[simp] theorem mFQuot.map_id :
    mFQuot.map (p := p) (MonoidHom.id G) =
      MonoidHom.id (mFQuot p G) := by
  apply MonoidHom.ext
  intro q
  refine QuotientGroup.induction_on q ?_
  intro x
  rfl

@[simp] theorem mFQuot.map_comp (f : G →* H) (g : H →* K) :
    mFQuot.map (p := p) (g.comp f) =
      (mFQuot.map (p := p) g).comp
        (mFQuot.map (p := p) f) := by
  apply MonoidHom.ext
  intro q
  refine QuotientGroup.induction_on q ?_
  intro x
  rfl

/-- Injectivity of a product-induced Frattini quotient map follows from injectivity on factors. -/
theorem mFQuot.map_prodmap_injinj
    {G₁ G₂ H₁ H₂ : Type*} [Group G₁] [Group G₂] [Group H₁] [Group H₂]
    (f : G₁ →* G₂) (g : H₁ →* H₂)
    (hf : Function.Injective (mFQuot.map (p := p) f))
    (hg : Function.Injective (mFQuot.map (p := p) g)) :
    Function.Injective (mFQuot.map (p := p) (MonoidHom.prodMap f g)) := by
  intro x y hxy
  apply (mFQuot.prodEquiv p G₁ H₁).injective
  have hp := congrArg (fun z => mFQuot.prodEquiv p G₂ H₂ z) hxy
  change mFQuot.prodEquiv p G₂ H₂
      (mFQuot.map (p := p) (MonoidHom.prodMap f g) x) =
    mFQuot.prodEquiv p G₂ H₂
      (mFQuot.map (p := p) (MonoidHom.prodMap f g) y) at hp
  rw [mFQuot.prod_equivmap_prodmap,
      mFQuot.prod_equivmap_prodmap] at hp
  exact Prod.ext (hf (congrArg Prod.fst hp)) (hg (congrArg Prod.snd hp))

/-- Surjectivity of a product-induced Frattini quotient map follows from surjectivity on factors. -/
theorem mFQuot.map_prodmap_surjsurj
    {G₁ G₂ H₁ H₂ : Type*} [Group G₁] [Group G₂] [Group H₁] [Group H₂]
    (f : G₁ →* G₂) (g : H₁ →* H₂)
    (hf : Function.Surjective (mFQuot.map (p := p) f))
    (hg : Function.Surjective (mFQuot.map (p := p) g)) :
    Function.Surjective (mFQuot.map (p := p) (MonoidHom.prodMap f g)) := by
  intro y
  let yp := mFQuot.prodEquiv p G₂ H₂ y
  rcases hf yp.1 with ⟨a, ha⟩
  rcases hg yp.2 with ⟨b, hb⟩
  refine ⟨(mFQuot.prodEquiv p G₁ H₁).symm (a, b), ?_⟩
  apply (mFQuot.prodEquiv p G₂ H₂).injective
  rw [mFQuot.prod_equivmap_prodmap]
  simpa [yp, ha, hb] using (show
    (mFQuot.map (p := p) f a,
      mFQuot.map (p := p) g b) = yp by
        rw [ha, hb])

/-- Bijectivity of a product-induced Frattini quotient map follows factorwise. -/
theorem mFQuot.map_prodmap_bijbij
    {G₁ G₂ H₁ H₂ : Type*} [Group G₁] [Group G₂] [Group H₁] [Group H₂]
    (f : G₁ →* G₂) (g : H₁ →* H₂)
    (hf : Function.Bijective (mFQuot.map (p := p) f))
    (hg : Function.Bijective (mFQuot.map (p := p) g)) :
    Function.Bijective (mFQuot.map (p := p) (MonoidHom.prodMap f g)) :=
  ⟨mFQuot.map_prodmap_injinj (p := p) f g hf.1 hg.1,
    mFQuot.map_prodmap_surjsurj (p := p) f g hf.2 hg.2⟩

/-- Naturality of first-factor insertion under product homomorphisms. -/
theorem mFQuot.map_prod_mapinl
    {G₁ G₂ H₁ H₂ : Type*} [Group G₁] [Group G₂] [Group H₁] [Group H₂]
    (f : G₁ →* G₂) (g : H₁ →* H₂) (x : mFQuot p G₁) :
    mFQuot.map (p := p) (MonoidHom.prodMap f g)
        (mFQuot.map (p := p) (MonoidHom.inl G₁ H₁) x) =
      mFQuot.map (p := p) (MonoidHom.inl G₂ H₂)
        (mFQuot.map (p := p) f x) := by
  change ((mFQuot.map (p := p) (MonoidHom.prodMap f g)).comp
      (mFQuot.map (p := p) (MonoidHom.inl G₁ H₁))) x =
    ((mFQuot.map (p := p) (MonoidHom.inl G₂ H₂)).comp
      (mFQuot.map (p := p) f)) x
  rw [← mFQuot.map_comp, ← mFQuot.map_comp]
  have hcomp : (MonoidHom.prodMap f g).comp (MonoidHom.inl G₁ H₁) =
      (MonoidHom.inl G₂ H₂).comp f := by
    ext a <;> simp [MonoidHom.inl, MonoidHom.prodMap]
  rw [hcomp]

/-- Naturality of second-factor insertion under product homomorphisms. -/
theorem mFQuot.map_prod_mapinr
    {G₁ G₂ H₁ H₂ : Type*} [Group G₁] [Group G₂] [Group H₁] [Group H₂]
    (f : G₁ →* G₂) (g : H₁ →* H₂) (y : mFQuot p H₁) :
    mFQuot.map (p := p) (MonoidHom.prodMap f g)
        (mFQuot.map (p := p) (MonoidHom.inr G₁ H₁) y) =
      mFQuot.map (p := p) (MonoidHom.inr G₂ H₂)
        (mFQuot.map (p := p) g y) := by
  change ((mFQuot.map (p := p) (MonoidHom.prodMap f g)).comp
      (mFQuot.map (p := p) (MonoidHom.inr G₁ H₁))) y =
    ((mFQuot.map (p := p) (MonoidHom.inr G₂ H₂)).comp
      (mFQuot.map (p := p) g)) y
  rw [← mFQuot.map_comp, ← mFQuot.map_comp]
  have hcomp : (MonoidHom.prodMap f g).comp (MonoidHom.inr G₁ H₁) =
      (MonoidHom.inr G₂ H₂).comp g := by
    ext a <;> simp [MonoidHom.inr, MonoidHom.prodMap]
  rw [hcomp]


/-- Naturality of first projection under product homomorphisms. -/
theorem mFQuot.map_fst_prodmap
    {G₁ G₂ H₁ H₂ : Type*} [Group G₁] [Group G₂] [Group H₁] [Group H₂]
    (f : G₁ →* G₂) (g : H₁ →* H₂) (x : mFQuot p (G₁ × H₁)) :
    mFQuot.map (p := p) f
        (mFQuot.map (p := p) (MonoidHom.fst G₁ H₁) x) =
      mFQuot.map (p := p) (MonoidHom.fst G₂ H₂)
        (mFQuot.map (p := p) (MonoidHom.prodMap f g) x) := by
  change ((mFQuot.map (p := p) f).comp
      (mFQuot.map (p := p) (MonoidHom.fst G₁ H₁))) x =
    ((mFQuot.map (p := p) (MonoidHom.fst G₂ H₂)).comp
      (mFQuot.map (p := p) (MonoidHom.prodMap f g))) x
  rw [← mFQuot.map_comp, ← mFQuot.map_comp]
  have hcomp : f.comp (MonoidHom.fst G₁ H₁) =
      (MonoidHom.fst G₂ H₂).comp (MonoidHom.prodMap f g) := by
    ext a
    rfl
  rw [hcomp]

/-- Naturality of second projection under product homomorphisms. -/
theorem mFQuot.map_snd_prodmap
    {G₁ G₂ H₁ H₂ : Type*} [Group G₁] [Group G₂] [Group H₁] [Group H₂]
    (f : G₁ →* G₂) (g : H₁ →* H₂) (x : mFQuot p (G₁ × H₁)) :
    mFQuot.map (p := p) g
        (mFQuot.map (p := p) (MonoidHom.snd G₁ H₁) x) =
      mFQuot.map (p := p) (MonoidHom.snd G₂ H₂)
        (mFQuot.map (p := p) (MonoidHom.prodMap f g) x) := by
  change ((mFQuot.map (p := p) g).comp
      (mFQuot.map (p := p) (MonoidHom.snd G₁ H₁))) x =
    ((mFQuot.map (p := p) (MonoidHom.snd G₂ H₂)).comp
      (mFQuot.map (p := p) (MonoidHom.prodMap f g))) x
  rw [← mFQuot.map_comp, ← mFQuot.map_comp]
  have hcomp : g.comp (MonoidHom.snd G₁ H₁) =
      (MonoidHom.snd G₂ H₂).comp (MonoidHom.prodMap f g) := by
    ext a
    rfl
  rw [hcomp]

/-- Injectivity of a product-induced quotient map implies injectivity on the first factor. -/
theorem mFQuot.mapinj_leftprod_mapinj
    {G₁ G₂ H₁ H₂ : Type*} [Group G₁] [Group G₂] [Group H₁] [Group H₂]
    (f : G₁ →* G₂) (g : H₁ →* H₂)
    (h : Function.Injective (mFQuot.map (p := p) (MonoidHom.prodMap f g))) :
    Function.Injective (mFQuot.map (p := p) f) := by
  intro x y hxy
  apply mFQuot.map_inl_injective (p := p) G₁ H₁
  apply h
  rw [mFQuot.map_prod_mapinl,
      mFQuot.map_prod_mapinl, hxy]

/-- Injectivity of a product-induced quotient map implies injectivity on the second factor. -/
theorem mFQuot.mapinj_rightprod_mapinj
    {G₁ G₂ H₁ H₂ : Type*} [Group G₁] [Group G₂] [Group H₁] [Group H₂]
    (f : G₁ →* G₂) (g : H₁ →* H₂)
    (h : Function.Injective (mFQuot.map (p := p) (MonoidHom.prodMap f g))) :
    Function.Injective (mFQuot.map (p := p) g) := by
  intro x y hxy
  apply mFQuot.map_inr_injective (p := p) G₁ H₁
  apply h
  rw [mFQuot.map_prod_mapinr,
      mFQuot.map_prod_mapinr, hxy]

/-- Surjectivity of a product-induced quotient map implies surjectivity on the first factor. -/
theorem mFQuot.mapsurj_leftprod_mapsurj
    {G₁ G₂ H₁ H₂ : Type*} [Group G₁] [Group G₂] [Group H₁] [Group H₂]
    (f : G₁ →* G₂) (g : H₁ →* H₂)
    (h : Function.Surjective (mFQuot.map (p := p) (MonoidHom.prodMap f g))) :
    Function.Surjective (mFQuot.map (p := p) f) := by
  intro z
  let target := (mFQuot.prodEquiv p G₂ H₂).symm
    (z, (1 : mFQuot p H₂))
  rcases h target with ⟨x, hx⟩
  refine ⟨mFQuot.map (p := p) (MonoidHom.fst G₁ H₁) x, ?_⟩
  calc
    mFQuot.map (p := p) f
        (mFQuot.map (p := p) (MonoidHom.fst G₁ H₁) x) =
        mFQuot.map (p := p) (MonoidHom.fst G₂ H₂)
          (mFQuot.map (p := p) (MonoidHom.prodMap f g) x) :=
      mFQuot.map_fst_prodmap (p := p) f g x
    _ = mFQuot.map (p := p) (MonoidHom.fst G₂ H₂) target := by rw [hx]
    _ = z := by
      simp [target]

/-- Surjectivity of a product-induced quotient map implies surjectivity on the second factor. -/
theorem mFQuot.mapsurj_rightprod_mapsurj
    {G₁ G₂ H₁ H₂ : Type*} [Group G₁] [Group G₂] [Group H₁] [Group H₂]
    (f : G₁ →* G₂) (g : H₁ →* H₂)
    (h : Function.Surjective (mFQuot.map (p := p) (MonoidHom.prodMap f g))) :
    Function.Surjective (mFQuot.map (p := p) g) := by
  intro z
  let target := (mFQuot.prodEquiv p G₂ H₂).symm
    ((1 : mFQuot p G₂), z)
  rcases h target with ⟨x, hx⟩
  refine ⟨mFQuot.map (p := p) (MonoidHom.snd G₁ H₁) x, ?_⟩
  calc
    mFQuot.map (p := p) g
        (mFQuot.map (p := p) (MonoidHom.snd G₁ H₁) x) =
        mFQuot.map (p := p) (MonoidHom.snd G₂ H₂)
          (mFQuot.map (p := p) (MonoidHom.prodMap f g) x) :=
      mFQuot.map_snd_prodmap (p := p) f g x
    _ = mFQuot.map (p := p) (MonoidHom.snd G₂ H₂) target := by rw [hx]
    _ = z := by
      simp [target]

/-- Factorwise criterion for injectivity of a product-induced quotient map. -/
theorem mFQuot.map_prodmap_injiff
    {G₁ G₂ H₁ H₂ : Type*} [Group G₁] [Group G₂] [Group H₁] [Group H₂]
    (f : G₁ →* G₂) (g : H₁ →* H₂) :
    Function.Injective (mFQuot.map (p := p) (MonoidHom.prodMap f g)) ↔
      Function.Injective (mFQuot.map (p := p) f) ∧
        Function.Injective (mFQuot.map (p := p) g) := by
  constructor
  · intro h
    exact ⟨mFQuot.mapinj_leftprod_mapinj (p := p) f g h,
      mFQuot.mapinj_rightprod_mapinj (p := p) f g h⟩
  · intro h
    exact mFQuot.map_prodmap_injinj (p := p) f g h.1 h.2

/-- Factorwise criterion for surjectivity of a product-induced quotient map. -/
theorem mFQuot.map_prodmap_surjiff
    {G₁ G₂ H₁ H₂ : Type*} [Group G₁] [Group G₂] [Group H₁] [Group H₂]
    (f : G₁ →* G₂) (g : H₁ →* H₂) :
    Function.Surjective (mFQuot.map (p := p) (MonoidHom.prodMap f g)) ↔
      Function.Surjective (mFQuot.map (p := p) f) ∧
        Function.Surjective (mFQuot.map (p := p) g) := by
  constructor
  · intro h
    exact ⟨mFQuot.mapsurj_leftprod_mapsurj (p := p) f g h,
      mFQuot.mapsurj_rightprod_mapsurj (p := p) f g h⟩
  · intro h
    exact mFQuot.map_prodmap_surjsurj (p := p) f g h.1 h.2

/-- Factorwise criterion for bijectivity of a product-induced quotient map. -/
theorem mFQuot.map_prodmap_bijiff
    {G₁ G₂ H₁ H₂ : Type*} [Group G₁] [Group G₂] [Group H₁] [Group H₂]
    (f : G₁ →* G₂) (g : H₁ →* H₂) :
    Function.Bijective (mFQuot.map (p := p) (MonoidHom.prodMap f g)) ↔
      Function.Bijective (mFQuot.map (p := p) f) ∧
        Function.Bijective (mFQuot.map (p := p) g) := by
  constructor
  · intro h
    exact ⟨⟨(mFQuot.map_prodmap_injiff (p := p) f g).mp h.1 |>.1,
        (mFQuot.map_prodmap_surjiff (p := p) f g).mp h.2 |>.1⟩,
      ⟨(mFQuot.map_prodmap_injiff (p := p) f g).mp h.1 |>.2,
        (mFQuot.map_prodmap_surjiff (p := p) f g).mp h.2 |>.2⟩⟩
  · intro h
    exact mFQuot.map_prodmap_bijbij (p := p) f g h.1 h.2

/-- Kernel-triviality of a product-induced quotient map is factorwise. -/
theorem mFQuot.mapprod_mapker_eqbotiff
    {G₁ G₂ H₁ H₂ : Type*} [Group G₁] [Group G₂] [Group H₁] [Group H₂]
    (f : G₁ →* G₂) (g : H₁ →* H₂) :
    MonoidHom.ker (mFQuot.map (p := p) (MonoidHom.prodMap f g)) = ⊥ ↔
      MonoidHom.ker (mFQuot.map (p := p) f) = ⊥ ∧
        MonoidHom.ker (mFQuot.map (p := p) g) = ⊥ := by
  rw [MonoidHom.ker_eq_bot_iff, MonoidHom.ker_eq_bot_iff, MonoidHom.ker_eq_bot_iff]
  exact mFQuot.map_prodmap_injiff (p := p) f g

/-- Full-range property of a product-induced quotient map is factorwise. -/
theorem mFQuot.mapprod_maprange_eqtopiff
    {G₁ G₂ H₁ H₂ : Type*} [Group G₁] [Group G₂] [Group H₁] [Group H₂]
    (f : G₁ →* G₂) (g : H₁ →* H₂) :
    MonoidHom.range (mFQuot.map (p := p) (MonoidHom.prodMap f g)) = ⊤ ↔
      MonoidHom.range (mFQuot.map (p := p) f) = ⊤ ∧
        MonoidHom.range (mFQuot.map (p := p) g) = ⊤ := by
  rw [MonoidHom.range_eq_top, MonoidHom.range_eq_top, MonoidHom.range_eq_top]
  exact mFQuot.map_prodmap_surjiff (p := p) f g

