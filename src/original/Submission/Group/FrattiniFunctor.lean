/-- Triangle coherence for the associator when the middle factor is a trivial
(subsingleton) group: deleting it on either side gives the same quotient map. -/
theorem mFQuot.map_prodassoc_trivialtriangle
    (G E H : Type*) [Group G] [Group E] [Group H] [Subsingleton E]
    (x : mFQuot p ((G × E) × H)) :
    mFQuot.map (p := p)
        (MonoidHom.prodMap (MonoidHom.fst G E) (MonoidHom.id H)) x =
      mFQuot.map (p := p)
        (MonoidHom.prodMap (MonoidHom.id G) (MonoidHom.snd E H))
        (mFQuot.prodAssocEquiv (p := p) G E H x) := by
  refine QuotientGroup.induction_on x ?_
  intro a
  rcases a with ⟨ge, h⟩
  rcases ge with ⟨g, e⟩
  have he : e = 1 := Subsingleton.elim e 1
  subst e
  rfl


/-- Inverse triangle coherence for deleting a trivial middle factor after the
inverse associator. -/
theorem mFQuot.mapprod_assocsymm_trivialtriangle
    (G E H : Type*) [Group G] [Group E] [Group H] [Subsingleton E]
    (x : mFQuot p (G × E × H)) :
    mFQuot.map (p := p)
        (MonoidHom.prodMap (MonoidHom.id G) (MonoidHom.snd E H)) x =
      mFQuot.map (p := p)
        (MonoidHom.prodMap (MonoidHom.fst G E) (MonoidHom.id H))
        ((mFQuot.prodAssocEquiv (p := p) G E H).symm x) := by
  refine QuotientGroup.induction_on x ?_
  intro a
  rcases a with ⟨g, eh⟩
  rcases eh with ⟨e, h⟩
  have he : e = 1 := Subsingleton.elim e 1
  subst e
  rfl

/-- Deleting a trivial middle factor gives a multiplicative equivalence on
Frattini quotients.  The inverse inserts the unique element of the middle factor. -/
noncomputable def mFQuot.prod_middle_trivialequiv
    (G E H : Type*) [Group G] [Group E] [Group H] [Subsingleton E] :
    mFQuot p ((G × E) × H) ≃*
      mFQuot p (G × H) :=
{ toFun := mFQuot.map (p := p)
    (MonoidHom.prodMap (MonoidHom.fst G E) (MonoidHom.id H))
  invFun := mFQuot.map (p := p)
    (MonoidHom.prodMap (MonoidHom.inl G E) (MonoidHom.id H))
  left_inv := by
    intro x
    refine QuotientGroup.induction_on x ?_
    intro a
    rcases a with ⟨ge, h⟩
    rcases ge with ⟨g, e⟩
    have he : e = 1 := Subsingleton.elim e 1
    subst e
    rfl
  right_inv := by
    intro x
    refine QuotientGroup.induction_on x ?_
    intro a
    rcases a with ⟨g, h⟩
    rfl
  map_mul' := by
    intro x y
    exact map_mul _ x y }

