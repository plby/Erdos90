import Submission.Group.Frattini
import Submission.Group.Filtration

/-!
# Functoriality of the mod-`p` Frattini quotient

Group homomorphisms preserve `G^p [G,G]`, hence induce maps on the degree-one
quotients.  We also expose the induced additive `ZMod p`-linear map.
-/

open scoped commutatorElement

namespace Submission

variable (p : ℕ) {G H K : Type*} [Group G] [Group H] [Group K]

/-- Homomorphisms preserve the normal subgroup generated by `p`th powers. -/
theorem p_subgroup_comap (f : G →* H) :
    pPowerSubgroup p G ≤ (pPowerSubgroup p H).comap f := by
  refine Subgroup.normalClosure_le_normal ?_
  intro x hx
  rcases hx with ⟨g, rfl⟩
  change f (g ^ p) ∈ pPowerSubgroup p H
  rw [map_pow]
  exact p_power_subgroup p H (f g)

/-- Homomorphisms preserve the commutator subgroup. -/
theorem commutator_le_comap (f : G →* H) :
    _root_.commutator G ≤ (_root_.commutator H).comap f := by
  rw [← Subgroup.map_le_iff_le_comap]
  rw [_root_.commutator_def, Subgroup.map_commutator, _root_.commutator_def]
  exact Subgroup.commutator_mono (by intro x _; trivial) (by intro x _; trivial)

/-- Homomorphisms preserve the mod-`p` Frattini subgroup. -/
theorem mod_frattini_comap (f : G →* H) :
    modPFrattini p G ≤ (modPFrattini p H).comap f := by
  dsimp [modPFrattini]
  apply sup_le
  · exact (p_subgroup_comap (p := p) f).trans (Subgroup.comap_mono le_sup_left)
  · exact (commutator_le_comap (G := G) (H := H) f).trans (Subgroup.comap_mono le_sup_right)


/-- The `p`-power subgroup commutes with binary direct products. -/
theorem p_subgroup_prod (G H : Type*) [Group G] [Group H] :
    pPowerSubgroup p (G × H) = (pPowerSubgroup p G).prod (pPowerSubgroup p H) := by
  apply le_antisymm
  · intro x hx
    rcases x with ⟨g, h⟩
    rw [Subgroup.mem_prod]
    constructor
    · exact p_subgroup_comap (p := p) (MonoidHom.fst G H) hx
    · exact p_subgroup_comap (p := p) (MonoidHom.snd G H) hx
  · intro x hx
    rcases x with ⟨g, h⟩
    rw [Subgroup.mem_prod] at hx
    rcases hx with ⟨hg, hh⟩
    have hg' : (g, (1 : H)) ∈ pPowerSubgroup p (G × H) := by
      change MonoidHom.inl G H g ∈ pPowerSubgroup p (G × H)
      exact p_subgroup_comap (p := p) (MonoidHom.inl G H) hg
    have hh' : ((1 : G), h) ∈ pPowerSubgroup p (G × H) := by
      change MonoidHom.inr G H h ∈ pPowerSubgroup p (G × H)
      exact p_subgroup_comap (p := p) (MonoidHom.inr G H) hh
    simpa using (pPowerSubgroup p (G × H)).mul_mem hg' hh'

/-- The commutator subgroup commutes with binary direct products. -/
theorem commutator_prod (G H : Type*) [Group G] [Group H] :
    _root_.commutator (G × H) = (_root_.commutator G).prod (_root_.commutator H) := by
  apply le_antisymm
  · intro x hx
    rcases x with ⟨g, h⟩
    rw [Subgroup.mem_prod]
    constructor
    · exact commutator_le_comap (G := G × H) (H := G) (MonoidHom.fst G H) hx
    · exact commutator_le_comap (G := G × H) (H := H) (MonoidHom.snd G H) hx
  · intro x hx
    rcases x with ⟨g, h⟩
    rw [Subgroup.mem_prod] at hx
    rcases hx with ⟨hg, hh⟩
    have hg' : (g, (1 : H)) ∈ _root_.commutator (G × H) := by
      change MonoidHom.inl G H g ∈ _root_.commutator (G × H)
      exact commutator_le_comap (G := G) (H := G × H) (MonoidHom.inl G H) hg
    have hh' : ((1 : G), h) ∈ _root_.commutator (G × H) := by
      change MonoidHom.inr G H h ∈ _root_.commutator (G × H)
      exact commutator_le_comap (G := H) (H := G × H) (MonoidHom.inr G H) hh
    simpa using (_root_.commutator (G × H)).mul_mem hg' hh'

/-- The mod-`p` Frattini subgroup commutes with binary direct products. -/
theorem mod_prod (G H : Type*) [Group G] [Group H] :
    modPFrattini p (G × H) = (modPFrattini p G).prod (modPFrattini p H) := by
  apply le_antisymm
  · intro x hx
    rcases x with ⟨g, h⟩
    rw [Subgroup.mem_prod]
    constructor
    · exact mod_frattini_comap (p := p) (MonoidHom.fst G H) hx
    · exact mod_frattini_comap (p := p) (MonoidHom.snd G H) hx
  · intro x hx
    rcases x with ⟨g, h⟩
    rw [Subgroup.mem_prod] at hx
    rcases hx with ⟨hg, hh⟩
    have hg' : (g, (1 : H)) ∈ modPFrattini p (G × H) := by
      change MonoidHom.inl G H g ∈ modPFrattini p (G × H)
      exact mod_frattini_comap (p := p) (MonoidHom.inl G H) hg
    have hh' : ((1 : G), h) ∈ modPFrattini p (G × H) := by
      change MonoidHom.inr G H h ∈ modPFrattini p (G × H)
      exact mod_frattini_comap (p := p) (MonoidHom.inr G H) hh
    simpa using (modPFrattini p (G × H)).mul_mem hg' hh'

/-- Quotients by mod-`p` Frattini subgroups commute with binary products. -/
noncomputable def mFQuot.prodEquiv (G H : Type*) [Group G] [Group H] :
    mFQuot p (G × H) ≃*
      (mFQuot p G × mFQuot p H) :=
  (QuotientGroup.quotientMulEquivOfEq (mod_prod (p := p) G H)).trans
    (Submission.quotientProdEquiv (modPFrattini p G) (modPFrattini p H))

@[simp] theorem mFQuot.prodEquiv_mk (G H : Type*) [Group G] [Group H]
    (g : G) (h : H) :
    mFQuot.prodEquiv p G H
        (QuotientGroup.mk' (modPFrattini p (G × H)) (g, h)) =
      (QuotientGroup.mk' (modPFrattini p G) g,
        QuotientGroup.mk' (modPFrattini p H) h) := rfl


@[simp] theorem mFQuot.prod_equiv_symmmk (G H : Type*) [Group G] [Group H]
    (g : G) (h : H) :
    (mFQuot.prodEquiv p G H).symm
        (QuotientGroup.mk' (modPFrattini p G) g,
          QuotientGroup.mk' (modPFrattini p H) h) =
      QuotientGroup.mk' (modPFrattini p (G × H)) (g, h) := by
  apply (mFQuot.prodEquiv p G H).injective
  simp only [MulEquiv.apply_symm_apply]
  change (QuotientGroup.mk' (modPFrattini p G) g,
      QuotientGroup.mk' (modPFrattini p H) h) = _
  rw [mFQuot.prodEquiv_mk]



/-- Cardinality of a Frattini quotient of a product, stated with `Nat.card` so it
also applies uniformly to infinite quotients. -/
theorem nat_mod_prod (G H : Type*) [Group G] [Group H] :
    Nat.card (mFQuot p (G × H)) =
      Nat.card (mFQuot p G) * Nat.card (mFQuot p H) := by
  rw [Nat.card_congr (mFQuot.prodEquiv p G H).toEquiv, Nat.card_prod]


/-- A surjective homomorphism maps the `p`-power subgroup onto the target one. -/
theorem p_subgroup_surjective (f : G →* H)
    (hs : Function.Surjective f) :
    (pPowerSubgroup p G).map f = pPowerSubgroup p H := by
  apply le_antisymm
  · rw [Subgroup.map_le_iff_le_comap]
    exact p_subgroup_comap (p := p) f
  · haveI : ((pPowerSubgroup p G).map f).Normal :=
      (p_subgroup_normal (p := p) (G := G)).map f hs
    refine Subgroup.normalClosure_le_normal ?_
    intro x hx
    rcases hx with ⟨h, rfl⟩
    rcases hs h with ⟨g, rfl⟩
    exact ⟨g ^ p, p_power_subgroup p G g, by simp⟩

/-- A surjective homomorphism maps the commutator subgroup onto the target one. -/
theorem commutator_surjective (f : G →* H)
    (hs : Function.Surjective f) :
    (_root_.commutator G).map f = _root_.commutator H := by
  rw [_root_.commutator_def, Subgroup.map_commutator, _root_.commutator_def]
  have htop : (⊤ : Subgroup G).map f = (⊤ : Subgroup H) := by
    ext h
    constructor
    · intro _; trivial
    · intro _
      rcases hs h with ⟨g, rfl⟩
      exact ⟨g, trivial, rfl⟩
  rw [htop]

/-- A surjective homomorphism maps `G^p [G,G]` onto `H^p [H,H]`. -/
theorem mod_frattini_surjective (f : G →* H)
    (hs : Function.Surjective f) :
    (modPFrattini p G).map f = modPFrattini p H := by
  dsimp [modPFrattini]
  rw [Subgroup.map_sup, p_subgroup_surjective (p := p) f hs,
    commutator_surjective (G := G) (H := H) f hs]


/-- Preimage of the target mod-`p` Frattini subgroup under a surjection. -/
theorem mod_comap_surjective (f : G →* H)
    (hs : Function.Surjective f) :
    (modPFrattini p H).comap f = modPFrattini p G ⊔ f.ker := by
  rw [← mod_frattini_surjective (p := p) f hs]
  exact Subgroup.comap_map_eq f (modPFrattini p G)

/-- Preimage of the target `p`-power subgroup under a surjection. -/
theorem p_comap_surjective (f : G →* H)
    (hs : Function.Surjective f) :
    (pPowerSubgroup p H).comap f = pPowerSubgroup p G ⊔ f.ker := by
  rw [← p_subgroup_surjective (p := p) f hs]
  exact Subgroup.comap_map_eq f (pPowerSubgroup p G)

/-- Preimage of the target commutator subgroup under a surjection. -/
theorem commutator_comap_surjective (f : G →* H)
    (hs : Function.Surjective f) :
    (_root_.commutator H).comap f = _root_.commutator G ⊔ f.ker := by
  rw [← commutator_surjective (G := G) (H := H) f hs]
  exact Subgroup.comap_map_eq f (_root_.commutator G)

/-- The map induced on mod-`p` Frattini quotients by a group homomorphism. -/
def mFQuot.map (f : G →* H) :
    mFQuot p G →* mFQuot p H :=
  QuotientGroup.map (modPFrattini p G) (modPFrattini p H) f
    (mod_frattini_comap (p := p) f)


/-- A Frattini quotient of a subsingleton group is subsingleton. -/
instance mFQuot.inst_subsingleton_subsingleton
    (E : Type*) [Group E] [Subsingleton E] :
    Subsingleton (mFQuot p E) := by
  refine ⟨?_⟩
  intro x y
  refine QuotientGroup.induction_on x ?_
  intro a
  refine QuotientGroup.induction_on y ?_
  intro b
  have h : a = b := Subsingleton.elim a b
  subst b
  rfl

@[simp] theorem mFQuot.map_mk (f : G →* H) (g : G) :
    mFQuot.map (p := p) f (mFQuot.mk p G g) =
      mFQuot.mk p H (f g) := by
  rfl

/-- First projection of the Frattini product quotient equivalence. -/
@[simp] theorem mFQuot.prodEquiv_fst (G H : Type*) [Group G] [Group H]
    (x : mFQuot p (G × H)) :
    (mFQuot.prodEquiv p G H x).1 =
      mFQuot.map (p := p) (MonoidHom.fst G H) x := by
  refine QuotientGroup.induction_on x ?_
  intro gh
  rcases gh with ⟨g, h⟩
  rfl

/-- Second projection of the Frattini product quotient equivalence. -/
@[simp] theorem mFQuot.prodEquiv_snd (G H : Type*) [Group G] [Group H]
    (x : mFQuot p (G × H)) :
    (mFQuot.prodEquiv p G H x).2 =
      mFQuot.map (p := p) (MonoidHom.snd G H) x := by
  refine QuotientGroup.induction_on x ?_
  intro gh
  rcases gh with ⟨g, h⟩
  rfl

/-- Inserting in the first factor is the inverse product quotient equivalence on `(x, 1)`. -/
@[simp] theorem mFQuot.prod_equiv_symminl (G H : Type*) [Group G] [Group H]
    (x : mFQuot p G) :
    (mFQuot.prodEquiv p G H).symm (x, 1) =
      mFQuot.map (p := p) (MonoidHom.inl G H) x := by
  refine QuotientGroup.induction_on x ?_
  intro g
  change (mFQuot.prodEquiv p G H).symm
      (QuotientGroup.mk' (modPFrattini p G) g,
       QuotientGroup.mk' (modPFrattini p H) (1 : H)) = _
  rw [mFQuot.prod_equiv_symmmk]
  rfl

/-- Inserting in the second factor is the inverse product quotient equivalence on `(1, y)`. -/
@[simp] theorem mFQuot.prod_equiv_symminr (G H : Type*) [Group G] [Group H]
    (y : mFQuot p H) :
    (mFQuot.prodEquiv p G H).symm (1, y) =
      mFQuot.map (p := p) (MonoidHom.inr G H) y := by
  refine QuotientGroup.induction_on y ?_
  intro h
  change (mFQuot.prodEquiv p G H).symm
      (QuotientGroup.mk' (modPFrattini p G) (1 : G),
       QuotientGroup.mk' (modPFrattini p H) h) = _
  rw [mFQuot.prod_equiv_symmmk]
  rfl

/-- The quotient map induced by insertion into the first factor is injective. -/
theorem mFQuot.map_inl_injective (G H : Type*) [Group G] [Group H] :
    Function.Injective (mFQuot.map (p := p) (MonoidHom.inl G H)) := by
  intro x y h
  rw [← mFQuot.prod_equiv_symminl (p := p) G H x,
      ← mFQuot.prod_equiv_symminl (p := p) G H y] at h
  have hpair := congrArg (fun z => mFQuot.prodEquiv p G H z) h
  have hp : (x, (1 : mFQuot p H)) = (y, 1) := by
    simpa only [MulEquiv.apply_symm_apply] using hpair
  exact congrArg Prod.fst hp

/-- The quotient map induced by insertion into the second factor is injective. -/
theorem mFQuot.map_inr_injective (G H : Type*) [Group G] [Group H] :
    Function.Injective (mFQuot.map (p := p) (MonoidHom.inr G H)) := by
  intro x y h
  rw [← mFQuot.prod_equiv_symminr (p := p) G H x,
      ← mFQuot.prod_equiv_symminr (p := p) G H y] at h
  have hpair := congrArg (fun z => mFQuot.prodEquiv p G H z) h
  have hp : ((1 : mFQuot p G), x) = (1, y) := by
    simpa only [MulEquiv.apply_symm_apply] using hpair
  exact congrArg Prod.snd hp

/-- The first projection quotient map is surjective. -/
theorem mFQuot.map_fst_surjective (G H : Type*) [Group G] [Group H] :
    Function.Surjective (mFQuot.map (p := p) (MonoidHom.fst G H)) := by
  intro x
  refine ⟨(mFQuot.prodEquiv p G H).symm
      (x, (1 : mFQuot p H)), ?_⟩
  have h := congrArg Prod.fst (MulEquiv.apply_symm_apply
    (mFQuot.prodEquiv p G H)
    (x, (1 : mFQuot p H)))
  simpa [mFQuot.prodEquiv_fst] using h

/-- The second projection quotient map is surjective. -/
theorem mFQuot.map_snd_surjective (G H : Type*) [Group G] [Group H] :
    Function.Surjective (mFQuot.map (p := p) (MonoidHom.snd G H)) := by
  intro y
  refine ⟨(mFQuot.prodEquiv p G H).symm
      ((1 : mFQuot p G), y), ?_⟩
  have h := congrArg Prod.snd (MulEquiv.apply_symm_apply
    (mFQuot.prodEquiv p G H)
    ((1 : mFQuot p G), y))
  simpa [mFQuot.prodEquiv_snd] using h

@[simp] theorem mFQuot.map_fst_inl (G H : Type*) [Group G] [Group H]
    (x : mFQuot p G) :
    mFQuot.map (p := p) (MonoidHom.fst G H)
        (mFQuot.map (p := p) (MonoidHom.inl G H) x) = x := by
  refine QuotientGroup.induction_on x ?_
  intro g
  rfl

@[simp] theorem mFQuot.map_snd_inl (G H : Type*) [Group G] [Group H]
    (x : mFQuot p G) :
    mFQuot.map (p := p) (MonoidHom.snd G H)
        (mFQuot.map (p := p) (MonoidHom.inl G H) x) = 1 := by
  refine QuotientGroup.induction_on x ?_
  intro g
  rfl

@[simp] theorem mFQuot.map_fst_inr (G H : Type*) [Group G] [Group H]
    (y : mFQuot p H) :
    mFQuot.map (p := p) (MonoidHom.fst G H)
        (mFQuot.map (p := p) (MonoidHom.inr G H) y) = 1 := by
  refine QuotientGroup.induction_on y ?_
  intro h
  rfl

@[simp] theorem mFQuot.map_snd_inr (G H : Type*) [Group G] [Group H]
    (y : mFQuot p H) :
    mFQuot.map (p := p) (MonoidHom.snd G H)
        (mFQuot.map (p := p) (MonoidHom.inr G H) y) = y := by
  refine QuotientGroup.induction_on y ?_
  intro h
  rfl

/-- Extensionality for product Frattini quotient classes via the two projections. -/
theorem mFQuot.prod_ext (G H : Type*) [Group G] [Group H]
    {x y : mFQuot p (G × H)}
    (hfst : mFQuot.map (p := p) (MonoidHom.fst G H) x =
      mFQuot.map (p := p) (MonoidHom.fst G H) y)
    (hsnd : mFQuot.map (p := p) (MonoidHom.snd G H) x =
      mFQuot.map (p := p) (MonoidHom.snd G H) y) : x = y := by
  apply (mFQuot.prodEquiv p G H).injective
  ext
  · simpa [mFQuot.prodEquiv_fst] using hfst
  · simpa [mFQuot.prodEquiv_snd] using hsnd

/-- The inverse product quotient equivalence is the product of the two insertion maps. -/
theorem mFQuot.prodequiv_symmeq_mulinlinr (G H : Type*)
    [Group G] [Group H]
    (x : mFQuot p G) (y : mFQuot p H) :
    (mFQuot.prodEquiv p G H).symm (x, y) =
      mFQuot.map (p := p) (MonoidHom.inl G H) x *
        mFQuot.map (p := p) (MonoidHom.inr G H) y := by
  apply (mFQuot.prodEquiv p G H).injective
  ext <;> simp [map_mul]

/-- Reconstruct a product quotient class from its two projected components. -/
theorem mFQuot.mapinl_fstmul_inrsnd (G H : Type*) [Group G] [Group H]
    (x : mFQuot p (G × H)) :
    mFQuot.map (p := p) (MonoidHom.inl G H)
        (mFQuot.map (p := p) (MonoidHom.fst G H) x) *
      mFQuot.map (p := p) (MonoidHom.inr G H)
        (mFQuot.map (p := p) (MonoidHom.snd G H) x) = x := by
  apply (mFQuot.prodEquiv p G H).injective
  ext <;> simp [map_mul]

@[simp] theorem mFQuot.map_inl_ker (G H : Type*) [Group G] [Group H] :
    (mFQuot.map (p := p) (MonoidHom.inl G H)).ker = ⊥ := by
  exact (MonoidHom.ker_eq_bot_iff _).2
    (mFQuot.map_inl_injective (p := p) G H)

@[simp] theorem mFQuot.map_inr_ker (G H : Type*) [Group G] [Group H] :
    (mFQuot.map (p := p) (MonoidHom.inr G H)).ker = ⊥ := by
  exact (MonoidHom.ker_eq_bot_iff _).2
    (mFQuot.map_inr_injective (p := p) G H)

@[simp] theorem mFQuot.map_fst_range (G H : Type*) [Group G] [Group H] :
    (mFQuot.map (p := p) (MonoidHom.fst G H)).range = ⊤ := by
  exact (MonoidHom.range_eq_top).2
    (mFQuot.map_fst_surjective (p := p) G H)

@[simp] theorem mFQuot.map_snd_range (G H : Type*) [Group G] [Group H] :
    (mFQuot.map (p := p) (MonoidHom.snd G H)).range = ⊤ := by
  exact (MonoidHom.range_eq_top).2
    (mFQuot.map_snd_surjective (p := p) G H)

/-- Characterize equality to the multiplicative product quotient equivalence via its inverse. -/
theorem mFQuot.prodequiv_eqiff_eqsymm (G H : Type*) [Group G] [Group H]
    (x : mFQuot p (G × H))
    (y : mFQuot p G × mFQuot p H) :
    mFQuot.prodEquiv p G H x = y ↔
      x = (mFQuot.prodEquiv p G H).symm y := by
  constructor
  · intro h
    rw [← h]
    exact ((mFQuot.prodEquiv p G H).left_inv x).symm
  · intro h
    rw [h]
    exact (mFQuot.prodEquiv p G H).right_inv y

/-- Characterize equality to the inverse multiplicative product quotient equivalence. -/
theorem mFQuot.eq_prodequiv_symmiff (G H : Type*) [Group G] [Group H]
    (x : mFQuot p (G × H))
    (y : mFQuot p G × mFQuot p H) :
    x = (mFQuot.prodEquiv p G H).symm y ↔
      mFQuot.prodEquiv p G H x = y := by
  exact (mFQuot.prodequiv_eqiff_eqsymm (p := p) G H x y).symm

@[simp] theorem mFQuot.prod_equivsymm_applyapply (G H : Type*)
    [Group G] [Group H] (x : mFQuot p (G × H)) :
    (mFQuot.prodEquiv p G H).symm
        (mFQuot.prodEquiv p G H x) = x := by
  exact (mFQuot.prodEquiv p G H).left_inv x

@[simp] theorem mFQuot.prod_equivapply_symmapply (G H : Type*)
    [Group G] [Group H]
    (y : mFQuot p G × mFQuot p H) :
    mFQuot.prodEquiv p G H
        ((mFQuot.prodEquiv p G H).symm y) = y := by
  exact (mFQuot.prodEquiv p G H).right_inv y

/-- Naturality of the Frattini product quotient equivalence with respect to
product homomorphisms. -/
theorem mFQuot.prodEquiv_naturality
    {G₁ G₂ H₁ H₂ : Type*} [Group G₁] [Group G₂] [Group H₁] [Group H₂]
    (f : G₁ →* G₂) (g : H₁ →* H₂) :
    (mFQuot.prodEquiv p G₂ H₂).toMonoidHom.comp
        (mFQuot.map (p := p) (MonoidHom.prodMap f g)) =
      (MonoidHom.prodMap (mFQuot.map (p := p) f)
        (mFQuot.map (p := p) g)).comp
        (mFQuot.prodEquiv p G₁ H₁).toMonoidHom := by
  ext x <;> rfl

/-- Pointwise form of naturality of the Frattini product quotient equivalence. -/
theorem mFQuot.prod_equivmap_prodmap
    {G₁ G₂ H₁ H₂ : Type*} [Group G₁] [Group G₂] [Group H₁] [Group H₂]
    (f : G₁ →* G₂) (g : H₁ →* H₂)
    (x : mFQuot p (G₁ × H₁)) :
    mFQuot.prodEquiv p G₂ H₂
        (mFQuot.map (p := p) (MonoidHom.prodMap f g) x) =
      (mFQuot.map (p := p) f
          (mFQuot.prodEquiv p G₁ H₁ x).1,
        mFQuot.map (p := p) g
          (mFQuot.prodEquiv p G₁ H₁ x).2) := by
  refine QuotientGroup.induction_on x ?_
  intro a
  rcases a with ⟨a, b⟩
  rfl


/-- The product equivalence is compatible with swapping the two factors. -/
theorem mFQuot.prod_equivmap_prodcomm
    (G H : Type*) [Group G] [Group H]
    (x : mFQuot p (G × H)) :
    mFQuot.prodEquiv p H G
        (mFQuot.map (p := p)
          (MulEquiv.prodComm (M := G) (N := H)).toMonoidHom x) =
      ((mFQuot.prodEquiv p G H x).2,
        (mFQuot.prodEquiv p G H x).1) := by
  refine QuotientGroup.induction_on x ?_
  intro a
  rcases a with ⟨a, b⟩
  rfl




/-- The first coordinate of the product splitting is the right-trivial unitor. -/
@[simp] theorem mFQuot.prod_equivright_trivialfst
    (G E : Type*) [Group G] [Group E] [Subsingleton E]
    (x : mFQuot p (G × E)) :
    (mFQuot.prodEquiv p G E x).1 =
      mFQuot.map (p := p) (MonoidHom.fst G E) x := by
  simp [mFQuot.prodEquiv_fst]

/-- The second coordinate of a product splitting with a trivial right factor is `1`. -/
@[simp] theorem mFQuot.prod_equivright_trivialsnd
    (G E : Type*) [Group G] [Group E] [Subsingleton E]
    (x : mFQuot p (G × E)) :
    (mFQuot.prodEquiv p G E x).2 = 1 :=
  Subsingleton.elim _ _

/-- The first coordinate of a product splitting with a trivial left factor is `1`. -/
@[simp] theorem mFQuot.prod_equivleft_trivialfst
    (E G : Type*) [Group E] [Group G] [Subsingleton E]
    (x : mFQuot p (E × G)) :
    (mFQuot.prodEquiv p E G x).1 = 1 :=
  Subsingleton.elim _ _

/-- The second coordinate of the product splitting is the left-trivial unitor. -/
@[simp] theorem mFQuot.prod_equivleft_trivialsnd
    (E G : Type*) [Group E] [Group G] [Subsingleton E]
    (x : mFQuot p (E × G)) :
    (mFQuot.prodEquiv p E G x).2 =
      mFQuot.map (p := p) (MonoidHom.snd E G) x := by
  simp [mFQuot.prodEquiv_snd]

/-- Right projection is a multiplicative equivalence on Frattini quotients when the
right factor is a subsingleton group.  This is a flexible unit law usable with any
chosen trivial group model. -/
noncomputable def mFQuot.prod_right_trivialequiv
    (G E : Type*) [Group G] [Group E] [Subsingleton E] :
    mFQuot p (G × E) ≃* mFQuot p G :=
{ toFun := mFQuot.map (p := p) (MonoidHom.fst G E)
  invFun := mFQuot.map (p := p) (MonoidHom.inl G E)
  left_inv := by
    intro x
    refine QuotientGroup.induction_on x ?_
    intro a
    rcases a with ⟨g, e⟩
    have he : e = 1 := Subsingleton.elim e 1
    subst e
    rfl
  right_inv := by
    intro x
    refine QuotientGroup.induction_on x ?_
    intro g
    rfl
  map_mul' := by
    intro x y
    exact map_mul (mFQuot.map (p := p) (MonoidHom.fst G E)) x y }

@[simp] theorem mFQuot.prod_righttrivial_equivapply
    (G E : Type*) [Group G] [Group E] [Subsingleton E]
    (x : mFQuot p (G × E)) :
    mFQuot.prod_right_trivialequiv (p := p) G E x =
      mFQuot.map (p := p) (MonoidHom.fst G E) x := rfl

@[simp] theorem mFQuot.prodright_trivialequiv_symmapply
    (G E : Type*) [Group G] [Group E] [Subsingleton E]
    (x : mFQuot p G) :
    (mFQuot.prod_right_trivialequiv (p := p) G E).symm x =
      mFQuot.map (p := p) (MonoidHom.inl G E) x := rfl


@[simp] theorem mFQuot.prod_righttrivial_equivmk
    (G E : Type*) [Group G] [Group E] [Subsingleton E] (g : G) (e : E) :
    mFQuot.prod_right_trivialequiv (p := p) G E
      (mFQuot.mk p (G × E) (g, e)) =
    mFQuot.mk p G g := rfl

@[simp] theorem mFQuot.prodright_trivialequiv_symmmk
    (G E : Type*) [Group G] [Group E] [Subsingleton E] (g : G) :
    (mFQuot.prod_right_trivialequiv (p := p) G E).symm
      (mFQuot.mk p G g) =
    mFQuot.mk p (G × E) (g, 1) := rfl

/-- Left projection is a multiplicative equivalence on Frattini quotients when the
left factor is a subsingleton group. -/
noncomputable def mFQuot.prod_left_trivialequiv
    (E G : Type*) [Group E] [Group G] [Subsingleton E] :
    mFQuot p (E × G) ≃* mFQuot p G :=
{ toFun := mFQuot.map (p := p) (MonoidHom.snd E G)
  invFun := mFQuot.map (p := p) (MonoidHom.inr E G)
  left_inv := by
    intro x
    refine QuotientGroup.induction_on x ?_
    intro a
    rcases a with ⟨e, g⟩
    have he : e = 1 := Subsingleton.elim e 1
    subst e
    rfl
  right_inv := by
    intro x
    refine QuotientGroup.induction_on x ?_
    intro g
    rfl
  map_mul' := by
    intro x y
    exact map_mul (mFQuot.map (p := p) (MonoidHom.snd E G)) x y }

@[simp] theorem mFQuot.prod_lefttrivial_equivapply
    (E G : Type*) [Group E] [Group G] [Subsingleton E]
    (x : mFQuot p (E × G)) :
    mFQuot.prod_left_trivialequiv (p := p) E G x =
      mFQuot.map (p := p) (MonoidHom.snd E G) x := rfl

@[simp] theorem mFQuot.prodleft_trivialequiv_symmapply
    (E G : Type*) [Group E] [Group G] [Subsingleton E]
    (x : mFQuot p G) :
    (mFQuot.prod_left_trivialequiv (p := p) E G).symm x =
      mFQuot.map (p := p) (MonoidHom.inr E G) x := rfl

@[simp] theorem mFQuot.prod_lefttrivial_equivmk
    (E G : Type*) [Group E] [Group G] [Subsingleton E] (e : E) (g : G) :
    mFQuot.prod_left_trivialequiv (p := p) E G
      (mFQuot.mk p (E × G) (e, g)) =
    mFQuot.mk p G g := rfl

@[simp] theorem mFQuot.prodleft_trivialequiv_symmmk
    (E G : Type*) [Group E] [Group G] [Subsingleton E] (g : G) :
    (mFQuot.prod_left_trivialequiv (p := p) E G).symm
      (mFQuot.mk p G g) =
    mFQuot.mk p (E × G) (1, g) := rfl


/-- Naturality of the right trivial-factor quotient equivalence. -/
theorem mFQuot.prod_righttrivial_equivnatural
    {G₁ G₂ E₁ E₂ : Type*} [Group G₁] [Group G₂] [Group E₁] [Group E₂]
    [Subsingleton E₁] [Subsingleton E₂]
    (f : G₁ →* G₂) (e : E₁ →* E₂)
    (x : mFQuot p (G₁ × E₁)) :
    mFQuot.map (p := p) f
        (mFQuot.prod_right_trivialequiv (p := p) G₁ E₁ x) =
      mFQuot.prod_right_trivialequiv (p := p) G₂ E₂
        (mFQuot.map (p := p) (MonoidHom.prodMap f e) x) := by
  refine QuotientGroup.induction_on x ?_
  intro a
  rcases a with ⟨g, t⟩
  rfl

/-- Naturality of the inverse right trivial-factor quotient equivalence. -/
theorem mFQuot.prodright_trivialequiv_symmnatural
    {G₁ G₂ E₁ E₂ : Type*} [Group G₁] [Group G₂] [Group E₁] [Group E₂]
    [Subsingleton E₁] [Subsingleton E₂]
    (f : G₁ →* G₂) (e : E₁ →* E₂)
    (x : mFQuot p G₁) :
    mFQuot.map (p := p) (MonoidHom.prodMap f e)
        ((mFQuot.prod_right_trivialequiv (p := p) G₁ E₁).symm x) =
      (mFQuot.prod_right_trivialequiv (p := p) G₂ E₂).symm
        (mFQuot.map (p := p) f x) := by
  refine QuotientGroup.induction_on x ?_
  intro g
  change mFQuot.mk p (G₂ × E₂) (f g, e 1) =
    mFQuot.mk p (G₂ × E₂) (f g, 1)
  rw [map_one]

/-- Naturality of the left trivial-factor quotient equivalence. -/
theorem mFQuot.prod_lefttrivial_equivnatural
    {E₁ E₂ G₁ G₂ : Type*} [Group E₁] [Group E₂] [Group G₁] [Group G₂]
    [Subsingleton E₁] [Subsingleton E₂]
    (e : E₁ →* E₂) (f : G₁ →* G₂)
    (x : mFQuot p (E₁ × G₁)) :
    mFQuot.map (p := p) f
        (mFQuot.prod_left_trivialequiv (p := p) E₁ G₁ x) =
      mFQuot.prod_left_trivialequiv (p := p) E₂ G₂
        (mFQuot.map (p := p) (MonoidHom.prodMap e f) x) := by
  refine QuotientGroup.induction_on x ?_
  intro a
  rcases a with ⟨t, g⟩
  rfl

/-- Naturality of the inverse left trivial-factor quotient equivalence. -/
theorem mFQuot.prodleft_trivialequiv_symmnatural
    {E₁ E₂ G₁ G₂ : Type*} [Group E₁] [Group E₂] [Group G₁] [Group G₂]
    [Subsingleton E₁] [Subsingleton E₂]
    (e : E₁ →* E₂) (f : G₁ →* G₂)
    (x : mFQuot p G₁) :
    mFQuot.map (p := p) (MonoidHom.prodMap e f)
        ((mFQuot.prod_left_trivialequiv (p := p) E₁ G₁).symm x) =
      (mFQuot.prod_left_trivialequiv (p := p) E₂ G₂).symm
        (mFQuot.map (p := p) f x) := by
  refine QuotientGroup.induction_on x ?_
  intro g
  change mFQuot.mk p (E₂ × G₂) (e 1, f g) =
    mFQuot.mk p (E₂ × G₂) (1, f g)
  rw [map_one]

/-- Inverse product splitting with a trivial right factor ignores the trivial coordinate. -/
@[simp] theorem mFQuot.prod_equivsymm_righttrivial
    (G E : Type*) [Group G] [Group E] [Subsingleton E]
    (x : mFQuot p G) (y : mFQuot p E) :
    (mFQuot.prodEquiv p G E).symm (x, y) =
      (mFQuot.prod_right_trivialequiv (p := p) G E).symm x := by
  have hy : y = 1 := Subsingleton.elim y 1
  subst y
  simp [mFQuot.prodright_trivialequiv_symmapply]

/-- Inverse product splitting with a trivial left factor ignores the trivial coordinate. -/
@[simp] theorem mFQuot.prod_equivsymm_lefttrivial
    (E G : Type*) [Group E] [Group G] [Subsingleton E]
    (x : mFQuot p E) (y : mFQuot p G) :
    (mFQuot.prodEquiv p E G).symm (x, y) =
      (mFQuot.prod_left_trivialequiv (p := p) E G).symm y := by
  have hx : x = 1 := Subsingleton.elim x 1
  subst x
  simp [mFQuot.prodleft_trivialequiv_symmapply]

/-- Splitting the inverse right-trivial unitor recovers the original coordinate and
the unique trivial coordinate. -/
@[simp] theorem mFQuot.prodequiv_prodright_trivequisymm
    (G E : Type*) [Group G] [Group E] [Subsingleton E]
    (x : mFQuot p G) :
    mFQuot.prodEquiv p G E
        ((mFQuot.prod_right_trivialequiv (p := p) G E).symm x) =
      (x, 1) := by
  refine QuotientGroup.induction_on x ?_
  intro g
  rfl

/-- Splitting the inverse left-trivial unitor recovers the unique trivial
coordinate and the original coordinate. -/
@[simp] theorem mFQuot.prodequiv_prodleft_trivequisymm
    (E G : Type*) [Group E] [Group G] [Subsingleton E]
    (x : mFQuot p G) :
    mFQuot.prodEquiv p E G
        ((mFQuot.prod_left_trivialequiv (p := p) E G).symm x) =
      (1, x) := by
  refine QuotientGroup.induction_on x ?_
  intro g
  rfl



/-- The Frattini quotient map induced by swapping product factors is involutive. -/
@[simp] theorem mFQuot.mapprod_commmap_prodcomm
    (G H : Type*) [Group G] [Group H]
    (x : mFQuot p (G × H)) :
    mFQuot.map (p := p)
        (MulEquiv.prodComm (M := H) (N := G)).toMonoidHom
        (mFQuot.map (p := p)
          (MulEquiv.prodComm (M := G) (N := H)).toMonoidHom x) = x := by
  refine QuotientGroup.induction_on x ?_
  intro a
  rcases a with ⟨a, b⟩
  rfl



/-- The quotient equivalence induced by swapping the two factors of a product. -/
noncomputable def mFQuot.prodCommEquiv (G H : Type*) [Group G] [Group H] :
    mFQuot p (G × H) ≃* mFQuot p (H × G) :=
{ toFun := mFQuot.map (p := p)
    (MulEquiv.prodComm (M := G) (N := H)).toMonoidHom
  invFun := mFQuot.map (p := p)
    (MulEquiv.prodComm (M := H) (N := G)).toMonoidHom
  left_inv := by
    intro x
    exact mFQuot.mapprod_commmap_prodcomm (p := p) G H x
  right_inv := by
    intro x
    exact mFQuot.mapprod_commmap_prodcomm (p := p) H G x
  map_mul' := by
    intro x y
    exact map_mul _ x y }

@[simp] theorem mFQuot.prod_comm_equivapply
    (G H : Type*) [Group G] [Group H]
    (x : mFQuot p (G × H)) :
    mFQuot.prodCommEquiv (p := p) G H x =
      mFQuot.map (p := p)
        (MulEquiv.prodComm (M := G) (N := H)).toMonoidHom x := rfl

@[simp] theorem mFQuot.prod_comm_equivsymm
    (G H : Type*) [Group G] [Group H] :
    (mFQuot.prodCommEquiv (p := p) G H).symm =
      mFQuot.prodCommEquiv (p := p) H G := by
  rfl


/-- Swapping a product with a trivial right factor and then deleting it agrees with
deleting the right factor directly. -/
theorem mFQuot.prod_commequiv_trivialright
    (G E : Type*) [Group G] [Group E] [Subsingleton E]
    (x : mFQuot p (G × E)) :
    mFQuot.prod_left_trivialequiv (p := p) E G
        (mFQuot.prodCommEquiv (p := p) G E x) =
      mFQuot.prod_right_trivialequiv (p := p) G E x := by
  refine QuotientGroup.induction_on x ?_
  intro a
  rcases a with ⟨g, e⟩
  rfl

/-- Swapping a product with a trivial left factor and then deleting it agrees with
deleting the left factor directly. -/
theorem mFQuot.prod_commequiv_trivialleft
    (E G : Type*) [Group E] [Group G] [Subsingleton E]
    (x : mFQuot p (E × G)) :
    mFQuot.prod_right_trivialequiv (p := p) G E
        (mFQuot.prodCommEquiv (p := p) E G x) =
      mFQuot.prod_left_trivialequiv (p := p) E G x := by
  refine QuotientGroup.induction_on x ?_
  intro a
  rcases a with ⟨e, g⟩
  rfl

/-- Naturality of the quotient swap map under factorwise product maps. -/
theorem mFQuot.map_prod_commnatural
    {G₁ G₂ H₁ H₂ : Type*} [Group G₁] [Group G₂] [Group H₁] [Group H₂]
    (f : G₁ →* G₂) (g : H₁ →* H₂)
    (x : mFQuot p (G₁ × H₁)) :
    mFQuot.map (p := p) (MonoidHom.prodMap g f)
        (mFQuot.map (p := p)
          (MulEquiv.prodComm (M := G₁) (N := H₁)).toMonoidHom x) =
      mFQuot.map (p := p)
        (MulEquiv.prodComm (M := G₂) (N := H₂)).toMonoidHom
        (mFQuot.map (p := p) (MonoidHom.prodMap f g) x) := by
  refine QuotientGroup.induction_on x ?_
  intro a
  rcases a with ⟨a, b⟩
  rfl

/-- Packaged quotient swap naturality under factorwise product maps. -/
theorem mFQuot.prod_comm_equivnatural
    {G₁ G₂ H₁ H₂ : Type*} [Group G₁] [Group G₂] [Group H₁] [Group H₂]
    (f : G₁ →* G₂) (g : H₁ →* H₂)
    (x : mFQuot p (G₁ × H₁)) :
    mFQuot.map (p := p) (MonoidHom.prodMap g f)
        (mFQuot.prodCommEquiv (p := p) G₁ H₁ x) =
      mFQuot.prodCommEquiv (p := p) G₂ H₂
        (mFQuot.map (p := p) (MonoidHom.prodMap f g) x) := by
  simpa using mFQuot.map_prod_commnatural (p := p) f g x


/-- Product equivalence formula using the packaged swap equivalence. -/
theorem mFQuot.prod_equivprod_commequiv
    (G H : Type*) [Group G] [Group H]
    (x : mFQuot p (G × H)) :
    mFQuot.prodEquiv p H G
        (mFQuot.prodCommEquiv (p := p) G H x) =
      ((mFQuot.prodEquiv p G H x).2,
        (mFQuot.prodEquiv p G H x).1) := by
  simpa using mFQuot.prod_equivmap_prodcomm (p := p) G H x

/-- Swapping after first-factor insertion gives second-factor insertion. -/
@[simp] theorem mFQuot.map_prod_comminl
    (G H : Type*) [Group G] [Group H]
    (x : mFQuot p G) :
    mFQuot.map (p := p)
        (MulEquiv.prodComm (M := G) (N := H)).toMonoidHom
        (mFQuot.map (p := p) (MonoidHom.inl G H) x) =
      mFQuot.map (p := p) (MonoidHom.inr H G) x := by
  refine QuotientGroup.induction_on x ?_
  intro a
  rfl

/-- Swapping after second-factor insertion gives first-factor insertion. -/
@[simp] theorem mFQuot.map_prod_comminr
    (G H : Type*) [Group G] [Group H]
    (x : mFQuot p H) :
    mFQuot.map (p := p)
        (MulEquiv.prodComm (M := G) (N := H)).toMonoidHom
        (mFQuot.map (p := p) (MonoidHom.inr G H) x) =
      mFQuot.map (p := p) (MonoidHom.inl H G) x := by
  refine QuotientGroup.induction_on x ?_
  intro b
  rfl

/-- First projection after swapping factors is the original second projection. -/
@[simp] theorem mFQuot.map_fst_prodcomm
    (G H : Type*) [Group G] [Group H]
    (x : mFQuot p (G × H)) :
    mFQuot.map (p := p) (MonoidHom.fst H G)
        (mFQuot.map (p := p)
          (MulEquiv.prodComm (M := G) (N := H)).toMonoidHom x) =
      mFQuot.map (p := p) (MonoidHom.snd G H) x := by
  refine QuotientGroup.induction_on x ?_
  intro a
  rcases a with ⟨a, b⟩
  rfl

/-- Second projection after swapping factors is the original first projection. -/
@[simp] theorem mFQuot.map_snd_prodcomm
    (G H : Type*) [Group G] [Group H]
    (x : mFQuot p (G × H)) :
    mFQuot.map (p := p) (MonoidHom.snd H G)
        (mFQuot.map (p := p)
          (MulEquiv.prodComm (M := G) (N := H)).toMonoidHom x) =
      mFQuot.map (p := p) (MonoidHom.fst G H) x := by
  refine QuotientGroup.induction_on x ?_
  intro a
  rcases a with ⟨a, b⟩
  rfl

/-- Inverse product equivalences are compatible with swapping the two factors. -/
theorem mFQuot.mapprod_commprod_equivsymm
    (G H : Type*) [Group G] [Group H]
    (x : mFQuot p G × mFQuot p H) :
    mFQuot.map (p := p)
        (MulEquiv.prodComm (M := G) (N := H)).toMonoidHom
        ((mFQuot.prodEquiv p G H).symm x) =
      (mFQuot.prodEquiv p H G).symm (x.2, x.1) := by
  rcases x with ⟨x, y⟩
  refine QuotientGroup.induction_on x ?_
  intro a
  refine QuotientGroup.induction_on y ?_
  intro b
  change mFQuot.map (p := p)
      (MulEquiv.prodComm (M := G) (N := H)).toMonoidHom
      ((mFQuot.prodEquiv p G H).symm
        (QuotientGroup.mk' (modPFrattini p G) a,
          QuotientGroup.mk' (modPFrattini p H) b)) =
    (mFQuot.prodEquiv p H G).symm
      (QuotientGroup.mk' (modPFrattini p H) b,
        QuotientGroup.mk' (modPFrattini p G) a)
  rw [mFQuot.prod_equiv_symmmk]
  rw [mFQuot.prod_equiv_symmmk]
  rfl

/-- Naturality of the inverse Frattini product quotient equivalence. -/
theorem mFQuot.prod_equiv_symmnatural
    {G₁ G₂ H₁ H₂ : Type*} [Group G₁] [Group G₂] [Group H₁] [Group H₂]
    (f : G₁ →* G₂) (g : H₁ →* H₂)
    (x : mFQuot p G₁ × mFQuot p H₁) :
    mFQuot.map (p := p) (MonoidHom.prodMap f g)
        ((mFQuot.prodEquiv p G₁ H₁).symm x) =
      (mFQuot.prodEquiv p G₂ H₂).symm
        (mFQuot.map (p := p) f x.1,
          mFQuot.map (p := p) g x.2) := by
  rcases x with ⟨x, y⟩
  refine QuotientGroup.induction_on x ?_
  intro a
  refine QuotientGroup.induction_on y ?_
  intro b
  change mFQuot.map (p := p) (MonoidHom.prodMap f g)
      ((mFQuot.prodEquiv p G₁ H₁).symm
        (QuotientGroup.mk' (modPFrattini p G₁) a,
          QuotientGroup.mk' (modPFrattini p H₁) b)) =
    (mFQuot.prodEquiv p G₂ H₂).symm
      (QuotientGroup.mk' (modPFrattini p G₂) (f a),
        QuotientGroup.mk' (modPFrattini p H₂) (g b))
  rw [mFQuot.prod_equiv_symmmk]
  rw [mFQuot.prod_equiv_symmmk]
  rfl


/-- Associator sends first-factor insertion to first-factor insertion on quotient products. -/
@[simp] theorem mFQuot.map_prodassoc_inlinl
    (G H K : Type*) [Group G] [Group H] [Group K]
    (x : mFQuot p G) :
    mFQuot.map (p := p)
        (MulEquiv.prodAssoc (M := G) (N := H) (P := K)).toMonoidHom
        (mFQuot.map (p := p) (MonoidHom.inl (G × H) K)
          (mFQuot.map (p := p) (MonoidHom.inl G H) x)) =
      mFQuot.map (p := p) (MonoidHom.inl G (H × K)) x := by
  refine QuotientGroup.induction_on x ?_
  intro a
