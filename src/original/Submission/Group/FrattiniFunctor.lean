    {G₁ G₂ H₁ H₂ : Type*} [Group G₁] [Group G₂] [Group H₁] [Group H₂]
    (f : G₁ →* G₂) (g : H₁ →* H₂) (x : mFAdditi p G₁) :
    mFAdditi.mapAdd (p := p) (MonoidHom.prodMap f g)
        (mFAdditi.mapAdd (p := p) (MonoidHom.inl G₁ H₁) x) =
      mFAdditi.mapAdd (p := p) (MonoidHom.inl G₂ H₂)
        (mFAdditi.mapAdd (p := p) f x) := by
  change ((mFAdditi.mapAdd (p := p) (MonoidHom.prodMap f g)).comp
      (mFAdditi.mapAdd (p := p) (MonoidHom.inl G₁ H₁))) x =
    ((mFAdditi.mapAdd (p := p) (MonoidHom.inl G₂ H₂)).comp
      (mFAdditi.mapAdd (p := p) f)) x
  rw [← mFAdditi.mapAdd_comp, ← mFAdditi.mapAdd_comp]
  have hcomp : (MonoidHom.prodMap f g).comp (MonoidHom.inl G₁ H₁) =
      (MonoidHom.inl G₂ H₂).comp f := by
    ext a <;> simp [MonoidHom.inl, MonoidHom.prodMap]
  rw [hcomp]

