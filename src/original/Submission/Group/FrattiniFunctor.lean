namespace Submission

variable (p : ℕ) {G H : Type*} [Group G] [Group H]

/-- A surjective homomorphism induces a surjective map on mod-`p` Frattini quotients. -/
theorem mFQuot.map_surjective (f : G →* H)
    (hs : Function.Surjective f) :
    Function.Surjective (mFQuot.map (p := p) f) := by
  intro q
  refine QuotientGroup.induction_on q ?_
  intro h
  rcases hs h with ⟨g, rfl⟩
  exact ⟨mFQuot.mk p G g, rfl⟩

/-- Additive surjectivity on mod-`p` Frattini quotients. -/
theorem mFAdditi.mapAdd_surjective (f : G →* H)
    (hs : Function.Surjective f) :
    Function.Surjective (mFAdditi.mapAdd (p := p) f) := by
  intro y
  induction y using Additive.rec with
  | ofMul q =>
      rcases mFQuot.map_surjective (p := p) f hs q with ⟨x, rfl⟩
      exact ⟨Additive.ofMul x, rfl⟩

/-- Linear surjectivity on mod-`p` Frattini quotients. -/
theorem mFAdditi.mapLinear_surjective (f : G →* H)
    (hs : Function.Surjective f) :
    Function.Surjective (mFAdditi.mapLinear (p := p) f) := by
  simpa [mFAdditi.mapLinear_apply] using
    mFAdditi.mapAdd_surjective (p := p) f hs



/-- Kernel of the induced Frattini quotient map as the image of the preimage
subgroup in the source quotient. -/
theorem mFQuot.ker_mapeq_mapcomap (f : G →* H) :
    MonoidHom.ker (mFQuot.map (p := p) f) =
      ((modPFrattini p H).comap f).map (QuotientGroup.mk' (modPFrattini p G)) := by
  ext q
  constructor
  · intro hq
    refine QuotientGroup.induction_on q ?_ hq
    intro g hg
    change mFQuot.map (p := p) f
        (QuotientGroup.mk' (modPFrattini p G) g) = 1 at hg
    change QuotientGroup.mk' (modPFrattini p H) (f g) = 1 at hg
    have hgmem : g ∈ (modPFrattini p H).comap f :=
      (QuotientGroup.eq_one_iff (N := modPFrattini p H) (f g)).1 hg
    exact ⟨g, hgmem, rfl⟩
  · intro hq
    rcases hq with ⟨g, hg, rfl⟩
    change mFQuot.map (p := p) f
        (QuotientGroup.mk' (modPFrattini p G) g) = 1
    change QuotientGroup.mk' (modPFrattini p H) (f g) = 1
    exact (QuotientGroup.eq_one_iff (N := modPFrattini p H) (f g)).2 hg

/-- For a surjection, the kernel of the induced Frattini quotient map is represented
by `(G^p [G,G] ⊔ ker f)/G^p [G,G]`. -/
theorem mFQuot.kermap_eqmap_supkersurj
    (f : G →* H) (hs : Function.Surjective f) :
    MonoidHom.ker (mFQuot.map (p := p) f) =
      (modPFrattini p G ⊔ f.ker).map (QuotientGroup.mk' (modPFrattini p G)) := by
  rw [mFQuot.ker_mapeq_mapcomap (p := p) f,
    mod_comap_surjective (p := p) f hs]


/-- The kernel of an induced Frattini quotient map as a quotient of the preimage
Frattini subgroup by the source Frattini subgroup. -/
noncomputable def mFQuot.kernelEquiv (f : G →* H) :
    ((modPFrattini p H).comap f) ⧸
      ((modPFrattini p G).subgroupOf ((modPFrattini p H).comap f)) ≃*
        MonoidHom.ker (mFQuot.map (p := p) f) := by
  let C : Subgroup G := (modPFrattini p H).comap f
  let N : Subgroup C := (modPFrattini p G).subgroupOf C
  let kmap : C →* MonoidHom.ker (mFQuot.map (p := p) f) :=
  { toFun := fun c => ⟨QuotientGroup.mk' (modPFrattini p G) (c : G), by
      change mFQuot.map (p := p) f
        (QuotientGroup.mk' (modPFrattini p G) (c : G)) = 1
      change QuotientGroup.mk' (modPFrattini p H) (f (c : G)) = 1
      exact (QuotientGroup.eq_one_iff (N := modPFrattini p H) (f (c : G))).2 c.property⟩
    map_one' := by ext; simp
    map_mul' := by intro a b; ext; simp }
  have hk_surj : Function.Surjective kmap := by
    intro q
    rcases q with ⟨q, hq⟩
    refine QuotientGroup.induction_on q ?_ hq
    intro g hg
    change mFQuot.map (p := p) f
      (QuotientGroup.mk' (modPFrattini p G) g) = 1 at hg
    change QuotientGroup.mk' (modPFrattini p H) (f g) = 1 at hg
    have gc : g ∈ C := (QuotientGroup.eq_one_iff (N := modPFrattini p H) (f g)).1 hg
    refine ⟨⟨g, gc⟩, ?_⟩
    ext
    rfl
  have hker : MonoidHom.ker kmap = N := by
    ext c
    constructor
    · intro hc
      have hcval := congrArg Subtype.val hc
      change QuotientGroup.mk' (modPFrattini p G) (c : G) = 1 at hcval
      exact (QuotientGroup.eq_one_iff (N := modPFrattini p G) (c : G)).1 hcval
    · intro hc
      ext
      change QuotientGroup.mk' (modPFrattini p G) (c : G) = 1
      exact (QuotientGroup.eq_one_iff (N := modPFrattini p G) (c : G)).2 hc
  refine (QuotientGroup.quotientMulEquivOfEq ?_).trans
    (QuotientGroup.quotientKerEquivOfSurjective kmap hk_surj)
  exact hker.symm

/-- Kernel membership for a representative in the induced Frattini quotient map,
under a surjective homomorphism. -/
@[simp] theorem mFQuot.mapmk_eqone_iffsurj
    (f : G →* H) (hs : Function.Surjective f) (g : G) :
    mFQuot.map (p := p) f (mFQuot.mk p G g) = 1 ↔
      g ∈ modPFrattini p G ⊔ f.ker := by
  change (f g : mFQuot p H) = 1 ↔ _
  rw [QuotientGroup.eq_one_iff (N := modPFrattini p H) (f g)]
  change g ∈ (modPFrattini p H).comap f ↔ _
  rw [mod_comap_surjective (p := p) f hs]

/-- Equality criterion for two representatives under the induced Frattini quotient map,
under a surjective homomorphism. -/
theorem mFQuot.mapmk_eqmk_iffsurj
    (f : G →* H) (hs : Function.Surjective f) (x y : G) :
    mFQuot.map (p := p) f (mFQuot.mk p G x) =
      mFQuot.map (p := p) f (mFQuot.mk p G y) ↔
      x⁻¹ * y ∈ modPFrattini p G ⊔ f.ker := by
  change (f x : mFQuot p H) =
      (f y : mFQuot p H) ↔ _
  rw [QuotientGroup.eq]
  have hmap : (f x)⁻¹ * f y = f (x⁻¹ * y) := by simp
  rw [hmap]
  change x⁻¹ * y ∈ (modPFrattini p H).comap f ↔ _
  rw [mod_comap_surjective (p := p) f hs]


/-- For a surjective homomorphism, kernel contained in `G^p [G,G]` implies the
induced map on mod-`p` Frattini quotients is injective. -/
theorem mFQuot.map_injective_ker (f : G →* H)
    (hs : Function.Surjective f) (hker : f.ker ≤ modPFrattini p G) :
    Function.Injective (mFQuot.map (p := p) f) := by
  intro a b hab
  revert b hab
  refine QuotientGroup.induction_on a ?_
  intro x b hab
  revert hab
  refine QuotientGroup.induction_on b ?_
  intro y hab
  apply QuotientGroup.eq.mpr
  have ht : x⁻¹ * y ∈ (modPFrattini p H).comap f := by
    change f (x⁻¹ * y) ∈ modPFrattini p H
    change QuotientGroup.mk' (modPFrattini p H) (f x) =
      QuotientGroup.mk' (modPFrattini p H) (f y) at hab
    simpa [map_mul, map_inv] using (QuotientGroup.eq.mp hab)
  rw [mod_comap_surjective (p := p) f hs] at ht
  exact (sup_le le_rfl hker) ht

/-- If the induced map on mod-`p` Frattini quotients is injective, the kernel of
the original homomorphism lies in `G^p [G,G]`. -/
theorem ker_frattini_injective (f : G →* H)
    (hinj : Function.Injective (mFQuot.map (p := p) f)) :
    f.ker ≤ modPFrattini p G := by
  intro k hk
  have hq : mFQuot.map (p := p) f
        (mFQuot.mk p G k) =
      mFQuot.map (p := p) f
        (mFQuot.mk p G 1) := by
    change (mFQuot.mk p H) (f k) =
      (mFQuot.mk p H) (f 1)
    rw [show f k = 1 from hk]
    simp
  have heq := hinj hq
  change QuotientGroup.mk' (modPFrattini p G) k =
    QuotientGroup.mk' (modPFrattini p G) 1 at heq
  simpa using (QuotientGroup.eq.mp heq)


/-- A surjection with kernel in `G^p [G,G]` induces a bijection on mod-`p`
Frattini quotients. -/
theorem mFQuot.map_bijsurj_kerle (f : G →* H)
    (hs : Function.Surjective f) (hker : f.ker ≤ modPFrattini p G) :
    Function.Bijective (mFQuot.map (p := p) f) :=
  ⟨mFQuot.map_injective_ker (p := p) f hs hker,
    mFQuot.map_surjective (p := p) f hs⟩

/-- Additive bijectivity version of `map_bijsurj_kerle`. -/
theorem mFAdditi.mapadd_bijsurj_kerle (f : G →* H)
    (hs : Function.Surjective f) (hker : f.ker ≤ modPFrattini p G) :
    Function.Bijective (mFAdditi.mapAdd (p := p) f) := by
  constructor
  · intro x y hxy
    induction x using Additive.rec with
    | ofMul x' =>
      induction y using Additive.rec with
      | ofMul y' =>
        apply congrArg Additive.ofMul
        exact (mFQuot.map_injective_ker (p := p) f hs hker) hxy
  · exact mFAdditi.mapAdd_surjective (p := p) f hs

/-- Linear bijectivity version of `map_bijsurj_kerle`. -/
theorem mFAdditi.maplin_bijsurj_kerle (f : G →* H)
    (hs : Function.Surjective f) (hker : f.ker ≤ modPFrattini p G) :
    Function.Bijective (mFAdditi.mapLinear (p := p) f) := by
  constructor
  · intro x y hxy
    exact (mFAdditi.mapadd_bijsurj_kerle
      (p := p) f hs hker).1 hxy
  · exact mFAdditi.mapLinear_surjective (p := p) f hs


/-- Additive injectivity criterion for induced Frattini quotient maps. -/
theorem mFAdditi.mapadd_injiff_kerle (f : G →* H)
    (hs : Function.Surjective f) :
    Function.Injective (mFAdditi.mapAdd (p := p) f) ↔
      f.ker ≤ modPFrattini p G := by
  constructor
  · intro hinj
    apply ker_frattini_injective (p := p) f
    intro a b h
    have ha : mFAdditi.mapAdd (p := p) f (Additive.ofMul a) =
        mFAdditi.mapAdd (p := p) f (Additive.ofMul b) := by
      change Additive.ofMul (mFQuot.map (p := p) f a) =
        Additive.ofMul (mFQuot.map (p := p) f b)
      rw [h]
    exact congrArg Additive.toMul (hinj ha)
  · intro hker
    exact (mFAdditi.mapadd_bijsurj_kerle
      (p := p) f hs hker).1

/-- Linear injectivity criterion for induced Frattini quotient maps. -/
theorem mFAdditi.maplin_injiff_kerle (f : G →* H)
    (hs : Function.Surjective f) :
    Function.Injective (mFAdditi.mapLinear (p := p) f) ↔
      f.ker ≤ modPFrattini p G := by
  constructor
  · intro hinj
    apply ker_frattini_injective (p := p) f
    intro a b h
    have ha : mFAdditi.mapLinear (p := p) f (Additive.ofMul a) =
        mFAdditi.mapLinear (p := p) f (Additive.ofMul b) := by
      change Additive.ofMul (mFQuot.map (p := p) f a) =
        Additive.ofMul (mFQuot.map (p := p) f b)
      rw [h]
    exact congrArg Additive.toMul (hinj ha)
  · intro hker
    exact (mFAdditi.maplin_bijsurj_kerle
      (p := p) f hs hker).1


/-- Additive bijectivity criterion for induced Frattini quotient maps. -/
theorem mFAdditi.mapadd_bijiff_kerle (f : G →* H)
    (hs : Function.Surjective f) :
    Function.Bijective (mFAdditi.mapAdd (p := p) f) ↔
      f.ker ≤ modPFrattini p G := by
  constructor
  · intro hb
    exact (mFAdditi.mapadd_injiff_kerle (p := p) f hs).mp hb.1
  · intro hker
    exact mFAdditi.mapadd_bijsurj_kerle
      (p := p) f hs hker

/-- Linear bijectivity criterion for induced Frattini quotient maps. -/
theorem mFAdditi.maplin_bijiff_kerle (f : G →* H)
    (hs : Function.Surjective f) :
    Function.Bijective (mFAdditi.mapLinear (p := p) f) ↔
      f.ker ≤ modPFrattini p G := by
  constructor
  · intro hb
    exact (mFAdditi.maplin_injiff_kerle (p := p) f hs).mp hb.1
  · intro hker
    exact mFAdditi.maplin_bijsurj_kerle
      (p := p) f hs hker

/-- For a surjective homomorphism, injectivity on mod-`p` Frattini quotients is
equivalent to having kernel contained in the source mod-`p` Frattini subgroup. -/
theorem mFQuot.map_injiff_kerle (f : G →* H)
    (hs : Function.Surjective f) :
    Function.Injective (mFQuot.map (p := p) f) ↔
      f.ker ≤ modPFrattini p G :=
  ⟨ker_frattini_injective (p := p) f,
    mFQuot.map_injective_ker (p := p) f hs⟩

end Submission
