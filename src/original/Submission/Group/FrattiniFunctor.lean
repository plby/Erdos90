/-- The quotient equivalence induced by associating three product factors. -/
noncomputable def mFQuot.prodAssocEquiv
    (G H K : Type*) [Group G] [Group H] [Group K] :
    mFQuot p ((G × H) × K) ≃*
      mFQuot p (G × H × K) :=
{ toFun := mFQuot.map (p := p)
    (MulEquiv.prodAssoc (M := G) (N := H) (P := K)).toMonoidHom
  invFun := mFQuot.map (p := p)
    (MulEquiv.prodAssoc (M := G) (N := H) (P := K)).symm.toMonoidHom
  left_inv := by
    intro x
    exact mFQuot.mapprod_assocsymm_mapprodassoc (p := p) G H K x
  right_inv := by
    intro x
    exact mFQuot.mapprod_assocmap_prodassocsymm (p := p) G H K x
  map_mul' := by
    intro x y
    exact map_mul _ x y }

/-- Packaged quotient associator naturality under factorwise product maps. -/
theorem mFQuot.prod_assoc_equivnatural
    {G₁ G₂ H₁ H₂ K₁ K₂ : Type*}
    [Group G₁] [Group G₂] [Group H₁] [Group H₂] [Group K₁] [Group K₂]
    (f : G₁ →* G₂) (g : H₁ →* H₂) (h : K₁ →* K₂)
    (x : mFQuot p ((G₁ × H₁) × K₁)) :
    mFQuot.map (p := p) (MonoidHom.prodMap f (MonoidHom.prodMap g h))
        (mFQuot.prodAssocEquiv (p := p) G₁ H₁ K₁ x) =
      mFQuot.prodAssocEquiv (p := p) G₂ H₂ K₂
        (mFQuot.map (p := p) (MonoidHom.prodMap (MonoidHom.prodMap f g) h) x) := by
  simpa using mFQuot.map_prod_assocnatural (p := p) f g h x

/-- Packaged inverse quotient associator naturality under factorwise product maps. -/
theorem mFQuot.prod_assocequiv_symmnatural
    {G₁ G₂ H₁ H₂ K₁ K₂ : Type*}
    [Group G₁] [Group G₂] [Group H₁] [Group H₂] [Group K₁] [Group K₂]
    (f : G₁ →* G₂) (g : H₁ →* H₂) (h : K₁ →* K₂)
    (x : mFQuot p (G₁ × H₁ × K₁)) :
    mFQuot.map (p := p) (MonoidHom.prodMap (MonoidHom.prodMap f g) h)
        ((mFQuot.prodAssocEquiv (p := p) G₁ H₁ K₁).symm x) =
      (mFQuot.prodAssocEquiv (p := p) G₂ H₂ K₂).symm
        (mFQuot.map (p := p) (MonoidHom.prodMap f (MonoidHom.prodMap g h)) x) := by
  simpa using mFQuot.map_prodassoc_symmnatural (p := p) f g h x


