/-- Extensionality for right-associated triple product Frattini classes via three projections. -/
theorem mFQuot.prod_triple_ext (G H K : Type*) [Group G] [Group H] [Group K]
    {x y : mFQuot p (G × H × K)}
    (h₁ : mFQuot.map (p := p) (MonoidHom.fst G (H × K)) x =
      mFQuot.map (p := p) (MonoidHom.fst G (H × K)) y)
    (h₂ : mFQuot.map (p := p) (MonoidHom.fst H K)
        (mFQuot.map (p := p) (MonoidHom.snd G (H × K)) x) =
      mFQuot.map (p := p) (MonoidHom.fst H K)
        (mFQuot.map (p := p) (MonoidHom.snd G (H × K)) y))
    (h₃ : mFQuot.map (p := p) (MonoidHom.snd H K)
        (mFQuot.map (p := p) (MonoidHom.snd G (H × K)) x) =
      mFQuot.map (p := p) (MonoidHom.snd H K)
        (mFQuot.map (p := p) (MonoidHom.snd G (H × K)) y)) : x = y := by
  apply mFQuot.prod_ext (p := p) G (H × K) h₁
  exact mFQuot.prod_ext (p := p) H K h₂ h₃


/-- Extensionality for left-associated triple product Frattini classes via three projections. -/
theorem mFQuot.prod_triple_leftext
    (G H K : Type*) [Group G] [Group H] [Group K]
    {x y : mFQuot p ((G × H) × K)}
    (h₁ : mFQuot.map (p := p) (MonoidHom.fst G H)
        (mFQuot.map (p := p) (MonoidHom.fst (G × H) K) x) =
      mFQuot.map (p := p) (MonoidHom.fst G H)
        (mFQuot.map (p := p) (MonoidHom.fst (G × H) K) y))
    (h₂ : mFQuot.map (p := p) (MonoidHom.snd G H)
        (mFQuot.map (p := p) (MonoidHom.fst (G × H) K) x) =
      mFQuot.map (p := p) (MonoidHom.snd G H)
        (mFQuot.map (p := p) (MonoidHom.fst (G × H) K) y))
    (h₃ : mFQuot.map (p := p) (MonoidHom.snd (G × H) K) x =
      mFQuot.map (p := p) (MonoidHom.snd (G × H) K) y) : x = y := by
  apply mFQuot.prod_ext (p := p) (G × H) K
  · exact mFQuot.prod_ext (p := p) G H h₁ h₂
  · exact h₃


/-- Inverse pentagon coherence for quotient product associator maps. -/
theorem mFQuot.map_prodassoc_symmpentagon
    (G H K L : Type*) [Group G] [Group H] [Group K] [Group L]
