import Submission.Group.Edmonton.CentralSeries
import Submission.Group.Edmonton.Polycyclic
import Mathlib.GroupTheory.FiniteAbelian.Basic
import Mathlib.GroupTheory.OrderOfElement
import Mathlib.GroupTheory.PGroup
import Mathlib.NumberTheory.SmoothNumbers

/-!
# The Edmonton Notes on Nilpotent Groups: finite torsion-generated groups

This file formalizes Hall's Theorem 1.10 and its corollary.
-/

namespace Submission
namespace Edmonton

open Group
open scoped commutatorElement

universe u v

variable {G : Type u} [Group G]

/-- Nilpotency class is invariant under group isomorphism. -/
lemma nilpotency_class_equiv
    {H : Type v} [Group H] [Group.IsNilpotent G] (e : G ≃* H) :
    Group.nilpotencyClass G = Group.nilpotencyClass H := by
  letI : Group.IsNilpotent H := Group.nilpotent_of_mulEquiv e
  apply le_antisymm
  · exact Group.nilpotencyClass_le_of_surjective e.symm.toMonoidHom e.symm.surjective
  · exact Group.nilpotencyClass_le_of_surjective e.toMonoidHom e.surjective

/-- Hall's subgroup `⟨x, G'⟩` is normal in `G`. -/
lemma generator_derived_normal (x : G) :
    (generatorDerivedSubgroup x).Normal := by
  apply Subgroup.commutator_top_left_le_iff.mp
  exact
    (Subgroup.commutator_mono le_rfl le_top).trans
      (show commutator G ≤ generatorDerivedSubgroup x from le_sup_right)

/-- The normal closure of `x` is contained in Hall's subgroup `⟨x, G'⟩`. -/
lemma normal_singleton_derived (x : G) :
    Subgroup.normalClosure {x} ≤ generatorDerivedSubgroup x := by
  letI : (generatorDerivedSubgroup x).Normal :=
    generator_derived_normal x
  apply Subgroup.normalClosure_le_normal
  intro y hy
  rw [Set.mem_singleton_iff.mp hy]
  exact
    (show Subgroup.closure {x} ≤ generatorDerivedSubgroup x from le_sup_left)
      (Subgroup.subset_closure (Set.mem_singleton x))

/-- Membership in a subgroup closure only uses finitely many generators. -/
lemma closure_finite_subset
    {C : Set G} {x : G} (hx : x ∈ Subgroup.closure C) :
    ∃ T : Set G, T.Finite ∧ T ⊆ C ∧ x ∈ Subgroup.closure T := by
  induction hx using Subgroup.closure_induction with
  | mem x hx =>
      exact ⟨{x}, Set.finite_singleton x, Set.singleton_subset_iff.mpr hx,
        Subgroup.subset_closure (Set.mem_singleton x)⟩
  | one =>
      exact ⟨∅, Set.finite_empty, Set.empty_subset C, Subgroup.one_mem _⟩
  | mul x y _ _ hx hy =>
      obtain ⟨S, hSfin, hSC, hxS⟩ := hx
      obtain ⟨T, hTfin, hTC, hyT⟩ := hy
      refine ⟨S ∪ T, hSfin.union hTfin, Set.union_subset hSC hTC, ?_⟩
      exact
        (Subgroup.closure (S ∪ T)).mul_mem
          (Subgroup.closure_mono Set.subset_union_left hxS)
          (Subgroup.closure_mono Set.subset_union_right hyT)
  | inv x _ hx =>
      obtain ⟨T, hTfin, hTC, hxT⟩ := hx
      exact ⟨T, hTfin, hTC, (Subgroup.closure T).inv_mem hxT⟩

/-- If a finitely generated subgroup is generated by a possibly infinite set,
then a finite subset of that set already generates it. -/
lemma subset_generates_fg
    {H : Subgroup G} (hHfg : H.FG) {C : Set G}
    (hHC : H = Subgroup.closure C) :
    ∃ T : Set G, T.Finite ∧ T ⊆ C ∧ Subgroup.closure T = H := by
  classical
  obtain ⟨S, hSgen, hSfin⟩ := (Subgroup.fg_iff H).mp hHfg
  have hmem : ∀ s : S, ∃ T : Set G,
      T.Finite ∧ T ⊆ C ∧ s.1 ∈ Subgroup.closure T := by
    intro s
    apply closure_finite_subset
    rw [← hHC, ← hSgen]
    exact Subgroup.subset_closure s.2
  choose T hTfin hTC hsT using hmem
  let U : Set G := ⋃ s : S, T s
  haveI : Finite S := hSfin
  have hUfin : U.Finite := Set.finite_iUnion hTfin
  have hUC : U ⊆ C := by
    intro x hx
    obtain ⟨s, hxT⟩ := Set.mem_iUnion.mp hx
    exact hTC s hxT
  refine ⟨U, hUfin, hUC, le_antisymm ?_ ?_⟩
  · rw [hHC]
    exact Subgroup.closure_mono hUC
  · rw [← hSgen, Subgroup.closure_le]
    intro s hs
    exact
      Subgroup.closure_mono
        (Set.subset_iUnion T ⟨s, hs⟩)
        (hsT ⟨s, hs⟩)

/-- A finitely generated normal closure is generated, as an ordinary
subgroup, by finitely many conjugates. -/
lemma normal_conjugate_generators
    (x : G) (hfg : (Subgroup.normalClosure {x}).FG) :
    ∃ T : Set G, T.Finite ∧ T ⊆ conjugatesOfSet {x} ∧
      Subgroup.closure T = Subgroup.normalClosure {x} := by
  apply subset_generates_fg hfg
  rfl

/-- Every chosen conjugate of `x` has finite order when `x` does. -/
lemma conjugates_set_singleton
    {x y : G} (hx : IsOfFinOrder x) (hy : y ∈ conjugatesOfSet {x}) :
    IsOfFinOrder y := by
  obtain ⟨z, hz, hzy⟩ := Group.mem_conjugatesOfSet_iff.mp hy
  rw [Set.mem_singleton_iff.mp hz] at hzy
  exact hzy.isOfFinOrder hx

/-- The supremum of two finite subgroups is finite when the second is
normal. -/
lemma sup_normal_right (H N : Subgroup G)
    [Finite H] [Finite N] [N.Normal] :
    Finite (H ⊔ N : Subgroup G) := by
  let f : H × N → (H ⊔ N : Subgroup G) := fun z ↦
    ⟨z.1.1 * z.2.1,
      (H ⊔ N).mul_mem
        ((show H ≤ H ⊔ N from le_sup_left) z.1.2)
        ((show N ≤ H ⊔ N from le_sup_right) z.2.2)⟩
  apply Finite.of_surjective f
  rintro ⟨g, hg⟩
  rw [← SetLike.mem_coe, Subgroup.mul_normal H N] at hg
  obtain ⟨h, hh, n, hn, rfl⟩ := hg
  exact ⟨(⟨h, hh⟩, ⟨n, hn⟩), rfl⟩

/-- A finite `Finset.sup` of finite normal subgroups is finite and normal. -/
lemma finset_sup_normal
    {ι : Type*} (S : Finset ι)
    (N : ι → Subgroup G) (hNnormal : ∀ i, (N i).Normal)
    (hNfinite : ∀ i ∈ S, Finite (N i)) :
    Finite (S.sup N : Subgroup G) ∧ (S.sup N : Subgroup G).Normal := by
  classical
  let p : Subgroup G → Prop := fun H ↦ Finite H ∧ H.Normal
  change p (S.sup N)
  apply Finset.sup_induction
  · exact ⟨inferInstance, inferInstance⟩
  · intro H hH K hK
    letI : Finite H := hH.1
    letI : H.Normal := hH.2
    letI : Finite K := hK.1
    letI : K.Normal := hK.2
    exact ⟨sup_normal_right H K, inferInstance⟩
  · intro i hi
    exact ⟨hNfinite i hi, hNnormal i⟩

/-- A finite supremum of finite normal subgroups is finite. -/
lemma bi_sup_normal
    {ι : Type*} {S : Set ι} (hS : S.Finite)
    (N : ι → Subgroup G) (hNnormal : ∀ i, (N i).Normal)
    (hNfinite : ∀ i ∈ S, Finite (N i)) :
    Finite ((⨆ i ∈ S, N i) : Subgroup G) ∧
      ((⨆ i ∈ S, N i) : Subgroup G).Normal := by
  classical
  simpa only [Finset.sup_eq_iSup, hS.mem_toFinset] using
    finset_sup_normal hS.toFinset N hNnormal
      (fun i hi ↦ hNfinite i (hS.mem_toFinset.mp hi))

/-- A nilpotent group generated by finitely many elements of finite order is
finite.  The parameter `c` is an upper bound for its nilpotency class and is
used for the induction. -/
theorem generators_nilpotency_class
    (c : ℕ) :
    ∀ {G : Type u} [Group G] [Group.IsNilpotent G] {S : Set G},
      Group.nilpotencyClass G ≤ c →
      S.Finite →
      Subgroup.closure S = ⊤ →
      (∀ x ∈ S, IsOfFinOrder x) →
      Finite G := by
  induction c using Nat.strong_induction_on with
  | h c ih =>
      intro G _ hnil S hclass hSfin hSgen hSorder
      by_cases hab : Group.nilpotencyClass G ≤ 1
      · letI : CommGroup G := commGroupOfNilpotencyClass hab
        letI : Group.FG G :=
          Group.fg_iff.mpr ⟨S, hSgen, hSfin⟩
        apply CommGroup.finite_of_fg_torsion
        intro g
        have hg : g ∈ Subgroup.closure S := by
          rw [hSgen]
          exact Subgroup.mem_top g
        induction hg using Subgroup.closure_induction with
        | mem x hx => exact hSorder x hx
        | one => simp
        | mul x y _ _ hx hy => exact hx.mul hy
        | inv x _ hx => exact hx.inv
      · have hclass_gt : 1 < Group.nilpotencyClass G := by omega
        letI : Group.FG G :=
          Group.fg_iff.mpr ⟨S, hSgen, hSfin⟩
        have hmax : SatisfiesMaximalCondition G :=
          polycyclic_implies_condition
            (supersoluble_implies_polycyclic
              fg_implies_supersoluble)
        have hnormalClosureFinite :
            ∀ x ∈ S, Finite (Subgroup.normalClosure {x}) := by
          intro x hxS
          let N : Subgroup G := Subgroup.normalClosure {x}
          have hNfg : N.FG := hmax N
          obtain ⟨T, hTfin, hTconj, hTgen⟩ :=
            normal_conjugate_generators x hNfg
          letI : Group.IsNilpotent N := Subgroup.isNilpotent N
          let H : Subgroup G := generatorDerivedSubgroup x
          have hN_le_H : N ≤ H :=
            normal_singleton_derived x
          let N' : Subgroup H := N.subgroupOf H
          letI : Group.IsNilpotent H := Subgroup.isNilpotent H
          letI : Group.IsNilpotent N' := Subgroup.isNilpotent N'
          have hclassN' :
              Group.nilpotencyClass N' ≤ Group.nilpotencyClass H :=
            N'.nilpotencyClass_le
          have heq :
              Group.nilpotencyClass N' = Group.nilpotencyClass N :=
            nilpotency_class_equiv
              (Subgroup.subgroupOfEquivOfLe hN_le_H)
          have hclassH :
              Group.nilpotencyClass H ≤ Group.nilpotencyClass G - 1 := by
            exact derived_nilpotency_class x
              ⟨hnil, rfl⟩ hclass_gt
          have hclassN :
              Group.nilpotencyClass N ≤ Group.nilpotencyClass G - 1 := by
            rw [← heq]
            exact hclassN'.trans hclassH
          have hbound_lt :
              Group.nilpotencyClass G - 1 < c := by
            omega
          let T' : Set N := N.subtype ⁻¹' T
          have hT'fin : T'.Finite := by
            exact hTfin.preimage N.subtype_injective.injOn
          have hT'gen : Subgroup.closure T' = ⊤ := by
            dsimp [T']
            change
              Subgroup.closure
                  ((Subgroup.normalClosure {x}).subtype ⁻¹' T) =
                ⊤
            rw [← hTgen]
            exact Subgroup.closure_preimage_eq_top T
          have hT'order : ∀ y ∈ T', IsOfFinOrder y := by
            intro y hy
            apply Submonoid.isOfFinOrder_coe.mp
            exact conjugates_set_singleton
              (hSorder x hxS) (hTconj hy)
          exact
            ih (Group.nilpotencyClass G - 1) hbound_lt hclassN
              hT'fin hT'gen hT'order
        let P : Subgroup G :=
          ⨆ x ∈ S, Subgroup.normalClosure {x}
        have hPfinite : Finite P := by
          dsimp [P]
          exact (bi_sup_normal hSfin
            (fun x ↦ Subgroup.normalClosure {x})
            (fun _ ↦ Subgroup.normalClosure_normal)
            hnormalClosureFinite).1
        letI : Finite P := hPfinite
        have hPtop : P = ⊤ := by
          apply eq_top_iff.mpr
          rw [← hSgen, Subgroup.closure_le]
          intro x hx
          have hle : Subgroup.normalClosure {x} ≤ P := by
            dsimp [P]
            exact le_iSup_of_le x (le_iSup_of_le hx le_rfl)
          exact hle (Subgroup.subset_normalClosure (Set.mem_singleton x))
        apply Finite.of_injective
          (fun g : G ↦
            (⟨g, hPtop.ge (Subgroup.mem_top g)⟩ : P))
        intro a b hab
        exact Subtype.ext_iff.mp hab

/-- If every prime divisor of `a` divides `b`, then `a` divides a power of
`b`. -/
lemma dvd_factors_subset
    {a b : ℕ} (ha : a ≠ 0) (hb : b ≠ 0)
    (hsub : a.primeFactors ⊆ b.primeFactors) :
    ∃ k : ℕ, a ∣ b ^ k := by
  refine ⟨a, (Nat.factorization_prime_le_iff_dvd ha (pow_ne_zero a hb)).mp ?_⟩
  intro p hp
  rw [Nat.factorization_pow]
  by_cases hpa : p ∣ a
  · have hp_mem_a : p ∈ a.primeFactors :=
      Nat.mem_primeFactors.mpr ⟨hp, hpa, ha⟩
    have hp_mem_b : p ∈ b.primeFactors := hsub hp_mem_a
    have hpb : p ∣ b := Nat.dvd_of_mem_primeFactors hp_mem_b
    have hfb : 1 ≤ b.factorization p :=
      (hp.dvd_iff_one_le_factorization hb).mp hpb
    have hfa : a.factorization p ≤ a :=
      (Nat.factorization_lt p ha).le
    exact hfa.trans (by
      simpa using (le_mul_of_one_le_right' hfb : a ≤ a * b.factorization p))
  · rw [Nat.factorization_eq_zero_of_not_dvd hpa]
    exact Nat.zero_le _

/-- In a finite nilpotent group, every prime dividing the group order
divides the order of one member of any finite generating set. -/
lemma subset_prod_order
    [Finite G] [Group.IsNilpotent G] (S : Finset G)
    (hSgen : Subgroup.closure (S : Set G) = ⊤) :
    (Nat.card G).primeFactors ⊆
      (∏ x ∈ S, orderOf x).primeFactors := by
  classical
  intro p hpCard
  have hp : p.Prime := Nat.prime_of_mem_primeFactors hpCard
  letI : Fact p.Prime := ⟨hp⟩
  let P : Sylow p G := default
  have hp_dvd_card : p ∣ Nat.card G :=
    Nat.dvd_of_mem_primeFactors hpCard
  have hPne : (P : Subgroup G) ≠ ⊥ :=
    P.ne_bot_of_dvd_card hp_dvd_card
  letI : Nontrivial P :=
    (P : Subgroup G).nontrivial_iff_ne_bot.mpr hPne
  obtain ⟨e⟩ :=
    ((Group.isNilpotent_of_finite_tfae (G := G)).out 0 4).mp
      (inferInstance : Group.IsNilpotent G)
  let f : G →* P :=
    (Pi.evalMonoidHom
        (fun Q : Sylow p G ↦ (Q : Subgroup G)) P).comp
      ((Pi.evalMonoidHom
          (fun q : (Nat.card G).primeFactors ↦
            ∀ Q : Sylow q G, (Q : Subgroup G))
          ⟨p, hpCard⟩).comp e.symm.toMonoidHom)
  have hf : Function.Surjective f := by
    exact
      (Function.surjective_eval P).comp
        ((Function.surjective_eval (⟨p, hpCard⟩ :
          (Nat.card G).primeFactors)).comp e.symm.surjective)
  have hex : ∃ x ∈ S, f x ≠ 1 := by
    by_contra h
    push Not at h
    have hker : Subgroup.closure (S : Set G) ≤ f.ker := by
      rw [Subgroup.closure_le]
      intro x hx
      exact MonoidHom.mem_ker.mpr (h x hx)
    have hkerTop : f.ker = ⊤ := by
      apply top_unique
      rw [← hSgen]
      exact hker
    have hfOne : f = 1 := MonoidHom.ker_eq_top_iff.mp hkerTop
    have hrangeTop : f.range = ⊤ :=
      f.range_eq_top_of_surjective hf
    have hbotTop : (⊥ : Subgroup P) = ⊤ := by
      simp [hfOne] at hrangeTop
    exact bot_ne_top hbotTop
  obtain ⟨x, hxS, hfx⟩ := hex
  obtain ⟨k, hk⟩ :=
    IsPGroup.iff_orderOf.mp P.isPGroup' (f x)
  have hk0 : k ≠ 0 := by
    intro hk0
    subst k
    apply hfx
    apply orderOf_eq_one_iff.mp
    simpa using hk
  have hp_dvd_image_order : p ∣ orderOf (f x) := by
    rw [hk]
    exact dvd_pow_self p hk0
  have hp_dvd_x_order : p ∣ orderOf x :=
    hp_dvd_image_order.trans (orderOf_map_dvd f x)
  have hp_dvd_product : p ∣ ∏ y ∈ S, orderOf y :=
    hp_dvd_x_order.trans (Finset.dvd_prod_of_mem orderOf hxS)
  have hproduct_ne_zero : ∏ y ∈ S, orderOf y ≠ 0 :=
    Finset.prod_ne_zero_iff.mpr fun y _ ↦ (orderOf_pos y).ne'
  exact Nat.mem_primeFactors.mpr ⟨hp, hp_dvd_product, hproduct_ne_zero⟩

/-- **Hall, Theorem 1.10.** A nilpotent group generated by finitely many
finite-order elements is finite, and its order divides a power of the product
of their orders. -/
theorem nilpotent_order_generators
    [Group.IsNilpotent G] (S : Finset G)
    (hSgen : Subgroup.closure (S : Set G) = ⊤)
    (hSorder : ∀ x ∈ S, IsOfFinOrder x) :
    Finite G ∧
      ∃ k : ℕ, Nat.card G ∣ (∏ x ∈ S, orderOf x) ^ k := by
  have hfinite : Finite G :=
    generators_nilpotency_class
      (Group.nilpotencyClass G) le_rfl S.finite_toSet hSgen hSorder
  letI : Finite G := hfinite
  refine ⟨hfinite, ?_⟩
  apply dvd_factors_subset
  · exact Nat.card_pos.ne'
  · exact Finset.prod_ne_zero_iff.mpr fun x _ ↦ (orderOf_pos x).ne'
  · exact subset_prod_order S hSgen

/-- The subgroup generated by an element and one conjugate is finite, with
order dividing a power of the element's order. -/
lemma pair_conjugate_dvd
    [Group.IsNilpotent G] (x g : G) (hx : IsOfFinOrder x) :
    let H := Subgroup.closure ({x, g * x * g⁻¹} : Set G)
    Finite H ∧ ∃ k : ℕ, Nat.card H ∣ orderOf x ^ k := by
  classical
  let A : Set G := {x, g * x * g⁻¹}
  let H : Subgroup G := Subgroup.closure A
  let AH : Set H := H.subtype ⁻¹' A
  have hAfin : A.Finite :=
    (Set.finite_singleton (g * x * g⁻¹)).insert x
  have hAHfin : AH.Finite := hAfin.preimage H.subtype_injective.injOn
  let S : Finset H := hAHfin.toFinset
  have hScoe : (S : Set H) = AH := by
    exact hAHfin.coe_toFinset
  have hSgen : Subgroup.closure (S : Set H) = ⊤ := by
    rw [hScoe]
    dsimp [AH, H]
    exact Subgroup.closure_preimage_eq_top A
  have hconjOrder : orderOf (g * x * g⁻¹) = orderOf x :=
    (SemiconjBy.orderOf_eq g (SemiconjBy.conj_mk g x)).symm
  have hSorderEq : ∀ z ∈ S, orderOf z = orderOf x := by
    intro z hz
    have hzAH : z ∈ AH := by
      rw [← hScoe]
      exact hz
    have hzA : (z : G) ∈ A := hzAH
    rw [← Subgroup.orderOf_coe z]
    rcases hzA with hzx | hzg
    · rw [hzx]
    · rw [Set.mem_singleton_iff.mp hzg, hconjOrder]
  have hSorder : ∀ z ∈ S, IsOfFinOrder z := by
    intro z hz
    apply Submonoid.isOfFinOrder_coe.mp
    have hzAH : z ∈ AH := by
      rw [← hScoe]
      exact hz
    have hzA : (z : G) ∈ A := hzAH
    rcases hzA with hzx | hzg
    · rw [hzx]
      exact hx
    · rw [Set.mem_singleton_iff.mp hzg]
      exact (isConj_iff.mpr ⟨g, rfl⟩).isOfFinOrder hx
  obtain ⟨hHfinite, k, hk⟩ := nilpotent_order_generators S hSgen hSorder
  letI : Finite H := hHfinite
  have hprod : ∏ z ∈ S, orderOf z = orderOf x ^ S.card := by
    calc
      ∏ z ∈ S, orderOf z = ∏ _z ∈ S, orderOf x :=
        Finset.prod_congr rfl hSorderEq
      _ = orderOf x ^ S.card := by simp
  refine ⟨hHfinite, S.card * k, ?_⟩
  rw [hprod, ← pow_mul] at hk
  exact hk

/-- **Hall, Corollary to Theorem 1.10.** Periodic elements of coprime order
commute in a nilpotent group. -/
theorem periodic_coprime_commute
    [Group.IsNilpotent G] {x y : G}
    (hx : IsOfFinOrder x) (hy : IsOfFinOrder y)
    (hcop : (orderOf x).Coprime (orderOf y)) :
    Commute x y := by
  let H : Subgroup G :=
    Subgroup.closure ({x, y⁻¹ * x * y} : Set G)
  let K : Subgroup G :=
    Subgroup.closure ({y, x⁻¹ * y * x} : Set G)
  obtain ⟨hHfinite, a, hHcard⟩ :=
    pair_conjugate_dvd x y⁻¹ hx
  obtain ⟨hKfinite, b, hKcard⟩ :=
    pair_conjugate_dvd y x⁻¹ hy
  letI : Finite H := by
    simpa [H] using hHfinite
  letI : Finite K := by
    simpa [K] using hKfinite
  have hHcard' : Nat.card H ∣ orderOf x ^ a := by
    simpa [H] using hHcard
  have hKcard' : Nat.card K ∣ orderOf y ^ b := by
    simpa [K] using hKcard
  have hxH : x ∈ H := by
    exact Subgroup.subset_closure (Set.mem_insert x {y⁻¹ * x * y})
  have hxyH : y⁻¹ * x * y ∈ H := by
    exact Subgroup.subset_closure
      (Set.mem_insert_of_mem x (Set.mem_singleton (y⁻¹ * x * y)))
  have hyK : y ∈ K := by
    exact Subgroup.subset_closure (Set.mem_insert y {x⁻¹ * y * x})
  have hyxK : x⁻¹ * y * x ∈ K := by
    exact Subgroup.subset_closure
      (Set.mem_insert_of_mem y (Set.mem_singleton (x⁻¹ * y * x)))
  let c : G := x⁻¹ * y⁻¹ * x * y
  have hcH : c ∈ H := by
    have hmem : x⁻¹ * (y⁻¹ * x * y) ∈ H :=
      H.mul_mem (H.inv_mem hxH) hxyH
    simpa [c, mul_assoc] using hmem
  have hcK : c ∈ K := by
    have hmem : (x⁻¹ * y * x)⁻¹ * y ∈ K :=
      K.mul_mem (K.inv_mem hyxK) hyK
    simpa [c, mul_assoc] using hmem
  have horder_dvd_xpow : orderOf c ∣ orderOf x ^ a :=
    (H.orderOf_dvd_natCard hcH).trans hHcard'
  have horder_dvd_ypow : orderOf c ∣ orderOf y ^ b :=
    (K.orderOf_dvd_natCard hcK).trans hKcard'
  have horder_one : orderOf c = 1 :=
    Nat.eq_one_of_dvd_coprimes
      (Nat.Coprime.pow a b hcop) horder_dvd_xpow horder_dvd_ypow
  have hc_one : c = 1 := orderOf_eq_one_iff.mp horder_one
  apply Commute.inv_inv_iff.mp
  change x⁻¹ * y⁻¹ = y⁻¹ * x⁻¹
  calc
    x⁻¹ * y⁻¹ = c * (y⁻¹ * x⁻¹) := by simp [c, mul_assoc]
    _ = y⁻¹ * x⁻¹ := by rw [hc_one]; simp

end Edmonton
end Submission
