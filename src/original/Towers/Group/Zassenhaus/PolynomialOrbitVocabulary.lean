/-!
# Natural stabilization through retained operational endpoint occurrences

For every pair of natural source multiplicities, the terminating More3
collector supplies one concrete ordered endpoint.  The below-cutoff occurrences
of that endpoint carry an occurrence-preserving finite polynomial-orbit trace.

This file connects that trace to the older compressed concrete signed-block
packet.  Both ordered products evaluate to the same powered commutator in the
lower-central truncation, so they agree without any permutation argument.

The resulting alignment boundary is the natural part of the missing symbolic
collector: one fixed finite-index trace must evaluate like each
multiplicity-dependent endpoint trace.  The signed extension at arbitrary
integral exponents remains a separate obligation.

This file is intentionally not imported by the existing collection proof.
-/

noncomputable section

namespace Towers
namespace TCTex
namespace
  ENStab

universe u

open scoped commutatorElement

open
  CSAggreg
open
  CSSpec
open
  CCTrunc
open
  UNPkt
open OCPartit
open HOCollec
open FMEnd
open
  UCSuppor
open
  RITrace
open
  TCEnd
open
  POSigned
open
  PTSigned

/-- Finite orbit-index trace of the canonically selected operational endpoint
at one natural specialization. -/
noncomputable def chosenCollectedTrace
    (n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (M N : ℕ) :
    List (RetainedOrbitIndex n leftWeight rightWeight) :=
  retainedCollectedTrace hleftWeight hrightWeight (endpoint M N)

/-- Ordered cutoff packet decoded from the selected operational endpoint
trace.  Its occurrences remain uncompressed and in collection order. -/
noncomputable def chosenCollectedPacket
    (n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (M N : ℕ) :
    OBPkt n leftWeight rightWeight :=
  retainedCollectedPacket
    hleftWeight hrightWeight (endpoint M N)

@[simp]
lemma packets_chosen_collected
    (n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (M N : ℕ) :
    (chosenCollectedPacket
      n leftWeight rightWeight hleftWeight hrightWeight M N).packets =
        indexBlockPackets
          (chosenCollectedTrace
            n leftWeight rightWeight hleftWeight hrightWeight M N) :=
  rfl

/-- Decoding the chosen endpoint trace recovers exactly the retained concrete
endpoint words, occurrence-for-occurrence and in their operational order. -/
lemma packets_chosen_packet
    (n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (M N : ℕ) :
    (chosenCollectedPacket
      n leftWeight rightWeight hleftWeight hrightWeight M N).packets.map
        (fun packet => packet.word) =
      (retainedCollectedTerms
        (endpoint M N) n leftWeight rightWeight).map
          (fun term => term.erasedShape) :=
  packets_cutoff_packet
    hleftWeight hrightWeight (endpoint M N)

/-- The retained endpoint occurrence trace evaluates to the natural powered
commutator in the free lower-central truncation. -/
lemma
    list_packets_pow
    {d n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (M N : ℕ)
    (left right :
      LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n)
    (hleft :
      left ∈ Subgroup.lowerCentralSeries
        (LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n)
        (leftWeight - 1))
    (hright :
      right ∈ Subgroup.lowerCentralSeries
        (LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n)
        (rightWeight - 1)) :
    ((chosenCollectedPacket
      n leftWeight rightWeight hleftWeight hrightWeight M N).packets.map
        fun packet => packet.word.eval (HPAtom.eval left right)).prod =
      ⁅left ^ M, right ^ N⁆ := by
  exact
    packets_collected_packet
      hleftWeight hrightWeight hleft hright
        SCFactor.trunc_last_bot
        (endpoint M N)

/-- The uncompressed endpoint occurrence trace and the older compressed
concrete signed-block packet have the same ordered product.  This comparison
passes through their common commutator value, not through a permutation. -/
lemma
    packets_packet_trunc
    {d n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (kernel : OCShape)
    (M N : ℕ)
    (left right :
      LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n)
    (hleft :
      left ∈ Subgroup.lowerCentralSeries
        (LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n)
        (leftWeight - 1))
    (hright :
      right ∈ Subgroup.lowerCentralSeries
        (LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n)
        (rightWeight - 1)) :
    ((chosenCollectedPacket
      n leftWeight rightWeight hleftWeight hrightWeight M N).packets.map
        fun packet => packet.word.eval (HPAtom.eval left right)).prod =
      ((truncatedConcretePackets
        kernel n leftWeight rightWeight M N).map fun packet =>
          packet.word.eval (HPAtom.eval left right) ^
            packet.profiles.value (M : ℤ) (N : ℤ)).prod := by
  calc
    ((chosenCollectedPacket
      n leftWeight rightWeight hleftWeight hrightWeight M N).packets.map
        fun packet => packet.word.eval (HPAtom.eval left right)).prod =
      ⁅left ^ M, right ^ N⁆ :=
        list_packets_pow
          hleftWeight hrightWeight M N left right hleft hright
    _ =
      ((truncatedConcretePackets
        kernel n leftWeight rightWeight M N).map fun packet =>
          packet.word.eval (HPAtom.eval left right) ^
            packet.profiles.value (M : ℤ) (N : ℤ)).prod :=
        (concrete_packets_pow
          hleftWeight hrightWeight kernel M N left right hleft hright).symm

/--
The natural recollection obligation for one fixed retained-index trace.

At every natural specialization, its polynomial-profile product must equal the
literal occurrence product decoded from the corresponding operational endpoint.
This is order-aware: neither side is permuted or deduplicated.
-/
def SatisfiesOccurrenceAlignment
    {d n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (trace : List (RetainedOrbitIndex n leftWeight rightWeight)) :
    Prop :=
  ∀ (M N : ℕ)
    (left right :
      LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n),
      left ∈ Subgroup.lowerCentralSeries
          (LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n)
          (leftWeight - 1) →
        right ∈ Subgroup.lowerCentralSeries
            (LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n)
            (rightWeight - 1) →
          ((indexBlockPackets trace).map fun packet =>
            packet.word.eval (HPAtom.eval left right) ^
              packet.profiles.value (M : ℤ) (N : ℤ)).prod =
            ((chosenCollectedPacket
              n leftWeight rightWeight hleftWeight hrightWeight M N).packets.map
                fun packet =>
                  packet.word.eval (HPAtom.eval left right)).prod

/-- Endpoint-occurrence alignment compiles to the existing natural
stabilization interface against compressed concrete packets. -/
noncomputable def
    stabilizationOccurrenceAlignment
    {d n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (kernel : OCShape)
    (trace : List (RetainedOrbitIndex n leftWeight rightWeight))
    (halignment :
      SatisfiesOccurrenceAlignment.{u}
        (d := d) hleftWeight hrightWeight trace) :
    TNStab.{u}
      kernel d n leftWeight rightWeight
        (indexBlockPackets trace) where
  leftWeight_pos := hleftWeight
  rightWeight_pos := hrightWeight
  packet_prod_concrete M N left right hleft hright :=
    (halignment M N left right hleft hright).trans
      (packets_packet_trunc
        hleftWeight hrightWeight kernel M N left right hleft hright)

/-- At root weights, endpoint-occurrence alignment supplies the natural packet
consumed by a later signed lift. -/
noncomputable def
    truncatedOccurrenceAlignment
    {d n : ℕ}
    (kernel : OCShape)
    (trace : List (RetainedOrbitIndex n 1 1))
    (halignment :
      SatisfiesOccurrenceAlignment.{u}
        (d := d) (by simp) (by simp) trace) :
    TBPkt.{u} d n :=
  (stabilizationOccurrenceAlignment
    (by simp) (by simp) kernel trace halignment)
      |>.truncNaturalPacket

/-- The all-integral finite-trace law implies the order-aware natural
endpoint-occurrence alignment.  This records precisely how the stronger signed
obligation dominates the operational natural one. -/
lemma
    satisfies_idx_trunc
    {d n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (trace : List (RetainedOrbitIndex n leftWeight rightWeight))
    (hlistEval :
      SatisfiesTruncatedEval.{u} (d := d) trace) :
    SatisfiesOccurrenceAlignment.{u}
      (d := d) hleftWeight hrightWeight trace := by
  intro M N left right hleft hright
  calc
    ((indexBlockPackets trace).map fun packet =>
      packet.word.eval (HPAtom.eval left right) ^
        packet.profiles.value (M : ℤ) (N : ℤ)).prod =
      ⁅left ^ M, right ^ N⁆ := by
        simpa only [zpow_natCast] using
          hlistEval left right (M : ℤ) (N : ℤ)
    _ =
      ((chosenCollectedPacket
        n leftWeight rightWeight hleftWeight hrightWeight M N).packets.map
          fun packet => packet.word.eval (HPAtom.eval left right)).prod :=
        (list_packets_pow
          hleftWeight hrightWeight M N left right hleft hright).symm

end
  ENStab
end TCTex
end Towers

/-!
# Recipe comparison for guarded polynomial-orbit evaluation

The recipe-free guarded evaluator has the same cutoff test and ordered
recursive packet as the earlier recipe-only operational recollector.  This
file proves their evaluations equal, then specializes the result to one
retained-history pair and its concrete polynomial-equivalent packet.

No factor permutation is used.
This file is intentionally not imported by the existing collection proof.
-/

namespace Towers
namespace TCTex
namespace
  RGCompar

universe u

open HACoeff
open RREvalua
open RRPkt
open BRPkt
