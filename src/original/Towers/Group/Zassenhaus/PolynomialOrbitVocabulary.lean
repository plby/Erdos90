/-!
# Local symbolic programs decoded from polynomial-orbit index traces

Each retained-history-pair cell of the arbitrary-multiplicity conservative
envelope is a finite-state operational index trace.  This file decodes one
cell into symbolic Hall polynomial factors and exposes its root-plus-two-
branches recurrence and ordered evaluation equation.

The result remains local and order preserving.  It does not aggregate
noncommuting factors or assert that the conservative envelope is a semantic
collection schedule.

This file is intentionally not imported by the existing collection proof.
-/

namespace Towers
namespace TCTex
namespace LSProgra

universe u

open RRPkt
open
  RRPkt.POObstru
open
  RITrace
open
  IEDecomp
open
  ILProgra
open
  RIRecurs
open OREnvelo
open RSEnvelo
open RPEnvelo

/-- Decode one retained-history-pair correction trace into symbolic Hall
polynomial factors. -/
noncomputable def universalOperationalFactors
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    (left right : SPFactor H ι) :
    List (SPFactor H ι) :=
  (universalOperationalTrace
    hleftWeight hrightWeight leftHistory rightHistory).map
      (orbitSymbolicFactor normalizer left right)

/-- The root symbolic factor emitted by one below-cutoff local operational
cell. -/
noncomputable def universalObstructionFactor
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    (hroot :
      (universalOrbitObstruction
        hleftWeight hrightWeight leftHistory rightHistory).weight
          leftWeight rightWeight < n)
    (left right : SPFactor H ι) :
    SPFactor H ι :=
  let O :=
    universalOrbitObstruction
      hleftWeight hrightWeight leftHistory rightHistory
  let hsupport :=
    universal_obstruction_supported
      hleftWeight hrightWeight leftHistory rightHistory hroot
  orbitSymbolicFactor normalizer left right
    (indexOrbitKey
      ⟨O.correction,
        correction_supported
          hleftWeight hrightWeight O hsupport⟩)

/-- Symbolic factors decoded from the surviving left recursive branch of one
below-cutoff local operational cell. -/
noncomputable def universalObstructionFactors
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    (hroot :
      (universalOrbitObstruction
        hleftWeight hrightWeight leftHistory rightHistory).weight
          leftWeight rightWeight < n)
    (left right : SPFactor H ι) :
    List (SPFactor H ι) :=
  let O :=
    universalOrbitObstruction
      hleftWeight hrightWeight leftHistory rightHistory
  let hsupport :=
    universal_obstruction_supported
      hleftWeight hrightWeight leftHistory rightHistory hroot
  if hleft :
      O.operationalNestedLeft.weight leftWeight rightWeight < n then
    (retainedIndexTrace (n := n)
      hleftWeight hrightWeight O.operationalNestedLeft
      (operational_left_supported
        hleftWeight hrightWeight O hsupport hleft)).map
          (orbitSymbolicFactor normalizer left right)
  else []

/-- Symbolic factors decoded from the surviving right recursive branch of one
below-cutoff local operational cell. -/
noncomputable def universalObstructionNested
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    (hroot :
      (universalOrbitObstruction
        hleftWeight hrightWeight leftHistory rightHistory).weight
          leftWeight rightWeight < n)
    (left right : SPFactor H ι) :
    List (SPFactor H ι) :=
  let O :=
    universalOrbitObstruction
      hleftWeight hrightWeight leftHistory rightHistory
  let hsupport :=
    universal_obstruction_supported
      hleftWeight hrightWeight leftHistory rightHistory hroot
  if hright :
      O.operationalNestedRight.weight leftWeight rightWeight < n then
    (retainedIndexTrace (n := n)
      hleftWeight hrightWeight O.operationalNestedRight
      (operational_nested_supported
        hleftWeight hrightWeight O hsupport hright)).map
          (orbitSymbolicFactor normalizer left right)
  else []

/-- At or above cutoff, one decoded local symbolic program is empty. -/
lemma universal_operational_nil
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    (hroot :
      ¬(universalOrbitObstruction
        hleftWeight hrightWeight leftHistory rightHistory).weight
          leftWeight rightWeight < n)
    (left right : SPFactor H ι) :
    universalOperationalFactors
        normalizer hleftWeight hrightWeight
          leftHistory rightHistory left right =
      [] := by
  unfold universalOperationalFactors
  rw [
    universal_nil_weight
      hleftWeight hrightWeight leftHistory rightHistory hroot]
  rfl

/-- Below cutoff, one decoded local symbolic program is its root factor
followed by its two surviving recursive branch programs. -/
lemma universal_operational_cons
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    (hroot :
      (universalOrbitObstruction
        hleftWeight hrightWeight leftHistory rightHistory).weight
          leftWeight rightWeight < n)
    (left right : SPFactor H ι) :
    universalOperationalFactors
        normalizer hleftWeight hrightWeight
          leftHistory rightHistory left right =
      universalObstructionFactor
          normalizer hleftWeight hrightWeight
            leftHistory rightHistory hroot left right ::
        universalObstructionFactors
            normalizer hleftWeight hrightWeight
              leftHistory rightHistory hroot left right ++
          universalObstructionNested
            normalizer hleftWeight hrightWeight
              leftHistory rightHistory hroot left right := by
  unfold universalOperationalFactors
  rw [
    universal_cons_append
      hleftWeight hrightWeight leftHistory rightHistory hroot]
  simp only [List.map_append, List.map_cons]
  unfold universalObstructionFactor
  unfold universalObstructionFactors
  unfold universalObstructionNested
  dsimp only
  split <;> split <;> rfl

/-- Below cutoff, ordered evaluation of one decoded local symbolic program is
the root-factor value followed by the two recursive branch values. -/
lemma universal_operational_branches
    {d truncation : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    (hroot :
      (universalOrbitObstruction
        hleftWeight hrightWeight leftHistory rightHistory).weight
          leftWeight rightWeight < n)
    (left right : SPFactor H ι) :
    SPFactor.listEval (n := truncation) e
        (universalOperationalFactors
          normalizer hleftWeight hrightWeight
            leftHistory rightHistory left right) =
      (universalObstructionFactor
        normalizer hleftWeight hrightWeight
          leftHistory rightHistory hroot left right).eval e *
        (SPFactor.listEval e
            (universalObstructionFactors
              normalizer hleftWeight hrightWeight
                leftHistory rightHistory hroot left right) *
          SPFactor.listEval e
            (universalObstructionNested
              normalizer hleftWeight hrightWeight
                leftHistory rightHistory hroot left right)) := by
  rw [
    universal_operational_cons,
    SPFactor.listEval_append,
    SPFactor.listEval_cons,
    mul_assoc]

end LSProgra
end TCTex
