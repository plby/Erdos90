/-!
# Symbolic decoding of the retained-transversal finite trace

The retained recipe transversal has a fixed occurrence-preserving finite-index
trace at every cutoff.  Decoding that trace through the finite polynomial-orbit
dictionary gives an explicit list of symbolic Hall polynomial factors.  Its
ordered evaluation is exactly the retained recipe product, so the remaining
global recollection theorem can be stated without silently changing order or
deduplicating factors.

The orbit dictionary may select a different polynomial-equivalent concrete
recipe representative for a key.  Accordingly, the comparison with the
retained-profile presentation is semantic: their ordered evaluations agree.

This file is intentionally not imported by the existing collection proof.
-/

noncomputable section

namespace Towers
namespace TCTex
namespace
  TSDecode

universe u

open scoped commutatorElement

open
  CFExp
open
  CTAssigna
open
  CCThree
open
  RPThree
open
  RITrace
open
  ERTransv
open
  POSigned
open
  PTRecipe
open
  ISClos

/-- Decode the retained-transversal occurrence trace as symbolic Hall
polynomial factors.  Repeated orbit indices remain repeated factors. -/
noncomputable def retainedSymbolicFactors
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (n : ℕ)
    (left right : SPFactor H ι) :
    List (SPFactor H ι) :=
  (retainedRecipeCoefficient n).map
    (orbitSymbolicFactor normalizer left right)

/-- The retained-transversal symbolic decoder is the packet decoder followed
by the ordinary symbolic-factor substitution. -/
lemma retained_symbolic_factors
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (n : ℕ)
    (left right : SPFactor H ι) :
    retainedSymbolicFactors
        normalizer n left right =
      symbolicFactors normalizer
        (indexBlockPackets
          (retainedRecipeCoefficient n))
        left right := by
  unfold retainedSymbolicFactors
  unfold orbitSymbolicFactor
  unfold indexBlockPackets
  unfold symbolicFactors
  simp only [List.map_map, Function.comp_def]

/-- Every factor decoded from the retained transversal belongs to the fixed
finite symbolic polynomial-orbit dictionary. -/
lemma factors_subset_vocabulary
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (n : ℕ)
    (left right : SPFactor H ι) :
    retainedSymbolicFactors
        normalizer n left right ⊆
      OSVocab.retainedPolyVocab
        normalizer n 1 1 left right := by
  unfold retainedSymbolicFactors
  exact retained_subset_vocabulary
    normalizer left right _

/-- Every retained-transversal symbolic factor lies below the cutoff, so
physical truncation removes no occurrence. -/
@[simp]
lemma truncate_factors_self
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n : ℕ}
    (left right : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = 1)
    (hright : right.word.weight HEAddres.weight = 1) :
    SPFactor.truncate n
        (retainedSymbolicFactors
          normalizer n left right) =
      retainedSymbolicFactors
        normalizer n left right := by
  unfold retainedSymbolicFactors
  exact truncate_symbolic_self
    normalizer (by simp) (by simp) left right hleft hright _

/-- Ordered evaluation of the decoded retained-transversal factors is exactly
the selected retained recipe product. -/
lemma
    symbolic_factors_recipes
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (left right : SPFactor H ι) :
    SPFactor.listEval (n := n) e
        (retainedSymbolicFactors
          normalizer n left right) =
      ((recipeCoefficientRecipes n).map fun recipe =>
          recipe.erasedShape.eval
            (HPAtom.eval
              (left.wordValue (n := n))
              (right.wordValue (n := n))) ^
          BRSpec.coefficientValue recipe
            (left.coefficient.eval e) (right.coefficient.eval e)).prod := by
  rw [
    retained_symbolic_factors,
    listSymbolicFactors]
  unfold retainedRecipeCoefficient
  rw [packets_recipe_packet]

/-- The trace-decoded factors and the retained-profile factors are two
order-aware symbolic presentations of the same retained recipe product. -/
lemma
    profile_recollect_factors
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (left right : SPFactor H ι) :
    SPFactor.listEval (n := n) e
        (retainedSymbolicFactors
          normalizer n left right) =
      SPFactor.listEval (n := n) e
        (globalProfileFactors
          normalizer n left right) := by
  rw [
    symbolic_factors_recipes,
    profile_recollection_recipes]

/-- The retained-transversal recollection theorem turns the decoded symbolic
trace into the powered commutator. -/
lemma
    symbolic_factors_commutator
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (hlistEval : SatisfiesRecipeCoefficient.{u} d n)
    (left right : SPFactor H ι) :
    SPFactor.listEval (n := n) e
        (retainedSymbolicFactors
          normalizer n left right) =
      ⁅left.wordValue (n := n) ^ left.coefficient.eval e,
        right.wordValue (n := n) ^ right.coefficient.eval e⁆ := by
  rw [
    symbolic_factors_recipes]
  exact
    hlistEval
      (left.wordValue (n := n))
      (right.wordValue (n := n))
      (left.coefficient.eval e)
      (right.coefficient.eval e)

/-- Through cutoff four, the decoded retained-transversal symbolic trace
evaluates unconditionally to the powered commutator. -/
lemma
    coefficient_n_four
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (hn : n ≤ 4)
    (left right : SPFactor H ι) :
    SPFactor.listEval (n := n) e
        (retainedSymbolicFactors
          normalizer n left right) =
      ⁅left.wordValue (n := n) ^ left.coefficient.eval e,
        right.wordValue (n := n) ^ right.coefficient.eval e⁆ :=
  symbolic_factors_commutator
    normalizer e
      (satisfies_coefficient_four hn)
      left right

end
  TSDecode
end TCTex
