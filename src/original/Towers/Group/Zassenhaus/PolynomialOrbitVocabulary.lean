/--
Inventory of the genuinely nonterminal recursive kernels needed by every cell
in the retained-history matrix.
-/
def UniversalNonterminalKernels
    {d M N n leftWeight rightWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (e : ι → HEFam H)
    (left right : SPFactor H ι) :
    Prop :=
  ∀ leftHistory ∈
      rawHistoriesAttached M N n leftWeight rightWeight,
    ∀ rightHistory ∈
        rawHistoriesAttached M N n leftWeight rightWeight,
      ∀ _hroot :
          (universalOrbitObstruction
            hleftWeight hrightWeight leftHistory rightHistory).weight
              leftWeight rightWeight < n,
        RNSwap
          n leftWeight rightWeight hleftWeight hrightWeight
          (left.wordValue (n := n)) (right.wordValue (n := n))
          (left.coefficient.eval e) (right.coefficient.eval e)

/--
Every retained-history matrix cell satisfies its total guarded symbolic swap
law.
-/
def SatisfiesCellSwaps
    {d M N n leftWeight rightWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : SPFactor H ι) :
    Prop :=
  ∀ leftHistory ∈
      rawHistoriesAttached M N n leftWeight rightWeight,
    ∀ rightHistory ∈
        rawHistoriesAttached M N n leftWeight rightWeight,
      SatisfiesCellSwap
        normalizer e hleftWeight hrightWeight
          leftHistory rightHistory left right

/--
One recipe-free nonterminal recursive kernel supplies the complete retained
history matrix: its type does not depend on either history coordinate.
-/
theorem
    grid_nonterminal_kernels
    {d M N n leftWeight rightWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (e : ι → HEFam H)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : SPFactor H ι)
    (kernel :
      RNSwap
        n leftWeight rightWeight hleftWeight hrightWeight
        (left.wordValue (n := n)) (right.wordValue (n := n))
        (left.coefficient.eval e) (right.coefficient.eval e)) :
    UniversalNonterminalKernels
      (M := M) (N := N) (n := n)
        hleftWeight hrightWeight e left right := by
  intro _leftHistory _hleftHistory _rightHistory _hrightHistory _hroot
  exact kernel

/--
A matrix inventory of nonterminal recursive kernels resolves every guarded
symbolic swap in the universal retained-history grid.
-/
theorem satisfiesCellSwaps
    {d M N n leftWeight rightWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = leftWeight)
    (hright : right.word.weight HEAddres.weight = rightWeight)
    (kernels :
      UniversalNonterminalKernels
        (M := M) (N := N) (n := n)
          hleftWeight hrightWeight e left right) :
    SatisfiesCellSwaps
      (M := M) (N := N) (n := n)
        normalizer e hleftWeight hrightWeight left right := by
  intro leftHistory hleftHistory rightHistory hrightHistory
  exact
    satisfiesCellSwap
      normalizer e hleftWeight hrightWeight
        leftHistory rightHistory left right hleft hright
      (kernels leftHistory hleftHistory rightHistory hrightHistory)

/--
One recipe-free nonterminal recursive kernel resolves every guarded symbolic
swap in the universal retained-history grid.
-/
theorem universal_cell_swaps
    {d M N n leftWeight rightWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = leftWeight)
    (hright : right.word.weight HEAddres.weight = rightWeight)
    (kernel :
      RNSwap
        n leftWeight rightWeight hleftWeight hrightWeight
        (left.wordValue (n := n)) (right.wordValue (n := n))
        (left.coefficient.eval e) (right.coefficient.eval e)) :
    SatisfiesCellSwaps
      (M := M) (N := N) (n := n)
        normalizer e hleftWeight hrightWeight left right := by
  exact
    satisfiesCellSwaps
      (M := M) (N := N) (n := n)
      normalizer e hleftWeight hrightWeight left right hleft hright
      (grid_nonterminal_kernels
        (M := M) (N := N) (n := n)
          e hleftWeight hrightWeight left right kernel)

/--
The strict weight-room form of the recipe-free Hall collector resolves every
guarded symbolic swap in the universal retained-history grid.
-/
theorem cell_swaps_room
    {d M N n leftWeight rightWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = leftWeight)
    (hright : right.word.weight HEAddres.weight = rightWeight)
    (kernel :
      RRSwap
        n leftWeight rightWeight hleftWeight hrightWeight
        (left.wordValue (n := n)) (right.wordValue (n := n))
        (left.coefficient.eval e) (right.coefficient.eval e)) :
    SatisfiesCellSwaps
      (M := M) (N := N) (n := n)
        normalizer e hleftWeight hrightWeight left right := by
  exact
    universal_cell_swaps
      (M := M) (N := N) (n := n)
      normalizer e hleftWeight hrightWeight left right hleft hright
      kernel.recursiveNonterminalSwap

/--
Through cutoff three, every retained-history grid cell has its required
nonterminal recursive kernel.
-/
theorem
    universal_nonterminal_kernels
    {d M N n leftWeight rightWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (e : ι → HEFam H)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 3)
    (left right : SPFactor H ι) :
    UniversalNonterminalKernels
      (M := M) (N := N) (n := n)
        hleftWeight hrightWeight e left right := by
  exact
    grid_nonterminal_kernels
      (M := M) (N := N) (n := n)
      e hleftWeight hrightWeight left right
      (RNSwap.cutoff_three
        hleftWeight hrightWeight hn
        (left.wordValue (n := n)) (right.wordValue (n := n))
        (left.coefficient.eval e) (right.coefficient.eval e))

/--
Through cutoff three, the complete retained-history matrix satisfies its
guarded symbolic cell-swap package without a nonterminal Hall-collection input.
-/
theorem
    operational_cell_swaps
    {d M N n leftWeight rightWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 3)
    (left right : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = leftWeight)
    (hright : right.word.weight HEAddres.weight = rightWeight) :
    SatisfiesCellSwaps
      (M := M) (N := N) (n := n)
        normalizer e hleftWeight hrightWeight left right := by
  exact
    satisfiesCellSwaps
      (M := M) (N := N) (n := n)
      normalizer e hleftWeight hrightWeight left right hleft hright
      (universal_nonterminal_kernels
        (M := M) (N := N) (n := n)
          e hleftWeight hrightWeight hn left right)

end
  OSGrid
end TCTex
end Towers

/-!
# Signed lift after retained operational endpoint alignment

The operational endpoint comparison isolates the natural part of a genuine
fixed finite-trace collector.  At root weights, one fixed trace satisfies the
full all-integral law exactly when it has:

* an order-aware alignment with every multiplicity-dependent retained endpoint;
* a signed extension of the resulting natural packet.

This separates the repeated-block recollection theorem from its integral
extension without flattening, permuting, or deduplicating endpoint occurrences.

This file is intentionally not imported by the existing collection proof.
-/

noncomputable section

namespace Towers
namespace TCTex
namespace
  ESLift

universe u

open
  CSAggreg
open
  UNPkt
open
  RITrace
open
  ENStab
open
  POSigned
open
  PTSigned

/-- The natural packet obtained from order-aware alignment of one fixed
root-weight retained-index trace with every collected endpoint. -/
noncomputable def occurrenceNaturalPacket
    {d n : ℕ}
    (kernel : OCShape)
    (trace : List (RetainedOrbitIndex n 1 1))
    (halignment :
      SatisfiesOccurrenceAlignment.{u}
        (d := d) (by simp) (by simp) trace) :
    TBPkt.{u} d n :=
  truncatedOccurrenceAlignment
    kernel trace halignment

@[simp]
lemma packets_occurrence_packet
    {d n : ℕ}
    (kernel : OCShape)
    (trace : List (RetainedOrbitIndex n 1 1))
    (halignment :
      SatisfiesOccurrenceAlignment.{u}
        (d := d) (by simp) (by simp) trace) :
    (occurrenceNaturalPacket
      kernel trace halignment).packets =
        indexBlockPackets trace :=
  rfl

/-- The remaining signed extension after order-aware retained-endpoint
alignment. -/
abbrev OccurrenceAllLift
    {d n : ℕ}
    (kernel : OCShape)
    (trace : List (RetainedOrbitIndex n 1 1))
    (halignment :
      SatisfiesOccurrenceAlignment.{u}
        (d := d) (by simp) (by simp) trace) :
    Prop :=
  (occurrenceNaturalPacket
    kernel trace halignment).AILift

/-- A signed lift of an endpoint-aligned fixed trace proves its all-integral
finite-trace law. -/
lemma
    satisfies_occurrence_lift
    {d n : ℕ}
    (kernel : OCShape)
    (trace : List (RetainedOrbitIndex n 1 1))
    (halignment :
      SatisfiesOccurrenceAlignment.{u}
        (d := d) (by simp) (by simp) trace)
    (lift :
      OccurrenceAllLift
        kernel trace halignment) :
    SatisfiesTruncatedEval.{u} (d := d) trace := by
  intro left right leftExponent rightExponent
  simpa only [
    packets_occurrence_packet] using
      lift.listEval_eq left right leftExponent rightExponent

/-- The full all-integral law supplies the natural retained-endpoint alignment
used by the signed-lift factorization. -/
noncomputable def
    occurrenceAlignmentSatisfies
    {d n : ℕ}
    (trace : List (RetainedOrbitIndex n 1 1))
    (hlistEval :
      SatisfiesTruncatedEval.{u} (d := d) trace) :
    SatisfiesOccurrenceAlignment.{u}
      (d := d) (by simp) (by simp) trace :=
  satisfies_idx_trunc
    (by simp) (by simp) trace hlistEval

/-- The full all-integral law also supplies the signed extension of its natural
retained-endpoint packet. -/
noncomputable def
    occurrenceAllSatisfies
    {d n : ℕ}
    (kernel : OCShape)
    (trace : List (RetainedOrbitIndex n 1 1))
    (hlistEval :
      SatisfiesTruncatedEval.{u} (d := d) trace) :
    OccurrenceAllLift kernel trace
      (occurrenceAlignmentSatisfies
        trace hlistEval) where
  listEval_eq := by
    intro left right leftExponent rightExponent
    simpa only [
      packets_occurrence_packet] using
        hlistEval left right leftExponent rightExponent

/--
For one fixed root-weight retained-index trace, the full all-integral semantic
law is equivalent to natural operational endpoint alignment together with its
signed extension.
-/
theorem
    satisfies_idx_alignment
    {d n : ℕ}
    (kernel : OCShape)
    (trace : List (RetainedOrbitIndex n 1 1)) :
    SatisfiesTruncatedEval.{u} (d := d) trace ↔
      ∃ halignment :
          SatisfiesOccurrenceAlignment.{u}
            (d := d) (by simp) (by simp) trace,
        OccurrenceAllLift kernel trace halignment := by
  constructor
  · intro hlistEval
    let halignment :=
      occurrenceAlignmentSatisfies
        trace hlistEval
    exact
      ⟨halignment,
        occurrenceAllSatisfies
          kernel trace hlistEval⟩
  · rintro ⟨halignment, lift⟩
    exact
      satisfies_occurrence_lift
        kernel trace halignment lift

namespace TSInput

/--
An endpoint-aligned root-weight trace and its signed extension instantiate the
Claim 5 coordinate-polynomial adapter.
-/
theorem
    coordOccLift
    {d n inputWeight : ℕ}
    (hn : 2 ≤ n)
    (H : ∀ s : ℕ, BCWta.{u} d s)
    (hH :
      ∀ s : ℕ,
        1 ≤ s →
          s < n →
            (H s).FormsAssocGradedbasis (n := n))
    {kernel : OCShape}
    (trace : List (RetainedOrbitIndex n 1 1))
    (halignment :
      SatisfiesOccurrenceAlignment.{u}
        (d := d) (by simp) (by simp) trace)
    (lift :
      OccurrenceAllLift
        kernel trace halignment)
    {e : HEFam H}
    (input :
      TSInput
        (n := n) (inputWeight := inputWeight) H e)
    (hsourceSupported :
      SPFactora.WordWeightLeast inputWeight input.source)
    (factorNormalization :
      ∀ lowerWeight : ℕ,
        ¬n ≤ 2 * lowerWeight →
          TSNormalb
              (n := n) (inputWeight := inputWeight)
                (lowerWeight := lowerWeight + 1) H →
            ∀ (factor : SPFactora H inputWeight),
              factor.word.weight PEAddres.weight = lowerWeight →
              factor.word.weight PEAddres.weight < n →
            TANorm
              (n := n) (lowerWeight := lowerWeight) H factor)
    (hinputWeight : 1 ≤ inputWeight) :
    CollectedPolynomialData (n := n) H e inputWeight :=
  coordPolyPacket
    hn H hH (kernel := kernel) trace
      (satisfies_occurrence_lift
        kernel trace halignment lift)
      input hsourceSupported factorNormalization hinputWeight

end TSInput

end
  ESLift
export
  ESLift.TSInput
    (coordOccLift)
end TCTex
end Towers

/-!
# Ordered signed-block packets for local polynomial-orbit trace programs

Each retained-history pair in the arbitrary-multiplicity envelope carries a
total finite-index trace: below cutoff it is the ordered recursive orbit
program, while at or above cutoff it is empty.  This file decodes that local
trace into singleton signed-block occurrences and packages it as an ordered
cutoff-supported packet.

The resulting ordered product is exactly the guarded operational evaluator,
and therefore exactly the corresponding concrete operational correction
packet.  All equalities retain occurrence order literally.

This file is intentionally not imported by the existing collection proof.
-/

namespace Towers
namespace TCTex
namespace
  PLSigned

open
  CFSubsti
open
  UCSuppor
open
  IEDecomp
open
  ILProgra
open
  POSigned
open
  RGEvalua
open
  RGCompar
open OREnvelo
open RPEnvelo

/-- Decode one retained-history pair's total finite-index program into
ordered singleton signed-block packet occurrences. -/
noncomputable def
    universalOperationalPackets
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight) :
    List RFPkt :=
  indexBlockPackets
    (universalOperationalTrace
      hleftWeight hrightWeight leftHistory rightHistory)

/-- Below cutoff, decoding one local total program gives exactly the packets
decoded from its supported recursive trace. -/
lemma
    poly_packets_weight
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    (hroot :
      (universalOrbitObstruction
        hleftWeight hrightWeight leftHistory rightHistory).weight
          leftWeight rightWeight < n) :
    universalOperationalPackets
        hleftWeight hrightWeight leftHistory rightHistory =
      retainedIndexPackets
        hleftWeight hrightWeight
        (universalOrbitObstruction
          hleftWeight hrightWeight leftHistory rightHistory)
        (universal_obstruction_supported
          hleftWeight hrightWeight leftHistory rightHistory hroot) := by
  unfold universalOperationalPackets
  rw [
    universal_operational_weight
      hleftWeight hrightWeight leftHistory rightHistory hroot]
  rfl

/-- At or above cutoff, decoding one local total program gives no signed-block
packet occurrences. -/
@[simp]
lemma
    universal_packets_nil
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    (hroot :
      ¬(universalOrbitObstruction
        hleftWeight hrightWeight leftHistory rightHistory).weight
          leftWeight rightWeight < n) :
    universalOperationalPackets
        hleftWeight hrightWeight leftHistory rightHistory =
      [] := by
  unfold universalOperationalPackets
  rw [
    universal_nil_weight
      hleftWeight hrightWeight leftHistory rightHistory hroot]
  rfl

/-- One local ordered signed-block packet evaluates exactly as the total
cutoff-guarded recursive orbit evaluator. -/
lemma
    list_poly_guarded
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    {G : Type*}
    [Group G]
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    ((universalOperationalPackets
      hleftWeight hrightWeight leftHistory rightHistory).map fun packet =>
        packet.word.eval (HPAtom.eval left right) ^
          packet.profiles.value leftExponent rightExponent).prod =
      guardedOperationalEval (n := n)
        hleftWeight hrightWeight
        (universalOrbitObstruction
          hleftWeight hrightWeight leftHistory rightHistory)
        left right leftExponent rightExponent := by
  by_cases hroot :
      (universalOrbitObstruction
        hleftWeight hrightWeight leftHistory rightHistory).weight
          leftWeight rightWeight < n
  · rw [
      poly_packets_weight
        hleftWeight hrightWeight leftHistory rightHistory hroot,
      block_packets_operational,
      ← guarded_operational_weight
        hleftWeight hrightWeight
        (universalOrbitObstruction
          hleftWeight hrightWeight leftHistory rightHistory)
        left right leftExponent rightExponent hroot]
  · rw [
      universal_packets_nil
        hleftWeight hrightWeight leftHistory rightHistory hroot,
      List.map_nil, List.prod_nil,
      guarded_operational_list
        hleftWeight hrightWeight
        (universalOrbitObstruction
          hleftWeight hrightWeight leftHistory rightHistory)
        left right leftExponent rightExponent hroot]

/-- One local decoded signed-block packet has exactly the ordered evaluation
of its concrete operational correction packet. -/
lemma
    operational_packets_concrete
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    {G : Type*}
    [Group G]
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    ((universalOperationalPackets
      hleftWeight hrightWeight leftHistory rightHistory).map fun packet =>
        packet.word.eval (HPAtom.eval left right) ^
          packet.profiles.value leftExponent rightExponent).prod =
      ((concreteOperationalPacket
        hleftWeight hrightWeight leftHistory rightHistory).map fun recipe =>
          recipe.erasedShape.eval (HPAtom.eval left right) ^
            BRSpec.coefficientValue recipe
              leftExponent rightExponent).prod := by
  rw [
    list_poly_guarded,
    guarded_universal_obstruction]

/-- One retained-history pair's total finite-index program as an ordered
cutoff-supported signed-block packet. -/
noncomputable def
    universalOperationalBlock
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight) :
    OBPkt n leftWeight rightWeight :=
  indexBlockPacket
    hleftWeight hrightWeight
    (universalOperationalTrace
      hleftWeight hrightWeight leftHistory rightHistory)

@[simp]
lemma
    packets_universal_operational
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight) :
    (universalOperationalBlock
      hleftWeight hrightWeight leftHistory rightHistory).packets =
        universalOperationalPackets
          hleftWeight hrightWeight leftHistory rightHistory :=
  rfl

end
  PLSigned
end TCTex
end Towers

/-!
# The shallow class-three boundary of polynomial-orbit swap recursion

Through cutoff four, a genuinely nonterminal polynomial-orbit obstruction has
only one possible weight profile: the cutoff is four and both parent orbit
weights are one.  Consequently both operational children survive, both are
terminal, and the ordered recursive trace consists of exactly three correction
keys.

This file records that classification and exposes the precise three-factor
local algebra law still needed to extend the checked class-two swap resolver
through cutoff four.  It deliberately does not identify that operational law
with the closed Hall-Petresco class-three packet: the two presentations carry
different coefficient expressions until a symbolic recollector relates them.

This file is intentionally not imported by the existing collection proof.
-/

noncomputable section

namespace Towers
namespace TCTex
namespace
  CTShallo

universe u

open ROEvalua
open RREvalua
open RRPkt
open
  RRPkt.POObstru
open ROTransi
open
  CTTermin
open
  CTTermin.POObstru
open
  OSGrid

namespace POObstru

/--
The root operational correction carries the product of its two inherited
polynomial-orbit coefficients.
-/
lemma coefficient_value_correction
    (O : POObstru)
    (leftExponent rightExponent : ℤ) :
    orbitCoefficientValue O.correction leftExponent rightExponent =
      orbitCoefficientValue O.left leftExponent rightExponent *
        orbitCoefficientValue O.right leftExponent rightExponent := by
  unfold correction orbitCorrection orbitCoefficientValue
  simp only [List.map_append, List.prod_append]
  ring

/--
The raw left triple branch carries `a * (a * b)`.  This is an inherited
multiplicative coefficient, not the collected `choose a 2 * b`.
-/
lemma value_operational_nested
    (O : POObstru)
    (leftExponent rightExponent : ℤ) :
    orbitCoefficientValue O.operationalNestedLeft.correction
        leftExponent rightExponent =
      orbitCoefficientValue O.left leftExponent rightExponent *
        (orbitCoefficientValue O.left leftExponent rightExponent *
          orbitCoefficientValue O.right
            leftExponent rightExponent) := by
  rw [coefficient_value_correction]
  change
    orbitCoefficientValue O.left leftExponent rightExponent *
        orbitCoefficientValue O.correction leftExponent rightExponent =
      _
  rw [coefficient_value_correction]

/--
The raw right triple branch carries `b * (a * b)`.  This is an inherited
multiplicative coefficient, not the collected `a * choose b 2`.
-/
lemma operational_nested_correction
    (O : POObstru)
    (leftExponent rightExponent : ℤ) :
    orbitCoefficientValue O.operationalNestedRight.correction
        leftExponent rightExponent =
      orbitCoefficientValue O.right leftExponent rightExponent *
        (orbitCoefficientValue O.left leftExponent rightExponent *
          orbitCoefficientValue O.right
            leftExponent rightExponent) := by
  rw [coefficient_value_correction]
  change
    orbitCoefficientValue O.right leftExponent rightExponent *
        orbitCoefficientValue O.correction leftExponent rightExponent =
      _
  rw [coefficient_value_correction]

/--
At inherited coefficient values `(2, 1)`, the raw left triple coefficient is
not the collected class-three coefficient.
-/
lemma triple_collected_values
    (O : POObstru)
    (leftExponent rightExponent : ℤ)
    (hleft :
      orbitCoefficientValue O.left leftExponent rightExponent = 2)
    (hright :
      orbitCoefficientValue O.right leftExponent rightExponent = 1) :
    orbitCoefficientValue O.operationalNestedLeft.correction
          leftExponent rightExponent ≠
      Ring.choose
          (orbitCoefficientValue O.left leftExponent rightExponent) 2 *
        orbitCoefficientValue O.right leftExponent rightExponent := by
  rw [value_operational_nested,
    hleft, hright]
  norm_num [Ring.choose]

/--
At inherited coefficient values `(1, 2)`, the raw right triple coefficient is
not the collected class-three coefficient.
-/
lemma raw_triple_values
    (O : POObstru)
    (leftExponent rightExponent : ℤ)
    (hleft :
      orbitCoefficientValue O.left leftExponent rightExponent = 1)
    (hright :
      orbitCoefficientValue O.right leftExponent rightExponent = 2) :
    orbitCoefficientValue O.operationalNestedRight.correction
          leftExponent rightExponent ≠
      orbitCoefficientValue O.left leftExponent rightExponent *
        Ring.choose
          (orbitCoefficientValue O.right leftExponent rightExponent) 2 := by
  rw [operational_nested_correction,
    hleft, hright]
  norm_num [Ring.choose]

/-- Every operational left child has weighted degree at least three. -/
lemma three_nested_left
    {leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru) :
    3 ≤ O.operationalNestedLeft.weight leftWeight rightWeight := by
  rw [weight_nested_left]
  have hleftOrbit :=
    one_orbit_weight hleftWeight hrightWeight O.left
  have hrightOrbit :=
    one_orbit_weight hleftWeight hrightWeight O.right
  omega

/-- Every operational right child has weighted degree at least three. -/
lemma three_operational_nested
    {leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru) :
    3 ≤ O.operationalNestedRight.weight leftWeight rightWeight := by
  rw [weight_operational_right]
  have hleftOrbit :=
    one_orbit_weight hleftWeight hrightWeight O.left
  have hrightOrbit :=
    one_orbit_weight hleftWeight hrightWeight O.right
  omega

/-- Through cutoff four, every operational left child is terminal. -/
lemma terminal_nested_four
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 4)
    (O : POObstru) :
    Terminal n leftWeight rightWeight O.operationalNestedLeft := by
  apply
    terminal_cutoff_one
      hleftWeight hrightWeight O.operationalNestedLeft
  have hchild :=
    three_nested_left hleftWeight hrightWeight O
  omega

/-- Through cutoff four, every operational right child is terminal. -/
lemma terminal_operational_four
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 4)
    (O : POObstru) :
    Terminal n leftWeight rightWeight O.operationalNestedRight := by
  apply
    terminal_cutoff_one
      hleftWeight hrightWeight O.operationalNestedRight
  have hchild :=
    three_operational_nested hleftWeight hrightWeight O
  omega

/-- A genuinely nonterminal node through cutoff four occurs exactly at cutoff four. -/
lemma cutoff_four_terminal
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 4)
    (O : POObstru)
    (hnonterminal : ¬Terminal n leftWeight rightWeight O) :
    n = 4 := by
  have hroom :=
    cutoff_not_terminal
      hleftWeight hrightWeight O hnonterminal
  have hweight := two_le_weight hleftWeight hrightWeight O
  omega

/-- The left parent orbit of a shallow class-three node has weight one. -/
lemma not_terminal_four
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 4)
    (O : POObstru)
    (hnonterminal : ¬Terminal n leftWeight rightWeight O) :
    orbitWeight leftWeight rightWeight O.left = 1 := by
  have hroom :=
    (not_terminal_min O).mp hnonterminal
  have hleftOrbit :=
    one_orbit_weight hleftWeight hrightWeight O.left
  have hrightOrbit :=
    one_orbit_weight hleftWeight hrightWeight O.right
  have hcutoff :=
    cutoff_four_terminal
      hleftWeight hrightWeight hn O hnonterminal
  unfold weight at hroom
  omega

/-- The right parent orbit of a shallow class-three node has weight one. -/
lemma orbit_terminal_four
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 4)
    (O : POObstru)
    (hnonterminal : ¬Terminal n leftWeight rightWeight O) :
    orbitWeight leftWeight rightWeight O.right = 1 := by
  have hroom :=
    (not_terminal_min O).mp hnonterminal
  have hleftOrbit :=
    one_orbit_weight hleftWeight hrightWeight O.left
  have hrightOrbit :=
    one_orbit_weight hleftWeight hrightWeight O.right
  have hcutoff :=
    cutoff_four_terminal
      hleftWeight hrightWeight hn O hnonterminal
  unfold weight at hroom
  omega

/-- Both shallow class-three operational children have weight three. -/
lemma nested_terminal_four
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 4)
    (O : POObstru)
    (hnonterminal : ¬Terminal n leftWeight rightWeight O) :
    O.operationalNestedLeft.weight leftWeight rightWeight = 3 := by
  rw [weight_nested_left,
    not_terminal_four
      hleftWeight hrightWeight hn O hnonterminal,
    orbit_terminal_four
      hleftWeight hrightWeight hn O hnonterminal]

/-- Both shallow class-three operational children have weight three. -/
lemma operational_terminal_four
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 4)
    (O : POObstru)
    (hnonterminal : ¬Terminal n leftWeight rightWeight O) :
    O.operationalNestedRight.weight leftWeight rightWeight = 3 := by
  rw [weight_operational_right,
    not_terminal_four
      hleftWeight hrightWeight hn O hnonterminal,
    orbit_terminal_four
      hleftWeight hrightWeight hn O hnonterminal]

/-- Both shallow class-three operational children survive below cutoff. -/
lemma operational_nested_terminal
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 4)
    (O : POObstru)
    (hnonterminal : ¬Terminal n leftWeight rightWeight O) :
    O.operationalNestedLeft.weight leftWeight rightWeight < n := by
  rw [nested_terminal_four
    hleftWeight hrightWeight hn O hnonterminal]
  have hcutoff :=
    cutoff_four_terminal
      hleftWeight hrightWeight hn O hnonterminal
  omega

/-- Both shallow class-three operational children survive below cutoff. -/
lemma operational_nested_four
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 4)
    (O : POObstru)
    (hnonterminal : ¬Terminal n leftWeight rightWeight O) :
    O.operationalNestedRight.weight leftWeight rightWeight < n := by
  rw [operational_terminal_four
    hleftWeight hrightWeight hn O hnonterminal]
  have hcutoff :=
    cutoff_four_terminal
      hleftWeight hrightWeight hn O hnonterminal
  omega

/-- A terminal orbit node emits only its leading correction key. -/
lemma keys_singleton_terminal
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru)
    (hterminal : Terminal n leftWeight rightWeight O) :
    O.retainedKeys (n := n) hleftWeight hrightWeight =
      [O.correction] := by
  rw [keys_cons_append hleftWeight hrightWeight O,
    dif_neg (Nat.not_lt_of_ge hterminal.1),
    dif_neg (Nat.not_lt_of_ge hterminal.2)]
  rfl

/--
A genuinely nonterminal node through cutoff four emits exactly its root
correction followed by the leading corrections of its two terminal children.
-/
lemma keys_terminal_four
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 4)
    (O : POObstru)
    (hnonterminal : ¬Terminal n leftWeight rightWeight O) :
    O.retainedKeys (n := n) hleftWeight hrightWeight =
      [O.correction,
        O.operationalNestedLeft.correction,
        O.operationalNestedRight.correction] := by
  rw [keys_cons_append hleftWeight hrightWeight O,
    dif_pos
      (operational_nested_terminal
        hleftWeight hrightWeight hn O hnonterminal),
    dif_pos
      (operational_nested_four
        hleftWeight hrightWeight hn O hnonterminal),
    keys_singleton_terminal hleftWeight hrightWeight
      O.operationalNestedLeft
      (terminal_nested_four
        hleftWeight hrightWeight hn O),
    keys_singleton_terminal hleftWeight hrightWeight
      O.operationalNestedRight
      (terminal_operational_four
        hleftWeight hrightWeight hn O)]
  rfl

/--
Evaluation of a genuinely nonterminal cutoff-four operational trace is the
explicit ordered product of its three shallow correction factors.
-/
lemma corrections_terminal_four
    {G : Type u}
    [Group G]
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 4)
    (O : POObstru)
    (hnonterminal : ¬Terminal n leftWeight rightWeight O)
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    RREvalua.listEval
        (n := n) hleftWeight hrightWeight O
          left right leftExponent rightExponent =
      orbitFactorValue O.correction
          left right leftExponent rightExponent *
        orbitFactorValue O.operationalNestedLeft.correction
            left right leftExponent rightExponent *
          orbitFactorValue O.operationalNestedRight.correction
            left right leftExponent rightExponent := by
  unfold
    RREvalua.listEval
  rw [keys_terminal_four
    hleftWeight hrightWeight hn O hnonterminal]
  simp only [List.map_cons, List.map_nil, List.prod_cons, List.prod_nil, mul_one,
    mul_assoc]

end POObstru

/--
Exact shallow class-three law still needed from a symbolic Hall recollector.
The statement is deliberately operational: it preserves the recursive trace
order and does not replace its coefficients by closed-form binomial terms.
-/
def RecursiveShallowLaw
    {G : Type u}
    [Group G]
    (n leftWeight rightWeight : ℕ)
    (_hleftWeight : 0 < leftWeight)
    (_hrightWeight : 0 < rightWeight)
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    Prop :=
  ∀ (O : POObstru),
    ¬POObstru.Terminal n leftWeight rightWeight O →
      orbitFactorValue O.correction
            left right leftExponent rightExponent *
          orbitFactorValue O.operationalNestedLeft.correction
              left right leftExponent rightExponent *
            orbitFactorValue O.operationalNestedRight.correction
                left right leftExponent rightExponent *
              orbitFactorValue O.right
                  left right leftExponent rightExponent *
                orbitFactorValue O.left
                    left right leftExponent rightExponent =
        orbitFactorValue O.left
            left right leftExponent rightExponent *
          orbitFactorValue O.right
            left right leftExponent rightExponent

namespace RNSwap

/--
Through cutoff four, the explicit shallow class-three operational law supplies
the complete nonterminal recursive kernel.
-/
def cutoff_four
    {G : Type u}
    [Group G]
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 4)
    (left right : G)
    (leftExponent rightExponent : ℤ)
    (law :
      RecursiveShallowLaw
        n leftWeight rightWeight hleftWeight hrightWeight
          left right leftExponent rightExponent) :
    RNSwap
      n leftWeight rightWeight hleftWeight hrightWeight
      left right leftExponent rightExponent where
  resolve_nonterminal := by
    intro O hroot hnonterminal _hleft _hright
    refine ⟨?_⟩
    rw [
      POObstru.corrections_terminal_four
        hleftWeight hrightWeight hn O hnonterminal]
    exact law O hnonterminal

end RNSwap

/--
Through cutoff four, one shallow class-three law supplies the complete
retained-history matrix inventory of nonterminal recursive kernels.
-/
theorem
    nonterminal_kernels_four
    {d M N n leftWeight rightWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (e : ι → HEFam H)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 4)
    (left right : SPFactor H ι)
    (law :
      RecursiveShallowLaw
        n leftWeight rightWeight hleftWeight hrightWeight
        (left.wordValue (n := n)) (right.wordValue (n := n))
        (left.coefficient.eval e) (right.coefficient.eval e)) :
    UniversalNonterminalKernels
      (M := M) (N := N) (n := n)
      hleftWeight hrightWeight e left right := by
  exact
    grid_nonterminal_kernels
      (M := M) (N := N) (n := n)
      e hleftWeight hrightWeight left right
      (RNSwap.cutoff_four
        hleftWeight hrightWeight hn
        (left.wordValue (n := n)) (right.wordValue (n := n))
        (left.coefficient.eval e) (right.coefficient.eval e) law)

/--
Through cutoff four, one shallow class-three law resolves every guarded
symbolic swap in the universal retained-history grid.
-/
theorem
    cell_swaps_four
    {d M N n leftWeight rightWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 4)
    (left right : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = leftWeight)
    (hright : right.word.weight HEAddres.weight = rightWeight)
    (law :
      RecursiveShallowLaw
        n leftWeight rightWeight hleftWeight hrightWeight
        (left.wordValue (n := n)) (right.wordValue (n := n))
        (left.coefficient.eval e) (right.coefficient.eval e)) :
    SatisfiesCellSwaps
      (M := M) (N := N) (n := n)
      normalizer e hleftWeight hrightWeight left right := by
  exact
    satisfiesCellSwaps
      (M := M) (N := N) (n := n)
      normalizer e hleftWeight hrightWeight left right hleft hright
      (nonterminal_kernels_four
        (M := M) (N := N) (n := n)
        e hleftWeight hrightWeight hn left right law)

end
  CTShallo
end TCTex
end Towers

/-!
# Retained operational endpoint traces through cutoff four

Through cutoff four, the retained closure transversal has an explicit
all-integral class-three collection law.  Encoding that transversal
occurrence-for-occurrence in the retained polynomial-orbit dictionary gives a
genuine fixed finite trace.

This file routes the explicit trace through the operational endpoint boundary:
it aligns with every multiplicity-dependent collected endpoint, has the
required signed lift, and therefore supplies the Claim 5 adapter in this base
range.

This file is intentionally not imported by the existing collection proof.
-/

noncomputable section

namespace Towers
namespace TCTex
namespace
  ECThree

universe u

open ROSuppor
open ROAggreg
open ROTransi
open
  CSAggreg
open
  CTAssigna
open
  CCThree
open
  RITrace
open
  ENStab
open
  ESLift
open
  PTRecipe
open
  PTSigned

/-- The retained closure transversal is pointwise supported by the finite
polynomial-orbit dictionary at every cutoff. -/
lemma supported_coefficient_recipes
    (n : ℕ) :
    RecipeOrbitSupported n 1 1
      (recipeCoefficientRecipes n) := by
  intro recipe hrecipe
  exact
    key_vocabulary_recipes
      (closure_recipes_coefficient
        hrecipe)

/-- Fixed finite polynomial-orbit trace obtained from the retained closure
transversal.  This definition is independent of the ambient free rank. -/
noncomputable def classIndexTrace
    (n : ℕ) :
    List (RetainedOrbitIndex n 1 1) :=
  recipeIndexTrace
    (recipeCoefficientRecipes n)
    (supported_coefficient_recipes n)

/-- Decoding the retained class-three trace recovers the selected orbit keys in
their inherited closure order. -/
lemma orbit_key_trace
    (n : ℕ) :
    (classIndexTrace n).map
        retainedOrbitKey =
      (recipeCoefficientRecipes n).map polynomialOrbitKey :=
  key_recipe_trace
    (recipeCoefficientRecipes n)
    (supported_coefficient_recipes n)

/-- Through cutoff four, the retained transversal trace satisfies the full
all-integral powered-commutator law. -/
lemma satisfies_truncated_retained
    {d n : ℕ}
    (hn : n ≤ 4) :
    SatisfiesTruncatedEval.{u} (d := d)
      (classIndexTrace n) := by
  intro left right leftExponent rightExponent
  unfold classIndexTrace
  rw [
    packets_recipe_packet]
  exact
    satisfies_coefficient_four
      hn left right leftExponent rightExponent

/-- Through cutoff four, the retained transversal trace aligns with every
natural collected operational endpoint in occurrence order. -/
noncomputable def
    collectedOccurrenceAlignment
    {d n : ℕ}
    (hn : n ≤ 4) :
    SatisfiesOccurrenceAlignment.{u}
      (d := d) (by simp) (by simp)
        (classIndexTrace n) :=
  occurrenceAlignmentSatisfies
    (classIndexTrace n)
    (satisfies_truncated_retained
      (d := d) hn)

/-- Through cutoff four, the retained transversal trace has the signed lift of
its order-aware natural endpoint packet. -/
noncomputable def
    collectedOccurrenceLift
    {d n : ℕ}
    (kernel : OCShape)
    (hn : n ≤ 4) :
    OccurrenceAllLift kernel
      (classIndexTrace n)
      (collectedOccurrenceAlignment
        (d := d) hn) where
  listEval_eq := by
    intro left right leftExponent rightExponent
    simpa only [
      packets_occurrence_packet] using
        satisfies_truncated_retained
          (d := d) hn left right leftExponent rightExponent

/-- The explicit class-three trace witnesses the operational factorization of
the fixed all-integral law. -/
theorem
    occurrence_alignment_lift
    {d n : ℕ}
    (kernel : OCShape)
    (hn : n ≤ 4) :
    ∃ halignment :
        SatisfiesOccurrenceAlignment.{u}
          (d := d) (by simp) (by simp)
            (classIndexTrace n),
      OccurrenceAllLift kernel
        (classIndexTrace n) halignment :=
  ⟨collectedOccurrenceAlignment (d := d) hn,
    collectedOccurrenceLift kernel hn⟩

namespace TSInput

/-- Through cutoff four, the retained operational endpoint trace supplies the
Claim 5 coordinate polynomials. -/
theorem
    coordPolyOcc
    {d n inputWeight : ℕ}
    (hn : 2 ≤ n)
    (hnUpper : n ≤ 4)
    (H : ∀ s : ℕ, BCWta.{u} d s)
    (hH :
      ∀ s : ℕ,
        1 ≤ s →
          s < n →
            (H s).FormsAssocGradedbasis (n := n))
    {kernel : OCShape}
    {e : HEFam H}
    (input :
      TSInput
        (n := n) (inputWeight := inputWeight) H e)
    (hsourceSupported :
      SPFactora.WordWeightLeast inputWeight input.source)
    (factorNormalization :
      ∀ lowerWeight : ℕ,
        ¬n ≤ 2 * lowerWeight →
          TSNormalb
              (n := n) (inputWeight := inputWeight)
                (lowerWeight := lowerWeight + 1) H →
            ∀ (factor : SPFactora H inputWeight),
              factor.word.weight PEAddres.weight = lowerWeight →
              factor.word.weight PEAddres.weight < n →
            TANorm
              (n := n) (lowerWeight := lowerWeight) H factor)
    (hinputWeight : 1 ≤ inputWeight) :
    CollectedPolynomialData (n := n) H e inputWeight :=
  coordOccLift
    hn H hH (kernel := kernel)
      (classIndexTrace n)
      (collectedOccurrenceAlignment
        (d := d) hnUpper)
      (collectedOccurrenceLift
        kernel hnUpper)
      input hsourceSupported factorNormalization hinputWeight

end TSInput

end
  ECThree
end TCTex
end Towers

/-!
# Operational endpoint traces from recipe-chunk-aligned packets

A recipe-chunk alignment compresses ordered same-word recipe chunks into signed
profile packets.  The finite polynomial-orbit trace should retain the flattened
recipe schedule itself: repeated recipe occurrences carry semantic content and
must not be discarded merely because their erased words coincide.

This file compiles a supported all-integral recipe packet
occurrence-for-occurrence, proves that its decoded trace has the same evaluation
as the chunk-aggregated profile assignment, and routes the resulting root-weight
trace through the operational endpoint factorization and Claim 5 adapter.

This file is intentionally not imported by the existing collection proof.
-/

noncomputable section

namespace Towers
namespace TCTex
namespace
  CABounda

universe u

open HACoeff
open ROSuppor
open ROAggreg
open BRSpec
open
  CSAggreg
open
  ACAlign
open
  FCAssign
open UCVocabu
open
  RITrace
open
  ENStab
open
  ESLift
open
  PTRecipe
open
  POSigned
open
  PTSigned
open PFSubsti

/--
Any ordered packet of retained closure recipes is pointwise supported by the
finite polynomial-orbit dictionary.  Repeated occurrences remain allowed.
-/
lemma recipe_supported_recipes
    {n leftWeight rightWeight : ℕ}
    {fixedRecipes : List BRecipe}
    (hrecipes :
      ∀ recipe ∈ fixedRecipes,
        recipe ∈
          correctionClosureRecipes n leftWeight rightWeight) :
    RecipeOrbitSupported n leftWeight rightWeight fixedRecipes := by
  intro recipe hrecipe
  exact
    key_vocabulary_recipes
      (hrecipes recipe hrecipe)

/--
Encode the flattened ordered recipe schedule underlying a chunk-aligned profile
assignment.  The trace deliberately retains repeated occurrences.
-/
noncomputable def chunkAlignedTrace
    {d n leftWeight rightWeight : ℕ}
    (assignment :
      SPAssign n leftWeight rightWeight)
    (packet : TAPkt.{u} d n)
    (hsupport :
      RecipeOrbitSupported n leftWeight rightWeight packet.recipes)
    (_alignment :
      SPAssign.RCAlign
        assignment packet.recipes) :
    List (RetainedOrbitIndex n leftWeight rightWeight) :=
  finIdxAll packet hsupport

/--
Decoding a chunk-aligned trace recovers every flattened recipe orbit key in
order, including repeated occurrences.
-/
lemma key_chunk_aligned
    {d n leftWeight rightWeight : ℕ}
    (assignment :
      SPAssign n leftWeight rightWeight)
    (packet : TAPkt.{u} d n)
    (hsupport :
      RecipeOrbitSupported n leftWeight rightWeight packet.recipes)
    (alignment :
      SPAssign.RCAlign
        assignment packet.recipes) :
    (chunkAlignedTrace
      assignment packet hsupport alignment).map
        retainedOrbitKey =
      packet.recipes.map polynomialOrbitKey := by
  unfold chunkAlignedTrace
  exact
    key_recipe_trace
      packet.recipes hsupport

/--
The occurrence-level finite trace and the chunk-aggregated profile assignment
have the same ordered group evaluation.
-/
lemma packets_chunk_aligned
    {d n leftWeight rightWeight : ℕ}
    (assignment :
      SPAssign n leftWeight rightWeight)
    (packet : TAPkt.{u} d n)
    (hsupport :
      RecipeOrbitSupported n leftWeight rightWeight packet.recipes)
    (alignment :
      SPAssign.RCAlign
        assignment packet.recipes)
    {G : Type*}
    [Group G]
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    ((indexBlockPackets
      (chunkAlignedTrace
        assignment packet hsupport alignment)).map fun signedPacket =>
          signedPacket.word.eval (HPAtom.eval left right) ^
            signedPacket.profiles.value leftExponent rightExponent).prod =
      (assignment.toPackets.map fun signedPacket =>
        signedPacket.word.eval (HPAtom.eval left right) ^
          signedPacket.profiles.value leftExponent rightExponent).prod := by
  unfold chunkAlignedTrace
  unfold finIdxAll
  exact
    (packets_recipe_packet
      packet.recipes hsupport
        left right leftExponent rightExponent).trans
      (alignment.list_recipe_factors
        left right leftExponent rightExponent).symm

/--
The all-integral recipe law compiles to the full semantic law for the
occurrence-preserving finite trace.
-/
lemma satisfies_chunk_aligned
    {d n leftWeight rightWeight : ℕ}
    (assignment :
      SPAssign n leftWeight rightWeight)
    (packet : TAPkt.{u} d n)
    (hsupport :
      RecipeOrbitSupported n leftWeight rightWeight packet.recipes)
    (alignment :
      SPAssign.RCAlign
        assignment packet.recipes) :
    SatisfiesTruncatedEval.{u} (d := d)
      (chunkAlignedTrace
        assignment packet hsupport alignment) := by
  unfold chunkAlignedTrace
  exact
    satisfies_all_packet
      packet hsupport

/--
At root weights, a chunk-aligned occurrence trace aligns with every natural
collected operational endpoint.
-/
noncomputable def
    chunkAlignedAlignment
    {d n : ℕ}
    (assignment : SPAssign n 1 1)
    (packet : TAPkt.{u} d n)
    (hsupport : RecipeOrbitSupported n 1 1 packet.recipes)
    (alignment :
      SPAssign.RCAlign
        assignment packet.recipes) :
    SatisfiesOccurrenceAlignment.{u}
      (d := d) (by simp) (by simp)
        (chunkAlignedTrace
          assignment packet hsupport alignment) :=
  occurrenceAlignmentSatisfies
    (chunkAlignedTrace
      assignment packet hsupport alignment)
    (satisfies_chunk_aligned
      assignment packet hsupport alignment)

/--
At root weights, a chunk-aligned occurrence trace has the signed lift of its
order-aware natural endpoint packet.
-/
noncomputable def chunkAlignedLift
    {d n : ℕ}
    (kernel : OCShape)
    (assignment : SPAssign n 1 1)
    (packet : TAPkt.{u} d n)
    (hsupport : RecipeOrbitSupported n 1 1 packet.recipes)
    (alignment :
      SPAssign.RCAlign
        assignment packet.recipes) :
    OccurrenceAllLift kernel
      (chunkAlignedTrace
        assignment packet hsupport alignment)
      (chunkAlignedAlignment
        assignment packet hsupport alignment) :=
  occurrenceAllSatisfies
    kernel
    (chunkAlignedTrace
      assignment packet hsupport alignment)
    (satisfies_chunk_aligned
      assignment packet hsupport alignment)

/--
A supported chunk-aligned all-integral packet witnesses the operational
factorization of its occurrence-level finite-trace law.
-/
theorem
    chunk_aligned_alignment
    {d n : ℕ}
    (kernel : OCShape)
    (assignment : SPAssign n 1 1)
    (packet : TAPkt.{u} d n)
    (hsupport : RecipeOrbitSupported n 1 1 packet.recipes)
    (alignment :
      SPAssign.RCAlign
        assignment packet.recipes) :
    ∃ halignment :
        SatisfiesOccurrenceAlignment.{u}
          (d := d) (by simp) (by simp)
            (chunkAlignedTrace
              assignment packet hsupport alignment),
      OccurrenceAllLift kernel
        (chunkAlignedTrace
          assignment packet hsupport alignment) halignment :=
  ⟨chunkAlignedAlignment
      assignment packet hsupport alignment,
    chunkAlignedLift
      kernel assignment packet hsupport alignment⟩

namespace TSInput

/--
A supported chunk-aligned occurrence trace supplies the Claim 5 coordinate
polynomials through its operational endpoint alignment and signed lift.
-/
theorem
    chunkAlignedOccurrence
    {d n inputWeight : ℕ}
    (hn : 2 ≤ n)
    (H : ∀ s : ℕ, BCWta.{u} d s)
    (hH :
      ∀ s : ℕ,
        1 ≤ s →
          s < n →
            (H s).FormsAssocGradedbasis (n := n))
    {kernel : OCShape}
    (assignment : SPAssign n 1 1)
    (packet : TAPkt.{u} d n)
    (hsupport : RecipeOrbitSupported n 1 1 packet.recipes)
    (alignment :
      SPAssign.RCAlign
        assignment packet.recipes)
    {e : HEFam H}
    (input :
      TSInput
        (n := n) (inputWeight := inputWeight) H e)
    (hsourceSupported :
      SPFactora.WordWeightLeast inputWeight input.source)
    (factorNormalization :
      ∀ lowerWeight : ℕ,
        ¬n ≤ 2 * lowerWeight →
          TSNormalb
              (n := n) (inputWeight := inputWeight)
                (lowerWeight := lowerWeight + 1) H →
            ∀ (factor : SPFactora H inputWeight),
              factor.word.weight PEAddres.weight = lowerWeight →
              factor.word.weight PEAddres.weight < n →
            TANorm
              (n := n) (lowerWeight := lowerWeight) H factor)
    (hinputWeight : 1 ≤ inputWeight) :
    CollectedPolynomialData (n := n) H e inputWeight :=
  coordOccLift
    hn H hH (kernel := kernel)
      (chunkAlignedTrace
        assignment packet hsupport alignment)
      (chunkAlignedAlignment
        assignment packet hsupport alignment)
      (chunkAlignedLift
        kernel assignment packet hsupport alignment)
      input hsourceSupported factorNormalization hinputWeight

end TSInput

end
  CABounda
end TCTex
