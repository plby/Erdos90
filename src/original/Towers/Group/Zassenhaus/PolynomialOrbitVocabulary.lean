/-!
# Finite polynomial-orbit index traces for fixed recipe packets

A fixed ordered recipe packet whose orbit keys lie in the retained finite
dictionary has an occurrence-preserving finite-index encoding.  Decoding that
trace as singleton signed-block packets preserves its ordered evaluation
exactly.

Consequently, every supported all-integral recipe packet, including one
carrying genuine closed inverse-schedule provenance, reaches the fixed-trace
semantic boundary used by the restricted-sharp Claim 5 route.

This file is intentionally not imported by the existing collection proof.
-/

noncomputable section

namespace Towers
namespace TCTex
namespace
  PTRecipe

universe u

open HACoeff
open ROSuppor
open ROAggreg
open ROTransi
open BRSpec
open
  CSAggreg
open ITSched
open ITSched.PPScheda
open
  UCAll
open
  RITrace
open
  POSigned
open
  PTSigned
open OREnvelo
open
  UREnvelo
open URVocabu
open PFSubsti

/-- Pointwise finite-dictionary support for one fixed ordered recipe packet. -/
def RecipeOrbitSupported
    (n leftWeight rightWeight : ℕ)
    (fixedRecipes : List BRecipe) :
    Prop :=
  ∀ recipe ∈ fixedRecipes,
    polynomialOrbitKey recipe ∈
      retainedOrbitVocabulary n leftWeight rightWeight

/-- The source-plus-operational universal recipe vocabulary is pointwise
supported by the retained finite orbit dictionary. -/
lemma supported_universal_recipes
    (n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight) :
    RecipeOrbitSupported n leftWeight rightWeight
      (recipes n leftWeight rightWeight hleftWeight hrightWeight) := by
  intro recipe hrecipe
  exact
    orbit_key_recipes
      hrecipe

/-- Encode a fixed supported recipe packet occurrence-for-occurrence by
indices into the retained finite polynomial-orbit dictionary. -/
noncomputable def recipeIndexTrace
    {n leftWeight rightWeight : ℕ}
    (fixedRecipes : List BRecipe)
    (hsupport :
      RecipeOrbitSupported n leftWeight rightWeight fixedRecipes) :
    List (RetainedOrbitIndex n leftWeight rightWeight) :=
  orbitIndexTrace
    (fixedRecipes.map polynomialOrbitKey)
    (by
      intro key hkey
      rcases List.mem_map.mp hkey with ⟨recipe, hrecipe, rfl⟩
      exact hsupport recipe hrecipe)

/-- Decoding a supported recipe packet trace recovers its ordered orbit-key
list, including every repeated occurrence. -/
lemma key_recipe_trace
    {n leftWeight rightWeight : ℕ}
    (fixedRecipes : List BRecipe)
    (hsupport :
      RecipeOrbitSupported n leftWeight rightWeight fixedRecipes) :
    (recipeIndexTrace fixedRecipes hsupport).map
        retainedOrbitKey =
      fixedRecipes.map polynomialOrbitKey := by
  unfold recipeIndexTrace
  exact
    retained_key_trace _ _

/-- Encoding and then decoding a supported fixed recipe packet as signed
blocks preserves its complete ordered group evaluation. -/
lemma
    packets_recipe_packet
    {n leftWeight rightWeight : ℕ}
    (fixedRecipes : List BRecipe)
    (hsupport :
      RecipeOrbitSupported n leftWeight rightWeight fixedRecipes)
    {G : Type*}
    [Group G]
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    ((indexBlockPackets
      (recipeIndexTrace fixedRecipes hsupport)).map fun packet =>
        packet.word.eval (HPAtom.eval left right) ^
          packet.profiles.value leftExponent rightExponent).prod =
      (fixedRecipes.map fun recipe =>
        recipe.erasedShape.eval (HPAtom.eval left right) ^
          coefficientValue recipe leftExponent rightExponent).prod := by
  unfold indexBlockPackets
  unfold recipeIndexTrace
  rw [
    retained_index_trace,
    list_block_packets]
  exact
    keys_orbit_key
      fixedRecipes left right leftExponent rightExponent

/-- The finite-index trace underlying a supported all-integral recipe packet. -/
noncomputable def finIdxAll
    {d n leftWeight rightWeight : ℕ}
    (packet : TAPkt.{u} d n)
    (hsupport :
      RecipeOrbitSupported n leftWeight rightWeight packet.recipes) :
    List (RetainedOrbitIndex n leftWeight rightWeight) :=
  recipeIndexTrace packet.recipes hsupport

/-- A supported all-integral recipe packet satisfies the fixed finite-index
trace semantic law. -/
lemma
    satisfies_all_packet
    {d n leftWeight rightWeight : ℕ}
    (packet : TAPkt.{u} d n)
    (hsupport :
      RecipeOrbitSupported n leftWeight rightWeight packet.recipes) :
    SatisfiesTruncatedEval.{u} (d := d)
      (finIdxAll packet hsupport) := by
  intro left right leftExponent rightExponent
  unfold finIdxAll
  rw [
    packets_recipe_packet]
  exact packet.listEval_eq left right leftExponent rightExponent

/-- Package a supported all-integral recipe packet as the ordered cutoff
signed-block packet represented by its finite-index trace. -/
noncomputable def
    truncatedAllPacket
    {d n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (packet : TAPkt.{u} d n)
    (hsupport :
      RecipeOrbitSupported n leftWeight rightWeight packet.recipes) :
    TAPkta.{u}
      d n leftWeight rightWeight :=
  allBlockPacket
    hleftWeight hrightWeight
    (finIdxAll packet hsupport)
    (satisfies_all_packet
      packet hsupport)

/-- The finite-index trace of a supported fixed signed packet produced by a
closed inverse-history schedule normalization. -/
noncomputable def indexUniformPacket
    {kernel : PPScheda}
    {fixedRecipes : List BRecipe}
    {d n leftWeight rightWeight : ℕ}
    (_packet : USPkt.{u} kernel fixedRecipes d n)
    (hsupport :
      RecipeOrbitSupported n leftWeight rightWeight fixedRecipes) :
    List (RetainedOrbitIndex n leftWeight rightWeight) :=
  recipeIndexTrace fixedRecipes hsupport

/-- Genuine schedule provenance plus retained orbit support supplies the fixed
finite-index trace semantic law. -/
lemma
    satisfies_uniform_packet
    {kernel : PPScheda}
    {fixedRecipes : List BRecipe}
    {d n leftWeight rightWeight : ℕ}
    (packet : USPkt.{u} kernel fixedRecipes d n)
    (hsupport :
      RecipeOrbitSupported n leftWeight rightWeight fixedRecipes) :
    SatisfiesTruncatedEval.{u} (d := d)
      (indexUniformPacket packet hsupport) := by
  intro left right leftExponent rightExponent
  unfold indexUniformPacket
  rw [
    packets_recipe_packet]
  exact
    packet.truncatedAll.listEval_eq
      left right leftExponent rightExponent

/-- Finite-index trace of the fixed source-plus-operational universal recipe
vocabulary. -/
noncomputable def universalRecipeTrace
    (n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight) :
    List (RetainedOrbitIndex n leftWeight rightWeight) :=
  recipeIndexTrace
    (recipes n leftWeight rightWeight hleftWeight hrightWeight)
    (supported_universal_recipes
      n leftWeight rightWeight hleftWeight hrightWeight)

/-- A signed schedule normalization of the universal operational vocabulary
instantiates the fixed retained-index trace semantic obligation. -/
lemma
    satisfies_idx_uniform
    {kernel : PPScheda}
    {d n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (packet :
      USPkt.{u} kernel
        (recipes n leftWeight rightWeight hleftWeight hrightWeight) d n) :
    SatisfiesTruncatedEval.{u} (d := d)
      (universalRecipeTrace
        n leftWeight rightWeight hleftWeight hrightWeight) := by
  unfold universalRecipeTrace
  exact
    satisfies_uniform_packet
      packet
      (supported_universal_recipes
        n leftWeight rightWeight hleftWeight hrightWeight)

namespace TSInput

/-- A retained-orbit-supported all-integral recipe packet supplies the Claim 5
coordinate polynomials through its occurrence-preserving finite-index trace. -/
theorem allRecipePacket
    {d n inputWeight : ℕ}
    (hn : 2 ≤ n)
    (H : ∀ s : ℕ, BCWta.{u} d s)
    (hH :
      ∀ s : ℕ,
        1 ≤ s →
          s < n →
            (H s).FormsAssocGradedbasis (n := n))
    {kernel : OCShape}
    (packet : TAPkt.{u} d n)
    (hsupport : RecipeOrbitSupported n 1 1 packet.recipes)
    {e : HEFam H}
    (input :
      TSInput
        (n := n) (inputWeight := inputWeight) H e)
    (hsourceSupported :
      SPFactora.WordWeightLeast inputWeight input.source)
    (factorNormalization :
      ∀ lowerWeight : ℕ,
        ¬n ≤ 2 * lowerWeight →
          TSNormalb
              (n := n) (inputWeight := inputWeight)
                (lowerWeight := lowerWeight + 1) H →
            ∀ (factor : SPFactora H inputWeight),
              factor.word.weight PEAddres.weight = lowerWeight →
              factor.word.weight PEAddres.weight < n →
            TANorm
              (n := n) (lowerWeight := lowerWeight) H factor)
    (hinputWeight : 1 ≤ inputWeight) :
    CollectedPolynomialData (n := n) H e inputWeight :=
  coordPolyPacket
    hn H hH (kernel := kernel)
      (finIdxAll packet hsupport)
      (satisfies_all_packet
        packet hsupport)
      input hsourceSupported factorNormalization hinputWeight

/-- A supported fixed signed packet carrying genuine closed inverse-schedule
provenance supplies the Claim 5 coordinate polynomials. -/
theorem uniformRecipePacket
    {scheduleKernel : PPScheda}
    {fixedRecipes : List BRecipe}
    {d n inputWeight : ℕ}
    (hn : 2 ≤ n)
    (H : ∀ s : ℕ, BCWta.{u} d s)
    (hH :
      ∀ s : ℕ,
        1 ≤ s →
          s < n →
            (H s).FormsAssocGradedbasis (n := n))
    {signedBlockKernel : OCShape}
    (packet :
      USPkt.{u}
        scheduleKernel fixedRecipes d n)
    (hsupport : RecipeOrbitSupported n 1 1 fixedRecipes)
    {e : HEFam H}
    (input :
      TSInput
        (n := n) (inputWeight := inputWeight) H e)
    (hsourceSupported :
      SPFactora.WordWeightLeast inputWeight input.source)
    (factorNormalization :
      ∀ lowerWeight : ℕ,
        ¬n ≤ 2 * lowerWeight →
          TSNormalb
              (n := n) (inputWeight := inputWeight)
                (lowerWeight := lowerWeight + 1) H →
            ∀ (factor : SPFactora H inputWeight),
              factor.word.weight PEAddres.weight = lowerWeight →
              factor.word.weight PEAddres.weight < n →
            TANorm
              (n := n) (lowerWeight := lowerWeight) H factor)
    (hinputWeight : 1 ≤ inputWeight) :
    CollectedPolynomialData (n := n) H e inputWeight :=
  allRecipePacket
    hn H hH (kernel := signedBlockKernel)
      packet.truncatedAll
      (by simpa only [
        PPScheda.USPkt.recipes_all_packet]
          using
          hsupport)
      input hsourceSupported factorNormalization hinputWeight

end TSInput

end
  PTRecipe
end TCTex
end Towers

/-!
# Semantic boundary for local polynomial-orbit index-trace programs

The retained-history grid presents each below-cutoff local correction cell as
an indexed symbolic Hall program.  The generic supported-obstruction decoder
gives the same program without mentioning the ambient grid.  This file
identifies the two presentations and transfers the generic semantic and
physical cutoff facts back to each local cell.

All equalities preserve the operational order literally.
This file is intentionally not imported by the existing collection proof.
-/

namespace Towers
namespace TCTex
namespace
  LSSem

universe u

open RREvalua
open
  ILProgra
open
  LSProgra
open
  RSProgra
open OREnvelo
open
  OSVocab
open RPEnvelo

/--
Below cutoff, the local retained-history cell is exactly the generic symbolic
decoder for its supported recipe-free obstruction.
-/
lemma local_symbolic_factors
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    (hroot :
      (universalOrbitObstruction
        hleftWeight hrightWeight leftHistory rightHistory).weight
          leftWeight rightWeight < n)
    (left right : SPFactor H ι) :
    universalOperationalFactors
        normalizer hleftWeight hrightWeight
          leftHistory rightHistory left right =
      retainedIdxFactors normalizer
        hleftWeight hrightWeight
        (universalOrbitObstruction
          hleftWeight hrightWeight leftHistory rightHistory)
        (universal_obstruction_supported
          hleftWeight hrightWeight leftHistory rightHistory hroot)
        left right := by
  unfold universalOperationalFactors
  unfold retainedIdxFactors
  rw [
    universal_operational_weight
      hleftWeight hrightWeight leftHistory rightHistory hroot]

/--
Evaluating one below-cutoff local grid cell is exactly the recipe-free
operational orbit evaluation rooted at that cell.
-/
lemma factors_operational_weight
    {d truncation : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    (hroot :
      (universalOrbitObstruction
        hleftWeight hrightWeight leftHistory rightHistory).weight
          leftWeight rightWeight < n)
    (left right : SPFactor H ι) :
    SPFactor.listEval (n := truncation) e
        (universalOperationalFactors
          normalizer hleftWeight hrightWeight
            leftHistory rightHistory left right) =
      RREvalua.listEval
        (n := n) hleftWeight hrightWeight
        (universalOrbitObstruction
          hleftWeight hrightWeight leftHistory rightHistory)
        (left.wordValue (n := truncation))
        (right.wordValue (n := truncation))
        (left.coefficient.eval e) (right.coefficient.eval e) := by
  rw [
    local_symbolic_factors
      normalizer hleftWeight hrightWeight
        leftHistory rightHistory hroot left right]
  exact
    symbolic_factors_operational
      normalizer e hleftWeight hrightWeight
      (universalOrbitObstruction
        hleftWeight hrightWeight leftHistory rightHistory)
      (universal_obstruction_supported
        hleftWeight hrightWeight leftHistory rightHistory hroot)
      left right

/-- Every factor in one below-cutoff local cell belongs to the fixed
cutoff-sized symbolic dictionary. -/
lemma subset_vocabulary_weight
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    (hroot :
      (universalOrbitObstruction
        hleftWeight hrightWeight leftHistory rightHistory).weight
          leftWeight rightWeight < n)
    (left right : SPFactor H ι) :
    universalOperationalFactors
        normalizer hleftWeight hrightWeight
          leftHistory rightHistory left right ⊆
      retainedPolyVocab
        normalizer n leftWeight rightWeight left right := by
  rw [
    local_symbolic_factors
      normalizer hleftWeight hrightWeight
        leftHistory rightHistory hroot left right]
  exact
    symbolic_subset_vocabulary
      normalizer hleftWeight hrightWeight
      (universalOrbitObstruction
        hleftWeight hrightWeight leftHistory rightHistory)
      (universal_obstruction_supported
        hleftWeight hrightWeight leftHistory rightHistory hroot)
      left right

/-- Every factor in one below-cutoff local cell is physically below the
cutoff when the symbolic parents have their declared weights. -/
lemma cutoff_symbolic_factors
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    (hroot :
      (universalOrbitObstruction
        hleftWeight hrightWeight leftHistory rightHistory).weight
          leftWeight rightWeight < n)
    (left right factor : SPFactor H ι)
    (hleft :
      left.word.weight HEAddres.weight = leftWeight)
    (hright :
      right.word.weight HEAddres.weight = rightWeight)
    (hfactor :
      factor ∈
        universalOperationalFactors
          normalizer hleftWeight hrightWeight
            leftHistory rightHistory left right) :
    factor.word.weight HEAddres.weight < n := by
  apply
    orbit_symbolic_vocabulary
      normalizer hleftWeight hrightWeight left right factor hleft hright
  exact
    subset_vocabulary_weight
      normalizer hleftWeight hrightWeight
        leftHistory rightHistory hroot left right hfactor

/-- Physical cutoff truncation removes no factor from one below-cutoff local
symbolic grid cell. -/
@[simp]
lemma truncate_self_weight
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    (hroot :
      (universalOrbitObstruction
        hleftWeight hrightWeight leftHistory rightHistory).weight
          leftWeight rightWeight < n)
    (left right : SPFactor H ι)
    (hleft :
      left.word.weight HEAddres.weight = leftWeight)
    (hright :
      right.word.weight HEAddres.weight = rightWeight) :
    SPFactor.truncate n
        (universalOperationalFactors
          normalizer hleftWeight hrightWeight
            leftHistory rightHistory left right) =
      universalOperationalFactors
        normalizer hleftWeight hrightWeight
          leftHistory rightHistory left right := by
  apply List.filter_eq_self.2
  intro factor hfactor
  simpa only [decide_eq_true_eq] using
    cutoff_symbolic_factors
      normalizer hleftWeight hrightWeight
        leftHistory rightHistory hroot left right factor
        hleft hright hfactor

end
  LSSem
end TCTex
end Towers

/-!
# Symbolic vocabulary closure for finite-index recollection traces

Every trace over the finite polynomial-orbit index type decodes into the fixed
symbolic factor dictionary.  Consequently, every decoded trace is already
stable under truncation at the declared cutoff.
-/

namespace Towers
namespace TCTex
namespace ISClos

open RITrace
open OSVocab
open LSProgra
open RPEnvelo

/-- Every finite orbit index decodes to a packet in the fixed packet dictionary. -/
lemma block_packet_vocabulary
    {n leftWeight rightWeight : ℕ}
    (index : RetainedOrbitIndex n leftWeight rightWeight) :
    orbitBlockPacket index ∈
      blockPacketVocabulary
        n leftWeight rightWeight := by
  unfold orbitBlockPacket
  exact retained_packet_vocabulary
    ⟨retainedOrbitKey index,
      retained_orbit_key index⟩

/-- Every finite orbit index decodes to a factor in the fixed symbolic dictionary. -/
lemma retained_symbolic_vocabulary
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n leftWeight rightWeight : ℕ}
    (left right : SPFactor H ι)
    (index : RetainedOrbitIndex n leftWeight rightWeight) :
    orbitSymbolicFactor normalizer left right index ∈
      retainedPolyVocab
        normalizer n leftWeight rightWeight left right := by
  unfold orbitSymbolicFactor
  unfold retainedPolyVocab
  exact List.mem_map.mpr
    ⟨orbitBlockPacket index,
      block_packet_vocabulary index,
      rfl⟩

/-- Decoding an arbitrary finite-index trace stays inside the fixed dictionary. -/
lemma retained_subset_vocabulary
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n leftWeight rightWeight : ℕ}
    (left right : SPFactor H ι)
    (trace : List (RetainedOrbitIndex n leftWeight rightWeight)) :
    trace.map (orbitSymbolicFactor normalizer left right) ⊆
      retainedPolyVocab
        normalizer n leftWeight rightWeight left right := by
  intro factor hfactor
  rcases List.mem_map.mp hfactor with ⟨index, _hindex, rfl⟩
  exact retained_symbolic_vocabulary
    normalizer left right index

/-- Every factor decoded from a finite orbit index lies strictly below the cutoff. -/
lemma orbit_symbolic_factor
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = leftWeight)
    (hright : right.word.weight HEAddres.weight = rightWeight)
    (index : RetainedOrbitIndex n leftWeight rightWeight) :
    (orbitSymbolicFactor
      normalizer left right index).word.weight HEAddres.weight < n :=
  orbit_symbolic_vocabulary
    normalizer hleftWeight hrightWeight left right
      (orbitSymbolicFactor normalizer left right index)
      hleft hright
      (retained_symbolic_vocabulary
        normalizer left right index)

/-- Truncation leaves every symbolic trace decoded from the finite index alphabet unchanged. -/
@[simp]
lemma truncate_symbolic_self
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = leftWeight)
    (hright : right.word.weight HEAddres.weight = rightWeight)
    (trace : List (RetainedOrbitIndex n leftWeight rightWeight)) :
    SPFactor.truncate n
        (trace.map
          (orbitSymbolicFactor normalizer left right)) =
      trace.map
        (orbitSymbolicFactor normalizer left right) := by
  apply List.filter_eq_self.2
  intro factor hfactor
  rcases List.mem_map.mp hfactor with ⟨index, _hindex, rfl⟩
  simpa only [decide_eq_true_eq] using
    orbit_symbolic_factor
      normalizer hleftWeight hrightWeight left right hleft hright index

/-- Each local recursive symbolic correction program stays inside the fixed dictionary. -/
lemma universal_subset_vocabulary
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    (left right : SPFactor H ι) :
    universalOperationalFactors
        normalizer hleftWeight hrightWeight
          leftHistory rightHistory left right ⊆
      retainedPolyVocab
        normalizer n leftWeight rightWeight left right := by
  unfold universalOperationalFactors
  exact retained_subset_vocabulary
    normalizer left right _

/-- Each local recursive symbolic correction program is already below the cutoff. -/
@[simp]
lemma truncate_universal_self
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    (left right : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = leftWeight)
    (hright : right.word.weight HEAddres.weight = rightWeight) :
    SPFactor.truncate n
        (universalOperationalFactors
          normalizer hleftWeight hrightWeight
            leftHistory rightHistory left right) =
      universalOperationalFactors
        normalizer hleftWeight hrightWeight
          leftHistory rightHistory left right := by
  unfold universalOperationalFactors
  exact truncate_symbolic_self
    normalizer hleftWeight hrightWeight left right hleft hright _

end ISClos
end TCTex
end Towers

/-!
# Explicit fixed finite-index traces at cutoff at most three

Below weight two the all-integral powered commutator packet is empty.  At
cutoff three its unique retained occurrence is the basic Hall-pair recipe.
This file encodes those explicit packets as fixed traces over the retained
polynomial-orbit dictionary and sends their semantic law to the Claim 5
coordinate-polynomial route.

This file is intentionally not imported by the existing collection proof.
-/

noncomputable section

namespace Towers
namespace TCTex
namespace
  RILow

universe u

open scoped commutatorElement

open HACoeff
open ROSuppor
open ROAggreg
open ROTransi
open BRSpec
open
  CSAggreg
open RHRecurs
open RHRecipe
open RRVocabu
open
  UCAll
open CLPacket
open UCVocabu
open
  RITrace
open
  POSigned
open
  PTRecipe
open
  PTSigned
open URVocabu

/-- The basic Hall-pair polynomial orbit is retained in the cutoff-three
dictionary.  The witness is the first explicit basic raw inverse history. -/
lemma key_vocabulary_three :
    polynomialOrbitKey hallPair ∈
      retainedOrbitVocabulary 3 1 1 := by
  let history : RHistor 3 3 :=
    .hallPair (Sum.inl 0) (Sum.inr 0)
  have hhistory :
      history ∈ inverseRawHistories 3 3 := by
    simp [history, inverseRawHistories, labelledLeftAtoms, labelledRightAtoms,
      inverseLeftHistories, inverseRightHistories,
      inverseConjHistory, inverseConjHistories]
  let recipe :=
    RRVocabu.RHistor.initialRecipe
      history hhistory
  have hkey :
      polynomialOrbitKey recipe.blockRecipe =
        polynomialOrbitKey hallPair := by
    dsimp [recipe, history]
    apply polynomial_orbit_key.mpr
    constructor
    · change
        [(LRecipe.ofLabelLinear
          (.commutator
            (.atom (Sum.inl (0 : Fin 3) : LabelledAtom 3 3))
            (.atom (Sum.inr (0 : Fin 3) : LabelledAtom 3 3))) _ _).leftDegree] =
            [1]
      congr 1
    constructor
    · change
        [(LRecipe.ofLabelLinear
          (.commutator
            (.atom (Sum.inl (0 : Fin 3) : LabelledAtom 3 3))
            (.atom (Sum.inr (0 : Fin 3) : LabelledAtom 3 3))) _ _).rightDegree] =
            [1]
      congr 1
    · change
        (LRecipe.ofLabelLinear
          (.commutator
            (.atom (Sum.inl (0 : Fin 3) : LabelledAtom 3 3))
            (.atom (Sum.inr (0 : Fin 3) : LabelledAtom 3 3)))
              (by
                simp [collapseWord, collapseLabel,
                  CWord.PBPos])
              (by
                simp [LabelLinear, labelSupport])).erasedShape =
            CWord.hallPairBase
      rw [erased_label_linear]
      rfl
  have hinitial :
      recipe ∈ retainedInitialRecipes 3 3 1 1 := by
    apply retained_initial_recipes.mpr
    constructor
    · rw [initialRecipes, List.mem_map]
      exact ⟨⟨history, hhistory⟩, by simp, rfl⟩
    · rw [
        RRVocabu.RHistor.initial_recipe_weight]
      simp [history, HHTrunc.RHistor.weight,
        collapseWord, collapseLabel, HPAtom.weight]
  have hsource :
      recipe.blockRecipe ∈ sourceRecipes 3 1 1 :=
    List.mem_map.mpr ⟨recipe, hinitial, rfl⟩
  rw [← hkey]
  apply
    key_vocabulary_recipes
  apply retained_correction_closure.mpr
  constructor
  · exact correction_closure
      (show recipe.blockRecipe ∈ correctionClosure (sourceRecipes 3 1 1) 0 by
        exact hsource)
      (Nat.zero_le _)
  · exact weighted_cutoff_recipes hsource

/-- Fixed finite-index trace for the complete all-integral packet at cutoff at
most three: empty through cutoff two and singleton basic at cutoff three. -/
noncomputable def lowIndexTrace
    (n : ℕ)
    (hn : n ≤ 3) :
    List (RetainedOrbitIndex n 1 1) :=
  if hlow : n ≤ 2 then
    []
  else
    recipeIndexTrace [hallPair] (by
      intro recipe hrecipe
      have hnThree : n = 3 := by omega
      subst n
      rcases List.mem_singleton.mp hrecipe with rfl
      exact
        key_vocabulary_three)

/-- The explicit low-cutoff trace has the full all-integral powered
commutator law. -/
lemma satisfies_low_cutoff
    {d n : ℕ}
    (hn : n ≤ 3) :
    SatisfiesTruncatedEval.{u} (d := d)
      (lowIndexTrace n hn) := by
  by_cases hlow : n ≤ 2
  · intro left right leftExponent rightExponent
    rw [lowIndexTrace, dif_pos hlow]
    simpa only [indexBlockPackets, List.map_nil,
      List.prod_nil] using
        (empty_n_two (d := d) hlow).listEval_eq
          left right leftExponent rightExponent
  · intro left right leftExponent rightExponent
    rw [lowIndexTrace, dif_neg hlow,
      packets_recipe_packet]
    exact
      (PFSubsti.TAPkt.n_three
        (d := d) hn).listEval_eq
          left right leftExponent rightExponent

/-- The explicit low-cutoff finite trace as the closure-supported ordered
signed-block packet consumed by symbolic recollection. -/
noncomputable def
    lowAllPacket
    {d n : ℕ}
    (hn : n ≤ 3) :
    TAPkta.{u} d n 1 1 :=
  allBlockPacket
    (by omega) (by omega)
    (lowIndexTrace n hn)
    (satisfies_low_cutoff
      (d := d) hn)

namespace TSInput

/-- At cutoff at most three, the explicit fixed retained-index trace supplies
the Claim 5 coordinate polynomials. -/
theorem coordinateLowPacket
    {d n inputWeight : ℕ}
    (hn : 2 ≤ n)
    (hnUpper : n ≤ 3)
    (H : ∀ s : ℕ, BCWta.{u} d s)
    (hH :
      ∀ s : ℕ,
        1 ≤ s →
          s < n →
            (H s).FormsAssocGradedbasis (n := n))
    {kernel : OCShape}
    {e : HEFam H}
    (input :
      TSInput
        (n := n) (inputWeight := inputWeight) H e)
    (hsourceSupported :
      SPFactora.WordWeightLeast inputWeight input.source)
    (factorNormalization :
      ∀ lowerWeight : ℕ,
        ¬n ≤ 2 * lowerWeight →
          TSNormalb
              (n := n) (inputWeight := inputWeight)
                (lowerWeight := lowerWeight + 1) H →
            ∀ (factor : SPFactora H inputWeight),
              factor.word.weight PEAddres.weight = lowerWeight →
              factor.word.weight PEAddres.weight < n →
            TANorm
              (n := n) (lowerWeight := lowerWeight) H factor)
    (hinputWeight : 1 ≤ inputWeight) :
    CollectedPolynomialData (n := n) H e inputWeight :=
  coordPolyPacket
    hn H hH (kernel := kernel)
      (lowIndexTrace n hnUpper)
      (satisfies_low_cutoff
        (d := d) hnUpper)
      input hsourceSupported factorNormalization hinputWeight

end TSInput

end
  RILow
end TCTex
end Towers

/-!
# Finite orbit-index traces for concrete retained operational corrections

The terminating More3 collector emits a concrete ordered correction list.
After cutoff filtering, every retained occurrence has an erased-word
representative in the finite correction closure.  This file chooses one such
representative occurrence-by-occurrence and encodes the resulting ordered
packet by indices into the retained polynomial-orbit vocabulary.

The selected closure recipes preserve the concrete erased Hall words in their
original order.  Their coefficient profiles remain explicit: this boundary
does not identify representative coefficients with concrete multiplicity
data or permute noncommuting factors.

This file is intentionally not imported by the existing collection proof.
-/

noncomputable section

namespace Towers
namespace TCTex
namespace
  TPBounda

open HACoeff
open
  ROSuppor
open ROAggreg
open ROTransi
open BRSpec
open OCPartit
open FMEnd
open
  UCSuppor
open UCVocabu
open RITrace
open
  POSigned
open
  PTRecipe
open UREnvelo

/-- Every retained concrete correction occurrence has an erased-word
representative in the finite correction closure. -/
lemma retained_closure_recipe
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {endpoint : ODEmissi M N}
    (partition :
      CCPartit endpoint
        n leftWeight rightWeight)
    (term : DFTerm M N
      (inverseLabelledCollection M N).factors.length)
    (hterm : term ∈ partition.retained) :
    ∃ recipe ∈
        correctionClosureRecipes n leftWeight rightWeight,
      recipe.erasedShape = term.erasedShape := by
  apply endpoint_corrections
    hleftWeight hrightWeight endpoint term
  · exact partition.corrections_perm.symm.subset
      (List.mem_append_left _ hterm)
  · have hweight := partition.retained_weight_lt term hterm
    simpa [decoratedFamilyWeight, weightedWordWeight,
      term.erased_shape_family] using hweight

/-- Choose one retained closure representative for one concrete retained
correction occurrence. -/
noncomputable def closureRecipeTerm
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {endpoint : ODEmissi M N}
    (partition :
      CCPartit endpoint
        n leftWeight rightWeight)
    (term : DFTerm M N
      (inverseLabelledCollection M N).factors.length)
    (hterm : term ∈ partition.retained) :
    BRecipe :=
  Classical.choose
    (retained_closure_recipe
      hleftWeight hrightWeight partition term hterm)

/-- The selected occurrence representative belongs to the finite correction
closure. -/
lemma closure_recipe_term
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {endpoint : ODEmissi M N}
    (partition :
      CCPartit endpoint
        n leftWeight rightWeight)
    (term : DFTerm M N
      (inverseLabelledCollection M N).factors.length)
    (hterm : term ∈ partition.retained) :
    closureRecipeTerm
        hleftWeight hrightWeight partition term hterm ∈
      correctionClosureRecipes n leftWeight rightWeight :=
  (Classical.choose_spec
    (retained_closure_recipe
      hleftWeight hrightWeight partition term hterm)).1

/-- The selected occurrence representative has the concrete retained term's
erased Hall word. -/
@[simp]
lemma erased_closure_term
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {endpoint : ODEmissi M N}
    (partition :
      CCPartit endpoint
        n leftWeight rightWeight)
    (term : DFTerm M N
      (inverseLabelledCollection M N).factors.length)
    (hterm : term ∈ partition.retained) :
    (closureRecipeTerm
      hleftWeight hrightWeight partition term hterm).erasedShape =
        term.erasedShape :=
  (Classical.choose_spec
    (retained_closure_recipe
      hleftWeight hrightWeight partition term hterm)).2

/-- Ordered finite-closure representatives of all retained concrete
correction occurrences. -/
noncomputable def closureRecipePacket
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {endpoint : ODEmissi M N}
    (partition :
      CCPartit endpoint
        n leftWeight rightWeight) :
    List BRecipe :=
  partition.retained.attach.map fun term =>
    closureRecipeTerm
      hleftWeight hrightWeight partition term.1 term.2

/-- Every selected representative in the ordered packet belongs to the finite
correction closure. -/
lemma closure_recipes_packet
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {endpoint : ODEmissi M N}
    (partition :
      CCPartit endpoint
        n leftWeight rightWeight)
    {recipe : BRecipe}
    (hrecipe :
      recipe ∈
        closureRecipePacket
          hleftWeight hrightWeight partition) :
    recipe ∈ correctionClosureRecipes n leftWeight rightWeight := by
  unfold closureRecipePacket at hrecipe
  rcases List.mem_map.mp hrecipe with ⟨term, _hterm, rfl⟩
  exact
    closure_recipe_term
      hleftWeight hrightWeight partition term.1 term.2

/-- The representative packet retains the exact concrete erased-word list,
including occurrence order and repetition. -/
lemma erased_closure_packet
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {endpoint : ODEmissi M N}
    (partition :
      CCPartit endpoint
        n leftWeight rightWeight) :
    (closureRecipePacket
        hleftWeight hrightWeight partition).map BRecipe.erasedShape =
      partition.retained.map DFTerm.erasedShape := by
  unfold closureRecipePacket
  simp only [List.map_map]
  simp

/-- The ordered representative packet is pointwise supported by the retained
polynomial-orbit dictionary. -/
lemma recipe_supported_closure
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {endpoint : ODEmissi M N}
    (partition :
      CCPartit endpoint
        n leftWeight rightWeight) :
    RecipeOrbitSupported n leftWeight rightWeight
      (closureRecipePacket
        hleftWeight hrightWeight partition) := by
  intro recipe hrecipe
  apply
    key_vocabulary_recipes
  exact
    closure_recipes_packet
      hleftWeight hrightWeight partition hrecipe

/-- Occurrence-preserving finite orbit-index trace of retained concrete
operational corrections. -/
noncomputable def retainedCorrectionTrace
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {endpoint : ODEmissi M N}
    (partition :
      CCPartit endpoint
        n leftWeight rightWeight) :
    List (RetainedOrbitIndex n leftWeight rightWeight) :=
  recipeIndexTrace
    (closureRecipePacket
      hleftWeight hrightWeight partition)
    (recipe_supported_closure
      hleftWeight hrightWeight partition)

/-- Decoding the retained-correction index trace recovers the selected
representative orbit-key list literally. -/
lemma key_index_trace
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {endpoint : ODEmissi M N}
    (partition :
      CCPartit endpoint
        n leftWeight rightWeight) :
    (retainedCorrectionTrace
      hleftWeight hrightWeight partition).map
        retainedOrbitKey =
      (closureRecipePacket
        hleftWeight hrightWeight partition).map polynomialOrbitKey := by
  unfold retainedCorrectionTrace
  exact
    key_recipe_trace
      (closureRecipePacket
        hleftWeight hrightWeight partition)
      (recipe_supported_closure
        hleftWeight hrightWeight partition)

/-- Retained operational corrections as an ordered cutoff-supported
signed-block packet over the finite orbit dictionary. -/
noncomputable def signedBlockPacket
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {endpoint : ODEmissi M N}
    (partition :
      CCPartit endpoint
        n leftWeight rightWeight) :
    OBPkt n leftWeight rightWeight :=
  indexBlockPacket
    hleftWeight hrightWeight
    (retainedCorrectionTrace
      hleftWeight hrightWeight partition)

@[simp]
lemma packets_ordered_packet
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {endpoint : ODEmissi M N}
    (partition :
      CCPartit endpoint
        n leftWeight rightWeight) :
    (signedBlockPacket
      hleftWeight hrightWeight partition).packets =
        indexBlockPackets
          (retainedCorrectionTrace
            hleftWeight hrightWeight partition) :=
  rfl

/-- For any fixed supported recipe packet, decoding its finite-index trace as
singleton signed blocks preserves its ordered erased-word list. -/
lemma block_packets_packet
    {n leftWeight rightWeight : ℕ}
    (fixedRecipes : List BRecipe)
    (hsupport :
      RecipeOrbitSupported n leftWeight rightWeight fixedRecipes) :
    (indexBlockPackets
      (recipeIndexTrace fixedRecipes hsupport)).map
        (fun packet => packet.word) =
      fixedRecipes.map BRecipe.erasedShape := by
  unfold indexBlockPackets
  rw [List.map_map]
  calc
    (recipeIndexTrace fixedRecipes hsupport).map
          (fun index =>
            (orbitBlockPacket index).word) =
        (recipeIndexTrace fixedRecipes hsupport).map
          (fun index => (retainedOrbitKey index).erasedShape) := by
            apply List.map_congr_left
            intro index _hindex
            unfold orbitBlockPacket
            exact orbit_block_packet _
    _ =
        ((recipeIndexTrace fixedRecipes hsupport).map
          retainedOrbitKey).map POKey.erasedShape := by
            rw [List.map_map]
            apply List.map_congr_left
            intro index _hindex
            rfl
    _ = (fixedRecipes.map polynomialOrbitKey).map
          POKey.erasedShape := by
            rw [
              key_recipe_trace]
    _ = fixedRecipes.map BRecipe.erasedShape := by
            rw [List.map_map]
            rfl

/-- Decoding retained concrete corrections as singleton signed blocks
recovers their erased Hall words occurrence-for-occurrence. -/
lemma index_packets_correction
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {endpoint : ODEmissi M N}
    (partition :
      CCPartit endpoint
        n leftWeight rightWeight) :
    (indexBlockPackets
      (retainedCorrectionTrace
        hleftWeight hrightWeight partition)).map
          (fun packet => packet.word) =
      partition.retained.map DFTerm.erasedShape := by
  unfold retainedCorrectionTrace
  rw [
    block_packets_packet,
    erased_closure_packet]

/-- The ordered cutoff packet adapter exposes the exact concrete retained
erased-word list. -/
lemma word_packets_packet
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {endpoint : ODEmissi M N}
    (partition :
      CCPartit endpoint
        n leftWeight rightWeight) :
    (signedBlockPacket
      hleftWeight hrightWeight partition).packets.map
        (fun packet => packet.word) =
      partition.retained.map DFTerm.erasedShape := by
  rw [
    packets_ordered_packet,
    index_packets_correction]

/-- The decoded retained-correction trace evaluates exactly as its selected
finite-closure representatives.  This theorem deliberately leaves the
representative coefficient profiles visible. -/
lemma
    block_packets_correction
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {endpoint : ODEmissi M N}
    (partition :
      CCPartit endpoint
        n leftWeight rightWeight)
    {G : Type*}
    [Group G]
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    ((indexBlockPackets
      (retainedCorrectionTrace
        hleftWeight hrightWeight partition)).map fun packet =>
          packet.word.eval (HPAtom.eval left right) ^
            packet.profiles.value leftExponent rightExponent).prod =
      ((closureRecipePacket
        hleftWeight hrightWeight partition).map fun recipe =>
          recipe.erasedShape.eval (HPAtom.eval left right) ^
            coefficientValue recipe leftExponent rightExponent).prod := by
  unfold retainedCorrectionTrace
  exact
    packets_recipe_packet
      (closureRecipePacket
        hleftWeight hrightWeight partition)
      (recipe_supported_closure
        hleftWeight hrightWeight partition)
      left right leftExponent rightExponent

end
  TPBounda
end TCTex
end Towers

/-!
# Global operational evaluation of finite-index symbolic envelopes

The complete arbitrary-multiplicity symbolic envelope is a source segment
followed by an ordered retained-history pair grid.  This file evaluates that
grid as an ordered matrix product of local recipe-free operational orbit
evaluators.  Above-cutoff cells contribute the identity.

This remains a conservative-envelope theorem.  It preserves the operational
order literally and does not identify the envelope with a semantic collection
schedule.
-/

namespace Towers
namespace TCTex
namespace
  IGEvalua

universe u

open RREvalua
open RRPkt
open
  RRPkt.POObstru
open
  RITrace
open
  IEDecomp
open
  ILProgra
open
  LSProgra
open
  RSProgra
open
  ISProgra
open RCCompar
open OREnvelo
open RSEnvelo
open RPEnvelo

/-- Ordered symbolic evaluation distributes over an ordered `flatMap`. -/
lemma SPFactor.list_eval_flatmap
    {d truncation : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι alpha : Type}
    (e : ι → HEFam H)
    (items : List alpha)
    (factors : alpha → List (SPFactor H ι)) :
    SPFactor.listEval (n := truncation) e
        (items.flatMap factors) =
      (items.map fun item =>
        SPFactor.listEval (n := truncation) e
          (factors item)).prod := by
  induction items with
  | nil =>
      rfl
  | cons item items ih =>
      simp only [List.flatMap_cons, List.map_cons, List.prod_cons]
      rw [SPFactor.listEval_append, ih]

/-- Below cutoff, one local decoded grid-cell program is the generic
supported finite-state symbolic trace of its chosen orbit obstruction. -/
lemma
    local_symbolic_factors
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    (hroot :
      (universalOrbitObstruction
        hleftWeight hrightWeight leftHistory rightHistory).weight
          leftWeight rightWeight < n)
    (left right : SPFactor H ι) :
    universalOperationalFactors
        normalizer hleftWeight hrightWeight
          leftHistory rightHistory left right =
      retainedIdxFactors normalizer
        hleftWeight hrightWeight
          (universalOrbitObstruction
            hleftWeight hrightWeight leftHistory rightHistory)
          (universal_obstruction_supported
            hleftWeight hrightWeight leftHistory rightHistory hroot)
          left right := by
  unfold universalOperationalFactors
  unfold retainedIdxFactors
  rw [
    universal_operational_weight
      hleftWeight hrightWeight leftHistory rightHistory hroot]

/-- One local decoded grid-cell program evaluates by the recipe-free
operational evaluator below cutoff and by the identity above cutoff. -/
lemma
    universal_operational_ite
    {d truncation : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    (left right : SPFactor H ι) :
    SPFactor.listEval (n := truncation) e
        (universalOperationalFactors
          normalizer hleftWeight hrightWeight
            leftHistory rightHistory left right) =
      if _hroot :
          (universalOrbitObstruction
            hleftWeight hrightWeight leftHistory rightHistory).weight
              leftWeight rightWeight < n then
        RREvalua.listEval
          (n := n) hleftWeight hrightWeight
          (universalOrbitObstruction
            hleftWeight hrightWeight leftHistory rightHistory)
          (left.wordValue (n := truncation))
          (right.wordValue (n := truncation))
          (left.coefficient.eval e) (right.coefficient.eval e)
      else
        1 := by
  split
  · rw [
      local_symbolic_factors
        normalizer hleftWeight hrightWeight leftHistory rightHistory
          ‹_› left right,
      symbolic_factors_operational]
  · rw [
      universal_operational_nil
        normalizer hleftWeight hrightWeight leftHistory rightHistory
          ‹_› left right]
    rfl

/-- Ordered evaluation of the retained-history pair grid is the corresponding
ordered matrix product of local decoded symbolic-program evaluations. -/
lemma
    pairwise_flat_factors
    {d truncation : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : SPFactor H ι) :
    SPFactor.listEval (n := truncation) e
        ((rawHistoriesAttached
          M N n leftWeight rightWeight).flatMap fun leftHistory =>
            (rawHistoriesAttached
              M N n leftWeight rightWeight).flatMap fun rightHistory =>
                (universalOperationalTrace
                  hleftWeight hrightWeight leftHistory rightHistory).map
                    (orbitSymbolicFactor
                      normalizer left right)) =
      ((rawHistoriesAttached
        M N n leftWeight rightWeight).map fun leftHistory =>
          ((rawHistoriesAttached
            M N n leftWeight rightWeight).map fun rightHistory =>
              SPFactor.listEval (n := truncation) e
                (universalOperationalFactors
                  normalizer hleftWeight hrightWeight
                    leftHistory rightHistory left right)).prod).prod := by
  rw [SPFactor.list_eval_flatmap]
  apply congrArg List.prod
  apply List.map_congr_left
  intro leftHistory _hleftHistory
  rw [SPFactor.list_eval_flatmap]
  rfl

/-- Global ordered operational evaluator: the decoded source segment followed
by the retained-history matrix of local finite-state orbit evaluators. -/
noncomputable def globalOperationalEval
    {d truncation : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : SPFactor H ι) :=
  SPFactor.listEval (n := truncation) e
      ((universalIndexTrace
        M N n leftWeight rightWeight hleftWeight hrightWeight).map
          (orbitSymbolicFactor
            normalizer left right)) *
    ((rawHistoriesAttached
      M N n leftWeight rightWeight).map fun leftHistory =>
        ((rawHistoriesAttached
          M N n leftWeight rightWeight).map fun rightHistory =>
            if _hroot :
                (universalOrbitObstruction
                  hleftWeight hrightWeight
                    leftHistory rightHistory).weight
                      leftWeight rightWeight < n then
              RREvalua.listEval
                (n := n) hleftWeight hrightWeight
                (universalOrbitObstruction
                  hleftWeight hrightWeight leftHistory rightHistory)
                (left.wordValue (n := truncation))
                (right.wordValue (n := truncation))
                (left.coefficient.eval e) (right.coefficient.eval e)
            else
              1).prod).prod

/-- The complete arbitrary-multiplicity symbolic envelope evaluates as its
source segment followed by the ordered matrix product of local recipe-free
operational evaluators. -/
lemma
    envelope_ite_operational
    {d truncation : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : SPFactor H ι) :
    SPFactor.listEval (n := truncation) e
        (universalEnvelopeFactors
          normalizer M N n leftWeight rightWeight
            hleftWeight hrightWeight left right) =
      globalOperationalEval normalizer e
        M N n leftWeight rightWeight
          hleftWeight hrightWeight left right := by
  unfold globalOperationalEval
  rw [
    envelope_pairwise_flat,
    pairwise_flat_factors]
  congr 1
  apply congrArg List.prod
  apply List.map_congr_left
  intro leftHistory _hleftHistory
  apply congrArg List.prod
  apply List.map_congr_left
  intro rightHistory _hrightHistory
  exact
    universal_operational_ite
      normalizer e hleftWeight hrightWeight
        leftHistory rightHistory left right

/-- The global ordered operational evaluator is exactly the concrete
arbitrary-multiplicity conservative recipe envelope. -/
lemma global_operational_envelope
    {d truncation : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : SPFactor H ι) :
    globalOperationalEval normalizer e
        M N n leftWeight rightWeight
          hleftWeight hrightWeight left right =
      ((concretePacketEnvelope
        M N n leftWeight rightWeight hleftWeight hrightWeight).map fun recipe =>
          recipe.erasedShape.eval
              (HPAtom.eval
                (left.wordValue (n := truncation))
                (right.wordValue (n := truncation))) ^
            BRSpec.coefficientValue recipe
              (left.coefficient.eval e) (right.coefficient.eval e)).prod := by
  rw [←
    envelope_ite_operational]
  exact
    universal_envelope_recipe
      normalizer e hleftWeight hrightWeight left right

end
  IGEvalua
end TCTex
end Towers

/-!
# Finite orbit-index traces for complete retained operational endpoints

The terminating More3 collector has a concrete ordered factor list.  Filtering
that list below a nilpotent cutoff deletes only factors which evaluate to the
identity.  Every surviving occurrence has an erased-word representative in the
finite correction closure, so the retained collected endpoint admits an
occurrence-preserving finite polynomial-orbit index trace.

This file keeps the two semantic layers separate.  It proves that decoded
packet words recover the retained endpoint word list and still evaluate to the
natural-power commutator.  The polynomial coefficient profiles attached to
the selected finite-closure representatives remain explicit.

This file is intentionally not imported by the existing collection proof.
-/

noncomputable section

namespace Towers
namespace TCTex
namespace
  TCEnd

open scoped commutatorElement

open HACoeff
open BFTrunc
open ROSuppor
open ROAggreg
open ROTransi
open BRSpec
open HOCollec
open OCPartit
open FMEnd
open RSCovera
open ITEvalua
open UCSuppor
open UCVocabu
open RITrace
open
  TPBounda
open
  POSigned
open
  PTRecipe

/-- Below-cutoff factors in the exact order produced by one terminating More3
collection endpoint. -/
def retainedCollectedTerms
    {M N : ℕ}
    (endpoint : ODEmissi M N)
    (n leftWeight rightWeight : ℕ) :
    List (DFTerm M N
      (inverseLabelledCollection M N).factors.length) :=
  belowCutoffTerms n leftWeight rightWeight endpoint.collected.factors

@[simp]
lemma retained_collected_terms
    {M N n leftWeight rightWeight : ℕ}
    {endpoint : ODEmissi M N}
    {term : DFTerm M N
      (inverseLabelledCollection M N).factors.length} :
    term ∈ retainedCollectedTerms endpoint n leftWeight rightWeight ↔
      term ∈ endpoint.collected.factors ∧
        decoratedFamilyWeight leftWeight rightWeight term < n := by
  exact below_cutoff_terms

/-- Every retained collected endpoint occurrence has an erased-word
representative in the finite correction closure. -/
lemma closure_collected_terms
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (endpoint : ODEmissi M N)
    (term : DFTerm M N
      (inverseLabelledCollection M N).factors.length)
    (hterm :
      term ∈ retainedCollectedTerms endpoint n leftWeight rightWeight) :
    ∃ recipe ∈
        correctionClosureRecipes n leftWeight rightWeight,
      recipe.erasedShape = term.erasedShape := by
  apply recipe_endpoint_factors
    hleftWeight hrightWeight endpoint term
  · exact (retained_collected_terms.mp hterm).1
  · have hweight := (retained_collected_terms.mp hterm).2
    simpa [decoratedFamilyWeight, weightedWordWeight,
      term.erased_shape_family] using hweight

/-- Choose one finite-closure representative for one retained collected
endpoint occurrence. -/
noncomputable def collectedClosureTerm
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (endpoint : ODEmissi M N)
    (term : DFTerm M N
      (inverseLabelledCollection M N).factors.length)
    (hterm :
      term ∈ retainedCollectedTerms endpoint n leftWeight rightWeight) :
    BRecipe :=
  Classical.choose
    (closure_collected_terms
      hleftWeight hrightWeight endpoint term hterm)

/-- The selected retained-endpoint representative belongs to the finite
correction closure. -/
lemma collected_closure_term
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (endpoint : ODEmissi M N)
    (term : DFTerm M N
      (inverseLabelledCollection M N).factors.length)
    (hterm :
      term ∈ retainedCollectedTerms endpoint n leftWeight rightWeight) :
    collectedClosureTerm
        hleftWeight hrightWeight endpoint term hterm ∈
      correctionClosureRecipes n leftWeight rightWeight :=
  (Classical.choose_spec
    (closure_collected_terms
      hleftWeight hrightWeight endpoint term hterm)).1

/-- The selected retained-endpoint representative has the concrete factor's
erased Hall word. -/
@[simp]
lemma erased_collected_term
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (endpoint : ODEmissi M N)
    (term : DFTerm M N
      (inverseLabelledCollection M N).factors.length)
    (hterm :
      term ∈ retainedCollectedTerms endpoint n leftWeight rightWeight) :
    (collectedClosureTerm
      hleftWeight hrightWeight endpoint term hterm).erasedShape =
        term.erasedShape :=
  (Classical.choose_spec
    (closure_collected_terms
      hleftWeight hrightWeight endpoint term hterm)).2

/-- Ordered finite-closure representatives of the retained collected endpoint
factor occurrences. -/
noncomputable def collectedClosurePacket
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (endpoint : ODEmissi M N) :
    List BRecipe :=
  (retainedCollectedTerms endpoint n leftWeight rightWeight).attach.map
    fun term =>
      collectedClosureTerm
        hleftWeight hrightWeight endpoint term.1 term.2

/-- Every selected retained-endpoint representative belongs to the finite
correction closure. -/
lemma
    recipes_collected_packet
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (endpoint : ODEmissi M N)
    {recipe : BRecipe}
    (hrecipe :
      recipe ∈
        collectedClosurePacket
          (n := n) hleftWeight hrightWeight endpoint) :
    recipe ∈ correctionClosureRecipes n leftWeight rightWeight := by
  unfold collectedClosurePacket at hrecipe
  rcases List.mem_map.mp hrecipe with ⟨term, _hterm, rfl⟩
  exact
    collected_closure_term
      hleftWeight hrightWeight endpoint term.1 term.2

/-- Selected representatives preserve the complete ordered retained-endpoint
erased-word list. -/
lemma erased_collected_packet
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (endpoint : ODEmissi M N) :
    (collectedClosurePacket
        (n := n) hleftWeight hrightWeight endpoint).map
          BRecipe.erasedShape =
      (retainedCollectedTerms endpoint n leftWeight rightWeight).map
        DFTerm.erasedShape := by
  unfold collectedClosurePacket
  simp only [List.map_map]
  simp

/-- The retained collected representative packet is pointwise supported by
the finite polynomial-orbit dictionary. -/
lemma supported_collected_closure
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (endpoint : ODEmissi M N) :
    RecipeOrbitSupported n leftWeight rightWeight
      (collectedClosurePacket
        (n := n) hleftWeight hrightWeight endpoint) := by
  intro recipe hrecipe
  apply
    key_vocabulary_recipes
  exact
    recipes_collected_packet
      hleftWeight hrightWeight endpoint hrecipe

/-- Occurrence-preserving finite orbit-index trace of the complete retained
collected endpoint. -/
noncomputable def retainedCollectedTrace
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (endpoint : ODEmissi M N) :
    List (RetainedOrbitIndex n leftWeight rightWeight) :=
  recipeIndexTrace
    (collectedClosurePacket
      (n := n) hleftWeight hrightWeight endpoint)
    (supported_collected_closure
      hleftWeight hrightWeight endpoint)

/-- Decoding the retained collected endpoint trace recovers the selected
orbit-key list literally. -/
lemma key_collected_trace
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (endpoint : ODEmissi M N) :
    (retainedCollectedTrace
      (n := n) hleftWeight hrightWeight endpoint).map
        retainedOrbitKey =
      (collectedClosurePacket
        (n := n) hleftWeight hrightWeight endpoint).map polynomialOrbitKey := by
  unfold retainedCollectedTrace
  exact
    key_recipe_trace
      (collectedClosurePacket
        (n := n) hleftWeight hrightWeight endpoint)
      (supported_collected_closure
        hleftWeight hrightWeight endpoint)

/-- Complete retained collected endpoint as an ordered cutoff-supported packet
over the finite polynomial-orbit dictionary. -/
noncomputable def retainedCollectedPacket
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (endpoint : ODEmissi M N) :
    OBPkt n leftWeight rightWeight :=
  indexBlockPacket
    hleftWeight hrightWeight
    (retainedCollectedTrace
      (n := n) hleftWeight hrightWeight endpoint)

@[simp]
lemma packets_retained_packet
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (endpoint : ODEmissi M N) :
    (retainedCollectedPacket
      (n := n) hleftWeight hrightWeight endpoint).packets =
        indexBlockPackets
          (retainedCollectedTrace
            (n := n) hleftWeight hrightWeight endpoint) :=
  rfl

/-- Decoding the retained endpoint packet recovers its concrete erased words
occurrence-for-occurrence. -/
lemma packets_cutoff_packet
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (endpoint : ODEmissi M N) :
    (retainedCollectedPacket
      (n := n) hleftWeight hrightWeight endpoint).packets.map
        (fun packet => packet.word) =
      (retainedCollectedTerms endpoint n leftWeight rightWeight).map
        DFTerm.erasedShape := by
  rw [packets_retained_packet]
  unfold retainedCollectedTrace
  rw [
    block_packets_packet,
    erased_collected_packet]

/-- Deleting concrete factors at or above the cutoff preserves ordered
collapsed evaluation: every deleted factor is individually trivial. -/
lemma collapsed_decorated_below
    {M N K n leftWeight rightWeight : ℕ}
    {G : Type*}
    [Group G]
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {x y : G}
    (hx : x ∈ Subgroup.lowerCentralSeries G (leftWeight - 1))
    (hy : y ∈ Subgroup.lowerCentralSeries G (rightWeight - 1))
    (hbot : Subgroup.lowerCentralSeries G (n - 1) = ⊥) :
    ∀ terms : List (DFTerm M N K),
      collapsedList x y
          (decoratedFamilyList
            (belowCutoffTerms n leftWeight rightWeight terms)) =
        collapsedList x y (decoratedFamilyList terms)
  | [] =>
      rfl
  | term :: terms => by
      by_cases hweight :
          decoratedFamilyWeight leftWeight rightWeight term < n
      · rw [show
          belowCutoffTerms n leftWeight rightWeight (term :: terms) =
            term :: belowCutoffTerms n leftWeight rightWeight terms by
          simp [belowCutoffTerms, hweight]]
        simp only [decoratedFamilyList, List.map_cons,
          collapsedList, List.prod_cons]
        exact congrArg
          (fun tail =>
            (collapseWord term.decorated.word).eval
                (HPAtom.eval x y) * tail)
          (collapsed_decorated_below
            hleftWeight hrightWeight hx hy hbot terms)
      · have hone :
            (collapseWord term.decorated.word).eval
                (HPAtom.eval x y) = 1 :=
          collapsed_one_weight
            hleftWeight hrightWeight hx hy hbot term
              (Nat.le_of_not_lt hweight)
        rw [show
          belowCutoffTerms n leftWeight rightWeight (term :: terms) =
            belowCutoffTerms n leftWeight rightWeight terms by
          simp [belowCutoffTerms, hweight]]
        simp only [decoratedFamilyList, List.map_cons,
          collapsedList, List.prod_cons]
        rw [hone, one_mul]
        exact
          collapsed_decorated_below
            hleftWeight hrightWeight hx hy hbot terms

/-- The complete retained collected endpoint still evaluates to the natural
power commutator in every matching nilpotent quotient. -/
lemma collapsed_decorated_terms
    {M N n leftWeight rightWeight : ℕ}
    {G : Type*}
    [Group G]
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {x y : G}
    (hx : x ∈ Subgroup.lowerCentralSeries G (leftWeight - 1))
    (hy : y ∈ Subgroup.lowerCentralSeries G (rightWeight - 1))
    (hbot : Subgroup.lowerCentralSeries G (n - 1) = ⊥)
    (endpoint : ODEmissi M N) :
    collapsedList x y
        (decoratedFamilyList
          (retainedCollectedTerms endpoint n leftWeight rightWeight)) =
      ⁅x ^ M, y ^ N⁆ := by
  calc
    collapsedList x y
          (decoratedFamilyList
            (retainedCollectedTerms endpoint n leftWeight rightWeight)) =
        collapsedList x y
          (decoratedFamilyList endpoint.collected.factors) :=
      collapsed_decorated_below
        hleftWeight hrightWeight hx hy hbot endpoint.collected.factors
    _ =
        collapsedList x y
          (decoratedFamilyList
            (inverseDecoratedTerms M N)) :=
      collapsed_labelled_rewrites
        x y endpoint.collected.labelledWordRewrites
    _ = ⁅x ^ M, y ^ N⁆ := by
      rw [decorated_raw_terms]
      exact collapsed_commutator_pow x y

/-- Decoded retained endpoint packet words, without any profile
specialization, still evaluate to the natural-power commutator. -/
lemma packets_collected_packet
    {M N n leftWeight rightWeight : ℕ}
    {G : Type*}
    [Group G]
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {x y : G}
    (hx : x ∈ Subgroup.lowerCentralSeries G (leftWeight - 1))
    (hy : y ∈ Subgroup.lowerCentralSeries G (rightWeight - 1))
    (hbot : Subgroup.lowerCentralSeries G (n - 1) = ⊥)
    (endpoint : ODEmissi M N) :
    ((retainedCollectedPacket
      (n := n) hleftWeight hrightWeight endpoint).packets.map fun packet =>
        packet.word.eval (HPAtom.eval x y)).prod =
      ⁅x ^ M, y ^ N⁆ := by
  have hwords :=
    packets_cutoff_packet
      (n := n) hleftWeight hrightWeight endpoint
  have hevalWords :=
    congrArg
      (fun words : List (CWord HPAtom) =>
        (words.map fun word => word.eval (HPAtom.eval x y)).prod)
      hwords
  calc
    ((retainedCollectedPacket
      (n := n) hleftWeight hrightWeight endpoint).packets.map fun packet =>
        packet.word.eval (HPAtom.eval x y)).prod =
      (((retainedCollectedTerms endpoint n leftWeight rightWeight).map
        DFTerm.erasedShape).map fun word =>
          word.eval (HPAtom.eval x y)).prod := by
            simpa only [List.map_map, Function.comp_apply] using hevalWords
    _ =
      collapsedList x y
        (decoratedFamilyList
          (retainedCollectedTerms endpoint n leftWeight rightWeight)) := by
            unfold collapsedList decoratedFamilyList
            rw [List.map_map, List.map_map]
            apply congrArg List.prod
            apply List.map_congr_left
            intro term _hterm
            rfl
    _ = ⁅x ^ M, y ^ N⁆ :=
      collapsed_decorated_terms
        hleftWeight hrightWeight hx hy hbot endpoint

/-- The decoded retained-endpoint finite trace evaluates exactly as its
selected finite-closure representatives.  Polynomial coefficient profiles
remain visible for the later stabilization theorem. -/
lemma
    block_packets_collected
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (endpoint : ODEmissi M N)
    {G : Type*}
    [Group G]
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    ((indexBlockPackets
      (retainedCollectedTrace
        (n := n) hleftWeight hrightWeight endpoint)).map fun packet =>
          packet.word.eval (HPAtom.eval left right) ^
            packet.profiles.value leftExponent rightExponent).prod =
      ((collectedClosurePacket
        (n := n) hleftWeight hrightWeight endpoint).map fun recipe =>
          recipe.erasedShape.eval (HPAtom.eval left right) ^
            coefficientValue recipe leftExponent rightExponent).prod := by
  unfold retainedCollectedTrace
  exact
    packets_recipe_packet
      (collectedClosurePacket
        (n := n) hleftWeight hrightWeight endpoint)
      (supported_collected_closure
        hleftWeight hrightWeight endpoint)
      left right leftExponent rightExponent

end
  TCEnd
end TCTex
end Towers

/-!
# Guarded operational evaluation of polynomial-orbit index traces

The finite-index envelope evaluates each retained-history pair by a
cutoff-guarded recipe-free operational trace.  This file packages that
`if`-expression as one total evaluator on polynomial-orbit obstructions.

Below cutoff, the evaluator emits the root orbit factor and recursively
evaluates the two operational children.  At or above cutoff, it is the
identity.  The global conservative envelope is then a source segment followed
by an ordered matrix product of these finite-state evaluators.

This file is intentionally not imported by the existing collection proof.
-/

namespace Towers
namespace TCTex
namespace
  RGEvalua

universe u

open ROEvalua
open RREvalua
open RRPkt
open
  RRPkt.POObstru
open
  RITrace
open
  IEDecomp
open
  IGEvalua
open
  LSProgra
open OREnvelo
open RSEnvelo
open RPEnvelo

/--
Total finite-state evaluation of one recipe-free orbit obstruction: recurse
below cutoff and emit the identity otherwise.
-/
noncomputable def guardedOperationalEval
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru)
    {G : Type*}
    [Group G]
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    G :=
  if _hroot : O.weight leftWeight rightWeight < n then
    RREvalua.listEval
      (n := n) hleftWeight hrightWeight O
      left right leftExponent rightExponent
  else
    1

/-- At or above cutoff, the guarded operational evaluator is the identity. -/
@[simp]
lemma guarded_operational_list
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru)
    {G : Type*}
    [Group G]
    (left right : G)
    (leftExponent rightExponent : ℤ)
    (hroot : ¬ O.weight leftWeight rightWeight < n) :
    guardedOperationalEval (n := n)
      hleftWeight hrightWeight O
        left right leftExponent rightExponent =
      1 := by
  rw [guardedOperationalEval, dif_neg hroot]

/-- Below cutoff, the guarded evaluator is the ordered operational trace. -/
lemma guarded_operational_weight
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru)
    {G : Type*}
    [Group G]
    (left right : G)
    (leftExponent rightExponent : ℤ)
    (hroot : O.weight leftWeight rightWeight < n) :
    guardedOperationalEval (n := n)
        hleftWeight hrightWeight O
          left right leftExponent rightExponent =
      RREvalua.listEval
        (n := n) hleftWeight hrightWeight O
          left right leftExponent rightExponent := by
  rw [guardedOperationalEval, dif_pos hroot]

/--
Below cutoff, the total evaluator is the root orbit factor followed by the
two guarded recursive branch evaluations.
-/
lemma guarded_operational_branches
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru)
    {G : Type*}
    [Group G]
    (left right : G)
    (leftExponent rightExponent : ℤ)
    (hroot : O.weight leftWeight rightWeight < n) :
    guardedOperationalEval (n := n)
        hleftWeight hrightWeight O
          left right leftExponent rightExponent =
      orbitFactorValue O.correction
          left right leftExponent rightExponent *
        (guardedOperationalEval (n := n)
            hleftWeight hrightWeight O.operationalNestedLeft
              left right leftExponent rightExponent *
          guardedOperationalEval (n := n)
            hleftWeight hrightWeight O.operationalNestedRight
              left right leftExponent rightExponent) := by
  rw [guarded_operational_weight
    hleftWeight hrightWeight O left right
      leftExponent rightExponent hroot]
  rw [list_root_branches]
  unfold guardedOperationalEval
  split <;> split <;> rfl

/--
The total evaluator exposes its cutoff guard and recursive branch equation in
one unconditional statement.
-/
lemma guarded_ite_branches
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru)
    {G : Type*}
    [Group G]
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    guardedOperationalEval (n := n)
        hleftWeight hrightWeight O
          left right leftExponent rightExponent =
      if _hroot : O.weight leftWeight rightWeight < n then
        orbitFactorValue O.correction
            left right leftExponent rightExponent *
          (guardedOperationalEval (n := n)
              hleftWeight hrightWeight O.operationalNestedLeft
                left right leftExponent rightExponent *
            guardedOperationalEval (n := n)
              hleftWeight hrightWeight O.operationalNestedRight
                left right leftExponent rightExponent)
      else
        1 := by
  split
  · exact
      guarded_operational_branches
        hleftWeight hrightWeight O left right
          leftExponent rightExponent ‹_›
  · exact
      guarded_operational_list
        hleftWeight hrightWeight O left right
          leftExponent rightExponent ‹_›

/--
One local decoded symbolic grid cell evaluates by the total guarded
operational evaluator rooted at its chosen orbit obstruction.
-/
lemma factors_guarded_operational
    {d truncation : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    (left right : SPFactor H ι) :
    SPFactor.listEval (n := truncation) e
        (universalOperationalFactors
          normalizer hleftWeight hrightWeight
            leftHistory rightHistory left right) =
      guardedOperationalEval (n := n)
        hleftWeight hrightWeight
        (universalOrbitObstruction
          hleftWeight hrightWeight leftHistory rightHistory)
        (left.wordValue (n := truncation))
        (right.wordValue (n := truncation))
        (left.coefficient.eval e) (right.coefficient.eval e) := by
  unfold guardedOperationalEval
  exact
    universal_operational_ite
      normalizer e hleftWeight hrightWeight
        leftHistory rightHistory left right

/--
The complete arbitrary-multiplicity symbolic envelope evaluates as its source
segment followed by the ordered matrix product of total guarded operational
evaluators.
-/
lemma
    envelope_guarded_operational
    {d truncation : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : SPFactor H ι) :
    SPFactor.listEval (n := truncation) e
        (universalEnvelopeFactors
          normalizer M N n leftWeight rightWeight
            hleftWeight hrightWeight left right) =
      SPFactor.listEval (n := truncation) e
          ((universalIndexTrace
            M N n leftWeight rightWeight hleftWeight hrightWeight).map
              (orbitSymbolicFactor
                normalizer left right)) *
        ((rawHistoriesAttached
          M N n leftWeight rightWeight).map fun leftHistory =>
            ((rawHistoriesAttached
              M N n leftWeight rightWeight).map fun rightHistory =>
                guardedOperationalEval (n := n)
                  hleftWeight hrightWeight
                  (universalOrbitObstruction
                    hleftWeight hrightWeight leftHistory rightHistory)
                  (left.wordValue (n := truncation))
                  (right.wordValue (n := truncation))
                  (left.coefficient.eval e)
                  (right.coefficient.eval e)).prod).prod := by
  simpa only [guardedOperationalEval] using
    envelope_ite_operational
      normalizer e M N n leftWeight rightWeight
        hleftWeight hrightWeight left right

end
  RGEvalua
end TCTex
end Towers

/-!
# Ordered swap resolution for universal polynomial-orbit grid cells

The universal arbitrary-multiplicity envelope is assembled from a retained
history grid of local polynomial-orbit programs.  This file connects one
below-cutoff grid cell to the recipe-free ordered swap resolver.  It does not
flatten the grid or identify the conservative envelope with a global collection
schedule.

Through cutoff three, every recursive orbit node is terminal, so the local cell
swap theorem is unconditional.

This file is intentionally not imported by the existing collection proof.
-/

noncomputable section

namespace Towers
namespace TCTex
namespace
  OSCell

universe u

open ROEvalua
open RRPkt
open
  IGEvalua
open
  ILProgra
open
  LSProgra
open
  CTTermin
open OREnvelo
open RSEnvelo
open RPEnvelo

/--
One below-cutoff universal history-grid cell satisfies the ordered adjacent-swap
law as soon as its genuinely nonterminal recursive orbit nodes can be resolved.
-/
theorem
    universal_operational_swap
    {d M N n leftWeight rightWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    (hroot :
      (universalOrbitObstruction
        hleftWeight hrightWeight leftHistory rightHistory).weight
          leftWeight rightWeight < n)
    (left right : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = leftWeight)
    (hright : right.word.weight HEAddres.weight = rightWeight)
    (kernel :
      RNSwap
        n leftWeight rightWeight hleftWeight hrightWeight
        (left.wordValue (n := n)) (right.wordValue (n := n))
        (left.coefficient.eval e) (right.coefficient.eval e)) :
    SPFactor.listEval (n := n) e
          (universalOperationalFactors
            normalizer hleftWeight hrightWeight
              leftHistory rightHistory left right) *
        orbitFactorValue
            (universalOrbitObstruction
              hleftWeight hrightWeight leftHistory rightHistory).right
          (left.wordValue (n := n)) (right.wordValue (n := n))
          (left.coefficient.eval e) (right.coefficient.eval e) *
      orbitFactorValue
          (universalOrbitObstruction
            hleftWeight hrightWeight leftHistory rightHistory).left
        (left.wordValue (n := n)) (right.wordValue (n := n))
        (left.coefficient.eval e) (right.coefficient.eval e) =
      orbitFactorValue
          (universalOrbitObstruction
            hleftWeight hrightWeight leftHistory rightHistory).left
        (left.wordValue (n := n)) (right.wordValue (n := n))
        (left.coefficient.eval e) (right.coefficient.eval e) *
        orbitFactorValue
            (universalOrbitObstruction
              hleftWeight hrightWeight leftHistory rightHistory).right
          (left.wordValue (n := n)) (right.wordValue (n := n))
          (left.coefficient.eval e) (right.coefficient.eval e) := by
  rw [
    local_symbolic_factors
      normalizer hleftWeight hrightWeight leftHistory rightHistory
        hroot left right]
  exact
    RNSwap.symbolic_factors_swap
      normalizer e hleftWeight hrightWeight
      (universalOrbitObstruction
        hleftWeight hrightWeight leftHistory rightHistory)
      (universal_obstruction_supported
        hleftWeight hrightWeight leftHistory rightHistory hroot)
      hroot left right hleft hright kernel

/--
Through cutoff three, one below-cutoff universal history-grid cell satisfies the
ordered adjacent-swap law without any nonterminal Hall-collection hypothesis.
-/
theorem
    poly_orbit_three
    {d M N n leftWeight rightWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 3)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    (hroot :
      (universalOrbitObstruction
        hleftWeight hrightWeight leftHistory rightHistory).weight
          leftWeight rightWeight < n)
    (left right : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = leftWeight)
    (hright : right.word.weight HEAddres.weight = rightWeight) :
    SPFactor.listEval (n := n) e
          (universalOperationalFactors
            normalizer hleftWeight hrightWeight
              leftHistory rightHistory left right) *
        orbitFactorValue
            (universalOrbitObstruction
              hleftWeight hrightWeight leftHistory rightHistory).right
          (left.wordValue (n := n)) (right.wordValue (n := n))
          (left.coefficient.eval e) (right.coefficient.eval e) *
      orbitFactorValue
          (universalOrbitObstruction
            hleftWeight hrightWeight leftHistory rightHistory).left
        (left.wordValue (n := n)) (right.wordValue (n := n))
        (left.coefficient.eval e) (right.coefficient.eval e) =
      orbitFactorValue
          (universalOrbitObstruction
            hleftWeight hrightWeight leftHistory rightHistory).left
        (left.wordValue (n := n)) (right.wordValue (n := n))
        (left.coefficient.eval e) (right.coefficient.eval e) *
        orbitFactorValue
            (universalOrbitObstruction
              hleftWeight hrightWeight leftHistory rightHistory).right
          (left.wordValue (n := n)) (right.wordValue (n := n))
          (left.coefficient.eval e) (right.coefficient.eval e) := by
  exact
    universal_operational_swap
      normalizer e hleftWeight hrightWeight leftHistory rightHistory hroot
        left right hleft hright
      (RNSwap.cutoff_three
        hleftWeight hrightWeight hn
        (left.wordValue (n := n)) (right.wordValue (n := n))
        (left.coefficient.eval e) (right.coefficient.eval e))

/--
Total guarded swap law for one universal history-grid cell.  Below cutoff it
uses the recursive packet; at or above cutoff the packet is empty and the
powered parent orbit factors commute in the free lower-central truncation.
-/
def SatisfiesCellSwap
    {d M N n leftWeight rightWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    (left right : SPFactor H ι) :
    Prop :=
  SPFactor.listEval (n := n) e
        (universalOperationalFactors
          normalizer hleftWeight hrightWeight
            leftHistory rightHistory left right) *
      orbitFactorValue
          (universalOrbitObstruction
            hleftWeight hrightWeight leftHistory rightHistory).right
        (left.wordValue (n := n)) (right.wordValue (n := n))
        (left.coefficient.eval e) (right.coefficient.eval e) *
    orbitFactorValue
        (universalOrbitObstruction
          hleftWeight hrightWeight leftHistory rightHistory).left
      (left.wordValue (n := n)) (right.wordValue (n := n))
      (left.coefficient.eval e) (right.coefficient.eval e) =
    orbitFactorValue
        (universalOrbitObstruction
          hleftWeight hrightWeight leftHistory rightHistory).left
      (left.wordValue (n := n)) (right.wordValue (n := n))
      (left.coefficient.eval e) (right.coefficient.eval e) *
      orbitFactorValue
          (universalOrbitObstruction
            hleftWeight hrightWeight leftHistory rightHistory).right
        (left.wordValue (n := n)) (right.wordValue (n := n))
        (left.coefficient.eval e) (right.coefficient.eval e)

/--
Nonterminal kernels for the surviving case resolve the total guarded swap law
of one universal history-grid cell.
-/
theorem satisfiesCellSwap
    {d M N n leftWeight rightWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    (left right : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = leftWeight)
    (hright : right.word.weight HEAddres.weight = rightWeight)
    (kernel :
      ∀ _hroot :
          (universalOrbitObstruction
            hleftWeight hrightWeight leftHistory rightHistory).weight
              leftWeight rightWeight < n,
        RNSwap
          n leftWeight rightWeight hleftWeight hrightWeight
          (left.wordValue (n := n)) (right.wordValue (n := n))
          (left.coefficient.eval e) (right.coefficient.eval e)) :
    SatisfiesCellSwap
      normalizer e hleftWeight hrightWeight
        leftHistory rightHistory left right := by
  unfold SatisfiesCellSwap
  by_cases hroot :
      (universalOrbitObstruction
        hleftWeight hrightWeight leftHistory rightHistory).weight
          leftWeight rightWeight < n
  · exact
      universal_operational_swap
        normalizer e hleftWeight hrightWeight leftHistory rightHistory hroot
          left right hleft hright (kernel hroot)
  · rw [
      universal_operational_nil
        normalizer hleftWeight hrightWeight leftHistory rightHistory
          hroot left right,
      SPFactor.listEval_nil,
      one_mul]
    exact
      (POObstru.orbit_commute_weight
        hleftWeight hrightWeight
        (by
          simpa only [hleft] using
            left.value_lower_series (n := n))
        (by
          simpa only [hright] using
            right.value_lower_series (n := n))
        SCFactor.trunc_last_bot
        (universalOrbitObstruction
          hleftWeight hrightWeight leftHistory rightHistory)
        (Nat.le_of_not_gt hroot)
        (left.coefficient.eval e) (right.coefficient.eval e)).eq.symm

/--
Through cutoff three, every universal history-grid cell satisfies its guarded
ordered swap law without a nonterminal Hall-collection hypothesis.
-/
theorem satisfies_operational_cell
    {d M N n leftWeight rightWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 3)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    (left right : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = leftWeight)
    (hright : right.word.weight HEAddres.weight = rightWeight) :
    SatisfiesCellSwap
      normalizer e hleftWeight hrightWeight
        leftHistory rightHistory left right := by
  apply
    satisfiesCellSwap
      normalizer e hleftWeight hrightWeight
        leftHistory rightHistory left right hleft hright
  intro _hroot
  exact
    RNSwap.cutoff_three
      hleftWeight hrightWeight hn
      (left.wordValue (n := n)) (right.wordValue (n := n))
      (left.coefficient.eval e) (right.coefficient.eval e)

end
  OSCell
end TCTex
