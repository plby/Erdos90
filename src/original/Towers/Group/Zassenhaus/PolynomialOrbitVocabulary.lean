/-!
# Global ordered signed-block decomposition of polynomial-orbit trace programs

The complete arbitrary-multiplicity polynomial-orbit envelope is a source
trace followed by a retained-history pair grid of local operational traces.
Finite-index decoding preserves this decomposition literally at the
signed-block packet level.

Consequently, the global ordered packet product is its source product
followed by the ordered matrix product of total guarded local operational
evaluators.  This is still a conservative-envelope theorem: identifying that
product with a semantic Hall collection schedule is a separate obligation.

This file is intentionally not imported by the existing collection proof.
-/

namespace Towers
namespace TCTex
namespace
  PGSigned

open
  CFSubsti
open
  RITrace
open
  IEDecomp
open
  PLSigned
open
  POSigned
open
  RGEvalua
open OREnvelo
open
  UREnvelo
open RPEnvelo

/-- Signed-block packet occurrences decoded from the complete source
finite-index trace. -/
noncomputable def universalBlockPackets
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight) :
    List RFPkt :=
  indexBlockPackets
    (universalIndexTrace
      M N n leftWeight rightWeight hleftWeight hrightWeight)

/-- Finite-index decoding preserves the literal global source-plus-grid
decomposition of signed-block occurrences. -/
lemma
    envelope_packets_flat
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight) :
    universalEnvelopePackets
        M N n leftWeight rightWeight hleftWeight hrightWeight =
      universalBlockPackets
          M N n leftWeight rightWeight hleftWeight hrightWeight ++
        (rawHistoriesAttached M N n leftWeight rightWeight).flatMap
          fun leftHistory =>
            (rawHistoriesAttached
              M N n leftWeight rightWeight).flatMap fun rightHistory =>
                universalOperationalPackets
                  hleftWeight hrightWeight leftHistory rightHistory := by
  rw [←
    polyEnvelopeIdx]
  rw [
    universal_pairwise_flat]
  simp only [List.map_append, List.map_flatMap]
  rfl

/-- Ordered packet evaluation distributes over an ordered `flatMap`. -/
lemma block_packets_flat
    {alpha G : Type*}
    [Group G]
    (items : List alpha)
    (packets : alpha → List RFPkt)
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    ((items.flatMap packets).map fun packet =>
      packet.word.eval (HPAtom.eval left right) ^
        packet.profiles.value leftExponent rightExponent).prod =
      (items.map fun item =>
        ((packets item).map fun packet =>
          packet.word.eval (HPAtom.eval left right) ^
            packet.profiles.value leftExponent rightExponent).prod).prod := by
  induction items with
  | nil =>
      rfl
  | cons item items ih =>
      simp only [List.flatMap_cons, List.map_append, List.prod_append,
        List.map_cons, List.prod_cons]
      rw [ih]

/-- The complete signed-block envelope evaluates as its source segment
followed by the ordered matrix product of total guarded local evaluators. -/
lemma
    poly_orbit_guarded
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {G : Type*}
    [Group G]
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    ((universalEnvelopePackets
      M N n leftWeight rightWeight hleftWeight hrightWeight).map fun packet =>
        packet.word.eval (HPAtom.eval left right) ^
          packet.profiles.value leftExponent rightExponent).prod =
      ((universalBlockPackets
        M N n leftWeight rightWeight hleftWeight hrightWeight).map fun packet =>
          packet.word.eval (HPAtom.eval left right) ^
            packet.profiles.value leftExponent rightExponent).prod *
        ((rawHistoriesAttached
          M N n leftWeight rightWeight).map fun leftHistory =>
            ((rawHistoriesAttached
              M N n leftWeight rightWeight).map fun rightHistory =>
                guardedOperationalEval (n := n)
                  hleftWeight hrightWeight
                  (universalOrbitObstruction
                    hleftWeight hrightWeight leftHistory rightHistory)
                  left right leftExponent rightExponent).prod).prod := by
  rw [
    envelope_packets_flat,
    List.map_append, List.prod_append,
    block_packets_flat]
  apply congrArg
    (fun correctionProduct =>
      ((universalBlockPackets
        M N n leftWeight rightWeight hleftWeight hrightWeight).map fun packet =>
          packet.word.eval (HPAtom.eval left right) ^
            packet.profiles.value leftExponent rightExponent).prod *
        correctionProduct)
  apply congrArg List.prod
  apply List.map_congr_left
  intro leftHistory _hleftHistory
  rw [block_packets_flat]
  apply congrArg List.prod
  apply List.map_congr_left
  intro rightHistory _hrightHistory
  exact
    list_poly_guarded
      hleftWeight hrightWeight leftHistory rightHistory
        left right leftExponent rightExponent

/-- The existing complete ordered cutoff packet exposes the same literal
source-plus-grid occurrence list. -/
lemma
    packets_pairwise_flat
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight) :
    (universalEnvelopeBlock
      M N n leftWeight rightWeight hleftWeight hrightWeight).packets =
      universalBlockPackets
          M N n leftWeight rightWeight hleftWeight hrightWeight ++
        (rawHistoriesAttached M N n leftWeight rightWeight).flatMap
          fun leftHistory =>
            (rawHistoriesAttached
              M N n leftWeight rightWeight).flatMap fun rightHistory =>
                universalOperationalPackets
                  hleftWeight hrightWeight leftHistory rightHistory := by
  rw [
    packets_universal_envelope,
    envelope_packets_flat]

end
  PGSigned
end TCTex
end Towers

/-!
# The naive shallow polynomial-orbit swap law is false

The recipe-free operational recursion emits its root correction and then both
nested correction branches.  At cutoff four this gives a tempting three-factor
local swap law.  The inherited orbit coefficients are not Hall-Petresco
binomial coefficients, however, and the resulting law already fails for two
transpositions in `S₃`.

This file records the concrete semantic obstruction.  Any global symbolic
recollector must retain occurrence-level collection data rather than interpret
the naive recursive orbit packet as an adjacent-swap certificate.

The file is intentionally not imported by the existing collection proof.
-/

noncomputable section

namespace Towers
namespace TCTex
namespace
  TSObstru

open ROEvalua
open RRPkt
open
  RRPkt.POObstru
open ROAggreg
open ROTransi
open
  CTShallo
open
  CTTermin.POObstru

/-- The atomic left polynomial-orbit key. -/
def atomicLeftKey :
    POKey where
  leftBlocks := [1]
  rightBlocks := []
  erasedShape := .atom .left

/-- The atomic right polynomial-orbit key. -/
def atomicRightKey :
    POKey where
  leftBlocks := []
  rightBlocks := [1]
  erasedShape := .atom .right

/-- The first nonterminal polynomial-orbit obstruction. -/
def atomicObstruction :
    POObstru where
  left := atomicLeftKey
  right := atomicRightKey

/-- The atomic obstruction is genuinely nonterminal at cutoff four. -/
lemma terminal_atomic_obstruction :
    ¬Terminal 4 1 1 atomicObstruction := by
  simp [Terminal, atomicObstruction, atomicLeftKey, atomicRightKey,
    operationalNestedLeft, operationalNestedRight, correction, orbitCorrection,
    weight, orbitWeight, HPAtom.weight]

/-- Two transpositions witnessing failure of the naive shallow packet. -/
def leftPermutation :
    Equiv.Perm (Fin 3) :=
  Equiv.swap 0 1

/-- Two transpositions witnessing failure of the naive shallow packet. -/
def rightPermutation :
    Equiv.Perm (Fin 3) :=
  Equiv.swap 1 2

/--
For the atomic keys at exponent pair `(1, 1)`, the root correction followed by
both raw nested corrections does not swap the two parent transpositions.
-/
lemma shallow_equation_fails :
    ¬(
      orbitFactorValue atomicObstruction.correction
            leftPermutation rightPermutation 1 1 *
          orbitFactorValue
              atomicObstruction.operationalNestedLeft.correction
              leftPermutation rightPermutation 1 1 *
            orbitFactorValue
                atomicObstruction.operationalNestedRight.correction
                leftPermutation rightPermutation 1 1 *
              orbitFactorValue atomicObstruction.right
                  leftPermutation rightPermutation 1 1 *
                orbitFactorValue atomicObstruction.left
                    leftPermutation rightPermutation 1 1 =
        orbitFactorValue atomicObstruction.left
              leftPermutation rightPermutation 1 1 *
          orbitFactorValue atomicObstruction.right
            leftPermutation rightPermutation 1 1) := by
  set_option maxRecDepth 10000 in
    decide

/--
The proposed cutoff-four shallow recursive orbit law is false, already on the
atomic source obstruction in `S₃`.
-/
theorem shallow_atomic_permutations :
    ¬RecursiveShallowLaw
      4 1 1 (by omega) (by omega)
      leftPermutation rightPermutation 1 1 := by
  intro law
  exact shallow_equation_fails
    (law atomicObstruction terminal_atomic_obstruction)

end
  TSObstru
end TCTex
end Towers

/-!
# The low-cutoff endpoint of universal polynomial-orbit grid swaps

The generic orbit recursion admits abstract shallow class-three roots through
cutoff four.  Genuine universal history-grid roots are more constrained: each
parent is the polynomial-orbit key of a positive block recipe.  Each parent
therefore has weight at least `leftWeight + rightWeight`, so a genuine grid root
has weight at least twice that quantity.

Consequently, below that explicit bound the universal grid never enters its
recursive branch.  In particular, positive source weights make every grid-cell
swap unconditional through cutoff four.

This file is intentionally not imported by the existing collection proof.
-/

noncomputable section

namespace Towers
namespace TCTex
namespace
  PGLow

universe u

open ROEvalua
open RRPkt
open
  RRPkt.POObstru
open ROAggreg
open ROTransi
open BRSpec
open OREnvelo
open
  LSProgra
open
  RSProgra
open
  IGEvalua
open
  CTTermin
open
  CTTermin.POObstru
open
  OSCell
open
  OSGrid
open RPEnvelo

/--
Every polynomial-orbit key coming from a positive block recipe has at least the
principal Hall-pair weight.
-/
lemma orbit_key_basic
    (leftWeight rightWeight : ℕ)
    (recipe : HACoeff.BRecipe) :
    leftWeight + rightWeight ≤
      orbitWeight leftWeight rightWeight (polynomialOrbitKey recipe) := by
  rw [weight_orbit_key]
  simpa only [weighted_word_pair] using
    weighted_weight_basic leftWeight rightWeight recipe

/-- The left parent of a genuine universal grid root has principal weight. -/
lemma universal_obstruction_left
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : RetainedRawHistory M N n leftWeight rightWeight) :
    leftWeight + rightWeight ≤
      orbitWeight leftWeight rightWeight
        (universalOrbitObstruction
          hleftWeight hrightWeight left right).left := by
  unfold universalOrbitObstruction
  exact
    orbit_key_basic leftWeight rightWeight
      (universalRawHistory
        hleftWeight hrightWeight left).blockRecipe

/-- The right parent of a genuine universal grid root has principal weight. -/
lemma universal_obstruction_right
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : RetainedRawHistory M N n leftWeight rightWeight) :
    leftWeight + rightWeight ≤
      orbitWeight leftWeight rightWeight
        (universalOrbitObstruction
          hleftWeight hrightWeight left right).right := by
  unfold universalOrbitObstruction
  exact
    orbit_key_basic leftWeight rightWeight
      (universalRawHistory
        hleftWeight hrightWeight right).blockRecipe

/--
A genuine universal history-grid root has at least twice the principal
Hall-pair weight.
-/
lemma universal_orbit_obstruction
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : RetainedRawHistory M N n leftWeight rightWeight) :
    2 * (leftWeight + rightWeight) ≤
      (universalOrbitObstruction
        hleftWeight hrightWeight left right).weight
          leftWeight rightWeight := by
  unfold universalOrbitObstruction
  unfold POObstru.weight
  change
    2 * (leftWeight + rightWeight) ≤
      orbitWeight leftWeight rightWeight
          (polynomialOrbitKey
            (universalRawHistory
              hleftWeight hrightWeight left).blockRecipe) +
        orbitWeight leftWeight rightWeight
          (polynomialOrbitKey
            (universalRawHistory
              hleftWeight hrightWeight right).blockRecipe)
  have hleft :=
    orbit_key_basic leftWeight rightWeight
      (universalRawHistory
        hleftWeight hrightWeight left).blockRecipe
  have hright :=
    orbit_key_basic leftWeight rightWeight
      (universalRawHistory
        hleftWeight hrightWeight right).blockRecipe
  omega

/--
Below three times the principal Hall-pair weight, every genuine universal grid
root is a terminal class-two node.
-/
lemma universal_obstruction_terminal
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 3 * (leftWeight + rightWeight))
    (left right : RetainedRawHistory M N n leftWeight rightWeight) :
    POObstru.Terminal n leftWeight rightWeight
      (universalOrbitObstruction
        hleftWeight hrightWeight left right) := by
  unfold POObstru.Terminal
  rw [weight_nested_left, weight_operational_right]
  have hleft :=
    universal_obstruction_left
      hleftWeight hrightWeight left right
  have hright :=
    universal_obstruction_right
      hleftWeight hrightWeight left right
  omega

/--
Below twice the principal Hall-pair weight, a genuine universal grid root is
never in the recursive branch.
-/
lemma not_universal_obstruction
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 2 * (leftWeight + rightWeight))
    (left right : RetainedRawHistory M N n leftWeight rightWeight) :
    ¬(universalOrbitObstruction
        hleftWeight hrightWeight left right).weight
          leftWeight rightWeight < n := by
  have hweight :=
    universal_orbit_obstruction
      hleftWeight hrightWeight left right
  omega

/--
Below three times the principal Hall-pair weight, one genuine universal
history-grid cell satisfies its guarded ordered swap law: surviving roots are
already terminal class-two nodes.
-/
theorem
    satisfies_universal_cell
    {d M N n leftWeight rightWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 3 * (leftWeight + rightWeight))
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    (left right : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = leftWeight)
    (hright : right.word.weight HEAddres.weight = rightWeight) :
    SatisfiesCellSwap
      normalizer e hleftWeight hrightWeight
        leftHistory rightHistory left right := by
  unfold SatisfiesCellSwap
  by_cases hroot :
      (universalOrbitObstruction
        hleftWeight hrightWeight leftHistory rightHistory).weight
          leftWeight rightWeight < n
  · rw [
      local_symbolic_factors
        normalizer hleftWeight hrightWeight leftHistory rightHistory
          hroot left right,
      symbolic_factors_operational]
    exact
      (RSCerta.of_terminal
        hleftWeight hrightWeight
        (by
          simpa only [hleft] using
            left.value_lower_series (n := n))
        (by
          simpa only [hright] using
            right.value_lower_series (n := n))
        SCFactor.trunc_last_bot
        (left.coefficient.eval e) (right.coefficient.eval e)
        (universalOrbitObstruction
          hleftWeight hrightWeight leftHistory rightHistory)
        hroot
        (universal_obstruction_terminal
          hleftWeight hrightWeight hn leftHistory rightHistory)).eval_mul_swap
  · rw [
      universal_operational_nil
        normalizer hleftWeight hrightWeight leftHistory rightHistory
          hroot left right,
      SPFactor.listEval_nil,
      one_mul]
    exact
      (POObstru.orbit_commute_weight
        hleftWeight hrightWeight
        (by
          simpa only [hleft] using
            left.value_lower_series (n := n))
        (by
          simpa only [hright] using
            right.value_lower_series (n := n))
        SCFactor.trunc_last_bot
        (universalOrbitObstruction
          hleftWeight hrightWeight leftHistory rightHistory)
        (Nat.le_of_not_gt hroot)
        (left.coefficient.eval e) (right.coefficient.eval e)).eq.symm

/--
Below three times the principal Hall-pair weight, every genuine universal
retained-history grid cell satisfies its guarded ordered swap law.
-/
theorem
    satisfies_cell_swaps
    {d M N n leftWeight rightWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 3 * (leftWeight + rightWeight))
    (left right : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = leftWeight)
    (hright : right.word.weight HEAddres.weight = rightWeight) :
    SatisfiesCellSwaps
      (M := M) (N := N) (n := n)
      normalizer e hleftWeight hrightWeight left right := by
  intro leftHistory _hleftHistory rightHistory _hrightHistory
  exact
    satisfies_universal_cell
      normalizer e hleftWeight hrightWeight hn
        leftHistory rightHistory left right hleft hright

/--
Below twice the principal Hall-pair weight, one genuine universal history-grid
cell satisfies its guarded ordered swap law without a recursive kernel.
-/
theorem
    satisfies_cell_swap
    {d M N n leftWeight rightWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 2 * (leftWeight + rightWeight))
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    (left right : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = leftWeight)
    (hright : right.word.weight HEAddres.weight = rightWeight) :
    SatisfiesCellSwap
      normalizer e hleftWeight hrightWeight
        leftHistory rightHistory left right := by
  apply
    satisfiesCellSwap
      normalizer e hleftWeight hrightWeight
        leftHistory rightHistory left right hleft hright
  intro hroot
  exact
    ((not_universal_obstruction
      hleftWeight hrightWeight hn leftHistory rightHistory) hroot).elim

/--
Below twice the principal Hall-pair weight, every genuine universal
retained-history grid cell satisfies its guarded ordered swap law.
-/
theorem
    grid_cell_swaps
    {d M N n leftWeight rightWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 2 * (leftWeight + rightWeight))
    (left right : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = leftWeight)
    (hright : right.word.weight HEAddres.weight = rightWeight) :
    SatisfiesCellSwaps
      (M := M) (N := N) (n := n)
      normalizer e hleftWeight hrightWeight left right := by
  intro leftHistory _hleftHistory rightHistory _hrightHistory
  exact
    satisfies_cell_swap
      normalizer e hleftWeight hrightWeight hn
        leftHistory rightHistory left right hleft hright

/--
Positive source weights put cutoff four below twice the principal Hall-pair
weight.
-/
lemma cutoff_sum_four
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 4) :
    n ≤ 2 * (leftWeight + rightWeight) := by
  omega

/--
Positive source weights put cutoff six below three times the principal
Hall-pair weight.
-/
lemma cutoff_sum_six
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 6) :
    n ≤ 3 * (leftWeight + rightWeight) := by
  omega

/--
Through cutoff four, every genuine universal retained-history grid cell
satisfies its guarded ordered swap law without a shallow class-three input.
-/
theorem
    cell_swaps_four
    {d M N n leftWeight rightWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 4)
    (left right : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = leftWeight)
    (hright : right.word.weight HEAddres.weight = rightWeight) :
    SatisfiesCellSwaps
      (M := M) (N := N) (n := n)
      normalizer e hleftWeight hrightWeight left right := by
  exact
    grid_cell_swaps
      normalizer e hleftWeight hrightWeight
      (cutoff_sum_four
        hleftWeight hrightWeight hn)
      left right hleft hright

/--
Through cutoff six, every genuine universal retained-history grid cell
satisfies its guarded ordered swap law without a nonterminal Hall collector.
-/
theorem
    cell_swaps_six
    {d M N n leftWeight rightWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 6)
    (left right : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = leftWeight)
    (hright : right.word.weight HEAddres.weight = rightWeight) :
    SatisfiesCellSwaps
      (M := M) (N := N) (n := n)
      normalizer e hleftWeight hrightWeight left right := by
  exact
    satisfies_cell_swaps
      normalizer e hleftWeight hrightWeight
      (cutoff_sum_six
        hleftWeight hrightWeight hn)
      left right hleft hright

end
