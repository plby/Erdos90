open URVocabu

/-- A decoded symbolic factor represents one concrete recipe when it has the
same substituted Hall word and the same evaluation for every truncation and
exponent family. -/
def SymbolicRepresentsRecipe
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (left right factor : SPFactor H ι)
    (recipe : BRecipe) :
    Prop :=
  factor.word =
      CWord.hallPairBind
        left.word right.word recipe.erasedShape ∧
    ∀ (truncation : ℕ) (e : ι → HEFam H),
      factor.eval (n := truncation) e =
        recipe.erasedShape.eval
            (HPAtom.eval
              (left.wordValue (n := truncation))
              (right.wordValue (n := truncation))) ^
          coefficientValue recipe
            (left.coefficient.eval e) (right.coefficient.eval e)

/-- The selected retained recipe branch exposed by closure decomposition. -/
def CoefficientRecursiveBranch
    (n : ℕ)
    (recipe : BRecipe) :
    Prop :=
  recipe ∈ sourceRecipes n 1 1 ∨
    ∃ leftRecipe ∈ recipeCoefficientRecipes n,
      ∃ rightRecipe ∈ recipeCoefficientRecipes n,
        recipe.erasedShape =
            .commutator leftRecipe.erasedShape rightRecipe.erasedShape ∧
          weightedWordWeight 1 1 leftRecipe <
              weightedWordWeight 1 1 recipe ∧
            weightedWordWeight 1 1 rightRecipe <
              weightedWordWeight 1 1 recipe

/-- Full occurrence certificate for a factor in the retained-transversal
symbolic trace. -/
def RetainedSymbolicFactor
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (n : ℕ)
    (left right factor : SPFactor H ι)
    (recipe : BRecipe) :
    Prop :=
  SymbolicRepresentsRecipe left right factor recipe ∧
    recipe ∈ recipeCoefficientRecipes n ∧
      CoefficientRecursiveBranch n recipe

/-- Looking up a recipe's orbit key and decoding it gives a symbolic factor
representing that recipe. -/
lemma symbolic_represents_key
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n leftWeight rightWeight : ℕ}
    (left right : SPFactor H ι)
    (index : RetainedOrbitIndex n leftWeight rightWeight)
    (recipe : BRecipe)
    (hkey :
      retainedOrbitKey index = polynomialOrbitKey recipe) :
    SymbolicRepresentsRecipe left right
      (orbitSymbolicFactor normalizer left right index)
      recipe := by
  constructor
  · unfold orbitSymbolicFactor
    rw [RFPkt.word_symbolicFactor]
    unfold RFPkt.boundWord
    unfold orbitBlockPacket
    rw [orbit_block_packet]
    exact congrArg
      (fun key : POKey =>
        CWord.hallPairBind
          left.word right.word key.erasedShape)
      hkey
  · intro truncation e
    rw [eval_symbolic_factor, hkey,
      orbit_value_key]

private lemma forall₂_of_map_eq
    {α : Type v}
    {β : Type w}
    {γ : Type x}
    {relation : α → β → Prop}
    (left : List α)
    (right : List β)
    (leftKey : α → γ)
    (rightKey : β → γ)
    (hmap : left.map leftKey = right.map rightKey)
    (hrelation :
      ∀ leftItem rightItem,
        leftKey leftItem = rightKey rightItem →
          relation leftItem rightItem) :
    List.Forall₂ relation left right := by
  induction left generalizing right with
  | nil =>
      cases right with
      | nil =>
          exact .nil
      | cons rightItem right =>
          simp at hmap
  | cons leftItem left ih =>
      cases right with
      | nil =>
          simp at hmap
      | cons rightItem right =>
          simp only [List.map_cons, List.cons.injEq] at hmap
          exact
            .cons
              (hrelation leftItem rightItem hmap.1)
              (ih right hmap.2)

private lemma forall₂_and_right_of_forall₂
    {α : Type v}
    {β : Type w}
    {relation : α → β → Prop}
    {motive : β → Prop}
    {left : List α}
    {right : List β}
    (hrelation : List.Forall₂ relation left right)
    (hmotive : ∀ rightItem ∈ right, motive rightItem) :
    List.Forall₂
      (fun leftItem rightItem =>
        relation leftItem rightItem ∧ motive rightItem)
      left right := by
  induction hrelation with
  | nil =>
      exact .nil
  | cons hhead htail ih =>
      exact
        .cons
          ⟨hhead, hmotive _ (by simp)⟩
          (ih (fun rightItem hrightItem =>
            hmotive rightItem (by simp [hrightItem])))

private lemma right_left_forall₂
    {α : Type v}
    {β : Type w}
    {relation : α → β → Prop}
    {left : List α}
    {right : List β}
    (hrelation : List.Forall₂ relation left right)
    {leftItem : α}
    (hleftItem : leftItem ∈ left) :
    ∃ rightItem ∈ right, relation leftItem rightItem := by
  induction hrelation with
  | nil =>
      simp at hleftItem
  | cons hhead htail ih =>
      rcases List.mem_cons.mp hleftItem with rfl | hleftItem
      · exact ⟨_, by simp, hhead⟩
      · rcases ih hleftItem with ⟨rightItem, hrightItem, hrelation⟩
        exact ⟨rightItem, by simp [hrightItem], hrelation⟩

private lemma left_right_forall₂
    {α : Type v}
    {β : Type w}
    {relation : α → β → Prop}
    {left : List α}
    {right : List β}
    (hrelation : List.Forall₂ relation left right)
    {rightItem : β}
    (hrightItem : rightItem ∈ right) :
    ∃ leftItem ∈ left, relation leftItem rightItem := by
  induction hrelation with
  | nil =>
      simp at hrightItem
  | cons hhead htail ih =>
      rcases List.mem_cons.mp hrightItem with rfl | hrightItem
      · exact ⟨_, by simp, hhead⟩
      · rcases ih hrightItem with ⟨leftItem, hleftItem, hrelation⟩
        exact ⟨leftItem, by simp [hleftItem], hrelation⟩

private lemma map_map_of₂
    {α : Type v}
    {β : Type w}
    {γ : Type x}
    {relation : α → β → Prop}
    {left : List α}
    {right : List β}
    (hrelation : List.Forall₂ relation left right)
    (leftValue : α → γ)
    (rightValue : β → γ)
    (hvalue :
      ∀ leftItem rightItem,
        relation leftItem rightItem →
          leftValue leftItem = rightValue rightItem) :
    left.map leftValue = right.map rightValue := by
  induction hrelation with
  | nil =>
      rfl
  | cons hhead _ ih =>
      simp only [List.map_cons, hvalue _ _ hhead, ih]

/-- Any supported fixed recipe packet is paired occurrence-for-occurrence
with the symbolic factors decoded from its finite-index trace. -/
lemma forall₂_symbolicFactorRepresentsRecipe_recipePacketFiniteIndexTrace
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n leftWeight rightWeight : ℕ}
    (left right : SPFactor H ι)
    (fixedRecipes : List BRecipe)
    (hsupport :
      RecipeOrbitSupported
        n leftWeight rightWeight fixedRecipes) :
    List.Forall₂
      (SymbolicRepresentsRecipe left right)
      ((recipeIndexTrace fixedRecipes hsupport).map
        (orbitSymbolicFactor normalizer left right))
      fixedRecipes := by
  rw [List.forall₂_map_left_iff]
  exact
    forall₂_of_map_eq
      (recipeIndexTrace fixedRecipes hsupport)
      fixedRecipes
      retainedOrbitKey
      polynomialOrbitKey
      (key_recipe_trace
        fixedRecipes hsupport)
      (fun index recipe hkey =>
        symbolic_represents_key
          normalizer left right index recipe hkey)

/-- The retained-transversal symbolic trace and the selected retained recipes
are paired occurrence-for-occurrence with full recursive provenance. -/
lemma
    forall₂_retainedTraceFactors_finiteIndexFactors
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (n : ℕ)
    (left right : SPFactor H ι) :
    List.Forall₂
      (RetainedSymbolicFactor n left right)
      (retainedSymbolicFactors
        normalizer n left right)
      (recipeCoefficientRecipes n) := by
  unfold retainedSymbolicFactors
  exact
    forall₂_and_right_of_forall₂
      (forall₂_symbolicFactorRepresentsRecipe_recipePacketFiniteIndexTrace
        normalizer left right
        (recipeCoefficientRecipes n)
        (supported_coefficient_recipes n))
      (fun recipe hrecipe =>
        ⟨hrecipe,
          source_recipes_coeff
            hrecipe⟩)

/-- Forgetting coefficients from the symbolic decoder recovers the selected
recipe words after Hall-pair substitution, in the same occurrence order. -/
lemma recipe_symbolic_factors
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (n : ℕ)
    (left right : SPFactor H ι) :
    (retainedSymbolicFactors
      normalizer n left right).map SPFactor.word =
      (recipeCoefficientRecipes n).map fun recipe =>
        CWord.hallPairBind
          left.word right.word recipe.erasedShape := by
  apply
    map_map_of₂
      (forall₂_retainedTraceFactors_finiteIndexFactors
        normalizer n left right)
  intro factor recipe hfactor
  exact hfactor.1.1

/-- Every decoded retained-transversal occurrence has a selected recipe
witness with an exact semantic certificate and its recursive branch. -/
lemma
    rec_idx_factors
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n : ℕ}
    (left right factor : SPFactor H ι)
    (hfactor :
      factor ∈
        retainedSymbolicFactors
          normalizer n left right) :
    ∃ recipe ∈ recipeCoefficientRecipes n,
      SymbolicRepresentsRecipe left right factor recipe ∧
        CoefficientRecursiveBranch n recipe := by
  rcases
      right_left_forall₂
        (forall₂_retainedTraceFactors_finiteIndexFactors
          normalizer n left right)
        hfactor with
    ⟨recipe, hrecipe, hrepresents, _hrecipe, hbranch⟩
  exact ⟨recipe, hrecipe, hrepresents, hbranch⟩

/-- Under root-weight substitution, the symbolic word weight of a represented
recipe is its weighted recipe word weight. -/
lemma weighted_represents_recipe
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    {left right factor : SPFactor H ι}
    {recipe : BRecipe}
    (hleft : left.word.weight HEAddres.weight = 1)
    (hright : right.word.weight HEAddres.weight = 1)
    (hrepresents :
      SymbolicRepresentsRecipe left right factor recipe) :
    factor.word.weight HEAddres.weight =
      weightedWordWeight 1 1 recipe := by
  rw [hrepresents.1, CWord.weight_pair_bind, hleft, hright]
  rfl

/--
Every decoded retained-transversal symbolic factor is either represented by a
source recipe or is literally a commutator word of two strictly lighter
decoded factors from the same finite trace.
-/
lemma
    idx_symbolic_factors
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n : ℕ}
    (left right factor : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = 1)
    (hright : right.word.weight HEAddres.weight = 1)
    (hfactor :
      factor ∈
        retainedSymbolicFactors
          normalizer n left right) :
    (∃ recipe ∈ sourceRecipes n 1 1,
      SymbolicRepresentsRecipe left right factor recipe) ∨
      ∃ leftFactor ∈
          retainedSymbolicFactors
            normalizer n left right,
        ∃ rightFactor ∈
            retainedSymbolicFactors
              normalizer n left right,
          factor.word = .commutator leftFactor.word rightFactor.word ∧
            leftFactor.word.weight HEAddres.weight <
                factor.word.weight HEAddres.weight ∧
              rightFactor.word.weight HEAddres.weight <
                factor.word.weight HEAddres.weight := by
  let relation :=
    RetainedSymbolicFactor n left right
  have hrelation :
      List.Forall₂ relation
        (retainedSymbolicFactors
          normalizer n left right)
        (recipeCoefficientRecipes n) :=
    forall₂_retainedTraceFactors_finiteIndexFactors
      normalizer n left right
  rcases
      right_left_forall₂ hrelation hfactor with
    ⟨recipe, _hrecipe, hrepresents, _hrecipeSelected, hbranch⟩
  rcases hbranch with
    hsource |
      ⟨leftRecipe, hleftRecipe, rightRecipe, hrightRecipe, hshape,
        hleftLt, hrightLt⟩
  · exact Or.inl ⟨recipe, hsource, hrepresents⟩
  · rcases
        left_right_forall₂ hrelation hleftRecipe with
      ⟨leftFactor, hleftFactor, hleftRepresents, _hleftSelected,
        _hleftBranch⟩
    rcases
        left_right_forall₂ hrelation hrightRecipe with
      ⟨rightFactor, hrightFactor, hrightRepresents, _hrightSelected,
        _hrightBranch⟩
    refine
      Or.inr
        ⟨leftFactor, hleftFactor, rightFactor, hrightFactor, ?_, ?_, ?_⟩
    · calc
        factor.word =
            CWord.hallPairBind
              left.word right.word recipe.erasedShape :=
          hrepresents.1
        _ =
            CWord.hallPairBind left.word right.word
              (.commutator leftRecipe.erasedShape rightRecipe.erasedShape) := by
          rw [hshape]
        _ =
            .commutator
              (CWord.hallPairBind
                left.word right.word leftRecipe.erasedShape)
              (CWord.hallPairBind
                left.word right.word rightRecipe.erasedShape) := by
          rfl
        _ = .commutator leftFactor.word rightFactor.word := by
          rw [← hleftRepresents.1, ← hrightRepresents.1]
    · rw [
        weighted_represents_recipe
          hleft hright hleftRepresents,
        weighted_represents_recipe
          hleft hright hrepresents]
      exact hleftLt
    · rw [
        weighted_represents_recipe
          hleft hright hrightRepresents,
        weighted_represents_recipe
          hleft hright hrepresents]
      exact hrightLt

/--
Well-founded induction over decoded retained-transversal symbolic factors.
The correction case receives strictly lighter parent factors from the same
occurrence inventory.
-/
theorem symbolic_factors_induction
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n : ℕ}
    (left right : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = 1)
    (hright : right.word.weight HEAddres.weight = 1)
    {motive : SPFactor H ι → Prop}
    (source :
      ∀ factor,
        factor ∈
            retainedSymbolicFactors
              normalizer n left right →
          (∃ recipe ∈ sourceRecipes n 1 1,
            SymbolicRepresentsRecipe left right factor recipe) →
            motive factor)
    (correction :
      ∀ factor leftFactor rightFactor,
        factor ∈
            retainedSymbolicFactors
              normalizer n left right →
          leftFactor ∈
              retainedSymbolicFactors
                normalizer n left right →
            rightFactor ∈
                retainedSymbolicFactors
                  normalizer n left right →
              factor.word = .commutator leftFactor.word rightFactor.word →
                motive leftFactor →
                  motive rightFactor →
                    motive factor) :
    ∀ factor ∈
        retainedSymbolicFactors
          normalizer n left right,
      motive factor := by
  intro factor hfactor
  refine
    (InvImage.wf
      (fun nextFactor : SPFactor H ι =>
        nextFactor.word.weight HEAddres.weight)
      Nat.lt_wfRel.wf).induction
        (C := fun nextFactor =>
          nextFactor ∈
              retainedSymbolicFactors
                normalizer n left right →
            motive nextFactor)
        factor ?_ hfactor
  intro nextFactor ih hnextFactor
  rcases
      idx_symbolic_factors
        normalizer left right nextFactor hleft hright hnextFactor with
    hsource |
      ⟨leftFactor, hleftFactor, rightFactor, hrightFactor, hword, hleftLt,
        hrightLt⟩
  · exact source nextFactor hnextFactor hsource
  · exact
      correction nextFactor leftFactor rightFactor
        hnextFactor hleftFactor hrightFactor hword
        (ih leftFactor hleftLt hleftFactor)
        (ih rightFactor hrightLt hrightFactor)

end
  SRProven
end TCTex
end Towers

/-!
# Semantic resolution for retained-transversal symbolic factors

The retained-transversal symbolic trace has an occurrence-preserving recursive
provenance certificate.  This file packages the local source and commutator
laws needed to propagate any factor-local invariant through that provenance.
The resolver retains strict word-weight descent at every correction step.

As a concrete instance, every decoded factor receives a finite derivation tree
whose leaves are represented by source recipes and whose internal nodes are
literal commutator words of strictly lighter decoded factors from the same
trace.

This factor-local resolution does not prove the ordered product identity for
the whole trace.  That schedule-sensitive obligation remains separate.

This file is intentionally not imported by the existing collection proof.
-/

noncomputable section

namespace Towers
namespace TCTex
namespace
  SSResolu

universe u

open scoped commutatorElement

open HACoeff
open BRSpec
open
  CTAssigna
open
  TSDecode
open
  SRProven
open URVocabu

/--
Local factor laws for propagating an invariant through the decoded
retained-transversal trace.  The correction law sees the strictly lighter
parents selected by recursive provenance.
-/
structure RSKerna
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (n : ℕ)
    (left right : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = 1)
    (hright : right.word.weight HEAddres.weight = 1) where
  factorMotive : SPFactor H ι → Prop
  source_motive :
    ∀ factor,
      factor ∈
          retainedSymbolicFactors
            normalizer n left right →
        (∃ recipe ∈ sourceRecipes n 1 1,
          SymbolicRepresentsRecipe left right factor recipe) →
          factorMotive factor
  correction_motive :
    ∀ factor leftFactor rightFactor,
      factor ∈
          retainedSymbolicFactors
            normalizer n left right →
        leftFactor ∈
            retainedSymbolicFactors
              normalizer n left right →
          rightFactor ∈
              retainedSymbolicFactors
                normalizer n left right →
            factor.word = .commutator leftFactor.word rightFactor.word →
              leftFactor.word.weight HEAddres.weight <
                  factor.word.weight HEAddres.weight →
                rightFactor.word.weight HEAddres.weight <
                    factor.word.weight HEAddres.weight →
                  factorMotive leftFactor →
                    factorMotive rightFactor →
                      factorMotive factor

namespace RSKerna

/--
Every decoded retained-transversal occurrence satisfies the invariant of a
local semantic kernel.
-/
theorem motive_of_mem
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    {normalizer :
      WBForm.RCNormal H ι}
    {n : ℕ}
    {left right : SPFactor H ι}
    {hleft : left.word.weight HEAddres.weight = 1}
    {hright : right.word.weight HEAddres.weight = 1}
    (kernel :
      RSKerna
        normalizer n left right hleft hright)
    {factor : SPFactor H ι}
    (hfactor :
      factor ∈
        retainedSymbolicFactors
          normalizer n left right) :
    kernel.factorMotive factor := by
  refine
    (InvImage.wf
      (fun nextFactor : SPFactor H ι =>
        nextFactor.word.weight HEAddres.weight)
      Nat.lt_wfRel.wf).induction
        (C := fun nextFactor =>
          nextFactor ∈
              retainedSymbolicFactors
                normalizer n left right →
            kernel.factorMotive nextFactor)
        factor ?_ hfactor
  intro nextFactor ih hnextFactor
  rcases
      idx_symbolic_factors
        normalizer left right nextFactor hleft hright hnextFactor with
    hsource |
      ⟨leftFactor, hleftFactor, rightFactor, hrightFactor, hword, hleftLt,
        hrightLt⟩
  · exact kernel.source_motive nextFactor hnextFactor hsource
  · exact
      kernel.correction_motive nextFactor leftFactor rightFactor
        hnextFactor hleftFactor hrightFactor hword hleftLt hrightLt
        (ih leftFactor hleftLt hleftFactor)
        (ih rightFactor hrightLt hrightFactor)

end RSKerna

/--
A finite derivation tree for one retained-transversal symbolic factor.  Every
node remains an occurrence from the decoded trace, and every correction edge
records strict word-weight descent.
-/
inductive RCGen
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (n : ℕ)
    (left right : SPFactor H ι) :
    SPFactor H ι → Prop
  | source {factor}
      (hfactor :
        factor ∈
          retainedSymbolicFactors
            normalizer n left right)
      (hsource :
        ∃ recipe ∈ sourceRecipes n 1 1,
          SymbolicRepresentsRecipe left right factor recipe) :
      RCGen normalizer n left right factor
  | commutator {factor leftFactor rightFactor}
      (hfactor :
        factor ∈
          retainedSymbolicFactors
            normalizer n left right)
      (hword :
        factor.word = .commutator leftFactor.word rightFactor.word)
      (hleftLt :
        leftFactor.word.weight HEAddres.weight <
          factor.word.weight HEAddres.weight)
      (hrightLt :
        rightFactor.word.weight HEAddres.weight <
          factor.word.weight HEAddres.weight)
      (hleftGenerated :
        RCGen
          normalizer n left right leftFactor)
      (hrightGenerated :
        RCGen
          normalizer n left right rightFactor) :
      RCGen normalizer n left right factor

namespace RCGen

/-- Every node of a retained source/commutator derivation belongs to the
decoded occurrence inventory. -/
lemma mem
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    {normalizer :
      WBForm.RCNormal H ι}
    {n : ℕ}
    {left right factor : SPFactor H ι}
    (hfactor :
      RCGen normalizer n left right factor) :
    factor ∈
      retainedSymbolicFactors
        normalizer n left right := by
  cases hfactor with
  | source hfactor _ =>
      exact hfactor
  | commutator hfactor _ _ _ _ _ =>
      exact hfactor

end RCGen

/-- Source leaves and literal commutator nodes form a semantic factor kernel. -/
def generatedSemanticKernel
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (n : ℕ)
    (left right : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = 1)
    (hright : right.word.weight HEAddres.weight = 1) :
    RSKerna
      normalizer n left right hleft hright where
  factorMotive :=
    RCGen normalizer n left right
  source_motive _factor hfactor hsource :=
    .source hfactor hsource
  correction_motive _factor _leftFactor _rightFactor
      hfactor _hleftFactor _hrightFactor hword hleftLt hrightLt
      hleftGenerated hrightGenerated :=
    .commutator hfactor hword hleftLt hrightLt
      hleftGenerated hrightGenerated

/--
Every decoded retained-transversal factor has a source/commutator derivation
tree internal to the same occurrence inventory.
-/
theorem
    retained_idx_factors
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n : ℕ}
    (left right factor : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = 1)
    (hright : right.word.weight HEAddres.weight = 1)
    (hfactor :
      factor ∈
        retainedSymbolicFactors
          normalizer n left right) :
    RCGen normalizer n left right factor :=
  (generatedSemanticKernel
    normalizer n left right hleft hright).motive_of_mem hfactor

/--
Factor-local recursion stops exactly at the ordered retained-recipe product.
Proving that product equal to the powered commutator is the remaining global
schedule obligation.
-/
theorem
    recipe_recipes_commutator
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (left right : SPFactor H ι) :
    SPFactor.listEval (n := n) e
        (retainedSymbolicFactors
          normalizer n left right) =
      ⁅left.wordValue (n := n) ^ left.coefficient.eval e,
        right.wordValue (n := n) ^ right.coefficient.eval e⁆ ↔
      ((recipeCoefficientRecipes n).map fun recipe =>
          recipe.erasedShape.eval
              (HPAtom.eval
                (left.wordValue (n := n))
                (right.wordValue (n := n))) ^
            coefficientValue recipe
              (left.coefficient.eval e) (right.coefficient.eval e)).prod =
        ⁅left.wordValue (n := n) ^ left.coefficient.eval e,
          right.wordValue (n := n) ^ right.coefficient.eval e⁆ := by
  rw [
    symbolic_factors_recipes]

end
  SSResolu
end TCTex
end Towers

/-!
# Support certificates for retained-transversal symbolic factors

The retained-transversal symbolic decoder preserves repeated occurrences and
its recursive provenance resolves every occurrence into source leaves and
strictly lighter commutator nodes.  This file packages that provenance together
with the finite-closure support and the physical root-weight interval of every
decoded factor.

The resulting certificate is factor local.  It does not assert the remaining
schedule-sensitive ordered recollection theorem.

This file is intentionally not imported by the existing collection proof.
-/

noncomputable section

namespace Towers
namespace TCTex
namespace
  TSSuppor

universe u

open HACoeff
open BRSpec
open
  CTAssigna
open UCVocabu
open
  TSDecode
open
  SRProven
open
  SSResolu

/--
Every decoded retained-transversal occurrence has a selected recipe witness in
the finite correction closure, with its exact symbolic semantics and recursive
branch.
-/
lemma
    recipe_idx_factors
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n : ℕ}
    (left right factor : SPFactor H ι)
    (hfactor :
      factor ∈
        retainedSymbolicFactors
          normalizer n left right) :
    ∃ recipe ∈ recipeCoefficientRecipes n,
      recipe ∈ correctionClosureRecipes n 1 1 ∧
        SymbolicRepresentsRecipe left right factor recipe ∧
          CoefficientRecursiveBranch n recipe := by
  rcases
      rec_idx_factors
        normalizer left right factor hfactor with
    ⟨recipe, hrecipe, hrepresents, hbranch⟩
  exact
    ⟨recipe, hrecipe,
      closure_recipes_coefficient
        hrecipe,
      hrepresents, hbranch⟩

/--
At root weights, every decoded retained-transversal factor has physical word
weight at least two.
-/
lemma
    two_symbolic_factors
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n : ℕ}
    (left right factor : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = 1)
    (hright : right.word.weight HEAddres.weight = 1)
    (hfactor :
      factor ∈
        retainedSymbolicFactors
          normalizer n left right) :
    2 ≤ factor.word.weight HEAddres.weight := by
  rcases
      rec_idx_factors
        normalizer left right factor hfactor with
    ⟨recipe, _hrecipe, hrepresents, _hbranch⟩
  rw [
    weighted_represents_recipe
      hleft hright hrepresents]
  have hleftDegree := leftDegree_pos recipe
  have hrightDegree := rightDegree_pos recipe
  simp only [weighted_word_weight, Nat.mul_one]
  omega

/--
At root weights, every decoded retained-transversal factor remains strictly
below the declared cutoff.
-/
lemma
    coefficient_symbolic_factors
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n : ℕ}
    (left right factor : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = 1)
    (hright : right.word.weight HEAddres.weight = 1)
    (hfactor :
      factor ∈
        retainedSymbolicFactors
          normalizer n left right) :
    factor.word.weight HEAddres.weight < n := by
  rcases
      recipe_idx_factors
        normalizer left right factor hfactor with
    ⟨recipe, _hrecipe, hclosure, hrepresents, _hbranch⟩
  rw [
    weighted_represents_recipe
      hleft hright hrepresents]
  exact
    weighted_closure_recipes
      hclosure

/--
Complete local support certificate for one decoded retained-transversal
occurrence.
-/
structure RetainedSymbolicSupport
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (n : ℕ)
    (left right factor : SPFactor H ι) : Prop where
  mem :
    factor ∈
      retainedSymbolicFactors
        normalizer n left right
  exists_recipe :
    ∃ recipe ∈ recipeCoefficientRecipes n,
      recipe ∈ correctionClosureRecipes n 1 1 ∧
        SymbolicRepresentsRecipe left right factor recipe ∧
          CoefficientRecursiveBranch n recipe
  generated :
    RCGen normalizer n left right factor
  two_word_weight : 2 ≤ factor.word.weight HEAddres.weight
  word_weight_cutoff : factor.word.weight HEAddres.weight < n

/--
Every decoded retained-transversal occurrence receives the complete local
support certificate.
-/
lemma retained_symbolic_support
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n : ℕ}
    (left right factor : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = 1)
    (hright : right.word.weight HEAddres.weight = 1)
    (hfactor :
      factor ∈
        retainedSymbolicFactors
          normalizer n left right) :
    RetainedSymbolicSupport normalizer n left right factor := by
  exact
    { mem := hfactor
      exists_recipe :=
        recipe_idx_factors
          normalizer left right factor hfactor
      generated :=
        retained_idx_factors
          normalizer left right factor hleft hright hfactor
      two_word_weight :=
        two_symbolic_factors
          normalizer left right factor hleft hright hfactor
      word_weight_cutoff :=
        coefficient_symbolic_factors
          normalizer left right factor hleft hright hfactor }

/--
The complete decoded retained-transversal list is locally supported
occurrence-by-occurrence.
-/
lemma forall_symbolic_support
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n : ℕ}
    (left right : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = 1)
    (hright : right.word.weight HEAddres.weight = 1) :
    ∀ factor ∈
        retainedSymbolicFactors
          normalizer n left right,
      RetainedSymbolicSupport normalizer n left right factor := by
  intro factor hfactor
  exact
    retained_symbolic_support
      normalizer left right factor hleft hright hfactor

/--
The presence of a decoded retained-transversal occurrence forces the cutoff to
lie strictly above the first bracket weight.
-/
lemma
    recipe_coefficient_factors
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n : ℕ}
    (left right factor : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = 1)
    (hright : right.word.weight HEAddres.weight = 1)
    (hfactor :
      factor ∈
        retainedSymbolicFactors
          normalizer n left right) :
    3 ≤ n := by
  have htwo :
      2 ≤ factor.word.weight HEAddres.weight :=
    two_symbolic_factors
      normalizer left right factor hleft hright hfactor
  have hlt :
      factor.word.weight HEAddres.weight < n :=
    coefficient_symbolic_factors
      normalizer left right factor hleft hright hfactor
  omega

/-- Below the first bracket cutoff, the decoded retained-transversal trace is
empty. -/
lemma
    nil_n_two
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n : ℕ}
    (left right : SPFactor H ι)
    (hleft : left.word.weight HEAddres.weight = 1)
    (hright : right.word.weight HEAddres.weight = 1)
    (hn : n ≤ 2) :
    retainedSymbolicFactors
        normalizer n left right =
      [] := by
  apply List.eq_nil_iff_forall_not_mem.mpr
  intro factor hfactor
  have hthree :
      3 ≤ n :=
    recipe_coefficient_factors
      normalizer left right factor hleft hright hfactor
  omega

end
  TSSuppor
end TCTex
end Towers

/-!
# Physical correction presentations for retained-transversal symbolic traces

The retained-transversal finite-index decoder and the retained-profile physical
correction packet may choose different polynomial-orbit representatives.  Their
ordered symbolic evaluations nevertheless agree because both evaluate as the
same selected retained recipe transversal.

This file combines that semantic comparison with the local support certificate
for every decoded finite-index occurrence.  The resulting presentation is an
arbitrary-cutoff interface for later residual schedulers, conditional only on
the remaining retained recipe-product recollection law.

This file is intentionally not imported by the existing collection proof.
-/

noncomputable section

namespace Towers
namespace TCTex
namespace
  PSPhysic

universe u

open
  CCThree
open
  UCFtry
open
  TSDecode
open
  TSSuppor
open CPSplita
open TAPkta

/--
The occurrence-preserving finite-index decoder and the routed physical
correction packet have the same ordered symbolic evaluation.
-/
lemma
    factors_physical_correction
    {d n lowerWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (hlistEval :
      SatisfiesRecipeCoefficient d n)
    (normalizers :
      WBForm.PositiveChooseNormalizer H)
    (left right : SPFactor H ι)
    (hleftSupported :
      lowerWeight ≤ left.word.weight HEAddres.weight)
    (hrightSupported :
      lowerWeight ≤ right.word.weight HEAddres.weight)
    (hleft : left.word.weight HEAddres.weight = 1)
    (hright : right.word.weight HEAddres.weight = 1)
    (e : ι → HEFam H) :
    SPFactor.listEval (n := n) e
        (retainedSymbolicFactors
          (normalizers.normalizer ι) n left right) =
      SPFactor.listEval (n := n) e
        (((supportedPacketFactory
            (coefficientTruncatedPacket
              hlistEval)
            normalizers lowerWeight).packet
              left right hleftSupported hrightSupported).factors) := by
  rw [
    supported_factory_global
      hlistEval normalizers left right hleftSupported hrightSupported
        hleft hright]
  exact
    profile_recollect_factors
      (normalizers.normalizer ι) e left right

/--
A routed physical correction packet together with an occurrence-preserving
support-certified finite-index presentation.
-/
structure SymbolicPhysicalPresentation
    {d n lowerWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (hlistEval :
      SatisfiesRecipeCoefficient d n)
    (normalizers :
      WBForm.PositiveChooseNormalizer H)
    (left right : SPFactor H ι)
    (hleftSupported :
      lowerWeight ≤ left.word.weight HEAddres.weight)
    (hrightSupported :
      lowerWeight ≤ right.word.weight HEAddres.weight)
    (hleft : left.word.weight HEAddres.weight = 1)
    (hright : right.word.weight HEAddres.weight = 1) : Prop where
  factor_support :
    ∀ factor ∈
        retainedSymbolicFactors
          (normalizers.normalizer ι) n left right,
      RetainedSymbolicSupport
        (normalizers.normalizer ι) n left right factor
  list_eval_physical :
    ∀ e : ι → HEFam H,
      SPFactor.listEval (n := n) e
          (retainedSymbolicFactors
            (normalizers.normalizer ι) n left right) =
        SPFactor.listEval (n := n) e
          (((supportedPacketFactory
              (coefficientTruncatedPacket
                hlistEval)
              normalizers lowerWeight).packet
                left right hleftSupported hrightSupported).factors)

/--
Every retained recipe-product recollection law supplies a support-certified
physical correction presentation.
-/
noncomputable def symbolicPhysicalPresentation
    {d n lowerWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (hlistEval :
      SatisfiesRecipeCoefficient d n)
    (normalizers :
      WBForm.PositiveChooseNormalizer H)
    (left right : SPFactor H ι)
    (hleftSupported :
      lowerWeight ≤ left.word.weight HEAddres.weight)
    (hrightSupported :
      lowerWeight ≤ right.word.weight HEAddres.weight)
    (hleft : left.word.weight HEAddres.weight = 1)
    (hright : right.word.weight HEAddres.weight = 1) :
    SymbolicPhysicalPresentation
      hlistEval normalizers left right hleftSupported hrightSupported
        hleft hright where
  factor_support :=
    forall_symbolic_support
      (normalizers.normalizer ι) left right hleft hright
  list_eval_physical :=
    factors_physical_correction
      hlistEval normalizers left right hleftSupported hrightSupported
        hleft hright

end
  PSPhysic
end TCTex
end Towers

/-!
# Occurrence schedules for the retained recipe transversal

The retained recipe-product recollection law is an ordered adjacent-swap
theorem.  This file exposes a compositional scheduler-facing form of that
theorem.  One local occurrence step replaces an adjacent pair by an ordered
correction block followed by the swapped pair.  A finite contextual run
preserves its ordered product.

The global retained schedule starts from the powered parent pair and ends at
the exact retained recipe transversal followed by the swapped parents.  Thus
its product invariant cancels to the required powered commutator formula.
Conversely, the powered commutator formula supplies a one-step schedule.  This
characterization isolates the remaining arbitrary-cutoff construction problem
as a genuine occurrence-level Hall collection run.

This file is intentionally not imported by the existing collection proof.
-/

noncomputable section

namespace Towers
namespace TCTex
namespace
  PTOcc

universe u

open scoped commutatorElement

open BRSpec
open
  CTAssigna
open
  CCThree
open
  TSDecode

/-- Evaluate the exact retained recipe transversal at one powered parent pair,
keeping every selected recipe occurrence in its inherited order. -/
def coefficientEvaluatedFactors
    {G : Type*}
    [Group G]
    (n : ℕ)
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    List G :=
  (recipeCoefficientRecipes n).map fun recipe =>
    recipe.erasedShape.eval (HPAtom.eval left right) ^
      coefficientValue recipe leftExponent rightExponent

/--
One occurrence-level Hall collection move.  The local correction block is
ordered and may retain repeated occurrences.  Its only semantic obligation is
the adjacent-swap equation it must implement.
-/
inductive COStep
    {G : Type*}
    [Group G] :
    List G → List G → Prop where
  | obstruction
      (front back : List G)
      (left right : G)
      (corrections : List G)
      (list_prod_mul_swap_eq :
        corrections.prod * right * left = left * right) :
      COStep
        (front ++ [left, right] ++ back)
        (front ++ corrections ++ [right, left] ++ back)

/-- Finite contextual occurrence-level Hall collection runs. -/
abbrev CORw
    {G : Type*}
    [Group G]
    (source target : List G) :
    Prop :=
  Relation.ReflTransGen
    (@COStep G _) source target

namespace COStep

/-- One occurrence-level Hall collection move preserves ordered products. -/
lemma list_prod_eq
    {G : Type*}
    [Group G]
    {source target : List G}
    (step :
      COStep source target) :
    target.prod = source.prod := by
  cases step with
  | obstruction front back left right corrections hswap =>
      calc
        (front ++ corrections ++ [right, left] ++ back).prod =
            front.prod * (corrections.prod * right * left) *
              back.prod := by
          simp [List.prod_append, mul_assoc]
        _ = front.prod * (left * right) * back.prod := by
          rw [hswap]
        _ = (front ++ [left, right] ++ back).prod := by
          simp [List.prod_append, mul_assoc]

/-- An occurrence-level Hall collection move remains valid in a list
context. -/
lemma context
    {G : Type*}
    [Group G]
    {source target : List G}
    (step :
      COStep source target)
    (front back : List G) :
    COStep
      (front ++ source ++ back)
      (front ++ target ++ back) := by
  cases step with
  | obstruction innerPrefix innerSuffix left right corrections hswap =>
      simpa [List.append_assoc] using
        (COStep.obstruction
          (front ++ innerPrefix) (innerSuffix ++ back)
          left right corrections hswap)

end COStep

namespace CORw

/-- Every finite occurrence-level Hall collection run preserves its ordered
product. -/
lemma list_prod_eq
    {G : Type*}
    [Group G]
    {source target : List G}
    (rewrites :
      CORw source target) :
    target.prod = source.prod := by
  induction rewrites with
  | refl =>
      rfl
  | tail _ step ih =>
      exact step.list_prod_eq.trans ih

/-- Finite occurrence-level Hall collection runs remain valid in list
contexts. -/
lemma context
    {G : Type*}
    [Group G]
    {source target : List G}
    (rewrites :
      CORw source target)
    (front back : List G) :
    CORw
      (front ++ source ++ back)
      (front ++ target ++ back) := by
  induction rewrites with
  | refl =>
      exact Relation.ReflTransGen.refl
  | tail _ step ih =>
      exact Relation.ReflTransGen.tail ih (step.context front back)

/-- Independently constructed occurrence-level Hall collection runs compose
under concatenation. -/
lemma append
    {G : Type*}
    [Group G]
    {leftSource leftTarget rightSource rightTarget : List G}
    (left :
      CORw
        leftSource leftTarget)
    (right :
      CORw
        rightSource rightTarget) :
    CORw
      (leftSource ++ rightSource)
      (leftTarget ++ rightTarget) := by
  have hleft :
      CORw
        (leftSource ++ rightSource)
        (leftTarget ++ rightSource) := by
    simpa using left.context [] rightSource
  have hright :
      CORw
        (leftTarget ++ rightSource)
        (leftTarget ++ rightTarget) := by
    simpa using right.context leftTarget []
  exact hleft.trans hright

end CORw

/--
Occurrence-aware arbitrary-cutoff recollection schedule for the retained
transversal.  Its target list is literal: repeated selected recipes are not
deduplicated or permuted.
-/
structure COSched
    (d n : ℕ) :
    Prop where
  rewrites :
    ∀ (left right :
        LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n)
      (leftExponent rightExponent : ℤ),
      CORw
        [left ^ leftExponent, right ^ rightExponent]
        (coefficientEvaluatedFactors
            n left right leftExponent rightExponent ++
          [right ^ rightExponent, left ^ leftExponent])

namespace COSched

/--
A retained occurrence schedule gives the adjacent-swap equation before
cancellation.
-/
lemma evaluated_factors_swap
    {d n : ℕ}
    (schedule :
      COSched.{u} d n)
    (left right :
      LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n)
    (leftExponent rightExponent : ℤ) :
    (coefficientEvaluatedFactors
        n left right leftExponent rightExponent).prod *
          right ^ rightExponent * left ^ leftExponent =
      left ^ leftExponent * right ^ rightExponent := by
  simpa [List.prod_append, mul_assoc] using
    (schedule.rewrites left right leftExponent rightExponent).list_prod_eq

/--
Cancellation of the swapped powered parents turns an occurrence schedule into
the retained recipe-product recollection law.
-/
theorem satisfiesRecipeCoefficient
    {d n : ℕ}
    (schedule :
      COSched.{u} d n) :
    SatisfiesRecipeCoefficient.{u} d n := by
  intro left right leftExponent rightExponent
  change
    (coefficientEvaluatedFactors
        n left right leftExponent rightExponent).prod =
      ⁅left ^ leftExponent, right ^ rightExponent⁆
  have hswap :=
    schedule.evaluated_factors_swap
      left right leftExponent rightExponent
  calc
    (coefficientEvaluatedFactors
          n left right leftExponent rightExponent).prod =
        (coefficientEvaluatedFactors
              n left right leftExponent rightExponent).prod *
            right ^ rightExponent * left ^ leftExponent *
          (left ^ leftExponent)⁻¹ * (right ^ rightExponent)⁻¹ := by
      group
    _ =
        left ^ leftExponent * right ^ rightExponent *
          (left ^ leftExponent)⁻¹ * (right ^ rightExponent)⁻¹ := by
      rw [hswap]
    _ = ⁅left ^ leftExponent, right ^ rightExponent⁆ := by
      rfl

/--
The retained recipe-product law itself supplies a one-step occurrence
schedule.  This direction is useful for transporting existing low-cutoff
packets into the scheduler interface.
-/
noncomputable def satisfies_recipe_coeff
    {d n : ℕ}
    (hlistEval :
      SatisfiesRecipeCoefficient.{u} d n) :
    COSched.{u} d n where
  rewrites left right leftExponent rightExponent := by
    apply Relation.ReflTransGen.single
    simpa using
      (COStep.obstruction
        [] [] (left ^ leftExponent) (right ^ rightExponent)
        (coefficientEvaluatedFactors
          n left right leftExponent rightExponent)
        (by
          unfold coefficientEvaluatedFactors
          rw [hlistEval left right leftExponent rightExponent]
          simp [commutatorElement_def, mul_assoc]))

/--
The missing arbitrary-cutoff retained law is equivalent to constructing an
occurrence-aware contextual Hall collection schedule.
-/
theorem
    satisfies_occ_schedule
    {d n : ℕ} :
    SatisfiesRecipeCoefficient.{u} d n ↔
      COSched.{u} d n := by
  constructor
  · exact satisfies_recipe_coeff
  · exact satisfiesRecipeCoefficient

/-- Through cutoff four, the retained transversal has an occurrence-aware
schedule. -/
noncomputable def n_four
    {d n : ℕ}
    (hn : n ≤ 4) :
    COSched.{u} d n :=
  satisfies_recipe_coeff
    (satisfies_coefficient_four hn)

end COSched

/--
The decoded retained-transversal symbolic trace satisfies its adjacent-swap
equation whenever an occurrence-aware retained schedule is available.
-/
lemma
    recipe_occ_schedule
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (schedule :
      COSched.{u} d n)
    (left right : SPFactor H ι) :
    SPFactor.listEval (n := n) e
          (retainedSymbolicFactors
            normalizer n left right) *
        right.eval (n := n) e * left.eval (n := n) e =
      left.eval (n := n) e * right.eval (n := n) e := by
  rw [
    symbolic_factors_recipes]
  exact
    schedule.evaluated_factors_swap
      (left.wordValue (n := n)) (right.wordValue (n := n))
      (left.coefficient.eval e) (right.coefficient.eval e)

end
  PTOcc
end TCTex
end Towers

/-!
# Occurrence schedules from the cutoff-full collector

The cutoff-full family collector is already a terminating Hall scheduler.
This file compiles its recursive insertion derivations into occurrence-level
adjacent-swap runs.  Retained crossings emit the selected concrete correction
occurrence; crossings at the cutoff emit an empty correction block after the
omitted commutator has been proved trivial.

Full cutoff collection additionally discards source terms whose weight has
already reached the cutoff.  A small semantic extension of the occurrence
relation records those identity erasures explicitly.  Thus every selected
cutoff-full endpoint comes with a finite operational rewrite certificate, not
merely an equality of evaluated products.

This file is intentionally not imported by the existing collection proof.
-/

noncomputable section

namespace Towers
namespace TCTex
namespace
  PCBridge

universe u

open
  HACoeff
open
  CFCollec
open
  CFCollec.DFTerm
open
  FCEnd
open
  FCEnd.IDTerms
open
  CRLayer
open
  OCPartit
open
  PTOcc

/-- Evaluate every concrete decorated-family occurrence without changing its
list order. -/
def collapsedEvaluatedFactors
    {M N K : ℕ}
    {G : Type*}
    [Group G]
    (x y : G)
    (terms : List (DFTerm M N K)) :
    List G :=
  terms.map fun term => collapsedEvalAt x y term

namespace DFTerm.CInsert

/--
Every recursive cutoff insertion compiles to an occurrence-level adjacent-swap
run.  Retained corrections remain literal singleton occurrences, including
repetitions.
-/
lemma occurrenceRewrites
    {M N K n leftWeight rightWeight : ℕ}
    {G : Type*}
    [Group G]
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {x y : G}
    (hx : x ∈ Subgroup.lowerCentralSeries G (leftWeight - 1))
    (hy : y ∈ Subgroup.lowerCentralSeries G (rightWeight - 1))
    (hbot : Subgroup.lowerCentralSeries G (n - 1) = ⊥)
    {L R : List (DFTerm M N K)}
    {A : DFTerm M N K}
    (hinsert :
      CInsert n leftWeight rightWeight L A R) :
    CORw
      (collapsedEvaluatedFactors x y L ++ [collapsedEvalAt x y A])
      (collapsedEvaluatedFactors x y R) := by
  induction hinsert with
  | nil A =>
      exact Relation.ReflTransGen.refl
  | append P B A _hBA =>
      simpa [collapsedEvaluatedFactors, List.map_append,
        List.append_assoc] using
          (Relation.ReflTransGen.refl :
            CORw
              (collapsedEvaluatedFactors x y (P ++ [B, A]))
              (collapsedEvaluatedFactors x y (P ++ [B, A])))
  | @retained P B A _hAB _hweight Q R hcorrection hinsert
      ihcorrection ihinsert =>
      have hswap :
          CORw
            (collapsedEvaluatedFactors x y (P ++ [B]) ++
              [collapsedEvalAt x y A])
            (collapsedEvaluatedFactors x y P ++
              [collapsedEvalAt x y (B.correction A),
                collapsedEvalAt x y A, collapsedEvalAt x y B]) := by
        apply Relation.ReflTransGen.single
        simpa [collapsedEvaluatedFactors, List.map_append,
          List.append_assoc] using
            (COStep.obstruction
              (collapsedEvaluatedFactors x y P) []
              (collapsedEvalAt x y B) (collapsedEvalAt x y A)
              [collapsedEvalAt x y (B.correction A)]
              (by
                simpa using collapsed_correction_mul x y B A))
      have hcorrection' :
          CORw
            (collapsedEvaluatedFactors x y P ++
              [collapsedEvalAt x y (B.correction A),
                collapsedEvalAt x y A, collapsedEvalAt x y B])
            (collapsedEvaluatedFactors x y Q ++
              [collapsedEvalAt x y A, collapsedEvalAt x y B]) := by
        simpa [List.append_assoc] using
          ihcorrection.context []
            [collapsedEvalAt x y A, collapsedEvalAt x y B]
      have hinsert' :
          CORw
            (collapsedEvaluatedFactors x y Q ++
              [collapsedEvalAt x y A, collapsedEvalAt x y B])
            (collapsedEvaluatedFactors x y R ++
              [collapsedEvalAt x y B]) := by
        simpa [List.append_assoc] using
          ihinsert.context [] [collapsedEvalAt x y B]
      simpa [collapsedEvaluatedFactors, List.map_append,
        List.append_assoc] using
          hswap.trans (hcorrection'.trans hinsert')
  | @residual P B A _hAB hweight R hinsert ihinsert =>
      have hcorrection :
          collapsedEvalAt x y (B.correction A) = 1 :=
        collapsed_eval_weight
          hleftWeight hrightWeight hx hy hbot (B.correction A) hweight
      have hcommute :
          collapsedEvalAt x y A * collapsedEvalAt x y B =
            collapsedEvalAt x y B * collapsedEvalAt x y A := by
        have hswap := collapsed_correction_mul x y B A
        rw [hcorrection, one_mul] at hswap
        exact hswap
      have hswap :
          CORw
            (collapsedEvaluatedFactors x y (P ++ [B]) ++
              [collapsedEvalAt x y A])
            (collapsedEvaluatedFactors x y P ++
              [collapsedEvalAt x y A, collapsedEvalAt x y B]) := by
        apply Relation.ReflTransGen.single
        simpa [collapsedEvaluatedFactors, List.map_append,
          List.append_assoc] using
            (COStep.obstruction
              (collapsedEvaluatedFactors x y P) []
              (collapsedEvalAt x y B) (collapsedEvalAt x y A) []
              (by simpa using hcommute))
      have hinsert' :
          CORw
            (collapsedEvaluatedFactors x y P ++
              [collapsedEvalAt x y A, collapsedEvalAt x y B])
            (collapsedEvaluatedFactors x y R ++
              [collapsedEvalAt x y B]) := by
        simpa [List.append_assoc] using
          ihinsert.context [] [collapsedEvalAt x y B]
      simpa [collapsedEvaluatedFactors, List.map_append,
        List.append_assoc] using hswap.trans hinsert'

end DFTerm.CInsert

/--
Occurrence-level cutoff collection step.  The adjacent-swap branch reuses the
retained-transversal scheduler vocabulary.  The terminal branch records the
semantic deletion of one factor already equal to the identity.
-/
inductive TOStepa
    {G : Type*}
    [Group G] :
    List G → List G → Prop where
  | swap
      {source target : List G}
      (step :
        COStep source target) :
      TOStepa source target
  | erase
      (front back : List G)
      (factor : G)
      (hfactor : factor = 1) :
      TOStepa
        (front ++ [factor] ++ back)
        (front ++ back)

/-- Finite cutoff-aware occurrence runs. -/
abbrev TORwa
    {G : Type*}
    [Group G]
    (source target : List G) :
    Prop :=
  Relation.ReflTransGen
    (@TOStepa G _) source target

namespace TOStepa

/-- One cutoff-aware occurrence step preserves its ordered product. -/
lemma list_prod_eq
    {G : Type*}
    [Group G]
    {source target : List G}
    (step : TOStepa source target) :
    target.prod = source.prod := by
  cases step with
  | swap step =>
      exact step.list_prod_eq
  | erase front back factor hfactor =>
      simp [List.prod_append, hfactor]

/-- Cutoff-aware occurrence steps remain valid in list contexts. -/
lemma context
    {G : Type*}
    [Group G]
    {source target : List G}
    (step : TOStepa source target)
    (front back : List G) :
    TOStepa
      (front ++ source ++ back)
      (front ++ target ++ back) := by
  cases step with
  | swap step =>
      exact TOStepa.swap (step.context front back)
  | erase innerFront innerBack factor hfactor =>
      simpa [List.append_assoc] using
        (TOStepa.erase
          (front ++ innerFront) (innerBack ++ back) factor hfactor)

end TOStepa

namespace TORwa

/-- Every finite cutoff-aware occurrence run preserves its ordered product. -/
lemma list_prod_eq
    {G : Type*}
    [Group G]
    {source target : List G}
    (rewrites : TORwa source target) :
    target.prod = source.prod := by
  induction rewrites with
  | refl =>
      rfl
  | tail _ step ih =>
      exact step.list_prod_eq.trans ih

/-- Cutoff-aware occurrence runs remain valid in list contexts. -/
lemma context
    {G : Type*}
    [Group G]
    {source target : List G}
    (rewrites : TORwa source target)
    (front back : List G) :
    TORwa
      (front ++ source ++ back)
      (front ++ target ++ back) := by
  induction rewrites with
  | refl =>
      exact Relation.ReflTransGen.refl
  | tail _ step ih =>
      exact Relation.ReflTransGen.tail ih (step.context front back)

/-- Pure adjacent-swap occurrence runs embed into cutoff-aware runs. -/
lemma ofOccurrenceRewrites
    {G : Type*}
    [Group G]
    {source target : List G}
    (rewrites :
      CORw source target) :
    TORwa source target := by
  induction rewrites with
  | refl =>
      exact Relation.ReflTransGen.refl
  | tail _ step ih =>
      exact Relation.ReflTransGen.tail ih
        (TOStepa.swap step)

end TORwa

namespace DFTerm.CCollec

/--
Every terminating cutoff-full collection derivation compiles to a finite
cutoff-aware occurrence run.  This exposes the collector's actual operational
schedule, including every terminal identity erasure.
-/
lemma truncatedOccurrenceRewrites
    {M N K n leftWeight rightWeight : ℕ}
    {G : Type*}
    [Group G]
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {x y : G}
    (hx : x ∈ Subgroup.lowerCentralSeries G (leftWeight - 1))
    (hy : y ∈ Subgroup.lowerCentralSeries G (rightWeight - 1))
    (hbot : Subgroup.lowerCentralSeries G (n - 1) = ⊥)
    {L R : List (DFTerm M N K)}
    (hcollect :
      CCollec n leftWeight rightWeight L R) :
    TORwa
      (collapsedEvaluatedFactors x y L)
      (collapsedEvaluatedFactors x y R) := by
  induction hcollect with
  | nil =>
      exact Relation.ReflTransGen.refl
  | @retained P A _hweight C R hcollect hinsert ihcollect =>
      have hcollect' :
          TORwa
            (collapsedEvaluatedFactors x y P ++ [collapsedEvalAt x y A])
            (collapsedEvaluatedFactors x y C ++ [collapsedEvalAt x y A]) := by
        simpa [List.append_assoc] using
          ihcollect.context [] [collapsedEvalAt x y A]
      have hinsert' :
          TORwa
            (collapsedEvaluatedFactors x y C ++ [collapsedEvalAt x y A])
            (collapsedEvaluatedFactors x y R) :=
        TORwa.ofOccurrenceRewrites
          (DFTerm.CInsert.occurrenceRewrites
            hleftWeight hrightWeight hx hy hbot hinsert)
      simpa [collapsedEvaluatedFactors, List.map_append,
        List.append_assoc] using hcollect'.trans hinsert'
  | @residual P A hweight C hcollect ihcollect =>
      have hA : collapsedEvalAt x y A = 1 :=
        collapsed_eval_weight
          hleftWeight hrightWeight hx hy hbot A hweight
      have herase :
          TORwa
            (collapsedEvaluatedFactors x y P ++ [collapsedEvalAt x y A])
            (collapsedEvaluatedFactors x y P) := by
        apply Relation.ReflTransGen.single
        simpa [List.append_assoc] using
          (TOStepa.erase
            (collapsedEvaluatedFactors x y P) []
            (collapsedEvalAt x y A) hA)
      simpa [collapsedEvaluatedFactors, List.map_append,
        List.append_assoc] using herase.trans ihcollect

end DFTerm.CCollec

namespace DFTerm

/--
The terminating cutoff-full collector constructs a finite cutoff-aware
occurrence run for every finite concrete input list.
-/
lemma truncated_occurrence_rewrites
    {M N K n leftWeight rightWeight : ℕ}
    {G : Type*}
    [Group G]
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {x y : G}
    (hx : x ∈ Subgroup.lowerCentralSeries G (leftWeight - 1))
    (hy : y ∈ Subgroup.lowerCentralSeries G (rightWeight - 1))
    (hbot : Subgroup.lowerCentralSeries G (n - 1) = ⊥)
    (terms : List (DFTerm M N K)) :
    ∃ endpoint : List (DFTerm M N K),
      TORwa
        (collapsedEvaluatedFactors x y terms)
        (collapsedEvaluatedFactors x y endpoint) := by
  rcases
      FCTermin.exists_cutoffCollects
        (n := n) hleftWeight hrightWeight terms with
    ⟨endpoint, hcollect⟩
  exact
    ⟨endpoint,
      DFTerm.CCollec.truncatedOccurrenceRewrites
        hleftWeight hrightWeight hx hy hbot hcollect⟩

end DFTerm

namespace IDTerms

/--
Every selected inverse-raw cutoff-full endpoint carries a literal finite
occurrence-level rewrite certificate from its inverse-oriented raw source.
-/
lemma truncatedOccurrenceRewrites
    {M N n leftWeight rightWeight : ℕ}
    (collected :
      IDTerms
        M N n leftWeight rightWeight)
    {G : Type*}
    [Group G]
    (x y : G)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hx : x ∈ Subgroup.lowerCentralSeries G (leftWeight - 1))
    (hy : y ∈ Subgroup.lowerCentralSeries G (rightWeight - 1))
    (hbot : Subgroup.lowerCentralSeries G (n - 1) = ⊥) :
    TORwa
      (collapsedEvaluatedFactors x y
        (inverseDecoratedTerms M N))
      (collapsedEvaluatedFactors x y collected.factors) :=
  DFTerm.CCollec.truncatedOccurrenceRewrites
    hleftWeight hrightWeight hx hy hbot
      collected.family_cutoff_collects

end IDTerms

namespace NRLayer

/--
The globally selected natural recollection endpoint inherits the literal
cutoff-aware occurrence run constructed by the terminating collector.
-/
lemma endpoint_occurrence_rewrites
    {n leftWeight rightWeight : ℕ}
    (layer : NRLayer n leftWeight rightWeight)
    (M N : ℕ)
    {G : Type*}
    [Group G]
    (x y : G)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hx : x ∈ Subgroup.lowerCentralSeries G (leftWeight - 1))
    (hy : y ∈ Subgroup.lowerCentralSeries G (rightWeight - 1))
    (hbot : Subgroup.lowerCentralSeries G (n - 1) = ⊥) :
    TORwa
      (collapsedEvaluatedFactors x y
        (inverseDecoratedTerms M N))
      (collapsedEvaluatedFactors x y (layer.endpoint M N).factors) :=
  IDTerms.truncatedOccurrenceRewrites
    (layer.endpoint M N) x y hleftWeight hrightWeight hx hy hbot

/--
At root weights, the free lower-central truncation discharges the support and
terminal-vanishing hypotheses automa.  This is the concrete
occurrence-run form consumed by Claim 5 constructions.
-/
lemma endpointOccRewrites
    {d n : ℕ}
    (layer : NRLayer n 1 1)
    (M N : ℕ)
    (x y :
      LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n) :
    TORwa
      (collapsedEvaluatedFactors x y
        (inverseDecoratedTerms M N))
      (collapsedEvaluatedFactors x y (layer.endpoint M N).factors) := by
  exact
    NRLayer.endpoint_occurrence_rewrites
      layer M N x y (by omega) (by omega) (by simp) (by simp)
        SCFactor.trunc_last_bot

end NRLayer

end
  PCBridge
end TCTex
end Towers

/-!
# Physical correction packets from retained occurrence schedules

An occurrence-aware retained-transversal schedule proves the global retained
recipe-product law.  The physical correction factory can therefore consume the
schedule directly.  This file records the scheduler-facing adapter and the
resulting adjacent-swap equation for the routed physical correction packet.

This file is intentionally not imported by the existing collection proof.
-/

noncomputable section

namespace Towers
namespace TCTex
namespace
  PCBounda

universe u

open
  CCThree
open
  UCFtry
open
  PTOcc
open
  PSPhysic
open CPSplita
open TAPkta

/--
An occurrence-aware retained schedule directly supplies the support-certified
physical correction presentation.
-/
noncomputable def
    physical_presentation_occurrence
    {d n lowerWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (schedule :
      COSched.{u} d n)
    (normalizers :
      WBForm.PositiveChooseNormalizer H)
    (left right : SPFactor H ι)
    (hleftSupported :
      lowerWeight ≤ left.word.weight HEAddres.weight)
    (hrightSupported :
      lowerWeight ≤ right.word.weight HEAddres.weight)
    (hleft : left.word.weight HEAddres.weight = 1)
    (hright : right.word.weight HEAddres.weight = 1) :
    SymbolicPhysicalPresentation
      schedule.satisfiesRecipeCoefficient
      normalizers left right hleftSupported hrightSupported hleft hright :=
  symbolicPhysicalPresentation
    schedule.satisfiesRecipeCoefficient
      normalizers left right hleftSupported hrightSupported hleft hright

/--
The routed physical correction packet supplied by an occurrence-aware
retained schedule performs its required adjacent swap.
-/
lemma
    physical_occurrence_schedule
    {d n lowerWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (schedule :
      COSched.{u} d n)
    (normalizers :
      WBForm.PositiveChooseNormalizer H)
    (left right : SPFactor H ι)
    (hleftSupported :
      lowerWeight ≤ left.word.weight HEAddres.weight)
    (hrightSupported :
      lowerWeight ≤ right.word.weight HEAddres.weight)
    (hleft : left.word.weight HEAddres.weight = 1)
    (hright : right.word.weight HEAddres.weight = 1)
    (e : ι → HEFam H) :
    SPFactor.listEval (n := n) e
          (((supportedPacketFactory
              (coefficientTruncatedPacket
                schedule.satisfiesRecipeCoefficient)
              normalizers lowerWeight).packet
                left right hleftSupported hrightSupported).factors) *
        right.eval (n := n) e * left.eval (n := n) e =
      left.eval (n := n) e * right.eval (n := n) e := by
  rw [←
    factors_physical_correction
      schedule.satisfiesRecipeCoefficient
        normalizers left right hleftSupported hrightSupported hleft hright e]
  exact
    recipe_occ_schedule
      (normalizers.normalizer ι) e schedule left right

end
  PCBounda
end TCTex
