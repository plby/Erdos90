/-!
# Universal recipe-free polynomial-orbit vocabulary

The universal inverse vocabulary was first stated using complete dependent
block recipes.  The operational recurrence now exists directly on polynomial
orbit keys, so the complete source-plus-correction inventory can also be
defined without dependent recipe labels.

This file proves that the recipe-free inventory is exactly the image of the
earlier recipe vocabulary and that every emitted key belongs to the retained
finite orbit closure.

This file is intentionally not imported by the existing collection proof.
-/

namespace Towers
namespace TCTex
namespace UOVocabu

open RRPkt
open
  RRPkt.POObstru
open ROSuppor
open ROAggreg
open ROTransi
open URVocabu

/-- Recipe-free source keys from the retained dummy raw trace. -/
noncomputable def sourceOrbitKeys
    (n leftWeight rightWeight : ℕ) :
    List POKey :=
  (sourceRecipes n leftWeight rightWeight).map polynomialOrbitKey

/--
Recipe-free operational corrections from one source-key pair, omitted once
the root pair reaches the cutoff.
-/
noncomputable def operationalOrbitKeys
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru) :
    List POKey :=
  if _hroot : O.weight leftWeight rightWeight < n then
    O.retainedKeys (n := n) hleftWeight hrightWeight
  else
    []

/-- All recipe-free operational corrections generated by source-key pairs. -/
noncomputable def operationalPolynomialKeys
    (n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight) :
    List POKey :=
  (sourceOrbitKeys n leftWeight rightWeight).flatMap fun left =>
    (sourceOrbitKeys n leftWeight rightWeight).flatMap fun right =>
      operationalOrbitKeys (n := n)
        hleftWeight hrightWeight {
          left := left
          right := right
        }

/-- Universal recipe-free source-and-operational polynomial-orbit inventory. -/
noncomputable def polynomialOrbitKeys
    (n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight) :
    List POKey :=
  sourceOrbitKeys n leftWeight rightWeight ++
    operationalPolynomialKeys n leftWeight rightWeight
      hleftWeight hrightWeight

/-- Mapping one recipe-rooted correction packet gives the recipe-free packet. -/
lemma key_operational_recipes
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : BRPkt.RObstru) :
    (operationalRecipes (n := n)
      hleftWeight hrightWeight O).map polynomialOrbitKey =
        operationalOrbitKeys (n := n)
          hleftWeight hrightWeight (polynomialOrbitObstruction O) := by
  unfold operationalRecipes operationalOrbitKeys
  by_cases hroot : O.weight leftWeight rightWeight < n
  · have horbit :
        (polynomialOrbitObstruction O).weight leftWeight rightWeight < n := by
      simpa using hroot
    rw [dif_pos hroot, dif_pos horbit]
    exact retained_orbit_keys
      hleftWeight hrightWeight O
  · have horbit :
        ¬(polynomialOrbitObstruction O).weight leftWeight rightWeight < n := by
      simpa using hroot
    rw [dif_neg hroot, dif_neg horbit, List.map_nil]

/-- Mapping all recipe-level operational corrections gives the recipe-free inventory. -/
lemma key_correction_recipes
    (n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight) :
    (operationalCorrectionRecipes n leftWeight rightWeight
      hleftWeight hrightWeight).map polynomialOrbitKey =
        operationalPolynomialKeys n leftWeight rightWeight
          hleftWeight hrightWeight := by
  unfold operationalCorrectionRecipes operationalPolynomialKeys
  unfold sourceOrbitKeys sourceRecipes
  rw [List.map_flatMap, List.map_map, List.flatMap_map]
  apply List.flatMap_congr
  intro left _hleft
  rw [List.map_flatMap, List.flatMap_map]
  apply List.flatMap_congr
  intro right _hright
  exact
    key_operational_recipes
      hleftWeight hrightWeight {
        left := left.blockRecipe
        right := right.blockRecipe
      }

/-- Mapping the complete recipe vocabulary gives the complete recipe-free vocabulary. -/
lemma polynomial_orbit_recipes
    (n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight) :
    (recipes n leftWeight rightWeight hleftWeight hrightWeight).map
        polynomialOrbitKey =
      polynomialOrbitKeys n leftWeight rightWeight
        hleftWeight hrightWeight := by
  unfold recipes polynomialOrbitKeys sourceOrbitKeys
  rw [List.map_append,
    key_correction_recipes]

/--
Every recipe-free source or operational key belongs to the retained finite
polynomial-orbit closure.
-/
lemma retained_vocabulary_keys
    {n leftWeight rightWeight : ℕ}
    {hleftWeight : 0 < leftWeight}
    {hrightWeight : 0 < rightWeight}
    {key : POKey}
    (hkey :
      key ∈ polynomialOrbitKeys n leftWeight rightWeight
        hleftWeight hrightWeight) :
    key ∈ retainedOrbitVocabulary n leftWeight rightWeight := by
  rw [← polynomial_orbit_recipes
    n leftWeight rightWeight hleftWeight hrightWeight] at hkey
  rcases List.mem_map.mp hkey with ⟨recipe, hrecipe, rfl⟩
  exact
    orbit_key_recipes
      hrecipe

end UOVocabu
end TCTex
end Towers

/-!
# Recipe-free polynomial-orbit envelopes for arbitrary raw packets

The universal raw-packet envelope chooses cutoff-vocabulary representatives
for arbitrary retained source occurrences and attaches every local
operational correction packet.  This file performs the same construction
directly with polynomial orbit keys.

The resulting envelope is still deliberately conservative: it is a finite
support envelope, not a noncommutative collection schedule.  Its order is
nevertheless exact, and its ordered key evaluation agrees with the earlier
recipe envelope without any factor permutation.

This file is intentionally not imported by the existing collection proof.
-/

namespace Towers
namespace TCTex
namespace OREnvelo

open ROEvalua
open RRPkt
open ROSuppor
open ROAggreg
open ROTransi
open BRSpec
open UOVocabu
open RPEnvelo

/-- Recipe-free chosen source packet for arbitrary retained raw occurrences. -/
noncomputable def universalOrbitPacket
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight) :
    List POKey :=
  (rawHistoriesAttached M N n leftWeight rightWeight).map
    fun history =>
      polynomialOrbitKey
        (universalRawHistory
          hleftWeight hrightWeight history).blockRecipe

/-- Erasing recipe labels in the chosen source packet is exact. -/
lemma key_universal_packet
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight) :
    (universalSourcePacket
      M N n leftWeight rightWeight hleftWeight hrightWeight).map
        polynomialOrbitKey =
      universalOrbitPacket
        M N n leftWeight rightWeight hleftWeight hrightWeight := by
  unfold universalSourcePacket universalOrbitPacket
  rw [List.map_map]
  rfl

/-- Recipe-free chosen obstruction for one arbitrary retained source pair. -/
noncomputable def universalOrbitObstruction
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : RetainedRawHistory M N n leftWeight rightWeight) :
    POObstru where
  left :=
    polynomialOrbitKey
      (universalRawHistory
        hleftWeight hrightWeight left).blockRecipe
  right :=
    polynomialOrbitKey
      (universalRawHistory
        hleftWeight hrightWeight right).blockRecipe

/-- The direct key obstruction is exactly the erased recipe obstruction. -/
lemma universal_polynomial_obstruction
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : RetainedRawHistory M N n leftWeight rightWeight) :
    universalOrbitObstruction hleftWeight hrightWeight left right =
      polynomialOrbitObstruction
        (universalObstruction hleftWeight hrightWeight left right) :=
  rfl

/-- Recipe-free operational correction packet for one retained source pair. -/
noncomputable def universalOperationalPacket
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : RetainedRawHistory M N n leftWeight rightWeight) :
    List POKey :=
  operationalOrbitKeys (n := n) hleftWeight hrightWeight
    (universalOrbitObstruction hleftWeight hrightWeight left right)

/-- Erasing recipe labels in one chosen correction packet is exact. -/
lemma key_universal_operational
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : RetainedRawHistory M N n leftWeight rightWeight) :
    (universalOperationalCorrection
      hleftWeight hrightWeight left right).map polynomialOrbitKey =
        universalOperationalPacket
          hleftWeight hrightWeight left right := by
  unfold universalOperationalCorrection
  unfold universalOperationalPacket
  rw [key_operational_recipes]
  rfl

/-- Recipe-free correction envelope over every retained source occurrence pair. -/
noncomputable def universalOrbitEnvelope
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight) :
    List POKey :=
  (rawHistoriesAttached M N n leftWeight rightWeight).flatMap
    fun left =>
      (rawHistoriesAttached M N n leftWeight rightWeight).flatMap
        fun right =>
          universalOperationalPacket
            hleftWeight hrightWeight left right

/-- Erasing recipe labels in the chosen correction envelope is exact. -/
lemma key_operational_envelope
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight) :
    (universalCorrectionEnvelope
      M N n leftWeight rightWeight hleftWeight hrightWeight).map
        polynomialOrbitKey =
      universalOrbitEnvelope
        M N n leftWeight rightWeight hleftWeight hrightWeight := by
  unfold universalCorrectionEnvelope
  unfold universalOrbitEnvelope
  rw [List.map_flatMap]
  apply List.flatMap_congr
  intro left _hleft
  rw [List.map_flatMap]
  apply List.flatMap_congr
  intro right _hright
  exact
    key_universal_operational
      hleftWeight hrightWeight left right

/-- Complete recipe-free source-and-correction envelope. -/
noncomputable def universalPolynomialEnvelope
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight) :
    List POKey :=
  universalOrbitPacket
      M N n leftWeight rightWeight hleftWeight hrightWeight ++
    universalOrbitEnvelope
      M N n leftWeight rightWeight hleftWeight hrightWeight

/-- Erasing recipe labels in the complete chosen envelope is exact. -/
lemma orbit_key_envelope
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight) :
    (universalPacketEnvelope
      M N n leftWeight rightWeight hleftWeight hrightWeight).map
        polynomialOrbitKey =
      universalPolynomialEnvelope
        M N n leftWeight rightWeight hleftWeight hrightWeight := by
  unfold universalPacketEnvelope universalPolynomialEnvelope
  rw [List.map_append,
    key_universal_packet,
    key_operational_envelope]

/-- Every chosen envelope key belongs to the universal recipe-free inventory. -/
lemma keys_universal_envelope
    {M N n leftWeight rightWeight : ℕ}
    {hleftWeight : 0 < leftWeight}
    {hrightWeight : 0 < rightWeight}
    {key : POKey}
    (hkey :
      key ∈ universalPolynomialEnvelope
        M N n leftWeight rightWeight hleftWeight hrightWeight) :
    key ∈ polynomialOrbitKeys n leftWeight rightWeight
      hleftWeight hrightWeight := by
  rw [← orbit_key_envelope
    M N n leftWeight rightWeight hleftWeight hrightWeight] at hkey
  rcases List.mem_map.mp hkey with ⟨recipe, hrecipe, rfl⟩
  rw [← polynomial_orbit_recipes
    n leftWeight rightWeight hleftWeight hrightWeight]
  exact List.mem_map.mpr
    ⟨recipe,
      recipes_universal_envelope
        hleftWeight hrightWeight hrecipe,
      rfl⟩

/-- Every chosen envelope key belongs to the retained finite orbit closure. -/
lemma
    vocabulary_universal_envelope
    {M N n leftWeight rightWeight : ℕ}
    {hleftWeight : 0 < leftWeight}
    {hrightWeight : 0 < rightWeight}
    {key : POKey}
    (hkey :
      key ∈ universalPolynomialEnvelope
        M N n leftWeight rightWeight hleftWeight hrightWeight) :
    key ∈ retainedOrbitVocabulary n leftWeight rightWeight :=
  retained_vocabulary_keys
    (keys_universal_envelope hkey)

/-- Evaluate an ordered list of recipe-free polynomial orbit keys. -/
def listEvalKeys
    {G : Type*}
    [Group G]
    (keys : List POKey)
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    G :=
  (keys.map fun key =>
    orbitFactorValue key
      left right leftExponent rightExponent).prod

/-- Erasing recipe labels preserves ordered evaluation exactly. -/
lemma keys_orbit_key
    {G : Type*}
    [Group G]
    (recipes : List HACoeff.BRecipe)
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    listEvalKeys (recipes.map polynomialOrbitKey)
        left right leftExponent rightExponent =
      (recipes.map fun recipe =>
        recipe.erasedShape.eval (HPAtom.eval left right) ^
          BRSpec.coefficientValue
            recipe leftExponent rightExponent).prod := by
  unfold listEvalKeys
  rw [List.map_map]
  rfl

/--
The complete recipe-free arbitrary-multiplicity envelope has exactly the
ordered evaluation of the earlier recipe envelope.
-/
lemma keys_envelope_recipe
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {G : Type*}
    [Group G]
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    listEvalKeys
        (universalPolynomialEnvelope
          M N n leftWeight rightWeight hleftWeight hrightWeight)
        left right leftExponent rightExponent =
      ((universalPacketEnvelope
        M N n leftWeight rightWeight hleftWeight hrightWeight).map
          fun recipe =>
            recipe.erasedShape.eval (HPAtom.eval left right) ^
              BRSpec.coefficientValue
                recipe leftExponent rightExponent).prod := by
  rw [← orbit_key_envelope
    M N n leftWeight rightWeight hleftWeight hrightWeight]
  exact
    keys_orbit_key
      (universalPacketEnvelope
        M N n leftWeight rightWeight hleftWeight hrightWeight)
      left right leftExponent rightExponent

end OREnvelo
end TCTex
end Towers

/-!
# Signed-block packets for arbitrary polynomial-orbit raw envelopes

The arbitrary-multiplicity raw envelope has an exact recipe-free presentation
as an ordered list of polynomial orbit keys.  Every occurrence is supported
in the retained finite orbit vocabulary.  This file chooses one retained
closure recipe representative for each supported key and attaches its
singleton positive signed-profile packet.

The construction deliberately preserves every occurrence and its order.  It
does not aggregate equal keys or permute noncommuting factors.  Its output is
an ordered cutoff-supported signed-block packet whose evaluation is exactly
the earlier recipe-envelope evaluation.

This file is intentionally not imported by the existing collection proof.
-/

namespace Towers
namespace TCTex
namespace UREnvelo

open HACoeff
open ROEvalua
open ROAggreg
open RFPacket
open ROTransi
open BRSpec
open
  CFSubsti
open
  UCAdapt
open
  UCSuppor
open UCVocabu
open OREnvelo
open RPEnvelo

/-- A polynomial orbit key supported by the retained finite correction closure. -/
abbrev RetainedOrbitKey
    (n leftWeight rightWeight : ℕ) :=
  { key : POKey //
    key ∈ retainedOrbitVocabulary n leftWeight rightWeight }

/-- Retained orbit support is the same as membership in the recipe-orbit
vocabulary of the retained concrete closure. -/
lemma orbit_vocabulary_retained
    {n leftWeight rightWeight : ℕ}
    {key : POKey}
    (hkey :
      key ∈ retainedOrbitVocabulary n leftWeight rightWeight) :
    key ∈ polynomialOrbitVocabulary
      (correctionClosureRecipes n leftWeight rightWeight) := by
  rw [← retained_orbit_vocabulary]
  exact hkey

/-- Choose one retained closure recipe representative of a supported orbit key. -/
noncomputable def recipeOrbitKey
    {n leftWeight rightWeight : ℕ}
    (key : RetainedOrbitKey n leftWeight rightWeight) :
    BRecipe :=
  recipePolynomialOrbit
    (correctionClosureRecipes n leftWeight rightWeight)
    ⟨key.1,
      orbit_vocabulary_retained
        key.2⟩

/-- The selected retained recipe belongs to the requested orbit chunk. -/
lemma recipe_orbit_key
    {n leftWeight rightWeight : ℕ}
    (key : RetainedOrbitKey n leftWeight rightWeight) :
    recipeOrbitKey key ∈
      recipesPolynomialOrbit
        (correctionClosureRecipes n leftWeight rightWeight)
        key.1 :=
  recipe_polynomial_orbit
    (correctionClosureRecipes n leftWeight rightWeight)
    ⟨key.1,
      orbit_vocabulary_retained
        key.2⟩

/-- The selected retained recipe has exactly the requested orbit key. -/
lemma key_recipe_retained
    {n leftWeight rightWeight : ℕ}
    (key : RetainedOrbitKey n leftWeight rightWeight) :
    polynomialOrbitKey (recipeOrbitKey key) = key.1 :=
  polynomial_key_recipes
    (recipe_orbit_key key)

/-- The selected retained recipe has the orbit key's erased Hall word. -/
lemma erased_shape_key
    {n leftWeight rightWeight : ℕ}
    (key : RetainedOrbitKey n leftWeight rightWeight) :
    (recipeOrbitKey key).erasedShape =
      key.1.erasedShape := by
  exact congrArg POKey.erasedShape
    (key_recipe_retained key)

/-- The selected retained recipe has the orbit key's coefficient value. -/
lemma coefficient_orbit_key
    {n leftWeight rightWeight : ℕ}
    (key : RetainedOrbitKey n leftWeight rightWeight)
    (leftExponent rightExponent : ℤ) :
    coefficientValue (recipeOrbitKey key)
        leftExponent rightExponent =
      orbitCoefficientValue key.1
        leftExponent rightExponent := by
  rw [← coefficient_value_key,
    key_recipe_retained]

/-- Attach one singleton positive signed-profile packet to a supported key. -/
noncomputable def retainedOrbitPacket
    {n leftWeight rightWeight : ℕ}
    (key : RetainedOrbitKey n leftWeight rightWeight) :
    RFPkt :=
  recollectionFormulaRecipe
    (recipeOrbitKey key)

@[simp]
lemma orbit_block_packet
    {n leftWeight rightWeight : ℕ}
    (key : RetainedOrbitKey n leftWeight rightWeight) :
    (retainedOrbitPacket key).word =
      key.1.erasedShape := by
  rw [retainedOrbitPacket,
    recollection_formula_recipe,
    erased_shape_key]

@[simp]
lemma profiles_block_packet
    {n leftWeight rightWeight : ℕ}
    (key : RetainedOrbitKey n leftWeight rightWeight)
    (leftExponent rightExponent : ℤ) :
    (retainedOrbitPacket key).profiles.value
        leftExponent rightExponent =
      orbitCoefficientValue key.1
        leftExponent rightExponent := by
  rw [retainedOrbitPacket,
    value_profiles_recipe,
    coefficient_orbit_key]

/-- One selected singleton signed-profile packet evaluates as its orbit key. -/
@[simp]
lemma factor_block_packet
    {n leftWeight rightWeight : ℕ}
    (key : RetainedOrbitKey n leftWeight rightWeight)
    {G : Type*}
    [Group G]
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    (retainedOrbitPacket key).word.eval
          (HPAtom.eval left right) ^
        (retainedOrbitPacket key).profiles.value
          leftExponent rightExponent =
      orbitFactorValue key.1
        left right leftExponent rightExponent := by
  rw [profiles_block_packet,
    orbit_block_packet]
  rfl

/-- The selected singleton packet is supported by the retained erased-word
vocabulary. -/
lemma erased_vocabulary_packet
    {n leftWeight rightWeight : ℕ}
    (key : RetainedOrbitKey n leftWeight rightWeight) :
    (retainedOrbitPacket key).word ∈
      erasedShapeVocabulary n leftWeight rightWeight := by
  rw [retainedOrbitPacket,
    recollection_formula_recipe]
  apply shape_vocabulary_recipes
  exact recipes_polynomial_orbit
    (recipe_orbit_key key)

/-- Attach singleton retained representatives to an ordered supported key list. -/
noncomputable def retainedBlockPackets
    {n leftWeight rightWeight : ℕ} :
    (keys : List POKey) →
      (∀ key ∈ keys,
        key ∈ retainedOrbitVocabulary n leftWeight rightWeight) →
        List RFPkt
  | [], _ =>
      []
  | key :: keys, hsupport =>
      retainedOrbitPacket
          ⟨key, hsupport key (by simp)⟩ ::
        retainedBlockPackets keys
          (fun next hnext => hsupport next (by simp [hnext]))

/-- Attaching singleton retained representatives preserves ordered evaluation. -/
lemma list_block_packets
    {n leftWeight rightWeight : ℕ}
    (keys : List POKey)
    (hsupport :
      ∀ key ∈ keys,
        key ∈ retainedOrbitVocabulary n leftWeight rightWeight)
    {G : Type*}
    [Group G]
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    ((retainedBlockPackets keys hsupport).map fun packet =>
      packet.word.eval (HPAtom.eval left right) ^
        packet.profiles.value leftExponent rightExponent).prod =
      listEvalKeys keys left right leftExponent rightExponent := by
  induction keys with
  | nil =>
      rfl
  | cons key keys ih =>
      unfold retainedBlockPackets
      unfold listEvalKeys
      simp only [List.map_cons, List.prod_cons]
      rw [factor_block_packet]
      simpa only using congrArg
        (fun tail =>
          orbitFactorValue key
              left right leftExponent rightExponent * tail)
        (ih (fun next hnext => hsupport next (by simp [hnext])))

/-- Every selected packet in an ordered supported key list remains supported
in the retained erased-word vocabulary. -/
lemma
    shape_vocabulary_packets
    {n leftWeight rightWeight : ℕ}
    (keys : List POKey)
    (hsupport :
      ∀ key ∈ keys,
        key ∈ retainedOrbitVocabulary n leftWeight rightWeight) :
    ∀ {packet : RFPkt},
      packet ∈ retainedBlockPackets keys hsupport →
        packet.word ∈ erasedShapeVocabulary n leftWeight rightWeight := by
  induction keys with
  | nil =>
      intro packet hpacket
      simp [retainedBlockPackets] at hpacket
  | cons key keys ih =>
      intro packet hpacket
      rw [retainedBlockPackets] at hpacket
      rcases List.mem_cons.mp hpacket with hpacket | hpacket
      · subst packet
        exact
          erased_vocabulary_packet
            ⟨key, hsupport key (by simp)⟩
      · exact ih
          (fun next hnext => hsupport next (by simp [hnext]))
          hpacket

/-- Singleton signed-profile packets for the complete arbitrary-multiplicity
recipe-free raw envelope. -/
noncomputable def universalEnvelopePackets
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight) :
    List RFPkt :=
  retainedBlockPackets
    (universalPolynomialEnvelope
      M N n leftWeight rightWeight hleftWeight hrightWeight)
    (fun _key hkey =>
      vocabulary_universal_envelope
        hkey)

/-- The arbitrary-multiplicity signed-profile envelope has exactly the ordered
evaluation of the earlier recipe envelope. -/
lemma
    universal_envelope_packets
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {G : Type*}
    [Group G]
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    ((universalEnvelopePackets
      M N n leftWeight rightWeight hleftWeight hrightWeight).map fun packet =>
        packet.word.eval (HPAtom.eval left right) ^
          packet.profiles.value leftExponent rightExponent).prod =
      ((universalPacketEnvelope
        M N n leftWeight rightWeight hleftWeight hrightWeight).map fun recipe =>
          recipe.erasedShape.eval (HPAtom.eval left right) ^
            coefficientValue recipe leftExponent rightExponent).prod := by
  rw [universalEnvelopePackets,
    list_block_packets]
  exact
    keys_envelope_recipe
      hleftWeight hrightWeight left right leftExponent rightExponent

/-- The arbitrary-multiplicity signed-profile envelope is pointwise supported
by the retained erased-word vocabulary. -/
lemma
    vocabulary_envelope_packets
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {packet : RFPkt}
    (hpacket :
      packet ∈ universalEnvelopePackets
        M N n leftWeight rightWeight hleftWeight hrightWeight) :
    packet.word ∈ erasedShapeVocabulary n leftWeight rightWeight := by
  apply
    shape_vocabulary_packets
      (universalPolynomialEnvelope
        M N n leftWeight rightWeight hleftWeight hrightWeight)
      (fun _key hkey =>
        vocabulary_universal_envelope
          hkey)
  exact hpacket

/-- The complete arbitrary-multiplicity orbit envelope as one ordered
cutoff-supported signed-block packet. -/
noncomputable def
    universalEnvelopeBlock
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight) :
    OBPkt n leftWeight rightWeight where
  leftWeight_pos :=
    hleftWeight
  rightWeight_pos :=
    hrightWeight
  packets :=
    universalEnvelopePackets
      M N n leftWeight rightWeight hleftWeight hrightWeight
  word_erased_vocabulary _packet hpacket :=
    vocabulary_envelope_packets
      hleftWeight hrightWeight hpacket

@[simp]
lemma packets_universal_envelope
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight) :
    (universalEnvelopeBlock
      M N n leftWeight rightWeight hleftWeight hrightWeight).packets =
        universalEnvelopePackets
          M N n leftWeight rightWeight hleftWeight hrightWeight :=
  rfl

end UREnvelo
end TCTex
end Towers

/-!
# Symbolic Hall factors for arbitrary polynomial-orbit raw envelopes

The arbitrary-multiplicity orbit envelope now has an ordered cutoff-supported
signed-block presentation.  This file substitutes arbitrary symbolic parent
factors into that packet list.  The resulting symbolic Hall polynomial factor
list evaluates exactly as the earlier recipe envelope, and every generated
factor is already physically below cutoff when the symbolic parents have the
declared weights.

The factor list retains the complete operational order.  No polynomial-orbit
deduplication or noncommutative regrouping occurs here.

This file is intentionally not imported by the existing collection proof.
-/

namespace Towers
namespace TCTex
namespace RSEnvelo

universe u

open HACoeff
open BRSpec
open
  CCTrunc
open
  CFExp
open
  CFSubsti
open
  UCSuppor
open
  UREnvelo
open RPEnvelo

/-- Substitute arbitrary symbolic parent factors into the complete
arbitrary-multiplicity orbit envelope. -/
noncomputable def universalEnvelopeFactors
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : SPFactor H ι) :
    List (SPFactor H ι) :=
  symbolicFactors normalizer
    (universalEnvelopePackets
      M N n leftWeight rightWeight hleftWeight hrightWeight)
    left right

/-- Evaluating the symbolic orbit envelope gives the earlier ordered recipe
envelope at the symbolic parents' values. -/
lemma envelope_symbolic_recipe
    {d truncation : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : SPFactor H ι) :
    SPFactor.listEval (n := truncation) e
        (universalEnvelopeFactors
          normalizer M N n leftWeight rightWeight
            hleftWeight hrightWeight left right) =
      ((universalPacketEnvelope
        M N n leftWeight rightWeight hleftWeight hrightWeight).map fun recipe =>
          recipe.erasedShape.eval
              (HPAtom.eval
                (left.wordValue (n := truncation))
                (right.wordValue (n := truncation))) ^
            coefficientValue recipe
              (left.coefficient.eval e) (right.coefficient.eval e)).prod := by
  unfold universalEnvelopeFactors
  rw [
    CFExp.listSymbolicFactors]
  exact
    universal_envelope_packets
      hleftWeight hrightWeight
      (left.wordValue (n := truncation))
      (right.wordValue (n := truncation))
      (left.coefficient.eval e) (right.coefficient.eval e)

/-- At symbolic parents of the declared weights, every generated orbit-envelope
factor is already strictly below cutoff. -/
lemma universal_envelope_factors
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right factor : SPFactor H ι)
    (hleft :
      left.word.weight HEAddres.weight = leftWeight)
    (hright :
      right.word.weight HEAddres.weight = rightWeight)
    (hfactor :
      factor ∈
        universalEnvelopeFactors
          normalizer M N n leftWeight rightWeight
            hleftWeight hrightWeight left right) :
    factor.word.weight HEAddres.weight < n := by
  unfold universalEnvelopeFactors at hfactor
  rcases packet_symbolic_factors hfactor with
    ⟨packet, hpacket, rfl⟩
  rw [packet.word_symbolicFactor, packet.weight_boundWord, hleft, hright]
  simpa [packetWeight, HPAtom.weight] using
    OBPkt.packet_weight_cutoff
      (universalEnvelopeBlock
        M N n leftWeight rightWeight hleftWeight hrightWeight)
      hpacket

/-- Physical cutoff truncation removes no symbolic factor from the complete
arbitrary-multiplicity orbit envelope. -/
@[simp]
lemma truncate_envelope_self
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : SPFactor H ι)
    (hleft :
      left.word.weight HEAddres.weight = leftWeight)
    (hright :
      right.word.weight HEAddres.weight = rightWeight) :
    SPFactor.truncate n
        (universalEnvelopeFactors
          normalizer M N n leftWeight rightWeight
            hleftWeight hrightWeight left right) =
      universalEnvelopeFactors
        normalizer M N n leftWeight rightWeight
          hleftWeight hrightWeight left right := by
  apply List.filter_eq_self.2
  intro factor hfactor
  simpa only [decide_eq_true_eq] using
    universal_envelope_factors
      normalizer hleftWeight hrightWeight left right factor
        hleft hright hfactor

end RSEnvelo
end TCTex
end Towers

/-!
# Concrete comparison for arbitrary polynomial-orbit raw envelopes

The universal raw envelope replaces arbitrary retained raw occurrences by
cutoff-vocabulary representatives.  Its recipe list is pointwise
polynomial-equivalent to the corresponding concrete recipe envelope.  This
file records the arbitrary-group ordered evaluation consequence and composes
it with the recipe-free signed-block and symbolic-factor adapters.

The concrete envelope is still deliberately conservative.  These theorems
compare two order-preserving envelope presentations; they do not identify the
envelope with a genuine noncommutative collection schedule.

This file is intentionally not imported by the existing collection proof.
-/

namespace Towers
namespace TCTex
namespace RCCompar

universe u

open HACoeff
open RPEquiv
open BRSpec
open
  UREnvelo
open RSEnvelo
open RPEnvelo

/-- Pointwise polynomial-equivalent recipe lists have the same ordered
arbitrary-group evaluation. -/
lemma recipe_factors_forall₂_polynomialEquivalent
    {leftRecipes rightRecipes : List BRecipe}
    (h :
      List.Forall₂
        RPEquiv.BRecipe.PolynomialEquivalent
        leftRecipes rightRecipes)
    {G : Type*}
    [Group G]
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    (leftRecipes.map fun recipe =>
      recipe.erasedShape.eval (HPAtom.eval left right) ^
        coefficientValue recipe leftExponent rightExponent).prod =
      (rightRecipes.map fun recipe =>
        recipe.erasedShape.eval (HPAtom.eval left right) ^
          coefficientValue recipe leftExponent rightExponent).prod := by
  induction h with
  | nil =>
      rfl
  | cons hrecipe _ ih =>
      simp only [List.map_cons, List.prod_cons]
      rw [hrecipe.2.2,
        RPEquiv.BRecipe.coeff_poly_equivalent
          hrecipe,
        ih]

/-- Universal replacement preserves the arbitrary-group ordered evaluation of
the complete concrete source-and-correction envelope. -/
lemma universal_envelope_concrete
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {G : Type*}
    [Group G]
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    ((universalPacketEnvelope
      M N n leftWeight rightWeight hleftWeight hrightWeight).map fun recipe =>
        recipe.erasedShape.eval (HPAtom.eval left right) ^
          coefficientValue recipe leftExponent rightExponent).prod =
      ((concretePacketEnvelope
        M N n leftWeight rightWeight hleftWeight hrightWeight).map fun recipe =>
          recipe.erasedShape.eval (HPAtom.eval left right) ^
            coefficientValue recipe leftExponent rightExponent).prod :=
  recipe_factors_forall₂_polynomialEquivalent
    (packet_envelope_forall₂
      M N n leftWeight rightWeight hleftWeight hrightWeight)
    left right leftExponent rightExponent

/-- The signed-profile orbit envelope has exactly the ordered arbitrary-group
evaluation of the concrete recipe envelope. -/
lemma
    envelope_packets_recipe
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {G : Type*}
    [Group G]
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    ((universalEnvelopePackets
      M N n leftWeight rightWeight hleftWeight hrightWeight).map fun packet =>
        packet.word.eval (HPAtom.eval left right) ^
          packet.profiles.value leftExponent rightExponent).prod =
      ((concretePacketEnvelope
        M N n leftWeight rightWeight hleftWeight hrightWeight).map fun recipe =>
          recipe.erasedShape.eval (HPAtom.eval left right) ^
            coefficientValue recipe leftExponent rightExponent).prod := by
  rw [
    universal_envelope_packets,
    universal_envelope_concrete]

/-- Evaluating the symbolic orbit envelope gives the concrete ordered recipe
envelope at the symbolic parents' values. -/
lemma
    universal_envelope_recipe
    {d truncation : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : SPFactor H ι) :
    SPFactor.listEval (n := truncation) e
        (universalEnvelopeFactors
          normalizer M N n leftWeight rightWeight
            hleftWeight hrightWeight left right) =
      ((concretePacketEnvelope
        M N n leftWeight rightWeight hleftWeight hrightWeight).map fun recipe =>
          recipe.erasedShape.eval
              (HPAtom.eval
                (left.wordValue (n := truncation))
                (right.wordValue (n := truncation))) ^
            coefficientValue recipe
              (left.coefficient.eval e) (right.coefficient.eval e)).prod := by
  rw [
    envelope_symbolic_recipe,
    universal_envelope_concrete]

end RCCompar
end TCTex
end Towers

/-!
# Finite symbolic vocabulary for arbitrary polynomial-orbit raw envelopes

The retained polynomial-orbit vocabulary is finite and multiplicity
independent.  Each supported key has a canonical retained singleton
signed-profile packet.  This file packages those packets as one fixed
cutoff-sized dictionary and proves that every arbitrary-multiplicity raw
envelope draws its ordered packet occurrences and symbolic factors pointwise
from that dictionary.

The dictionary is deduplicated at the orbit-key level.  Local envelopes may
repeat dictionary entries and retain their complete operational order.

This file is intentionally not imported by the existing collection proof.
-/

namespace Towers
namespace TCTex
namespace OSVocab

universe u

open ROAggreg
open ROTransi
open
  CCTrunc
open
  CFExp
open
  CFSubsti
open
  UCSuppor
open
  UREnvelo
open OREnvelo
open RSEnvelo

/-- Fixed singleton signed-profile dictionary indexed by the retained finite
polynomial-orbit vocabulary. -/
noncomputable def blockPacketVocabulary
    (n leftWeight rightWeight : ℕ) :
    List RFPkt :=
  (retainedOrbitVocabulary n leftWeight rightWeight).attach.map
    retainedOrbitPacket

@[simp]
lemma length_packet_vocabulary
    (n leftWeight rightWeight : ℕ) :
    (blockPacketVocabulary
      n leftWeight rightWeight).length =
        (retainedOrbitVocabulary n leftWeight rightWeight).length := by
  simp [blockPacketVocabulary]

/-- The canonical packet of every retained orbit key occurs in the fixed
singleton dictionary. -/
lemma retained_packet_vocabulary
    {n leftWeight rightWeight : ℕ}
    (key : RetainedOrbitKey n leftWeight rightWeight) :
    retainedOrbitPacket key ∈
      blockPacketVocabulary
        n leftWeight rightWeight := by
  unfold blockPacketVocabulary
  exact List.mem_map.mpr ⟨key, by simp, rfl⟩

/-- Every packet occurrence selected from a supported orbit-key list belongs
to the fixed singleton dictionary. -/
lemma
    retained_poly_packets
    {n leftWeight rightWeight : ℕ}
    (keys : List POKey)
    (hsupport :
      ∀ key ∈ keys,
        key ∈ retainedOrbitVocabulary n leftWeight rightWeight) :
    ∀ {packet : RFPkt},
      packet ∈ retainedBlockPackets keys hsupport →
        packet ∈ blockPacketVocabulary
          n leftWeight rightWeight := by
  induction keys with
  | nil =>
      intro packet hpacket
      simp [retainedBlockPackets] at hpacket
  | cons key keys ih =>
      intro packet hpacket
      rw [retainedBlockPackets] at hpacket
      rcases List.mem_cons.mp hpacket with hpacket | hpacket
      · subst packet
        exact retained_packet_vocabulary
          ⟨key, hsupport key (by simp)⟩
      · exact ih
          (fun next hnext => hsupport next (by simp [hnext]))
          hpacket

/-- Every packet occurrence in an arbitrary-multiplicity orbit envelope
belongs to the fixed singleton dictionary. -/
lemma
    poly_envelope_packets
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {packet : RFPkt}
    (hpacket :
      packet ∈ universalEnvelopePackets
        M N n leftWeight rightWeight hleftWeight hrightWeight) :
    packet ∈ blockPacketVocabulary
      n leftWeight rightWeight := by
  apply
    retained_poly_packets
      (universalPolynomialEnvelope
        M N n leftWeight rightWeight hleftWeight hrightWeight)
      (fun _key hkey =>
        vocabulary_universal_envelope
          hkey)
  exact hpacket

/-- The fixed singleton dictionary is itself an ordered cutoff-supported
packet.  Its order is dictionary order, not a semantic collection schedule. -/
noncomputable def
    retainedVocabularyCutoff
    (n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight) :
    OBPkt n leftWeight rightWeight where
  leftWeight_pos :=
    hleftWeight
  rightWeight_pos :=
    hrightWeight
  packets :=
    blockPacketVocabulary
      n leftWeight rightWeight
  word_erased_vocabulary packet hpacket := by
    rcases List.mem_map.mp hpacket with ⟨key, _hkey, rfl⟩
    exact
      erased_vocabulary_packet
        key

/-- Fixed symbolic factor dictionary obtained by substituting two arbitrary
symbolic parents into the retained singleton packet vocabulary. -/
noncomputable def retainedPolyVocab
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (n leftWeight rightWeight : ℕ)
    (left right : SPFactor H ι) :
    List (SPFactor H ι) :=
  symbolicFactors normalizer
    (blockPacketVocabulary
      n leftWeight rightWeight)
    left right

/-- Every symbolic factor emitted by an arbitrary-multiplicity orbit envelope
belongs to the fixed substituted symbolic-factor dictionary. -/
lemma
    polyEnvelopeVocab
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : SPFactor H ι) :
    universalEnvelopeFactors
        normalizer M N n leftWeight rightWeight
          hleftWeight hrightWeight left right ⊆
      retainedPolyVocab
        normalizer n leftWeight rightWeight left right := by
  intro factor hfactor
  unfold universalEnvelopeFactors at hfactor
  rcases packet_symbolic_factors hfactor with
    ⟨packet, hpacket, rfl⟩
  unfold retainedPolyVocab
  exact List.mem_map.mpr
    ⟨packet,
      poly_envelope_packets
        hleftWeight hrightWeight hpacket,
      rfl⟩

/-- At symbolic parents of the declared weights, every factor in the fixed
symbolic dictionary is strictly below cutoff. -/
lemma orbit_symbolic_vocabulary
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right factor : SPFactor H ι)
    (hleft :
      left.word.weight HEAddres.weight = leftWeight)
    (hright :
      right.word.weight HEAddres.weight = rightWeight)
    (hfactor :
      factor ∈ retainedPolyVocab
        normalizer n leftWeight rightWeight left right) :
    factor.word.weight HEAddres.weight < n := by
  unfold retainedPolyVocab at hfactor
  rcases packet_symbolic_factors hfactor with
    ⟨packet, hpacket, rfl⟩
  rw [packet.word_symbolicFactor, packet.weight_boundWord, hleft, hright]
  simpa [packetWeight, HPAtom.weight] using
    OBPkt.packet_weight_cutoff
      (retainedVocabularyCutoff
        n leftWeight rightWeight hleftWeight hrightWeight)
      hpacket

/-- Physical cutoff truncation removes no factor from the fixed substituted
symbolic-factor dictionary. -/
@[simp]
lemma truncate_vocabulary_self
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : SPFactor H ι)
    (hleft :
      left.word.weight HEAddres.weight = leftWeight)
    (hright :
      right.word.weight HEAddres.weight = rightWeight) :
    SPFactor.truncate n
        (retainedPolyVocab
          normalizer n leftWeight rightWeight left right) =
      retainedPolyVocab
        normalizer n leftWeight rightWeight left right := by
  apply List.filter_eq_self.2
  intro factor hfactor
  simpa only [decide_eq_true_eq] using
    orbit_symbolic_vocabulary
      normalizer hleftWeight hrightWeight left right factor
        hleft hright hfactor

end OSVocab
end TCTex
end Towers

/-!
# Finite index traces for arbitrary polynomial-orbit raw envelopes

The retained polynomial-orbit vocabulary is a finite ordered list.  This file
uses its `Fin` index type to encode every arbitrary-multiplicity orbit
envelope as an ordered index trace.  Mapping the finite dictionary back over
that trace recovers the orbit keys, singleton signed-profile packets, and
symbolic Hall polynomial factors exactly.

The trace may repeat indices.  It preserves operational order and does not
claim stabilization of multiplicity-dependent traces.

This file is intentionally not imported by the existing collection proof.
-/

namespace Towers
namespace TCTex
namespace RITrace

universe u

open ROAggreg
open ROTransi
open
  CFExp
open
  CFSubsti
open
  UREnvelo
open RCCompar
open OREnvelo
open RSEnvelo
open OSVocab

/-- Finite ordered index type for the retained polynomial-orbit vocabulary. -/
abbrev RetainedOrbitIndex
    (n leftWeight rightWeight : ℕ) :=
  Fin (retainedOrbitVocabulary n leftWeight rightWeight).length

/-- Retained polynomial-orbit key represented by one finite vocabulary index. -/
noncomputable def retainedOrbitKey
    {n leftWeight rightWeight : ℕ}
    (index : RetainedOrbitIndex n leftWeight rightWeight) :
    POKey :=
  (retainedOrbitVocabulary n leftWeight rightWeight).get index

/-- Every indexed key belongs to the retained polynomial-orbit vocabulary. -/
lemma retained_orbit_key
    {n leftWeight rightWeight : ℕ}
    (index : RetainedOrbitIndex n leftWeight rightWeight) :
    retainedOrbitKey index ∈
      retainedOrbitVocabulary n leftWeight rightWeight :=
  List.get_mem _ index

/-- Choose a finite vocabulary index representing one retained orbit key. -/
noncomputable def indexOrbitKey
    {n leftWeight rightWeight : ℕ}
    (key : RetainedOrbitKey n leftWeight rightWeight) :
    RetainedOrbitIndex n leftWeight rightWeight :=
  Classical.choose (List.get_of_mem key.2)

/-- Looking up the selected finite index recovers its retained orbit key. -/
@[simp]
lemma orbit_key_index
    {n leftWeight rightWeight : ℕ}
    (key : RetainedOrbitKey n leftWeight rightWeight) :
    retainedOrbitKey
        (indexOrbitKey key) =
      key.1 :=
  Classical.choose_spec (List.get_of_mem key.2)

/-- Encode an ordered supported orbit-key list by finite vocabulary indices. -/
noncomputable def orbitIndexTrace
    {n leftWeight rightWeight : ℕ} :
    (keys : List POKey) →
      (∀ key ∈ keys,
        key ∈ retainedOrbitVocabulary n leftWeight rightWeight) →
        List (RetainedOrbitIndex n leftWeight rightWeight)
  | [], _ =>
      []
  | key :: keys, hsupport =>
      indexOrbitKey
          ⟨key, hsupport key (by simp)⟩ ::
        orbitIndexTrace keys
          (fun next hnext => hsupport next (by simp [hnext]))

/-- Mapping indexed keys over an encoded trace recovers the ordered key list. -/
lemma retained_key_trace
    {n leftWeight rightWeight : ℕ}
    (keys : List POKey)
    (hsupport :
      ∀ key ∈ keys,
        key ∈ retainedOrbitVocabulary n leftWeight rightWeight) :
    (orbitIndexTrace keys hsupport).map
        retainedOrbitKey =
      keys := by
  induction keys with
  | nil =>
      rfl
  | cons key keys ih =>
      unfold orbitIndexTrace
      simp only [List.map_cons,
        orbit_key_index]
      exact congrArg (List.cons key)
        (ih (fun next hnext => hsupport next (by simp [hnext])))

/-- Finite index trace of the complete arbitrary-multiplicity orbit envelope. -/
noncomputable def universalEnvelopeTrace
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight) :
    List (RetainedOrbitIndex n leftWeight rightWeight) :=
  orbitIndexTrace
    (universalPolynomialEnvelope
      M N n leftWeight rightWeight hleftWeight hrightWeight)
    (fun _key hkey =>
      vocabulary_universal_envelope
        hkey)

/-- Decoding the arbitrary-multiplicity finite trace recovers its ordered orbit
envelope exactly. -/
lemma
    key_universal_envelope
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight) :
    (universalEnvelopeTrace
      M N n leftWeight rightWeight hleftWeight hrightWeight).map
        retainedOrbitKey =
      universalPolynomialEnvelope
        M N n leftWeight rightWeight hleftWeight hrightWeight :=
  retained_key_trace
    (universalPolynomialEnvelope
      M N n leftWeight rightWeight hleftWeight hrightWeight)
    (fun _key hkey =>
      vocabulary_universal_envelope
        hkey)

/-- Singleton retained signed-profile packet represented by one finite orbit
index. -/
noncomputable def orbitBlockPacket
    {n leftWeight rightWeight : ℕ}
    (index : RetainedOrbitIndex n leftWeight rightWeight) :
    RFPkt :=
  retainedOrbitPacket
    ⟨retainedOrbitKey index,
      retained_orbit_key index⟩

/-- Looking up the selected index packet recovers the canonical packet of its
retained orbit key. -/
@[simp]
lemma retained_index_key
    {n leftWeight rightWeight : ℕ}
    (key : RetainedOrbitKey n leftWeight rightWeight) :
    orbitBlockPacket
        (indexOrbitKey key) =
      retainedOrbitPacket key := by
  apply congrArg retainedOrbitPacket
  apply Subtype.ext
  exact orbit_key_index key

/-- Decoding a finite trace into singleton signed-profile packets recovers the
ordered supported packet list exactly. -/
lemma retained_index_trace
    {n leftWeight rightWeight : ℕ}
    (keys : List POKey)
    (hsupport :
      ∀ key ∈ keys,
        key ∈ retainedOrbitVocabulary n leftWeight rightWeight) :
    (orbitIndexTrace keys hsupport).map
        orbitBlockPacket =
      retainedBlockPackets keys hsupport := by
  induction keys with
  | nil =>
      rfl
  | cons key keys ih =>
      unfold orbitIndexTrace
      unfold retainedBlockPackets
      simp only [List.map_cons,
        retained_index_key]
      exact congrArg
        (List.cons
          (retainedOrbitPacket
            ⟨key, hsupport key (by simp)⟩))
        (ih (fun next hnext => hsupport next (by simp [hnext])))

/-- Decoding the arbitrary-multiplicity trace into singleton signed-profile
packets recovers its ordered packet envelope exactly. -/
lemma
    polyEnvelopeIdx
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight) :
    (universalEnvelopeTrace
      M N n leftWeight rightWeight hleftWeight hrightWeight).map
        orbitBlockPacket =
      universalEnvelopePackets
        M N n leftWeight rightWeight hleftWeight hrightWeight :=
  retained_index_trace
    (universalPolynomialEnvelope
      M N n leftWeight rightWeight hleftWeight hrightWeight)
    (fun _key hkey =>
      vocabulary_universal_envelope
        hkey)

/-- Symbolic Hall polynomial factor represented by one finite orbit index. -/
noncomputable def orbitSymbolicFactor
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n leftWeight rightWeight : ℕ}
    (left right : SPFactor H ι)
    (index : RetainedOrbitIndex n leftWeight rightWeight) :
    SPFactor H ι :=
  (orbitBlockPacket index).symbolicFactor
    normalizer left right

/-- Decoding the arbitrary-multiplicity finite trace into symbolic factors
recovers its ordered symbolic envelope exactly. -/
lemma
    universal_packet_envelope
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : SPFactor H ι) :
    (universalEnvelopeTrace
      M N n leftWeight rightWeight hleftWeight hrightWeight).map
        (orbitSymbolicFactor normalizer left right) =
      universalEnvelopeFactors
        normalizer M N n leftWeight rightWeight
          hleftWeight hrightWeight left right := by
  unfold orbitSymbolicFactor
  unfold universalEnvelopeFactors
  unfold symbolicFactors
  simpa only [List.map_map, Function.comp_apply] using
    congrArg
      (List.map fun packet => packet.symbolicFactor normalizer left right)
      (polyEnvelopeIdx
        M N n leftWeight rightWeight hleftWeight hrightWeight)

/-- The finite-index symbolic trace evaluates exactly as the concrete
arbitrary-multiplicity recipe envelope. -/
lemma
    list_recipe_envelope
    {d truncation : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : SPFactor H ι) :
    SPFactor.listEval (n := truncation) e
        ((universalEnvelopeTrace
          M N n leftWeight rightWeight hleftWeight hrightWeight).map
            (orbitSymbolicFactor
              normalizer left right)) =
      ((RPEnvelo.concretePacketEnvelope
        M N n leftWeight rightWeight hleftWeight hrightWeight).map fun recipe =>
          recipe.erasedShape.eval
              (HPAtom.eval
                (left.wordValue (n := truncation))
                (right.wordValue (n := truncation))) ^
            BRSpec.coefficientValue recipe
              (left.coefficient.eval e) (right.coefficient.eval e)).prod := by
  rw [
    universal_packet_envelope,
    universal_envelope_recipe]

end RITrace
end TCTex
end Towers

/-!
# Recursive finite-index traces for polynomial-orbit raw packets

The retained polynomial-orbit alphabet is finite, and arbitrary raw envelopes
already have exact ordered traces over its `Fin` index type.  This file
records the recursive structure hidden inside those traces.

Finite encoding preserves concatenation literally.  Hence one local
operational orbit packet can be encoded as its leading correction followed by
the two surviving recursive branch traces, in the same order as the original
Hall-Petresco recursion.

No aggregation, permutation, or semantic scheduling claim is made here.
This file is intentionally not imported by the existing collection proof.
-/

namespace Towers
namespace TCTex
namespace RIRecurs

open RRPkt
open
  RRPkt.POObstru
open ROAggreg
open ROTransi
open RITrace

/-- Finite encoding preserves ordered concatenation literally. -/
lemma orbit_index_append
    {n leftWeight rightWeight : ℕ}
    (left right : List POKey)
    (hsupport :
      ∀ key ∈ left ++ right,
        key ∈ retainedOrbitVocabulary n leftWeight rightWeight) :
    orbitIndexTrace (left ++ right) hsupport =
      orbitIndexTrace left
          (fun key hkey =>
            hsupport key (List.mem_append_left right hkey)) ++
        orbitIndexTrace right
          (fun key hkey =>
            hsupport key (List.mem_append_right left hkey)) := by
  induction left with
  | nil =>
      rfl
  | cons key left ih =>
      simp only [List.cons_append, orbitIndexTrace]
      exact congrArg (List.cons _) (ih _)

/-- Finite encoding exposes its head index and ordered tail trace. -/
lemma orbit_index_cons
    {n leftWeight rightWeight : ℕ}
    (key : POKey)
    (keys : List POKey)
    (hsupport :
      ∀ next ∈ key :: keys,
        next ∈ retainedOrbitVocabulary n leftWeight rightWeight) :
    orbitIndexTrace (key :: keys) hsupport =
      indexOrbitKey
          ⟨key, hsupport key (by simp)⟩ ::
        orbitIndexTrace keys
          (fun next hnext => hsupport next (by simp [hnext])) := by
  rfl

/-- Finite encoding depends only on the supported key list, not on the proof
used to establish support. -/
lemma orbit_index_congr
    {n leftWeight rightWeight : ℕ}
    {left right : List POKey}
    (hkeys : left = right)
    (hleft :
      ∀ key ∈ left,
        key ∈ retainedOrbitVocabulary n leftWeight rightWeight)
    (hright :
      ∀ key ∈ right,
        key ∈ retainedOrbitVocabulary n leftWeight rightWeight) :
    orbitIndexTrace left hleft =
      orbitIndexTrace right hright := by
  subst right
  rfl

/-- Pointwise support needed to encode one recipe-free operational packet. -/
def IsSupported
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru) :
    Prop :=
  ∀ key ∈ O.retainedKeys (n := n) hleftWeight hrightWeight,
    key ∈ retainedOrbitVocabulary n leftWeight rightWeight

/-- Encode one supported recipe-free operational packet by finite alphabet
indices. -/
noncomputable def retainedIndexTrace
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru)
    (hsupport : IsSupported (n := n) hleftWeight hrightWeight O) :
    List (RetainedOrbitIndex n leftWeight rightWeight) :=
  orbitIndexTrace
    (O.retainedKeys (n := n) hleftWeight hrightWeight)
    hsupport

/-- Decoding one supported operational finite trace recovers its ordered
recipe-free key packet exactly. -/
lemma key_retained_trace
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru)
    (hsupport : IsSupported (n := n) hleftWeight hrightWeight O) :
    (retainedIndexTrace (n := n) hleftWeight hrightWeight O hsupport).map
        retainedOrbitKey =
      O.retainedKeys (n := n) hleftWeight hrightWeight :=
  retained_key_trace
    (O.retainedKeys (n := n) hleftWeight hrightWeight)
    hsupport

/-- The root correction of a supported packet belongs to the retained finite
alphabet. -/
lemma correction_supported
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru)
    (hsupport : IsSupported (n := n) hleftWeight hrightWeight O) :
    O.correction ∈
      retainedOrbitVocabulary n leftWeight rightWeight := by
  apply hsupport
  rw [O.keys_cons_append hleftWeight hrightWeight]
  simp

/-- A surviving left branch of a supported packet remains supported. -/
lemma operational_left_supported
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru)
    (hsupport : IsSupported (n := n) hleftWeight hrightWeight O)
    (hleft :
      O.operationalNestedLeft.weight leftWeight rightWeight < n) :
    IsSupported (n := n) hleftWeight hrightWeight
      O.operationalNestedLeft := by
  intro key hkey
  apply hsupport
  rw [O.keys_cons_append hleftWeight hrightWeight]
  rw [dif_pos hleft]
  exact List.mem_cons_of_mem _
    (List.mem_append_left _ hkey)

/-- A surviving right branch of a supported packet remains supported. -/
lemma operational_nested_supported
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru)
    (hsupport : IsSupported (n := n) hleftWeight hrightWeight O)
    (hright :
      O.operationalNestedRight.weight leftWeight rightWeight < n) :
    IsSupported (n := n) hleftWeight hrightWeight
      O.operationalNestedRight := by
  intro key hkey
  apply hsupport
  rw [O.keys_cons_append hleftWeight hrightWeight]
  apply List.mem_cons_of_mem
  apply List.mem_append_right
  rw [dif_pos hright]
  exact hkey

/-- One supported local operational trace is the root index followed by the
two surviving recursive branch traces. -/
lemma retained_cons_append
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru)
    (hsupport : IsSupported (n := n) hleftWeight hrightWeight O) :
    retainedIndexTrace (n := n) hleftWeight hrightWeight O hsupport =
      indexOrbitKey
          ⟨O.correction,
            correction_supported
              hleftWeight hrightWeight O hsupport⟩ ::
        (if hleft :
            O.operationalNestedLeft.weight leftWeight rightWeight < n then
          retainedIndexTrace (n := n)
            hleftWeight hrightWeight O.operationalNestedLeft
            (operational_left_supported
              hleftWeight hrightWeight O hsupport hleft)
        else []) ++
        (if hright :
            O.operationalNestedRight.weight leftWeight rightWeight < n then
          retainedIndexTrace (n := n)
            hleftWeight hrightWeight O.operationalNestedRight
            (operational_nested_supported
              hleftWeight hrightWeight O hsupport hright)
        else []) := by
  let leftKeys :=
    if _hleft :
        O.operationalNestedLeft.weight leftWeight rightWeight < n then
      O.operationalNestedLeft.retainedKeys
        (n := n) hleftWeight hrightWeight
    else []
  let rightKeys :=
    if _hright :
        O.operationalNestedRight.weight leftWeight rightWeight < n then
      O.operationalNestedRight.retainedKeys
        (n := n) hleftWeight hrightWeight
    else []
  have hkeys :
      O.retainedKeys (n := n) hleftWeight hrightWeight =
        O.correction :: leftKeys ++ rightKeys := by
    simpa only [leftKeys, rightKeys] using
      O.keys_cons_append hleftWeight hrightWeight
  have hcombined :
      ∀ key ∈ O.correction :: leftKeys ++ rightKeys,
        key ∈ retainedOrbitVocabulary
          n leftWeight rightWeight := by
    intro key hkey
    apply hsupport key
    rw [hkeys]
    exact hkey
  calc
    retainedIndexTrace (n := n) hleftWeight hrightWeight O hsupport =
        orbitIndexTrace
          (O.correction :: leftKeys ++ rightKeys) hcombined := by
      unfold retainedIndexTrace
      exact
        orbit_index_congr hkeys hsupport hcombined
    _ =
        indexOrbitKey
            ⟨O.correction, hcombined O.correction (by simp)⟩ ::
          orbitIndexTrace leftKeys
              (fun key hkey =>
                hcombined key
                  (List.mem_cons_of_mem _
                    (List.mem_append_left _ hkey))) ++
            orbitIndexTrace rightKeys
              (fun key hkey =>
                hcombined key
                  (List.mem_cons_of_mem _
                    (List.mem_append_right _ hkey))) := by
      rw [orbit_index_append]
      rw [orbit_index_cons]
    _ = _ := by
      dsimp only [leftKeys, rightKeys]
      by_cases hleft :
          O.operationalNestedLeft.weight leftWeight rightWeight < n
      · simp only [dif_pos hleft]
        by_cases hright :
            O.operationalNestedRight.weight leftWeight rightWeight < n
        · simp only [dif_pos hright, retainedIndexTrace]
        · simp only [dif_neg hright, retainedIndexTrace,
            orbitIndexTrace, List.append_nil]
      · simp only [dif_neg hleft, retainedIndexTrace,
          orbitIndexTrace]
        by_cases hright :
            O.operationalNestedRight.weight leftWeight rightWeight < n
        · simp only [dif_pos hright]
        · simp only [dif_neg hright, orbitIndexTrace]

end RIRecurs
end TCTex
end Towers

/-!
# Global finite-index decomposition of polynomial-orbit raw envelopes

Finite orbit-index encoding preserves concatenation and local operational
recursion.  This file lifts the complete arbitrary-multiplicity conservative
raw envelope into the same algebra:

* the global trace is the source trace followed by the correction trace;
* the correction trace is the retained-history pairwise `flatMap` of local
  operational finite traces.

All equalities preserve the original list order literally.  The conservative
envelope is still not asserted to be a semantic collection schedule.

This file is intentionally not imported by the existing collection proof.
-/

namespace Towers
namespace TCTex
namespace IEDecomp

open ROAggreg
open ROTransi
open OREnvelo
open RITrace
open
  RIRecurs
open RPEnvelo

/-- Encoding a supported `flatMap` is the ordered `flatMap` of its local
finite-index traces. -/
lemma orbit_index_flat
    {alpha : Type}
    {n leftWeight rightWeight : ℕ}
    (items : List alpha)
    (packets : alpha → List POKey)
    (hpacketSupport :
      ∀ item key, key ∈ packets item →
        key ∈ retainedOrbitVocabulary n leftWeight rightWeight) :
    orbitIndexTrace (items.flatMap packets)
        (fun key hkey => by
          rcases List.mem_flatMap.mp hkey with ⟨item, _hitem, hkey⟩
          exact hpacketSupport item key hkey) =
      items.flatMap fun item =>
        orbitIndexTrace (packets item)
          (hpacketSupport item) := by
  induction items with
  | nil =>
      rfl
  | cons item items ih =>
      simp only [List.flatMap_cons]
      rw [orbit_index_append]
      exact congrArg₂ (· ++ ·) rfl ih

/-- Every chosen source-key occurrence belongs to the retained finite orbit
alphabet. -/
lemma
    vocabulary_universal_packet
    {M N n leftWeight rightWeight : ℕ}
    {hleftWeight : 0 < leftWeight}
    {hrightWeight : 0 < rightWeight}
    {key : POKey}
    (hkey :
      key ∈ universalOrbitPacket
        M N n leftWeight rightWeight hleftWeight hrightWeight) :
    key ∈ retainedOrbitVocabulary n leftWeight rightWeight := by
  apply
    vocabulary_universal_envelope
  exact List.mem_append_left _ hkey

/-- Every chosen correction-key occurrence belongs to the retained finite
orbit alphabet. -/
lemma
    vocabulary_operational_envelope
    {M N n leftWeight rightWeight : ℕ}
    {hleftWeight : 0 < leftWeight}
    {hrightWeight : 0 < rightWeight}
    {key : POKey}
    (hkey :
      key ∈ universalOrbitEnvelope
        M N n leftWeight rightWeight hleftWeight hrightWeight) :
    key ∈ retainedOrbitVocabulary n leftWeight rightWeight := by
  apply
    vocabulary_universal_envelope
  exact List.mem_append_right _ hkey

/-- Every local chosen correction packet for a retained-history pair belongs
pointwise to the retained finite orbit alphabet. -/
lemma
    vocabulary_universal_operational
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : RetainedRawHistory M N n leftWeight rightWeight)
    {key : POKey}
    (hkey :
      key ∈ universalOperationalPacket
        hleftWeight hrightWeight left right) :
    key ∈ retainedOrbitVocabulary n leftWeight rightWeight := by
  refine
    vocabulary_operational_envelope
      (M := M) (N := N)
      (hleftWeight := hleftWeight) (hrightWeight := hrightWeight)
      ?_
  exact List.mem_flatMap.mpr
    ⟨left, List.mem_attach _ left,
      List.mem_flatMap.mpr
        ⟨right, List.mem_attach _ right, hkey⟩⟩

/-- Every key in one retained-history row of local correction packets belongs
to the retained finite orbit alphabet. -/
lemma
    vocabulary_universal_row
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left : RetainedRawHistory M N n leftWeight rightWeight)
    {key : POKey}
    (hkey :
      key ∈
        (rawHistoriesAttached M N n leftWeight rightWeight).flatMap
          fun right =>
            universalOperationalPacket
              hleftWeight hrightWeight left right) :
    key ∈ retainedOrbitVocabulary n leftWeight rightWeight := by
  rcases List.mem_flatMap.mp hkey with ⟨right, _hright, hkey⟩
  exact
    vocabulary_universal_operational
      hleftWeight hrightWeight left right hkey

/-- Finite-index trace of the chosen source packet. -/
noncomputable def universalIndexTrace
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight) :
    List (RetainedOrbitIndex n leftWeight rightWeight) :=
  orbitIndexTrace
    (universalOrbitPacket
      M N n leftWeight rightWeight hleftWeight hrightWeight)
    (fun _key hkey =>
      vocabulary_universal_packet
        hkey)

/-- Finite-index trace of one retained-history-pair correction packet. -/
noncomputable def universalOperationalTrace
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : RetainedRawHistory M N n leftWeight rightWeight) :
    List (RetainedOrbitIndex n leftWeight rightWeight) :=
  orbitIndexTrace
    (universalOperationalPacket
      hleftWeight hrightWeight left right)
    (fun _key hkey =>
      vocabulary_universal_operational
        hleftWeight hrightWeight left right hkey)

/-- Finite-index trace of the complete retained-history-pair correction
envelope. -/
noncomputable def universalOperationalEnvelope
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight) :
    List (RetainedOrbitIndex n leftWeight rightWeight) :=
  orbitIndexTrace
    (universalOrbitEnvelope
      M N n leftWeight rightWeight hleftWeight hrightWeight)
    (fun _key hkey =>
      vocabulary_operational_envelope
        hkey)

/-- The complete arbitrary-multiplicity finite trace is its source trace
followed by its correction-envelope trace. -/
lemma universal_envelope_corrections
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight) :
    universalEnvelopeTrace
        M N n leftWeight rightWeight hleftWeight hrightWeight =
      universalIndexTrace
          M N n leftWeight rightWeight hleftWeight hrightWeight ++
        universalOperationalEnvelope
          M N n leftWeight rightWeight hleftWeight hrightWeight := by
  unfold universalEnvelopeTrace
  unfold universalPolynomialEnvelope
  unfold universalIndexTrace
  unfold universalOperationalEnvelope
  rw [orbit_index_append]

/-- The correction-envelope finite trace is exactly the retained-history
pairwise `flatMap` of local correction traces. -/
lemma
    universal_envelope_pairwise
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight) :
    universalOperationalEnvelope
        M N n leftWeight rightWeight hleftWeight hrightWeight =
      (rawHistoriesAttached M N n leftWeight rightWeight).flatMap
        fun left =>
          (rawHistoriesAttached M N n leftWeight rightWeight).flatMap
            fun right =>
              universalOperationalTrace
                hleftWeight hrightWeight left right := by
  unfold universalOperationalEnvelope
  unfold universalOrbitEnvelope
  rw [orbit_index_flat _ _
    (fun left key hkey =>
      vocabulary_universal_row
        hleftWeight hrightWeight left hkey)]
  apply List.flatMap_congr
  intro left _hleft
  rw [orbit_index_flat _ _
    (fun right key hkey =>
      vocabulary_universal_operational
        hleftWeight hrightWeight left right hkey)]
  apply List.flatMap_congr
  intro right _hright
  rfl

/-- The complete arbitrary-multiplicity finite trace is its source trace
followed by the pairwise `flatMap` of local operational correction traces. -/
lemma
    universal_pairwise_flat
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight) :
    universalEnvelopeTrace
        M N n leftWeight rightWeight hleftWeight hrightWeight =
      universalIndexTrace
          M N n leftWeight rightWeight hleftWeight hrightWeight ++
        (rawHistoriesAttached M N n leftWeight rightWeight).flatMap
          fun left =>
            (rawHistoriesAttached M N n leftWeight rightWeight).flatMap
              fun right =>
                universalOperationalTrace
                  hleftWeight hrightWeight left right := by
  rw [
    universal_envelope_corrections,
    universal_envelope_pairwise]

end IEDecomp
end TCTex
end Towers

/-!
# Ordered signed-block packets for finite polynomial-orbit index traces

The retained polynomial-orbit alphabet is a finite support dictionary.
An operational trace may revisit dictionary entries, so its signed-block
presentation must preserve the complete index list rather than deduplicate it.

This file packages every finite index trace as an ordered cutoff-supported
signed-block packet.  For traces emitted by one supported recursive orbit
obstruction, its ordered packet evaluation is exactly the recipe-free
operational evaluator.

No aggregation or noncommutative factor permutation is used.
This file is intentionally not imported by the existing collection proof.
-/

namespace Towers
namespace TCTex
namespace
  POSigned

open RREvalua
open
  CFSubsti
open
  UCSuppor
open
  RITrace
open
  RIRecurs
open
  UREnvelo
open RPEnvelo

/-- Decode a finite orbit-index trace into its ordered singleton signed-block
packet occurrences. -/
noncomputable def indexBlockPackets
    {n leftWeight rightWeight : ℕ}
    (trace :
      List (RetainedOrbitIndex n leftWeight rightWeight)) :
    List RFPkt :=
  trace.map orbitBlockPacket

/-- Every packet decoded from a finite orbit-index trace belongs to the
retained erased-word support dictionary. -/
lemma vocabulary_block_packets
    {n leftWeight rightWeight : ℕ}
    (trace :
      List (RetainedOrbitIndex n leftWeight rightWeight))
    {packet : RFPkt}
    (hpacket : packet ∈ indexBlockPackets trace) :
    packet.word ∈ erasedShapeVocabulary n leftWeight rightWeight := by
  rcases List.mem_map.mp hpacket with ⟨index, _hindex, rfl⟩
  unfold orbitBlockPacket
  exact
    erased_vocabulary_packet
      ⟨retainedOrbitKey index,
        retained_orbit_key index⟩

/-- Every finite orbit-index trace is an ordered cutoff-supported signed-block
packet.  Repeated indices remain repeated packet occurrences. -/
noncomputable def indexBlockPacket
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (trace :
      List (RetainedOrbitIndex n leftWeight rightWeight)) :
    OBPkt n leftWeight rightWeight where
  leftWeight_pos :=
    hleftWeight
  rightWeight_pos :=
    hrightWeight
  packets :=
    indexBlockPackets trace
  word_erased_vocabulary _packet hpacket :=
    vocabulary_block_packets
      trace hpacket

@[simp]
lemma packets_signed_packet
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (trace :
      List (RetainedOrbitIndex n leftWeight rightWeight)) :
    (indexBlockPacket
      hleftWeight hrightWeight trace).packets =
        indexBlockPackets trace :=
  rfl

/-- Decode the finite trace emitted by one supported recursive orbit
obstruction into ordered signed-block occurrences. -/
noncomputable def retainedIndexPackets
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O :
      RRPkt.POObstru)
    (hsupport : IsSupported (n := n) hleftWeight hrightWeight O) :
    List RFPkt :=
  indexBlockPackets
    (retainedIndexTrace (n := n) hleftWeight hrightWeight O hsupport)

/-- Decoding a supported operational finite trace gives exactly the singleton
packet list attached to its ordered emitted orbit keys. -/
lemma block_packets_orbit
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O :
      RRPkt.POObstru)
    (hsupport : IsSupported (n := n) hleftWeight hrightWeight O) :
    retainedIndexPackets
        hleftWeight hrightWeight O hsupport =
      retainedBlockPackets
        (O.retainedKeys (n := n) hleftWeight hrightWeight)
        hsupport := by
  unfold retainedIndexPackets
  unfold indexBlockPackets
  unfold retainedIndexTrace
  exact
    retained_index_trace
      (O.retainedKeys (n := n) hleftWeight hrightWeight)
      hsupport

/-- The ordered signed-block occurrences decoded from one supported recursive
trace evaluate exactly as its recipe-free operational orbit evaluator. -/
lemma block_packets_operational
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O :
      RRPkt.POObstru)
    (hsupport : IsSupported (n := n) hleftWeight hrightWeight O)
    {G : Type*}
    [Group G]
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    ((retainedIndexPackets
      hleftWeight hrightWeight O hsupport).map fun packet =>
        packet.word.eval (HPAtom.eval left right) ^
          packet.profiles.value leftExponent rightExponent).prod =
      listEval (n := n) hleftWeight hrightWeight O
        left right leftExponent rightExponent := by
  rw [
    block_packets_orbit,
    list_block_packets]
  rfl

/-- One supported recursive orbit obstruction, retaining its complete emitted
order, as an ordered cutoff-supported signed-block packet. -/
noncomputable def retainedBlockPacket
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O :
      RRPkt.POObstru)
    (hsupport : IsSupported (n := n) hleftWeight hrightWeight O) :
    OBPkt n leftWeight rightWeight :=
  indexBlockPacket
    hleftWeight hrightWeight
    (retainedIndexTrace (n := n) hleftWeight hrightWeight O hsupport)

@[simp]
lemma packets_index_packet
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O :
      RRPkt.POObstru)
    (hsupport : IsSupported (n := n) hleftWeight hrightWeight O) :
    (retainedBlockPacket
      hleftWeight hrightWeight O hsupport).packets =
        retainedIndexPackets
          hleftWeight hrightWeight O hsupport :=
  rfl

end
  POSigned
end TCTex
end Towers

/-!
# Generic symbolic programs for finite polynomial-orbit index traces

Every supported recipe-free operational obstruction has an ordered finite
index trace over the retained polynomial-orbit vocabulary.  This file decodes
that trace into symbolic Hall polynomial factors before specializing to a
particular raw-history grid.

The decoded program preserves the operational root-and-two-branches
recursion literally.  Its symbolic evaluation is exactly the recipe-free
operational orbit evaluation, and every emitted factor belongs to the fixed
cutoff-sized symbolic dictionary.

This file is intentionally not imported by the existing collection proof.
-/

namespace Towers
namespace TCTex
namespace
  RSProgra

universe u

open ROEvalua
open RREvalua
open RRPkt
open
  RRPkt.POObstru
open
  CFExp
open
  RITrace
open
  RIRecurs
open
  UREnvelo
open
  OSVocab

/-- Decode one supported operational finite trace into symbolic Hall factors. -/
noncomputable def retainedIdxFactors
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru)
    (hsupport : IsSupported (n := n) hleftWeight hrightWeight O)
    (left right : SPFactor H ι) :
    List (SPFactor H ι) :=
  (retainedIndexTrace (n := n)
    hleftWeight hrightWeight O hsupport).map
      (orbitSymbolicFactor normalizer left right)

/-- Root symbolic Hall factor emitted by one supported operational trace. -/
noncomputable def retainedSymbolicFactor
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru)
    (hsupport : IsSupported (n := n) hleftWeight hrightWeight O)
    (left right : SPFactor H ι) :
    SPFactor H ι :=
  orbitSymbolicFactor normalizer left right
    (indexOrbitKey
      ⟨O.correction,
        correction_supported
          hleftWeight hrightWeight O hsupport⟩)

/-- Symbolic factors decoded from a surviving left recursive branch. -/
noncomputable def retainedNestedFactors
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru)
    (hsupport : IsSupported (n := n) hleftWeight hrightWeight O)
    (left right : SPFactor H ι) :
    List (SPFactor H ι) :=
  if hleft :
      O.operationalNestedLeft.weight leftWeight rightWeight < n then
    retainedIdxFactors normalizer
      hleftWeight hrightWeight O.operationalNestedLeft
      (operational_left_supported
        hleftWeight hrightWeight O hsupport hleft)
      left right
  else []

/-- Symbolic factors decoded from a surviving right recursive branch. -/
noncomputable def nestedSymbolicFactors
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru)
    (hsupport : IsSupported (n := n) hleftWeight hrightWeight O)
    (left right : SPFactor H ι) :
    List (SPFactor H ι) :=
  if hright :
      O.operationalNestedRight.weight leftWeight rightWeight < n then
    retainedIdxFactors normalizer
      hleftWeight hrightWeight O.operationalNestedRight
      (operational_nested_supported
        hleftWeight hrightWeight O hsupport hright)
      left right
  else []

/--
Decoding preserves the root-and-two-branches operational recursion literally.
-/
lemma factors_cons_append
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru)
    (hsupport : IsSupported (n := n) hleftWeight hrightWeight O)
    (left right : SPFactor H ι) :
    retainedIdxFactors normalizer
        hleftWeight hrightWeight O hsupport left right =
      retainedSymbolicFactor normalizer
          hleftWeight hrightWeight O hsupport left right ::
        retainedNestedFactors normalizer
            hleftWeight hrightWeight O hsupport left right ++
          nestedSymbolicFactors normalizer
            hleftWeight hrightWeight O hsupport left right := by
  unfold retainedIdxFactors
  rw [retained_cons_append]
  simp only [List.map_append, List.map_cons]
  unfold retainedSymbolicFactor
  unfold retainedNestedFactors
  unfold nestedSymbolicFactors
  split <;> split <;> rfl

/-- One decoded dictionary index evaluates as its recipe-free orbit key. -/
@[simp]
lemma eval_symbolic_factor
    {d truncation : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    {n leftWeight rightWeight : ℕ}
    (left right : SPFactor H ι)
    (index : RetainedOrbitIndex n leftWeight rightWeight) :
    (orbitSymbolicFactor
      normalizer left right index).eval (n := truncation) e =
        orbitFactorValue (retainedOrbitKey index)
          (left.wordValue (n := truncation))
          (right.wordValue (n := truncation))
          (left.coefficient.eval e) (right.coefficient.eval e) := by
  unfold orbitSymbolicFactor
  unfold orbitBlockPacket
  rw [eval_symbolicFactor]
  exact
    factor_block_packet
      ⟨retainedOrbitKey index,
        retained_orbit_key index⟩
      (left.wordValue (n := truncation))
      (right.wordValue (n := truncation))
      (left.coefficient.eval e) (right.coefficient.eval e)

/--
Evaluating a decoded finite trace is exactly the original recipe-free
operational orbit evaluation.
-/
lemma symbolic_factors_operational
    {d truncation : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru)
    (hsupport : IsSupported (n := n) hleftWeight hrightWeight O)
    (left right : SPFactor H ι) :
    SPFactor.listEval (n := truncation) e
        (retainedIdxFactors normalizer
          hleftWeight hrightWeight O hsupport left right) =
      RREvalua.listEval
        (n := n) hleftWeight hrightWeight O
        (left.wordValue (n := truncation))
        (right.wordValue (n := truncation))
        (left.coefficient.eval e) (right.coefficient.eval e) := by
  unfold retainedIdxFactors
  unfold SPFactor.listEval
  unfold
    RREvalua.listEval
  rw [← key_retained_trace
    hleftWeight hrightWeight O hsupport]
  rw [List.map_map, List.map_map]
  apply congrArg List.prod
  apply List.map_congr_left
  intro index _hindex
  simpa only [Function.comp_apply] using
    eval_symbolic_factor
      normalizer e left right index

/--
The symbolic evaluation exposes the same root orbit factor and ordered branch
evaluations as the recipe-free operational recurrence.
-/
lemma symbolic_factors_branches
    {d truncation : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru)
    (hsupport : IsSupported (n := n) hleftWeight hrightWeight O)
    (left right : SPFactor H ι) :
    SPFactor.listEval (n := truncation) e
        (retainedIdxFactors normalizer
          hleftWeight hrightWeight O hsupport left right) =
      orbitFactorValue O.correction
          (left.wordValue (n := truncation))
          (right.wordValue (n := truncation))
          (left.coefficient.eval e) (right.coefficient.eval e) *
        (((if _hleft :
              O.operationalNestedLeft.weight leftWeight rightWeight < n then
            O.operationalNestedLeft.retainedKeys
              (n := n) hleftWeight hrightWeight
          else []).map fun key =>
            orbitFactorValue key
              (left.wordValue (n := truncation))
              (right.wordValue (n := truncation))
              (left.coefficient.eval e) (right.coefficient.eval e)).prod *
          ((if _hright :
              O.operationalNestedRight.weight leftWeight rightWeight < n then
            O.operationalNestedRight.retainedKeys
              (n := n) hleftWeight hrightWeight
          else []).map fun key =>
            orbitFactorValue key
              (left.wordValue (n := truncation))
              (right.wordValue (n := truncation))
              (left.coefficient.eval e) (right.coefficient.eval e)).prod) := by
  rw [
    symbolic_factors_operational,
    list_root_branches]

/--
The same recursive evaluation equation can be read directly in the decoded
symbolic-factor language.
-/
lemma list_symbolic_branches
    {d truncation : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru)
    (hsupport : IsSupported (n := n) hleftWeight hrightWeight O)
    (left right : SPFactor H ι) :
    SPFactor.listEval (n := truncation) e
        (retainedIdxFactors normalizer
          hleftWeight hrightWeight O hsupport left right) =
      (retainedSymbolicFactor normalizer
        hleftWeight hrightWeight O hsupport left right).eval e *
        (SPFactor.listEval e
            (retainedNestedFactors normalizer
              hleftWeight hrightWeight O hsupport left right) *
          SPFactor.listEval e
            (nestedSymbolicFactors normalizer
              hleftWeight hrightWeight O hsupport left right)) := by
  rw [factors_cons_append,
    SPFactor.listEval_append,
    SPFactor.listEval_cons,
    mul_assoc]

/-- Every finite dictionary lookup belongs to the fixed symbolic vocabulary. -/
lemma retained_symbolic_vocabulary
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n leftWeight rightWeight : ℕ}
    (left right : SPFactor H ι)
    (index : RetainedOrbitIndex n leftWeight rightWeight) :
    orbitSymbolicFactor normalizer left right index ∈
      retainedPolyVocab
        normalizer n leftWeight rightWeight left right := by
  unfold orbitSymbolicFactor
  unfold retainedPolyVocab
  unfold symbolicFactors
  apply List.mem_map.mpr
  refine ⟨orbitBlockPacket index, ?_, rfl⟩
  unfold orbitBlockPacket
  exact
    retained_packet_vocabulary
      ⟨retainedOrbitKey index,
        retained_orbit_key index⟩

/-- Every factor emitted by a supported recursive trace belongs to the fixed
cutoff-sized symbolic vocabulary. -/
lemma symbolic_subset_vocabulary
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru)
    (hsupport : IsSupported (n := n) hleftWeight hrightWeight O)
    (left right : SPFactor H ι) :
    retainedIdxFactors normalizer
        hleftWeight hrightWeight O hsupport left right ⊆
      retainedPolyVocab
        normalizer n leftWeight rightWeight left right := by
  intro factor hfactor
  rcases List.mem_map.mp hfactor with ⟨index, _hindex, rfl⟩
  exact
    retained_symbolic_vocabulary
      normalizer left right index

/-- Every factor emitted by a supported recursive trace is physically below
the cutoff when the symbolic parents have their declared weights. -/
lemma index_symbolic_factors
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru)
    (hsupport : IsSupported (n := n) hleftWeight hrightWeight O)
    (left right factor : SPFactor H ι)
    (hleft :
      left.word.weight HEAddres.weight = leftWeight)
    (hright :
      right.word.weight HEAddres.weight = rightWeight)
    (hfactor :
      factor ∈ retainedIdxFactors normalizer
        hleftWeight hrightWeight O hsupport left right) :
    factor.word.weight HEAddres.weight < n := by
  exact
    orbit_symbolic_vocabulary
      normalizer hleftWeight hrightWeight left right factor hleft hright
      (symbolic_subset_vocabulary
        normalizer hleftWeight hrightWeight O hsupport left right hfactor)

/-- Physical cutoff truncation removes no factor from a supported recursive
symbolic trace. -/
@[simp]
lemma truncate_index_self
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru)
    (hsupport : IsSupported (n := n) hleftWeight hrightWeight O)
    (left right : SPFactor H ι)
    (hleft :
      left.word.weight HEAddres.weight = leftWeight)
    (hright :
      right.word.weight HEAddres.weight = rightWeight) :
    SPFactor.truncate n
        (retainedIdxFactors normalizer
          hleftWeight hrightWeight O hsupport left right) =
      retainedIdxFactors normalizer
        hleftWeight hrightWeight O hsupport left right := by
  apply List.filter_eq_self.2
  intro factor hfactor
  simpa only [decide_eq_true_eq] using
    index_symbolic_factors
      normalizer hleftWeight hrightWeight O hsupport left right factor
        hleft hright hfactor

end
  RSProgra
end TCTex
end Towers

/-!
# Local operational programs for finite polynomial-orbit index traces

The arbitrary-multiplicity global trace is a source trace followed by a
retained-history pair grid of local correction traces.  This file identifies
each local correction trace with the finite-state operational recursion:

* at or above the cutoff, the local trace is empty;
* below the cutoff, it is the root correction index followed by the two
  surviving recursive branch traces.

The result is still an exact ordered conservative-envelope statement.  It
does not reorder factors or identify the envelope with a semantic collection
schedule.

This file is intentionally not imported by the existing collection proof.
-/

namespace Towers
namespace TCTex
namespace
  ILProgra

open RRPkt
open
  RRPkt.POObstru
open ROTransi
open OREnvelo
open
  RITrace
open
  IEDecomp
open
  RIRecurs
open UOVocabu
open RPEnvelo

/-- Below cutoff, the recipe-free operational keys in one retained-history
pair are supported pointwise by the retained finite alphabet. -/
lemma universal_obstruction_supported
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : RetainedRawHistory M N n leftWeight rightWeight)
    (hroot :
      (universalOrbitObstruction
        hleftWeight hrightWeight left right).weight
          leftWeight rightWeight < n) :
    IsSupported (n := n) hleftWeight hrightWeight
      (universalOrbitObstruction
        hleftWeight hrightWeight left right) := by
  intro key hkey
  apply
    vocabulary_universal_operational
      hleftWeight hrightWeight left right
  unfold universalOperationalPacket
  unfold operationalOrbitKeys
  rw [dif_pos hroot]
  exact hkey

/-- Below cutoff, one local grid-cell trace is exactly the retained
finite-state operational trace rooted at its chosen orbit obstruction. -/
lemma universal_operational_weight
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : RetainedRawHistory M N n leftWeight rightWeight)
    (hroot :
      (universalOrbitObstruction
        hleftWeight hrightWeight left right).weight
          leftWeight rightWeight < n) :
    universalOperationalTrace
        hleftWeight hrightWeight left right =
      retainedIndexTrace (n := n) hleftWeight hrightWeight
        (universalOrbitObstruction
          hleftWeight hrightWeight left right)
        (universal_obstruction_supported
          hleftWeight hrightWeight left right hroot) := by
  unfold universalOperationalTrace
  unfold retainedIndexTrace
  apply orbit_index_congr
  unfold universalOperationalPacket
  unfold operationalOrbitKeys
  rw [dif_pos hroot]

/-- At or above cutoff, one local grid-cell trace emits no correction
indices. -/
lemma universal_nil_weight
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : RetainedRawHistory M N n leftWeight rightWeight)
    (hroot :
      ¬(universalOrbitObstruction
        hleftWeight hrightWeight left right).weight
          leftWeight rightWeight < n) :
    universalOperationalTrace
        hleftWeight hrightWeight left right =
      [] := by
  unfold universalOperationalTrace
  calc
    orbitIndexTrace
          (universalOperationalPacket
            hleftWeight hrightWeight left right) _ =
        orbitIndexTrace []
          (fun key hkey => by simp at hkey) := by
      apply orbit_index_congr
      unfold universalOperationalPacket
      unfold operationalOrbitKeys
      rw [dif_neg hroot]
    _ = [] := by
      rfl

/-- Below cutoff, one local grid-cell trace is its root index followed by the
two surviving recursive finite-state branch traces. -/
lemma universal_cons_append
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : RetainedRawHistory M N n leftWeight rightWeight)
    (hroot :
      (universalOrbitObstruction
        hleftWeight hrightWeight left right).weight
          leftWeight rightWeight < n) :
    universalOperationalTrace
        hleftWeight hrightWeight left right =
      let O :=
        universalOrbitObstruction
          hleftWeight hrightWeight left right
      let hsupport :=
        universal_obstruction_supported
          hleftWeight hrightWeight left right hroot
      indexOrbitKey
          ⟨O.correction,
            correction_supported
              hleftWeight hrightWeight O hsupport⟩ ::
        (if hleft :
            O.operationalNestedLeft.weight leftWeight rightWeight < n then
          retainedIndexTrace (n := n)
            hleftWeight hrightWeight O.operationalNestedLeft
            (operational_left_supported
              hleftWeight hrightWeight O hsupport hleft)
        else []) ++
        (if hright :
            O.operationalNestedRight.weight leftWeight rightWeight < n then
          retainedIndexTrace (n := n)
            hleftWeight hrightWeight O.operationalNestedRight
            (operational_nested_supported
              hleftWeight hrightWeight O hsupport hright)
        else []) := by
  rw [
    universal_operational_weight
      hleftWeight hrightWeight left right hroot]
  exact
    retained_cons_append
      hleftWeight hrightWeight
      (universalOrbitObstruction
        hleftWeight hrightWeight left right)
      (universal_obstruction_supported
        hleftWeight hrightWeight left right hroot)

end ILProgra
end TCTex
end Towers

/-!
# Ordered swap resolution for recursive polynomial-orbit traces

The recipe-free operational trace is ordered: it emits its root correction,
then the surviving left branch, then the surviving right branch.  This file
packages the local algebra theorem needed to interpret that ordered trace as a
complete adjacent swap.  A kernel constructor receives certificates for both
strictly smaller surviving branches.  Well-founded recursion on cutoff defect
then resolves every below-cutoff orbit obstruction.

Two adapters expose the resolved theorem in the decoded finite-index symbolic
language and in the original recipe language.  No commutative regrouping or
permutation of correction factors is used.

Constructing a kernel remains the local Hall collection theorem.

This file is intentionally not imported by the existing collection proof.
-/

noncomputable section

namespace Towers
namespace TCTex
namespace
  OSResolu

universe u

open ROEvalua
open RREvalua
open RRPkt
open
  RRPkt.POObstru
open BRPkt
open ROAggreg
open BRSpec
open
  RIRecurs
open
  RSProgra

/--
The ordered operational correction packet rooted at `O`, followed by the
swapped parent factors, evaluates as the original parent order.
-/
structure RSCerta
    {G : Type u}
    [Group G]
    (n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : G)
    (leftExponent rightExponent : ℤ)
    (O : POObstru)
    (hroot : O.weight leftWeight rightWeight < n) :
    Prop where
  eval_mul_swap :
    RREvalua.listEval
          (n := n) hleftWeight hrightWeight O
          left right leftExponent rightExponent *
        orbitFactorValue O.right
          left right leftExponent rightExponent *
      orbitFactorValue O.left
        left right leftExponent rightExponent =
      orbitFactorValue O.left
          left right leftExponent rightExponent *
        orbitFactorValue O.right
          left right leftExponent rightExponent

/--
Local Hall collection law for recipe-free operational traces.  A nonterminal
node may use the already-resolved swap laws of each surviving recursive
branch.
-/
structure RTSwap
    {G : Type u}
    [Group G]
    (n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    Prop where
  resolve_local :
    ∀ (O : POObstru)
      (hroot : O.weight leftWeight rightWeight < n),
      (∀ hleft :
          O.operationalNestedLeft.weight leftWeight rightWeight < n,
        RSCerta
          n leftWeight rightWeight hleftWeight hrightWeight
          left right leftExponent rightExponent
          O.operationalNestedLeft hleft) →
      (∀ hright :
          O.operationalNestedRight.weight leftWeight rightWeight < n,
        RSCerta
          n leftWeight rightWeight hleftWeight hrightWeight
          left right leftExponent rightExponent
          O.operationalNestedRight hright) →
      RSCerta
        n leftWeight rightWeight hleftWeight hrightWeight
        left right leftExponent rightExponent O hroot

namespace RTSwap

/--
Resolve the ordered adjacent-swap theorem for every below-cutoff recipe-free
orbit obstruction by well-founded recursion on cutoff defect.
-/
noncomputable def resolve
    {G : Type u}
    [Group G]
    {n leftWeight rightWeight : ℕ}
    {hleftWeight : 0 < leftWeight}
    {hrightWeight : 0 < rightWeight}
    {left right : G}
    {leftExponent rightExponent : ℤ}
    (kernel :
      RTSwap
        n leftWeight rightWeight hleftWeight hrightWeight
        left right leftExponent rightExponent)
    (O : POObstru)
    (hroot : O.weight leftWeight rightWeight < n) :
    RSCerta
      n leftWeight rightWeight hleftWeight hrightWeight
      left right leftExponent rightExponent O hroot := by
  exact
    (descends_wellFounded n leftWeight rightWeight).induction
      (C := fun parent =>
        ∀ hparent : parent.weight leftWeight rightWeight < n,
          RSCerta
            n leftWeight rightWeight hleftWeight hrightWeight
            left right leftExponent rightExponent parent hparent)
      O
      (fun parent recurse hparent =>
        kernel.resolve_local parent hparent
          (fun hleft =>
            recurse parent.operationalNestedLeft
              (parent.nestedLeftDescends
                hleftWeight hrightWeight hleft)
              hleft)
          (fun hright =>
            recurse parent.operationalNestedRight
              (parent.nestedRightDescends
                hleftWeight hrightWeight hright)
              hright))
      hroot

/--
A resolved orbit-swap kernel gives the same ordered theorem after decoding a
supported finite-index trace into symbolic Hall polynomial factors.
-/
theorem symbolic_factors_swap
    {d n leftWeight rightWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru)
    (hsupport : IsSupported (n := n) hleftWeight hrightWeight O)
    (hroot : O.weight leftWeight rightWeight < n)
    (left right : SPFactor H ι)
    (kernel :
      RTSwap
        n leftWeight rightWeight hleftWeight hrightWeight
        (left.wordValue (n := n)) (right.wordValue (n := n))
        (left.coefficient.eval e) (right.coefficient.eval e)) :
    SPFactor.listEval (n := n) e
          (retainedIdxFactors normalizer
            hleftWeight hrightWeight O hsupport left right) *
        orbitFactorValue O.right
          (left.wordValue (n := n)) (right.wordValue (n := n))
          (left.coefficient.eval e) (right.coefficient.eval e) *
      orbitFactorValue O.left
        (left.wordValue (n := n)) (right.wordValue (n := n))
        (left.coefficient.eval e) (right.coefficient.eval e) =
      orbitFactorValue O.left
          (left.wordValue (n := n)) (right.wordValue (n := n))
          (left.coefficient.eval e) (right.coefficient.eval e) *
        orbitFactorValue O.right
          (left.wordValue (n := n)) (right.wordValue (n := n))
          (left.coefficient.eval e) (right.coefficient.eval e) := by
  rw [
    symbolic_factors_operational]
  exact (kernel.resolve O hroot).eval_mul_swap

/--
A resolved orbit-swap kernel also gives the corresponding ordered theorem for
the original retained recipe packet.
-/
theorem list_recipes_swap
    {G : Type u}
    [Group G]
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : RObstru)
    (hroot : O.weight leftWeight rightWeight < n)
    (left right : G)
    (leftExponent rightExponent : ℤ)
    (kernel :
      RTSwap
        n leftWeight rightWeight hleftWeight hrightWeight
        left right leftExponent rightExponent) :
    ((O.retainedRecipes (n := n) hleftWeight hrightWeight).map fun recipe =>
          recipe.erasedShape.eval (HPAtom.eval left right) ^
            coefficientValue recipe leftExponent rightExponent).prod *
        (O.right.erasedShape.eval (HPAtom.eval left right) ^
          coefficientValue O.right leftExponent rightExponent) *
      (O.left.erasedShape.eval (HPAtom.eval left right) ^
        coefficientValue O.left leftExponent rightExponent) =
      (O.left.erasedShape.eval (HPAtom.eval left right) ^
          coefficientValue O.left leftExponent rightExponent) *
        (O.right.erasedShape.eval (HPAtom.eval left right) ^
          coefficientValue O.right leftExponent rightExponent) := by
  rw [←
    orbit_obstruction_recipes
      hleftWeight hrightWeight O left right leftExponent rightExponent]
  exact
    (kernel.resolve (polynomialOrbitObstruction O) (by simpa using hroot))
      |>.eval_mul_swap

end RTSwap

end
  OSResolu
end TCTex
end Towers

/-!
# All-integral semantic boundary for fixed finite-index traces

The retained polynomial-orbit alphabet supplies a finite cutoff-supported
dictionary.  A genuine symbolic Hall collector must still produce one fixed
ordered trace over that dictionary and prove its all-integral commutator law.

This file packages that exact remaining obligation.  Once the law is proved,
the fixed trace becomes the all-integral ordered cutoff packet consumed by
the restricted-sharp Claim 5 route.

This file is intentionally not imported by the existing collection proof.
-/

namespace Towers
namespace TCTex
namespace
  PTSigned

universe u

open scoped commutatorElement

open
  CSAggreg
open
  UCAll
open
  RITrace
open
  POSigned

/-- The fixed-truncation semantic scheduling obligation for one fixed trace
over the retained finite polynomial-orbit dictionary. -/
def SatisfiesTruncatedEval
    {d n leftWeight rightWeight : ℕ}
    (trace :
      List (RetainedOrbitIndex n leftWeight rightWeight)) :
    Prop :=
  ∀ (left right :
      LowerCentralTruncation.{u} (FreeGroup (FreeGenerator.{u} d)) n)
    (leftExponent rightExponent : ℤ),
      ((indexBlockPackets trace).map fun packet =>
        packet.word.eval (HPAtom.eval left right) ^
          packet.profiles.value leftExponent rightExponent).prod =
        ⁅left ^ leftExponent, right ^ rightExponent⁆

/-- A fixed retained-index trace and its all-integral semantic law instantiate
the closure-supported packet consumed by symbolic recollection. -/
noncomputable def
    allBlockPacket
    {d n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (trace :
      List (RetainedOrbitIndex n leftWeight rightWeight))
    (hlistEval :
      SatisfiesTruncatedEval (d := d) trace) :
    TAPkta.{u}
      d n leftWeight rightWeight where
  toOBPkt :=
    indexBlockPacket
      hleftWeight hrightWeight trace
  listEval_eq :=
    hlistEval

@[simp]
lemma
    packets_all_packet
    {d n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (trace :
      List (RetainedOrbitIndex n leftWeight rightWeight))
    (hlistEval :
      SatisfiesTruncatedEval (d := d) trace) :
    (allBlockPacket
      hleftWeight hrightWeight trace hlistEval).packets =
        indexBlockPackets trace :=
  rfl

namespace TSInput

/--
A fixed root-weight retained-index trace with its all-integral scheduling law
supplies the Claim 5 coordinate polynomials.
-/
theorem coordPolyPacket
    {d n inputWeight : ℕ}
    (hn : 2 ≤ n)
    (H : ∀ s : ℕ, BCWta.{u} d s)
    (hH :
      ∀ s : ℕ,
        1 ≤ s →
          s < n →
            (H s).FormsAssocGradedbasis (n := n))
    {kernel : OCShape}
    (trace : List (RetainedOrbitIndex n 1 1))
    (hlistEval :
      SatisfiesTruncatedEval.{u}
        (d := d) trace)
    {e : HEFam H}
    (input :
      TSInput
        (n := n) (inputWeight := inputWeight) H e)
    (hsourceSupported :
      SPFactora.WordWeightLeast inputWeight input.source)
    (factorNormalization :
      ∀ lowerWeight : ℕ,
        ¬n ≤ 2 * lowerWeight →
          TSNormalb
              (n := n) (inputWeight := inputWeight)
                (lowerWeight := lowerWeight + 1) H →
            ∀ (factor : SPFactora H inputWeight),
              factor.word.weight PEAddres.weight = lowerWeight →
              factor.word.weight PEAddres.weight < n →
            TANorm
              (n := n) (lowerWeight := lowerWeight) H factor)
    (hinputWeight : 1 ≤ inputWeight) :
    CollectedPolynomialData (n := n) H e inputWeight :=
  input.coordinateAllPacket
    hn H hH (kernel := kernel)
      (allBlockPacket
        (by simp) (by simp) trace hlistEval)
      hsourceSupported factorNormalization hinputWeight

end TSInput

end
  PTSigned
export
  PTSigned.TSInput
    (coordPolyPacket)
end TCTex
end Towers

/-!
# Symbolic programs decoded from finite polynomial-orbit index traces

The arbitrary-multiplicity conservative raw envelope is an exact finite-index
program over one cutoff-sized polynomial-orbit alphabet.  This file decodes
that program into symbolic Hall polynomial factors while retaining its
source-plus-pairwise-grid structure literally.

The decoded program is exactly the earlier symbolic orbit envelope, and its
ordered evaluation is exactly the concrete conservative recipe envelope.
No noncommutative factor permutation is used.

This file is intentionally not imported by the existing collection proof.
-/

namespace Towers
namespace TCTex
namespace ISProgra

universe u

open
  RCCompar
open
  RITrace
open
  IEDecomp
open
  RSEnvelo
open RPEnvelo

/-- Mapping the fixed symbolic dictionary over the complete finite trace
preserves its literal source-plus-pairwise-grid decomposition. -/
lemma
    append_pairwise_flat
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : SPFactor H ι) :
    (universalEnvelopeTrace
      M N n leftWeight rightWeight hleftWeight hrightWeight).map
        (orbitSymbolicFactor normalizer left right) =
      (universalIndexTrace
        M N n leftWeight rightWeight hleftWeight hrightWeight).map
          (orbitSymbolicFactor normalizer left right) ++
        (rawHistoriesAttached M N n leftWeight rightWeight).flatMap
          fun leftHistory =>
            (rawHistoriesAttached M N n leftWeight rightWeight).flatMap
              fun rightHistory =>
                (universalOperationalTrace
                  hleftWeight hrightWeight leftHistory rightHistory).map
                    (orbitSymbolicFactor
                      normalizer left right) := by
  rw [
    universal_pairwise_flat]
  simp only [List.map_append, List.map_flatMap]

/-- The earlier symbolic orbit envelope is literally the decoded source trace
followed by the pairwise grid of decoded local operational programs. -/
lemma
    universal_envelope_flat
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : SPFactor H ι) :
    universalEnvelopeFactors
        normalizer M N n leftWeight rightWeight
          hleftWeight hrightWeight left right =
      (universalIndexTrace
        M N n leftWeight rightWeight hleftWeight hrightWeight).map
          (orbitSymbolicFactor normalizer left right) ++
        (rawHistoriesAttached M N n leftWeight rightWeight).flatMap
          fun leftHistory =>
            (rawHistoriesAttached M N n leftWeight rightWeight).flatMap
              fun rightHistory =>
                (universalOperationalTrace
                  hleftWeight hrightWeight leftHistory rightHistory).map
                    (orbitSymbolicFactor
                      normalizer left right) := by
  rw [←
    universal_packet_envelope]
  exact
    append_pairwise_flat
      normalizer M N n leftWeight rightWeight
        hleftWeight hrightWeight left right

/-- Ordered symbolic evaluation splits into the source-segment value followed
by the pairwise-grid local-program value. -/
lemma
    envelope_pairwise_flat
    {d truncation : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : SPFactor H ι) :
    SPFactor.listEval (n := truncation) e
        (universalEnvelopeFactors
          normalizer M N n leftWeight rightWeight
            hleftWeight hrightWeight left right) =
      SPFactor.listEval (n := truncation) e
          ((universalIndexTrace
            M N n leftWeight rightWeight hleftWeight hrightWeight).map
              (orbitSymbolicFactor
                normalizer left right)) *
        SPFactor.listEval (n := truncation) e
          ((rawHistoriesAttached
            M N n leftWeight rightWeight).flatMap fun leftHistory =>
              (rawHistoriesAttached
                M N n leftWeight rightWeight).flatMap fun rightHistory =>
                  (universalOperationalTrace
                    hleftWeight hrightWeight leftHistory rightHistory).map
                      (orbitSymbolicFactor
                        normalizer left right)) := by
  rw [
    universal_envelope_flat,
    SPFactor.listEval_append]

/-- The decoded source-plus-pairwise-grid symbolic program evaluates exactly
as the concrete arbitrary-multiplicity conservative recipe envelope. -/
lemma
    pairwise_flat_envelope
    {d truncation : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (M N n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : SPFactor H ι) :
    SPFactor.listEval (n := truncation) e
        ((universalIndexTrace
          M N n leftWeight rightWeight hleftWeight hrightWeight).map
            (orbitSymbolicFactor normalizer left right) ++
          (rawHistoriesAttached
            M N n leftWeight rightWeight).flatMap fun leftHistory =>
              (rawHistoriesAttached
                M N n leftWeight rightWeight).flatMap fun rightHistory =>
                  (universalOperationalTrace
                    hleftWeight hrightWeight leftHistory rightHistory).map
                      (orbitSymbolicFactor
                        normalizer left right)) =
      ((concretePacketEnvelope
        M N n leftWeight rightWeight hleftWeight hrightWeight).map fun recipe =>
          recipe.erasedShape.eval
              (HPAtom.eval
                (left.wordValue (n := truncation))
                (right.wordValue (n := truncation))) ^
            BRSpec.coefficientValue recipe
              (left.coefficient.eval e) (right.coefficient.eval e)).prod := by
  rw [←
    universal_envelope_flat]
  exact
    universal_envelope_recipe
      normalizer e hleftWeight hrightWeight left right

end ISProgra
end TCTex
