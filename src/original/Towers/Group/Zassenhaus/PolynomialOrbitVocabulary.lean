/-!
# Class-two terminal nodes for recursive polynomial-orbit swaps

The ordered orbit-swap resolver still needs one local constructor at each
node.  Near the cutoff, both recursive children vanish and the leading orbit
correction is the complete swap packet.  This file proves that terminal case
for arbitrary integral polynomial-orbit coefficients in any matching
nilpotent quotient.

The final reduced kernel asks only for genuinely nonterminal nodes.  Terminal
nodes are discharged automa.

This file is intentionally not imported by the existing collection proof.
-/

noncomputable section

namespace Towers
namespace TCTex
namespace
  CTTermin

universe u

open scoped commutatorElement

open ROEvalua
open RREvalua
open RRPkt
open
  RRPkt.POObstru
open ROAggreg
open ROTransi
open
  OSResolu

namespace POKey

/-- One recipe-free orbit shape evaluates in its weighted lower-central layer. -/
lemma erased_shape_series
    {leftWeight rightWeight : ℕ}
    {G : Type*}
    [Group G]
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {left right : G}
    (hleft : left ∈ Subgroup.lowerCentralSeries G (leftWeight - 1))
    (hright : right ∈ Subgroup.lowerCentralSeries G (rightWeight - 1))
    (key : POKey) :
    key.erasedShape.eval (HPAtom.eval left right) ∈
      Subgroup.lowerCentralSeries G
        (orbitWeight leftWeight rightWeight key - 1) := by
  apply CWord.eval_lower_series
    (HPAtom.eval left right)
    (HPAtom.weight leftWeight rightWeight)
    (HPAtom.weight_pos hleftWeight hrightWeight)
  intro atom
  cases atom with
  | left =>
      simpa [HPAtom.eval, HPAtom.weight] using hleft
  | right =>
      simpa [HPAtom.eval, HPAtom.weight] using hright

end POKey

namespace POObstru

/-- Both recursively emitted children have reached the nilpotent cutoff. -/
def Terminal
    (n leftWeight rightWeight : ℕ)
    (O : POObstru) :
    Prop :=
  n ≤ O.operationalNestedLeft.weight leftWeight rightWeight ∧
    n ≤ O.operationalNestedRight.weight leftWeight rightWeight

/-- A node is nonterminal exactly when at least one recursive child survives. -/
lemma not_terminal_iff
    {n leftWeight rightWeight : ℕ}
    (O : POObstru) :
    ¬Terminal n leftWeight rightWeight O ↔
      O.operationalNestedLeft.weight leftWeight rightWeight < n ∨
        O.operationalNestedRight.weight leftWeight rightWeight < n := by
  unfold Terminal
  omega

/--
The class-two terminal zone starts exactly after the root weight plus the
smaller parent-orbit weight.
-/
lemma terminal_cutoff_min
    {n leftWeight rightWeight : ℕ}
    (O : POObstru) :
    Terminal n leftWeight rightWeight O ↔
      n ≤ O.weight leftWeight rightWeight +
        min (orbitWeight leftWeight rightWeight O.left)
          (orbitWeight leftWeight rightWeight O.right) := by
  rw [Terminal, weight_nested_left, weight_operational_right]
  unfold weight
  omega

/--
A genuinely nonterminal node has strict room for the root correction and the
smaller parent-orbit weight.
-/
lemma not_terminal_min
    {n leftWeight rightWeight : ℕ}
    (O : POObstru) :
    ¬Terminal n leftWeight rightWeight O ↔
      O.weight leftWeight rightWeight +
          min (orbitWeight leftWeight rightWeight O.left)
            (orbitWeight leftWeight rightWeight O.right) <
        n := by
  rw [terminal_cutoff_min]
  omega

/-- Every parent orbit has positive weighted degree. -/
lemma one_orbit_weight
    {leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (key : POKey) :
    1 ≤ orbitWeight leftWeight rightWeight key := by
  unfold orbitWeight
  exact
    CWord.weight_pos
      (HPAtom.weight leftWeight rightWeight)
      (HPAtom.weight_pos hleftWeight hrightWeight)
      key.erasedShape

/-- Every orbit obstruction has weighted degree at least two. -/
lemma two_le_weight
    {leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru) :
    2 ≤ O.weight leftWeight rightWeight := by
  have hleftOrbit :=
    one_orbit_weight hleftWeight hrightWeight O.left
  have hrightOrbit :=
    one_orbit_weight hleftWeight hrightWeight O.right
  unfold weight
  omega

/--
One spare weight step above the root is enough to enter the class-two terminal
zone.
-/
lemma terminal_cutoff_one
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru)
    (hn : n ≤ O.weight leftWeight rightWeight + 1) :
    Terminal n leftWeight rightWeight O := by
  rw [terminal_cutoff_min]
  have hleftOrbit :=
    one_orbit_weight hleftWeight hrightWeight O.left
  have hrightOrbit :=
    one_orbit_weight hleftWeight hrightWeight O.right
  omega

/--
A genuinely nonterminal node leaves at least one additional weighted degree
below the cutoff.
-/
lemma cutoff_not_terminal
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru)
    (hnonterminal : ¬Terminal n leftWeight rightWeight O) :
    O.weight leftWeight rightWeight + 1 < n := by
  by_contra hnot
  exact
    hnonterminal
      (terminal_cutoff_one
        hleftWeight hrightWeight O (by omega))

/--
Through cutoff three, every positive-weight orbit obstruction is already in
the class-two terminal zone.
-/
lemma terminal_cutoff_three
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 3)
    (O : POObstru) :
    Terminal n leftWeight rightWeight O := by
  apply terminal_cutoff_one hleftWeight hrightWeight O
  have hweight := two_le_weight hleftWeight hrightWeight O
  omega

/--
At or above the cutoff, the two powered parent orbit factors commute in any
matching nilpotent quotient.
-/
lemma orbit_commute_weight
    {G : Type u}
    [Group G]
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {left right : G}
    (hleft : left ∈ Subgroup.lowerCentralSeries G (leftWeight - 1))
    (hright : right ∈ Subgroup.lowerCentralSeries G (rightWeight - 1))
    (hbot : Subgroup.lowerCentralSeries G (n - 1) = ⊥)
    (O : POObstru)
    (hroot : n ≤ O.weight leftWeight rightWeight)
    (leftExponent rightExponent : ℤ) :
    Commute
      (orbitFactorValue O.left
        left right leftExponent rightExponent)
      (orbitFactorValue O.right
        left right leftExponent rightExponent) := by
  let leftOrbitWeight :=
    orbitWeight leftWeight rightWeight O.left
  let rightOrbitWeight :=
    orbitWeight leftWeight rightWeight O.right
  have hleftOrbitWeight : 0 < leftOrbitWeight := by
    unfold leftOrbitWeight orbitWeight
    exact
      CWord.weight_pos
        (HPAtom.weight leftWeight rightWeight)
        (HPAtom.weight_pos hleftWeight hrightWeight)
        O.left.erasedShape
  have hrightOrbitWeight : 0 < rightOrbitWeight := by
    unfold rightOrbitWeight orbitWeight
    exact
      CWord.weight_pos
        (HPAtom.weight leftWeight rightWeight)
        (HPAtom.weight_pos hleftWeight hrightWeight)
        O.right.erasedShape
  have hleftFactor :
      orbitFactorValue O.left
          left right leftExponent rightExponent ∈
        Subgroup.lowerCentralSeries G (leftOrbitWeight - 1) := by
    unfold orbitFactorValue
    exact
      (Subgroup.lowerCentralSeries G (leftOrbitWeight - 1)).zpow_mem
        (by
          simpa [leftOrbitWeight] using
            POKey.erased_shape_series
              hleftWeight hrightWeight hleft hright O.left)
        _
  have hrightFactor :
      orbitFactorValue O.right
          left right leftExponent rightExponent ∈
        Subgroup.lowerCentralSeries G (rightOrbitWeight - 1) := by
    unfold orbitFactorValue
    exact
      (Subgroup.lowerCentralSeries G (rightOrbitWeight - 1)).zpow_mem
        (by
          simpa [rightOrbitWeight] using
            POKey.erased_shape_series
              hleftWeight hrightWeight hleft hright O.right)
        _
  have hcommutator :
      ⁅orbitFactorValue O.left
            left right leftExponent rightExponent,
          orbitFactorValue O.right
            left right leftExponent rightExponent⁆ ∈
        Subgroup.lowerCentralSeries G
          ((leftOrbitWeight - 1) + (rightOrbitWeight - 1) + 1) :=
    element_lower_series
      hleftFactor hrightFactor
  rw [← commutatorElement_eq_one_iff_commute]
  apply eq_bot_iff.mp hbot
  exact Subgroup.lowerCentralSeries_antitone (by
    unfold POObstru.weight at hroot
    dsimp [leftOrbitWeight, rightOrbitWeight]
    omega) hcommutator

/--
At a class-two terminal node, the leading orbit correction evaluates as the
commutator of the two powered parent orbit factors.
-/
lemma orbit_value_terminal
    {G : Type u}
    [Group G]
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {left right : G}
    (hleft : left ∈ Subgroup.lowerCentralSeries G (leftWeight - 1))
    (hright : right ∈ Subgroup.lowerCentralSeries G (rightWeight - 1))
    (hbot : Subgroup.lowerCentralSeries G (n - 1) = ⊥)
    (O : POObstru)
    (hterminal : Terminal n leftWeight rightWeight O)
    (leftExponent rightExponent : ℤ) :
    orbitFactorValue O.correction
        left right leftExponent rightExponent =
      ⁅orbitFactorValue O.left
          left right leftExponent rightExponent,
        orbitFactorValue O.right
          left right leftExponent rightExponent⁆ := by
  let leftValue :=
    O.left.erasedShape.eval (HPAtom.eval left right)
  let rightValue :=
    O.right.erasedShape.eval (HPAtom.eval left right)
  let leftOrbitWeight :=
    orbitWeight leftWeight rightWeight O.left
  let rightOrbitWeight :=
    orbitWeight leftWeight rightWeight O.right
  have hleftOrbitWeight : 0 < leftOrbitWeight := by
    unfold leftOrbitWeight orbitWeight
    exact
      CWord.weight_pos
        (HPAtom.weight leftWeight rightWeight)
        (HPAtom.weight_pos hleftWeight hrightWeight)
        O.left.erasedShape
  have hrightOrbitWeight : 0 < rightOrbitWeight := by
    unfold rightOrbitWeight orbitWeight
    exact
      CWord.weight_pos
        (HPAtom.weight leftWeight rightWeight)
        (HPAtom.weight_pos hleftWeight hrightWeight)
        O.right.erasedShape
  have hleftValue :
      leftValue ∈ Subgroup.lowerCentralSeries G (leftOrbitWeight - 1) := by
    simpa [leftValue, leftOrbitWeight] using
      POKey.erased_shape_series
        hleftWeight hrightWeight hleft hright O.left
  have hrightValue :
      rightValue ∈ Subgroup.lowerCentralSeries G (rightOrbitWeight - 1) := by
    simpa [rightValue, rightOrbitWeight] using
      POKey.erased_shape_series
        hleftWeight hrightWeight hleft hright O.right
  have hcommutator :
      ⁅leftValue, rightValue⁆ ∈
        Subgroup.lowerCentralSeries G
          ((leftOrbitWeight - 1) + (rightOrbitWeight - 1) + 1) :=
    element_lower_series
      hleftValue hrightValue
  have hleftNested :
      ⁅leftValue, ⁅leftValue, rightValue⁆⁆ ∈
        Subgroup.lowerCentralSeries G
          ((leftOrbitWeight - 1) +
            ((leftOrbitWeight - 1) + (rightOrbitWeight - 1) + 1) + 1) :=
    element_lower_series
      hleftValue hcommutator
  have hrightNested :
      ⁅rightValue, ⁅leftValue, rightValue⁆⁆ ∈
        Subgroup.lowerCentralSeries G
          ((rightOrbitWeight - 1) +
            ((leftOrbitWeight - 1) + (rightOrbitWeight - 1) + 1) + 1) :=
    element_lower_series
      hrightValue hcommutator
  have hleftNestedOne :
      ⁅leftValue, ⁅leftValue, rightValue⁆⁆ = 1 := by
    apply eq_bot_iff.mp hbot
    exact Subgroup.lowerCentralSeries_antitone (by
      have hterminalLeft := hterminal.1
      rw [weight_nested_left] at hterminalLeft
      dsimp [leftOrbitWeight, rightOrbitWeight]
      omega) hleftNested
  have hrightNestedOne :
      ⁅rightValue, ⁅leftValue, rightValue⁆⁆ = 1 := by
    apply eq_bot_iff.mp hbot
    exact Subgroup.lowerCentralSeries_antitone (by
      have hterminalRight := hterminal.2
      rw [weight_operational_right] at hterminalRight
      dsimp [leftOrbitWeight, rightOrbitWeight]
      omega) hrightNested
  have hleftCommute :
      Commute leftValue ⁅leftValue, rightValue⁆ :=
    commutatorElement_eq_one_iff_commute.mp hleftNestedOne
  have hrightCommute :
      Commute rightValue ⁅leftValue, rightValue⁆ :=
    commutatorElement_eq_one_iff_commute.mp hrightNestedOne
  have hcoefficient :
      orbitCoefficientValue O.correction
          leftExponent rightExponent =
        orbitCoefficientValue O.left leftExponent rightExponent *
          orbitCoefficientValue O.right
            leftExponent rightExponent := by
    unfold POObstru.correction
    unfold orbitCorrection orbitCoefficientValue
    simp only [List.map_append, List.prod_append]
    ring
  have hleftPower :
      ⁅leftValue ^
            orbitCoefficientValue O.left
              leftExponent rightExponent,
          rightValue⁆ =
        ⁅leftValue, rightValue⁆ ^
          orbitCoefficientValue O.left
            leftExponent rightExponent :=
    commutator_zpow_commute
      hleftCommute _
  have hrightCommutePower :
      Commute rightValue
        ⁅leftValue ^
            orbitCoefficientValue O.left
              leftExponent rightExponent,
          rightValue⁆ := by
    rw [hleftPower]
    exact
      hrightCommute.zpow_right
        (orbitCoefficientValue O.left
          leftExponent rightExponent)
  unfold orbitFactorValue
  rw [hcoefficient]
  change
    ⁅leftValue, rightValue⁆ ^
        (orbitCoefficientValue O.left
            leftExponent rightExponent *
          orbitCoefficientValue O.right
            leftExponent rightExponent) =
      ⁅leftValue ^
          orbitCoefficientValue O.left
            leftExponent rightExponent,
        rightValue ^
          orbitCoefficientValue O.right
            leftExponent rightExponent⁆
  rw [
    zpow_commute_collection
      hrightCommutePower,
    hleftPower, zpow_mul]

end POObstru

namespace RSCerta

/-- Terminal orbit obstructions are resolved by their singleton correction. -/
def of_terminal
    {G : Type u}
    [Group G]
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    {left right : G}
    (hleft : left ∈ Subgroup.lowerCentralSeries G (leftWeight - 1))
    (hright : right ∈ Subgroup.lowerCentralSeries G (rightWeight - 1))
    (hbot : Subgroup.lowerCentralSeries G (n - 1) = ⊥)
    (leftExponent rightExponent : ℤ)
    (O : POObstru)
    (hroot : O.weight leftWeight rightWeight < n)
    (hterminal :
      POObstru.Terminal n leftWeight rightWeight O) :
    RSCerta
      n leftWeight rightWeight hleftWeight hrightWeight
      left right leftExponent rightExponent O hroot where
  eval_mul_swap := by
    rw [
      list_root_branches,
      dif_neg (Nat.not_lt_of_ge hterminal.1),
      dif_neg (Nat.not_lt_of_ge hterminal.2)]
    simp only [List.map_nil, List.prod_nil, mul_one]
    rw [
      POObstru.orbit_value_terminal
        hleftWeight hrightWeight hleft hright hbot O hterminal]
    simp [commutatorElement_def]

end RSCerta

/--
Only genuinely nonterminal orbit obstructions remain as local Hall collection
obligations.  Terminal nodes are supplied by the checked class-two theorem.
-/
structure RNSwap
    {G : Type u}
    [Group G]
    (n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    Prop where
  resolve_nonterminal :
    ∀ (O : POObstru)
      (hroot : O.weight leftWeight rightWeight < n),
      ¬POObstru.Terminal n leftWeight rightWeight O →
      (∀ hleft :
          O.operationalNestedLeft.weight leftWeight rightWeight < n,
        RSCerta
          n leftWeight rightWeight hleftWeight hrightWeight
          left right leftExponent rightExponent
          O.operationalNestedLeft hleft) →
      (∀ hright :
          O.operationalNestedRight.weight leftWeight rightWeight < n,
        RSCerta
          n leftWeight rightWeight hleftWeight hrightWeight
          left right leftExponent rightExponent
          O.operationalNestedRight hright) →
      RSCerta
        n leftWeight rightWeight hleftWeight hrightWeight
        left right leftExponent rightExponent O hroot

/--
Equivalent arithmetic form of the remaining local Hall collection law.  The
strict room hypothesis is exactly nonterminality, but it exposes the weight
range expected by a cutoff-aware collector.
-/
structure RRSwap
    {G : Type u}
    [Group G]
    (n leftWeight rightWeight : ℕ)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    Prop where
  resolve_weight_room :
    ∀ (O : POObstru)
      (hroot : O.weight leftWeight rightWeight < n),
      O.weight leftWeight rightWeight +
            min (orbitWeight leftWeight rightWeight O.left)
              (orbitWeight leftWeight rightWeight O.right) <
          n →
      (∀ hleft :
          O.operationalNestedLeft.weight leftWeight rightWeight < n,
        RSCerta
          n leftWeight rightWeight hleftWeight hrightWeight
          left right leftExponent rightExponent
          O.operationalNestedLeft hleft) →
      (∀ hright :
          O.operationalNestedRight.weight leftWeight rightWeight < n,
        RSCerta
          n leftWeight rightWeight hleftWeight hrightWeight
          left right leftExponent rightExponent
          O.operationalNestedRight hright) →
      RSCerta
        n leftWeight rightWeight hleftWeight hrightWeight
        left right leftExponent rightExponent O hroot

namespace RRSwap

/--
Compile the numeric strict-room interface to the equivalent nonterminal
interface used by the terminal-leaf filler.
-/
def recursiveNonterminalSwap
    {G : Type u}
    [Group G]
    {n leftWeight rightWeight : ℕ}
    {hleftWeight : 0 < leftWeight}
    {hrightWeight : 0 < rightWeight}
    {left right : G}
    {leftExponent rightExponent : ℤ}
    (kernel :
      RRSwap
        n leftWeight rightWeight hleftWeight hrightWeight
        left right leftExponent rightExponent) :
    RNSwap
      n leftWeight rightWeight hleftWeight hrightWeight
      left right leftExponent rightExponent where
  resolve_nonterminal := by
    intro O hroot hnonterminal hleft hright
    exact
      kernel.resolve_weight_room O hroot
        ((POObstru.not_terminal_min
          O).mp hnonterminal)
        hleft hright

end RRSwap

namespace RNSwap

/--
Through cutoff three the nonterminal kernel is vacuous: every positive-weight
orbit obstruction is filled by the terminal constructor.
-/
def cutoff_three
    {G : Type u}
    [Group G]
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 3)
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    RNSwap
      n leftWeight rightWeight hleftWeight hrightWeight
      left right leftExponent rightExponent where
  resolve_nonterminal := by
    intro O _hroot hnonterminal _hleft _hright
    exact
      (hnonterminal
        (POObstru.terminal_cutoff_three
          hleftWeight hrightWeight hn O)).elim

/--
Compile a nonterminal kernel to the full ordered-swap kernel by filling every
class-two terminal leaf automa.
-/
def recursiveTruncatedSwap
    {G : Type u}
    [Group G]
    {n leftWeight rightWeight : ℕ}
    {hleftWeight : 0 < leftWeight}
    {hrightWeight : 0 < rightWeight}
    {left right : G}
    (hleft : left ∈ Subgroup.lowerCentralSeries G (leftWeight - 1))
    (hright : right ∈ Subgroup.lowerCentralSeries G (rightWeight - 1))
    (hbot : Subgroup.lowerCentralSeries G (n - 1) = ⊥)
    {leftExponent rightExponent : ℤ}
    (kernel :
      RNSwap
        n leftWeight rightWeight hleftWeight hrightWeight
        left right leftExponent rightExponent) :
    RTSwap
      n leftWeight rightWeight hleftWeight hrightWeight
      left right leftExponent rightExponent where
  resolve_local := by
    intro O hroot _hleft _hright
    by_cases hterminal :
        POObstru.Terminal n leftWeight rightWeight O
    · exact
        RSCerta.of_terminal
          hleftWeight hrightWeight hleft hright hbot
          leftExponent rightExponent O hroot hterminal
    · exact
        kernel.resolve_nonterminal O hroot hterminal _hleft _hright

/--
Resolve every below-cutoff orbit obstruction from nonterminal local laws and
the automatic class-two terminal constructor.
-/
noncomputable def resolve
    {G : Type u}
    [Group G]
    {n leftWeight rightWeight : ℕ}
    {hleftWeight : 0 < leftWeight}
    {hrightWeight : 0 < rightWeight}
    {left right : G}
    (hleft : left ∈ Subgroup.lowerCentralSeries G (leftWeight - 1))
    (hright : right ∈ Subgroup.lowerCentralSeries G (rightWeight - 1))
    (hbot : Subgroup.lowerCentralSeries G (n - 1) = ⊥)
    {leftExponent rightExponent : ℤ}
    (kernel :
      RNSwap
        n leftWeight rightWeight hleftWeight hrightWeight
        left right leftExponent rightExponent)
    (O : POObstru)
    (hroot : O.weight leftWeight rightWeight < n) :
    RSCerta
      n leftWeight rightWeight hleftWeight hrightWeight
      left right leftExponent rightExponent O hroot :=
  (kernel.recursiveTruncatedSwap hleft hright hbot).resolve O hroot

/--
For decoded symbolic parents, lower-central support and terminal vanishing are
automatic in the free lower-central truncation.
-/
def recursiveSwapFactors
    {d n leftWeight rightWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (e : ι → HEFam H)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : SPFactor H ι)
    (hleft :
      left.word.weight HEAddres.weight = leftWeight)
    (hright :
      right.word.weight HEAddres.weight = rightWeight)
    (kernel :
      RNSwap
        n leftWeight rightWeight hleftWeight hrightWeight
        (left.wordValue (n := n)) (right.wordValue (n := n))
        (left.coefficient.eval e) (right.coefficient.eval e)) :
    RTSwap
      n leftWeight rightWeight hleftWeight hrightWeight
      (left.wordValue (n := n)) (right.wordValue (n := n))
      (left.coefficient.eval e) (right.coefficient.eval e) := by
  apply kernel.recursiveTruncatedSwap
  · simpa only [hleft] using left.value_lower_series (n := n)
  · simpa only [hright] using right.value_lower_series (n := n)
  · exact
      SCFactor.trunc_last_bot

/--
A nonterminal local Hall-swap kernel resolves the ordered decoded finite-index
trace.  Class-two leaves are filled automa.
-/
theorem symbolic_factors_swap
    {d n leftWeight rightWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : POObstru)
    (hsupport :
      RIRecurs.IsSupported
        (n := n) hleftWeight hrightWeight O)
    (hroot : O.weight leftWeight rightWeight < n)
    (left right : SPFactor H ι)
    (hleft :
      left.word.weight HEAddres.weight = leftWeight)
    (hright :
      right.word.weight HEAddres.weight = rightWeight)
    (kernel :
      RNSwap
        n leftWeight rightWeight hleftWeight hrightWeight
        (left.wordValue (n := n)) (right.wordValue (n := n))
        (left.coefficient.eval e) (right.coefficient.eval e)) :
    SPFactor.listEval (n := n) e
          (RSProgra.retainedIdxFactors
            normalizer hleftWeight hrightWeight O hsupport left right) *
        orbitFactorValue O.right
          (left.wordValue (n := n)) (right.wordValue (n := n))
          (left.coefficient.eval e) (right.coefficient.eval e) *
      orbitFactorValue O.left
        (left.wordValue (n := n)) (right.wordValue (n := n))
        (left.coefficient.eval e) (right.coefficient.eval e) =
      orbitFactorValue O.left
          (left.wordValue (n := n)) (right.wordValue (n := n))
          (left.coefficient.eval e) (right.coefficient.eval e) *
        orbitFactorValue O.right
          (left.wordValue (n := n)) (right.wordValue (n := n))
          (left.coefficient.eval e) (right.coefficient.eval e) := by
  exact
    RTSwap.symbolic_factors_swap
      normalizer e hleftWeight hrightWeight O hsupport hroot left right
      (kernel.recursiveSwapFactors
        e hleftWeight hrightWeight left right hleft hright)

/--
A nonterminal local kernel also resolves the ordered retained recipe packet;
class-two leaves are inserted automa.
-/
theorem list_recipes_swap
    {G : Type u}
    [Group G]
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (left right : G)
    (hleft :
      left ∈ Subgroup.lowerCentralSeries G (leftWeight - 1))
    (hright :
      right ∈ Subgroup.lowerCentralSeries G (rightWeight - 1))
    (hbot : Subgroup.lowerCentralSeries G (n - 1) = ⊥)
    (O : BRPkt.RObstru)
    (hroot : O.weight leftWeight rightWeight < n)
    (leftExponent rightExponent : ℤ)
    (kernel :
      RNSwap
        n leftWeight rightWeight hleftWeight hrightWeight
        left right leftExponent rightExponent) :
    ((O.retainedRecipes (n := n) hleftWeight hrightWeight).map fun recipe =>
          recipe.erasedShape.eval (HPAtom.eval left right) ^
            BRSpec.coefficientValue
              recipe leftExponent rightExponent).prod *
        (O.right.erasedShape.eval (HPAtom.eval left right) ^
          BRSpec.coefficientValue
            O.right leftExponent rightExponent) *
      (O.left.erasedShape.eval (HPAtom.eval left right) ^
        BRSpec.coefficientValue
          O.left leftExponent rightExponent) =
      (O.left.erasedShape.eval (HPAtom.eval left right) ^
          BRSpec.coefficientValue
            O.left leftExponent rightExponent) *
        (O.right.erasedShape.eval (HPAtom.eval left right) ^
          BRSpec.coefficientValue
            O.right leftExponent rightExponent) := by
  exact
    RTSwap.list_recipes_swap
      hleftWeight hrightWeight O hroot left right leftExponent rightExponent
      (kernel.recursiveTruncatedSwap hleft hright hbot)

end RNSwap

namespace RTSwap

/--
Through cutoff three, lower-central support alone constructs the complete
ordered-swap kernel: every recursive orbit node is terminal.
-/
def cutoff_three
    {G : Type u}
    [Group G]
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (hn : n ≤ 3)
    (left right : G)
    (hleft : left ∈ Subgroup.lowerCentralSeries G (leftWeight - 1))
    (hright : right ∈ Subgroup.lowerCentralSeries G (rightWeight - 1))
    (hbot : Subgroup.lowerCentralSeries G (n - 1) = ⊥)
    (leftExponent rightExponent : ℤ) :
    RTSwap
      n leftWeight rightWeight hleftWeight hrightWeight
      left right leftExponent rightExponent :=
  (RNSwap.cutoff_three
      hleftWeight hrightWeight hn left right leftExponent rightExponent
    |>.recursiveTruncatedSwap hleft hright hbot)

end RTSwap

end
  CTTermin
end TCTex
