/--
For an obstruction arising from recipes, guarded orbit evaluation is exactly
the original guarded ordered recipe correction product.
-/
lemma
    guarded_obstruction_recipes
    {n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (O : RObstru)
    {G : Type*}
    [Group G]
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    guardedOperationalEval (n := n)
        hleftWeight hrightWeight (polynomialOrbitObstruction O)
          left right leftExponent rightExponent =
      ((operationalRecipes (n := n)
        hleftWeight hrightWeight O).map fun recipe =>
          recipe.erasedShape.eval (HPAtom.eval left right) ^
            coefficientValue recipe
              leftExponent rightExponent).prod := by
  unfold guardedOperationalEval
  unfold operationalRecipes
  by_cases hroot : O.weight leftWeight rightWeight < n
  · have horbit :
        (polynomialOrbitObstruction O).weight leftWeight rightWeight < n := by
      simpa using hroot
    rw [dif_pos horbit, dif_pos hroot]
    exact
      orbit_obstruction_recipes
        hleftWeight hrightWeight O
          left right leftExponent rightExponent
  · have horbit :
        ¬(polynomialOrbitObstruction O).weight leftWeight rightWeight < n := by
      simpa using hroot
    rw [dif_neg horbit, dif_neg hroot]
    rfl

/--
For one retained-history pair, guarded orbit evaluation is exactly the chosen
universal operational recipe correction packet.
-/
lemma
    guarded_operational_obstruction
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    {G : Type*}
    [Group G]
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    guardedOperationalEval (n := n)
        hleftWeight hrightWeight
        (universalOrbitObstruction
          hleftWeight hrightWeight leftHistory rightHistory)
        left right leftExponent rightExponent =
      ((universalOperationalCorrection
        hleftWeight hrightWeight leftHistory rightHistory).map fun recipe =>
          recipe.erasedShape.eval (HPAtom.eval left right) ^
            coefficientValue recipe
              leftExponent rightExponent).prod := by
  rw [universal_polynomial_obstruction]
  exact
    guarded_obstruction_recipes
      hleftWeight hrightWeight
      (universalObstruction
        hleftWeight hrightWeight leftHistory rightHistory)
      left right leftExponent rightExponent

/--
Universal replacement does not change one retained-history pair's guarded
ordered recipe correction product.
-/
lemma
    guarded_universal_obstruction
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    {G : Type*}
    [Group G]
    (left right : G)
    (leftExponent rightExponent : ℤ) :
    guardedOperationalEval (n := n)
        hleftWeight hrightWeight
        (universalOrbitObstruction
          hleftWeight hrightWeight leftHistory rightHistory)
        left right leftExponent rightExponent =
      ((concreteOperationalPacket
        hleftWeight hrightWeight leftHistory rightHistory).map fun recipe =>
          recipe.erasedShape.eval (HPAtom.eval left right) ^
            coefficientValue recipe
              leftExponent rightExponent).prod := by
  rw [
    guarded_operational_obstruction
      hleftWeight hrightWeight leftHistory rightHistory
        left right leftExponent rightExponent]
  exact
    recipe_factors_forall₂_polynomialEquivalent
      (universal_operational_forall₂
        hleftWeight hrightWeight leftHistory rightHistory)
      left right leftExponent rightExponent

/--
One decoded local symbolic cell evaluates exactly as its concrete guarded
recipe correction packet at the symbolic parents' values.
-/
lemma factors_concrete_packet
    {d truncation : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    {ι : Type}
    (normalizer : WBForm.RCNormal H ι)
    (e : ι → HEFam H)
    {M N n leftWeight rightWeight : ℕ}
    (hleftWeight : 0 < leftWeight)
    (hrightWeight : 0 < rightWeight)
    (leftHistory rightHistory :
      RetainedRawHistory M N n leftWeight rightWeight)
    (left right : SPFactor H ι) :
    SPFactor.listEval (n := truncation) e
        (universalOperationalFactors
          normalizer hleftWeight hrightWeight
            leftHistory rightHistory left right) =
      ((concreteOperationalPacket
        hleftWeight hrightWeight leftHistory rightHistory).map fun recipe =>
          recipe.erasedShape.eval
              (HPAtom.eval
                (left.wordValue (n := truncation))
                (right.wordValue (n := truncation))) ^
            coefficientValue recipe
              (left.coefficient.eval e) (right.coefficient.eval e)).prod := by
  rw [
    factors_guarded_operational,
    guarded_universal_obstruction]

end
