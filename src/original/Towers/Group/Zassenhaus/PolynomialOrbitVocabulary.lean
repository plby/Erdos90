/-- The retained-transversal trace at arbitrary cutoff.  The name emphasizes
that its semantic law remains a separate theorem above cutoff four. -/
noncomputable def retainedRecipeCoefficient
    (n : ℕ) :
    List (RetainedOrbitIndex n 1 1) :=
  recipeIndexTrace
    (recipeCoefficientRecipes n)
    (supported_coefficient_recipes n)

/-- Decoding the retained-transversal trace recovers its selected orbit keys
occurrence-for-occurrence and in inherited closure order. -/
lemma key_recipe_coefficient
    (n : ℕ) :
    (retainedRecipeCoefficient n).map
        retainedOrbitKey =
      (recipeCoefficientRecipes n).map
        ROAggreg.polynomialOrbitKey :=
  key_recipe_trace
    (recipeCoefficientRecipes n)
    (supported_coefficient_recipes n)

/--
The full finite-trace semantic law for the retained transversal is exactly its
ordered selected-recipe product theorem.
-/
theorem
    satisfies_fin_idx
    {d n : ℕ} :
    SatisfiesTruncatedEval.{u} (d := d)
        (retainedRecipeCoefficient n) ↔
      SatisfiesRecipeCoefficient.{u} d n := by
  constructor
  · intro htrace left right leftExponent rightExponent
    rw [←
      packets_recipe_packet
        (recipeCoefficientRecipes n)
        (supported_coefficient_recipes n)]
    exact htrace left right leftExponent rightExponent
  · intro hrecipes left right leftExponent rightExponent
    unfold retainedRecipeCoefficient
    rw [
      packets_recipe_packet]
    exact hrecipes left right leftExponent rightExponent

/-- A retained recipe-product recollection theorem supplies order-aware natural
alignment of the corresponding fixed trace with every collected endpoint. -/
noncomputable def
    occurrenceNaturalAlignment
    {d n : ℕ}
    (hrecipes :
      SatisfiesRecipeCoefficient.{u} d n) :
    SatisfiesOccurrenceAlignment.{u}
      (d := d) (by simp) (by simp)
        (retainedRecipeCoefficient n) :=
  occurrenceAlignmentSatisfies
    (retainedRecipeCoefficient n)
    (satisfies_fin_idx.mpr
      hrecipes)

/-- A retained recipe-product recollection theorem supplies the signed lift of
its endpoint-aligned fixed trace. -/
noncomputable def
    occurrenceAllLift
    {d n : ℕ}
    (kernel : OCShape)
    (hrecipes :
      SatisfiesRecipeCoefficient.{u} d n) :
    OccurrenceAllLift kernel
      (retainedRecipeCoefficient n)
      (occurrenceNaturalAlignment
        hrecipes) where
  listEval_eq := by
    intro left right leftExponent rightExponent
    simpa only [
      packets_occurrence_packet] using
        (satisfies_fin_idx.mpr
          hrecipes) left right leftExponent rightExponent

/--
The retained recipe-product recollection theorem is equivalent to the two
honest obligations needed by the operational endpoint route: natural
occurrence alignment and its signed extension.
-/
theorem
    satisfies_alignment_lift
    {d n : ℕ}
    (kernel : OCShape) :
    SatisfiesRecipeCoefficient.{u} d n ↔
      ∃ halignment :
          SatisfiesOccurrenceAlignment.{u}
            (d := d) (by simp) (by simp)
              (retainedRecipeCoefficient n),
        OccurrenceAllLift kernel
          (retainedRecipeCoefficient n) halignment := by
  rw [←
    satisfies_fin_idx]
  exact
    satisfies_idx_alignment
      kernel (retainedRecipeCoefficient n)

namespace TSInput

/--
A retained-transversal recipe-product recollection theorem instantiates the
Claim 5 coordinate-polynomial adapter through its operational endpoint trace.
-/
theorem
    coordCollectedOcc
    {d n inputWeight : ℕ}
    (hn : 2 ≤ n)
    (H : ∀ s : ℕ, BCWta.{u} d s)
    (hH :
      ∀ s : ℕ,
        1 ≤ s →
          s < n →
            (H s).FormsAssocGradedbasis (n := n))
    {kernel : OCShape}
    (hrecipes :
      SatisfiesRecipeCoefficient.{u} d n)
    {e : HEFam H}
    (input :
      TSInput
        (n := n) (inputWeight := inputWeight) H e)
    (hsourceSupported :
      SPFactora.WordWeightLeast inputWeight input.source)
    (factorNormalization :
      ∀ lowerWeight : ℕ,
        ¬n ≤ 2 * lowerWeight →
          TSNormalb
              (n := n) (inputWeight := inputWeight)
                (lowerWeight := lowerWeight + 1) H →
            ∀ (factor : SPFactora H inputWeight),
              factor.word.weight PEAddres.weight = lowerWeight →
              factor.word.weight PEAddres.weight < n →
            TANorm
              (n := n) (lowerWeight := lowerWeight) H factor)
    (hinputWeight : 1 ≤ inputWeight) :
    CollectedPolynomialData (n := n) H e inputWeight :=
  coordOccLift
    hn H hH (kernel := kernel)
      (retainedRecipeCoefficient n)
      (occurrenceNaturalAlignment
        hrecipes)
      (occurrenceAllLift
        kernel hrecipes)
      input hsourceSupported factorNormalization hinputWeight

end TSInput

