import Mathlib
import Towers.Group.PowerWidth.OpenNormal


open scoped Topology Pointwise

noncomputable section

namespace Towers

universe u
universe v w z

/-- The subgroup generated by `m`th powers is characteristic. -/
lemma powerSubgroup_characteristic
    (G : Type u) [Group G] (m : ℕ) :
    (powerSubgroup G m).Characteristic := by
  rw [Subgroup.characteristic_iff_map_le]
  intro ϕ
  rw [powerSubgroup, Subgroup.map_normalClosure _ ϕ.toMonoidHom ϕ.surjective]
  apply Subgroup.normalClosure_mono
  rintro _ ⟨_x, ⟨y, rfl⟩, rfl⟩
  exact ⟨ϕ y, by simp⟩
/-- Ordered product of `k` many `m`th powers. -/
def powerWidthProduct {G : Type u} [Monoid G] (m : ℕ) :
    (k : ℕ) → (Fin k → G) → G
  | 0, _ => 1
  | k + 1, f =>
      powerWidthProduct (G := G) m k (fun i : Fin k => f i.castSucc) *
        f (Fin.last k) ^ m
@[simp]
lemma power_width_zero
    {G : Type u} [Monoid G] (m : ℕ) (f : Fin 0 → G) :
    powerWidthProduct (G := G) m 0 f = 1 := rfl
@[simp]
lemma power_width_succ
    {G : Type u} [Monoid G] (m k : ℕ) (f : Fin (k + 1) → G) :
    powerWidthProduct (G := G) m (k + 1) f =
      powerWidthProduct (G := G) m k (fun i : Fin k => f i.castSucc) *
        f (Fin.last k) ^ m := rfl
/-- The set of ordered products of exactly `k` many `m`th powers. -/
def powerWidthSet (G : Type u) [Monoid G] (m k : ℕ) : Set G :=
  Set.range (powerWidthProduct (G := G) m k)
/-- The set of ordered products of at most `k` many `m`th powers. -/
def widthMostSet (G : Type u) [Monoid G] (m k : ℕ) : Set G :=
  ⋃ l : Fin (k + 1), powerWidthSet G m (l : ℕ)
/-- Every bounded product of `m`th powers lies in the subgroup generated by `m`th powers. -/
lemma power_width_product
    {G : Type u} [Group G] (m : ℕ) :
    ∀ k : ℕ, ∀ f : Fin k → G,
      powerWidthProduct (G := G) m k f ∈ powerSubgroup G m := by
  intro k
  induction k with
  | zero =>
      intro f
      simp [powerWidthProduct]
  | succ k ih =>
      intro f
      have hprefix :
          powerWidthProduct (G := G) m k
              (fun i : Fin k => f i.castSucc) ∈ powerSubgroup G m :=
        ih (fun i : Fin k => f i.castSucc)
      have hlast : f (Fin.last k) ^ m ∈ powerSubgroup G m := by
        exact pow_power_subgroup m (f (Fin.last k))
      simpa [powerWidthProduct] using
        (powerSubgroup G m).mul_mem hprefix hlast
/-- Exact-width power products are contained in `powerSubgroup`. -/
lemma width_set_subset
    {G : Type u} [Group G] (m k : ℕ) :
    powerWidthSet G m k ⊆
      ((powerSubgroup G m : Subgroup G) : Set G) := by
  rintro x ⟨f, rfl⟩
  exact power_width_product (G := G) m k f
/-- Bounded-width power products are contained in `powerSubgroup`. -/
lemma width_most_subset
    {G : Type u} [Group G] (m k : ℕ) :
    widthMostSet G m k ⊆
      ((powerSubgroup G m : Subgroup G) : Set G) := by
  intro x hx
  rw [widthMostSet] at hx
  rcases Set.mem_iUnion.mp hx with ⟨l, hl⟩
  exact width_set_subset (G := G) m (l : ℕ) hl
/-- The ordered product of `m`th powers is continuous. -/
lemma continuous_width_product
    {Γ : Type u} [Group Γ] [TopologicalSpace Γ] [IsTopologicalGroup Γ]
    (m : ℕ) :
    ∀ k : ℕ, Continuous (powerWidthProduct (G := Γ) m k) := by
  intro k
  induction k with
  | zero =>
      simpa [powerWidthProduct] using
        (continuous_const :
          Continuous (fun _ : Fin 0 → Γ => (1 : Γ)))
  | succ k ih =>
      have hprefix : Continuous (fun f : Fin (k + 1) → Γ =>
          powerWidthProduct (G := Γ) m k
            (fun i : Fin k => f i.castSucc)) := by
        exact ih.comp (continuous_pi fun i => continuous_apply i.castSucc)
      have hlast_apply : Continuous (fun f : Fin (k + 1) → Γ =>
          f (Fin.last k)) :=
        continuous_apply (Fin.last k)
      have hlast : Continuous (fun f : Fin (k + 1) → Γ =>
          f (Fin.last k) ^ m) :=
        hlast_apply.pow m
      simpa [powerWidthProduct] using hprefix.mul hlast
/-- Exact-width power-product sets are compact in a compact topological group. -/
lemma compact_width_set
    {Γ : Type u} [Group Γ] [TopologicalSpace Γ] [IsTopologicalGroup Γ]
    [CompactSpace Γ]
    (m k : ℕ) :
    IsCompact (powerWidthSet Γ m k) := by
  classical
  simpa [powerWidthSet] using
    (isCompact_univ.image
      (continuous_width_product (Γ := Γ) m k))
/-- Exact-width power-product sets are closed in a compact Hausdorff topological group. -/
lemma closed_width_set
    {Γ : Type u} [Group Γ] [TopologicalSpace Γ] [IsTopologicalGroup Γ]
    [CompactSpace Γ] [T2Space Γ]
    (m k : ℕ) :
    IsClosed (powerWidthSet Γ m k) := by
  exact (compact_width_set (Γ := Γ) m k).isClosed
/-- Bounded-width power-product sets are closed in a compact Hausdorff topological group. -/
lemma width_most_set
    {Γ : Type u} [Group Γ] [TopologicalSpace Γ] [IsTopologicalGroup Γ]
    [CompactSpace Γ] [T2Space Γ]
    (m k : ℕ) :
    IsClosed (widthMostSet Γ m k) := by
  classical
  simpa [widthMostSet] using
    (isClosed_iUnion_of_finite fun l : Fin (k + 1) =>
      closed_width_set (Γ := Γ) m (l : ℕ))
/-- The power word has finite width in `G`: every element generated by `m`th powers is a product
of uniformly bounded length. -/
def powerSubgroupWidth (G : Type u) [Group G] (m : ℕ) : Prop :=
  ∃ k : ℕ,
    ((powerSubgroup G m : Subgroup G) : Set G) ⊆
      widthMostSet G m k
/-- Convert a pointwise finite-width bound into the set-theoretic finite-width predicate. -/
lemma subgroup_width_bound
    {G : Type u} [Group G] {m : ℕ}
    (h :
      ∃ k : ℕ,
        ∀ x : G, x ∈ powerSubgroup G m →
          ∃ l : ℕ, l ≤ k ∧
            ∃ f : Fin l → G,
              powerWidthProduct (G := G) m l f = x) :
    powerSubgroupWidth G m := by
  rcases h with ⟨k, hk⟩
  refine ⟨k, ?_⟩
  intro x hx
  rcases hk x hx with ⟨l, hlk, f, hf⟩
  rw [widthMostSet]
  exact Set.mem_iUnion.mpr
    ⟨⟨l, Nat.lt_succ_of_le hlk⟩, ⟨f, hf⟩⟩
/-- Finite width of the power word makes `powerSubgroup` closed. -/
lemma power_closed_width
    {Γ : Type u} [Group Γ] [TopologicalSpace Γ] [IsTopologicalGroup Γ]
    [CompactSpace Γ] [T2Space Γ]
    {m : ℕ}
    (hwidth : powerSubgroupWidth Γ m) :
    IsClosed ((powerSubgroup Γ m : Subgroup Γ) : Set Γ) := by
  rcases hwidth with ⟨k, hk⟩
  have hsub :
      widthMostSet Γ m k ⊆
        ((powerSubgroup Γ m : Subgroup Γ) : Set Γ) :=
    width_most_subset (G := Γ) m k
  have heq :
      ((powerSubgroup Γ m : Subgroup Γ) : Set Γ) =
        widthMostSet Γ m k :=
    Set.Subset.antisymm hk hsub
  rw [heq]
  exact width_most_set (Γ := Γ) m k
/-- A finite-width family gives the closedness family needed by the Zassenhaus separation
reduction. -/
lemma closed_family_width
    {Γ : Type u} [Group Γ] [TopologicalSpace Γ] [IsTopologicalGroup Γ]
    [CompactSpace Γ] [T2Space Γ]
    (hwidth : ∀ m : ℕ, 1 < m → powerSubgroupWidth Γ m) :
    ∀ m : ℕ, 1 < m →
      IsClosed ((powerSubgroup Γ m : Subgroup Γ) : Set Γ) := by
  intro m hm
  exact power_closed_width (Γ := Γ) (m := m) (hwidth m hm)
/-- The quotient by the subgroup generated by `m`th powers has exponent dividing `m`. -/
lemma power_pow_one
    (G : Type u) [Group G] (m : ℕ) :
    letI : (powerSubgroup G m).Normal := powerSubgroup_normal G m
    ∀ x : G ⧸ powerSubgroup G m, x ^ m = 1 := by
  let P : Subgroup G := powerSubgroup G m
  letI : P.Normal := by
    dsimp [P]
    exact powerSubgroup_normal G m
  intro x
  rcases QuotientGroup.mk'_surjective P x with ⟨g, rfl⟩
  change (QuotientGroup.mk' P g) ^ m = 1
  rw [← map_pow]
  exact (QuotientGroup.eq_one_iff (N := P) (g ^ m)).mpr
    (by
      dsimp [P, powerSubgroup]
      exact Subgroup.subset_normalClosure ⟨g, rfl⟩)
/-- For positive `m`, the power-subgroup quotient is a torsion group. -/
lemma power_subgroup_torsion
    (G : Type u) [Group G] {m : ℕ}
    (hm : 0 < m) :
    letI : (powerSubgroup G m).Normal := powerSubgroup_normal G m
    Monoid.IsTorsion (G ⧸ powerSubgroup G m) := by
  letI : (powerSubgroup G m).Normal := powerSubgroup_normal G m
  intro x
  exact isOfFinOrder_iff_pow_eq_one.mpr
    ⟨m, hm, power_pow_one G m x⟩
/-- Finite dense generators remain dense after quotienting by any normal subgroup. -/
lemma dense_generators
    {Γ : Type u} [Group Γ] [TopologicalSpace Γ] [IsTopologicalGroup Γ]
    {Hq : Subgroup Γ} [Hq.Normal]
    {d : ℕ} (s : Fin d → Γ)
    (hs : Subgroup.topologicalClosure (Subgroup.closure (Set.range s)) = ⊤) :
    closure
        (((Subgroup.closure
          (Set.range
            (fun i : Fin d =>
              QuotientGroup.mk' Hq (s i)))) :
            Subgroup (Γ ⧸ Hq)) :
          Set (Γ ⧸ Hq)) =
      Set.univ := by
  let q : Γ →* Γ ⧸ Hq := QuotientGroup.mk' Hq
  let H : Subgroup Γ := Subgroup.closure (Set.range s)
  let K : Subgroup (Γ ⧸ Hq) :=
    Subgroup.closure (Set.range fun i : Fin d => q (s i))
  have hq_cont : Continuous (fun g : Γ => q g) := by
    dsimp [q]
    change Continuous (QuotientGroup.mk : Γ → Γ ⧸ Hq)
    exact QuotientGroup.continuous_mk
  have hq_dense : DenseRange (fun g : Γ => q g) :=
    (QuotientGroup.mk'_surjective Hq).denseRange
  have hH_closure :
      closure ((H : Subgroup Γ) : Set Γ) = Set.univ := by
    simpa [H, Subgroup.topologicalClosure_coe] using
      congrArg (fun L : Subgroup Γ => (L : Set Γ)) hs
  have hH_dense : Dense ((H : Subgroup Γ) : Set Γ) := by
    rw [dense_iff_closure_eq]
    exact hH_closure
  have hqH_dense :
      Dense (q '' ((H : Subgroup Γ) : Set Γ)) :=
    hq_dense.dense_image hq_cont hH_dense
  have himage_subset :
      q '' ((H : Subgroup Γ) : Set Γ) ⊆ (K : Set (Γ ⧸ Hq)) := by
    rintro y ⟨x, hx, rfl⟩
    change q x ∈ K
    change x ∈ H at hx
    dsimp [H] at hx
    refine Subgroup.closure_induction (k := Set.range s) ?mem ?one ?mul ?inv hx
    · intro x hx
      rcases hx with ⟨i, rfl⟩
      exact Subgroup.subset_closure ⟨i, rfl⟩
    · simpa only [map_one] using K.one_mem
    · intro x y _hx _hy hxK hyK
      simpa using K.mul_mem hxK hyK
    · intro x _hx hxK
      simpa using K.inv_mem hxK
  simpa [K, q] using (hqH_dense.mono himage_subset).closure_eq
/-- Finite dense generators remain dense after quotienting by a power subgroup. -/
lemma dense_generators_quotient
    {Γ : Type u} [Group Γ] [TopologicalSpace Γ] [IsTopologicalGroup Γ]
    {d : ℕ} (s : Fin d → Γ)
    (hs : Subgroup.topologicalClosure (Subgroup.closure (Set.range s)) = ⊤)
    (m : ℕ) :
    letI : (powerSubgroup Γ m).Normal := powerSubgroup_normal Γ m
    closure
        (((Subgroup.closure
          (Set.range
            (fun i : Fin d =>
              QuotientGroup.mk' (powerSubgroup Γ m) (s i)))) :
            Subgroup (Γ ⧸ powerSubgroup Γ m)) :
          Set (Γ ⧸ powerSubgroup Γ m)) =
      Set.univ := by
  let P : Subgroup Γ := powerSubgroup Γ m
  letI : P.Normal := by
    dsimp [P]
    exact powerSubgroup_normal Γ m
  let q : Γ →* Γ ⧸ P := QuotientGroup.mk' P
  let H : Subgroup Γ := Subgroup.closure (Set.range s)
  let K : Subgroup (Γ ⧸ P) :=
    Subgroup.closure (Set.range fun i : Fin d => q (s i))
  have hq_cont : Continuous (fun g : Γ => q g) := by
    dsimp [q]
    change Continuous (QuotientGroup.mk : Γ → Γ ⧸ P)
    exact QuotientGroup.continuous_mk
  have hq_dense : DenseRange (fun g : Γ => q g) :=
    (QuotientGroup.mk'_surjective P).denseRange
  have hH_closure :
      closure ((H : Subgroup Γ) : Set Γ) = Set.univ := by
    simpa [H, Subgroup.topologicalClosure_coe] using
      congrArg (fun L : Subgroup Γ => (L : Set Γ)) hs
  have hH_dense : Dense ((H : Subgroup Γ) : Set Γ) := by
    rw [dense_iff_closure_eq]
    exact hH_closure
  have hqH_dense :
      Dense (q '' ((H : Subgroup Γ) : Set Γ)) :=
    hq_dense.dense_image hq_cont hH_dense
  have himage_subset :
      q '' ((H : Subgroup Γ) : Set Γ) ⊆ (K : Set (Γ ⧸ P)) := by
    rintro y ⟨x, hx, rfl⟩
    change q x ∈ K
    change x ∈ H at hx
    dsimp [H] at hx
    refine Subgroup.closure_induction (k := Set.range s) ?mem ?one ?mul ?inv hx
    · intro x hx
      rcases hx with ⟨i, rfl⟩
      exact Subgroup.subset_closure ⟨i, rfl⟩
    · simpa only [map_one] using K.one_mem
    · intro x y _hx _hy hxK hyK
      simpa using K.mul_mem hxK hyK
    · intro x _hx hxK
      simpa using K.inv_mem hxK
  simpa [K, q, P] using (hqH_dense.mono himage_subset).closure_eq
/-- A closed power subgroup with finite quotient is open in a compact topological group. -/
lemma power_open_closed
    (G : Type u) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [CompactSpace G] (m : ℕ)
    (hclosed : IsClosed ((powerSubgroup G m : Subgroup G) : Set G))
    (hfinite :
      letI : (powerSubgroup G m).Normal := powerSubgroup_normal G m
      Finite (G ⧸ powerSubgroup G m)) :
    IsOpen ((powerSubgroup G m : Subgroup G) : Set G) := by
  let P : Subgroup G := powerSubgroup G m
  letI : P.Normal := by
    dsimp [P]
    exact powerSubgroup_normal G m
  haveI : Finite (G ⧸ P) := by
    simpa [P] using hfinite
  haveI : P.FiniteIndex := Subgroup.finiteIndex_of_finite_quotient
  exact P.isOpen_of_isClosed_of_finiteIndex (by simpa [P] using hclosed)
/-- Closedness plus finite quotient packages a power subgroup as an open normal subgroup. -/
lemma open_normal_closed
    (G : Type u) [Group G] [TopologicalSpace G] [IsTopologicalGroup G]
    [CompactSpace G] (m : ℕ)
    (hclosed : IsClosed ((powerSubgroup G m : Subgroup G) : Set G))
    (hfinite :
      letI : (powerSubgroup G m).Normal := powerSubgroup_normal G m
      Finite (G ⧸ powerSubgroup G m)) :
    ∃ N : OpenNormalSubgroup G,
      N.toSubgroup ≤ powerSubgroup G m := by
  have hopen : IsOpen ((powerSubgroup G m : Subgroup G) : Set G) :=
    power_open_closed
      G m hclosed hfinite
  let N : OpenNormalSubgroup G :=
    { toOpenSubgroup :=
        { toSubgroup := powerSubgroup G m
          isOpen' := hopen }
      isNormal' := powerSubgroup_normal G m }
  exact ⟨N, by intro x hx; simpa [N] using hx⟩
end Towers
