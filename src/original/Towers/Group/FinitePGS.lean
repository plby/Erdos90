namespace Towers


lemma simple_coatom_p
    {p : ℕ} [Fact p.Prime] {G : Type*} [Group G] [Finite G]
    (_hG : IsPGroup p G) {M : Subgroup G} [M.Normal] (hM : IsCoatom M) :
    IsSimpleGroup (G ⧸ M) := by
  refine
    { toNontrivial := (QuotientGroup.nontrivial_iff.mpr hM.1)
      eq_bot_or_eq_top_of_normal := ?_ }
  intro N hN
  have hle : M ≤ Subgroup.comap (QuotientGroup.mk' M) N :=
    QuotientGroup.le_comap_mk' M N
  by_cases hcomap : Subgroup.comap (QuotientGroup.mk' M) N = M
  · left
    calc
      N = (Subgroup.comap (QuotientGroup.mk' M) N).map (QuotientGroup.mk' M) := by
            symm
            exact Subgroup.map_comap_eq_self_of_surjective (QuotientGroup.mk'_surjective M) N
      _ = M.map (QuotientGroup.mk' M) := by rw [hcomap]
      _ = ⊥ := QuotientGroup.map_mk'_self M
  · right
    have htop : Subgroup.comap (QuotientGroup.mk' M) N = ⊤ :=
      hM.2 _ (lt_of_le_of_ne hle (Ne.symm hcomap))
    calc
      N = (Subgroup.comap (QuotientGroup.mk' M) N).map (QuotientGroup.mk' M) := by
            symm
            exact Subgroup.map_comap_eq_self_of_surjective (QuotientGroup.mk'_surjective M) N
      _ = ⊤ := by
            rw [htop]
            exact Subgroup.map_top_of_surjective _ (QuotientGroup.mk'_surjective M)

lemma coatom_p_group
    {p : ℕ} [Fact p.Prime] {G : Type*} [Group G] [Finite G]
    (hG : IsPGroup p G) {M : Subgroup G} [M.Normal] (hM : IsCoatom M) :
    Nat.card (G ⧸ M) = p := by
  letI : IsSimpleGroup (G ⧸ M) :=
    simple_coatom_p hG hM
  letI : Group.IsNilpotent (G ⧸ M) := (hG.to_quotient M).isNilpotent
  have hprime : (Nat.card (G ⧸ M)).Prime := IsSimpleGroup.prime_card
  obtain ⟨n, hn⟩ := IsPGroup.iff_card.mp (hG.to_quotient M)
  exact ((Nat.Prime.pow_eq_iff hprime).mp hn.symm).1.symm

lemma commutator_coatom_group
    {p : ℕ} [Fact p.Prime] {G : Type*} [Group G] [Finite G]
    (hG : IsPGroup p G) {M : Subgroup G} [M.Normal] (hM : IsCoatom M) :
    _root_.commutator G ≤ M := by
  rw [← Subgroup.Normal.quotient_commutative_iff_commutator_le]
  let hcard := coatom_p_group hG hM
  exact (isCyclic_of_prime_card hcard).isMulCommutative

lemma pow_coatom_group
    {p : ℕ} [Fact p.Prime] {G : Type*} [Group G] [Finite G]
    (hG : IsPGroup p G) {M : Subgroup G} [M.Normal] (hM : IsCoatom M) (g : G) :
    g ^ p ∈ M := by
  have hcard := coatom_p_group hG hM
  have hpow : (QuotientGroup.mk' M g) ^ p = 1 := by
    simpa [hcard] using (pow_card_eq_one' (x := QuotientGroup.mk' M g))
  exact (QuotientGroup.eq_one_iff _).mp hpow

/--
For a finite `p`-group, every maximal subgroup contains the commutator subgroup, so the
commutator subgroup lies in the Frattini subgroup.
-/
theorem commutator_frattini_group
    {p : ℕ} [Fact p.Prime] {G : Type*} [Group G] [Finite G]
    (hG : IsPGroup p G) :
    _root_.commutator G ≤ frattini G := by
  intro g hg
  rw [frattini, Order.radical]
  simp only [Subgroup.mem_iInf]
  intro M
  simp only [Set.mem_setOf_eq]
  intro hM
  letI : M.Normal :=
    Subgroup.NormalizerCondition.normal_of_coatom
      (G := G) (H := M)
      (hnc := Group.normalizerCondition_of_isNilpotent (G := G) (h := hG.isNilpotent)) hM
  exact commutator_coatom_group hG hM hg

/--
For a finite `p`-group, every `p`-th power lies in the Frattini subgroup.
-/
theorem frattini_p_group
    {p : ℕ} [Fact p.Prime] {G : Type*} [Group G] [Finite G]
    (hG : IsPGroup p G) (g : G) :
    g ^ p ∈ frattini G := by
  rw [frattini, Order.radical]
  simp only [Subgroup.mem_iInf]
  intro M
  simp only [Set.mem_setOf_eq]
  intro hM
  letI : M.Normal :=
    Subgroup.NormalizerCondition.normal_of_coatom
      (G := G) (H := M)
      (hnc := Group.normalizerCondition_of_isNilpotent (G := G) (h := hG.isNilpotent)) hM
  exact pow_coatom_group hG hM g

namespace NPP

/-- A finite nontrivial `p`-group has a finite generating set. -/
theorem generatorCounts_nonempty (P : NPP) :
    P.GeneratorCounts.Nonempty := by
  classical
  letI := P.instGroup
  letI := P.instFinite
  have hfg : Group.FG P.carrier := inferInstance
  rcases (Group.fg_iff_exists_freeGroup_hom_surjective_finite (G := P.carrier)).mp hfg with
    ⟨α, _, φ, hφ⟩
  letI : Fintype α := Fintype.ofFinite α
  let e : α ≃ Fin (Fintype.card α) := Fintype.equivFin α
  refine ⟨Fintype.card α, ?_⟩
  refine ⟨φ.comp (FreeGroup.freeGroupCongr e.symm).toMonoidHom, ?_⟩
  exact hφ.comp (FreeGroup.freeGroupCongr e.symm).surjective

/-- The minimal generator rank is realized by an actual surjection. -/
theorem generator_rank_counts (P : NPP) :
    P.generatorRank ∈ P.GeneratorCounts :=
  Nat.sInf_mem (s := P.GeneratorCounts) P.generatorCounts_nonempty

/-- A nontrivial finite `p`-group cannot be generated by zero generators. -/
theorem not_generator_counts (P : NPP) :
    0 ∉ P.GeneratorCounts := by
  classical
  letI := P.instGroup
  intro hzero
  rcases hzero with ⟨φ, hφ⟩
  haveI : Subsingleton (FreeGroup (Fin 0)) := by infer_instance
  haveI : Subsingleton P.carrier := Function.Surjective.subsingleton hφ
  exact false_of_nontrivial_of_subsingleton P.carrier

/-- The minimal number of generators of a finite nontrivial `p`-group is positive. -/
theorem generatorRank_pos (P : NPP) :
    1 ≤ P.generatorRank := by
  have hmem := P.generator_rank_counts
  have hne : P.generatorRank ≠ 0 := by
    intro h0
    exact P.not_generator_counts (h0 ▸ hmem)
  exact Nat.succ_le_of_lt (Nat.pos_of_ne_zero hne)

/--
The kernel of a surjection from the free group on a minimal generating set is a
finite-index subgroup of a finitely generated free group, hence finitely
generated; choosing generators for that kernel yields a finite relator family.
-/
theorem relationCounts_nonempty (P : NPP) :
    P.RelationCounts.Nonempty := by
  classical
  letI := P.instGroup
  letI := P.instFinite
  rcases P.generator_rank_counts with ⟨φ, hφ⟩
  have hker_fg_group : Group.FG φ.ker := by infer_instance
  have hker_fg : φ.ker.FG := (Group.fg_iff_subgroup_fg φ.ker).mp hker_fg_group
  rcases hker_fg with ⟨S, hS⟩
  let e : {x // x ∈ S} ≃ Fin (Fintype.card {x // x ∈ S}) := Fintype.equivFin {x // x ∈ S}
  let rels : Fin (Fintype.card {x // x ∈ S}) → FreeGroup (Fin P.generatorRank) :=
    fun i => (e.symm i).1
  have hrange : Set.range rels = (↑S : Set (FreeGroup (Fin P.generatorRank))) := by
    ext x
    constructor
    · rintro ⟨i, rfl⟩
      exact (e.symm i).2
    · intro hx
      refine ⟨e ⟨x, hx⟩, ?_⟩
      simp [rels]
  refine ⟨Fintype.card {x // x ∈ S}, ?_⟩
  refine ⟨rels, ?_⟩
  refine ⟨?_⟩
  let hclosure : Subgroup.normalClosure (Set.range rels) = φ.ker := by
    calc
      Subgroup.normalClosure (Set.range rels)
          = Subgroup.normalClosure (↑S : Set (FreeGroup (Fin P.generatorRank))) := by
              rw [hrange]
      _ =
          Subgroup.normalClosure
            ↑(Subgroup.closure (↑S : Set (FreeGroup (Fin P.generatorRank)))) := by
            rw [Subgroup.normalClosure_closure_eq_normalClosure]
      _ = Subgroup.normalClosure (↑φ.ker : Set (FreeGroup (Fin P.generatorRank))) := by
            rw [hS]
      _ = φ.ker := Subgroup.normalClosure_eq_self _
  simpa [PresentedGroup] using
    (QuotientGroup.quotientMulEquivOfEq hclosure).trans
      (QuotientGroup.quotientKerEquivOfSurjective φ hφ)

/-- The minimal relation rank is realized by an actual finite relator family. -/
theorem relation_rank_counts (P : NPP) :
    P.relationRank ∈ P.RelationCounts :=
  Nat.sInf_mem (s := P.RelationCounts) P.relationCounts_nonempty

/--
There is no zero-relator presentation on a minimal generating set for a finite
nontrivial `p`-group: such a presentation would identify the group with a free
group, but minimality of the generating rank forces that free group to have at
least one generator and hence be infinite.
-/
theorem not_relation_counts (P : NPP) :
    0 ∉ P.RelationCounts := by
  classical
  letI := P.instGroup
  letI := P.instFinite
  intro hzero
  rcases hzero with ⟨rels, ⟨e⟩⟩
  have hrange : Set.range rels = (∅ : Set (FreeGroup (Fin P.generatorRank))) := by
    ext x
    simp
  have hfree : PresentedGroup (Set.range rels) ≃* FreeGroup (Fin P.generatorRank) := by
    let hN :
        Subgroup.normalClosure (Set.range rels) =
          (⊥ : Subgroup (FreeGroup (Fin P.generatorRank))) := by
      rw [hrange, Subgroup.normalClosure_empty]
    exact (QuotientGroup.quotientMulEquivOfEq hN).trans
      (QuotientGroup.quotientBot (G := FreeGroup (Fin P.generatorRank)))
  have hpos : 0 < P.generatorRank := Nat.succ_le_iff.mp P.generatorRank_pos
  haveI : Nonempty (Fin P.generatorRank) := Fin.pos_iff_nonempty.mp hpos
  haveI : Finite (FreeGroup (Fin P.generatorRank)) :=
    Finite.of_equiv P.carrier (e.symm.trans hfree).toEquiv
  exact Infinite.false (show Infinite (FreeGroup (Fin P.generatorRank)) from inferInstance)

/-- The minimal number of relations in a minimal-generator presentation is positive. -/
theorem relationRank_pos (P : NPP) :
    1 ≤ P.relationRank := by
  have hmem := P.relation_rank_counts
  have hne : P.relationRank ≠ 0 := by
    intro h0
    exact P.not_relation_counts (h0 ▸ hmem)
  exact Nat.succ_le_of_lt (Nat.pos_of_ne_zero hne)

/--
A finite nontrivial `p`-group with generator rank `2` must have relation rank
at least `2`: otherwise it would has a two-generator one-relator
presentation, hence be infinite by `twoRelatorInfinite`.
-/
theorem relation_rank_infinite
    (P : NPP)
    (hgen : P.generatorRank = 2) :
    2 ≤ P.relationRank := by
  have hpos := P.relationRank_pos
  by_contra hlt
  have h1 : P.relationRank = 1 := by omega
  have hmem := P.relation_rank_counts
  have hmem1 :
      ∃ rels : Fin 1 → FreeGroup (Fin P.generatorRank),
        Nonempty (PresentedGroup (Set.range rels) ≃* P.carrier) := by
    simpa [NPP.RelationCounts, h1] using hmem
  rcases hmem1 with ⟨rels, ⟨e⟩⟩
  let egen : Fin P.generatorRank ≃ Fin 2 := finCongr hgen
  let rels' : Fin 1 → FreeGroup (Fin 2) := fun i => FreeGroup.freeGroupCongr egen (rels i)
  have hrange' :
      Set.range rels' = (FreeGroup.freeGroupCongr egen) '' Set.range rels := by
    ext x
    constructor
    · rintro ⟨i, rfl⟩
      exact ⟨rels i, ⟨i, rfl⟩, rfl⟩
    · rintro ⟨x, ⟨i, rfl⟩, rfl⟩
      exact ⟨i, rfl⟩
  have eimg : PresentedGroup ((FreeGroup.freeGroupCongr egen) '' Set.range rels) ≃* P.carrier :=
    (PresentedGroup.equivPresentedGroup (Set.range rels) egen).symm.trans e
  have e0 : PresentedGroup (Set.range rels') ≃* P.carrier := by
    rw [hrange']
    exact eimg
  let w : FreeGroup (Fin 2) := rels' 0
  have hrange : Set.range rels' = ({w} : Set (FreeGroup (Fin 2))) := by
    ext x
    constructor
    · rintro ⟨i, rfl⟩
      fin_cases i
      simp [w]
    · intro hx
      simp only [Set.mem_singleton_iff] at hx
      refine ⟨0, ?_⟩
      simpa [w] using hx.symm
  have e' : PresentedGroup ({w} : Set (FreeGroup (Fin 2))) ≃* P.carrier := by
    rw [hrange] at e0
    exact e0
  haveI : Finite (PresentedGroup ({w} : Set (FreeGroup (Fin 2)))) :=
    Finite.of_equiv P.carrier e'.symm.toEquiv
  exact Infinite.false (GShafar.twoRelatorInfinite w)

end NPP

/-- The minimal number of generators of the underlying finite `p`-group is positive. -/
theorem PPDatum.generatorRank_pos (H : PPDatum) :
    1 ≤ H.generatorRank := by
  simpa [PPDatum.generatorRank] using
    H.realizesFiniteNontrivial.generatorRank_pos

/-- The minimal number of relations in a minimal-generator presentation is positive. -/
theorem PPDatum.relationRank_pos (H : PPDatum) :
    1 ≤ H.relationRank := by
  simpa [PPDatum.relationRank] using
    H.realizesFiniteNontrivial.relationRank_pos

/--
The `d = 2` small-generator relation-rank bound follows from the one-relator
infinitude input.
-/
theorem PPDatum.relation_rank_infinite
    (H : PPDatum)
    (hgen : H.generatorRank = 2) :
    2 ≤ H.relationRank := by
  simpa [PPDatum.generatorRank, PPDatum.relationRank] using
    H.realizesFiniteNontrivial.relation_rank_infinite
      hgen

/--
Package the extra hypotheses still needed to derive the Golod--Shafarevich
inequality from the abstract finite pro-`p` group data in the imported source.
-/
def PPDatum.golod_shafarevich_datum
    (H : PPDatum)
    (hgs : ∀ t : ℝ, 0 < t → t < 1 →
      0 < GShafar.polynomial H.generatorRank H.relationRank t) :
    GShafar.FinitePresentationDatum where
  generatorRank := H.generatorRank
  relationRank := H.relationRank
  relationRank_pos := H.relationRank_pos
  relation_rank_two :=
    H.relation_rank_infinite
  gs_positive := hgs

/--
Golod--Shafarevich, reduced to the remaining Hilbert-series input:

positivity of the Golod--Shafarevich quadratic on `(0, 1)`.
-/
theorem golod_shafarevich_bounds
    (H : PPDatum)
    (hgs : ∀ t : ℝ, 0 < t → t < 1 →
      0 < GShafar.polynomial H.generatorRank H.relationRank t) :
    (H.relationRank : ℝ) > (H.generatorRank : ℝ) ^ (2 : ℕ) / 4 := by
  exact GShafar.inequality
    (H.golod_shafarevich_datum hgs)

/--
The exact remaining Hilbert-series input for a finite pro-`p` group, stated in the
depth-counted form closest to the classical Golod--Shafarevich proof.
-/
def PPDatum.PRSeries (H : PPDatum) : Prop :=
  GShafar.PositiveRelationWitness H.generatorRank H.relationRank

/--
The local Zassenhaus filtration on the abstract free group used by a minimal
presentation of `H`.

This reuses the concrete filtration definition already present above; what
is still missing is the classical bridge showing that relators lying at these
depths force positivity of the associated Golod--Shafarevich relation series.
-/
abbrev PPDatum.relatorZassenhausFiltration
    (H : PPDatum) (n : ℕ) :
    Subgroup (FreeGroup (Fin H.generatorRank)) :=
  zassenhausFiltration
    H.realizesFiniteNontrivial.p
    (FreeGroup (Fin H.generatorRank))
    n

/--
The minimal presentation part of the remaining bridge is already available from
the current finite pro-`p` abstractions: `relationRank` is defined by taking the
least size of a relator family presenting `H` on exactly `generatorRank`
generators.
-/
theorem PPDatum.minimalPresentationExists (H : PPDatum) :
    ∃ rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank),
      Nonempty (PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier) := by
  simpa [PPDatum.generatorRank, PPDatum.relationRank] using
    H.realizesFiniteNontrivial.relation_rank_counts

/--
A concrete minimal presentation of `H` together with a chosen Zassenhaus depth
for each minimal relator.

This is the exact kind of finite input the classical Hilbert-series argument
consumes before producing positivity of
`1 - d t + Σ_i t^(depth i)`.
-/
def PPDatum.MinPresZassdepths
    (H : PPDatum) : Prop :=
  ∃ rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank),
    Nonempty (PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier) ∧
    ∃ depth : Fin H.relationRank → ℕ,
      (∀ i, rels i ∈ H.relatorZassenhausFiltration (depth i)) ∧
      (∀ i, 2 ≤ depth i)

/--
Relators equipped with declared Zassenhaus depths already give concrete
augmentation-ideal relations in the free-group algebra over `ZMod p`.
-/
theorem PPDatum.relatordiffere_memaug_idealpow
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {depth : Fin H.relationRank → ℕ}
    (hmem : ∀ i, rels i ∈ H.relatorZassenhausFiltration (depth i)) :
    ∀ i,
      MonoidAlgebra.of (ZMod H.realizesFiniteNontrivial.p)
          (FreeGroup (Fin H.generatorRank)) (rels i) - 1 ∈
        GShafar.augmentationIdeal
            (R := ZMod H.realizesFiniteNontrivial.p)
            (G := FreeGroup (Fin H.generatorRank)) ^ depth i := by
  intro i
  have hi : rels i ∈ GShafar.augmentationPowerSubgroup
      (R := ZMod H.realizesFiniteNontrivial.p)
      (G := FreeGroup (Fin H.generatorRank)) (depth i) := by
    exact GShafar.zassenhaus_filtration_subgroup
      (p := H.realizesFiniteNontrivial.p)
      (G := FreeGroup (Fin H.generatorRank)) (depth i) (hmem i)
  exact hi

/--
The same depth data also identifies the relator differences as elements killed
by the quotient map to the presented group algebra.

This is the local algebra package immediately preceding the usual Hilbert-series
argument: each `of (rels i) - 1` both lies in the claimed augmentation-ideal
power and vanishes in the presented algebra.
-/
theorem PPDatum.relatordiffere_memaugideal_powpreszero
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {depth : Fin H.relationRank → ℕ}
    (hmem : ∀ i, rels i ∈ H.relatorZassenhausFiltration (depth i)) :
    ∀ i,
      let x : MonoidAlgebra (ZMod H.realizesFiniteNontrivial.p)
          (FreeGroup (Fin H.generatorRank)) :=
        MonoidAlgebra.of (ZMod H.realizesFiniteNontrivial.p)
          (FreeGroup (Fin H.generatorRank)) (rels i) - 1
      x ∈ GShafar.augmentationIdeal
            (R := ZMod H.realizesFiniteNontrivial.p)
            (G := FreeGroup (Fin H.generatorRank)) ^ depth i ∧
        GShafar.presentedAlgebra
            (R := ZMod H.realizesFiniteNontrivial.p) (Set.range rels) x = 0 := by
  intro i
  dsimp
  refine ⟨H.relatordiffere_memaug_idealpow hmem i, ?_⟩
  exact RingHom.mem_ker.mp
    (GShafar.relator_presented_algebra
      (R := ZMod H.realizesFiniteNontrivial.p)
      (rels := Set.range rels) (r := rels i) (Set.mem_range_self i))

/--
If the relators come with declared depths `depth i`, then the ideal generated by
all relator differences lies in any augmentation-ideal power dominated by those
depths.

This is the sharpest local quotient-algebra bridge currently available on the
free side: the free-group algebra modulo the relator-difference ideal surjects
onto every truncated augmentation quotient `A / I^n` allowed by the depth
bounds.
-/
theorem PPDatum.relatordiffere_idealle_augidealpow
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {depth : Fin H.relationRank → ℕ}
    {n : ℕ}
    (hmem : ∀ i, rels i ∈ H.relatorZassenhausFiltration (depth i))
    (hn : ∀ i, n ≤ depth i) :
    GShafar.relatorDifferenceIdeal
        (R := ZMod H.realizesFiniteNontrivial.p) rels ≤
      GShafar.augmentationIdeal
          (R := ZMod H.realizesFiniteNontrivial.p)
          (G := FreeGroup (Fin H.generatorRank)) ^ n := by
  intro x hx
  change x ∈ TwoSidedIdeal.span
      (Set.range fun i =>
        MonoidAlgebra.of (ZMod H.realizesFiniteNontrivial.p)
          (FreeGroup (Fin H.generatorRank)) (rels i) - 1) at hx
  have hspan :
      TwoSidedIdeal.span
          (Set.range fun i =>
            MonoidAlgebra.of (ZMod H.realizesFiniteNontrivial.p)
              (FreeGroup (Fin H.generatorRank)) (rels i) - 1) ≤
        (GShafar.augmentationIdeal
            (R := ZMod H.realizesFiniteNontrivial.p)
            (G := FreeGroup (Fin H.generatorRank)) ^ n).toTwoSided := by
    rw [TwoSidedIdeal.span_le]
    rintro _ ⟨i, rfl⟩
    simpa using (Ideal.pow_le_pow_right (hn i))
      (H.relatordiffere_memaug_idealpow hmem i)
  simpa using hspan hx

/--
With depth bounds `n ≤ depth i`, the quotient of the free-group algebra by the
relator-difference ideal surjects onto the `n`th augmentation quotient `A / I^n`.
-/
abbrev PPDatum.relatordiffere_quotaug_idealpowquot
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {depth : Fin H.relationRank → ℕ}
    {n : ℕ}
    (hmem : ∀ i, rels i ∈ H.relatorZassenhausFiltration (depth i))
    (hn : ∀ i, n ≤ depth i) :
    MonoidAlgebra (ZMod H.realizesFiniteNontrivial.p)
        (FreeGroup (Fin H.generatorRank)) ⧸
        GShafar.relatorDifferenceIdeal
          (R := ZMod H.realizesFiniteNontrivial.p) rels →+*
      MonoidAlgebra (ZMod H.realizesFiniteNontrivial.p)
          (FreeGroup (Fin H.generatorRank)) ⧸
        GShafar.augmentationIdeal
          (R := ZMod H.realizesFiniteNontrivial.p)
          (G := FreeGroup (Fin H.generatorRank)) ^ n :=
  Ideal.Quotient.factor (H.relatordiffere_idealle_augidealpow hmem hn)

theorem PPDatum.relatordiffere_quotaugideal_powquotsurj
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {depth : Fin H.relationRank → ℕ}
    {n : ℕ}
    (hmem : ∀ i, rels i ∈ H.relatorZassenhausFiltration (depth i))
    (hn : ∀ i, n ≤ depth i) :
    Function.Surjective
      (PPDatum.relatordiffere_quotaug_idealpowquot
        H hmem hn) := by
  exact Ideal.Quotient.factor_surjective
    (H.relatordiffere_idealle_augidealpow hmem hn)

/--
With the usual Golod--Shafarevich lower bound `2 ≤ depth i`, the whole relator-difference ideal
already lies in the square `I²` of the augmentation ideal.
-/
theorem PPDatum.relatordiffere_idealle_augidealsq
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {depth : Fin H.relationRank → ℕ}
    (hmem : ∀ i, rels i ∈ H.relatorZassenhausFiltration (depth i))
    (hdepth : ∀ i, 2 ≤ depth i) :
    GShafar.relatorDifferenceIdeal
        (R := ZMod H.realizesFiniteNontrivial.p) rels ≤
      GShafar.augmentationIdeal
          (R := ZMod H.realizesFiniteNontrivial.p)
          (G := FreeGroup (Fin H.generatorRank)) ^ 2 := by
  exact H.relatordiffere_idealle_augidealpow hmem hdepth

/--
Under depth bounds `2 ≤ depth i`, the relator-difference ideal sits simultaneously inside `I²`
and inside the kernel of the canonical map to the presented-group algebra.
-/
theorem PPDatum.reladiffidea_leinfaug_idealsqker
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {depth : Fin H.relationRank → ℕ}
    (hmem : ∀ i, rels i ∈ H.relatorZassenhausFiltration (depth i))
    (hdepth : ∀ i, 2 ≤ depth i) :
    GShafar.relatorDifferenceIdeal
        (R := ZMod H.realizesFiniteNontrivial.p) rels ≤
      GShafar.augmentationIdeal
          (R := ZMod H.realizesFiniteNontrivial.p)
          (G := FreeGroup (Fin H.generatorRank)) ^ 2 ⊓
        RingHom.ker
          (GShafar.presentedAlgebra
            (R := ZMod H.realizesFiniteNontrivial.p) (Set.range rels)) := by
  refine le_inf ?_ ?_
  · exact H.relatordiffere_idealle_augidealsq hmem hdepth
  · exact
      GShafar.difference_presented_algebra
        (R := ZMod H.realizesFiniteNontrivial.p) rels

/--
The quadratic truncation `A / I²` is the special case `n = 2` of the preceding
free augmentation-quotient comparison.
-/
abbrev PPDatum.relatordiffere_quotaug_idealsqquot
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {depth : Fin H.relationRank → ℕ}
    (hmem : ∀ i, rels i ∈ H.relatorZassenhausFiltration (depth i))
    (hdepth : ∀ i, 2 ≤ depth i) :
    MonoidAlgebra (ZMod H.realizesFiniteNontrivial.p)
        (FreeGroup (Fin H.generatorRank)) ⧸
        GShafar.relatorDifferenceIdeal
          (R := ZMod H.realizesFiniteNontrivial.p) rels →+*
      MonoidAlgebra (ZMod H.realizesFiniteNontrivial.p)
          (FreeGroup (Fin H.generatorRank)) ⧸
        GShafar.augmentationIdeal
          (R := ZMod H.realizesFiniteNontrivial.p)
          (G := FreeGroup (Fin H.generatorRank)) ^ 2 :=
  H.relatordiffere_quotaug_idealpowquot hmem hdepth

theorem PPDatum.relatordiffere_quotaugideal_sqquotsurj
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {depth : Fin H.relationRank → ℕ}
    (hmem : ∀ i, rels i ∈ H.relatorZassenhausFiltration (depth i))
    (hdepth : ∀ i, 2 ≤ depth i) :
    Function.Surjective
      (PPDatum.relatordiffere_quotaug_idealsqquot
        H hmem hdepth) := by
  exact H.relatordiffere_quotaugideal_powquotsurj hmem hdepth

/-
The same depth data compares the relator-difference quotient to every higher
augmentation truncation of the presented-group algebra as well.
-/
abbrev
    PPDatum.relatordiff_quotpres_augpowquot
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {depth : Fin H.relationRank → ℕ}
    {n : ℕ}
    (hmem : ∀ i, rels i ∈ H.relatorZassenhausFiltration (depth i))
    (hn : ∀ i, n ≤ depth i) :
    MonoidAlgebra (ZMod H.realizesFiniteNontrivial.p)
        (FreeGroup (Fin H.generatorRank)) ⧸
        GShafar.relatorDifferenceIdeal
          (R := ZMod H.realizesFiniteNontrivial.p) rels →+*
      MonoidAlgebra (ZMod H.realizesFiniteNontrivial.p)
          (PresentedGroup (Set.range rels)) ⧸
        GShafar.augmentationIdeal
          (R := ZMod H.realizesFiniteNontrivial.p)
          (G := PresentedGroup (Set.range rels)) ^ n :=
    (GShafar.freePresentedAug
      (R := ZMod H.realizesFiniteNontrivial.p) (rels := Set.range rels) n).comp
    (H.relatordiffere_quotaug_idealpowquot hmem hn)

theorem
    PPDatum.relatordiff_quotpresaug_powquotsurj
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {depth : Fin H.relationRank → ℕ}
    {n : ℕ}
    (hmem : ∀ i, rels i ∈ H.relatorZassenhausFiltration (depth i))
    (hn : ∀ i, n ≤ depth i) :
    Function.Surjective
      (H.relatordiff_quotpres_augpowquot
        hmem hn) := by
  exact
    (GShafar.presented_aug_surjective
      (R := ZMod H.realizesFiniteNontrivial.p) (rels := Set.range rels) n).comp
      (H.relatordiffere_quotaugideal_powquotsurj hmem hn)

/--
The depth-`2` quotient package already determines the entire degree-`0/1`
algebra visible to the classical Hilbert-series argument: the relator-difference
quotient surjects onto the explicit square-zero first-order algebra on
`generatorRank` generators.
-/
abbrev PPDatum.relator_differencequot_firstorder
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {depth : Fin H.relationRank → ℕ}
    (hmem : ∀ i, rels i ∈ H.relatorZassenhausFiltration (depth i))
    (hdepth : ∀ i, 2 ≤ depth i) :
    MonoidAlgebra (ZMod H.realizesFiniteNontrivial.p)
        (FreeGroup (Fin H.generatorRank)) ⧸
        GShafar.relatorDifferenceIdeal
          (R := ZMod H.realizesFiniteNontrivial.p) rels →+*
      TrivSqZeroExt (ZMod H.realizesFiniteNontrivial.p)
        ((Fin H.generatorRank) →₀ ZMod H.realizesFiniteNontrivial.p) :=
  (GShafar.augmentationSqOrder
      (α := Fin H.generatorRank) (p := H.realizesFiniteNontrivial.p)).comp
    (H.relatordiffere_quotaug_idealsqquot hmem hdepth)

theorem PPDatum.relatordiffere_quotfirst_ordersurj
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {depth : Fin H.relationRank → ℕ}
    (hmem : ∀ i, rels i ∈ H.relatorZassenhausFiltration (depth i))
    (hdepth : ∀ i, 2 ≤ depth i) :
    Function.Surjective
      (PPDatum.relator_differencequot_firstorder
        H hmem hdepth) := by
  exact
    (GShafar.augmentation_sq_surjective
      (α := Fin H.generatorRank) (p := H.realizesFiniteNontrivial.p)).comp
      (H.relatordiffere_quotaugideal_sqquotsurj
        hmem hdepth)

/--
The remaining depth-`2` gap can be isolated very concretely: every relator in a
minimal presentation should have abelianization vector divisible by `p`.

Once this is proved, the local Zassenhaus infrastructure already upgrades those
relators to lie in `D₂`, so `MinPresZassdepths`
follows with the constant depth function `2`.
-/
def PPDatum.MinrelatorsHavepDvdabeliani
    (H : PPDatum) : Prop :=
  ∀ ⦃rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)⦄,
    Nonempty (PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier) →
    ∀ i a,
      ((H.realizesFiniteNontrivial.p : ℤ) ∣ GShafar.abelianizationVector (rels i) a)

/--
The same remaining gap, phrased in the more natural mod-`p` language suggested
by the Frattini quotient `G / Φ(G)`: every minimal relator should vanish in the
elementary abelian `p`-quotient of the free group.
-/
def PPDatum.MinrelatorsHavevanishingModpabeliani
    (H : PPDatum) : Prop :=
  ∀ ⦃rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)⦄,
    Nonempty (PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier) →
    ∀ i,
      GShafar.modAbelianizationVector H.realizesFiniteNontrivial.p (rels i) = 0

theorem PPDatum.minrelators_havevanishing_modpabeliani
    (H : PPDatum) :
    H.MinrelatorsHavevanishingModpabeliani := by
  intro rels hrels i
  classical
  let P := H.realizesFiniteNontrivial
  let G := P.carrier
  letI : Group G := P.instGroup
  letI : Finite G := P.instFinite
  let e : PresentedGroup (Set.range rels) ≃* G := Classical.choice hrels
  let g : Fin H.generatorRank → G := fun j => e (PresentedGroup.of j)
  let Φ : Subgroup G := frattini G
  letI : Φ.Normal := by
    dsimp [Φ]
    infer_instance
  letI : IsMulCommutative (G ⧸ Φ) :=
    (Subgroup.Normal.quotient_commutative_iff_commutator_le (N := Φ)).2
      (commutator_frattini_group P.isPGroup)
  letI : CommGroup (G ⧸ Φ) :=
    { (inferInstance : Group (G ⧸ Φ)) with mul_comm := mul_comm' }
  let q : Fin H.generatorRank → G ⧸ Φ := fun j => QuotientGroup.mk' Φ (g j)
  by_contra hnonzero
  obtain ⟨a, ha⟩ :
      ∃ a, ¬ ((P.p : ℤ) ∣ GShafar.abelianizationVector (rels i) a) := by
    by_contra hdiv
    push Not at hdiv
    apply hnonzero
    exact
      (GShafar.abelianization_vector_zero
        (p := P.p) (w := rels i)).2 hdiv
  let β := {j : Fin H.generatorRank // j ≠ a}
  let K : Subgroup G := Subgroup.closure (Set.range fun j : β => g j.1)
  let S : Subgroup (G ⧸ Φ) := K.map (QuotientGroup.mk' Φ)
  let qA : Fin H.generatorRank → Additive (G ⧸ Φ) := fun j => Additive.ofMul (q j)
  let SA : AddSubgroup (Additive (G ⧸ Φ)) := S.toAddSubgroup
  have hmk :
      FreeGroup.lift
          (PresentedGroup.of : Fin H.generatorRank → PresentedGroup (Set.range rels)) =
        PresentedGroup.mk (Set.range rels) := by
    ext x
    simp [PresentedGroup.of]
  have hfac :
      e.symm.toMonoidHom.comp (FreeGroup.lift g) =
        PresentedGroup.mk (Set.range rels) := by
    rw [← hmk]
    ext x
    exact FreeGroup.lift_unique
      (g := e.symm.toMonoidHom.comp (FreeGroup.lift g))
      (f := PresentedGroup.of)
      (by intro y; simp [g, PresentedGroup.of])
  have hrelG : FreeGroup.lift g (rels i) = 1 := by
    apply e.symm.injective
    simpa using
      (DFunLike.congr_fun hfac (rels i)).trans
        (PresentedGroup.one_of_mem (Set.mem_range_self i))
  have hqfac :
      (QuotientGroup.mk' Φ).comp (FreeGroup.lift g) = FreeGroup.lift q := by
    ext x
    exact FreeGroup.lift_unique
      (g := (QuotientGroup.mk' Φ).comp (FreeGroup.lift g))
      (f := q)
      (by intro y; simp [q, g])
  have hrelQ : FreeGroup.lift q (rels i) = 1 := by
    have hqfac' := DFunLike.congr_fun hqfac (rels i)
    rw [← hqfac']
    simp [hrelG]
  have hrelSum :
      ∑ j, GShafar.abelianizationVector (rels i) j • qA j = 0 := by
    have hsum0 :
        FreeGroup.lift q (rels i) =
          Multiplicative.ofAdd
            (∑ j, GShafar.abelianizationVector (rels i) j • qA j) := by
      simpa [qA, q] using
        (GShafar.abelianization_vector_zsmul
          (f := qA) (w := rels i))
    have hsum :
        Multiplicative.ofAdd (0 : Additive (G ⧸ Φ)) =
          Multiplicative.ofAdd
            (∑ j, GShafar.abelianizationVector (rels i) j • qA j) := by
      simpa [hrelQ] using hsum0
    simpa using Multiplicative.ofAdd.injective hsum.symm
  have hq_mem_of_ne {j : Fin H.generatorRank} (hj : j ≠ a) : q j ∈ S := by
    refine ⟨g j, ?_, rfl⟩
    exact Subgroup.subset_closure ⟨⟨j, hj⟩, rfl⟩
  have hqA_mem_of_ne {j : Fin H.generatorRank} (hj : j ≠ a) : qA j ∈ SA := by
    simpa [SA, qA] using hq_mem_of_ne (j := j) hj
  let otherSum : Additive (G ⧸ Φ) := ((Finset.univ.erase a : Finset (Fin H.generatorRank)).sum
    fun j => GShafar.abelianizationVector (rels i) j • qA j)
  have hother_mem : otherSum ∈ SA := by
    dsimp [otherSum]
    exact sum_mem (S := SA) (t := Finset.univ.erase a)
      (fun j hj => SA.zsmul_mem (hqA_mem_of_ne ((Finset.mem_erase.mp hj).1)) _)
  let c : ℤ := GShafar.abelianizationVector (rels i) a
  have hsplit :
      ∑ j, GShafar.abelianizationVector (rels i) j • qA j =
        c • qA a + otherSum := by
    calc
      ∑ j, GShafar.abelianizationVector (rels i) j • qA j =
          otherSum + c • qA a := by
            dsimp [c, otherSum]
            symm
            exact Finset.sum_erase_add
              (s := Finset.univ)
              (f := fun j : Fin H.generatorRank =>
                GShafar.abelianizationVector (rels i) j • qA j)
              (Finset.mem_univ a)
      _ = c • qA a + otherSum := by
            simp [add_comm]
  have hc_eq : c • qA a = -otherSum := by
    have hsum0 : c • qA a + otherSum = 0 := by
      simpa [hsplit] using hrelSum
    exact eq_neg_of_add_eq_zero_left hsum0
  have hp_zero : ((P.p : ℤ) • qA a) = 0 := by
    have hpow : q a ^ P.p = 1 := by
      apply (QuotientGroup.eq_one_iff _).2
      exact frattini_p_group P.isPGroup (g a)
    simpa [qA, zsmul_eq_mul] using congrArg Additive.ofMul hpow
  have hnotdivNat : ¬ P.p ∣ c.natAbs := by
    intro hdiv
    exact ha ((Int.natCast_dvd).2 hdiv)
  have hcop : IsCoprime (P.p : ℤ) c := by
    exact
      (Int.isCoprime_iff_nat_coprime).2
        ((Nat.Prime.coprime_iff_not_dvd (Fact.out : Nat.Prime P.p)).2 hnotdivNat)
  obtain ⟨u, v, huv⟩ := hcop
  have hqa_mem : qA a ∈ SA := by
    have hqa_expr :
        qA a = u • (0 : Additive (G ⧸ Φ)) + v • (c • qA a) := by
      calc
        qA a = (1 : ℤ) • qA a := by simp
        _ = (u * (P.p : ℤ) + v * c) • qA a := by simp [huv]
        _ = u • ((P.p : ℤ) • qA a) + v • (c • qA a) := by
              simp [add_zsmul, mul_zsmul]
        _ = u • (0 : Additive (G ⧸ Φ)) + v • (c • qA a) := by
              simp [hp_zero]
    rw [hqa_expr, hc_eq]
    exact SA.add_mem
      (SA.zsmul_mem SA.zero_mem u)
      (SA.zsmul_mem (SA.neg_mem hother_mem) v)
  have hq_mem : ∀ j : Fin H.generatorRank, q j ∈ S := by
    intro j
    by_cases hj : j = a
    · subst hj
      simpa [SA, qA] using hqa_mem
    · exact hq_mem_of_ne hj
  have hq_top : Subgroup.closure (Set.range q) = ⊤ := by
    let φQ : PresentedGroup (Set.range rels) →* (G ⧸ Φ) :=
      (QuotientGroup.mk' Φ).comp e.toMonoidHom
    have hφQsurj : Function.Surjective φQ := by
      intro y
      rcases QuotientGroup.mk'_surjective Φ y with ⟨x, rfl⟩
      rcases e.surjective x with ⟨z, rfl⟩
      exact ⟨z, rfl⟩
    have hq_def : q = φQ ∘ PresentedGroup.of := by
      funext j
      rfl
    rw [hq_def, Set.range_comp, ← MonoidHom.map_closure, PresentedGroup.closure_range_of,
      ← MonoidHom.range_eq_map]
    exact MonoidHom.range_eq_top.2 hφQsurj
  have hS_top : S = (⊤ : Subgroup (G ⧸ Φ)) := by
    have hclosure_le : Subgroup.closure (Set.range q) ≤ S :=
      (Subgroup.closure_le _).mpr fun y hy => by
        rcases hy with ⟨j, rfl⟩
        exact hq_mem j
    apply top_unique
    simpa [hq_top] using hclosure_le
  have hmap_top : K.map (QuotientGroup.mk' Φ) = (⊤ : Subgroup (G ⧸ Φ)) := by
    simpa [S] using hS_top
  have hK_sup : K ⊔ Φ = (⊤ : Subgroup G) := by
    have h := QuotientGroup.comap_map_mk' Φ K
    rw [hmap_top, Subgroup.comap_top] at h
    simpa [sup_comm] using h.symm
  have hK_top : K = ⊤ := by
    apply frattini_nongenerating
    simpa [Φ, sup_comm] using hK_sup
  let φβ : FreeGroup β →* G := FreeGroup.lift (fun j : β => g j.1)
  have hφβsurj : Function.Surjective φβ := by
    rw [← MonoidHom.range_eq_top, FreeGroup.range_lift_eq_closure]
    exact hK_top
  let eβ : β ≃ Fin (Fintype.card β) := Fintype.equivFin β
  let φ : FreeGroup (Fin (Fintype.card β)) →* G :=
    φβ.comp (FreeGroup.freeGroupCongr eβ.symm).toMonoidHom
  have hφsurj : Function.Surjective φ := by
    exact hφβsurj.comp (FreeGroup.freeGroupCongr eβ.symm).surjective
  have hcount : Fintype.card β ∈ P.GeneratorCounts := by
    exact ⟨φ, hφsurj⟩
  have hle : H.generatorRank ≤ Fintype.card β := by
    simpa [PPDatum.generatorRank, P] using Nat.sInf_le hcount
  have hlt : Fintype.card β < H.generatorRank := by
    simpa [β] using
      (Fintype.card_subtype_lt
        (p := fun j : Fin H.generatorRank => j ≠ a)
        (x := a) (by simp))
  exact (not_lt_of_ge hle hlt).elim

theorem PPDatum.minrelators_havevanimod_pabelianiiff
    (H : PPDatum) :
    H.MinrelatorsHavevanishingModpabeliani ↔
      H.MinrelatorsHavepDvdabeliani := by
  constructor
  · intro h rels hrels i a
    have hzero := h (rels := rels) hrels i
    exact
      (GShafar.abelianization_vector_zero
        (p := H.realizesFiniteNontrivial.p) (w := rels i)).mp hzero a
  · intro h rels hrels i
    exact
      (GShafar.abelianization_vector_zero
        (p := H.realizesFiniteNontrivial.p) (w := rels i)).mpr
        (fun a => h (rels := rels) hrels i a)

/-
The degree-`0/1` piece already survives in the quadratic augmentation truncation
of a minimal presented-group algebra: its `𝔽_p`-dimension is at least
`generatorRank + 1`.
-/
set_option maxHeartbeats 1000000 in
-- The quotient-to-first-order comparison expands several finite-dimensional
-- algebra abbreviations, so the default heartbeat budget is too small here.
theorem
    PPDatum.finrankpresaug_sqquotge_genrankaddone
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (hrels : Nonempty (PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier)) :
    H.generatorRank + 1 ≤
      Module.finrank (ZMod H.realizesFiniteNontrivial.p)
        (MonoidAlgebra (ZMod H.realizesFiniteNontrivial.p)
          (PresentedGroup (Set.range rels)) ⧸
            GShafar.augmentationIdeal
              (R := ZMod H.realizesFiniteNontrivial.p)
              (G := PresentedGroup (Set.range rels)) ^ 2) := by
  classical
  let e : PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier :=
    Classical.choice hrels
  letI : Finite (PresentedGroup (Set.range rels)) :=
    Finite.of_equiv H.realizesFiniteNontrivial.carrier e.toEquiv.symm
  letI : Module.Finite (ZMod H.realizesFiniteNontrivial.p)
      (MonoidAlgebra (ZMod H.realizesFiniteNontrivial.p)
        (PresentedGroup (Set.range rels))) := by
    infer_instance
  letI : Module.Finite (ZMod H.realizesFiniteNontrivial.p)
      (MonoidAlgebra (ZMod H.realizesFiniteNontrivial.p)
        (PresentedGroup (Set.range rels)) ⧸
          GShafar.augmentationIdeal
            (R := ZMod H.realizesFiniteNontrivial.p)
            (G := PresentedGroup (Set.range rels)) ^ 2) := by
    let q :
        MonoidAlgebra (ZMod H.realizesFiniteNontrivial.p)
            (PresentedGroup (Set.range rels)) →ₗ[ZMod H.realizesFiniteNontrivial.p]
          MonoidAlgebra (ZMod H.realizesFiniteNontrivial.p)
            (PresentedGroup (Set.range rels)) ⧸
              GShafar.augmentationIdeal
                (R := ZMod H.realizesFiniteNontrivial.p)
                (G := PresentedGroup (Set.range rels)) ^ 2 :=
      (Ideal.Quotient.mkₐ (ZMod H.realizesFiniteNontrivial.p)
        (GShafar.augmentationIdeal
          (R := ZMod H.realizesFiniteNontrivial.p)
          (G := PresentedGroup (Set.range rels)) ^ 2)).toLinearMap
    exact Module.Finite.of_surjective
      (R := ZMod H.realizesFiniteNontrivial.p)
      (M := MonoidAlgebra (ZMod H.realizesFiniteNontrivial.p)
        (PresentedGroup (Set.range rels)))
      (P := MonoidAlgebra (ZMod H.realizesFiniteNontrivial.p)
        (PresentedGroup (Set.range rels)) ⧸
          GShafar.augmentationIdeal
            (R := ZMod H.realizesFiniteNontrivial.p)
            (G := PresentedGroup (Set.range rels)) ^ 2)
      q Ideal.Quotient.mk_surjective
  simpa using
    GShafar.finrank_aug_sq
      (α := Fin H.generatorRank)
      (ι := Fin H.relationRank)
      (p := H.realizesFiniteNontrivial.p)
      (rels := rels)
      (hzero := fun i =>
        H.minrelators_havevanishing_modpabeliani (rels := rels) hrels i)

/--
Deeper augmentation truncations of a minimal presented-group algebra can only
increase the visible `𝔽_p`-dimension.
-/
theorem PPDatum.finrankpres_augpow_quotmono
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (hrels : Nonempty (PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier))
    {m n : ℕ} (hmn : m ≤ n) :
    Module.finrank (ZMod H.realizesFiniteNontrivial.p)
      (MonoidAlgebra (ZMod H.realizesFiniteNontrivial.p)
        (PresentedGroup (Set.range rels)) ⧸
          GShafar.augmentationIdeal
            (R := ZMod H.realizesFiniteNontrivial.p)
            (G := PresentedGroup (Set.range rels)) ^ m) ≤
    Module.finrank (ZMod H.realizesFiniteNontrivial.p)
      (MonoidAlgebra (ZMod H.realizesFiniteNontrivial.p)
        (PresentedGroup (Set.range rels)) ⧸
          GShafar.augmentationIdeal
            (R := ZMod H.realizesFiniteNontrivial.p)
            (G := PresentedGroup (Set.range rels)) ^ n) := by
  classical
  let p := H.realizesFiniteNontrivial.p
  let e : PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier :=
    Classical.choice hrels
  letI : Finite (PresentedGroup (Set.range rels)) :=
    Finite.of_equiv H.realizesFiniteNontrivial.carrier e.toEquiv.symm
  let A := MonoidAlgebra (ZMod p) (PresentedGroup (Set.range rels))
  let I : Ideal A :=
    GShafar.augmentationIdeal (R := ZMod p) (G := PresentedGroup (Set.range rels))
  letI : Module.Finite (ZMod p) A := by
    dsimp [A]
    infer_instance
  have hfinitePow (k : ℕ) : Module.Finite (ZMod p) (A ⧸ I ^ k) := by
    let q : A →ₗ[ZMod p] A ⧸ I ^ k :=
      (Ideal.Quotient.mkₐ (ZMod p) (I ^ k)).toLinearMap
    exact Module.Finite.of_surjective
      (R := ZMod p) (M := A) (P := A ⧸ I ^ k) q Ideal.Quotient.mk_surjective
  letI : Module.Finite (ZMod p) (A ⧸ I ^ m) := hfinitePow m
  letI : Module.Finite (ZMod p) (A ⧸ I ^ n) := hfinitePow n
  let f₀ : A ⧸ I ^ n →+* A ⧸ I ^ m := Ideal.Quotient.factorPow I hmn
  have hf₀ : Function.Surjective f₀ := by
    simpa [f₀, Ideal.Quotient.factorPow] using
      (Ideal.Quotient.factor_surjective (Ideal.pow_le_pow_right hmn) :
        Function.Surjective (Ideal.Quotient.factor (Ideal.pow_le_pow_right hmn)))
  let f : A ⧸ I ^ n →ₗ[ZMod p] A ⧸ I ^ m := f₀.toAddMonoidHom.toZModLinearMap p
  have hf : Function.Surjective f := by
    simpa [f, AddMonoidHom.coe_toZModLinearMap] using hf₀
  have hle :=
    Module.finrank_le_finrank_of_rank_le_rank
      (LinearMap.lift_rank_le_of_surjective f hf)
      (Module.rank_lt_aleph0 (ZMod p) (A ⧸ I ^ n))
  simpa [p, A, I] using hle

/-
Consequently, every deeper augmentation truncation already contains the full
degree-`0/1` contribution `generatorRank + 1`.
-/
theorem
    PPDatum.finrankpresaug_powquotge_genrankaddone
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (hrels : Nonempty (PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier))
    {n : ℕ} (hn : 2 ≤ n) :
    H.generatorRank + 1 ≤
      Module.finrank (ZMod H.realizesFiniteNontrivial.p)
        (MonoidAlgebra (ZMod H.realizesFiniteNontrivial.p)
          (PresentedGroup (Set.range rels)) ⧸
            GShafar.augmentationIdeal
              (R := ZMod H.realizesFiniteNontrivial.p)
              (G := PresentedGroup (Set.range rels)) ^ n) := by
  exact le_trans
    (H.finrankpresaug_sqquotge_genrankaddone
      (rels := rels) hrels)
    (H.finrankpres_augpow_quotmono
      (rels := rels) hrels (m := 2) (n := n) hn)

/-
Whenever the relator-difference quotient is finite dimensional, every
augmentation-power quotient of the presented-group algebra allowed by the depth
bounds has no larger `𝔽_p`-dimension.

This is the first genuinely higher-depth quantitative comparison on the source
of the Hilbert-series argument itself: the new surjections from the
relator-difference quotient already transfer all lower bounds proved on the
presented augmentation truncations.
-/
theorem
    PPDatum.finrankpresaug_powquotle_relatordiffquot
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {depth : Fin H.relationRank → ℕ}
    (hrels : Nonempty (PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier))
    (hmem : ∀ i, rels i ∈ H.relatorZassenhausFiltration (depth i))
    {n : ℕ} (hn : ∀ i, n ≤ depth i)
    [Module.Finite (ZMod H.realizesFiniteNontrivial.p)
      (MonoidAlgebra (ZMod H.realizesFiniteNontrivial.p)
        (FreeGroup (Fin H.generatorRank)) ⧸
          GShafar.relatorDifferenceIdeal
            (R := ZMod H.realizesFiniteNontrivial.p) rels)] :
    Module.finrank (ZMod H.realizesFiniteNontrivial.p)
      (MonoidAlgebra (ZMod H.realizesFiniteNontrivial.p)
        (PresentedGroup (Set.range rels)) ⧸
          GShafar.augmentationIdeal
            (R := ZMod H.realizesFiniteNontrivial.p)
            (G := PresentedGroup (Set.range rels)) ^ n) ≤
    Module.finrank (ZMod H.realizesFiniteNontrivial.p)
      (MonoidAlgebra (ZMod H.realizesFiniteNontrivial.p)
        (FreeGroup (Fin H.generatorRank)) ⧸
          GShafar.relatorDifferenceIdeal
            (R := ZMod H.realizesFiniteNontrivial.p) rels) := by
  classical
  let p := H.realizesFiniteNontrivial.p
  let e : PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier :=
    Classical.choice hrels
  letI : Finite (PresentedGroup (Set.range rels)) :=
    Finite.of_equiv H.realizesFiniteNontrivial.carrier e.toEquiv.symm
  let A := MonoidAlgebra (ZMod p) (FreeGroup (Fin H.generatorRank))
  let B := MonoidAlgebra (ZMod p) (PresentedGroup (Set.range rels))
  let J : Ideal B :=
    GShafar.augmentationIdeal (R := ZMod p) (G := PresentedGroup (Set.range rels))
  letI : Module.Finite (ZMod p) B := by
    dsimp [B]
    infer_instance
  letI : Module.Finite (ZMod p) (B ⧸ J ^ n) := by
    let q : B →ₗ[ZMod p] B ⧸ J ^ n :=
      (Ideal.Quotient.mkₐ (ZMod p) (J ^ n)).toLinearMap
    exact Module.Finite.of_surjective
      (R := ZMod p) (M := B) (P := B ⧸ J ^ n) q Ideal.Quotient.mk_surjective
  let f₀ :
      A ⧸ GShafar.relatorDifferenceIdeal (R := ZMod p) rels →+*
        B ⧸ J ^ n :=
    H.relatordiff_quotpres_augpowquot
      (rels := rels) (depth := depth) hmem hn
  let f :
      A ⧸ GShafar.relatorDifferenceIdeal (R := ZMod p) rels →ₗ[ZMod p]
        B ⧸ J ^ n :=
    f₀.toAddMonoidHom.toZModLinearMap p
  have hf : Function.Surjective f := by
    simpa [f, f₀, AddMonoidHom.coe_toZModLinearMap] using
      (H.relatordiff_quotpresaug_powquotsurj
        (rels := rels) (depth := depth) hmem hn)
  have hle :=
    Module.finrank_le_finrank_of_rank_le_rank
      (LinearMap.lift_rank_le_of_surjective f hf)
      (Module.rank_lt_aleph0 (ZMod p)
        (A ⧸ GShafar.relatorDifferenceIdeal (R := ZMod p) rels))
  simpa [p, A, B, J] using hle

/-
Therefore any finite-dimensional relator-difference quotient compatible with a
minimal presentation and depth data already has dimension at least
`generatorRank + 1`.

This isolates the next quantitative frontier very explicitly: the remaining
Hilbert-series step must provide upper growth bounds on the same source quotient
strong enough to force positivity of the depth-counted relation expression.
-/
theorem PPDatum.finrreladiff_quotgegen_rankaddone
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {depth : Fin H.relationRank → ℕ}
    (hrels : Nonempty (PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier))
    (hmem : ∀ i, rels i ∈ H.relatorZassenhausFiltration (depth i))
    {n : ℕ} (hn₂ : 2 ≤ n)
    (hn : ∀ i, n ≤ depth i)
    [Module.Finite (ZMod H.realizesFiniteNontrivial.p)
      (MonoidAlgebra (ZMod H.realizesFiniteNontrivial.p)
        (FreeGroup (Fin H.generatorRank)) ⧸
          GShafar.relatorDifferenceIdeal
            (R := ZMod H.realizesFiniteNontrivial.p) rels)] :
    H.generatorRank + 1 ≤
      Module.finrank (ZMod H.realizesFiniteNontrivial.p)
        (MonoidAlgebra (ZMod H.realizesFiniteNontrivial.p)
          (FreeGroup (Fin H.generatorRank)) ⧸
            GShafar.relatorDifferenceIdeal
              (R := ZMod H.realizesFiniteNontrivial.p) rels) := by
  exact le_trans
    (H.finrankpresaug_powquotge_genrankaddone
      (rels := rels) hrels hn₂)
    (H.finrankpresaug_powquotle_relatordiffquot
      (rels := rels) (depth := depth) hrels hmem hn)

/--
The degree-`0/1` piece of the Hilbert-series argument is now fully internal to
the current finite `p`-group setup: the presented-group algebra of a minimal
presentation already surjects onto the explicit square-zero first-order model,
so it has `𝔽_p`-dimension at least `generatorRank + 1`.
-/
theorem PPDatum.finrpresgrou_alggegen_rankaddone
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (hrels : Nonempty (PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier)) :
    H.generatorRank + 1 ≤
      Module.finrank (ZMod H.realizesFiniteNontrivial.p)
        (MonoidAlgebra (ZMod H.realizesFiniteNontrivial.p)
          (PresentedGroup (Set.range rels))) := by
  classical
  let e : PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier :=
    Classical.choice hrels
  letI : Finite (PresentedGroup (Set.range rels)) :=
    Finite.of_equiv H.realizesFiniteNontrivial.carrier e.toEquiv.symm
  letI : Module.Finite (ZMod H.realizesFiniteNontrivial.p)
      (MonoidAlgebra (ZMod H.realizesFiniteNontrivial.p)
        (PresentedGroup (Set.range rels))) := by
    infer_instance
  simpa using
    GShafar.finrank_model_surjective
      (α := Fin H.generatorRank)
      (ι := Fin H.relationRank)
      (p := H.realizesFiniteNontrivial.p)
      (rels := rels)
      (hzero := fun i =>
        H.minrelators_havevanishing_modpabeliani (rels := rels) hrels i)

/-
The Zassenhaus-depth part of the reduction is therefore already complete modulo
the mod-`p` abelianization statement above.
-/
theorem
    PPDatum.minzass_depthsp_dvdabeliani
    (H : PPDatum)
    (hdiv : H.MinrelatorsHavepDvdabeliani) :
    H.MinPresZassdepths := by
  rcases H.minimalPresentationExists with ⟨rels, hrels⟩
  refine ⟨rels, hrels, fun _ => 2, ?_, ?_⟩
  · intro i
    have hdivi :
        ∀ a,
          ((H.realizesFiniteNontrivial.p : ℤ) ∣
            GShafar.abelianizationVector (rels i) a) := by
      intro a
      exact hdiv (rels := rels) hrels i a
    simpa [PPDatum.relatorZassenhausFiltration] using
      (GShafar.dvd_abelianization_vector
        (p := H.realizesFiniteNontrivial.p) (w := rels i) hdivi)
  · intro i
    simp

/-
The same depth-`2` reduction, but now stated in the quotient-friendly mod-`p`
abelianization language.
-/
theorem
    PPDatum.minzass_depthsmod_pabelianizero
    (H : PPDatum)
    (hzero : H.MinrelatorsHavevanishingModpabeliani) :
    H.MinPresZassdepths := by
  apply H.minzass_depthsp_dvdabeliani
  exact (H.minrelators_havevanimod_pabelianiiff.mp hzero)

abbrev PPDatum.pGroup
    (H : PPDatum)
    (rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)) : Type :=
  PresentedGroup (Set.range rels)

/-- The group algebra of the presented group over `𝔽_p`. -/
abbrev PPDatum.presentedGroupAlgebra
    (H : PPDatum)
    (rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)) : Type :=
  MonoidAlgebra (ZMod H.realizesFiniteNontrivial.p) (H.pGroup rels)

/-- The augmentation ideal of the presented group algebra. -/
abbrev PPDatum.presentedAugmentationIdeal
    (H : PPDatum)
    (rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)) :
    Ideal (H.presentedGroupAlgebra rels) :=
  GShafar.augmentationIdeal
    (ZMod H.realizesFiniteNontrivial.p)
    (H.pGroup rels)

/-- The `n`th augmentation-power submodule, viewed over `𝔽_p`. -/
abbrev PPDatum.presentedAugmentationSubmodule
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (n : ℕ) :
    Submodule (ZMod H.realizesFiniteNontrivial.p)
      (H.presentedGroupAlgebra rels) :=
  ((H.presentedAugmentationIdeal rels) ^ n).restrictScalars
    (ZMod H.realizesFiniteNontrivial.p)

/--
The denominator `I^(n+1)` inside the numerator `I^n` for the `n`th graded
augmentation layer.
-/
abbrev PPDatum.presentedAugmentationKernel
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (n : ℕ) :
    Submodule (ZMod H.realizesFiniteNontrivial.p)
      (H.presentedAugmentationSubmodule (rels := rels) n) :=
  (H.presentedAugmentationSubmodule (rels := rels) (n + 1)).comap
    (Submodule.subtype (H.presentedAugmentationSubmodule (rels := rels) n))

/-- The `n`th associated-graded augmentation layer `I^n / I^(n+1)`. -/
abbrev PPDatum.pALayer
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (n : ℕ) : Type :=
  (↥(H.presentedAugmentationSubmodule (rels := rels) n)) ⧸
    H.presentedAugmentationKernel (rels := rels) n

/--
The `𝔽_p`-dimension of the `n`th graded layer `I^n / I^(n+1)` of the
augmentation filtration of the presented group algebra.

The Golod--Shafarevich Hilbert series uses these associated-graded dimensions,
not the cumulative quotient dimensions `A / I^n`.
-/
noncomputable def PPDatum.presentedAugmentationFinrank
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (_hrels : Nonempty (PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier))
    (n : ℕ) : ℕ := by
  exact Module.finrank (ZMod H.realizesFiniteNontrivial.p)
    (H.pALayer (rels := rels) n)

/--
The concrete Hilbert-series coefficient sequence to be used for the remaining
finite-window recurrence.
-/
noncomputable def PPDatum.presentedHilbertSequence
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (hrels : Nonempty (PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier)) :
    ℕ → ℝ :=
  fun n => (H.presentedAugmentationFinrank hrels n : ℝ)

/-- The concrete augmentation-quotient sequence is termwise nonnegative. -/
lemma PPDatum.pres_aughilbert_sequencenonneg
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (hrels : Nonempty (PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier)) :
    ∀ n, 0 ≤ H.presentedHilbertSequence hrels n := by
  intro n
  dsimp [PPDatum.presentedHilbertSequence]
  exact_mod_cast
    (Nat.zero_le (H.presentedAugmentationFinrank hrels n))

/--
The augmentation-layer sequence has positive constant term.

Mathematically, this is the statement that the degree-zero layer `A / I`
still sees the class of `1`.
-/
theorem PPDatum.presaug_hilbertsequence_zeropos
    (H : PPDatum)
    (_p_prime : Nat.Prime H.realizesFiniteNontrivial.p)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (hrels : Nonempty (PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier)) :
    0 < H.presentedHilbertSequence hrels 0 := by
  classical
  let p := H.realizesFiniteNontrivial.p
  letI : Fact p.Prime := ⟨_p_prime⟩
  let G := PresentedGroup (Set.range rels)
  let e : G ≃* H.realizesFiniteNontrivial.carrier := Classical.choice hrels
  letI : Finite G := Finite.of_equiv H.realizesFiniteNontrivial.carrier e.toEquiv.symm
  let A := MonoidAlgebra (ZMod p) G
  let I : Ideal A := GShafar.augmentationIdeal (ZMod p) G
  let I0 : Submodule (ZMod p) A := (I ^ (0 : ℕ)).restrictScalars (ZMod p)
  let I1 : Submodule (ZMod p) A := (I ^ (1 : ℕ)).restrictScalars (ZMod p)
  let K : Submodule (ZMod p) I0 := I1.comap (Submodule.subtype I0)
  have hone_mem_I0 : (1 : A) ∈ I0 := by
    change (1 : A) ∈ (I ^ (0 : ℕ) : Submodule A A)
    rw [Submodule.pow_zero]
    simp
  let oneI0 : I0 := ⟨1, hone_mem_I0⟩
  have hone_not_mem_K : oneI0 ∉ K := by
    intro hone_mem_K
    have hone_mem_I : (1 : A) ∈ I := by
      have hone_mem_I1 : (oneI0 : A) ∈ I1 := hone_mem_K
      have hone_mem_I_pow_one : (1 : A) ∈ I ^ (1 : ℕ) := by
        simpa [oneI0, I1] using hone_mem_I1
      change (1 : A) ∈ (I : Submodule A A)
      change (1 : A) ∈ (I ^ (1 : ℕ) : Submodule A A) at hone_mem_I_pow_one
      rw [Submodule.pow_one] at hone_mem_I_pow_one
      exact hone_mem_I_pow_one
    have hmap_zero : (GShafar.augmentationHom (ZMod p) G).toRingHom (1 : A) = 0 := by
      exact RingHom.mem_ker.mp hone_mem_I
    have hmap_one : (GShafar.augmentationHom (ZMod p) G).toRingHom (1 : A) = 1 := by
      simp
    have hzero_eq_one : (0 : ZMod p) = 1 := by
      rw [← hmap_zero, hmap_one]
    exact zero_ne_one hzero_eq_one
  haveI : Nontrivial ((↥I0) ⧸ K) := by
    refine ⟨⟨Submodule.Quotient.mk oneI0, 0, ?_⟩⟩
    intro hzero
    exact hone_not_mem_K ((Submodule.Quotient.mk_eq_zero K).mp hzero)
  haveI : Module.Finite (ZMod p) ((↥I0) ⧸ K) := by
    infer_instance
  have hfinrank_pos : 0 < Module.finrank (ZMod p) ((↥I0) ⧸ K) :=
    (Module.finrank_pos_iff (R := ZMod p) (M := (↥I0) ⧸ K)).2 inferInstance
  simpa [PPDatum.presentedHilbertSequence,
    PPDatum.presentedAugmentationFinrank, p, G, A, I, I0, I1, K] using
    hfinrank_pos

/--
Once an augmentation power is zero, the corresponding associated-graded layer
has zero `𝔽_p`-dimension.
-/
theorem PPDatum.presauglayer_finrankeqzero_powereqbot
    (H : PPDatum)
    (_p_prime : Nat.Prime H.realizesFiniteNontrivial.p)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (hrels : Nonempty (PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier))
    {n : ℕ}
    (hpow : (H.presentedAugmentationIdeal rels) ^ n = ⊥) :
    H.presentedAugmentationFinrank hrels n = 0 := by
  classical
  let p := H.realizesFiniteNontrivial.p
  letI : Fact p.Prime := ⟨_p_prime⟩
  let A := H.presentedGroupAlgebra rels
  let I : Ideal A := H.presentedAugmentationIdeal rels
  let In1 : Submodule (ZMod p) A := (I ^ (n + 1)).restrictScalars (ZMod p)
  dsimp [PPDatum.presentedAugmentationFinrank,
    PPDatum.pALayer,
    PPDatum.presentedAugmentationKernel,
    PPDatum.presentedAugmentationSubmodule]
  change Module.finrank (ZMod p)
      ((↥((I ^ n).restrictScalars (ZMod p))) ⧸
        Submodule.comap (Submodule.subtype ((I ^ n).restrictScalars (ZMod p))) In1) = 0
  rw [hpow]
  let K : Submodule (ZMod p) (↥(⊥ : Submodule (ZMod p) A)) :=
    Submodule.comap (Submodule.subtype (⊥ : Submodule (ZMod p) A)) In1
  change Module.finrank (ZMod p) ((↥(⊥ : Submodule (ZMod p) A)) ⧸ K) = 0
  haveI : Subsingleton ((↥(⊥ : Submodule (ZMod p) A)) ⧸ K) := inferInstance
  exact (Module.finrank_zero_iff
    (R := ZMod p) (M := ((↥(⊥ : Submodule (ZMod p) A)) ⧸ K))).2 inferInstance

/-- If an augmentation ideal has a zero power, all sufficiently high powers are zero. -/
lemma PPDatum.presented_bot_nilpotence
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {N n : ℕ}
    (hN : (H.presentedAugmentationIdeal rels) ^ N = ⊥)
    (hNn : N ≤ n) :
    (H.presentedAugmentationIdeal rels) ^ n = ⊥ := by
  apply le_antisymm
  · calc
      (H.presentedAugmentationIdeal rels) ^ n
          ≤ (H.presentedAugmentationIdeal rels) ^ N :=
            Ideal.pow_le_pow_right hNn
      _ = ⊥ := hN
  · exact bot_le

/--
Nilpotence of the presented augmentation ideal implies eventual vanishing of
all associated-graded augmentation layers.
-/
theorem PPDatum.presaug_layerfinrank_evenzeronilp
    (H : PPDatum)
    (_p_prime : Nat.Prime H.realizesFiniteNontrivial.p)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (hrels : Nonempty (PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier))
    (hnil :
      ∃ N : ℕ, (H.presentedAugmentationIdeal rels) ^ N = ⊥) :
    ∃ N : ℕ, ∀ n, N ≤ n → H.presentedAugmentationFinrank hrels n = 0 := by
  rcases hnil with ⟨N, hN⟩
  refine ⟨N, ?_⟩
  intro n hNn
  exact H.presauglayer_finrankeqzero_powereqbot
    _p_prime hrels
    (H.presented_bot_nilpotence
      (rels := rels) hN hNn)

/-- A chosen equivalence from the presented group to the finite `p`-group it presents. -/
noncomputable def PPDatum.presentedGroupEquiv
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (hrels : Nonempty (PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier)) :
    H.pGroup rels ≃* H.realizesFiniteNontrivial.carrier :=
  Classical.choice hrels

/--
The presented group is finite because it is equivalent to the finite group
realized by `H`.
-/
theorem PPDatum.presentedGroup_finite
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (hrels : Nonempty (PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier)) :
    Finite (H.pGroup rels) := by
  classical
  exact Finite.of_equiv H.realizesFiniteNontrivial.carrier
    (H.presentedGroupEquiv hrels).toEquiv.symm

/--
The presented group is a `p`-group because it is equivalent to the finite
`p`-group realized by `H`.
-/
theorem PPDatum.pres_group_pgroup
    (H : PPDatum)
    (_p_prime : Nat.Prime H.realizesFiniteNontrivial.p)
    (_isPGroup : IsPGroup H.realizesFiniteNontrivial.p H.realizesFiniteNontrivial.carrier)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (hrels : Nonempty (PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier)) :
    IsPGroup H.realizesFiniteNontrivial.p (H.pGroup rels) := by
  classical
  exact IsPGroup.of_equiv _isPGroup (H.presentedGroupEquiv hrels).symm

/-- The standard augmentation-ideal generator attached to `g`, namely `g - 1`. -/
def augmentationDifference (R G : Type*) [CommRing R] [Monoid G] (g : G) :
    MonoidAlgebra R G :=
  MonoidAlgebra.single g 1 - 1

/-- Each difference `g - 1` lies in the augmentation ideal. -/
lemma augmentation_difference_ideal
    (R G : Type*) [CommRing R] [Monoid G] (g : G) :
    augmentationDifference R G g ∈
      GShafar.augmentationIdeal R G := by
  rw [GShafar.augmentationIdeal, RingHom.mem_ker]
  change
    (GShafar.augmentationHom R G).toRingHom
      (MonoidAlgebra.single g 1 - 1) = 0
  simp [GShafar.augmentationHom, GShafar.augmentationCharacter]

/--
The augmentation difference of a product, in the form used by Fox calculus.

This is the identity `(gh - 1) = (g - 1) + g * (h - 1)` in the group algebra.
-/
lemma augmentation_difference_left
    (R G : Type*) [CommRing R] [Group G] (g h : G) :
    augmentationDifference R G (g * h) =
      augmentationDifference R G g +
        MonoidAlgebra.single g (1 : R) * augmentationDifference R G h := by
  unfold augmentationDifference
  have hmul :
      MonoidAlgebra.single g (1 : R) * MonoidAlgebra.single h (1 : R) =
        MonoidAlgebra.single (g * h) (1 : R) := by
    simp [MonoidAlgebra.single_mul_single]
  rw [← hmul]
  noncomm_ring

/--
The augmentation difference of an inverse, in the form used by Fox calculus.

This is the identity `(g⁻¹ - 1) = -g⁻¹ * (g - 1)` in the group algebra.
-/
lemma difference_inv_neg
    (R G : Type*) [CommRing R] [Group G] (g : G) :
    augmentationDifference R G g⁻¹ =
      (-MonoidAlgebra.single g⁻¹ (1 : R)) * augmentationDifference R G g := by
  unfold augmentationDifference
  have hmul :
      MonoidAlgebra.single g⁻¹ (1 : R) * MonoidAlgebra.single g (1 : R) =
        (1 : MonoidAlgebra R G) := by
    simp [MonoidAlgebra.single_mul_single, MonoidAlgebra.one_def]
  have hmul_neg :
      (-MonoidAlgebra.single g⁻¹ (1 : R)) * MonoidAlgebra.single g (1 : R) =
        -(1 : MonoidAlgebra R G) := by
    rw [neg_mul, hmul]
  have hone_neg :
      (-MonoidAlgebra.single g⁻¹ (1 : R)) * (1 : MonoidAlgebra R G) =
        -MonoidAlgebra.single g⁻¹ (1 : R) := by
    rw [mul_one]
  rw [mul_sub, hmul_neg, hone_neg]
  noncomm_ring

/-- The group element represented by one free-group letter. -/
def freeGroupLetter {ι : Type*} (l : ι × Bool) : FreeGroup ι :=
  FreeGroup.mk [l]

@[simp]
lemma free_letter_pos {ι : Type*} (i : ι) :
    freeGroupLetter (i, true) = FreeGroup.of i :=
  rfl

@[simp]
lemma free_letter_neg {ι : Type*} (i : ι) :
    freeGroupLetter (i, false) = (FreeGroup.of i)⁻¹ := by
  change FreeGroup.mk [(i, false)] = (FreeGroup.mk [(i, true)])⁻¹
  rw [FreeGroup.inv_mk]
  simp [FreeGroup.invRev]

lemma free_letter_mk {ι : Type*} (l : ι × Bool) (L : List (ι × Bool)) :
    freeGroupLetter l * FreeGroup.mk L = FreeGroup.mk (l :: L) := by
  rw [freeGroupLetter, FreeGroup.mul_mk]
  rfl

/--
The Fox derivative of one free-group letter.

For a positive letter `x_i` this is `1` in the `i`th derivative and `0`
elsewhere.  For a negative letter `x_i⁻¹` this is `-x_i⁻¹` in the `i`th
derivative and `0` elsewhere.
-/
def foxLetterDerivative
    (R : Type*) {ι : Type*} [CommRing R] [DecidableEq ι]
    (j : ι) (l : ι × Bool) : MonoidAlgebra R (FreeGroup ι) :=
  if l.1 = j then
    if l.2 then
      1
    else
      -MonoidAlgebra.single (freeGroupLetter l) (1 : R)
  else
    0

/-- The fundamental Fox identity for one free-group letter. -/
lemma letter_derivative_fundamental
    (R : Type*) {ι : Type*} [CommRing R] [Fintype ι] [DecidableEq ι]
    (l : ι × Bool) :
    augmentationDifference R (FreeGroup ι) (freeGroupLetter l) =
      ∑ j, foxLetterDerivative R j l *
        augmentationDifference R (FreeGroup ι) (FreeGroup.of j) := by
  classical
  rcases l with ⟨i, b⟩
  cases b
  · rw [Finset.sum_eq_single i]
    · simpa [foxLetterDerivative] using
        difference_inv_neg
          R (FreeGroup ι) (FreeGroup.of i)
    · intro j _hj hji
      simp [foxLetterDerivative, hji.symm]
    · intro hi
      exact (hi (Finset.mem_univ i)).elim
  · rw [Finset.sum_eq_single i]
    · simp [foxLetterDerivative]
    · intro j _hj hji
      simp [foxLetterDerivative, hji.symm]
    · intro hi
      exact (hi (Finset.mem_univ i)).elim

/--
The Fox derivative of a word in the free group, computed from left to right.

The recursion is the product rule `∂(uv) = ∂u + u * ∂v`, with the one-letter
derivative above.
-/
def foxDerivativeList
    (R : Type*) {ι : Type*} [CommRing R] [DecidableEq ι]
    (j : ι) : List (ι × Bool) → MonoidAlgebra R (FreeGroup ι)
  | [] => 0
  | l :: L =>
      foxLetterDerivative R j l +
        MonoidAlgebra.single (freeGroupLetter l) (1 : R) *
          foxDerivativeList R j L

/-- The fundamental Fox identity for a concrete free-group word. -/
lemma fox_derivative_fundamental
    (R : Type*) {ι : Type*} [CommRing R] [Fintype ι] [DecidableEq ι]
    (L : List (ι × Bool)) :
    augmentationDifference R (FreeGroup ι) (FreeGroup.mk L) =
      ∑ j, foxDerivativeList R j L *
        augmentationDifference R (FreeGroup ι) (FreeGroup.of j) := by
  classical
  induction L with
  | nil =>
      simp [foxDerivativeList, augmentationDifference,
        FreeGroup.one_eq_mk, MonoidAlgebra.one_def]
  | cons l L ih =>
      have hmk :
          FreeGroup.mk (l :: L) = freeGroupLetter l * FreeGroup.mk L := by
        rw [free_letter_mk]
      calc
        augmentationDifference R (FreeGroup ι) (FreeGroup.mk (l :: L))
            = augmentationDifference R (FreeGroup ι)
                (freeGroupLetter l * FreeGroup.mk L) := by
              rw [hmk]
        _ = augmentationDifference R (FreeGroup ι) (freeGroupLetter l) +
              MonoidAlgebra.single (freeGroupLetter l) (1 : R) *
                augmentationDifference R (FreeGroup ι) (FreeGroup.mk L) := by
              rw [augmentation_difference_left]
        _ = (∑ j, foxLetterDerivative R j l *
                augmentationDifference R (FreeGroup ι) (FreeGroup.of j)) +
              MonoidAlgebra.single (freeGroupLetter l) (1 : R) *
                (∑ j, foxDerivativeList R j L *
                  augmentationDifference R (FreeGroup ι) (FreeGroup.of j)) := by
              rw [letter_derivative_fundamental R l, ih]
        _ = ∑ j, foxDerivativeList R j (l :: L) *
              augmentationDifference R (FreeGroup ι) (FreeGroup.of j) := by
              rw [Finset.mul_sum, ← Finset.sum_add_distrib]
              apply Finset.sum_congr rfl
              intro j _hj
              rw [foxDerivativeList]
              noncomm_ring

/-- The Fox derivative of an element of the free group, using its reduced word. -/
def groupFoxDerivative
    (R : Type*) {ι : Type*} [CommRing R] [DecidableEq ι]
    (j : ι) (g : FreeGroup ι) : MonoidAlgebra R (FreeGroup ι) :=
  foxDerivativeList R j g.toWord

/-- The fundamental Fox identity in the free group algebra. -/
theorem free_derivative_fundamental
    (R : Type*) {ι : Type*} [CommRing R] [Fintype ι] [DecidableEq ι]
    (g : FreeGroup ι) :
    augmentationDifference R (FreeGroup ι) g =
      ∑ j, groupFoxDerivative R j g *
        augmentationDifference R (FreeGroup ι) (FreeGroup.of j) := by
  simpa [groupFoxDerivative, FreeGroup.mk_toWord] using
    fox_derivative_fundamental R g.toWord

/-- Augmentation differences commute with mapping the group variable. -/
lemma domain_ring_difference
    (R G K : Type*) [CommRing R] [Group G] [Group K]
    (φ : G →* K) (g : G) :
    MonoidAlgebra.mapDomainRingHom R φ (augmentationDifference R G g) =
      augmentationDifference R K (φ g) := by
  unfold augmentationDifference
  rw [map_sub]
  simp [MonoidAlgebra.mapDomainRingHom]

/--
Mapping the group variable in a group algebra preserves the augmentation ideal.

This is the degree-one form of functoriality for the augmentation filtration.
It is deliberately stated without finiteness assumptions, since the source group
for the Fox estimate is a free group.
-/
lemma domain_ring_ideal
    (R G K : Type*) [CommRing R] [Group G] [Group K]
    (φ : G →* K)
    {x : MonoidAlgebra R G}
    (hx : x ∈ GShafar.augmentationIdeal R G) :
    MonoidAlgebra.mapDomainRingHom R φ x ∈
      GShafar.augmentationIdeal R K := by
  let q : MonoidAlgebra R G →+* MonoidAlgebra R K :=
    MonoidAlgebra.mapDomainRingHom R φ
  have hxzero :
      (GShafar.augmentationHom R G).toRingHom x = 0 := by
    exact RingHom.mem_ker.mp hx
  have hcomp :
      (GShafar.augmentationHom R K).toRingHom.comp q =
        (GShafar.augmentationHom R G).toRingHom := by
    apply MonoidAlgebra.ringHom_ext
    · intro r
      simp [q, GShafar.augmentationHom,
        GShafar.augmentationCharacter, MonoidAlgebra.mapDomainRingHom]
    · intro g
      simp [q, GShafar.augmentationHom,
        GShafar.augmentationCharacter, MonoidAlgebra.mapDomainRingHom]
  rw [GShafar.augmentationIdeal, RingHom.mem_ker]
  change ((GShafar.augmentationHom R K).toRingHom.comp q) x = 0
  rw [hcomp]
  exact hxzero

/--
Mapping the group variable in a group algebra preserves every augmentation
power.

This is the filtered-algebra functoriality needed to push Fox-derivative
estimates from the free group algebra to the presented quotient algebra.
-/
lemma domain_ring_pow
    (R G K : Type*) [CommRing R] [Group G] [Group K]
    (φ : G →* K)
    {n : ℕ}
    {x : MonoidAlgebra R G}
    (hx : x ∈ (GShafar.augmentationIdeal R G) ^ n) :
    MonoidAlgebra.mapDomainRingHom R φ x ∈
      (GShafar.augmentationIdeal R K) ^ n := by
  let q : MonoidAlgebra R G →+* MonoidAlgebra R K :=
    MonoidAlgebra.mapDomainRingHom R φ
  let I : Ideal (MonoidAlgebra R G) :=
    GShafar.augmentationIdeal R G
  let J : Ideal (MonoidAlgebra R K) :=
    GShafar.augmentationIdeal R K
  haveI : I.IsTwoSided := by
    dsimp [I, GShafar.augmentationIdeal]
    infer_instance
  haveI : J.IsTwoSided := by
    dsimp [J, GShafar.augmentationIdeal]
    infer_instance
  induction n generalizing x with
  | zero =>
      simp [Submodule.pow_zero]
  | succ n ih =>
      have hxmul : x ∈ I ^ n * I := by
        simpa [I, Submodule.pow_succ] using hx
      have htarget : q x ∈ J ^ n * J := by
        refine Submodule.mul_induction_on hxmul ?mul_mem ?add_mem
        · intro a ha b hb
          have hqa : q a ∈ J ^ n := by
            exact ih (by simpa [I] using ha)
          have hqb : q b ∈ J := by
            exact domain_ring_ideal R G K φ
              (by simpa [I] using hb)
          have hprod : q a * q b ∈ J ^ n * J :=
            Ideal.mul_mem_mul hqa hqb
          simpa [q, map_mul] using hprod
        · intro u v hu hv
          have hadd : q u + q v ∈ J ^ n * J :=
            (J ^ n * J).add_mem hu hv
          simpa [q, map_add] using hadd
      simpa [J, q, Submodule.pow_succ] using htarget

/--
The augmentation-difference commutator step for the lower central series.

If `x - 1` has degree at least `i + 1`, then the group commutator
`[x,y] = x y x⁻¹ y⁻¹` has augmentation difference of degree at least `i + 2`.
This is the local multiplication calculation behind the lower-central
augmentation estimate.
-/
theorem free_difference_commutator
    {p : ℕ}
    {ι : Type*}
    {i : ℕ}
    {x y : FreeGroup ι}
    (hxDiff :
      augmentationDifference (ZMod p) (FreeGroup ι) x ∈
        (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^ (i + 1)) :
    augmentationDifference (ZMod p) (FreeGroup ι) (x * y * x⁻¹ * y⁻¹) ∈
      (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^ (i + 2) := by
  classical
  let A := MonoidAlgebra (ZMod p) (FreeGroup ι)
  let I : Ideal A :=
    GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)
  haveI : I.IsTwoSided := by
    dsimp [I, GShafar.augmentationIdeal]
    infer_instance
  let X : A := augmentationDifference (ZMod p) (FreeGroup ι) x
  let Y : A := augmentationDifference (ZMod p) (FreeGroup ι) y
  let sx : A := MonoidAlgebra.single x (1 : ZMod p)
  let sy : A := MonoidAlgebra.single y (1 : ZMod p)
  let sxInv : A := MonoidAlgebra.single x⁻¹ (1 : ZMod p)
  let syInv : A := MonoidAlgebra.single y⁻¹ (1 : ZMod p)
  have hxI : X ∈ I ^ (i + 1) := by
    simpa [I, X] using hxDiff
  have hyI : Y ∈ I := by
    simpa [I, Y] using
      augmentation_difference_ideal (ZMod p) (FreeGroup ι) y
  have hXY : X * Y ∈ I ^ (i + 2) := by
    have hmul : X * Y ∈ I ^ (i + 1) * I :=
      Ideal.mul_mem_mul hxI hyI
    rw [show i + 2 = (i + 1) + 1 by omega]
    simpa [Submodule.pow_succ] using hmul
  have hYX : Y * X ∈ I ^ (i + 2) := by
    have hmul : Y * X ∈ I * I ^ (i + 1) :=
      Ideal.mul_mem_mul hyI hxI
    rw [show i + 2 = (i + 1) + 1 by omega]
    simpa [Ideal.IsTwoSided.pow_succ] using hmul
  have hXY' : X * Y * sxInv * syInv ∈ I ^ (i + 2) := by
    exact (I ^ (i + 2)).mul_mem_right syInv
      ((I ^ (i + 2)).mul_mem_right sxInv hXY)
  have hYX' : Y * X * sxInv * syInv ∈ I ^ (i + 2) := by
    exact (I ^ (i + 2)).mul_mem_right syInv
      ((I ^ (i + 2)).mul_mem_right sxInv hYX)
  have hsingle_mul (a b : FreeGroup ι) :
      MonoidAlgebra.single a (1 : ZMod p) *
          MonoidAlgebra.single b (1 : ZMod p) =
        MonoidAlgebra.single (a * b) (1 : ZMod p) := by
    simp [MonoidAlgebra.single_mul_single]
  have hsx_mul_sxInv : sx * sxInv = 1 := by
    change MonoidAlgebra.single x (1 : ZMod p) *
        MonoidAlgebra.single x⁻¹ (1 : ZMod p) = (1 : A)
    rw [hsingle_mul x x⁻¹]
    change MonoidAlgebra.single (x * x⁻¹) (1 : ZMod p) =
      (1 : MonoidAlgebra (ZMod p) (FreeGroup ι))
    simp [MonoidAlgebra.one_def]
  have hsy_mul_syInv : sy * syInv = 1 := by
    change MonoidAlgebra.single y (1 : ZMod p) *
        MonoidAlgebra.single y⁻¹ (1 : ZMod p) = (1 : A)
    rw [hsingle_mul y y⁻¹]
    change MonoidAlgebra.single (y * y⁻¹) (1 : ZMod p) =
      (1 : MonoidAlgebra (ZMod p) (FreeGroup ι))
    simp [MonoidAlgebra.one_def]
  have hprod :
      sx * sy * sxInv * syInv =
        MonoidAlgebra.single (x * y * x⁻¹ * y⁻¹) (1 : ZMod p) := by
    change
      ((MonoidAlgebra.single x (1 : ZMod p) *
            MonoidAlgebra.single y (1 : ZMod p)) *
          MonoidAlgebra.single x⁻¹ (1 : ZMod p)) *
        MonoidAlgebra.single y⁻¹ (1 : ZMod p) =
          MonoidAlgebra.single (x * y * x⁻¹ * y⁻¹) (1 : ZMod p)
    rw [hsingle_mul x y]
    rw [hsingle_mul (x * y) x⁻¹]
    rw [hsingle_mul (x * y * x⁻¹) y⁻¹]
  have hYX_cancel : sy * sx * sxInv * syInv = 1 := by
    calc
      sy * sx * sxInv * syInv = sy * (sx * sxInv) * syInv := by
        noncomm_ring
      _ = sy * 1 * syInv := by
        rw [hsx_mul_sxInv]
      _ = sy * syInv := by
        noncomm_ring
      _ = 1 := hsy_mul_syInv
  have hexpand :
      X * Y * sxInv * syInv - Y * X * sxInv * syInv =
        sx * sy * sxInv * syInv - sy * sx * sxInv * syInv := by
    have hX : X = sx - 1 := by
      simp [X, sx, augmentationDifference]
    have hY : Y = sy - 1 := by
      simp [Y, sy, augmentationDifference]
    have hbracket :
        (sx - 1) * (sy - 1) - (sy - 1) * (sx - 1) = sx * sy - sy * sx := by
      simp [sub_mul, mul_sub, one_mul, mul_one]
      abel
    rw [hX, hY]
    calc
      (sx - 1) * (sy - 1) * sxInv * syInv -
          (sy - 1) * (sx - 1) * sxInv * syInv =
            (((sx - 1) * (sy - 1) - (sy - 1) * (sx - 1)) * sxInv) * syInv := by
              simp [sub_mul]
      _ = ((sx * sy - sy * sx) * sxInv) * syInv := by
              rw [hbracket]
      _ = sx * sy * sxInv * syInv - sy * sx * sxInv * syInv := by
              simp [sub_mul]
  have hcommAlg :
      sx * sy * sxInv * syInv - 1 =
        X * Y * sxInv * syInv - Y * X * sxInv * syInv := by
    rw [hexpand, hYX_cancel]
  have hcomm :
      augmentationDifference (ZMod p) (FreeGroup ι) (x * y * x⁻¹ * y⁻¹) =
        X * Y * sxInv * syInv - Y * X * sxInv * syInv := by
    calc
      augmentationDifference (ZMod p) (FreeGroup ι) (x * y * x⁻¹ * y⁻¹)
          = sx * sy * sxInv * syInv - 1 := by
              rw [augmentationDifference, hprod]
      _ = X * Y * sxInv * syInv - Y * X * sxInv * syInv := hcommAlg
  rw [hcomm]
  exact (I ^ (i + 2)).sub_mem hXY' hYX'

/--
Lower-central membership implies augmentation-difference membership in the
corresponding augmentation power.

This is the group-algebra half of the standard estimate
`γ_i(F) ⊆ 1 + I^i`, with the indexing convention of this file:
`Subgroup.lowerCentralSeries F i` lands in `I^(i+1)` because `Subgroup.lowerCentralSeries F 0 = F`.
It is independent of Fox derivatives and will feed the commutator step below.
-/
theorem free_difference_central
    {p : ℕ}
    {ι : Type*}
    {i : ℕ}
    {x : FreeGroup ι}
    (hx : x ∈ Subgroup.lowerCentralSeries (FreeGroup ι) i) :
    augmentationDifference (ZMod p) (FreeGroup ι) x ∈
      (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^ (i + 1) := by
  let I : Ideal (MonoidAlgebra (ZMod p) (FreeGroup ι)) :=
    GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)
  induction i generalizing x with
  | zero =>
      have hxI :
          augmentationDifference (ZMod p) (FreeGroup ι) x ∈ I :=
        augmentation_difference_ideal (ZMod p) (FreeGroup ι) x
      simpa [I, Submodule.pow_one] using hxI
  | succ i ih =>
      have hclosed :
          ∀ z ∈ Subgroup.closure
              { z : FreeGroup ι |
                ∃ a ∈ Subgroup.lowerCentralSeries (FreeGroup ι) i,
                  ∃ b ∈ (⊤ : Subgroup (FreeGroup ι)),
                    a * b * a⁻¹ * b⁻¹ = z },
            augmentationDifference (ZMod p) (FreeGroup ι) z ∈ I ^ (i + 2) := by
        intro z hz
        refine Subgroup.closure_induction
          (k := { z : FreeGroup ι |
            ∃ a ∈ Subgroup.lowerCentralSeries (FreeGroup ι) i,
              ∃ b ∈ (⊤ : Subgroup (FreeGroup ι)),
                a * b * a⁻¹ * b⁻¹ = z })
          (p := fun z _hz =>
            augmentationDifference (ZMod p) (FreeGroup ι) z ∈ I ^ (i + 2))
          ?mem ?one ?mul ?inv hz
        · intro z hzgen
          rcases hzgen with ⟨a, ha, b, _hb, rfl⟩
          have haDiff :
              augmentationDifference (ZMod p) (FreeGroup ι) a ∈ I ^ (i + 1) := by
            simpa [I] using ih ha
          simpa [I] using
            free_difference_commutator
              (p := p) (i := i) (x := a) (y := b)
              (by simpa [I] using haDiff)
        · have hzero :
              augmentationDifference (ZMod p) (FreeGroup ι) (1 : FreeGroup ι) = 0 := by
            simp [augmentationDifference, MonoidAlgebra.one_def]
          change augmentationDifference (ZMod p) (FreeGroup ι) (1 : FreeGroup ι) ∈
            I ^ (i + 2)
          rw [hzero]
          exact Submodule.zero_mem (I ^ (i + 2))
        · intro a b _ha _hb haP hbP
          rw [augmentation_difference_left]
          exact (I ^ (i + 2)).add_mem
            (by simpa [I] using haP)
            (by
              exact (I ^ (i + 2)).mul_mem_left
                (MonoidAlgebra.single a (1 : ZMod p))
                (by simpa [I] using hbP))
        · intro a _ha haP
          rw [difference_inv_neg]
          exact (I ^ (i + 2)).mul_mem_left
            (-MonoidAlgebra.single a⁻¹ (1 : ZMod p))
            (by simpa [I] using haP)
      have hx' :
          x ∈ Subgroup.closure
              { z : FreeGroup ι |
                ∃ a ∈ Subgroup.lowerCentralSeries (FreeGroup ι) i,
                  ∃ b ∈ (⊤ : Subgroup (FreeGroup ι)),
                    a * b * a⁻¹ * b⁻¹ = z } := by
        simpa [Subgroup.lowerCentralSeries_succ] using hx
      simpa [I, Nat.succ_eq_add_one, Nat.add_assoc] using hclosed x hx'

/-- The Fox derivative of the identity element is zero. -/
lemma group_fox_derivative
    (R : Type*) {ι : Type*} [CommRing R] [DecidableEq ι]
    (j : ι) :
    groupFoxDerivative R j (1 : FreeGroup ι) = 0 := by
  rw [groupFoxDerivative]
  rw [FreeGroup.toWord_one]
  rw [foxDerivativeList]

/-- The letter represented by toggling the Boolean sign is the inverse letter. -/
lemma free_letter_not {ι : Type*} (l : ι × Bool) :
    freeGroupLetter (l.1, !l.2) = (freeGroupLetter l)⁻¹ := by
  rcases l with ⟨i, b⟩
  cases b <;> simp

/--
The two one-letter Fox derivatives attached to an adjacent inverse pair cancel.

This is the local algebraic reason that the Fox derivative is invariant under
one free reduction step.
-/
lemma letter_derivative_cancel
    (R : Type*) {ι : Type*} [CommRing R] [DecidableEq ι]
    (j : ι) (l : ι × Bool) :
    foxLetterDerivative R j l +
        MonoidAlgebra.single (freeGroupLetter l) (1 : R) *
          foxLetterDerivative R j (l.1, !l.2) =
      0 := by
  rcases l with ⟨i, b⟩
  by_cases hji : i = j
  · subst j
    cases b <;>
      simp [foxLetterDerivative,
        MonoidAlgebra.single_mul_single, MonoidAlgebra.one_def]
  · cases b <;>
      simp [foxLetterDerivative, hji]

/--
The list Fox derivative satisfies the product rule for concatenating unreduced
words.

The remaining product-rule difficulty is therefore only compatibility with
free reduction.
-/
lemma fox_derivative_append
    (R : Type*) {ι : Type*} [CommRing R] [DecidableEq ι]
    (j : ι) (L M : List (ι × Bool)) :
    foxDerivativeList R j (L ++ M) =
      foxDerivativeList R j L +
        MonoidAlgebra.single (FreeGroup.mk L) (1 : R) *
          foxDerivativeList R j M := by
  induction L with
  | nil =>
      rw [List.nil_append, foxDerivativeList]
      rw [show FreeGroup.mk ([] : List (ι × Bool)) = (1 : FreeGroup ι) by
        rw [← FreeGroup.one_eq_mk]]
      rw [← MonoidAlgebra.one_def]
      rw [one_mul]
      rw [zero_add]
  | cons l L ih =>
      rw [List.cons_append, foxDerivativeList, foxDerivativeList, ih]
      have hsingle :
          MonoidAlgebra.single (freeGroupLetter l) (1 : R) *
              MonoidAlgebra.single (FreeGroup.mk L) (1 : R) =
            MonoidAlgebra.single (FreeGroup.mk (l :: L)) (1 : R) := by
        rw [← free_letter_mk l L]
        simp [MonoidAlgebra.single_mul_single]
      rw [mul_add, ← mul_assoc, hsingle]
      abel

/--
Deleting one adjacent inverse-letter pair does not change the list Fox
derivative.

This is the explicit one-step calculation behind reduction invariance.
-/
lemma derivative_cancel_pair
    (R : Type*) {ι : Type*} [CommRing R] [DecidableEq ι]
    (j : ι) (L₁ L₂ : List (ι × Bool)) (i : ι) (b : Bool) :
    foxDerivativeList R j
        (L₁ ++ (i, b) :: (i, !b) :: L₂) =
      foxDerivativeList R j (L₁ ++ L₂) := by
  let l : ι × Bool := (i, b)
  have hpair :
      foxDerivativeList R j (l :: (l.1, !l.2) :: L₂) =
        foxDerivativeList R j L₂ := by
    rw [foxDerivativeList, foxDerivativeList]
    have hcancel := letter_derivative_cancel R j l
    have hsingle :
        MonoidAlgebra.single (freeGroupLetter l) (1 : R) *
            MonoidAlgebra.single (freeGroupLetter (l.1, !l.2)) (1 : R) =
          (1 : MonoidAlgebra R (FreeGroup ι)) := by
      rw [free_letter_not]
      simp [MonoidAlgebra.single_mul_single, MonoidAlgebra.one_def]
    calc
      foxLetterDerivative R j l +
          MonoidAlgebra.single (freeGroupLetter l) (1 : R) *
            (foxLetterDerivative R j (l.1, !l.2) +
              MonoidAlgebra.single (freeGroupLetter (l.1, !l.2)) (1 : R) *
                foxDerivativeList R j L₂)
          =
        (foxLetterDerivative R j l +
            MonoidAlgebra.single (freeGroupLetter l) (1 : R) *
              foxLetterDerivative R j (l.1, !l.2)) +
          (MonoidAlgebra.single (freeGroupLetter l) (1 : R) *
              MonoidAlgebra.single (freeGroupLetter (l.1, !l.2)) (1 : R)) *
            foxDerivativeList R j L₂ := by
              noncomm_ring
      _ = foxDerivativeList R j L₂ := by
        rw [hcancel, hsingle]
        simp
  calc
    foxDerivativeList R j (L₁ ++ (i, b) :: (i, !b) :: L₂)
        =
      foxDerivativeList R j L₁ +
        MonoidAlgebra.single (FreeGroup.mk L₁) (1 : R) *
          foxDerivativeList R j (l :: (l.1, !l.2) :: L₂) := by
          simpa [l, List.append_assoc] using
            fox_derivative_append R j L₁ (l :: (l.1, !l.2) :: L₂)
    _ =
      foxDerivativeList R j L₁ +
        MonoidAlgebra.single (FreeGroup.mk L₁) (1 : R) *
          foxDerivativeList R j L₂ := by
          rw [hpair]
    _ = foxDerivativeList R j (L₁ ++ L₂) := by
      rw [fox_derivative_append]

/-- A single free reduction step preserves the list Fox derivative. -/
lemma fox_derivative_red
    (R : Type*) {ι : Type*} [CommRing R] [DecidableEq ι]
    (j : ι) {L M : List (ι × Bool)}
    (h : FreeGroup.Red.Step L M) :
    foxDerivativeList R j L =
      foxDerivativeList R j M := by
  cases h with
  | not =>
      exact derivative_cancel_pair R j _ _ _ _

/--
Any finite chain of free reductions preserves the list Fox derivative.

This is the exact reduction-invariance statement needed to pass from unreduced
word concatenation to multiplication in the free group.
-/
lemma free_derivative_red
    (R : Type*) {ι : Type*} [CommRing R] [DecidableEq ι]
    (j : ι) {L M : List (ι × Bool)}
    (h : FreeGroup.Red L M) :
    foxDerivativeList R j L =
      foxDerivativeList R j M := by
  induction h with
  | refl => rfl
  | tail _ hstep ih =>
      exact ih.trans (fox_derivative_red R j hstep)

/-- Reducing a word does not change its list Fox derivative. -/
lemma fox_derivative_reduce
    (R : Type*) {ι : Type*} [CommRing R] [DecidableEq ι]
    (j : ι) (L : List (ι × Bool)) :
    foxDerivativeList R j (FreeGroup.reduce L) =
      foxDerivativeList R j L := by
  exact (free_derivative_red R j (FreeGroup.reduce.red (L := L))).symm

/--
The product rule for the word-defined Fox derivative on the free group.

This is the exact algebraic identity needed by the closure argument.  It is
strictly smaller than the Zassenhaus closure theorem: no filtration appears
here, only compatibility of the reduced-word definition with multiplication in
`FreeGroup`.
-/
theorem free_derivative_mul
    (R : Type*) {ι : Type*} [CommRing R] [DecidableEq ι]
    (j : ι) (x y : FreeGroup ι) :
    groupFoxDerivative R j (x * y) =
      groupFoxDerivative R j x +
        MonoidAlgebra.single x (1 : R) * groupFoxDerivative R j y := by
  rw [groupFoxDerivative, FreeGroup.toWord_mul]
  calc
    foxDerivativeList R j (FreeGroup.reduce (x.toWord ++ y.toWord))
        = foxDerivativeList R j (x.toWord ++ y.toWord) := by
            rw [fox_derivative_reduce]
    _ =
        foxDerivativeList R j x.toWord +
          MonoidAlgebra.single (FreeGroup.mk x.toWord) (1 : R) *
            foxDerivativeList R j y.toWord := by
            rw [fox_derivative_append]
    _ =
        foxDerivativeList R j x.toWord +
          MonoidAlgebra.single x (1 : R) *
            foxDerivativeList R j y.toWord := by
            rw [FreeGroup.mk_toWord]

/--
The inverse rule for the word-defined Fox derivative on the free group.

This is the second exact algebraic identity needed by the closure argument; it
is independent of the Zassenhaus filtration and should follow from the product
rule applied to `x⁻¹ * x = 1`.
-/
theorem free_derivative_inv
    (R : Type*) {ι : Type*} [CommRing R] [DecidableEq ι]
    (j : ι) (x : FreeGroup ι) :
    groupFoxDerivative R j x⁻¹ =
      -MonoidAlgebra.single x⁻¹ (1 : R) * groupFoxDerivative R j x := by
  have hmul := free_derivative_mul R j x⁻¹ x
  have hsum :
      groupFoxDerivative R j x⁻¹ +
          MonoidAlgebra.single x⁻¹ (1 : R) * groupFoxDerivative R j x =
        0 := by
    simpa [group_fox_derivative] using hmul.symm
  have hneg :
      groupFoxDerivative R j x⁻¹ =
        -(MonoidAlgebra.single x⁻¹ (1 : R) * groupFoxDerivative R j x) :=
    eq_neg_of_add_eq_zero_left hsum
  simpa [neg_mul] using hneg

/--
The Fox derivative of a power is the usual geometric Fox sum.

This is the algebraic formula
`∂(x^m) = (1 + x + ... + x^(m-1)) ∂x`, stated in the group algebra.  It is
independent of characteristic and supplies the concrete expansion used in the
Jennings `p`-power step below.
-/
lemma fox_derivative_sum
    (R : Type*) {ι : Type*} [CommRing R] [DecidableEq ι]
    (j : ι) (x : FreeGroup ι) (m : ℕ) :
    groupFoxDerivative R j (x ^ m) =
      Finset.sum (Finset.range m) fun r =>
        MonoidAlgebra.single (x ^ r) (1 : R) *
          groupFoxDerivative R j x := by
  induction m with
  | zero =>
      rw [pow_zero, group_fox_derivative]
      simp
  | succ m ih =>
      calc
        groupFoxDerivative R j (x ^ (m + 1))
            = groupFoxDerivative R j (x ^ m * x) := by
                rw [pow_succ]
        _ =
            groupFoxDerivative R j (x ^ m) +
              MonoidAlgebra.single (x ^ m) (1 : R) *
                groupFoxDerivative R j x := by
                rw [free_derivative_mul]
        _ =
            (Finset.sum (Finset.range m) fun r =>
              MonoidAlgebra.single (x ^ r) (1 : R) *
                groupFoxDerivative R j x) +
              MonoidAlgebra.single (x ^ m) (1 : R) *
                groupFoxDerivative R j x := by
                rw [ih]
        _ =
            (Finset.sum (Finset.range (m + 1)) fun r =>
              MonoidAlgebra.single (x ^ r) (1 : R) *
                groupFoxDerivative R j x) := by
                rw [Finset.sum_range_succ]

/--
The commutator step for the lower-central Fox filtration estimate.

If `x - 1` has degree at least `i + 1` and all Fox derivatives of `x` have
degree at least `i`, then every Fox derivative of `[x,y]` has degree at least
`i + 1`.  This is exactly the extra degree gained when passing from
`γ_i(F)` to `γ_{i+1}(F)`.
-/
theorem fox_derivative_commutator
    {p : ℕ}
    {ι : Type*} [DecidableEq ι]
    {i : ℕ}
    {x y : FreeGroup ι}
    (hxDiff :
      augmentationDifference (ZMod p) (FreeGroup ι) x ∈
        (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^ (i + 1))
    (hxDeriv :
      ∀ j : ι,
        groupFoxDerivative (ZMod p) j x ∈
          (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^ i)
    (j : ι) :
    groupFoxDerivative (ZMod p) j (x * y * x⁻¹ * y⁻¹) ∈
      (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^ (i + 1) := by
  classical
  let A := MonoidAlgebra (ZMod p) (FreeGroup ι)
  let I : Ideal A :=
    GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)
  haveI : I.IsTwoSided := by
    dsimp [I, GShafar.augmentationIdeal]
    infer_instance
  let Dx : A := groupFoxDerivative (ZMod p) j x
  let Dy : A := groupFoxDerivative (ZMod p) j y
  let X : A := augmentationDifference (ZMod p) (FreeGroup ι) x
  let sx : A := MonoidAlgebra.single x (1 : ZMod p)
  let sy : A := MonoidAlgebra.single y (1 : ZMod p)
  let sxInv : A := MonoidAlgebra.single x⁻¹ (1 : ZMod p)
  let syInv : A := MonoidAlgebra.single y⁻¹ (1 : ZMod p)
  have hxI : X ∈ I ^ (i + 1) := by
    simpa [I, X] using hxDiff
  have hxD : Dx ∈ I ^ i := by
    simpa [I, Dx] using hxDeriv j
  have hsingle_mul (a b : FreeGroup ι) :
      MonoidAlgebra.single a (1 : ZMod p) *
          MonoidAlgebra.single b (1 : ZMod p) =
        MonoidAlgebra.single (a * b) (1 : ZMod p) := by
    simp [MonoidAlgebra.single_mul_single]
  have hsx_mul_sxInv : sx * sxInv = 1 := by
    change MonoidAlgebra.single x (1 : ZMod p) *
        MonoidAlgebra.single x⁻¹ (1 : ZMod p) = (1 : A)
    rw [hsingle_mul x x⁻¹]
    change MonoidAlgebra.single (x * x⁻¹) (1 : ZMod p) =
      (1 : MonoidAlgebra (ZMod p) (FreeGroup ι))
    simp [MonoidAlgebra.one_def]
  have hsxInv_mul_sx : sxInv * sx = 1 := by
    change MonoidAlgebra.single x⁻¹ (1 : ZMod p) *
        MonoidAlgebra.single x (1 : ZMod p) = (1 : A)
    rw [hsingle_mul x⁻¹ x]
    change MonoidAlgebra.single (x⁻¹ * x) (1 : ZMod p) =
      (1 : MonoidAlgebra (ZMod p) (FreeGroup ι))
    simp [MonoidAlgebra.one_def]
  have hsy_mul_syInv : sy * syInv = 1 := by
    change MonoidAlgebra.single y (1 : ZMod p) *
        MonoidAlgebra.single y⁻¹ (1 : ZMod p) = (1 : A)
    rw [hsingle_mul y y⁻¹]
    change MonoidAlgebra.single (y * y⁻¹) (1 : ZMod p) =
      (1 : MonoidAlgebra (ZMod p) (FreeGroup ι))
    simp [MonoidAlgebra.one_def]
  have hxy_single :
      MonoidAlgebra.single (x * y) (1 : ZMod p) = sx * sy := by
    rw [hsingle_mul x y]
  have hxyx_single :
      MonoidAlgebra.single (x * y * x⁻¹) (1 : ZMod p) = sx * sy * sxInv := by
    rw [← hsingle_mul (x * y) x⁻¹, hxy_single]
  have hxyx_single_assoc :
      MonoidAlgebra.single (x * (y * x⁻¹)) (1 : ZMod p) = sx * sy * sxInv := by
    rw [← mul_assoc x y x⁻¹]
    exact hxyx_single
  have hcoeffDx_mem : 1 - sx * sy * sxInv ∈ I := by
    have hdiff :
        augmentationDifference (ZMod p) (FreeGroup ι) (x * y * x⁻¹) ∈ I := by
      simpa [I] using
        augmentation_difference_ideal
          (ZMod p) (FreeGroup ι) (x * y * x⁻¹)
    have hcoeff_eq :
        1 - sx * sy * sxInv =
          -augmentationDifference (ZMod p) (FreeGroup ι) (x * y * x⁻¹) := by
      rw [augmentationDifference, hxyx_single]
      abel
    rw [hcoeff_eq]
    exact I.neg_mem hdiff
  have htermDx : (1 - sx * sy * sxInv) * Dx ∈ I ^ (i + 1) := by
    have hmul : (1 - sx * sy * sxInv) * Dx ∈ I * I ^ i :=
      Ideal.mul_mem_mul hcoeffDx_mem hxD
    simpa [Ideal.IsTwoSided.pow_succ] using hmul
  have hX_eq : X = sx - 1 := by
    simp [X, sx, augmentationDifference]
  have hcoeffDy_eq :
      sx - sx * sy * sxInv * syInv = sx * sy * sxInv * X * syInv := by
    rw [hX_eq]
    calc
      sx - sx * sy * sxInv * syInv
          = sx * (sy * syInv) - sx * sy * sxInv * syInv := by
              rw [hsy_mul_syInv, mul_one]
      _ = sx * sy * (1 - sxInv) * syInv := by
              simp [sub_mul, mul_sub, mul_assoc]
      _ = sx * sy * (sxInv * sx - sxInv) * syInv := by
              rw [hsxInv_mul_sx]
      _ = sx * sy * (sxInv * (sx - 1)) * syInv := by
              simp [mul_sub]
      _ = sx * sy * sxInv * (sx - 1) * syInv := by
              simp [mul_assoc]
  have hcoeffDy_mem : sx - sx * sy * sxInv * syInv ∈ I ^ (i + 1) := by
    rw [hcoeffDy_eq]
    exact (I ^ (i + 1)).mul_mem_right syInv
      ((I ^ (i + 1)).mul_mem_left (sx * sy * sxInv) hxI)
  have htermDy : (sx - sx * sy * sxInv * syInv) * Dy ∈ I ^ (i + 1) := by
    exact (I ^ (i + 1)).mul_mem_right Dy hcoeffDy_mem
  have hderiv :
      groupFoxDerivative (ZMod p) j (x * y * x⁻¹ * y⁻¹) =
        (1 - sx * sy * sxInv) * Dx +
          (sx - sx * sy * sxInv * syInv) * Dy := by
    calc
      groupFoxDerivative (ZMod p) j (x * y * x⁻¹ * y⁻¹)
          =
            groupFoxDerivative (ZMod p) j (x * y * x⁻¹) +
              MonoidAlgebra.single (x * y * x⁻¹) (1 : ZMod p) *
                groupFoxDerivative (ZMod p) j y⁻¹ := by
              rw [free_derivative_mul]
      _ =
            (groupFoxDerivative (ZMod p) j (x * y) +
              MonoidAlgebra.single (x * y) (1 : ZMod p) *
                groupFoxDerivative (ZMod p) j x⁻¹) +
              MonoidAlgebra.single (x * y * x⁻¹) (1 : ZMod p) *
                groupFoxDerivative (ZMod p) j y⁻¹ := by
              rw [free_derivative_mul]
      _ =
            Dx + sx * Dy - (sx * sy * sxInv) * Dx -
              (sx * sy * sxInv * syInv) * Dy := by
              rw [free_derivative_mul]
              rw [free_derivative_inv]
              rw [free_derivative_inv]
              simp [Dx, Dy, sx, sy, sxInv, syInv, hxy_single, hxyx_single_assoc,
                neg_mul, mul_neg, sub_eq_add_neg, mul_assoc]
      _ =
            (1 - sx * sy * sxInv) * Dx +
              (sx - sx * sy * sxInv * syInv) * Dy := by
              symm
              rw [sub_mul, sub_mul, one_mul]
              repeat rw [sub_eq_add_neg]
              ac_rfl
  rw [hderiv]
  exact (I ^ (i + 1)).add_mem htermDx htermDy

/--
Multiplying an element of an augmentation power on the left by a group element
keeps it in the same augmentation power.
-/
lemma monoid_algebra_single
    (R G : Type*) [CommRing R] [Group G]
    {n : ℕ}
    (g : G)
    {x : MonoidAlgebra R G}
    (hx : x ∈ (GShafar.augmentationIdeal R G) ^ n) :
    MonoidAlgebra.single g (1 : R) * x ∈
      (GShafar.augmentationIdeal R G) ^ n := by
  let I : Ideal (MonoidAlgebra R G) :=
    GShafar.augmentationIdeal R G
  have hxI : x ∈ I ^ n := by
    simpa [I] using hx
  have hmul : MonoidAlgebra.single g (1 : R) * x ∈ I ^ n :=
    (I ^ n).mul_mem_left (MonoidAlgebra.single g (1 : R)) hxI
  simpa [I] using hmul

/--
The Fox derivative filtration condition is stable under multiplication.

This is the product-rule half of the subgroup-closure argument for the
Zassenhaus filtration.
-/
lemma free_derivative_pow
    {p : ℕ} [Fact p.Prime]
    {ι : Type*} [DecidableEq ι]
    {n : ℕ}
    {x y : FreeGroup ι}
    (hx :
      ∀ j : ι,
        groupFoxDerivative (ZMod p) j x ∈
          (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^ n)
    (hy :
      ∀ j : ι,
        groupFoxDerivative (ZMod p) j y ∈
          (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^ n)
    (j : ι) :
    groupFoxDerivative (ZMod p) j (x * y) ∈
      (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^ n := by
  rw [free_derivative_mul]
  let I : Ideal (MonoidAlgebra (ZMod p) (FreeGroup ι)) :=
    GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)
  have hxI : groupFoxDerivative (ZMod p) j x ∈ I ^ n := by
    simpa [I] using hx j
  have hyI :
      MonoidAlgebra.single x (1 : ZMod p) *
          groupFoxDerivative (ZMod p) j y ∈ I ^ n := by
    exact monoid_algebra_single
      (ZMod p) (FreeGroup ι) x (by simpa [I] using hy j)
  exact (I ^ n).add_mem hxI hyI

/--
The Fox derivative filtration condition is stable under inversion.

This is the inverse-rule half of the subgroup-closure argument for the
Zassenhaus filtration.
-/
lemma fox_derivative_inv
    {p : ℕ} [Fact p.Prime]
    {ι : Type*} [DecidableEq ι]
    {n : ℕ}
    {x : FreeGroup ι}
    (hx :
      ∀ j : ι,
        groupFoxDerivative (ZMod p) j x ∈
          (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^ n)
    (j : ι) :
    groupFoxDerivative (ZMod p) j x⁻¹ ∈
      (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^ n := by
  rw [free_derivative_inv]
  let I : Ideal (MonoidAlgebra (ZMod p) (FreeGroup ι)) :=
    GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)
  have hxI :
      MonoidAlgebra.single x⁻¹ (1 : ZMod p) *
          groupFoxDerivative (ZMod p) j x ∈ I ^ n := by
    exact monoid_algebra_single
      (ZMod p) (FreeGroup ι) x⁻¹ (by simpa [I] using hx j)
  simpa [I, neg_mul] using (I ^ n).neg_mem hxI

/--
Lower-central membership gives the first half of the Fox filtration estimate.

With the convention used by `zassenhausGeneratorSet`, an element of
`Subgroup.lowerCentralSeries F i` has augmentation degree at least `i + 1`, so its Fox
derivatives have degree at least `i`.  This is the commutator part of the
dimension-subgroup calculation.
-/
theorem fox_derivative_central
    {p : ℕ} [Fact p.Prime]
    {ι : Type*} [DecidableEq ι]
    {i : ℕ}
    {x : FreeGroup ι}
    (hx : x ∈ Subgroup.lowerCentralSeries (FreeGroup ι) i)
    (j : ι) :
    groupFoxDerivative (ZMod p) j x ∈
      (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^ i := by
  let I : Ideal (MonoidAlgebra (ZMod p) (FreeGroup ι)) :=
    GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)
  revert j
  induction i generalizing x with
  | zero =>
      intro j
      have htop :
          groupFoxDerivative (ZMod p) j x ∈
            (⊤ : Submodule
              (MonoidAlgebra (ZMod p) (FreeGroup ι))
              (MonoidAlgebra (ZMod p) (FreeGroup ι))) :=
        Submodule.mem_top
      simp [Submodule.pow_zero]
  | succ i ih =>
      intro j
      have hclosed :
          ∀ z ∈ Subgroup.closure
              { z : FreeGroup ι |
                ∃ a ∈ Subgroup.lowerCentralSeries (FreeGroup ι) i,
                  ∃ b ∈ (⊤ : Subgroup (FreeGroup ι)),
                    a * b * a⁻¹ * b⁻¹ = z },
            ∀ j : ι,
              groupFoxDerivative (ZMod p) j z ∈ I ^ (i + 1) := by
        intro z hz
        refine Subgroup.closure_induction
          (k := { z : FreeGroup ι |
            ∃ a ∈ Subgroup.lowerCentralSeries (FreeGroup ι) i,
              ∃ b ∈ (⊤ : Subgroup (FreeGroup ι)),
                a * b * a⁻¹ * b⁻¹ = z })
          (p := fun z _hz =>
            ∀ j : ι, groupFoxDerivative (ZMod p) j z ∈ I ^ (i + 1))
          ?mem ?one ?mul ?inv hz
        · intro z hzgen j
          rcases hzgen with ⟨a, ha, b, _hb, rfl⟩
          have haDiff :
              augmentationDifference (ZMod p) (FreeGroup ι) a ∈ I ^ (i + 1) := by
            simpa [I] using
              free_difference_central
                (p := p) (i := i) ha
          have haDeriv :
              ∀ j : ι, groupFoxDerivative (ZMod p) j a ∈ I ^ i := by
            intro j
            simpa [I] using ih ha j
          simpa [I] using
            fox_derivative_commutator
              (p := p) (i := i) (x := a) (y := b)
              (by simpa [I] using haDiff)
              (by intro j; simpa [I] using haDeriv j)
              j
        · intro j
          rw [group_fox_derivative]
          exact Submodule.zero_mem (I ^ (i + 1))
        · intro a b _ha _hb haP hbP j
          simpa [I] using
            free_derivative_pow
              (p := p) (n := i + 1) (x := a) (y := b)
              (by intro j; simpa [I] using haP j)
              (by intro j; simpa [I] using hbP j)
              j
        · intro a _ha haP j
          simpa [I] using
            fox_derivative_inv
              (p := p) (n := i + 1) (x := a)
              (by intro j; simpa [I] using haP j)
              j
      have hx' :
          x ∈ Subgroup.closure
              { z : FreeGroup ι |
                ∃ a ∈ Subgroup.lowerCentralSeries (FreeGroup ι) i,
                  ∃ b ∈ (⊤ : Subgroup (FreeGroup ι)),
                    a * b * a⁻¹ * b⁻¹ = z } := by
        simpa [Subgroup.lowerCentralSeries_succ] using hx
      simpa [I] using hclosed x hx' j

/--
The single `p`-power step for augmentation differences.

If `g - 1` starts in degree `m`, then over `𝔽_p` the difference `g^p - 1`
starts in degree `m * p`.  This is the Freshman's-dream calculation
`(1 + (g - 1))^p - 1 = (g - 1)^p` in the commutative subalgebra generated by
the one group element `g`.
-/
theorem free_difference_pow
    {p : ℕ} [Fact p.Prime]
    {ι : Type*}
    {m : ℕ}
    {g : FreeGroup ι}
    (hDiff :
      augmentationDifference (ZMod p) (FreeGroup ι) g ∈
        (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^ m) :
    augmentationDifference (ZMod p) (FreeGroup ι) (g ^ p) ∈
      (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^ (m * p) := by
  let A := MonoidAlgebra (ZMod p) (FreeGroup ι)
  let I : Ideal A :=
    GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)
  haveI : I.IsTwoSided := by
    dsimp [I, GShafar.augmentationIdeal]
    infer_instance
  let sg : A := MonoidAlgebra.single g (1 : ZMod p)
  let X : A := augmentationDifference (ZMod p) (FreeGroup ι) g
  have hsingleOne_injective :
      Function.Injective
        (MonoidAlgebra.singleOneRingHom
          (R := ZMod p) (M := FreeGroup ι)) := by
    intro a b hab
    have hcoeff := congr_arg (fun x : A => x (1 : FreeGroup ι)) hab
    simpa [A, MonoidAlgebra.singleOneRingHom] using hcoeff
  haveI : CharP A p := charP_of_injective_ringHom hsingleOne_injective p
  have hX : X = sg - 1 := by
    simp [X, sg, augmentationDifference]
  have hsingle_pow :
      sg ^ p = MonoidAlgebra.single (g ^ p) (1 : ZMod p) := by
    change (MonoidAlgebra.single g (1 : ZMod p)) ^ p =
      MonoidAlgebra.single (g ^ p) (1 : ZMod p)
    rw [MonoidAlgebra.single_pow]
    simp
  have hfresh :
      X ^ p = sg ^ p - 1 := by
    rw [hX]
    have hcomm : Commute sg (1 : A) := Commute.one_right _
    simpa using
      (sub_pow_char_of_commute
        (R := A) (x := sg) (y := (1 : A)) p hcomm)
  have haug_eq :
      augmentationDifference (ZMod p) (FreeGroup ι) (g ^ p) = X ^ p := by
    calc
      augmentationDifference (ZMod p) (FreeGroup ι) (g ^ p)
          = MonoidAlgebra.single (g ^ p) (1 : ZMod p) - (1 : A) := by
              rfl
      _ = sg ^ p - 1 := by
              rw [hsingle_pow]
      _ = X ^ p := hfresh.symm
  have hXI : X ∈ I ^ m := by
    simpa [I, X] using hDiff
  have hpow : X ^ p ∈ I ^ (m * p) := by
    have hpow_mem : ∀ n : ℕ, X ^ n ∈ I ^ (m * n) := by
      intro n
      induction n with
      | zero =>
          simp [Submodule.pow_zero]
      | succ n ih =>
          have hmul : X ^ n * X ∈ I ^ (m * n) * I ^ m :=
            Ideal.mul_mem_mul ih hXI
          have htarget : X ^ n * X ∈ I ^ (m * n + m) := by
            rw [Ideal.IsTwoSided.pow_add]
            exact hmul
          simpa [pow_succ, Nat.mul_succ] using htarget
    exact hpow_mem p
  rw [haug_eq]
  exact hpow

/--
Prime powers of a lower-central element have the expected augmentation degree.

This is the augmentation-difference half of the Jennings `p`-power argument:
if `x - 1` starts in degree `i + 1`, then over `𝔽_p` the difference
`x^(p^k) - 1` starts in degree `(i + 1) p^k`.
-/
theorem free_difference_power
    {p : ℕ} [Fact p.Prime]
    {ι : Type*}
    {i k : ℕ}
    {x : FreeGroup ι}
    (hx : x ∈ Subgroup.lowerCentralSeries (FreeGroup ι) i) :
    augmentationDifference (ZMod p) (FreeGroup ι) (x ^ (p ^ k)) ∈
      (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^
        ((i + 1) * p ^ k) := by
  induction k with
  | zero =>
      have hbase :
          augmentationDifference (ZMod p) (FreeGroup ι) x ∈
            (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^ (i + 1) :=
        free_difference_central
          (p := p) hx
      simpa using hbase
  | succ k ih =>
      let m : ℕ := (i + 1) * p ^ k
      have hstep :
          augmentationDifference (ZMod p) (FreeGroup ι) ((x ^ (p ^ k)) ^ p) ∈
            (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^ (m * p) :=
        free_difference_pow
          (p := p) (m := m) (g := x ^ (p ^ k)) (by simpa [m] using ih)
      have hpow :
          x ^ (p ^ (k + 1)) = (x ^ (p ^ k)) ^ p := by
        rw [pow_succ, pow_mul]
      have hdegree :
          m * p = (i + 1) * p ^ (k + 1) := by
        change ((i + 1) * p ^ k) * p = (i + 1) * p ^ (k + 1)
        rw [pow_succ, Nat.mul_assoc]
      simpa [hpow, hdegree] using hstep

/--
Powers preserve ideal-power degree multiplicatively.

This small bookkeeping lemma is used twice in the Jennings argument: once for
`(g - 1)^p`, and once for the geometric Fox coefficient
`(g - 1)^(p - 1)`.
-/
lemma of_mem_pow
    {A : Type*} [Ring A]
    (I : Ideal A) [I.IsTwoSided]
    {x : A} {m n : ℕ}
    (hx : x ∈ I ^ m) :
    x ^ n ∈ I ^ (m * n) := by
  induction n with
  | zero =>
      simp [Submodule.pow_zero]
  | succ n ih =>
      have hmul : x ^ n * x ∈ I ^ (m * n) * I ^ m :=
        Ideal.mul_mem_mul ih hx
      have htarget : x ^ n * x ∈ I ^ (m * n + m) := by
        rw [Ideal.IsTwoSided.pow_add]
        exact hmul
      simpa [pow_succ, Nat.mul_succ] using htarget

/--
The intermediate binomial coefficients in the `p`th row vanish in `ZMod p`.

This is the coefficient-level input for the characteristic-`p` geometric
identity: the hockey-stick coefficient `choose p (i + 1)` is zero unless
`i + 1 = p`.
-/
lemma zmod_choose_succ
    {p : ℕ} [Fact p.Prime]
    {i : ℕ}
    (hi : i + 1 < p) :
    ((p.choose (i + 1) : ℕ) : ZMod p) = 0 := by
  have hi_ne_zero : i + 1 ≠ 0 := by
    omega
  have hdiv :
      p ∣ p.choose (i + 1) :=
    (Fact.out : Nat.Prime p).dvd_choose_self hi_ne_zero hi
  exact (CharP.cast_eq_zero_iff (ZMod p) p (p.choose (i + 1))).2 hdiv

/--
Over `ZMod p`, the hockey-stick polynomial collapses to its top term.

Mathlib supplies the polynomial identity
`sum_{r<p} (X + 1)^r = sum_i choose p (i+1) X^i`; this lemma records the
prime-field coefficient collapse on the right-hand side.
-/
lemma geometric_hockey_stick
    {p : ℕ} [Fact p.Prime] :
    (Finset.range p).sum (fun i : ℕ =>
        (p.choose (i + 1) : Polynomial (ZMod p)) * Polynomial.X ^ i) =
      (Polynomial.X : Polynomial (ZMod p)) ^ (p - 1) := by
  have hp_pos : 0 < p := (Fact.out : Nat.Prime p).pos
  have hp_one : 1 ≤ p := (Fact.out : Nat.Prime p).one_le
  rw [Finset.sum_eq_single (p - 1)]
  · have hp_sub_add : p - 1 + 1 = p := Nat.sub_add_cancel hp_one
    simp [hp_sub_add]
  · intro i hi hne
    have hi_lt : i < p := Finset.mem_range.mp hi
    have hi_succ_le : i + 1 ≤ p := Nat.succ_le_of_lt hi_lt
    have hi_succ_ne : i + 1 ≠ p := by
      intro hsucc
      apply hne
      omega
    have hi_succ_lt : i + 1 < p := lt_of_le_of_ne hi_succ_le hi_succ_ne
    have hchoose :
        ((p.choose (i + 1) : ℕ) : ZMod p) = 0 :=
      zmod_choose_succ (p := p) hi_succ_lt
    have hchoose_poly :
        (p.choose (i + 1) : Polynomial (ZMod p)) = 0 := by
      rw [← Polynomial.C_eq_natCast]
      rw [hchoose]
      simp
    simp [hchoose_poly]
  · intro hnot
    have hmem : p - 1 ∈ Finset.range p := by
      exact Finset.mem_range.mpr (by omega)
    exact False.elim (hnot hmem)

/--
Evaluating the geometric polynomial after the shift `X |-> X + 1`.

This isolates the noncommutative evaluation step: although the polynomial lives
over the commutative ring `ZMod p`, it can be evaluated at an element of any
ring of characteristic `p`.
-/
lemma aeval_geometric_x
    {p : ℕ}
    {A : Type*} [Ring A] [CharP A p] [Algebra (ZMod p) A]
    (x : A) :
    Polynomial.aeval x
        (((Finset.range p).sum (fun i : ℕ =>
            (Polynomial.X : Polynomial (ZMod p)) ^ i)).comp
          (Polynomial.X + 1)) =
      Finset.sum (Finset.range p) (fun i => (1 + x) ^ i) := by
  rw [Polynomial.aeval_comp]
  simp [add_comm]

/--
The characteristic-`p` geometric sum identity.

In any ring of characteristic `p`, the finite geometric coefficient of
`1 + x` is `x^(p-1)`.  This is the polynomial identity
`Σ_{r<p} (1+X)^r = X^(p-1)` over `𝔽_p`, evaluated at `x`.
-/
theorem geom_pred_char
    {p : ℕ} [Fact p.Prime]
    {A : Type*} [Ring A] [CharP A p]
    (x : A) :
    Finset.sum (Finset.range p) (fun r => (1 + x) ^ r) = x ^ (p - 1) := by
  letI : Algebra (ZMod p) A := ZMod.algebra A p
  let geom : Polynomial (ZMod p) :=
    (Finset.range p).sum fun i : ℕ =>
      (Polynomial.X : Polynomial (ZMod p)) ^ i
  have hpoly :
      geom.comp (Polynomial.X + 1) =
        (Finset.range p).sum (fun i : ℕ =>
          (p.choose (i + 1) : Polynomial (ZMod p)) * Polynomial.X ^ i) := by
    simpa [geom] using
      (Polynomial.geom_sum_X_comp_X_add_one_eq_sum (R := ZMod p) p)
  calc
    Finset.sum (Finset.range p) (fun r => (1 + x) ^ r)
        = Polynomial.aeval x (geom.comp (Polynomial.X + 1)) := by
            simpa [geom] using
              (aeval_geometric_x (p := p) x).symm
    _ =
        Polynomial.aeval x
          ((Finset.range p).sum (fun i : ℕ =>
            (p.choose (i + 1) : Polynomial (ZMod p)) * Polynomial.X ^ i)) := by
            rw [hpoly]
    _ = Polynomial.aeval x
          ((Polynomial.X : Polynomial (ZMod p)) ^ (p - 1)) := by
            rw [geometric_hockey_stick (p := p)]
    _ = x ^ (p - 1) := by
            simp

/--
The group-algebra geometric coefficient for a free-group element.

For `X = g - 1`, the sum of the group elements `1 + g + ... + g^(p-1)` is
`X^(p-1)` in characteristic `p`.
-/
lemma free_geometric_difference
    {p : ℕ} [Fact p.Prime]
    {ι : Type*}
    (g : FreeGroup ι) :
    Finset.sum (Finset.range p) (fun r =>
        MonoidAlgebra.single (g ^ r) (1 : ZMod p)) =
      (augmentationDifference (ZMod p) (FreeGroup ι) g) ^ (p - 1) := by
  let A := MonoidAlgebra (ZMod p) (FreeGroup ι)
  let sg : A := MonoidAlgebra.single g (1 : ZMod p)
  let X : A := augmentationDifference (ZMod p) (FreeGroup ι) g
  have hsingleOne_injective :
      Function.Injective
        (MonoidAlgebra.singleOneRingHom
          (R := ZMod p) (M := FreeGroup ι)) := by
    intro a b hab
    have hcoeff := congr_arg (fun x : A => x (1 : FreeGroup ι)) hab
    simpa [A, MonoidAlgebra.singleOneRingHom] using hcoeff
  haveI : CharP A p := charP_of_injective_ringHom hsingleOne_injective p
  have hsg : sg = 1 + X := by
    dsimp [sg, X, augmentationDifference]
    abel
  have hterm :
      ∀ r : ℕ,
        MonoidAlgebra.single (g ^ r) (1 : ZMod p) = (1 + X) ^ r := by
    intro r
    have hsingle_pow :
        sg ^ r = MonoidAlgebra.single (g ^ r) (1 : ZMod p) := by
      change (MonoidAlgebra.single g (1 : ZMod p)) ^ r =
        MonoidAlgebra.single (g ^ r) (1 : ZMod p)
      rw [MonoidAlgebra.single_pow]
      simp
    calc
      MonoidAlgebra.single (g ^ r) (1 : ZMod p)
          = sg ^ r := hsingle_pow.symm
      _ = (1 + X) ^ r := by rw [hsg]
  calc
    Finset.sum (Finset.range p) (fun r =>
        MonoidAlgebra.single (g ^ r) (1 : ZMod p))
        = Finset.sum (Finset.range p) (fun r => (1 + X) ^ r) := by
            apply Finset.sum_congr rfl
            intro r _hr
            exact hterm r
    _ = X ^ (p - 1) :=
            geom_pred_char (p := p) X
    _ = (augmentationDifference (ZMod p) (FreeGroup ι) g) ^ (p - 1) := by
            rfl

/--
The geometric Fox coefficient has the filtration degree predicted by Jennings.
-/
lemma free_geometric_pow
    {p : ℕ} [Fact p.Prime]
    {ι : Type*}
    {m : ℕ}
    {g : FreeGroup ι}
    (hDiff :
      augmentationDifference (ZMod p) (FreeGroup ι) g ∈
        (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^ m) :
    Finset.sum (Finset.range p) (fun r =>
        MonoidAlgebra.single (g ^ r) (1 : ZMod p)) ∈
      (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^ (m * (p - 1)) := by
  let A := MonoidAlgebra (ZMod p) (FreeGroup ι)
  let I : Ideal A :=
    GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)
  haveI : I.IsTwoSided := by
    dsimp [I, GShafar.augmentationIdeal]
    infer_instance
  have hpow :
      (augmentationDifference (ZMod p) (FreeGroup ι) g) ^ (p - 1) ∈
        I ^ (m * (p - 1)) :=
    of_mem_pow I (by simpa [I] using hDiff)
  rw [free_geometric_difference (p := p) g]
  exact hpow

/--
The single `p`-power step for Fox derivatives.

Assume `g - 1` starts in degree `m` and `∂g` starts in degree `m - 1`.  The
geometric Fox formula gives
`∂(g^p) = (1 + g + ... + g^(p-1)) ∂g`; over `𝔽_p`, the geometric coefficient is
`(g - 1)^(p-1)`, hence has degree `m * (p - 1)`.  Multiplying by `∂g` gives
degree `m * p - 1`.
-/
theorem fox_derivative_pow
    {p : ℕ} [Fact p.Prime]
    {ι : Type*} [DecidableEq ι]
    {m : ℕ}
    {g : FreeGroup ι}
    (hDiff :
      augmentationDifference (ZMod p) (FreeGroup ι) g ∈
        (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^ m)
    (j : ι)
    (hDeriv :
      groupFoxDerivative (ZMod p) j g ∈
        (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^ (m - 1))
    :
    groupFoxDerivative (ZMod p) j (g ^ p) ∈
      (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^ (m * p - 1) := by
  let A := MonoidAlgebra (ZMod p) (FreeGroup ι)
  let I : Ideal A :=
    GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)
  haveI : I.IsTwoSided := by
    dsimp [I, GShafar.augmentationIdeal]
    infer_instance
  let coeff : A :=
    Finset.sum (Finset.range p) fun r =>
      MonoidAlgebra.single (g ^ r) (1 : ZMod p)
  let D : A := groupFoxDerivative (ZMod p) j g
  have hcoeff : coeff ∈ I ^ (m * (p - 1)) := by
    simpa [coeff, I] using
      free_geometric_pow
        (p := p) (m := m) (g := g) hDiff
  have hD : D ∈ I ^ (m - 1) := by
    simpa [D, I] using hDeriv
  have hformula :
      groupFoxDerivative (ZMod p) j (g ^ p) = coeff * D := by
    calc
      groupFoxDerivative (ZMod p) j (g ^ p)
          =
            Finset.sum (Finset.range p) fun r =>
              MonoidAlgebra.single (g ^ r) (1 : ZMod p) *
                groupFoxDerivative (ZMod p) j g := by
              rw [fox_derivative_sum]
      _ = coeff * D := by
              dsimp [coeff, D]
              rw [← Finset.sum_mul]
  have hmul : coeff * D ∈ I ^ (m * (p - 1)) * I ^ (m - 1) :=
    Ideal.mul_mem_mul hcoeff hD
  have htarget : coeff * D ∈ I ^ (m * (p - 1) + (m - 1)) := by
    rw [Ideal.IsTwoSided.pow_add]
    exact hmul
  have hdegree : m * (p - 1) + (m - 1) = m * p - 1 := by
    have hp_one : 1 ≤ p := (Fact.out : Nat.Prime p).one_le
    cases m with
    | zero =>
        simp
    | succ m =>
        have hp_sub_add : p - 1 + 1 = p := Nat.sub_add_cancel hp_one
        calc
          (Nat.succ m) * (p - 1) + (Nat.succ m - 1)
              = (m * (p - 1) + (p - 1)) + m := by
                  simp [Nat.succ_mul]
          _ = m * (p - 1) + m + (p - 1) := by
                  omega
          _ = m * ((p - 1) + 1) + (p - 1) := by
                  rw [Nat.mul_add, Nat.mul_one]
          _ = m * p + (p - 1) := by
                  rw [hp_sub_add]
          _ = m * p + p - 1 := by
                  omega
          _ = (Nat.succ m) * p - 1 := by
                  rw [Nat.succ_mul]
  rw [hformula]
  simpa [hdegree] using htarget

/--
The `p`-power half of the Fox filtration estimate for Zassenhaus generators.

If `x` has lower-central weight `i + 1`, then `x^(p^k)` has Zassenhaus weight
`(i + 1) * p^k`; over `𝔽_p`, its Fox derivative therefore has augmentation
degree one less.
-/
theorem free_fox_derivative
    {p : ℕ} [Fact p.Prime]
    {ι : Type*} [DecidableEq ι]
    {i k : ℕ}
    {x : FreeGroup ι}
    (hx : x ∈ Subgroup.lowerCentralSeries (FreeGroup ι) i)
    (j : ι) :
    groupFoxDerivative (ZMod p) j (x ^ (p ^ k)) ∈
      (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^
        ((i + 1) * p ^ k - 1) := by
  induction k with
  | zero =>
      have hbase :
          groupFoxDerivative (ZMod p) j x ∈
            (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^ i :=
        fox_derivative_central
          (p := p) hx j
      simpa using hbase
  | succ k ih =>
      let m : ℕ := (i + 1) * p ^ k
      have hDiff :
          augmentationDifference (ZMod p) (FreeGroup ι) (x ^ (p ^ k)) ∈
            (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^ m := by
        simpa [m] using
          free_difference_power
            (p := p) (i := i) (k := k) hx
      have hDeriv :
          groupFoxDerivative (ZMod p) j (x ^ (p ^ k)) ∈
            (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^ (m - 1) := by
        simpa [m] using ih
      have hstep :
          groupFoxDerivative (ZMod p) j ((x ^ (p ^ k)) ^ p) ∈
            (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^
              (m * p - 1) :=
        fox_derivative_pow
          (p := p) (m := m) (g := x ^ (p ^ k)) hDiff j hDeriv
      have hpow :
          x ^ (p ^ (k + 1)) = (x ^ (p ^ k)) ^ p := by
        rw [pow_succ, pow_mul]
      have hdegree :
          m * p - 1 = (i + 1) * p ^ (k + 1) - 1 := by
        change ((i + 1) * p ^ k) * p - 1 = (i + 1) * p ^ (k + 1) - 1
        rw [pow_succ, Nat.mul_assoc]
      simpa [hpow, hdegree] using hstep

/--
Fox derivatives of the explicit generators of `D_n(F)` have degree at least
`n - 1`.

This packages the lower-central and `p`-power estimates in exactly the shape of
`zassenhausGeneratorSet`.
-/
theorem fox_derivative_generator
    {p : ℕ} [Fact p.Prime]
    {ι : Type*} [DecidableEq ι]
    {n : ℕ}
    {g : FreeGroup ι}
    (hg : g ∈ zassenhausGeneratorSet p (FreeGroup ι) n)
    (hn : 2 ≤ n)
    (j : ι) :
    groupFoxDerivative (ZMod p) j g ∈
      (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^ (n - 1) := by
  rcases hg with ⟨i, k, x, hx_lower, hweight, rfl⟩
  have hprimePower :
      groupFoxDerivative (ZMod p) j (x ^ (p ^ k)) ∈
        (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^
          ((i + 1) * p ^ k - 1) :=
    free_fox_derivative
      (p := p) hx_lower j
  have hle : n - 1 ≤ (i + 1) * p ^ k - 1 := by
    omega
  exact Ideal.pow_le_pow_right hle hprimePower

/--
The Fox filtration estimate is stable under subgroup closure.

Once it is known for the explicit Zassenhaus generators, it extends to their
subgroup closure using the Fox product and inverse rules together with the fact
that augmentation powers are ideals.
-/
theorem fox_derivative_closure
    {p : ℕ} [Fact p.Prime]
    {ι : Type*} [DecidableEq ι]
    {n : ℕ}
    (hgen :
      ∀ g ∈ zassenhausGeneratorSet p (FreeGroup ι) n,
        ∀ j : ι,
          groupFoxDerivative (ZMod p) j g ∈
            (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^ (n - 1))
    {g : FreeGroup ι}
    (hg : g ∈ zassenhausFiltration p (FreeGroup ι) n)
    (j : ι) :
    groupFoxDerivative (ZMod p) j g ∈
      (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^ (n - 1) := by
  let I : Ideal (MonoidAlgebra (ZMod p) (FreeGroup ι)) :=
    GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)
  have hclosed :
      ∀ g ∈ Subgroup.closure (zassenhausGeneratorSet p (FreeGroup ι) n),
        ∀ j : ι, groupFoxDerivative (ZMod p) j g ∈ I ^ (n - 1) := by
    intro g hg
    refine Subgroup.closure_induction
      (k := zassenhausGeneratorSet p (FreeGroup ι) n)
      (p := fun g _hg =>
        ∀ j : ι, groupFoxDerivative (ZMod p) j g ∈ I ^ (n - 1))
      ?mem ?one ?mul ?inv hg
    · intro x hxgen j
      simpa [I] using hgen x hxgen j
    · intro j
      rw [group_fox_derivative]
      exact Submodule.zero_mem (I ^ (n - 1))
    · intro x y _hx _hy hxI hyI j
      exact
        free_derivative_pow
          (p := p) (n := n - 1)
          (x := x) (y := y)
          (by intro j; simpa [I] using hxI j)
          (by intro j; simpa [I] using hyI j)
          j
    · intro x _hx hxI j
      exact
        fox_derivative_inv
          (p := p) (n := n - 1)
          (x := x)
          (by intro j; simpa [I] using hxI j)
          j
  exact hclosed g (by simpa [zassenhausFiltration] using hg) j

/--
Fox derivatives lower Zassenhaus degree by one in the free group algebra.

This is the free-group form of the coefficient-filtration theorem.  It contains
all nontrivial Fox/Zassenhaus mathematics, while the later presented version is
only this theorem transported through the quotient group-algebra map.
-/
theorem fox_derivative_zassenhaus
    {p : ℕ} [Fact p.Prime]
    {ι : Type*} [DecidableEq ι]
    {n : ℕ}
    {g : FreeGroup ι}
    (hg : g ∈ zassenhausFiltration p (FreeGroup ι) n)
    (hn : 2 ≤ n)
    (j : ι) :
    groupFoxDerivative (ZMod p) j g ∈
      (GShafar.augmentationIdeal (ZMod p) (FreeGroup ι)) ^ (n - 1) := by
  refine
    fox_derivative_closure
      (p := p) (n := n) ?_ hg j
  intro g hggen j
  exact
    fox_derivative_generator
      (p := p) hggen hn j

/-- The degree-one numerator `I` of the augmentation filtration. -/
abbrev augmentationDegreeSubmodule
    (R G : Type*) [CommRing R] [Group G] :
    Submodule R (MonoidAlgebra R G) :=
  ((GShafar.augmentationIdeal R G) ^ (1 : ℕ)).restrictScalars R

/-- The degree-one denominator `I²` of the augmentation filtration. -/
abbrev augmentationSquareSubmodule
    (R G : Type*) [CommRing R] [Group G] :
    Submodule R (MonoidAlgebra R G) :=
  ((GShafar.augmentationIdeal R G) ^ (2 : ℕ)).restrictScalars R

/-- The kernel submodule defining the quotient `I / I²`. -/
abbrev augmentationDegreeKernel
    (R G : Type*) [CommRing R] [Group G] :
    Submodule R (augmentationDegreeSubmodule R G) :=
  (augmentationSquareSubmodule R G).comap
    (Submodule.subtype (augmentationDegreeSubmodule R G))

/-- The first associated graded piece `I / I²` of the augmentation filtration. -/
abbrev augmentationDegreeLayer
    (R G : Type*) [CommRing R] [Group G] : Type _ :=
  (↥(augmentationDegreeSubmodule R G)) ⧸
    augmentationDegreeKernel R G

/-- The class of `g - 1` in the degree-one augmentation layer `I / I²`. -/
noncomputable def augmentationDegreeClass
    (R G : Type*) [CommRing R] [Group G] (g : G) :
    augmentationDegreeLayer R G :=
  Submodule.Quotient.mk
    (p := augmentationDegreeKernel R G)
    ⟨augmentationDifference R G g, by
      change augmentationDifference R G g ∈
        ((GShafar.augmentationIdeal R G) ^ (1 : ℕ) :
          Submodule (MonoidAlgebra R G) (MonoidAlgebra R G))
      rw [Submodule.pow_one]
      exact augmentation_difference_ideal R G g⟩

/--
The quotient class in `I / I²` of an arbitrary element known to lie in the
augmentation ideal.
-/
noncomputable def augmentationDegreeMk
    (R G : Type*) [CommRing R] [Group G]
    (x : MonoidAlgebra R G)
    (hx : x ∈ GShafar.augmentationIdeal R G) :
    augmentationDegreeLayer R G :=
  Submodule.Quotient.mk
    (p := augmentationDegreeKernel R G)
    ⟨x, by
      change x ∈
        ((GShafar.augmentationIdeal R G) ^ (1 : ℕ) :
          Submodule (MonoidAlgebra R G) (MonoidAlgebra R G))
      rw [Submodule.pow_one]
      exact hx⟩

/-- For a group element, `augmentationDegreeMk` recovers `augmentationDegreeClass`. -/
lemma augmentation_mk_difference
    (R G : Type*) [CommRing R] [Group G] (g : G)
    (hx : augmentationDifference R G g ∈
      GShafar.augmentationIdeal R G) :
    augmentationDegreeMk R G (augmentationDifference R G g) hx =
      augmentationDegreeClass R G g := by
  rfl

/-- The identity element has zero degree-one augmentation class. -/
lemma augmentation_degree_class
    (R G : Type*) [CommRing R] [Group G] :
    augmentationDegreeClass R G (1 : G) = 0 := by
  apply (Submodule.Quotient.mk_eq_zero (augmentationDegreeKernel R G)).2
  change augmentationDifference R G (1 : G) ∈
    ((GShafar.augmentationIdeal R G) ^ (2 : ℕ)).restrictScalars R
  change augmentationDifference R G (1 : G) ∈
    ((GShafar.augmentationIdeal R G) ^ (2 : ℕ) :
      Submodule (MonoidAlgebra R G) (MonoidAlgebra R G))
  have hzero : augmentationDifference R G (1 : G) = 0 := by
    simp [augmentationDifference, MonoidAlgebra.one_def]
  rw [hzero]
  exact Submodule.zero_mem _

/--
Subtracting the scalar augmentation from a group-algebra element lands in the
augmentation ideal.
-/
lemma sub_single_ideal
    (R G : Type*) [CommRing R] [Group G]
    (a : MonoidAlgebra R G) :
    a - MonoidAlgebra.single (1 : G)
        ((GShafar.augmentationHom R G).toRingHom a) ∈
      GShafar.augmentationIdeal R G := by
  rw [GShafar.augmentationIdeal, RingHom.mem_ker]
  simp [map_sub, GShafar.augmentationHom,
    GShafar.augmentationCharacter]

/-- The product of two elements of the augmentation ideal lies in `I²`. -/
lemma augmentation_ideal_sq
    (R G : Type*) [CommRing R] [Group G]
    {x y : MonoidAlgebra R G}
    (hx : x ∈ GShafar.augmentationIdeal R G)
    (hy : y ∈ GShafar.augmentationIdeal R G) :
    x * y ∈
      ((GShafar.augmentationIdeal R G) ^ (2 : ℕ) :
        Submodule (MonoidAlgebra R G) (MonoidAlgebra R G)) := by
  rw [show (2 : ℕ) = 1 + 1 by norm_num]
  rw [Submodule.pow_succ, Submodule.pow_one]
  exact Ideal.mul_mem_mul hx hy

/--
In the quotient `I / I²`, left multiplication by a group-algebra element is only
scalar multiplication by its augmentation.
-/
lemma augmentation_mk_smul
    (R G : Type*) [CommRing R] [Group G]
    (a x : MonoidAlgebra R G)
    (hx : x ∈ GShafar.augmentationIdeal R G) :
    augmentationDegreeMk R G
        (a * x)
        ((GShafar.augmentationIdeal R G).mul_mem_left a hx) =
      ((GShafar.augmentationHom R G).toRingHom a) •
        augmentationDegreeMk R G x hx := by
  apply (Submodule.Quotient.eq (augmentationDegreeKernel R G)).2
  change
    a * x -
        ((GShafar.augmentationHom R G).toRingHom a) • x ∈
      ((GShafar.augmentationIdeal R G) ^ (2 : ℕ)).restrictScalars R
  change
    a * x -
        ((GShafar.augmentationHom R G).toRingHom a) • x ∈
      ((GShafar.augmentationIdeal R G) ^ (2 : ℕ) :
        Submodule (MonoidAlgebra R G) (MonoidAlgebra R G))
  have hscalar :
      MonoidAlgebra.single (1 : G)
          ((GShafar.augmentationHom R G).toRingHom a) * x =
        ((GShafar.augmentationHom R G).toRingHom a) • x := by
    ext g
    simp
  have hdiff :
      a * x -
          ((GShafar.augmentationHom R G).toRingHom a) • x =
        (a - MonoidAlgebra.single (1 : G)
          ((GShafar.augmentationHom R G).toRingHom a)) * x := by
    rw [← hscalar]
    noncomm_ring
  rw [hdiff]
  exact augmentation_ideal_sq R G
    (sub_single_ideal R G a)
    hx

/-- The quotient constructor is additive. -/
lemma augmentation_mk_add
    (R G : Type*) [CommRing R] [Group G]
    {x y : MonoidAlgebra R G}
    (hx : x ∈ GShafar.augmentationIdeal R G)
    (hy : y ∈ GShafar.augmentationIdeal R G) :
    augmentationDegreeMk R G (x + y)
        ((GShafar.augmentationIdeal R G).add_mem hx hy) =
      augmentationDegreeMk R G x hx +
        augmentationDegreeMk R G y hy := by
  rfl

/--
The product of two augmentation differences lies in `I²`.

This is the algebraic reason multiplication in the group becomes addition in the
degree-one associated graded piece.
-/
lemma augmentation_difference_sq
    (R G : Type*) [CommRing R] [Group G] (g h : G) :
    augmentationDifference R G g * augmentationDifference R G h ∈
      ((GShafar.augmentationIdeal R G) ^ (2 : ℕ) :
        Submodule (MonoidAlgebra R G) (MonoidAlgebra R G)) := by
  exact augmentation_ideal_sq R G
    (augmentation_difference_ideal R G g)
    (augmentation_difference_ideal R G h)

/--
Modulo `I²`, the difference attached to a product differs from the sum of the
two differences by the product of the differences.
-/
lemma difference_sub_sum
    (R G : Type*) [CommRing R] [Group G] (g h : G) :
    augmentationDifference R G (g * h) -
        (augmentationDifference R G g + augmentationDifference R G h) =
      augmentationDifference R G g * augmentationDifference R G h := by
  unfold augmentationDifference
  have hmul :
      MonoidAlgebra.single g (1 : R) * MonoidAlgebra.single h (1 : R) =
        MonoidAlgebra.single (g * h) (1 : R) := by
    simp [MonoidAlgebra.single_mul_single]
  rw [← hmul]
  noncomm_ring

/--
In `I / I²`, the class of `g * h - 1` is the sum of the classes of `g - 1` and
`h - 1`.
-/
lemma augmentation_degree_mul
    (R G : Type*) [CommRing R] [Group G] (g h : G) :
    augmentationDegreeClass R G (g * h) =
      augmentationDegreeClass R G g + augmentationDegreeClass R G h := by
  apply (Submodule.Quotient.eq (augmentationDegreeKernel R G)).2
  change
    augmentationDifference R G (g * h) -
        (augmentationDifference R G g + augmentationDifference R G h) ∈
      ((GShafar.augmentationIdeal R G) ^ (2 : ℕ)).restrictScalars R
  change
    augmentationDifference R G (g * h) -
        (augmentationDifference R G g + augmentationDifference R G h) ∈
      ((GShafar.augmentationIdeal R G) ^ (2 : ℕ) :
        Submodule (MonoidAlgebra R G) (MonoidAlgebra R G))
  rw [difference_sub_sum]
  exact augmentation_difference_sq R G g h

/--
The degree-one augmentation class kills inverses additively.
-/
lemma augmentation_degree_inv
    (R G : Type*) [CommRing R] [Group G] (g : G) :
    augmentationDegreeClass R G g⁻¹ =
      -augmentationDegreeClass R G g := by
  have hmul := augmentation_degree_mul R G g⁻¹ g
  rw [inv_mul_cancel, augmentation_degree_class] at hmul
  exact eq_neg_of_add_eq_zero_left hmul.symm

/--
The degree-one augmentation class kills commutators. This is the first formal
shadow of the Frattini quotient inside the group algebra.
-/
lemma augmentation_degree_commutator
    (R G : Type*) [CommRing R] [Group G] (g h : G) :
    augmentationDegreeClass R G (g * h * g⁻¹ * h⁻¹) = 0 := by
  rw [augmentation_degree_mul]
  rw [augmentation_degree_mul]
  rw [augmentation_degree_mul]
  rw [augmentation_degree_inv]
  rw [augmentation_degree_inv]
  abel

/--
A multiplicative character `G → Multiplicative (ZMod p)` is the same as an
additive `ZMod p`-valued character after applying `Multiplicative.toAdd`.
Extending its values linearly over the group algebra gives the linear form that
will descend to `I / I²`.
-/
noncomputable def multiplicativeZForm
    {p : ℕ} (G : Type*) [Group G]
    (χ : G →* Multiplicative (ZMod p)) :
    MonoidAlgebra (ZMod p) G →ₗ[ZMod p] ZMod p :=
  Finsupp.linearCombination (ZMod p) fun g : G => (χ g).toAdd

@[simp]
lemma multiplicative_z_single
    {p : ℕ} (G : Type*) [Group G]
    (χ : G →* Multiplicative (ZMod p))
    (g : G) (a : ZMod p) :
    multiplicativeZForm G χ
        (MonoidAlgebra.single g a) =
      a * (χ g).toAdd := by
  rw [multiplicativeZForm]
  change
    (Finsupp.linearCombination (ZMod p)
        (fun g : G => (χ g).toAdd)) (Finsupp.single g a) =
      a * (χ g).toAdd
  rw [Finsupp.linearCombination_single]
  rw [smul_eq_mul]

@[simp]
lemma multiplicative_z_mod
    {p : ℕ} (G : Type*) [Group G]
    (χ : G →* Multiplicative (ZMod p)) :
    multiplicativeZForm G χ
        (1 : MonoidAlgebra (ZMod p) G) = 0 := by
  simp [MonoidAlgebra.one_def]

/--
On the augmentation difference `g - 1`, the character-linear form reads off the
additive value of the character at `g`.
-/
lemma z_form_difference
    {p : ℕ} (G : Type*) [Group G]
    (χ : G →* Multiplicative (ZMod p)) (g : G) :
    multiplicativeZForm G χ
        (augmentationDifference (ZMod p) G g) =
      (χ g).toAdd := by
  simp [augmentationDifference]

/--
If a group element is killed by the multiplicative character, then its
degree-one augmentation difference is killed by the associated linear form.
-/
lemma multiplicative_z_difference
    {p : ℕ} (G : Type*) [Group G]
    (χ : G →* Multiplicative (ZMod p)) {g : G}
    (hχ : χ g = 1) :
    multiplicativeZForm G χ
        (augmentationDifference (ZMod p) G g) = 0 := by
  rw [z_form_difference]
  rw [hχ]
  simp

/--
The character-linear form kills the basic products `(g - 1)(h - 1)`.  This is
the concrete `I²` calculation behind the eventual descent to the degree-one
augmentation quotient.
-/
lemma multiplicative_form_difference
    {p : ℕ} (G : Type*) [Group G]
    (χ : G →* Multiplicative (ZMod p)) (g h : G) :
    multiplicativeZForm G χ
        (augmentationDifference (ZMod p) G g *
          augmentationDifference (ZMod p) G h) = 0 := by
  rw [← difference_sub_sum (ZMod p) G g h]
  rw [LinearMap.map_sub, LinearMap.map_add]
  rw [z_form_difference]
  rw [z_form_difference]
  rw [z_form_difference]
  rw [χ.map_mul]
  change (χ g).toAdd + (χ h).toAdd -
      ((χ g).toAdd + (χ h).toAdd) = 0
  abel

/--
The weighted difference `a • g - a • 1` belongs to the ideal generated by all
augmentation differences.
-/
lemma weighted_difference_span
    (R G : Type*) [CommRing R] [Group G] (a : R) (g : G) :
    MonoidAlgebra.single g a - MonoidAlgebra.single 1 a ∈
      Ideal.span (Set.range (fun h : G => augmentationDifference R G h)) := by
  classical
  let J : Ideal (MonoidAlgebra R G) :=
    Ideal.span (Set.range (fun h : G => augmentationDifference R G h))
  have hgen : augmentationDifference R G g ∈ J := by
    exact Ideal.subset_span ⟨g, rfl⟩
  have hmul :
      MonoidAlgebra.single 1 a * augmentationDifference R G g ∈ J := by
    exact Ideal.mul_mem_left J (MonoidAlgebra.single 1 a) hgen
  have hsingle_mul :
      MonoidAlgebra.single 1 a * augmentationDifference R G g =
        MonoidAlgebra.single g a - MonoidAlgebra.single 1 a := by
    simp [augmentationDifference, mul_sub, MonoidAlgebra.single_mul_single]
  exact hsingle_mul ▸ hmul

/-- Over a finite indexing group, a group-algebra element is the sum of its basis coefficients. -/
lemma monoid_sum_single
    (R G : Type*) [Semiring R] [Monoid G] [Fintype G]
    (x : MonoidAlgebra R G) :
    x = ∑ g : G, MonoidAlgebra.single g (x g) := by
  classical
  calc
    x = x.sum (fun g a => MonoidAlgebra.single g a) := by
      exact (Finsupp.sum_single x).symm
    _ = (∑ g ∈ x.support, MonoidAlgebra.single g (x g)) := by
      rfl
    _ = ∑ g : G, MonoidAlgebra.single g (x g) := by
      refine Finset.sum_subset (Finset.subset_univ x.support) ?_
      intro g _ hg
      rw [Finsupp.notMem_support_iff.mp hg]
      exact Finsupp.single_zero g

/-- The augmentation map is the sum of coefficients. -/
lemma augmentation_sum_coeff
    (R G : Type*) [CommSemiring R] [Monoid G] [Fintype G]
    (x : MonoidAlgebra R G) :
    (GShafar.augmentationHom R G).toRingHom x = ∑ g : G, x g := by
  classical
  conv_lhs => rw [monoid_sum_single R G x]
  simp [GShafar.augmentationHom, GShafar.augmentationCharacter]

/--
The augmentation ideal of a finite group algebra is generated by the differences
`g - 1`.

The nontrivial containment is the usual coefficient-sum decomposition: if
`∑ c_g g` has augmentation zero, then subtracting the coefficient of `1`
rewrites it as a finite sum of the terms `c_g * (g - 1)`.
-/
theorem augmentation_span_differences
    (R G : Type*) [CommRing R] [Group G] [Finite G] :
    GShafar.augmentationIdeal R G =
      Ideal.span (Set.range (fun g : G => augmentationDifference R G g)) := by
  classical
  have hgenerators_mem :
      Set.range (fun g : G => augmentationDifference R G g) ⊆
        GShafar.augmentationIdeal R G := by
    intro x hx
    rcases hx with ⟨g, rfl⟩
    exact augmentation_difference_ideal R G g
  have hspan_le :
      Ideal.span (Set.range (fun g : G => augmentationDifference R G g)) ≤
        GShafar.augmentationIdeal R G :=
    Ideal.span_le.mpr hgenerators_mem
  apply le_antisymm
  · /-
    For the forward containment, expand an arbitrary finitely supported group
    algebra element in the canonical basis. The augmentation-zero condition says
    that the sum of its coefficients is zero, so the coefficient of `1` can be
    absorbed into the expression
      `∑ g, c_g • (single g 1 - 1)`.
    This gives membership in the ideal generated by all `g - 1`.
    -/
    intro x hx
    letI : Fintype G := Fintype.ofFinite G
    let J : Ideal (MonoidAlgebra R G) :=
      Ideal.span (Set.range (fun g : G => augmentationDifference R G g))
    have hcoeffsum : (∑ g : G, x g) = 0 := by
      have hxzero :
          (GShafar.augmentationHom R G).toRingHom x = 0 :=
        RingHom.mem_ker.mp hx
      rw [augmentation_sum_coeff R G x] at hxzero
      exact hxzero
    have hconstant_sum :
        (∑ g : G, MonoidAlgebra.single (1 : G) (x g)) = 0 := by
      calc
        (∑ g : G, MonoidAlgebra.single (1 : G) (x g))
            = MonoidAlgebra.single (1 : G) (∑ g : G, x g) := by
              exact (map_sum
                (MonoidAlgebra.singleAddHom (R := R) (M := G) (1 : G))
                (fun g : G => x g) Finset.univ).symm
        _ = 0 := by
          rw [hcoeffsum]
          exact MonoidAlgebra.single_zero (1 : G)
    have hx_eq_sum :
        x =
          ∑ g : G,
            (MonoidAlgebra.single g (x g) -
              MonoidAlgebra.single (1 : G) (x g)) := by
      calc
        x = ∑ g : G, MonoidAlgebra.single g (x g) := by
          exact monoid_sum_single R G x
        _ =
            (∑ g : G, MonoidAlgebra.single g (x g)) -
              ∑ g : G, MonoidAlgebra.single (1 : G) (x g) := by
              simp [hconstant_sum]
        _ =
          ∑ g : G,
            (MonoidAlgebra.single g (x g) -
              MonoidAlgebra.single (1 : G) (x g)) := by
            rw [Finset.sum_sub_distrib]
    rw [hx_eq_sum]
    exact Ideal.sum_mem J (t := Finset.univ) (fun g _hg =>
      weighted_difference_span R G (x g) g)
  · exact hspan_le

/--
The same finite-group decomposition, but as a statement about the underlying
`R`-submodule.  This stronger form is the right tool for linear functionals:
an augmentation-zero element is an `R`-linear combination of the differences
`g - 1`, without needing arbitrary group-algebra multipliers.
-/
theorem restrict_scalars_differences
    (R G : Type*) [CommRing R] [Group G] :
    (GShafar.augmentationIdeal R G).restrictScalars R =
      Submodule.span R (Set.range (fun g : G => augmentationDifference R G g)) := by
  classical
  apply le_antisymm
  · intro x hx
    let S : Submodule R (MonoidAlgebra R G) :=
      Submodule.span R (Set.range (fun g : G => augmentationDifference R G g))
    have hsub :
        ∀ y : MonoidAlgebra R G,
          y - MonoidAlgebra.single 1
              (GShafar.augmentationHom R G y) ∈ S := by
      intro y
      refine MonoidAlgebra.induction_on
        (p := fun y : MonoidAlgebra R G =>
          y - MonoidAlgebra.single 1
              (GShafar.augmentationHom R G y) ∈ S)
        y ?_ ?_ ?_
      · intro g
        simpa [S, augmentationDifference, GShafar.augmentationHom,
          GShafar.augmentationCharacter, MonoidAlgebra.one_def] using
          (Submodule.subset_span
            (R := R)
            (s := Set.range (fun g : G => augmentationDifference R G g))
            ⟨g, rfl⟩)
      · intro y z hy hz
        have hsum :
            y + z - MonoidAlgebra.single 1
                (GShafar.augmentationHom R G (y + z)) =
              (y - MonoidAlgebra.single 1
                (GShafar.augmentationHom R G y)) +
              (z - MonoidAlgebra.single 1
                (GShafar.augmentationHom R G z)) := by
          rw [map_add]
          have hsingle :
              MonoidAlgebra.single (1 : G)
                    (GShafar.augmentationHom R G y +
                      GShafar.augmentationHom R G z) =
                MonoidAlgebra.single (1 : G)
                    (GShafar.augmentationHom R G y) +
                  MonoidAlgebra.single (1 : G)
                    (GShafar.augmentationHom R G z) := by
            exact
              (MonoidAlgebra.singleAddHom (R := R) (M := G) (1 : G)).map_add
                (GShafar.augmentationHom R G y)
                (GShafar.augmentationHom R G z)
          rw [hsingle]
          abel
        rw [hsum]
        exact S.add_mem hy hz
      · intro r y hy
        have hsmul :
            r • y - MonoidAlgebra.single 1
                (GShafar.augmentationHom R G (r • y)) =
              r •
                (y - MonoidAlgebra.single 1
                  (GShafar.augmentationHom R G y)) := by
          simp [smul_sub, GShafar.augmentationHom,
            GShafar.augmentationCharacter]
        rw [hsmul]
        exact S.smul_mem r hy
    have hxzero :
        GShafar.augmentationHom R G x = 0 := by
      exact RingHom.mem_ker.mp hx
    have hxsub := hsub x
    have hsingle :
        MonoidAlgebra.single (1 : G) (0 : R) = 0 := by
      exact (MonoidAlgebra.singleAddHom (R := R) (M := G) (1 : G)).map_zero
    rw [hxzero, hsingle, sub_zero] at hxsub
    exact hxsub
  · refine Submodule.span_le.mpr ?_
    intro x hx
    rcases hx with ⟨g, rfl⟩
    exact augmentation_difference_ideal R G g

/--
The character-linear form kills products of two arbitrary elements of the
augmentation ideal.  The proof reduces both factors to the linear span of
augmentation differences and then uses the basic `(g - 1)(h - 1)` calculation.
-/
lemma multiplicative_z_form
    {p : ℕ} (G : Type*) [Group G] [Finite G]
    (χ : G →* Multiplicative (ZMod p))
    {x y : MonoidAlgebra (ZMod p) G}
    (hx : x ∈ GShafar.augmentationIdeal (ZMod p) G)
    (hy : y ∈ GShafar.augmentationIdeal (ZMod p) G) :
    multiplicativeZForm G χ (x * y) = 0 := by
  classical
  let S : Submodule (ZMod p) (MonoidAlgebra (ZMod p) G) :=
    Submodule.span (ZMod p)
      (Set.range fun g : G => augmentationDifference (ZMod p) G g)
  have hxS : x ∈ S := by
    have hx' :
        x ∈ (GShafar.augmentationIdeal (ZMod p) G).restrictScalars
          (ZMod p) := hx
    simpa [S, restrict_scalars_differences
      (ZMod p) G] using hx'
  have hyS : y ∈ S := by
    have hy' :
        y ∈ (GShafar.augmentationIdeal (ZMod p) G).restrictScalars
          (ZMod p) := hy
    simpa [S, restrict_scalars_differences
      (ZMod p) G] using hy'
  have hmul_zero :
      ∀ x ∈ S, ∀ y ∈ S,
        multiplicativeZForm G χ (x * y) = 0 := by
    intro x hx
    refine Submodule.span_induction (R := ZMod p)
      (s := Set.range fun g : G => augmentationDifference (ZMod p) G g)
      (p := fun x _ => ∀ y ∈ S,
        multiplicativeZForm G χ (x * y) = 0)
      ?mem ?zero ?add ?smul hx
    · intro x hx
      rcases hx with ⟨g, rfl⟩
      intro y hy
      refine Submodule.span_induction (R := ZMod p)
        (s := Set.range fun h : G => augmentationDifference (ZMod p) G h)
        (p := fun y _ =>
          multiplicativeZForm G χ
            (augmentationDifference (ZMod p) G g * y) = 0)
        ?mem_y ?zero_y ?add_y ?smul_y hy
      · intro y hy
        rcases hy with ⟨h, rfl⟩
        exact multiplicative_form_difference
          G χ g h
      · simp
      · intro y z _hy _hz hy0 hz0
        rw [mul_add, LinearMap.map_add, hy0, hz0, add_zero]
      · intro a y _hy hy0
        rw [mul_smul_comm, LinearMap.map_smul, hy0, smul_zero]
    · intro y _hy
      simp
    · intro x z _hx _hz hx0 hz0 y hy
      rw [add_mul, LinearMap.map_add, hx0 y hy, hz0 y hy, add_zero]
    · intro a x _hx hx0 y hy
      rw [smul_mul_assoc, LinearMap.map_smul, hx0 y hy, smul_zero]
  exact hmul_zero x hxS y hyS

/--
Consequently the character-linear form vanishes on `I²`, the denominator of the
degree-one augmentation layer.
-/
lemma multiplicative_z_sq
    {p : ℕ} (G : Type*) [Group G] [Finite G]
    (χ : G →* Multiplicative (ZMod p))
    {x : MonoidAlgebra (ZMod p) G}
    (hx : x ∈
      ((GShafar.augmentationIdeal (ZMod p) G) ^ (2 : ℕ) :
        Submodule (MonoidAlgebra (ZMod p) G)
          (MonoidAlgebra (ZMod p) G))) :
    multiplicativeZForm G χ x = 0 := by
  let I : Ideal (MonoidAlgebra (ZMod p) G) :=
    GShafar.augmentationIdeal (ZMod p) G
  have hxmul : x ∈ I * I := by
    rw [show (2 : ℕ) = 1 + 1 by norm_num] at hx
    rw [Submodule.pow_succ, Submodule.pow_one] at hx
    exact hx
  refine Submodule.mul_induction_on hxmul ?mul_mem ?add_mem
  · intro x hxI y hyI
    exact multiplicative_z_form
      G χ hxI hyI
  · intro x y hx0 hy0
    rw [LinearMap.map_add, hx0, hy0, add_zero]

/--
The restriction of the character-linear form to the augmentation ideal kills
the kernel defining `I / I²`.
-/
lemma multiplicative_z_character
    {p : ℕ} (G : Type*) [Group G] [Finite G]
    (χ : G →* Multiplicative (ZMod p))
    {x : augmentationDegreeSubmodule (ZMod p) G}
    (hx : x ∈ augmentationDegreeKernel (ZMod p) G) :
    multiplicativeZForm G χ (x : MonoidAlgebra (ZMod p) G) =
      0 := by
  exact multiplicative_z_sq
    G χ hx

/--
The descended functional on the first associated graded piece `I / I²`
associated to a multiplicative `ZMod p`-valued character.
-/
noncomputable def multiplicativeZFunctional
    {p : ℕ} (G : Type*) [Group G] [Finite G]
    (χ : G →* Multiplicative (ZMod p)) :
    augmentationDegreeLayer (ZMod p) G →ₗ[ZMod p] ZMod p :=
  (augmentationDegreeKernel (ZMod p) G).liftQ
    ((multiplicativeZForm G χ).comp
      (Submodule.subtype (augmentationDegreeSubmodule (ZMod p) G)))
    (by
      intro x hx
      rw [LinearMap.mem_ker]
      exact multiplicative_z_character
        G χ hx)

@[simp]
lemma multiplicative_z_functional
    {p : ℕ} (G : Type*) [Group G] [Finite G]
    (χ : G →* Multiplicative (ZMod p)) (g : G) :
    multiplicativeZFunctional G χ
        (augmentationDegreeClass (ZMod p) G g) =
      (χ g).toAdd := by
  simp [multiplicativeZFunctional,
    augmentationDegreeClass,
    z_form_difference]

/--
If the character is nontrivial, then the descended degree-one functional is
nonzero: otherwise all character values have additive coordinate zero.
-/
lemma multiplicative_functional_ne
    {p : ℕ} (G : Type*) [Group G] [Finite G]
    (χ : G →* Multiplicative (ZMod p))
    (hχ : χ ≠ 1) :
    multiplicativeZFunctional G χ ≠ 0 := by
  intro hℓ
  apply hχ
  ext g
  have hvalue :
      multiplicativeZFunctional G χ
          (augmentationDegreeClass (ZMod p) G g) =
        (0 : ZMod p) := by
    simpa using DFunLike.congr_fun hℓ
      (augmentationDegreeClass (ZMod p) G g)
  have htoAdd : (χ g).toAdd = 0 := by
    simpa using hvalue
  exact (toAdd_eq_zero).mp htoAdd

/--
An abstract character that kills a subgroup gives the annihilating functional
needed for the coatom-span obstruction.  The remaining group-theoretic work for
finite `p`-groups is only to manufacture such a nontrivial character from the
maximal quotient.
-/
theorem annihilator_functional_character
    {p : ℕ}
    {G : Type*} [Group G] [Finite G]
    {M : Subgroup G}
    {χ : G →* Multiplicative (ZMod p)}
    (hχ_ne : χ ≠ 1)
    (hχM : ∀ m : M, χ (m : G) = 1) :
    ∃ ℓ : augmentationDegreeLayer (ZMod p) G →ₗ[ZMod p] ZMod p,
      ℓ ≠ 0 ∧
        ∀ m : M,
          ℓ (augmentationDegreeClass (ZMod p) G (m : G)) = 0 := by
  let ℓ : augmentationDegreeLayer (ZMod p) G →ₗ[ZMod p] ZMod p :=
    multiplicativeZFunctional G χ
  refine ⟨ℓ, ?_, ?_⟩
  · exact multiplicative_functional_ne G χ hχ_ne
  · intro m
    rw [multiplicative_z_functional]
    rw [hχM m]
    simp

/--
Every element of the augmentation ideal has degree-one class in the span of the
classes `[g - 1]`.

The key point is that ideal generation by `g - 1` allows arbitrary left
multipliers, and `augmentation_mk_smul` reduces those
multipliers modulo `I²` to scalar multiplication by their augmentations.
-/
lemma mk_classes_ideal
    (R G : Type*) [CommRing R] [Group G] [Finite G]
    {x : MonoidAlgebra R G}
    (hx : x ∈ GShafar.augmentationIdeal R G) :
    augmentationDegreeMk R G x hx ∈
      Submodule.span R (Set.range (augmentationDegreeClass R G)) := by
  classical
  let A := MonoidAlgebra R G
  let I : Ideal A := GShafar.augmentationIdeal R G
  let S : Submodule R (augmentationDegreeLayer R G) :=
    Submodule.span R (Set.range (augmentationDegreeClass R G))
  have hxSpan :
      x ∈ Ideal.span (Set.range (fun g : G => augmentationDifference R G g)) := by
    simpa [I, augmentation_span_differences R G] using hx
  have hind :
      x ∈ I ∧
        ∀ hxI : x ∈ I, augmentationDegreeMk R G x hxI ∈ S := by
    refine Submodule.span_induction
      (s := Set.range (fun g : G => augmentationDifference R G g))
      (p := fun y _ =>
        y ∈ I ∧ ∀ hyI : y ∈ I, augmentationDegreeMk R G y hyI ∈ S)
      ?mem ?zero ?add ?smul hxSpan
    · intro y hy
      rcases hy with ⟨g, rfl⟩
      constructor
      · exact augmentation_difference_ideal R G g
      · intro hyI
        rw [augmentation_mk_difference R G g hyI]
        exact Submodule.subset_span (Set.mem_range_self g)
    · constructor
      · exact I.zero_mem
      · intro hzero
        change (0 : augmentationDegreeLayer R G) ∈ S
        exact Submodule.zero_mem S
    · intro y z _hySpan _hzSpan hy hz
      rcases hy with ⟨hyI, hyS⟩
      rcases hz with ⟨hzI, hzS⟩
      constructor
      · exact I.add_mem hyI hzI
      · intro hyzI
        change
          augmentationDegreeMk R G (y + z) (I.add_mem hyI hzI) ∈ S
        rw [augmentation_mk_add R G hyI hzI]
        exact S.add_mem (hyS hyI) (hzS hzI)
    · intro a y _hySpan hy
      rcases hy with ⟨hyI, hyS⟩
      constructor
      · exact I.smul_mem a hyI
      · intro hayI
        change
          augmentationDegreeMk R G (a * y) (I.mul_mem_left a hyI) ∈ S
        rw [augmentation_mk_smul R G a y hyI]
        exact S.smul_mem ((GShafar.augmentationHom R G).toRingHom a)
          (hyS hyI)
  exact hind.2 hx

/-- The classes `[g - 1]` span the full degree-one augmentation layer `I / I²`. -/
lemma augmentation_span_top
    (R G : Type*) [CommRing R] [Group G] [Finite G] :
    Submodule.span R (Set.range (augmentationDegreeClass R G)) = ⊤ := by
  classical
  let I : Ideal (MonoidAlgebra R G) := GShafar.augmentationIdeal R G
  let S : Submodule R (augmentationDegreeLayer R G) :=
    Submodule.span R (Set.range (augmentationDegreeClass R G))
  rw [eq_top_iff]
  intro q _hq
  refine Submodule.Quotient.induction_on
    (p := augmentationDegreeKernel R G) q ?_
  intro x
  have hxI : (x : MonoidAlgebra R G) ∈ I := by
    have hxpow :
        (x : MonoidAlgebra R G) ∈
          ((I) ^ (1 : ℕ) :
            Submodule (MonoidAlgebra R G) (MonoidAlgebra R G)) := by
      simp [I, augmentationDegreeSubmodule] at x ⊢
    simpa [Submodule.pow_one] using hxpow
  simpa [augmentationDegreeMk, S, I] using
    mk_classes_ideal
      R G hxI

/--
In a finite `p`-group, each basic augmentation difference is nilpotent over
`𝔽_p`.

Indeed, if `g` has order dividing `p^k`, then in characteristic `p` one has
`(g - 1)^(p^k) = g^(p^k) - 1 = 0`.
-/
theorem augmentation_difference_nilpotent
    (p : ℕ) (hp : Nat.Prime p)
    (G : Type*) [Group G] [Finite G]
    (_hG : IsPGroup p G) (g : G) :
    ∃ N : ℕ, (augmentationDifference (ZMod p) G g) ^ N = 0 := by
  classical
  letI : Fact p.Prime := ⟨hp⟩
  let A := MonoidAlgebra (ZMod p) G
  have hsingleOne_injective :
      Function.Injective
        (MonoidAlgebra.singleOneRingHom (R := ZMod p) (M := G)) := by
    intro a b hab
    have hcoeff := congr_arg (fun x : A => x (1 : G)) hab
    simpa [MonoidAlgebra.singleOneRingHom] using hcoeff
  haveI : CharP A p :=
    charP_of_injective_ringHom hsingleOne_injective p
  rcases _hG g with ⟨k, hgk⟩
  refine ⟨p ^ k, ?_⟩
  have hcomm :
      Commute (MonoidAlgebra.single g (1 : ZMod p)) (1 : A) :=
    Commute.one_right _
  calc
    (augmentationDifference (ZMod p) G g) ^ (p ^ k)
        = (MonoidAlgebra.single g (1 : ZMod p) - (1 : A)) ^ (p ^ k) := by
            rfl
    _ = (MonoidAlgebra.single g (1 : ZMod p)) ^ (p ^ k) - (1 : A) ^ (p ^ k) := by
            exact sub_pow_char_pow_of_commute
              (R := A)
              (x := MonoidAlgebra.single g (1 : ZMod p))
              (y := (1 : A))
              p
              k
              hcomm
    _ = 0 := by
            simp [MonoidAlgebra.single_pow, hgk, MonoidAlgebra.one_def, A]

/-- The norm element `∑ g, g` in a finite group algebra. -/
def groupAlgebraElement
    (R G : Type*) [Semiring R] [Monoid G] [Fintype G] :
    MonoidAlgebra R G :=
  ∑ g : G, MonoidAlgebra.single g 1

/-- The coefficient of the norm element is constantly `1`. -/
lemma algebra_norm_element
    (R G : Type*) [Semiring R] [Group G] [Fintype G] (g : G) :
    groupAlgebraElement R G g = 1 := by
  classical
  rw [groupAlgebraElement]
  calc
    (∑ h : G, MonoidAlgebra.single h (1 : R)) g =
        ∑ h ∈ (Finset.univ : Finset G),
          (MonoidAlgebra.single h (1 : R)) g := by
      exact
        (Finsupp.finsetSum_apply (Finset.univ : Finset G)
          (fun h : G => MonoidAlgebra.single h (1 : R)) g)
    _ = 1 := by
      rw [Finset.sum_eq_single g]
      · simp
      · intro h _hh hne
        exact Finsupp.single_eq_of_ne (Ne.symm hne)
      · intro hg
        exact False.elim (hg (Finset.mem_univ g))

/-- Left multiplication by a group element fixes the norm element. -/
lemma single_mul_element
    (R G : Type*) [CommSemiring R] [Group G] [Fintype G] (g : G) :
    MonoidAlgebra.single g (1 : R) * groupAlgebraElement R G =
      groupAlgebraElement R G := by
  classical
  ext h
  rw [algebra_norm_element R G h]
  rw [groupAlgebraElement]
  rw [Finset.mul_sum]
  calc
    (∑ a : G,
        MonoidAlgebra.single g (1 : R) * MonoidAlgebra.single a (1 : R)) h =
        ∑ a ∈ (Finset.univ : Finset G),
          (MonoidAlgebra.single g (1 : R) *
            MonoidAlgebra.single a (1 : R)) h := by
      exact
        (Finsupp.finsetSum_apply (Finset.univ : Finset G)
          (fun a : G =>
            MonoidAlgebra.single g (1 : R) *
              MonoidAlgebra.single a (1 : R)) h)
    _ = 1 := by
      rw [Finset.sum_eq_single (g⁻¹ * h)]
      · simp [MonoidAlgebra.single_mul_single]
      · intro a _ha hne
        have hga_ne : g * a ≠ h := by
          intro hga
          apply hne
          calc
            a = 1 * a := by rw [one_mul]
            _ = g⁻¹ * (g * a) := by simp
            _ = g⁻¹ * h := by rw [hga]
        simp [MonoidAlgebra.single_mul_single, hga_ne]
      · intro hg
        exact False.elim (hg (Finset.mem_univ (g⁻¹ * h)))

/-- Right multiplication by a group element fixes the norm element. -/
lemma group_element_single
    (R G : Type*) [CommSemiring R] [Group G] [Fintype G] (g : G) :
    groupAlgebraElement R G * MonoidAlgebra.single g (1 : R) =
      groupAlgebraElement R G := by
  classical
  ext h
  rw [algebra_norm_element R G h]
  rw [groupAlgebraElement]
  rw [Finset.sum_mul]
  calc
    (∑ a : G,
        MonoidAlgebra.single a (1 : R) * MonoidAlgebra.single g (1 : R)) h =
        ∑ a ∈ (Finset.univ : Finset G),
          (MonoidAlgebra.single a (1 : R) *
            MonoidAlgebra.single g (1 : R)) h := by
      exact
        (Finsupp.finsetSum_apply (Finset.univ : Finset G)
          (fun a : G =>
            MonoidAlgebra.single a (1 : R) *
              MonoidAlgebra.single g (1 : R)) h)
    _ = 1 := by
      rw [Finset.sum_eq_single (h * g⁻¹)]
      · simp [MonoidAlgebra.single_mul_single]
      · intro a _ha hne
        have hag_ne : a * g ≠ h := by
          intro hag
          apply hne
          calc
            a = a * 1 := by rw [mul_one]
            _ = (a * g) * g⁻¹ := by simp
            _ = h * g⁻¹ := by rw [hag]
        simp [MonoidAlgebra.single_mul_single, hag_ne]
      · intro hg
        exact False.elim (hg (Finset.mem_univ (h * g⁻¹)))

/-- Multiplication of the norm element by a scalar at the identity, on the left. -/
lemma single_norm_element
    (R G : Type*) [CommSemiring R] [Group G] [Fintype G] (r : R) :
    MonoidAlgebra.single (1 : G) r * groupAlgebraElement R G =
      ∑ g : G, MonoidAlgebra.single g r := by
  classical
  rw [groupAlgebraElement]
  rw [Finset.mul_sum]
  refine Finset.sum_congr rfl ?_
  intro g _hg
  simp [MonoidAlgebra.single_mul_single]

/-- Multiplication of the norm element by a scalar at the identity, on the right. -/
lemma algebra_element_single
    (R G : Type*) [CommSemiring R] [Group G] [Fintype G] (r : R) :
    groupAlgebraElement R G * MonoidAlgebra.single (1 : G) r =
      ∑ g : G, MonoidAlgebra.single g r := by
  classical
  rw [groupAlgebraElement]
  rw [Finset.sum_mul]
  refine Finset.sum_congr rfl ?_
  intro g _hg
  simp [MonoidAlgebra.single_mul_single]

/--
Right multiplication of the norm element by a single basis coefficient depends
only on that coefficient, not on the basis group element.
-/
lemma element_single_coeff
    (R G : Type*) [CommSemiring R] [Group G] [Fintype G] (g : G) (r : R) :
    groupAlgebraElement R G * MonoidAlgebra.single g r =
      MonoidAlgebra.single (1 : G) r * groupAlgebraElement R G := by
  classical
  have hsingle :
      MonoidAlgebra.single g r =
        MonoidAlgebra.single g (1 : R) * MonoidAlgebra.single (1 : G) r := by
    simp [MonoidAlgebra.single_mul_single]
  calc
    groupAlgebraElement R G * MonoidAlgebra.single g r =
        groupAlgebraElement R G *
          (MonoidAlgebra.single g (1 : R) *
            MonoidAlgebra.single (1 : G) r) := by
          rw [hsingle]
    _ =
        (groupAlgebraElement R G * MonoidAlgebra.single g (1 : R)) *
          MonoidAlgebra.single (1 : G) r := by
          rw [mul_assoc]
    _ = groupAlgebraElement R G * MonoidAlgebra.single (1 : G) r := by
          rw [group_element_single]
    _ = MonoidAlgebra.single (1 : G) r * groupAlgebraElement R G := by
          rw [algebra_element_single,
            single_norm_element]

/--
Left multiplication of the norm element by a single basis coefficient depends
only on that coefficient, not on the basis group element.
-/
lemma single_coeff_element
    (R G : Type*) [CommSemiring R] [Group G] [Fintype G] (g : G) (r : R) :
    MonoidAlgebra.single g r * groupAlgebraElement R G =
      MonoidAlgebra.single (1 : G) r * groupAlgebraElement R G := by
  classical
  have hsingle :
      MonoidAlgebra.single g r =
        MonoidAlgebra.single (1 : G) r * MonoidAlgebra.single g (1 : R) := by
    simp [MonoidAlgebra.single_mul_single]
  calc
    MonoidAlgebra.single g r * groupAlgebraElement R G =
        (MonoidAlgebra.single (1 : G) r *
          MonoidAlgebra.single g (1 : R)) *
            groupAlgebraElement R G := by
          rw [hsingle]
    _ =
        MonoidAlgebra.single (1 : G) r *
          (MonoidAlgebra.single g (1 : R) *
            groupAlgebraElement R G) := by
          rw [mul_assoc]
    _ = MonoidAlgebra.single (1 : G) r * groupAlgebraElement R G := by
          rw [single_mul_element]

/-- The norm element times an arbitrary group-algebra element is augmentation times norm. -/
lemma algebra_element_mul
    (R G : Type*) [CommSemiring R] [Group G] [Fintype G]
    (x : MonoidAlgebra R G) :
    groupAlgebraElement R G * x =
      MonoidAlgebra.single (1 : G)
          ((GShafar.augmentationHom R G).toRingHom x) *
        groupAlgebraElement R G := by
  classical
  have hsum_single :
      (∑ g : G, MonoidAlgebra.single (1 : G) (x g)) =
        MonoidAlgebra.single (1 : G) (∑ g : G, x g) := by
    exact (map_sum
      (MonoidAlgebra.singleAddHom (R := R) (M := G) (1 : G))
      (fun g : G => x g) Finset.univ).symm
  calc
    groupAlgebraElement R G * x =
        groupAlgebraElement R G *
          ∑ g : G, MonoidAlgebra.single g (x g) := by
          rw [← monoid_sum_single R G x]
    _ =
        ∑ g : G,
          groupAlgebraElement R G * MonoidAlgebra.single g (x g) := by
          rw [Finset.mul_sum]
    _ =
        ∑ g : G,
          MonoidAlgebra.single (1 : G) (x g) * groupAlgebraElement R G := by
          refine Finset.sum_congr rfl ?_
          intro g _hg
          exact element_single_coeff R G g (x g)
    _ =
        (∑ g : G, MonoidAlgebra.single (1 : G) (x g)) *
          groupAlgebraElement R G := by
          rw [Finset.sum_mul]
    _ =
        MonoidAlgebra.single (1 : G) (∑ g : G, x g) *
          groupAlgebraElement R G := by
          rw [hsum_single]
    _ =
        MonoidAlgebra.single (1 : G)
            ((GShafar.augmentationHom R G).toRingHom x) *
          groupAlgebraElement R G := by
          rw [augmentation_sum_coeff R G x]

/-- An arbitrary group-algebra element times the norm element is augmentation times norm. -/
lemma mul_algebra_element
    (R G : Type*) [CommSemiring R] [Group G] [Fintype G]
    (x : MonoidAlgebra R G) :
    x * groupAlgebraElement R G =
      MonoidAlgebra.single (1 : G)
          ((GShafar.augmentationHom R G).toRingHom x) *
        groupAlgebraElement R G := by
  classical
  have hsum_single :
      (∑ g : G, MonoidAlgebra.single (1 : G) (x g)) =
        MonoidAlgebra.single (1 : G) (∑ g : G, x g) := by
    exact (map_sum
      (MonoidAlgebra.singleAddHom (R := R) (M := G) (1 : G))
      (fun g : G => x g) Finset.univ).symm
  calc
    x * groupAlgebraElement R G =
        (∑ g : G, MonoidAlgebra.single g (x g)) *
          groupAlgebraElement R G := by
          rw [← monoid_sum_single R G x]
    _ =
        ∑ g : G,
          MonoidAlgebra.single g (x g) * groupAlgebraElement R G := by
          rw [Finset.sum_mul]
    _ =
        ∑ g : G,
          MonoidAlgebra.single (1 : G) (x g) * groupAlgebraElement R G := by
          refine Finset.sum_congr rfl ?_
          intro g _hg
          exact single_coeff_element R G g (x g)
    _ =
        (∑ g : G, MonoidAlgebra.single (1 : G) (x g)) *
          groupAlgebraElement R G := by
          rw [Finset.sum_mul]
    _ =
        MonoidAlgebra.single (1 : G) (∑ g : G, x g) *
          groupAlgebraElement R G := by
          rw [hsum_single]
    _ =
        MonoidAlgebra.single (1 : G)
            ((GShafar.augmentationHom R G).toRingHom x) *
          groupAlgebraElement R G := by
          rw [augmentation_sum_coeff R G x]

/-- Augmentation-one elements fix the norm element by right multiplication. -/
lemma group_algebra_element
    (R G : Type*) [CommSemiring R] [Group G] [Fintype G]
    (x : MonoidAlgebra R G)
    (hx : (GShafar.augmentationHom R G).toRingHom x = 1) :
    groupAlgebraElement R G * x = groupAlgebraElement R G := by
  calc
    groupAlgebraElement R G * x =
        MonoidAlgebra.single (1 : G)
            ((GShafar.augmentationHom R G).toRingHom x) *
          groupAlgebraElement R G := by
          exact algebra_element_mul R G x
    _ =
        MonoidAlgebra.single (1 : G) (1 : R) *
          groupAlgebraElement R G := by
          rw [hx]
    _ = groupAlgebraElement R G := by
          exact single_mul_element R G (1 : G)

/-- Augmentation-one elements fix the norm element by left multiplication. -/
lemma algebra_element_augmentation
    (R G : Type*) [CommSemiring R] [Group G] [Fintype G]
    (x : MonoidAlgebra R G)
    (hx : (GShafar.augmentationHom R G).toRingHom x = 1) :
    x * groupAlgebraElement R G = groupAlgebraElement R G := by
  calc
    x * groupAlgebraElement R G =
        MonoidAlgebra.single (1 : G)
            ((GShafar.augmentationHom R G).toRingHom x) *
          groupAlgebraElement R G := by
          exact mul_algebra_element R G x
    _ =
        MonoidAlgebra.single (1 : G) (1 : R) *
          groupAlgebraElement R G := by
          rw [hx]
    _ = groupAlgebraElement R G := by
          exact single_mul_element R G (1 : G)

/-- The norm element is nonzero over a nontrivial coefficient semiring. -/
lemma element_ne_zero
    (R G : Type*) [Semiring R] [Group G] [Fintype G] [Nontrivial R] :
    groupAlgebraElement R G ≠ 0 := by
  intro hzero
  have hcoeff :
      (groupAlgebraElement R G) (1 : G) = (0 : MonoidAlgebra R G) (1 : G) :=
    congrArg (fun x : MonoidAlgebra R G => x (1 : G)) hzero
  rw [algebra_norm_element R G (1 : G)] at hcoeff
  change (1 : R) = 0 at hcoeff
  exact one_ne_zero hcoeff

/-- The coefficient of a constant group-algebra sum is the chosen constant. -/
lemma algebra_constant_sum
    (R G : Type*) [Semiring R] [Group G] [Fintype G] (r : R) (g : G) :
    (∑ h : G, MonoidAlgebra.single h r) g = r := by
  classical
  calc
    (∑ h : G, MonoidAlgebra.single h r) g =
        ∑ h ∈ (Finset.univ : Finset G),
          (MonoidAlgebra.single h r) g := by
      exact
        (Finsupp.finsetSum_apply (Finset.univ : Finset G)
          (fun h : G => MonoidAlgebra.single h r) g)
    _ = r := by
      rw [Finset.sum_eq_single g]
      · simp
      · intro h _hh hne
        exact Finsupp.single_eq_of_ne (Ne.symm hne)
      · intro hg
        exact False.elim (hg (Finset.mem_univ g))

/-- A nonzero scalar multiple of the norm element is nonzero. -/
lemma single_element_ne
    (R G : Type*) [CommSemiring R] [Group G] [Fintype G]
    {r : R} (hr : r ≠ 0) :
    MonoidAlgebra.single (1 : G) r * groupAlgebraElement R G ≠ 0 := by
  classical
  intro hzero
  have hcoeff :
      (MonoidAlgebra.single (1 : G) r * groupAlgebraElement R G) (1 : G) =
        (0 : MonoidAlgebra R G) (1 : G) :=
    congrArg (fun x : MonoidAlgebra R G => x (1 : G)) hzero
  rw [single_norm_element R G r] at hcoeff
  rw [algebra_constant_sum R G r (1 : G)] at hcoeff
  change r = 0 at hcoeff
  exact hr hcoeff

/-- Scalars at the identity commute with every finite group-algebra element. -/
lemma single_comm_algebra
    (R G : Type*) [CommSemiring R] [Group G]
    (r : R) (x : MonoidAlgebra R G) :
    MonoidAlgebra.single (1 : G) r * x =
      x * MonoidAlgebra.single (1 : G) r := by
  classical
  calc
    MonoidAlgebra.single (1 : G) r * x =
        (algebraMap R (MonoidAlgebra R G)) r * x := by
          simp
    _ = x * (algebraMap R (MonoidAlgebra R G)) r := by
          exact Algebra.commutes r x
    _ = x * MonoidAlgebra.single (1 : G) r := by
          simp

/--
An augmentation-one element fixes every scalar multiple of the norm element
under left multiplication.
-/
lemma single_element_augmentation
    (R G : Type*) [CommSemiring R] [Group G] [Fintype G]
    (a : MonoidAlgebra R G) (r : R)
    (ha : (GShafar.augmentationHom R G).toRingHom a = 1) :
    a * (MonoidAlgebra.single (1 : G) r * groupAlgebraElement R G) =
      MonoidAlgebra.single (1 : G) r * groupAlgebraElement R G := by
  calc
    a * (MonoidAlgebra.single (1 : G) r * groupAlgebraElement R G) =
        (a * MonoidAlgebra.single (1 : G) r) *
          groupAlgebraElement R G := by
          rw [mul_assoc]
    _ =
        (MonoidAlgebra.single (1 : G) r * a) *
          groupAlgebraElement R G := by
          rw [← single_comm_algebra R G r a]
    _ =
        MonoidAlgebra.single (1 : G) r *
          (a * groupAlgebraElement R G) := by
          rw [mul_assoc]
    _ =
        MonoidAlgebra.single (1 : G) r * groupAlgebraElement R G := by
          rw [algebra_element_augmentation R G a ha]

/--
An augmentation-one element fixes every scalar multiple of the norm element
under right multiplication.
-/
lemma single_algebra_element
    (R G : Type*) [CommSemiring R] [Group G] [Fintype G]
    (a : MonoidAlgebra R G) (r : R)
    (ha : (GShafar.augmentationHom R G).toRingHom a = 1) :
    (MonoidAlgebra.single (1 : G) r * groupAlgebraElement R G) * a =
      MonoidAlgebra.single (1 : G) r * groupAlgebraElement R G := by
  calc
    (MonoidAlgebra.single (1 : G) r * groupAlgebraElement R G) * a =
        MonoidAlgebra.single (1 : G) r *
          (groupAlgebraElement R G * a) := by
          rw [mul_assoc]
    _ =
        MonoidAlgebra.single (1 : G) r * groupAlgebraElement R G := by
          rw [group_algebra_element R G a ha]

/-- A vector fixed by all right translations has every coefficient equal to its `1`-coefficient. -/
lemma right_invariant_coeff
    (R G : Type*) [Semiring R] [Group G]
    (x : MonoidAlgebra R G)
    (hfix : ∀ g : G, x * MonoidAlgebra.single g (1 : R) = x)
    (g : G) :
    x g = x (1 : G) := by
  have hcoeff := congrArg
    (fun y : MonoidAlgebra R G => y g)
    (hfix g)
  change (x * MonoidAlgebra.single g (1 : R)) g = x g at hcoeff
  rw [MonoidAlgebra.mul_single_apply] at hcoeff
  simpa using hcoeff.symm

/-- A vector fixed by all left translations has every coefficient equal to its `1`-coefficient. -/
lemma invariant_coeff_one
    (R G : Type*) [Semiring R] [Group G]
    (x : MonoidAlgebra R G)
    (hfix : ∀ g : G, MonoidAlgebra.single g (1 : R) * x = x)
    (g : G) :
    x g = x (1 : G) := by
  have hcoeff := congrArg
    (fun y : MonoidAlgebra R G => y g)
    (hfix g)
  change (MonoidAlgebra.single g (1 : R) * x) g = x g at hcoeff
  rw [MonoidAlgebra.single_mul_apply] at hcoeff
  simpa using hcoeff.symm

/-- A group-algebra vector with constant coefficients is a scalar multiple of the norm element. -/
lemma single_element_coeff
    (R G : Type*) [CommSemiring R] [Group G] [Fintype G]
    (x : MonoidAlgebra R G)
    (hcoeff : ∀ g : G, x g = x (1 : G)) :
    x = MonoidAlgebra.single (1 : G) (x (1 : G)) *
      groupAlgebraElement R G := by
  ext g
  rw [hcoeff g]
  rw [single_norm_element R G (x (1 : G))]
  rw [algebra_constant_sum R G (x (1 : G)) g]

/-- Right-invariant vectors in the regular representation are norm multiples. -/
lemma invariant_single_element
    (R G : Type*) [CommSemiring R] [Group G] [Fintype G]
    (x : MonoidAlgebra R G)
    (hfix : ∀ g : G, x * MonoidAlgebra.single g (1 : R) = x) :
    x = MonoidAlgebra.single (1 : G) (x (1 : G)) *
      groupAlgebraElement R G := by
  exact single_element_coeff
    R G x (right_invariant_coeff R G x hfix)

/-- Left-invariant vectors in the regular representation are norm multiples. -/
lemma left_single_element
    (R G : Type*) [CommSemiring R] [Group G] [Fintype G]
    (x : MonoidAlgebra R G)
    (hfix : ∀ g : G, MonoidAlgebra.single g (1 : R) * x = x) :
    x = MonoidAlgebra.single (1 : G) (x (1 : G)) *
      groupAlgebraElement R G := by
  exact single_element_coeff
    R G x (invariant_coeff_one R G x hfix)

/-- A nonzero right-invariant vector has nonzero `1`-coefficient. -/
lemma invariant_coeff_ne
    (R G : Type*) [CommSemiring R] [Group G] [Finite G]
    (x : MonoidAlgebra R G)
    (hx_ne : x ≠ 0)
    (hfix : ∀ g : G, x * MonoidAlgebra.single g (1 : R) = x) :
    x (1 : G) ≠ 0 := by
  classical
  letI : Fintype G := Fintype.ofFinite G
  intro hcoeff_zero
  apply hx_ne
  calc
    x =
        MonoidAlgebra.single (1 : G) (x (1 : G)) *
          groupAlgebraElement R G := by
          exact invariant_single_element
            R G x hfix
    _ = 0 := by
          rw [hcoeff_zero]
          rw [MonoidAlgebra.single_zero]
          exact zero_mul (groupAlgebraElement R G)

/-- A nonzero left-invariant vector has nonzero `1`-coefficient. -/
lemma left_invariant_coeff
    (R G : Type*) [CommSemiring R] [Group G] [Finite G]
    (x : MonoidAlgebra R G)
    (hx_ne : x ≠ 0)
    (hfix : ∀ g : G, MonoidAlgebra.single g (1 : R) * x = x) :
    x (1 : G) ≠ 0 := by
  classical
  letI : Fintype G := Fintype.ofFinite G
  intro hcoeff_zero
  apply hx_ne
  calc
    x =
        MonoidAlgebra.single (1 : G) (x (1 : G)) *
          groupAlgebraElement R G := by
          exact left_single_element
            R G x hfix
    _ = 0 := by
          rw [hcoeff_zero]
          rw [MonoidAlgebra.single_zero]
          exact zero_mul (groupAlgebraElement R G)

/-- If the action fixes zero, it preserves the complement of zero. -/
lemma ne_zero_fixed
    (G V : Type*) [Group G] [Zero V] [MulAction G V]
    (hzero_fixed : ∀ g : G, g • (0 : V) = 0)
    (g : G) {v : V} (hv : v ≠ 0) :
    g • v ≠ 0 := by
  intro hgv
  apply hv
  calc
    v = g⁻¹ • (g • v) := by
          rw [inv_smul_smul]
    _ = g⁻¹ • (0 : V) := by
          rw [hgv]
    _ = 0 := by
          exact hzero_fixed g⁻¹

/-- Under an action fixing zero, translating by a group element is zero exactly at zero. -/
lemma smul_zero_fixed
    (G V : Type*) [Group G] [Zero V] [MulAction G V]
    (hzero_fixed : ∀ g : G, g • (0 : V) = 0)
    (g : G) (v : V) :
    g • v = 0 ↔ v = 0 := by
  constructor
  · intro hgv
    calc
      v = g⁻¹ • (g • v) := by
            rw [inv_smul_smul]
      _ = g⁻¹ • (0 : V) := by
            rw [hgv]
      _ = 0 := by
            exact hzero_fixed g⁻¹
  · intro hv
    rw [hv]
    exact hzero_fixed g

/-- Under an action fixing zero, translating by a group element preserves nonzero-ness. -/
lemma smul_ne_fixed
    (G V : Type*) [Group G] [Zero V] [MulAction G V]
    (hzero_fixed : ∀ g : G, g • (0 : V) = 0)
    (g : G) (v : V) :
    g • v ≠ 0 ↔ v ≠ 0 := by
  constructor
  · intro hgv hv
    exact hgv ((smul_zero_fixed G V hzero_fixed g v).2 hv)
  · intro hv
    exact ne_zero_fixed G V hzero_fixed g hv

/-- The nonzero subtype of a nontrivial type with zero is inhabited. -/
lemma nonzeroSubtype_nonempty
    (V : Type*) [Zero V] [Nontrivial V] :
    Nonempty {v : V // v ≠ 0} := by
  rcases exists_ne (0 : V) with ⟨v, hv⟩
  exact ⟨⟨v, hv⟩⟩

/-- A fixed point in the nonzero subtype gives a nonzero fixed point upstairs. -/
lemma nonzero_subtype_lifts
    (G V : Type*) [Group G] [Zero V] [MulAction G V]
    (hzero_fixed : ∀ g : G, g • (0 : V) = 0)
    (x : {v : V // v ≠ 0})
    (hx : ∀ g : G,
      (⟨g • (x : V), ne_zero_fixed G V hzero_fixed g x.2⟩ :
        {v : V // v ≠ 0}) = x) :
    (x : V) ≠ 0 ∧ ∀ g : G, g • (x : V) = x := by
  refine ⟨x.2, ?_⟩
  intro g
  exact congrArg Subtype.val (hx g)

/-- A prime `p` does not divide `p^n - 1` when `n` is positive. -/
lemma not_dvd_sub
    (p n : ℕ) (hp : Nat.Prime p) (hn : 0 < n) :
    ¬ p ∣ p ^ n - 1 := by
  intro hdvd
  have hpow_dvd : p ∣ p ^ n := dvd_pow_self p (Nat.ne_of_gt hn)
  have hpow_one_le : 1 ≤ p ^ n := Nat.one_le_pow n p hp.pos
  have hone_dvd : p ∣ 1 := by
    have hsub : p ∣ p ^ n - (p ^ n - 1) :=
      Nat.dvd_sub hpow_dvd hdvd
    simpa [Nat.sub_sub_self hpow_one_le] using hsub
  exact hp.not_dvd_one hone_dvd

/--
The nonzero part of a nontrivial finite `𝔽_p`-vector space has cardinal not
divisible by `p`.

Mathematically, a finite nontrivial `ZMod p`-module has cardinal `p^n` for
some positive `n`, so the complement of zero has cardinal `p^n - 1`.
-/
theorem nonzero_z_dvd
    (p : ℕ) (hp : Nat.Prime p)
    (V : Type*) [AddCommGroup V] [Module (ZMod p) V] [Finite V]
    [Nontrivial V] :
    ¬ p ∣ Nat.card {v : V // v ≠ 0} := by
  classical
  letI : Fact p.Prime := ⟨hp⟩
  letI : Fintype V := Fintype.ofFinite V
  haveI : Fintype {v : V // v ≠ 0} := inferInstance
  have hcardV0 :
      Fintype.card V =
        Fintype.card (ZMod p) ^ Module.finrank (ZMod p) V := by
    exact Module.card_eq_pow_finrank (K := ZMod p) (V := V)
  have hcardV :
      Fintype.card V = p ^ Module.finrank (ZMod p) V := by
    rw [hcardV0, ZMod.card p]
  have hfinrank_pos : 0 < Module.finrank (ZMod p) V := by
    exact (Module.finrank_pos_iff (R := ZMod p) (M := V)).2 inferInstance
  have hcard_nonzero :
      Fintype.card {v : V // v ≠ 0} = Fintype.card V - 1 := by
    rw [Fintype.card_subtype_compl (fun v : V => v = 0)]
    simp
  rw [Nat.card_eq_fintype_card]
  rw [hcard_nonzero, hcardV]
  exact not_dvd_sub p (Module.finrank (ZMod p) V) hp hfinrank_pos

/--
Logical form of "not fixed-point-free".

This lets the orbit-counting theorem work contrapositively: if there is no
global fixed point, every point has some group element moving it.
-/
lemma forall_moved_fixed
    (G X : Type*) [SMul G X] :
    (¬ ∀ x : X, ∃ g : G, g • x ≠ x) ↔
      ∃ x : X, ∀ g : G, g • x = x := by
  classical
  constructor
  · intro h
    rw [Classical.not_forall] at h
    rcases h with ⟨x, hx⟩
    refine ⟨x, ?_⟩
    intro g
    by_contra hg
    exact hx ⟨g, hg⟩
  · intro h hall_moved
    rcases h with ⟨x, hx⟩
    rcases hall_moved x with ⟨g, hg⟩
    exact hg (hx g)

/--
A proper subgroup of a finite `p`-group has index divisible by `p`.

The proof uses Mathlib's cardinal characterization of finite `p`-groups:
both `G` and the subgroup have cardinal a power of `p`; since
`index * |H| = |G|`, the index is also a power of `p`, and properness excludes
the zeroth power.
-/
theorem proper_index_dvd
    (p : ℕ) [Fact p.Prime]
    (G : Type*) [Group G] [Finite G]
    (hG : IsPGroup p G)
    (H : Subgroup G) (hH_ne_top : H ≠ ⊤) :
    p ∣ H.index := by
  classical
  have hHpg : IsPGroup p H := by
    intro h
    rcases hG (h : G) with ⟨k, hk⟩
    exact ⟨k, Subtype.ext hk⟩
  rcases IsPGroup.exists_card_eq hG with ⟨n, hcardG⟩
  rcases IsPGroup.exists_card_eq hHpg with ⟨m, hcardH⟩
  have hmul : H.index * p ^ m = p ^ n := by
    calc
      H.index * p ^ m = H.index * Nat.card H := by
        rw [hcardH]
      _ = Nat.card G := Subgroup.index_mul_card H
      _ = p ^ n := hcardG
  have hindex_dvd_pow : H.index ∣ p ^ n := ⟨p ^ m, hmul.symm⟩
  rcases (Nat.dvd_prime_pow (Fact.out : Nat.Prime p)).1 hindex_dvd_pow with
    ⟨k, _hk_le, hindex_eq⟩
  rw [hindex_eq]
  cases k with
  | zero =>
      exfalso
      apply hH_ne_top
      exact (Subgroup.index_eq_one.mp hindex_eq)
  | succ k =>
      exact dvd_pow_self p (Nat.succ_ne_zero k)

/-- The cardinal of an orbit is the index of the stabilizer. -/
lemma orbit_stabilizer_index
    (G X : Type*) [Group G] [MulAction G X] (x : X) :
    Nat.card (MulAction.orbit G x) =
      (MulAction.stabilizer G x).index := by
  calc
    Nat.card (MulAction.orbit G x) =
        Nat.card (G ⧸ MulAction.stabilizer G x) := by
      exact Nat.card_congr (MulAction.orbitEquivQuotientStabilizer G x)
    _ = (MulAction.stabilizer G x).index := by
      exact (Subgroup.index_eq_card (MulAction.stabilizer G x)).symm

/--
Orbit-size divisibility for a non-fixed point under a finite `p`-group.

Mathematically, if some group element moves `x`, then the stabilizer of `x` is
proper. The orbit is equivalent to `G / stabilizer(x)`, and every proper index
in a finite `p`-group is divisible by `p`.
-/
theorem nonfixed_orbit_dvd
    (p : ℕ) (hp : Nat.Prime p)
    (G : Type*) [Group G] [Finite G]
    (_hG : IsPGroup p G)
    (X : Type*) [MulAction G X]
    (x : X)
    (hmoved : ∃ g : G, g • x ≠ x) :
    p ∣ Nat.card (MulAction.orbit G x) := by
  classical
  letI : Fact p.Prime := ⟨hp⟩
  have hproper : MulAction.stabilizer G x ≠ ⊤ := by
    rcases hmoved with ⟨g, hg⟩
    intro htop
    have hgmem : g ∈ MulAction.stabilizer G x := by
      rw [htop]
      exact trivial
    exact hg hgmem
  have hindex_dvd :
      p ∣ (MulAction.stabilizer G x).index :=
    proper_index_dvd
      p G _hG (MulAction.stabilizer G x) hproper
  rwa [orbit_stabilizer_index G X x]

/--
The fiber of the quotient map `X → X / orbitRel` over the class of `x` is
equivalent to the orbit of `x`.
-/
noncomputable def orbit_fiber_equiv
    (G X : Type*) [Group G] [MulAction G X] (x : X) :
    {y : X // Quotient.mk (MulAction.orbitRel G X) y =
        Quotient.mk (MulAction.orbitRel G X) x} ≃
      MulAction.orbit G x where
  toFun y := by
    refine ⟨y.1, ?_⟩
    have hrel : (MulAction.orbitRel G X).r y.1 x := Quotient.exact y.2
    simpa [MulAction.orbitRel, MulAction.mem_orbit_iff] using hrel
  invFun y := by
    refine ⟨y.1, ?_⟩
    apply Quotient.sound
    change (y : X) ∈ MulAction.orbit G x
    exact y.2
  left_inv y := by
    exact Subtype.ext rfl
  right_inv y := by
    exact Subtype.ext rfl

/--
If every orbit in a finite action has cardinal divisible by `p`, then the
whole finite set has cardinal divisible by `p`.

This is the orbit-decomposition half of the class equation: the orbits form a
finite partition of `X`, so the cardinal of `X` is the sum of the orbit
cardinals.
-/
theorem card_dvd_orbit
    (p : ℕ)
    (G X : Type*) [Group G] [Finite X] [MulAction G X]
    (horbit : ∀ x : X, p ∣ Nat.card (MulAction.orbit G x)) :
    p ∣ Nat.card X := by
  classical
  let Q := MulAction.orbitRel.Quotient G X
  let f : X → Q := fun x => Quotient.mk (MulAction.orbitRel G X) x
  haveI : Finite Q := Finite.of_surjective f (by
    intro q
    exact Quotient.exists_rep q)
  letI : Fintype Q := Fintype.ofFinite Q
  have hfiber_dvd : ∀ q : Q, p ∣ Nat.card {x : X // f x = q} := by
    intro q
    refine Quotient.inductionOn q ?_
    intro x
    have hcard :
        Nat.card {y : X // f y = Quotient.mk (MulAction.orbitRel G X) x} =
          Nat.card (MulAction.orbit G x) := by
      exact Nat.card_congr (orbit_fiber_equiv G X x)
    rw [hcard]
    exact horbit x
  have hcardX : Nat.card X = ∑ q : Q, Nat.card {x : X // f x = q} := by
    calc
      Nat.card X = Nat.card ((q : Q) × {x : X // f x = q}) := by
        exact (Nat.card_congr (Equiv.sigmaFiberEquiv f)).symm
      _ = ∑ q : Q, Nat.card {x : X // f x = q} := by
        rw [Nat.card_sigma]
  rw [hcardX]
  exact Finset.dvd_sum (s := Finset.univ) (a := p)
    (fun q _hq => hfiber_dvd q)

/--
If a finite `p`-group action has no global fixed point, the underlying finite
set has cardinal divisible by `p`.
-/
theorem action_no_point
    (p : ℕ) (hp : Nat.Prime p)
    (G : Type*) [Group G] [Finite G]
    (_hG : IsPGroup p G)
    (X : Type*) [Finite X] [MulAction G X]
    (hno_fixed : ¬ ∃ x : X, ∀ g : G, g • x = x) :
    p ∣ Nat.card X := by
  classical
  have hall_moved : ∀ x : X, ∃ g : G, g • x ≠ x := by
    by_contra hnot
    exact hno_fixed ((forall_moved_fixed G X).1 hnot)
  have horbit : ∀ x : X, p ∣ Nat.card (MulAction.orbit G x) := by
    intro x
    exact nonfixed_orbit_dvd p hp G _hG X x (hall_moved x)
  exact card_dvd_orbit p G X horbit

/--
Class-equation fixed-point theorem for finite `p`-group actions.

If a finite `p`-group acts on a finite set whose cardinal is not divisible by
`p`, then some point is fixed by the whole group. This is the orbit-counting
lemma: non-singleton orbits have cardinal divisible by `p`, so at least one
singleton orbit must occur.
-/
theorem action_point_card
    (p : ℕ) (hp : Nat.Prime p)
    (G : Type*) [Group G] [Finite G]
    (_hG : IsPGroup p G)
    (X : Type*) [Finite X] [MulAction G X]
    (hcard : ¬ p ∣ Nat.card X) :
    ∃ x : X, ∀ g : G, g • x = x := by
  classical
  by_contra hno_fixed
  exact hcard
    (action_no_point
      p hp G _hG X hno_fixed)

/--
The remaining orbit-counting core.

If a finite `p`-group acts on a nontrivial finite `𝔽_p`-module and fixes the
zero vector, then it has a nonzero fixed vector. Mathematically, this is the
class equation: non-fixed orbits have size divisible by `p`, while the whole
nontrivial finite vector space has cardinal divisible by `p`; since `0` is
already fixed, there must be another fixed point.
-/
theorem action_nonzero_vector
    (p : ℕ) (hp : Nat.Prime p)
    (G : Type*) [Group G] [Finite G]
    (_hG : IsPGroup p G)
    (V : Type*) [AddCommGroup V] [Module (ZMod p) V] [Finite V]
    [Nontrivial V] [MulAction G V]
    (hzero_fixed : ∀ g : G, g • (0 : V) = 0) :
    ∃ v : V, v ≠ 0 ∧ ∀ g : G, g • v = v := by
  classical
  let X := {v : V // v ≠ 0}
  haveI : Finite X := inferInstance
  letI : MulAction G X := {
    smul := fun g x =>
      ⟨g • (x : V), ne_zero_fixed G V hzero_fixed g x.2⟩
    one_smul := by
      intro x
      ext
      exact one_smul G (x : V)
    mul_smul := by
      intro g h x
      ext
      exact mul_smul g h (x : V)
  }
  have hcard : ¬ p ∣ Nat.card X :=
    nonzero_z_dvd p hp V
  rcases action_point_card
      p hp G _hG X hcard with
    ⟨x, hx_fixed⟩
  rcases nonzero_subtype_lifts G V hzero_fixed x hx_fixed with
    ⟨hx_ne, hx_fixed_upstairs⟩
  exact ⟨(x : V), hx_ne, hx_fixed_upstairs⟩

/--
Fixed-vector input for right-stable submodules of the regular representation.

This is the pure finite `p`-group orbit-counting step: a nonzero subspace
stable under the right regular action contains a nonzero vector fixed by every
right translation.
-/
theorem stable_contains_nonzero
    (p : ℕ) (hp : Nat.Prime p)
    (G : Type*) [Group G] [Finite G]
    (_hG : IsPGroup p G)
    (W : Submodule (ZMod p) (MonoidAlgebra (ZMod p) G))
    (hW_nonzero :
      ∃ x : MonoidAlgebra (ZMod p) G, x ∈ W ∧ x ≠ 0)
    (hW_right :
      ∀ x : MonoidAlgebra (ZMod p) G,
        x ∈ W → ∀ g : G,
          x * MonoidAlgebra.single g (1 : ZMod p) ∈ W) :
    ∃ x : MonoidAlgebra (ZMod p) G,
      x ∈ W ∧ x ≠ 0 ∧
        ∀ g : G, x * MonoidAlgebra.single g (1 : ZMod p) = x := by
  classical
  letI : Fact p.Prime := ⟨hp⟩
  letI : Fintype G := Fintype.ofFinite G
  let A := MonoidAlgebra (ZMod p) G
  haveI : Finite A := by
    letI : Fintype (ZMod p) := inferInstance
    haveI : Finite (ZMod p) := inferInstance
    exact Finite.of_injective
      (fun x : A => fun g : G => x g)
      (by
        intro x y hxy
        ext g
        exact congrFun hxy g)
  haveI : Finite W := inferInstance
  haveI : Nontrivial W := by
    rcases hW_nonzero with ⟨x, hxW, hx_ne⟩
    refine ⟨⟨⟨x, hxW⟩, 0, ?_⟩⟩
    intro hzero
    apply hx_ne
    have hval := congrArg Subtype.val hzero
    simpa using hval
  letI : MulAction G W := {
    smul := fun g x =>
      ⟨(x : A) * MonoidAlgebra.single g⁻¹ (1 : ZMod p),
        hW_right (x : A) x.2 g⁻¹⟩
    one_smul := by
      intro x
      ext h
      change ((x : A) * MonoidAlgebra.single (1 : G)⁻¹ (1 : ZMod p)) h =
        (x : A) h
      simp [MonoidAlgebra.mul_single_apply]
    mul_smul := by
      intro g h x
      ext k
      change
        ((x : A) * MonoidAlgebra.single (g * h)⁻¹ (1 : ZMod p)) k =
          (((x : A) * MonoidAlgebra.single h⁻¹ (1 : ZMod p)) *
            MonoidAlgebra.single g⁻¹ (1 : ZMod p)) k
      rw [MonoidAlgebra.mul_single_apply]
      rw [MonoidAlgebra.mul_single_apply]
      rw [MonoidAlgebra.mul_single_apply]
      simp [mul_assoc]
  }
  have hzero_fixed : ∀ g : G, g • (0 : W) = 0 := by
    intro g
    ext h
    change
      (((0 : W) : A) * MonoidAlgebra.single g⁻¹ (1 : ZMod p)) h =
        ((0 : W) : A) h
    simp
  rcases action_nonzero_vector
      p hp G _hG W hzero_fixed with
    ⟨x, hx_ne, hx_fix⟩
  refine ⟨(x : A), x.2, ?_, ?_⟩
  · intro hx_zero
    apply hx_ne
    exact Subtype.ext hx_zero
  · intro g
    have hfix_inv := congrArg Subtype.val (hx_fix g⁻¹)
    change
      ((x : A) * MonoidAlgebra.single (g⁻¹)⁻¹ (1 : ZMod p)) =
        (x : A) at hfix_inv
    simpa using hfix_inv

/--
Fixed-vector input for left-stable submodules of the regular representation.

This is the left-action analogue of
`stable_contains_nonzero`.
-/
theorem stable_submodule_contains
    (p : ℕ) (hp : Nat.Prime p)
    (G : Type*) [Group G] [Finite G]
    (_hG : IsPGroup p G)
    (W : Submodule (ZMod p) (MonoidAlgebra (ZMod p) G))
    (hW_nonzero :
      ∃ x : MonoidAlgebra (ZMod p) G, x ∈ W ∧ x ≠ 0)
    (hW_left :
      ∀ x : MonoidAlgebra (ZMod p) G,
        x ∈ W → ∀ g : G,
          MonoidAlgebra.single g (1 : ZMod p) * x ∈ W) :
    ∃ x : MonoidAlgebra (ZMod p) G,
      x ∈ W ∧ x ≠ 0 ∧
        ∀ g : G, MonoidAlgebra.single g (1 : ZMod p) * x = x := by
  classical
  letI : Fact p.Prime := ⟨hp⟩
  letI : Fintype G := Fintype.ofFinite G
  let A := MonoidAlgebra (ZMod p) G
  haveI : Finite A := by
    letI : Fintype (ZMod p) := inferInstance
    haveI : Finite (ZMod p) := inferInstance
    exact Finite.of_injective
      (fun x : A => fun g : G => x g)
      (by
        intro x y hxy
        ext g
        exact congrFun hxy g)
  haveI : Finite W := inferInstance
  haveI : Nontrivial W := by
    rcases hW_nonzero with ⟨x, hxW, hx_ne⟩
    refine ⟨⟨⟨x, hxW⟩, 0, ?_⟩⟩
    intro hzero
    apply hx_ne
    have hval := congrArg Subtype.val hzero
    simpa using hval
  letI : MulAction G W := {
    smul := fun g x =>
      ⟨MonoidAlgebra.single g (1 : ZMod p) * (x : A),
        hW_left (x : A) x.2 g⟩
    one_smul := by
      intro x
      ext h
      change (MonoidAlgebra.single (1 : G) (1 : ZMod p) * (x : A)) h =
        (x : A) h
      simp [MonoidAlgebra.single_mul_apply]
    mul_smul := by
      intro g h x
      ext k
      change
        (MonoidAlgebra.single (g * h) (1 : ZMod p) * (x : A)) k =
          (MonoidAlgebra.single g (1 : ZMod p) *
            (MonoidAlgebra.single h (1 : ZMod p) * (x : A))) k
      rw [MonoidAlgebra.single_mul_apply]
      rw [MonoidAlgebra.single_mul_apply]
      rw [MonoidAlgebra.single_mul_apply]
      simp [mul_assoc]
  }
  have hzero_fixed : ∀ g : G, g • (0 : W) = 0 := by
    intro g
    ext h
    change
      (MonoidAlgebra.single g (1 : ZMod p) * ((0 : W) : A)) h =
        ((0 : W) : A) h
    simp
  rcases action_nonzero_vector
      p hp G _hG W hzero_fixed with
    ⟨x, hx_ne, hx_fix⟩
  refine ⟨(x : A), x.2, ?_, ?_⟩
  · intro hx_zero
    apply hx_ne
    exact Subtype.ext hx_zero
  · intro g
    have hfix := congrArg Subtype.val (hx_fix g)
    change
      MonoidAlgebra.single g (1 : ZMod p) * (x : A) =
        (x : A) at hfix
    exact hfix

/--
Fixed-point input for right-stable submodules of the regular representation.

Mathematically, the finite `p`-group acts on any nonzero finite
`𝔽_p`-subspace by right multiplication. Orbit counting shows that its fixed
subspace is nonzero; the fixed vectors for right multiplication by every group
element are exactly the nonzero scalar multiples of the norm element.
-/
theorem contains_nonzero_multiple
    (p : ℕ) (hp : Nat.Prime p)
    (G : Type*) [Group G] [Fintype G]
    (_hG : IsPGroup p G)
    (W : Submodule (ZMod p) (MonoidAlgebra (ZMod p) G))
    (hW_nonzero :
      ∃ x : MonoidAlgebra (ZMod p) G, x ∈ W ∧ x ≠ 0)
    (hW_right :
      ∀ x : MonoidAlgebra (ZMod p) G,
        x ∈ W → ∀ g : G,
          x * MonoidAlgebra.single g (1 : ZMod p) ∈ W) :
    ∃ c : ZMod p,
      c ≠ 0 ∧
        MonoidAlgebra.single (1 : G) c *
            groupAlgebraElement (ZMod p) G ∈ W := by
  rcases stable_contains_nonzero
      p hp G _hG W hW_nonzero hW_right with
    ⟨x, hxW, hx_ne, hx_fix⟩
  refine ⟨x (1 : G), ?_, ?_⟩
  · exact invariant_coeff_ne
      (ZMod p) G x hx_ne hx_fix
  · have hx_eq :
        x =
          MonoidAlgebra.single (1 : G) (x (1 : G)) *
            groupAlgebraElement (ZMod p) G :=
      invariant_single_element
        (ZMod p) G x hx_fix
    rw [← hx_eq]
    exact hxW

/--
Fixed-point input for left-stable submodules of the regular representation.

This is the left-action counterpart of
`contains_nonzero_multiple`.
-/
theorem stable_contains_multiple
    (p : ℕ) (hp : Nat.Prime p)
    (G : Type*) [Group G] [Fintype G]
    (_hG : IsPGroup p G)
    (W : Submodule (ZMod p) (MonoidAlgebra (ZMod p) G))
    (hW_nonzero :
      ∃ x : MonoidAlgebra (ZMod p) G, x ∈ W ∧ x ≠ 0)
    (hW_left :
      ∀ x : MonoidAlgebra (ZMod p) G,
        x ∈ W → ∀ g : G,
          MonoidAlgebra.single g (1 : ZMod p) * x ∈ W) :
    ∃ c : ZMod p,
      c ≠ 0 ∧
        MonoidAlgebra.single (1 : G) c *
            groupAlgebraElement (ZMod p) G ∈ W := by
  rcases stable_submodule_contains
      p hp G _hG W hW_nonzero hW_left with
    ⟨x, hxW, hx_ne, hx_fix⟩
  refine ⟨x (1 : G), ?_, ?_⟩
  · exact left_invariant_coeff
      (ZMod p) G x hx_ne hx_fix
  · have hx_eq :
        x =
          MonoidAlgebra.single (1 : G) (x (1 : G)) *
            groupAlgebraElement (ZMod p) G :=
      left_single_element
        (ZMod p) G x hx_fix
    rw [← hx_eq]
    exact hxW

/--
Left multiplication by an augmentation-one element is injective.

The remaining mathematical point is the fixed-point argument: a nonzero kernel
is a nonzero right-stable subspace of the regular representation, hence
contains a nonzero scalar multiple of the norm element. The previous norm
calculation shows that this norm element is not killed by an augmentation-one
element.
-/
theorem left_p_group
    (p : ℕ) (hp : Nat.Prime p)
    (G : Type*) [Group G] [Finite G]
    (_hG : IsPGroup p G)
    (a : MonoidAlgebra (ZMod p) G)
    (ha :
      (GShafar.augmentationHom (ZMod p) G).toRingHom a = 1) :
    Function.Injective (fun b : MonoidAlgebra (ZMod p) G => a * b) := by
  classical
  letI : Fact p.Prime := ⟨hp⟩
  letI : Fintype G := Fintype.ofFinite G
  let A := MonoidAlgebra (ZMod p) G
  intro b c hbc
  by_contra hne
  let W : Submodule (ZMod p) A :=
    LinearMap.ker (LinearMap.mulLeft (ZMod p) (A := A) a)
  have hz_ne : b - c ≠ 0 := by
    intro hz
    exact hne (sub_eq_zero.mp hz)
  have hz_mem : b - c ∈ W := by
    rw [LinearMap.mem_ker]
    have hbc' : a * b = a * c := hbc
    change a * (b - c) = 0
    rw [mul_sub, hbc', sub_self]
  have hW_nonzero :
      ∃ x : A, x ∈ W ∧ x ≠ 0 := by
    exact ⟨b - c, hz_mem, hz_ne⟩
  have hW_right :
      ∀ x : A,
        x ∈ W → ∀ g : G,
          x * MonoidAlgebra.single g (1 : ZMod p) ∈ W := by
    intro x hx g
    rw [LinearMap.mem_ker] at hx ⊢
    change a * x = 0 at hx
    change a * (x * MonoidAlgebra.single g (1 : ZMod p)) = 0
    calc
      a * (x * MonoidAlgebra.single g (1 : ZMod p)) =
          (a * x) * MonoidAlgebra.single g (1 : ZMod p) := by
          rw [mul_assoc]
      _ = 0 * MonoidAlgebra.single g (1 : ZMod p) := by
          rw [hx]
      _ = 0 := by
          rw [zero_mul]
  rcases contains_nonzero_multiple
      p hp G _hG W hW_nonzero hW_right with
    ⟨r, hr_ne, hr_mem⟩
  have hkill :
      a * (MonoidAlgebra.single (1 : G) r *
          groupAlgebraElement (ZMod p) G) = 0 := by
    simpa [W] using (LinearMap.mem_ker.mp hr_mem)
  have hfixed :
      a * (MonoidAlgebra.single (1 : G) r *
          groupAlgebraElement (ZMod p) G) =
        MonoidAlgebra.single (1 : G) r *
          groupAlgebraElement (ZMod p) G :=
    single_element_augmentation
      (ZMod p) G a r ha
  have hnorm_zero :
      MonoidAlgebra.single (1 : G) r *
          groupAlgebraElement (ZMod p) G = 0 := by
    rw [← hfixed]
    exact hkill
  exact
    (single_element_ne
      (ZMod p) G hr_ne) hnorm_zero

/--
Right multiplication by an augmentation-one element is injective.

This is the left-stable analogue of
`left_p_group`.
-/
theorem injective_p_group
    (p : ℕ) (hp : Nat.Prime p)
    (G : Type*) [Group G] [Finite G]
    (_hG : IsPGroup p G)
    (a : MonoidAlgebra (ZMod p) G)
    (ha :
      (GShafar.augmentationHom (ZMod p) G).toRingHom a = 1) :
    Function.Injective (fun b : MonoidAlgebra (ZMod p) G => b * a) := by
  classical
  letI : Fact p.Prime := ⟨hp⟩
  letI : Fintype G := Fintype.ofFinite G
  let A := MonoidAlgebra (ZMod p) G
  intro b c hbc
  by_contra hne
  let W : Submodule (ZMod p) A :=
    LinearMap.ker (LinearMap.mulRight (ZMod p) (A := A) a)
  have hz_ne : b - c ≠ 0 := by
    intro hz
    exact hne (sub_eq_zero.mp hz)
  have hz_mem : b - c ∈ W := by
    rw [LinearMap.mem_ker]
    have hbc' : b * a = c * a := hbc
    change (b - c) * a = 0
    rw [sub_mul, hbc', sub_self]
  have hW_nonzero :
      ∃ x : A, x ∈ W ∧ x ≠ 0 := by
    exact ⟨b - c, hz_mem, hz_ne⟩
  have hW_left :
      ∀ x : A,
        x ∈ W → ∀ g : G,
          MonoidAlgebra.single g (1 : ZMod p) * x ∈ W := by
    intro x hx g
    rw [LinearMap.mem_ker] at hx ⊢
    change x * a = 0 at hx
    change (MonoidAlgebra.single g (1 : ZMod p) * x) * a = 0
    calc
      (MonoidAlgebra.single g (1 : ZMod p) * x) * a =
          MonoidAlgebra.single g (1 : ZMod p) * (x * a) := by
          rw [mul_assoc]
      _ = MonoidAlgebra.single g (1 : ZMod p) * 0 := by
          rw [hx]
      _ = 0 := by
          rw [mul_zero]
  rcases stable_contains_multiple
      p hp G _hG W hW_nonzero hW_left with
    ⟨r, hr_ne, hr_mem⟩
  have hkill :
      (MonoidAlgebra.single (1 : G) r *
          groupAlgebraElement (ZMod p) G) * a = 0 := by
    simpa [W] using (LinearMap.mem_ker.mp hr_mem)
  have hfixed :
      (MonoidAlgebra.single (1 : G) r *
          groupAlgebraElement (ZMod p) G) * a =
        MonoidAlgebra.single (1 : G) r *
          groupAlgebraElement (ZMod p) G :=
    single_algebra_element
      (ZMod p) G a r ha
  have hnorm_zero :
      MonoidAlgebra.single (1 : G) r *
          groupAlgebraElement (ZMod p) G = 0 := by
    rw [← hfixed]
    exact hkill
  exact
    (single_element_ne
      (ZMod p) G hr_ne) hnorm_zero

/--
Right inverse criterion for augmentation-one elements in a finite `p`-group
algebra.

The standard proof shows that right multiplication by such an element is
injective. If its kernel were nonzero, the finite `p`-group fixed-point
argument applied to the right regular action would put a nonzero scalar
multiple of the norm element in the kernel. But the norm element multiplied on
the right by `a` is `augmentation(a)` times the norm element, hence nonzero
when the augmentation is `1`.
-/
theorem augmentation_p_group
    (p : ℕ) (hp : Nat.Prime p)
    (G : Type*) [Group G] [Finite G]
    (_hG : IsPGroup p G)
    (a : MonoidAlgebra (ZMod p) G)
    (ha :
      (GShafar.augmentationHom (ZMod p) G).toRingHom a = 1) :
    ∃ b : MonoidAlgebra (ZMod p) G, a * b = 1 := by
  classical
  let A := MonoidAlgebra (ZMod p) G
  haveI : Finite A := by
    letI : Fact p.Prime := ⟨hp⟩
    letI : Fintype G := Fintype.ofFinite G
    letI : Fintype (ZMod p) := inferInstance
    haveI : Finite (ZMod p) := inferInstance
    exact Finite.of_injective
      (fun x : A => fun g : G => x g)
      (by
        intro x y hxy
        ext g
        exact congrFun hxy g)
  have hinj : Function.Injective (fun b : A => a * b) :=
    left_p_group p hp G _hG a ha
  rcases (Finite.surjective_of_injective hinj) (1 : A) with ⟨b, hb⟩
  exact ⟨b, hb⟩

/--
Left inverse criterion for augmentation-one elements in a finite `p`-group
algebra.

This is the left-regular analogue of
`augmentation_p_group`; the same fixed-point
argument is applied to left ideals.
-/
theorem augmentation_inverse_group
    (p : ℕ) (hp : Nat.Prime p)
    (G : Type*) [Group G] [Finite G]
    (_hG : IsPGroup p G)
    (a : MonoidAlgebra (ZMod p) G)
    (ha :
      (GShafar.augmentationHom (ZMod p) G).toRingHom a = 1) :
    ∃ b : MonoidAlgebra (ZMod p) G, b * a = 1 := by
  classical
  let A := MonoidAlgebra (ZMod p) G
  haveI : Finite A := by
    letI : Fact p.Prime := ⟨hp⟩
    letI : Fintype G := Fintype.ofFinite G
    letI : Fintype (ZMod p) := inferInstance
    haveI : Finite (ZMod p) := inferInstance
    exact Finite.of_injective
      (fun x : A => fun g : G => x g)
      (by
        intro x y hxy
        ext g
        exact congrFun hxy g)
  have hinj : Function.Injective (fun b : A => b * a) :=
    injective_p_group p hp G _hG a ha
  rcases (Finite.surjective_of_injective hinj) (1 : A) with ⟨b, hb⟩
  exact ⟨b, hb⟩

/-- Augmentation-one elements in a finite `p`-group algebra are units. -/
theorem augmentation_unit_group
    (p : ℕ) (hp : Nat.Prime p)
    (G : Type*) [Group G] [Finite G]
    (_hG : IsPGroup p G)
    (a : MonoidAlgebra (ZMod p) G)
    (ha :
      (GShafar.augmentationHom (ZMod p) G).toRingHom a = 1) :
    IsUnit a := by
  classical
  rcases augmentation_p_group p hp G _hG a ha with
    ⟨b, hab⟩
  rcases augmentation_inverse_group p hp G _hG a ha with
    ⟨c, hca⟩
  have hb_eq_c : b = c := by
    calc
      b = 1 * b := by rw [one_mul]
      _ = (c * a) * b := by rw [hca]
      _ = c * (a * b) := by rw [mul_assoc]
      _ = c * 1 := by rw [hab]
      _ = c := by rw [mul_one]
  refine ⟨⟨a, b, hab, ?_⟩, rfl⟩
  rw [hb_eq_c]
  exact hca

/--
The augmentation-difference ideal is contained in the Jacobson radical of the
finite `p`-group algebra.
-/
theorem span_differences_jacobson
    (p : ℕ) (hp : Nat.Prime p)
    (G : Type*) [Group G] [Finite G]
    (_hG : IsPGroup p G) :
    Ideal.span
        (Set.range (fun g : G => augmentationDifference (ZMod p) G g)) ≤
      Ring.jacobson (MonoidAlgebra (ZMod p) G) := by
  classical
  intro x hx
  rw [← Ideal.jacobson_bot]
  rw [Ideal.mem_jacobson_iff]
  intro y
  let A := MonoidAlgebra (ZMod p) G
  have hxaug :
      x ∈ GShafar.augmentationIdeal (ZMod p) G := by
    simpa [augmentation_span_differences (ZMod p) G] using hx
  have hyxaug :
      y * x ∈ GShafar.augmentationIdeal (ZMod p) G :=
    (GShafar.augmentationIdeal (ZMod p) G).mul_mem_left y hxaug
  have haug_yx :
      (GShafar.augmentationHom (ZMod p) G).toRingHom (y * x) = 0 :=
    RingHom.mem_ker.mp hyxaug
  have haug_one :
      (GShafar.augmentationHom (ZMod p) G).toRingHom (y * x + 1) = 1 := by
    rw [map_add, haug_yx, map_one, zero_add]
  have hunit : IsUnit (y * x + 1) :=
    augmentation_unit_group p hp G _hG (y * x + 1) haug_one
  rcases hunit with ⟨u, hu⟩
  refine ⟨↑u⁻¹, ?_⟩
  rw [Submodule.mem_bot]
  have hinv : (↑u⁻¹ : A) * (y * x + 1) = 1 := by
    rw [← hu]
    exact Units.inv_mul u
  have hsum : (↑u⁻¹ : A) * y * x + ↑u⁻¹ = 1 := by
    simpa [mul_add, mul_assoc] using hinv
  exact sub_eq_zero.mpr hsum

/--
Every element of the ideal spanned by the differences `g - 1` is nilpotent for
a finite `p`-group over `𝔽_p`.

This packages the standard finite-dimensional argument that the augmentation
ideal of a finite `p`-group algebra is a nil ideal. The previous lemma supplies
nilpotence of the spanning differences; the remaining ingredient is the
finite-dimensional group-algebra structure, not any presentation-specific fact.
-/
theorem span_differences_nil
    (p : ℕ) (hp : Nat.Prime p)
    (G : Type*) [Group G] [Finite G]
    (_hG : IsPGroup p G) :
    ∀ x : MonoidAlgebra (ZMod p) G,
      x ∈ Ideal.span
        (Set.range (fun g : G => augmentationDifference (ZMod p) G g)) →
      ∃ N : ℕ, x ^ N = 0 := by
  classical
  intro x hx
  let A := MonoidAlgebra (ZMod p) G
  haveI : Finite A := by
    letI : Fact p.Prime := ⟨hp⟩
    letI : Fintype G := Fintype.ofFinite G
    letI : Fintype (ZMod p) := inferInstance
    haveI : Finite (ZMod p) := inferInstance
    exact Finite.of_injective
      (fun x : A => fun g : G => x g)
      (by
        intro x y hxy
        ext g
        exact congrFun hxy g)
  haveI : IsArtinianRing A := isArtinian_of_finite
  have hle :
      Ideal.span
          (Set.range (fun g : G => augmentationDifference (ZMod p) G g)) ≤
        Ring.jacobson A :=
    span_differences_jacobson p hp G _hG
  rcases IsArtinianRing.isNilpotent_jacobson_bot (R := A) with ⟨N, hN⟩
  refine ⟨N, ?_⟩
  have hJN : (Ring.jacobson A) ^ N = ⊥ := by
    simpa [← Ideal.jacobson_bot] using hN
  have hxpow_mem : x ^ N ∈ (Ring.jacobson A) ^ N :=
    Ideal.pow_mem_pow (hle hx) N
  have hxbot : x ^ N ∈ (⊥ : Ideal A) := by
    simpa [hJN] using hxpow_mem
  simpa using hxbot

/-- The whole augmentation ideal is a nil ideal for a finite `p`-group algebra. -/
theorem augmentation_nil_group
    (p : ℕ) (hp : Nat.Prime p)
    (G : Type*) [Group G] [Finite G]
    (_hG : IsPGroup p G) :
    ∀ x : MonoidAlgebra (ZMod p) G,
      x ∈ GShafar.augmentationIdeal (ZMod p) G →
      ∃ N : ℕ, x ^ N = 0 := by
  classical
  intro x hx
  have hxspan :
      x ∈ Ideal.span
        (Set.range (fun g : G => augmentationDifference (ZMod p) G g)) := by
    simpa [augmentation_span_differences (ZMod p) G] using hx
  exact span_differences_nil
    p hp G _hG x hxspan

/--
The group algebra `𝔽_p[G]` is a finite ring when `G` is finite.

As a type, `MonoidAlgebra (ZMod p) G` is the finitely supported function type
`G →₀ ZMod p`; when `G` and `ZMod p` are finite, this is finite as well.
-/
theorem zmod_group_algebra
    (p : ℕ) (hp : Nat.Prime p)
    (G : Type*) [Monoid G] [Finite G] :
    Finite (MonoidAlgebra (ZMod p) G) := by
  classical
  letI : Fact p.Prime := ⟨hp⟩
  letI : Fintype G := Fintype.ofFinite G
  letI : Fintype (ZMod p) := inferInstance
  haveI : Finite (ZMod p) := inferInstance
  exact Finite.of_injective
    (fun x : MonoidAlgebra (ZMod p) G => fun g : G => x g)
    (by
      intro x y hxy
      ext g
      exact congrFun hxy g)

/--
In a finite ring, every nil ideal is nilpotent.

This is the Artinian-ring step in the augmentation-ideal argument: a finite ring
is Artinian, and nil ideals in Artinian rings are nilpotent.
-/
theorem ring_nil_nilpotent
    {A : Type*} [Ring A] [Finite A] (I : Ideal A)
    (hI : ∀ x : A, x ∈ I → ∃ N : ℕ, x ^ N = 0) :
  ∃ N : ℕ, I ^ N = ⊥ := by
  classical
  haveI : IsArtinianRing A := isArtinian_of_finite
  have hI_le_jac :
      I ≤ Ring.jacobson A := by
    rw [← Ideal.jacobson_bot]
    intro x hx
    rw [Ideal.mem_jacobson_iff]
    intro y
    have hyx_nil : IsNilpotent (y * x) := by
      rcases hI (y * x) (I.mul_mem_left y hx) with ⟨N, hN⟩
      exact ⟨N, hN⟩
    have hyx_unit : IsUnit (y * x + 1) :=
      IsNilpotent.isUnit_add_one hyx_nil
    rcases hyx_unit with ⟨u, hu⟩
    refine ⟨↑u⁻¹, ?_⟩
    rw [Submodule.mem_bot]
    have hinv : (↑u⁻¹ : A) * (y * x + 1) = 1 := by
      rw [← hu]
      exact Units.inv_mul u
    have hsum : (↑u⁻¹ : A) * y * x + ↑u⁻¹ = 1 := by
      simpa [mul_add, mul_assoc] using hinv
    exact sub_eq_zero.mpr hsum
  rcases IsArtinianRing.isNilpotent_jacobson_bot (R := A) with ⟨N, hN⟩
  refine ⟨N, ?_⟩
  apply le_antisymm
  · calc
      I ^ N ≤ (Ring.jacobson A) ^ N :=
        Ideal.pow_right_mono hI_le_jac N
      _ = ⊥ := by
        simpa [← Ideal.jacobson_bot] using hN
  · exact bot_le

/--
The generic nilpotence input needed for the finite `p`-group algebra:
for a finite `p`-group `G`, the augmentation ideal of `𝔽_p[G]` is nilpotent.

This is independent of presentations. It is the standard modular group-algebra
fact that the augmentation ideal is contained in the Jacobson radical and, in a
finite-dimensional algebra, the radical is nilpotent.
-/
theorem augmentation_nilpotent_group
    (p : ℕ) (hp : Nat.Prime p)
    (G : Type*) [Group G] [Finite G]
    (_hG : IsPGroup p G) :
    ∃ N : ℕ,
      (GShafar.augmentationIdeal (ZMod p) G) ^ N = ⊥ := by
  classical
  haveI : Finite (MonoidAlgebra (ZMod p) G) :=
    zmod_group_algebra p hp G
  exact ring_nil_nilpotent
    (I := GShafar.augmentationIdeal (ZMod p) G)
    (augmentation_nil_group p hp G _hG)

/--
The remaining nilpotence input: for the finite presented `p`-group, the
augmentation ideal in its group algebra over `𝔽_p` is nilpotent.
-/
theorem PPDatum.pres_aug_idealnilpotent
    (H : PPDatum)
    (_p_prime : Nat.Prime H.realizesFiniteNontrivial.p)
    [Finite H.realizesFiniteNontrivial.carrier]
    [Nontrivial H.realizesFiniteNontrivial.carrier]
    (_isPGroup : IsPGroup H.realizesFiniteNontrivial.p H.realizesFiniteNontrivial.carrier) :
  ∀ ⦃rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)⦄,
      Nonempty (PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier) →
      ∃ N : ℕ, (H.presentedAugmentationIdeal rels) ^ N = ⊥ := by
  intro rels hrels
  classical
  let G := H.pGroup rels
  haveI : Finite G := H.presentedGroup_finite hrels
  exact augmentation_nilpotent_group
    H.realizesFiniteNontrivial.p
    _p_prime
    G
    (H.pres_group_pgroup _p_prime _isPGroup hrels)

/--
In degree zero the full natural-number coefficient inequality is formal: the
generator contribution vanishes.
-/
lemma full_coefficient_inequality
    {d r : ℕ} {b : ℕ → ℕ} {depth : Fin r → ℕ} :
    GShafar.fullCoefficientInequality d b depth 0 := by
  unfold GShafar.fullCoefficientInequality
  unfold GShafar.fullNatTerm
  simp

/-- In degree one, the full natural-number generator contribution is `b 0`. -/
lemma full_nat_generator (b : ℕ → ℕ) :
    GShafar.fullNatTerm b 1 = b 0 := by
  unfold GShafar.fullNatTerm
  simp

/--
If every relator has depth strictly larger than `n`, then no relator contributes
to the degree-`n` coefficient.
-/
lemma full_nat_depth
    {r : ℕ} (b : ℕ → ℕ) (depth : Fin r → ℕ) {n : ℕ}
    (hdepth : ∀ i, n < depth i) :
    GShafar.fullRelatorTerm b depth n = 0 := by
  unfold GShafar.fullRelatorTerm
  refine Finset.sum_eq_zero ?_
  intro i _hi
  have hnot : ¬ depth i ≤ n := Nat.not_le_of_gt (hdepth i)
  simp [hnot]

/--
If all relators have Zassenhaus depth at least two, then the degree-one relator
correction term vanishes.
-/
lemma full_depth_two
    {r : ℕ} (b : ℕ → ℕ) (depth : Fin r → ℕ)
    (hdepth : ∀ i, 2 ≤ depth i) :
    GShafar.fullRelatorTerm b depth 1 = 0 := by
  apply full_nat_depth
  intro i
  have hi : 2 ≤ depth i := hdepth i
  omega

/--
In any positive degree, the full generator contribution is the previous
coefficient. This is the arithmetic normalization used by the high-degree
linear-algebra estimate.
-/
lemma full_nat_pos
    {b : ℕ → ℕ} {n : ℕ}
    (hn : 1 ≤ n) :
    GShafar.fullNatTerm b n = b (n - 1) := by
  unfold GShafar.fullNatTerm
  simp [hn]

/--
The same generator-term normalization in the range relevant to the
Golod--Shafarevich high-degree estimate.
-/
lemma full_nat_two
    {b : ℕ → ℕ} {n : ℕ}
    (hn : 2 ≤ n) :
    GShafar.fullNatTerm b n = b (n - 1) := by
  have hpos : 1 ≤ n := by
    omega
  exact full_nat_pos (b := b) hpos

/--
To prove the full natural-number coefficient inequality in positive degree, it
is enough to prove the normalized bound with the generator contribution already
rewritten as the previous coefficient.
-/
lemma full_inequality_high
    {d r : ℕ} {b : ℕ → ℕ} {depth : Fin r → ℕ} {n : ℕ}
    (hn : 1 ≤ n)
    (hbound :
      d * b (n - 1) ≤
        b n + ∑ i, if depth i ≤ n then b (n - depth i) else 0) :
    GShafar.fullCoefficientInequality d b depth n := by
  unfold GShafar.fullCoefficientInequality
  rw [full_nat_pos (b := b) hn]
  unfold GShafar.fullRelatorTerm
  exact hbound

/--
The degree-zero associated graded augmentation layer of a presented group
algebra is one-dimensional.

This is the concrete algebra statement `I^0 / I^1 ≃ 𝔽_p`, since `I^0` is the
whole group algebra and `I^1` is the augmentation ideal. It sharpens the earlier
positivity lemma to the exact dimension needed by the degree-one coefficient
inequality.
-/
theorem PPDatum.presaug_layerfinrank_zeroeqone
    (H : PPDatum)
    (_p_prime : Nat.Prime H.realizesFiniteNontrivial.p)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (hrels : Nonempty (PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier)) :
    H.presentedAugmentationFinrank hrels 0 = 1 := by
  classical
  let p := H.realizesFiniteNontrivial.p
  letI : Fact p.Prime := ⟨_p_prime⟩
  let G := PresentedGroup (Set.range rels)
  let A := MonoidAlgebra (ZMod p) G
  let I : Ideal A := GShafar.augmentationIdeal (ZMod p) G
  let I0 : Submodule (ZMod p) A := (I ^ (0 : ℕ)).restrictScalars (ZMod p)
  let I1 : Submodule (ZMod p) A := (I ^ (1 : ℕ)).restrictScalars (ZMod p)
  let K : Submodule (ZMod p) I0 := I1.comap (Submodule.subtype I0)
  let augLinear : A →ₗ[ZMod p] ZMod p :=
    (GShafar.augmentationHom (ZMod p) G).toLinearMap
  let aug0 : I0 →ₗ[ZMod p] ZMod p := augLinear.comp (Submodule.subtype I0)
  have hker : LinearMap.ker aug0 = K := by
    ext x
    constructor
    · intro hx
      have hxI : (x : A) ∈ I := by
        have hxaug : (GShafar.augmentationHom (ZMod p) G).toRingHom (x : A) = 0 := by
          simpa [aug0, augLinear] using hx
        exact RingHom.mem_ker.mpr hxaug
      change (x : A) ∈ I1
      change (x : A) ∈ (I ^ (1 : ℕ)).restrictScalars (ZMod p)
      change (x : A) ∈ (I ^ (1 : ℕ) : Submodule A A)
      simpa [Submodule.pow_one] using hxI
    · intro hx
      have hxI : (x : A) ∈ I := by
        have hxI1 : (x : A) ∈ I1 := hx
        change (x : A) ∈ (I ^ (1 : ℕ)).restrictScalars (ZMod p) at hxI1
        change (x : A) ∈ (I ^ (1 : ℕ) : Submodule A A) at hxI1
        simpa [Submodule.pow_one] using hxI1
      have hxaug :
          (GShafar.augmentationHom (ZMod p) G).toRingHom (x : A) = 0 :=
        RingHom.mem_ker.mp hxI
      change aug0 x = 0
      simpa [aug0, augLinear] using hxaug
  have hsurj : Function.Surjective aug0 := by
    intro c
    have hmem : (c • (1 : A)) ∈ I0 := by
      change (c • (1 : A)) ∈ (I ^ (0 : ℕ)).restrictScalars (ZMod p)
      change (c • (1 : A)) ∈ (I ^ (0 : ℕ) : Submodule A A)
      rw [Submodule.pow_zero]
      simp
    refine ⟨⟨c • (1 : A), hmem⟩, ?_⟩
    simp [aug0, augLinear]
  let e : ((↥I0) ⧸ K) ≃ₗ[ZMod p] ZMod p :=
    (Submodule.quotEquivOfEq K (LinearMap.ker aug0) hker.symm).trans
      (aug0.quotKerEquivOfSurjective hsurj)
  have hfinrank :
      Module.finrank (ZMod p) ((↥I0) ⧸ K) = 1 := by
    calc
      Module.finrank (ZMod p) ((↥I0) ⧸ K)
          = Module.finrank (ZMod p) (ZMod p) :=
            LinearEquiv.finrank_eq e
      _ = 1 := CommSemiring.finrank_self (ZMod p)
  change Module.finrank (ZMod p) ((↥I0) ⧸ K) = 1
  exact hfinrank

/--
The minimal generator rank is bounded by any explicit free-group generating
family.

This is just the bookkeeping part of minimality: `generatorRank` was defined as
the `sInf` of all sizes of surjective free-group maps.
-/
theorem NPP.genrank_lemem_gencounts
    (P : NPP) {n : ℕ}
    (hn : n ∈ P.GeneratorCounts) :
    P.generatorRank ≤ n := by
  change sInf P.GeneratorCounts ≤ n
  exact Nat.sInf_le hn

/--
A surjection from a free group on `n` letters gives the numerical inequality
`generatorRank ≤ n`.
-/
theorem NPP.genrank_lesurj_freegroup
    (P : NPP) {n : ℕ}
    (φ : FreeGroup (Fin n) →* P.carrier)
    (hφ : Function.Surjective φ) :
    P.generatorRank ≤ n := by
  apply P.genrank_lemem_gencounts
  exact ⟨φ, hφ⟩

/--
The same generator-rank bookkeeping lemma, phrased for the surrounding finite
pro-`p` datum.
-/
theorem PPDatum.genrank_lesurj_freegroup
    (H : PPDatum) {n : ℕ}
    (φ : FreeGroup (Fin n) →* H.realizesFiniteNontrivial.carrier)
    (hφ : Function.Surjective φ) :
    H.generatorRank ≤ n := by
  simpa [PPDatum.generatorRank] using
    H.realizesFiniteNontrivial.genrank_lesurj_freegroup φ hφ

/--
From any spanning family in a finite-dimensional vector space, choose a spanning
subfamily indexed by `Fin (finrank K V)`.

This is the remaining pure linear-algebra extraction step needed by the
degree-one argument. It is independent of group algebras: one should choose a
basis contained in the given spanning set, then reindex it by `Fin (finrank K V)`.
-/
theorem finrank_subfamily_top
    {K V ι : Type*} [DivisionRing K] [AddCommGroup V] [Module K V]
    [Module.Finite K V]
    (v : ι → V)
    (hspan : Submodule.span K (Set.range v) = ⊤) :
    ∃ u : Fin (Module.finrank K V) → ι,
      Submodule.span K (Set.range fun i => v (u i)) = ⊤ := by
  classical
  let s : Set V := Set.range v
  haveI : Module.Finite K (Submodule.span K s) := by
    rw [show Submodule.span K s = ⊤ by simpa [s] using hspan]
    infer_instance
  obtain ⟨f, hf_mem, hf_span, _hf_indep⟩ :=
    Submodule.exists_fun_fin_finrank_span_eq (K := K) (s := s)
  have hfin :
      Module.finrank K (Submodule.span K s) = Module.finrank K V := by
    rw [show Submodule.span K s = ⊤ by simpa [s] using hspan]
    exact finrank_top K V
  have hpre :
      ∀ i : Fin (Module.finrank K V),
        ∃ j : ι, v j = f (Fin.cast hfin.symm i) := by
    intro i
    have hmem : f (Fin.cast hfin.symm i) ∈ Set.range v := by
      simpa [s] using hf_mem (Fin.cast hfin.symm i)
    simpa [Set.mem_range] using hmem
  choose u hu using hpre
  refine ⟨u, ?_⟩
  have hrange :
      Set.range (fun i : Fin (Module.finrank K V) => v (u i)) =
        Set.range f := by
    ext x
    constructor
    · rintro ⟨i, rfl⟩
      exact ⟨Fin.cast hfin.symm i, (hu i).symm⟩
    · rintro ⟨i, rfl⟩
      refine ⟨Fin.cast hfin i, ?_⟩
      simpa using hu (Fin.cast hfin i)
  rw [hrange, hf_span]
  simpa [s] using hspan

/--
For a presented finite `p`-group, all degree-one classes `[g - 1]` span the
first augmentation layer.
-/
theorem PPDatum.presgroup_alldegree_oneclassesspan
    (H : PPDatum)
    (_p_prime : Nat.Prime H.realizesFiniteNontrivial.p)
    [Finite H.realizesFiniteNontrivial.carrier]
    [Nontrivial H.realizesFiniteNontrivial.carrier] :
  ∀ ⦃rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)⦄,
      (hrels :
        Nonempty (PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier)) →
      Submodule.span (ZMod H.realizesFiniteNontrivial.p)
        (Set.range fun g : H.pGroup rels =>
          augmentationDegreeClass
            (ZMod H.realizesFiniteNontrivial.p) (H.pGroup rels) g) =
        ⊤ := by
  intro rels hrels
  classical
  let p := H.realizesFiniteNontrivial.p
  letI : Fact p.Prime := ⟨_p_prime⟩
  haveI : Finite (H.pGroup rels) := H.presentedGroup_finite hrels
  simpa [p] using
    augmentation_span_top
      (ZMod p) (H.pGroup rels)

/--
The first linear-algebra part of the degree-one argument: the degree-one classes
`[g - 1]` contain a spanning family of size equal to the first augmentation-layer
dimension.

This is the finite-dimensional extraction step from the fact that the
augmentation ideal is generated by all differences `g - 1`.
-/
theorem PPDatum.presgroup_degreeone_classpanfam
    (H : PPDatum)
    (_p_prime : Nat.Prime H.realizesFiniteNontrivial.p)
    [Finite H.realizesFiniteNontrivial.carrier]
    [Nontrivial H.realizesFiniteNontrivial.carrier]
    (_isPGroup : IsPGroup H.realizesFiniteNontrivial.p H.realizesFiniteNontrivial.carrier) :
  ∀ ⦃rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)⦄,
      (hrels :
        Nonempty (PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier)) →
      ∃ u : Fin (H.presentedAugmentationFinrank hrels 1) →
          H.pGroup rels,
        Submodule.span (ZMod H.realizesFiniteNontrivial.p)
          (Set.range fun i =>
            augmentationDegreeClass
              (ZMod H.realizesFiniteNontrivial.p) (H.pGroup rels) (u i)) =
          ⊤ := by
  intro rels hrels
  classical
  let p := H.realizesFiniteNontrivial.p
  letI : Fact p.Prime := ⟨_p_prime⟩
  haveI : Finite (H.pGroup rels) := H.presentedGroup_finite hrels
  have hall :
      Submodule.span (ZMod p)
        (Set.range fun g : H.pGroup rels =>
          augmentationDegreeClass (ZMod p) (H.pGroup rels) g) =
        ⊤ := by
    simpa [p] using
      H.presgroup_alldegree_oneclassesspan _p_prime hrels
  have hchoose :
      ∃ u : Fin (Module.finrank (ZMod p)
          (augmentationDegreeLayer (ZMod p) (H.pGroup rels))) →
          H.pGroup rels,
        Submodule.span (ZMod p)
          (Set.range fun i =>
            augmentationDegreeClass (ZMod p) (H.pGroup rels) (u i)) =
          ⊤ :=
    finrank_subfamily_top
      (K := ZMod p)
      (V := augmentationDegreeLayer (ZMod p) (H.pGroup rels))
      (ι := H.pGroup rels)
      (v := fun g => augmentationDegreeClass (ZMod p) (H.pGroup rels) g)
      hall
  simpa [p, PPDatum.presentedAugmentationFinrank,
    PPDatum.pALayer,
    PPDatum.presentedAugmentationKernel,
    PPDatum.presentedAugmentationSubmodule,
    PPDatum.presentedAugmentationIdeal,
    PPDatum.presentedGroupAlgebra,
    PPDatum.pGroup,
    augmentationDegreeLayer,
    augmentationDegreeKernel,
    augmentationDegreeSubmodule,
    augmentationSquareSubmodule] using hchoose

/--
If `g` belongs to the subgroup generated by a family `u`, then its degree-one
augmentation class belongs to the span of the classes of the elements of `u`.

This is the formal part of the statement that the map `g ↦ [g - 1]` is an
additive homomorphism after passing to `I / I²`: multiplication becomes
addition and inversion becomes negation.
-/
lemma span_range_closure
    (R G ι : Type*) [CommRing R] [Group G]
    (u : ι → G) {g : G}
    (hg : g ∈ Subgroup.closure (Set.range u)) :
    augmentationDegreeClass R G g ∈
      Submodule.span R
        (Set.range fun i : ι => augmentationDegreeClass R G (u i)) := by
  classical
  let S : Submodule R (augmentationDegreeLayer R G) :=
    Submodule.span R
      (Set.range fun i : ι => augmentationDegreeClass R G (u i))
  change augmentationDegreeClass R G g ∈ S
  refine Subgroup.closure_induction
    (k := Set.range u)
    (p := fun x _hx => augmentationDegreeClass R G x ∈ S)
    ?mem ?one ?mul ?inv hg
  · intro x hx
    rcases hx with ⟨i, rfl⟩
    exact Submodule.subset_span (Set.mem_range_self i)
  · change augmentationDegreeClass R G (1 : G) ∈ S
    rw [augmentation_degree_class]
    exact Submodule.zero_mem S
  · intro x y _hx _hy hxS hyS
    rw [augmentation_degree_mul]
    exact S.add_mem hxS hyS
  · intro x _hx hxS
    rw [augmentation_degree_inv]
    exact S.neg_mem hxS

/--
If every element of a family `u` lies in a subgroup `K`, then the degree-one
classes of the family span a subspace of the degree-one classes of all elements
of `K`.
-/
lemma degree_range_classes
    (R G ι : Type*) [CommRing R] [Group G]
    (K : Subgroup G) (u : ι → G)
    (hu : ∀ i, u i ∈ K) :
    Submodule.span R
        (Set.range fun i : ι => augmentationDegreeClass R G (u i)) ≤
      Submodule.span R
        (Set.range fun k : K => augmentationDegreeClass R G (k : G)) := by
  refine Submodule.span_le.mpr ?_
  intro x hx
  rcases hx with ⟨i, rfl⟩
  exact Submodule.subset_span ⟨⟨u i, hu i⟩, rfl⟩

/--
The mod-`p` Frattini generators: ordinary commutators and `p`th powers.

For a finite `p`-group, the subgroup generated by these elements is the
Frattini subgroup. Here we keep the definition elementary so the augmentation
calculation can refer only to the concrete generators it needs.
-/
def modFrattiniSet
    (p : ℕ) (G : Type*) [Group G] : Set G :=
  Set.range (fun gh : G × G => gh.1 * gh.2 * gh.1⁻¹ * gh.2⁻¹) ∪
    Set.range (fun g : G => g ^ p)

/-- The subgroup generated by commutators and `p`th powers. -/
def modFrattiniSubgroup
    (p : ℕ) (G : Type*) [Group G] : Subgroup G :=
  Subgroup.closure (modFrattiniSet p G)

/--
In the degree-one augmentation layer, powers become scalar multiples of the
class of the base element.
-/
lemma augmentation_degree_nat
    (R G : Type*) [CommRing R] [Group G] (g : G) :
    ∀ n : ℕ,
      augmentationDegreeClass R G (g ^ n) =
        (n : R) • augmentationDegreeClass R G g := by
  intro n
  induction n with
  | zero =>
      simp [augmentation_degree_class]
  | succ n ih =>
      rw [pow_succ, augmentation_degree_mul, ih]
      simp [Nat.cast_succ, add_smul]

/--
Over `ZMod p`, the degree-one augmentation class kills `p`th powers.
-/
lemma augmentation_char_zero
    (p : ℕ) (G : Type*) [Group G] (g : G) :
    augmentationDegreeClass (ZMod p) G (g ^ p) = 0 := by
  rw [augmentation_degree_nat]
  rw [CharP.cast_eq_zero (ZMod p) p]
  exact zero_smul (ZMod p) (augmentationDegreeClass (ZMod p) G g)

/--
Each generator of the mod-`p` Frattini subgroup has zero class in `I / I²`.
-/
lemma frattini_generator_set
    (p : ℕ) (G : Type*) [Group G] {x : G}
    (hx : x ∈ modFrattiniSet p G) :
    augmentationDegreeClass (ZMod p) G x = 0 := by
  rcases hx with hx | hx
  · rcases hx with ⟨gh, rfl⟩
    exact augmentation_degree_commutator (ZMod p) G gh.1 gh.2
  · rcases hx with ⟨g, rfl⟩
    exact augmentation_char_zero p G g

/--
Every element of the mod-`p` Frattini subgroup has zero degree-one augmentation
class.
-/
lemma augmentation_frattini_subgroup
    (p : ℕ) (G : Type*) [Group G] {x : G}
    (hx : x ∈ modFrattiniSubgroup p G) :
    augmentationDegreeClass (ZMod p) G x = 0 := by
  change x ∈ Subgroup.closure (modFrattiniSet p G) at hx
  refine Subgroup.closure_induction
    (k := modFrattiniSet p G)
    (p := fun y _hy => augmentationDegreeClass (ZMod p) G y = 0)
    ?mem ?one ?mul ?inv hx
  · intro y hy
    exact frattini_generator_set
      p G hy
  · change augmentationDegreeClass (ZMod p) G (1 : G) = 0
    exact augmentation_degree_class (ZMod p) G
  · intro y z _hy _hz hy0 hz0
    rw [augmentation_degree_mul, hy0, hz0, zero_add]
  · intro y _hy hy0
    rw [augmentation_degree_inv, hy0, neg_zero]

/--
If an element lies in `K` together with the mod-`p` Frattini subgroup, then its
degree-one class already lies in the span of the degree-one classes from `K`.
-/
lemma classes_sup_frattini
    (p : ℕ) (G : Type*) [Group G]
    (K : Subgroup G) {g : G}
    (hg : g ∈ K ⊔ modFrattiniSubgroup p G) :
    augmentationDegreeClass (ZMod p) G g ∈
      Submodule.span (ZMod p)
        (Set.range fun k : K =>
          augmentationDegreeClass (ZMod p) G (k : G)) := by
  let S : Submodule (ZMod p) (augmentationDegreeLayer (ZMod p) G) :=
    Submodule.span (ZMod p)
      (Set.range fun k : K =>
        augmentationDegreeClass (ZMod p) G (k : G))
  change augmentationDegreeClass (ZMod p) G g ∈ S
  rw [Subgroup.sup_eq_closure] at hg
  refine Subgroup.closure_induction
    (k := (K : Set G) ∪ (modFrattiniSubgroup p G : Set G))
    (p := fun y _hy => augmentationDegreeClass (ZMod p) G y ∈ S)
    ?mem ?one ?mul ?inv hg
  · intro y hy
    rcases hy with hyK | hyF
    · exact Submodule.subset_span ⟨⟨y, hyK⟩, rfl⟩
    · rw [augmentation_frattini_subgroup p G hyF]
      exact Submodule.zero_mem S
  · change augmentationDegreeClass (ZMod p) G (1 : G) ∈ S
    rw [augmentation_degree_class]
    exact Submodule.zero_mem S
  · intro y z _hy _hz hyS hzS
    rw [augmentation_degree_mul]
    exact S.add_mem hyS hzS
  · intro y _hy hyS
    rw [augmentation_degree_inv]
    exact S.neg_mem hyS

/--
If `K` together with the mod-`p` Frattini subgroup is all of `G`, then the
degree-one classes of elements of `K` span `I(G) / I(G)^2`.

This is the easy augmentation-theoretic direction of the Burnside bridge:
Frattini elements vanish in degree one, and all group elements have
degree-one classes spanning the layer.
-/
theorem classes_top_frattini
    (p : ℕ) (G : Type*) [Group G] [Finite G]
    (K : Subgroup G)
    (hsup : K ⊔ modFrattiniSubgroup p G = ⊤) :
    Submodule.span (ZMod p)
        (Set.range fun k : K =>
          augmentationDegreeClass (ZMod p) G (k : G)) =
      ⊤ := by
  classical
  let S : Submodule (ZMod p) (augmentationDegreeLayer (ZMod p) G) :=
    Submodule.span (ZMod p)
      (Set.range fun k : K =>
        augmentationDegreeClass (ZMod p) G (k : G))
  have hall_le :
      Submodule.span (ZMod p)
          (Set.range fun g : G =>
            augmentationDegreeClass (ZMod p) G g) ≤ S := by
    refine Submodule.span_le.mpr ?_
    intro x hx
    rcases hx with ⟨g, rfl⟩
    have hg : g ∈ K ⊔ modFrattiniSubgroup p G := by
      rw [hsup]
      exact Subgroup.mem_top g
    exact classes_sup_frattini
      p G K hg
  rw [eq_top_iff]
  intro x _hx
  have hx_all :
      x ∈ Submodule.span (ZMod p)
        (Set.range fun g : G =>
          augmentationDegreeClass (ZMod p) G g) := by
    rw [augmentation_span_top]
    exact Submodule.mem_top
  exact hall_le hx_all

/--
A proper subgroup of a finite group is contained in a maximal subgroup.

We use Mathlib's coatomicity instance for finite posets.  This is the lattice
step in the contrapositive form of Burnside's basis theorem: if
`K ⊔ Φ_p(G)` is still proper, separate it by a coatom.
-/
theorem coatom_above_top
    {G : Type*} [Group G] [Finite G]
    (S : Subgroup G)
    (hS : S ≠ ⊤) :
    ∃ M : Subgroup G, IsCoatom M ∧ S ≤ M := by
  classical
  rcases eq_top_or_exists_le_coatom S with htop | hcoatom
  · exact (hS htop).elim
  · exact hcoatom

/--
Maximal subgroups of finite `p`-groups are normal, recorded here before the
degree-one annihilator theorem so the quotient character can be constructed in
declaration order.
-/
theorem coatom_normal_annihilator
    {p : ℕ} [Fact p.Prime]
    {G : Type*} [Group G] [Finite G]
    (hG : IsPGroup p G)
    {M : Subgroup G}
    (hM : IsCoatom M) :
    M.Normal := by
  haveI : Group.IsNilpotent G := hG.isNilpotent
  exact Subgroup.NormalizerCondition.normal_of_coatom M
    (Group.normalizerCondition_of_isNilpotent (G := G)) hM

/--
In the quotient by a maximal subgroup, every subgroup is either bottom or top.
This is the correspondence theorem specialized to the coatom situation.
-/
theorem coatom_or_annihilator
    {G : Type*} [Group G]
    {M : Subgroup G} [M.Normal]
    (hM : IsCoatom M)
    (L : Subgroup (G ⧸ M)) :
    L = ⊥ ∨ L = ⊤ := by
  classical
  let e := QuotientGroup.comapMk'OrderIso M
  have hbetween :
      (e L).1 = ⊤ ∨ (e L).1 = M := by
    exact (hM.le_iff (x := (e L).1)).mp (e L).2
  rcases hbetween with htop | hM_eq
  · right
    apply e.injective
    apply Subtype.ext
    simpa [e, QuotientGroup.comapMk'OrderIso] using htop
  · left
    apply e.injective
    apply Subtype.ext
    simpa [e, QuotientGroup.comapMk'OrderIso] using hM_eq

/--
The quotient by a coatom is not the trivial group.
-/
theorem coatom_bot_annihilator
    {G : Type*} [Group G]
    {M : Subgroup G} [M.Normal]
    (hM : IsCoatom M) :
    (⊥ : Subgroup (G ⧸ M)) ≠ ⊤ := by
  classical
  intro hbot_top
  have hsubgroups : Subsingleton (Subgroup (G ⧸ M)) :=
    subsingleton_of_bot_eq_top hbot_top
  have hquotient : Subsingleton (G ⧸ M) :=
    Subgroup.subsingleton_iff.mp hsubgroups
  exact hM.ne_top (QuotientGroup.subgroup_eq_top_of_subsingleton M hquotient)

/--
A nontrivial finite `p`-group with no nontrivial subgroups has cardinality `p`.
-/
theorem bot_or_annihilator
    {p : ℕ} [Fact p.Prime]
    {Q : Type*} [Group Q] [Finite Q]
    (hQ : IsPGroup p Q)
    (hbot_ne_top : (⊥ : Subgroup Q) ≠ ⊤)
    (hsubgroups : ∀ L : Subgroup Q, L = ⊥ ∨ L = ⊤) :
    Nat.card Q = p := by
  classical
  rcases IsPGroup.exists_card_eq hQ with ⟨n, hcardQ⟩
  have hp_ne_one : p ≠ 1 := (Fact.out : Nat.Prime p).ne_one
  have hn_ne_zero : n ≠ 0 := by
    intro hn
    subst n
    have hcard_one : Nat.card Q = 1 := by
      simpa using hcardQ
    have hQ_subsingleton : Subsingleton Q :=
      (Nat.card_eq_one_iff_unique.mp hcard_one).1
    have hsubgroup_subsingleton : Subsingleton (Subgroup Q) :=
      Subgroup.subsingleton_iff.mpr hQ_subsingleton
    exact hbot_ne_top (Subsingleton.elim (⊥ : Subgroup Q) ⊤)
  have hp_le_card : p ≤ Nat.card Q := by
    rw [hcardQ]
    exact le_self_pow (show 1 ≤ p from (Fact.out : Nat.Prime p).one_le) hn_ne_zero
  rcases Sylow.exists_subgroup_card_pow_prime_of_le_card
      (G := Q) (n := 1) (p := p)
      (Fact.out : Nat.Prime p) hQ (by simpa [pow_one] using hp_le_card) with
    ⟨P, hPcard⟩
  rcases hsubgroups P with hP_bot | hP_top
  · exfalso
    apply hp_ne_one
    calc
      p = p ^ 1 := by simp
      _ = Nat.card P := hPcard.symm
      _ = Nat.card (⊥ : Subgroup Q) := by rw [hP_bot]
      _ = 1 := Subgroup.card_bot (G := Q)
  · calc
      Nat.card Q = Nat.card (⊤ : Subgroup Q) := (Subgroup.card_top (G := Q)).symm
      _ = Nat.card P := by rw [hP_top]
      _ = p ^ 1 := hPcard
      _ = p := by simp

/--
The maximal quotient of a finite `p`-group has order `p`.
-/
theorem coatom_index_annihilator
    {p : ℕ} [Fact p.Prime]
    {G : Type*} [Group G] [Finite G]
    (hG : IsPGroup p G)
    {M : Subgroup G}
    (hM : IsCoatom M) :
    M.index = p := by
  classical
  haveI : M.Normal := coatom_normal_annihilator hG hM
  have hquotient_pgroup : IsPGroup p (G ⧸ M) :=
    hG.to_quotient M
  have hquotient_nontrivial : (⊥ : Subgroup (G ⧸ M)) ≠ ⊤ :=
    coatom_bot_annihilator hM
  have hquotient_subgroups :
      ∀ L : Subgroup (G ⧸ M), L = ⊥ ∨ L = ⊤ :=
    coatom_or_annihilator hM
  have hcard : Nat.card (G ⧸ M) = p :=
    bot_or_annihilator
      hquotient_pgroup hquotient_nontrivial hquotient_subgroups
  rw [M.index_eq_card, hcard]

/--
The maximal quotient is isomorphic to `Multiplicative (ZMod p)`.
-/
theorem coatom_z_annihilator
    {p : ℕ} [Fact p.Prime]
    {G : Type*} [Group G] [Finite G]
    (hG : IsPGroup p G)
    {M : Subgroup G} [M.Normal]
    (hM : IsCoatom M) :
    Nonempty ((G ⧸ M) ≃* Multiplicative (ZMod p)) := by
  classical
  have hcardQ : Nat.card (G ⧸ M) = p := by
    rw [← M.index_eq_card, coatom_index_annihilator hG hM]
  have hcardZ : Nat.card (Multiplicative (ZMod p)) = p := by
    simp [Nat.card_eq_fintype_card, Fintype.card_multiplicative, ZMod.card]
  exact ⟨mulEquivOfPrimeCardEq hcardQ hcardZ⟩

/--
The quotient by a maximal subgroup supplies a nontrivial `ZMod p`-valued
character that kills the subgroup.
-/
theorem coatom_multiplicative_annihilator
    {p : ℕ} [Fact p.Prime]
    {G : Type*} [Group G] [Finite G]
    (hG : IsPGroup p G)
    {M : Subgroup G}
    (hM : IsCoatom M) :
    ∃ χ : G →* Multiplicative (ZMod p),
      χ ≠ 1 ∧ ∀ m : M, χ (m : G) = 1 := by
  classical
  haveI : M.Normal := coatom_normal_annihilator hG hM
  rcases coatom_z_annihilator
      hG hM with
    ⟨e⟩
  let χ : G →* Multiplicative (ZMod p) :=
    e.toMonoidHom.comp (QuotientGroup.mk' M)
  refine ⟨χ, ?_, ?_⟩
  · intro hχ
    have hquot_all_one : ∀ q : G ⧸ M, e q = 1 := by
      intro q
      rcases QuotientGroup.mk'_surjective M q with ⟨g, rfl⟩
      have hvalue := DFunLike.congr_fun hχ g
      simpa [χ] using hvalue
    have hquot_subsingleton : Subsingleton (G ⧸ M) := by
      refine ⟨fun q₁ q₂ => ?_⟩
      apply e.injective
      rw [hquot_all_one q₁, hquot_all_one q₂]
    exact coatom_bot_annihilator hM
      (Subsingleton.elim (⊥ : Subgroup (G ⧸ M)) ⊤)
  · intro m
    have hmk : QuotientGroup.mk' M (m : G) = 1 := by
      change ((m : G) : G ⧸ M) = 1
      exact (QuotientGroup.eq_one_iff (m : G)).mpr m.property
    change e.toMonoidHom (QuotientGroup.mk' M (m : G)) = 1
    rw [hmk]
    simp

/--
The quotient by a maximal subgroup supplies a nonzero linear functional on
`I(G) / I(G)^2` that kills the classes coming from that maximal subgroup.

Mathematically, the quotient `G / M` has order `p`.  Choosing a nontrivial
homomorphism `G / M → (ZMod p, +)` and extending linearly over the group
algebra gives a map on augmentation layers; the classes of elements of `M` map
to zero, while some element outside `M` maps nontrivially.
-/
theorem coatom_annihilator_functional
    {p : ℕ} [Fact p.Prime]
    {G : Type*} [Group G] [Finite G]
    (hG : IsPGroup p G)
    {M : Subgroup G}
    (hM : IsCoatom M) :
    ∃ ℓ : augmentationDegreeLayer (ZMod p) G →ₗ[ZMod p] ZMod p,
      ℓ ≠ 0 ∧
        ∀ m : M,
          ℓ (augmentationDegreeClass (ZMod p) G (m : G)) = 0 := by
  rcases coatom_multiplicative_annihilator
      hG hM with
    ⟨χ, hχ_ne, hχM⟩
  exact annihilator_functional_character
    hχ_ne hχM

/--
The degree-one classes of a maximal subgroup do not span `I(G) / I(G)^2`.

The previous lemma supplies a nonzero functional killing all generators of this
span.  If the span were the whole degree-one layer, the functional would vanish
everywhere.
-/
theorem coatom_classes_top
    {p : ℕ} [Fact p.Prime]
    {G : Type*} [Group G] [Finite G]
    (hG : IsPGroup p G)
    {M : Subgroup G}
    (hM : IsCoatom M) :
    Submodule.span (ZMod p)
        (Set.range fun m : M =>
          augmentationDegreeClass (ZMod p) G (m : G)) ≠
      ⊤ := by
  classical
  rcases coatom_annihilator_functional
      hG hM with
    ⟨ℓ, hℓ_ne_zero, hℓM⟩
  intro hspan
  apply hℓ_ne_zero
  apply LinearMap.ext
  intro x
  have hx_span :
      x ∈ Submodule.span (ZMod p)
        (Set.range fun m : M =>
          augmentationDegreeClass (ZMod p) G (m : G)) := by
    rw [hspan]
    exact Submodule.mem_top
  have hspan_le_ker :
      Submodule.span (ZMod p)
          (Set.range fun m : M =>
            augmentationDegreeClass (ZMod p) G (m : G)) ≤
        LinearMap.ker ℓ := by
    refine Submodule.span_le.mpr ?_
    intro x hx
    rcases hx with ⟨m, rfl⟩
    exact LinearMap.mem_ker.mpr (hℓM m)
  exact LinearMap.mem_ker.mp (hspan_le_ker hx_span)

/--
Any subgroup contained in a coatom has degree-one classes spanning at most the
proper coatom span.
-/
theorem classes_top_coatom
    {p : ℕ} [Fact p.Prime]
    {G : Type*} [Group G] [Finite G]
    (hG : IsPGroup p G)
    (K : Subgroup G)
    {M : Subgroup G}
    (hM : IsCoatom M)
    (hKM : K ≤ M) :
    Submodule.span (ZMod p)
        (Set.range fun k : K =>
          augmentationDegreeClass (ZMod p) G (k : G)) ≠
      ⊤ := by
  classical
  intro hKspan
  have hspan_le :
      Submodule.span (ZMod p)
          (Set.range fun k : K =>
            augmentationDegreeClass (ZMod p) G (k : G)) ≤
        Submodule.span (ZMod p)
          (Set.range fun m : M =>
            augmentationDegreeClass (ZMod p) G (m : G)) := by
    refine Submodule.span_le.mpr ?_
    intro x hx
    rcases hx with ⟨k, rfl⟩
    exact Submodule.subset_span
      ⟨⟨(k : G), hKM k.property⟩, rfl⟩
  have hMspan :
      Submodule.span (ZMod p)
          (Set.range fun m : M =>
            augmentationDegreeClass (ZMod p) G (m : G)) =
        ⊤ := by
    rw [eq_top_iff]
    intro x _hx
    have hxK :
        x ∈ Submodule.span (ZMod p)
          (Set.range fun k : K =>
            augmentationDegreeClass (ZMod p) G (k : G)) := by
      rw [hKspan]
      exact Submodule.mem_top
    exact hspan_le hxK
  exact coatom_classes_top
    hG hM hMspan

/--
The hard quotient direction of the Burnside bridge.

If the degree-one classes of a subgroup span `I(G) / I(G)^2`, then `K` maps
onto the mod-`p` Frattini quotient, i.e. adjoining commutators and `p`th powers
to `K` generates all of `G`.
-/
theorem classes_imp_frattini
    {p : ℕ} [Fact p.Prime]
    {G : Type*} [Group G] [Finite G]
    (hG : IsPGroup p G)
    (K : Subgroup G)
    (hspan :
      Submodule.span (ZMod p)
          (Set.range fun k : K =>
            augmentationDegreeClass (ZMod p) G (k : G)) =
        ⊤) :
    K ⊔ modFrattiniSubgroup p G = ⊤ := by
  classical
  by_contra hsup_ne_top
  rcases coatom_above_top
      (K ⊔ modFrattiniSubgroup p G) hsup_ne_top with
    ⟨M, hM, hsup_le_M⟩
  have hK_le_M : K ≤ M :=
    le_trans le_sup_left hsup_le_M
  exact classes_top_coatom
    hG K hM hK_le_M hspan

/--
Maximal subgroups of finite `p`-groups are normal.

This is the normalizer-condition part of finite nilpotent group theory, using
Mathlib's theorem that finite `p`-groups are nilpotent.
-/
theorem p_coatom_normal
    {p : ℕ} [Fact p.Prime]
    {G : Type*} [Group G] [Finite G]
    (hG : IsPGroup p G)
    {M : Subgroup G}
    (hM : IsCoatom M) :
    M.Normal := by
  haveI : Group.IsNilpotent G := hG.isNilpotent
  exact Subgroup.NormalizerCondition.normal_of_coatom M
    (Group.normalizerCondition_of_isNilpotent (G := G)) hM

/--
The quotient by a maximal subgroup has no intermediate subgroups.

Via the correspondence theorem for quotients, a subgroup of `G ⧸ M` is the same
as a subgroup of `G` containing `M`.  Since `M` is a coatom, such a subgroup is
either `M` itself or all of `G`.
-/
theorem coatom_or_top
    {G : Type*} [Group G]
    {M : Subgroup G} [M.Normal]
    (hM : IsCoatom M)
    (L : Subgroup (G ⧸ M)) :
    L = ⊥ ∨ L = ⊤ := by
  classical
  let e := QuotientGroup.comapMk'OrderIso M
  have hbetween :
      (e L).1 = ⊤ ∨ (e L).1 = M := by
    exact (hM.le_iff (x := (e L).1)).mp (e L).2
  rcases hbetween with htop | hM_eq
  · right
    apply e.injective
    apply Subtype.ext
    simpa [e, QuotientGroup.comapMk'OrderIso] using htop
  · left
    apply e.injective
    apply Subtype.ext
    simpa [e, QuotientGroup.comapMk'OrderIso] using hM_eq

/--
The quotient by a proper subgroup is not the trivial group, expressed as
non-collapse of bottom and top in its subgroup lattice.
-/
theorem coatom_bot_top
    {G : Type*} [Group G]
    {M : Subgroup G} [M.Normal]
    (hM : IsCoatom M) :
    (⊥ : Subgroup (G ⧸ M)) ≠ ⊤ := by
  classical
  intro hbot_top
  have hsubgroups : Subsingleton (Subgroup (G ⧸ M)) :=
    subsingleton_of_bot_eq_top hbot_top
  have hquotient : Subsingleton (G ⧸ M) :=
    Subgroup.subsingleton_iff.mp hsubgroups
  exact hM.ne_top (QuotientGroup.subgroup_eq_top_of_subsingleton M hquotient)

/--
A nontrivial finite `p`-group whose subgroup lattice has only bottom and top has
cardinality exactly `p`.

Indeed, Sylow's first theorem gives a subgroup of order `p`; it cannot be
bottom because `p` is prime, so it must be top.
-/
theorem bot_or_top
    {p : ℕ} [Fact p.Prime]
    {Q : Type*} [Group Q] [Finite Q]
    (hQ : IsPGroup p Q)
    (hbot_ne_top : (⊥ : Subgroup Q) ≠ ⊤)
    (hsubgroups : ∀ L : Subgroup Q, L = ⊥ ∨ L = ⊤) :
    Nat.card Q = p := by
  classical
  rcases IsPGroup.exists_card_eq hQ with ⟨n, hcardQ⟩
  have hp_ne_one : p ≠ 1 := (Fact.out : Nat.Prime p).ne_one
  have hn_ne_zero : n ≠ 0 := by
    intro hn
    subst n
    have hcard_one : Nat.card Q = 1 := by
      simpa using hcardQ
    have hQ_subsingleton : Subsingleton Q :=
      (Nat.card_eq_one_iff_unique.mp hcard_one).1
    have hsubgroup_subsingleton : Subsingleton (Subgroup Q) :=
      Subgroup.subsingleton_iff.mpr hQ_subsingleton
    exact hbot_ne_top (Subsingleton.elim (⊥ : Subgroup Q) ⊤)
  have hp_le_card : p ≤ Nat.card Q := by
    rw [hcardQ]
    exact le_self_pow (show 1 ≤ p from (Fact.out : Nat.Prime p).one_le) hn_ne_zero
  rcases Sylow.exists_subgroup_card_pow_prime_of_le_card
      (G := Q) (n := 1) (p := p)
      (Fact.out : Nat.Prime p) hQ (by simpa [pow_one] using hp_le_card) with
    ⟨P, hPcard⟩
  rcases hsubgroups P with hP_bot | hP_top
  · exfalso
    apply hp_ne_one
    calc
      p = p ^ 1 := by simp
      _ = Nat.card P := hPcard.symm
      _ = Nat.card (⊥ : Subgroup Q) := by rw [hP_bot]
      _ = 1 := Subgroup.card_bot (G := Q)
  · calc
      Nat.card Q = Nat.card (⊤ : Subgroup Q) := (Subgroup.card_top (G := Q)).symm
      _ = Nat.card P := by rw [hP_top]
      _ = p ^ 1 := hPcard
      _ = p := by simp

/--
A maximal subgroup of a finite `p`-group has index `p`.

This is the remaining finite `p`-group lattice input used to place the
commutator and `p`th-power generators inside the Frattini subgroup.
-/
theorem coatom_index_prime
    {p : ℕ} [Fact p.Prime]
    {G : Type*} [Group G] [Finite G]
    (hG : IsPGroup p G)
    {M : Subgroup G}
    (hM : IsCoatom M) :
    M.index = p := by
  classical
  haveI : M.Normal := p_coatom_normal hG hM
  have hquotient_pgroup : IsPGroup p (G ⧸ M) :=
    hG.to_quotient M
  have hquotient_nontrivial : (⊥ : Subgroup (G ⧸ M)) ≠ ⊤ :=
    coatom_bot_top hM
  have hquotient_subgroups :
      ∀ L : Subgroup (G ⧸ M), L = ⊥ ∨ L = ⊤ :=
    coatom_or_top hM
  have hcard : Nat.card (G ⧸ M) = p :=
    bot_or_top
      hquotient_pgroup hquotient_nontrivial hquotient_subgroups
  rw [M.index_eq_card, hcard]

/--
Once `M` is known normal, the maximal quotient `G ⧸ M` is cyclic of order
`p`, hence isomorphic to the additive group of `ZMod p`, written
multiplicatively.
-/
theorem coatom_multiplicative_z
    {p : ℕ} [Fact p.Prime]
    {G : Type*} [Group G] [Finite G]
    (hG : IsPGroup p G)
    {M : Subgroup G} [M.Normal]
    (hM : IsCoatom M) :
    Nonempty ((G ⧸ M) ≃* Multiplicative (ZMod p)) := by
  classical
  have hcardQ : Nat.card (G ⧸ M) = p := by
    rw [← M.index_eq_card, coatom_index_prime hG hM]
  have hcardZ : Nat.card (Multiplicative (ZMod p)) = p := by
    simp [Nat.card_eq_fintype_card, Fintype.card_multiplicative, ZMod.card]
  exact ⟨mulEquivOfPrimeCardEq hcardQ hcardZ⟩

/--
A maximal subgroup of a finite `p`-group has a nontrivial `ZMod p`-valued
character, written multiplicatively, whose kernel contains the subgroup.

This is the group-theoretic input for the annihilating functional on
`I(G) / I(G)^2`: the quotient `G ⧸ M` has order `p`, so it has a coordinate in
`ZMod p`; composing the quotient map with that coordinate kills every element
of `M` and is nonzero because the quotient is not collapsed.
-/
theorem coatom_z_character
    {p : ℕ} [Fact p.Prime]
    {G : Type*} [Group G] [Finite G]
    (hG : IsPGroup p G)
    {M : Subgroup G}
    (hM : IsCoatom M) :
    ∃ χ : G →* Multiplicative (ZMod p),
      χ ≠ 1 ∧ ∀ m : M, χ (m : G) = 1 := by
  classical
  haveI : M.Normal := p_coatom_normal hG hM
  rcases coatom_multiplicative_z
      hG hM with
    ⟨e⟩
  let χ : G →* Multiplicative (ZMod p) :=
    e.toMonoidHom.comp (QuotientGroup.mk' M)
  refine ⟨χ, ?_, ?_⟩
  · intro hχ
    have hquot_all_one : ∀ q : G ⧸ M, e q = 1 := by
      intro q
      rcases QuotientGroup.mk'_surjective M q with ⟨g, rfl⟩
      have hvalue := DFunLike.congr_fun hχ g
      simpa [χ] using hvalue
    have hquot_subsingleton : Subsingleton (G ⧸ M) := by
      refine ⟨fun q₁ q₂ => ?_⟩
      apply e.injective
      rw [hquot_all_one q₁, hquot_all_one q₂]
    exact coatom_bot_top hM
      (Subsingleton.elim (⊥ : Subgroup (G ⧸ M)) ⊤)
  · intro m
    have hmk : QuotientGroup.mk' M (m : G) = 1 := by
      change ((m : G) : G ⧸ M) = 1
      exact (QuotientGroup.eq_one_iff (m : G)).mpr m.property
    change e.toMonoidHom (QuotientGroup.mk' M (m : G)) = 1
    rw [hmk]
    simp

/--
Every maximal subgroup of a finite `p`-group contains all commutators.
-/
theorem coatom_contains_commutator
    {p : ℕ} [Fact p.Prime]
    {G : Type*} [Group G] [Finite G]
    (hG : IsPGroup p G)
    {M : Subgroup G}
    (hM : IsCoatom M)
    (a b : G) :
    a * b * a⁻¹ * b⁻¹ ∈ M := by
  haveI : M.Normal := p_coatom_normal hG hM
  have hindex : M.index = p :=
    coatom_index_prime hG hM
  have hcard : Nat.card (G ⧸ M) = p := by
    rw [← M.index_eq_card, hindex]
  haveI : IsCyclic (G ⧸ M) := isCyclic_of_prime_card hcard
  letI : CommGroup (G ⧸ M) := IsCyclic.commGroup
  have hquot_comm : IsMulCommutative (G ⧸ M) :=
    IsMulCommutative.of_comm fun x y => mul_comm x y
  have hcomm_le : _root_.commutator G ≤ M :=
    (Subgroup.Normal.quotient_commutative_iff_commutator_le
      (N := M)).mp hquot_comm
  have hcomm_mem : a * b * a⁻¹ * b⁻¹ ∈ _root_.commutator G := by
    rw [commutator_eq_closure]
    exact Subgroup.subset_closure (by
      rw [commutatorSet_def]
      exact ⟨a, b, by simp [commutatorElement_def]⟩)
  exact hcomm_le hcomm_mem

/--
Every maximal subgroup of a finite `p`-group contains all `p`th powers.
-/
theorem p_coatom_contains
    {p : ℕ} [Fact p.Prime]
    {G : Type*} [Group G] [Finite G]
    (hG : IsPGroup p G)
    {M : Subgroup G}
    (hM : IsCoatom M)
    (g : G) :
    g ^ p ∈ M := by
  haveI : M.Normal := p_coatom_normal hG hM
  have hindex : M.index = p :=
    coatom_index_prime hG hM
  simpa [hindex] using Subgroup.pow_index_mem M g

/--
In a finite `p`-group, every commutator lies in the Frattini subgroup.

Equivalently, the Frattini quotient is abelian. A standard proof checks
membership in every maximal subgroup: maximal subgroups of finite `p`-groups
are normal, so their quotients are simple `p`-groups, hence cyclic of order
`p`, hence abelian.
-/
theorem p_commutator_frattini
    {p : ℕ} [Fact p.Prime]
    {G : Type*} [Group G] [Finite G]
    (hG : IsPGroup p G)
    (a b : G) :
    a * b * a⁻¹ * b⁻¹ ∈ frattini G := by
  rw [frattini, Order.radical]
  rw [Subgroup.mem_iInf]
  intro M
  rw [Subgroup.mem_iInf]
  intro hM
  exact coatom_contains_commutator hG hM a b

/--
In a finite `p`-group, every `p`th power lies in the Frattini subgroup.

Equivalently, the Frattini quotient has exponent `p`. The same maximal-subgroup
argument applies: each maximal quotient has order `p`, so `g ^ p` maps to the
identity in every such quotient.
-/
theorem p_group_frattini
    {p : ℕ} [Fact p.Prime]
    {G : Type*} [Group G] [Finite G]
    (hG : IsPGroup p G)
    (g : G) :
    g ^ p ∈ frattini G := by
  rw [frattini, Order.radical]
  rw [Subgroup.mem_iInf]
  intro M
  rw [Subgroup.mem_iInf]
  intro hM
  exact p_coatom_contains hG hM g

/--
The concrete commutator/`p`th-power generator set for `Φ_p(G)` is contained in
Mathlib's Frattini subgroup for finite `p`-groups.
-/
theorem mod_set_subset
    {p : ℕ} [Fact p.Prime]
    {G : Type*} [Group G] [Finite G]
    (hG : IsPGroup p G) :
    modFrattiniSet p G ⊆ frattini G := by
  intro x hx
  rcases hx with hx | hx
  · rcases hx with ⟨gh, rfl⟩
    exact p_commutator_frattini hG gh.1 gh.2
  · rcases hx with ⟨g, rfl⟩
    exact p_group_frattini hG g

/--
The concrete mod-`p` Frattini subgroup is contained in Mathlib's Frattini
subgroup for finite `p`-groups.
-/
theorem mod_p_frattini
    {p : ℕ} [Fact p.Prime]
    {G : Type*} [Group G] [Finite G]
    (hG : IsPGroup p G) :
    modFrattiniSubgroup p G ≤ frattini G := by
  rw [modFrattiniSubgroup]
  rw [Subgroup.closure_le]
  exact mod_set_subset hG

/--
Burnside's basis theorem in subgroup form.

In a finite `p`-group, a proper subgroup cannot become all of `G` after
adjoining the mod-`p` Frattini subgroup.
-/
theorem sup_frattini_top
    {p : ℕ} [Fact p.Prime]
    {G : Type*} [Group G] [Finite G]
    (hG : IsPGroup p G)
    (K : Subgroup G)
    (hK : K ≠ ⊤) :
    K ⊔ modFrattiniSubgroup p G ≠ ⊤ := by
  intro hsup
  have hle : modFrattiniSubgroup p G ≤ frattini G :=
    mod_p_frattini hG
  have hsup_frattini : K ⊔ frattini G = ⊤ := by
    apply le_antisymm le_top
    rw [← hsup]
    exact sup_le_sup_left hle K
  exact hK (frattini_nongenerating hsup_frattini)

/--
The remaining Burnside-basis obstruction in subgroup form.

For a finite `p`-group, a proper subgroup cannot have degree-one augmentation
classes spanning all of `I(G) / I(G)^2`. Equivalently, the image of a proper
subgroup in the Frattini quotient is a proper subspace.
-/
theorem classes_ne_top
    {p : ℕ} [Fact p.Prime]
    {G : Type*} [Group G] [Finite G]
    (hG : IsPGroup p G)
    (K : Subgroup G)
    (hK : K ≠ ⊤) :
    Submodule.span (ZMod p)
        (Set.range fun k : K =>
          augmentationDegreeClass (ZMod p) G (k : G)) ≠
      ⊤ := by
  intro hspan
  have hsup : K ⊔ modFrattiniSubgroup p G = ⊤ :=
    classes_imp_frattini
      hG K hspan
  exact sup_frattini_top hG K hK hsup

/--
If the selected degree-one classes span `I / I²` in a finite `p`-group, then
the selected group elements generate the whole group as a subgroup.
-/
theorem range_top_span
    {p : ℕ} [Fact p.Prime]
    {G ι : Type*} [Group G] [Finite G]
    (hG : IsPGroup p G)
    (u : ι → G)
    (hspan :
      Submodule.span (ZMod p)
        (Set.range fun i : ι =>
          augmentationDegreeClass (ZMod p) G (u i)) =
        ⊤) :
    Subgroup.closure (Set.range u) = ⊤ := by
  classical
  by_contra hclosure
  let K : Subgroup G := Subgroup.closure (Set.range u)
  have huK : ∀ i, u i ∈ K := by
    intro i
    exact Subgroup.subset_closure (Set.mem_range_self i)
  have hle :
      Submodule.span (ZMod p)
          (Set.range fun i : ι =>
            augmentationDegreeClass (ZMod p) G (u i)) ≤
        Submodule.span (ZMod p)
          (Set.range fun k : K =>
            augmentationDegreeClass (ZMod p) G (k : G)) :=
    degree_range_classes
      (ZMod p) G ι K u huK
  have hKspan :
      Submodule.span (ZMod p)
          (Set.range fun k : K =>
            augmentationDegreeClass (ZMod p) G (k : G)) =
        ⊤ := by
    rw [eq_top_iff]
    intro x _hx
    have hx_top :
        x ∈ Submodule.span (ZMod p)
          (Set.range fun i : ι =>
            augmentationDegreeClass (ZMod p) G (u i)) := by
      rw [hspan]
      exact Submodule.mem_top
    exact hle hx_top
  exact classes_ne_top
    hG K hclosure hKspan

/--
If a family generates a group as a subgroup, then the lift from the free group
on that family is surjective.
-/
theorem free_range_top
    {G ι : Type*} [Group G]
    (u : ι → G)
    (hclosure : Subgroup.closure (Set.range u) = ⊤) :
    Function.Surjective (FreeGroup.lift u) := by
  rw [← MonoidHom.range_eq_top]
  rw [FreeGroup.range_lift_eq_closure]
  exact hclosure

/--
The existential form of `free_range_top`.
-/
theorem surjective_range_top
    {G ι : Type*} [Group G]
    (u : ι → G)
    (hclosure : Subgroup.closure (Set.range u) = ⊤) :
    ∃ φ : FreeGroup ι →* G, Function.Surjective φ := by
  exact ⟨FreeGroup.lift u,
    free_range_top u hclosure⟩

/--
The group-theoretic Burnside-basis part of the degree-one argument.

If the degree-one augmentation classes of a family `u` span `I / I²`, then `u`
generates the finite `p`-group. The formal lemmas
`augmentation_degree_mul`, `augmentation_degree_inv`, and
`augmentation_degree_commutator` are the basic algebraic inputs showing
that this class map factors through the mod-`p` abelian Frattini quotient.
-/
theorem PPDatum.presgroupsurj_freegroupdegree_oneclassspan
    (H : PPDatum)
    (_p_prime : Nat.Prime H.realizesFiniteNontrivial.p)
    [Finite H.realizesFiniteNontrivial.carrier]
    [Nontrivial H.realizesFiniteNontrivial.carrier]
    (_isPGroup : IsPGroup H.realizesFiniteNontrivial.p H.realizesFiniteNontrivial.carrier)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (hrels :
      Nonempty (PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier))
    (u : Fin (H.presentedAugmentationFinrank hrels 1) →
      H.pGroup rels)
    (hspan :
      Submodule.span (ZMod H.realizesFiniteNontrivial.p)
        (Set.range fun i =>
          augmentationDegreeClass
            (ZMod H.realizesFiniteNontrivial.p) (H.pGroup rels) (u i)) =
        ⊤) :
    ∃ φ : FreeGroup (Fin (H.presentedAugmentationFinrank hrels 1)) →*
        H.pGroup rels,
      Function.Surjective φ := by
  classical
  let p := H.realizesFiniteNontrivial.p
  let G := H.pGroup rels
  letI : Fact p.Prime := ⟨_p_prime⟩
  haveI : Finite G := H.presentedGroup_finite hrels
  have hG : IsPGroup p G :=
    H.pres_group_pgroup _p_prime _isPGroup hrels
  have hclosure :
      Subgroup.closure (Set.range u) = ⊤ :=
    range_top_span
      (p := p) (G := G)
      hG u (by simpa [p, G] using hspan)
  exact surjective_range_top u hclosure

/--
The Burnside-basis input in the degree-one augmentation layer.

For a finite `p`-group `G`, the group algebra layer `I(G) / I(G)^2` is dual to
the Frattini quotient enough to recover a generating family: choosing a basis of
this layer gives `finrank I/I²` group elements whose images generate `G`. This
lemma isolates exactly that theorem for the presented group attached to `rels`.
-/
theorem PPDatum.presgroup_surjfreegroup_degreeonelayer
    (H : PPDatum)
    (_p_prime : Nat.Prime H.realizesFiniteNontrivial.p)
    [Finite H.realizesFiniteNontrivial.carrier]
    [Nontrivial H.realizesFiniteNontrivial.carrier]
    (_isPGroup : IsPGroup H.realizesFiniteNontrivial.p H.realizesFiniteNontrivial.carrier) :
  ∀ ⦃rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)⦄,
      (hrels :
        Nonempty (PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier)) →
      ∃ φ : FreeGroup (Fin (H.presentedAugmentationFinrank hrels 1)) →*
          H.pGroup rels,
        Function.Surjective φ := by
  intro rels hrels
  rcases H.presgroup_degreeone_classpanfam
      _p_prime _isPGroup hrels with
    ⟨u, hspan⟩
  exact H.presgroupsurj_freegroupdegree_oneclassspan
    _p_prime _isPGroup hrels u hspan

/--
Transport the degree-one-layer generating family from the presented group to the
finite `p`-group represented by the datum.
-/
theorem PPDatum.carriersurj_freegroup_degreeonelayer
    (H : PPDatum)
    (_p_prime : Nat.Prime H.realizesFiniteNontrivial.p)
    [Finite H.realizesFiniteNontrivial.carrier]
    [Nontrivial H.realizesFiniteNontrivial.carrier]
    (_isPGroup : IsPGroup H.realizesFiniteNontrivial.p H.realizesFiniteNontrivial.carrier) :
  ∀ ⦃rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)⦄,
      (hrels :
        Nonempty (PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier)) →
      ∃ φ : FreeGroup (Fin (H.presentedAugmentationFinrank hrels 1)) →*
          H.realizesFiniteNontrivial.carrier,
        Function.Surjective φ := by
  intro rels hrels
  rcases H.presgroup_surjfreegroup_degreeonelayer
      _p_prime _isPGroup hrels with
    ⟨φ, hφ⟩
  let e : H.pGroup rels ≃* H.realizesFiniteNontrivial.carrier :=
    H.presentedGroupEquiv hrels
  let ψ : FreeGroup (Fin (H.presentedAugmentationFinrank hrels 1)) →*
      H.realizesFiniteNontrivial.carrier :=
    e.toMonoidHom.comp φ
  refine ⟨ψ, ?_⟩
  intro y
  rcases hφ (e.symm y) with ⟨x, hx⟩
  refine ⟨x, ?_⟩
  simp [ψ, hx]

/--
The first augmentation layer has dimension at least the minimal generator rank
of the finite `p`-group.

For a finite `p`-group, the standard identification
`I / I^2 ≃ G / Φ(G) ⊗ 𝔽_p` shows that this dimension is the minimal number of
generators. We only need the easy direction here: the chosen minimal-generator
presentation gives at least `generatorRank` independent degree-one classes.
-/
theorem PPDatum.presaug_layerfinrankone_gegenrank
    (H : PPDatum)
    (_p_prime : Nat.Prime H.realizesFiniteNontrivial.p)
    [Finite H.realizesFiniteNontrivial.carrier]
    [Nontrivial H.realizesFiniteNontrivial.carrier]
    (_isPGroup : IsPGroup H.realizesFiniteNontrivial.p H.realizesFiniteNontrivial.carrier) :
  ∀ ⦃rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)⦄,
      (hrels :
        Nonempty (PresentedGroup (Set.range rels) ≃* H.realizesFiniteNontrivial.carrier)) →
      H.generatorRank ≤ H.presentedAugmentationFinrank hrels 1 := by
  intro rels hrels
  rcases H.carriersurj_freegroup_degreeonelayer
      _p_prime _isPGroup hrels with
    ⟨φ, hφ⟩
  exact H.genrank_lesurj_freegroup φ hφ

/--
The high-degree generator source in the Golod--Shafarevich estimate.

In degree `n`, this is one copy of the previous augmentation layer for each
minimal generator. Its dimension should be
`generatorRank * b (n - 1)`.
-/
abbrev PPDatum.pres_highdegree_gensource
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (n : ℕ) : Type :=
  Fin H.generatorRank →
    H.pALayer (rels := rels) (n - 1)

/--
The relators that contribute to the degree-`n` coefficient: precisely those
whose Zassenhaus depth is at most `n`.
-/
abbrev PPDatum.pres_highdegree_relatorindex
    (H : PPDatum)
    (depth : Fin H.relationRank → ℕ)
    (n : ℕ) : Type :=
  { i : Fin H.relationRank // depth i ≤ n }

/--
The high-degree relator correction source.

A relator of depth `q ≤ n` contributes a shifted copy of the augmentation layer
in degree `n - q`. Indexing only over relators satisfying `q ≤ n` avoids
carrying zero summands through the linear-algebra statement.
-/
abbrev PPDatum.pHSrc
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (depth : Fin H.relationRank → ℕ)
    (n : ℕ) : Type :=
  (i : H.pres_highdegree_relatorindex depth n) →
    H.pALayer (rels := rels) (n - depth i.1)

/--
The domain whose dimension is the right-hand side of the high-degree
Golod--Shafarevich inequality: the target degree-`n` layer, together with the
relator correction layers.
-/
abbrev PPDatum.pres_highdegree_targetrelators
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (depth : Fin H.relationRank → ℕ)
    (n : ℕ) : Type :=
  H.pALayer (rels := rels) n ×
    H.pHSrc (rels := rels) depth n

/--
Linear algebra behind the split form of the high-degree
Golod--Shafarevich estimate.

If `β : G → T` is onto and the range of `α : R → G` contains `ker β`, then a
linear section of `β` and the map `α` together give a surjection
`T × R → G`.
-/
theorem linear_coprod_range
    {K G T R : Type*}
    [Semiring K]
    [AddCommGroup G] [AddCommGroup T] [AddCommMonoid R]
    [Module K G] [Module K T] [Module K R]
    [Module.Projective K T]
    (β : G →ₗ[K] T)
    (α : R →ₗ[K] G)
    (hβ : Function.Surjective β)
    (hker : LinearMap.ker β ≤ LinearMap.range α) :
    ∃ Ψ : T × R →ₗ[K] G, Function.Surjective Ψ := by
  classical
  rcases β.exists_rightInverse_of_surjective (LinearMap.range_eq_top.mpr hβ) with
    ⟨σ, hσ⟩
  refine ⟨σ.coprod α, ?_⟩
  intro x
  have hsection : β (σ (β x)) = β x := by
    change (β.comp σ) (β x) = (LinearMap.id : T →ₗ[K] T) (β x)
    rw [hσ]
  have hxker : x - σ (β x) ∈ LinearMap.ker β := by
    change β (x - σ (β x)) = 0
    rw [map_sub, hsection, sub_self]
  have hxrange : x - σ (β x) ∈ LinearMap.range α :=
    hker hxker
  rcases hxrange with ⟨r, hr⟩
  refine ⟨(β x, r), ?_⟩
  change σ (β x) + α r = x
  rw [hr]
  abel

/--
Multiplication by an element of `I^m` sends the `n`th augmentation power into
the `(m + n)`th augmentation power.

This is the basic filtered-algebra fact underlying the high-degree
Golod--Shafarevich multiplication map.
-/
lemma PPDatum.presented_augmentation_left
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {m n : ℕ}
    {a : H.presentedGroupAlgebra rels}
    (ha : a ∈ (H.presentedAugmentationIdeal rels) ^ m)
    (x : H.presentedAugmentationSubmodule (rels := rels) n) :
    a * (x : H.presentedGroupAlgebra rels) ∈
      H.presentedAugmentationSubmodule (rels := rels) (m + n) := by
  let I : Ideal (H.presentedGroupAlgebra rels) :=
    H.presentedAugmentationIdeal rels
  haveI : I.IsTwoSided := by
    change (H.presentedAugmentationIdeal rels).IsTwoSided
    dsimp [PPDatum.presentedAugmentationIdeal,
      GShafar.augmentationIdeal]
    infer_instance
  have hx : (x : H.presentedGroupAlgebra rels) ∈ I ^ n := by
    simp [I, PPDatum.presentedAugmentationSubmodule]
  have hprod : a * (x : H.presentedGroupAlgebra rels) ∈ I ^ m * I ^ n :=
    Ideal.mul_mem_mul (by simpa [I] using ha) hx
  have htarget : a * (x : H.presentedGroupAlgebra rels) ∈ I ^ (m + n) := by
    rw [Ideal.IsTwoSided.pow_add]
    exact hprod
  simpa [I, PPDatum.presentedAugmentationSubmodule] using htarget

/--
The filtered left-multiplication map `I^n → I^(m+n)` induced by an element of
`I^m`.
-/
noncomputable def PPDatum.pres_augpower_leftmul
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {m n : ℕ}
    (a : H.presentedGroupAlgebra rels)
    (ha : a ∈ (H.presentedAugmentationIdeal rels) ^ m) :
    H.presentedAugmentationSubmodule (rels := rels) n →ₗ[
        ZMod H.realizesFiniteNontrivial.p]
      H.presentedAugmentationSubmodule (rels := rels) (m + n) where
  toFun x :=
    ⟨a * (x : H.presentedGroupAlgebra rels),
      H.presented_augmentation_left (m := m) (n := n) ha x⟩
  map_add' x y := by
    ext
    simp [mul_add]
  map_smul' c x := by
    ext
    simp

@[simp]
lemma PPDatum.presaug_powerleft_mulapply
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {m n : ℕ}
    (a : H.presentedGroupAlgebra rels)
    (ha : a ∈ (H.presentedAugmentationIdeal rels) ^ m)
    (x : H.presentedAugmentationSubmodule (rels := rels) n) :
    (H.pres_augpower_leftmul (m := m) (n := n) a ha x :
        H.presentedGroupAlgebra rels) =
      a * (x : H.presentedGroupAlgebra rels) := rfl

/--
The filtered multiplication map respects the quotient kernels:
`I^(n+1)` maps into `I^(m+n+1)`.
-/
lemma PPDatum.presaug_powerleftmul_memlayerkernel
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {m n : ℕ}
    (a : H.presentedGroupAlgebra rels)
    (ha : a ∈ (H.presentedAugmentationIdeal rels) ^ m)
    {x : H.presentedAugmentationSubmodule (rels := rels) n}
    (hx : x ∈ H.presentedAugmentationKernel (rels := rels) n) :
    H.pres_augpower_leftmul (m := m) (n := n) a ha x ∈
      H.presentedAugmentationKernel (rels := rels) (m + n) := by
  let I : Ideal (H.presentedGroupAlgebra rels) :=
    H.presentedAugmentationIdeal rels
  haveI : I.IsTwoSided := by
    change (H.presentedAugmentationIdeal rels).IsTwoSided
    dsimp [PPDatum.presentedAugmentationIdeal,
      GShafar.augmentationIdeal]
    infer_instance
  have hxpow : (x : H.presentedGroupAlgebra rels) ∈ I ^ (n + 1) := by
    simpa [I, PPDatum.presentedAugmentationKernel,
      PPDatum.presentedAugmentationSubmodule] using hx
  have hprod :
      a * (x : H.presentedGroupAlgebra rels) ∈ I ^ m * I ^ (n + 1) :=
    Ideal.mul_mem_mul (by simpa [I] using ha) hxpow
  have htarget :
      a * (x : H.presentedGroupAlgebra rels) ∈ I ^ ((m + n) + 1) := by
    have hdegree : m + (n + 1) = (m + n) + 1 := by omega
    rw [← hdegree, Ideal.IsTwoSided.pow_add]
    exact hprod
  simpa [I, PPDatum.presentedAugmentationKernel,
    PPDatum.presentedAugmentationSubmodule] using htarget

/--
The associated-graded left-multiplication map
`I^n / I^(n+1) → I^(m+n) / I^(m+n+1)` induced by an element of `I^m`.
-/
noncomputable def PPDatum.pres_auglayer_leftmul
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {m n : ℕ}
    (a : H.presentedGroupAlgebra rels)
    (ha : a ∈ (H.presentedAugmentationIdeal rels) ^ m) :
    H.pALayer (rels := rels) n →ₗ[
        ZMod H.realizesFiniteNontrivial.p]
      H.pALayer (rels := rels) (m + n) :=
  (H.presentedAugmentationKernel (rels := rels) n).mapQ
    (H.presentedAugmentationKernel (rels := rels) (m + n))
    (H.pres_augpower_leftmul (m := m) (n := n) a ha)
    (by
      intro x hx
      exact H.presaug_powerleftmul_memlayerkernel
        (m := m) (n := n) a ha hx)

@[simp]
lemma PPDatum.presaug_layerleft_mulmk
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {m n : ℕ}
    (a : H.presentedGroupAlgebra rels)
    (ha : a ∈ (H.presentedAugmentationIdeal rels) ^ m)
    (x : H.presentedAugmentationSubmodule (rels := rels) n) :
    H.pres_auglayer_leftmul (m := m) (n := n) a ha
        ((H.presentedAugmentationKernel (rels := rels) n).mkQ x) =
      (H.presentedAugmentationKernel (rels := rels) (m + n)).mkQ
        (H.pres_augpower_leftmul (m := m) (n := n) a ha x) := rfl

/--
The filtered multiplication map with the target augmentation power rewritten to
a specified equal degree.
-/
noncomputable def PPDatum.presentedAugmentationLeft
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {m n k : ℕ}
    (hdegree : m + n = k)
    (a : H.presentedGroupAlgebra rels)
    (ha : a ∈ (H.presentedAugmentationIdeal rels) ^ m) :
    H.presentedAugmentationSubmodule (rels := rels) n →ₗ[
        ZMod H.realizesFiniteNontrivial.p]
      H.presentedAugmentationSubmodule (rels := rels) k where
  toFun x :=
    ⟨a * (x : H.presentedGroupAlgebra rels),
      by
        have hx :
            a * (x : H.presentedGroupAlgebra rels) ∈
              H.presentedAugmentationSubmodule (rels := rels) (m + n) :=
          H.presented_augmentation_left (m := m) (n := n) ha x
        simpa [hdegree] using hx⟩
  map_add' x y := by
    ext
    simp [mul_add]
  map_smul' c x := by
    ext
    simp

@[simp]
lemma PPDatum.presented_left_mul
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {m n k : ℕ}
    (hdegree : m + n = k)
    (a : H.presentedGroupAlgebra rels)
    (ha : a ∈ (H.presentedAugmentationIdeal rels) ^ m)
    (x : H.presentedAugmentationSubmodule (rels := rels) n) :
    (H.presentedAugmentationLeft
        (m := m) (n := n) (k := k) hdegree a ha x :
        H.presentedGroupAlgebra rels) =
      a * (x : H.presentedGroupAlgebra rels) := rfl

/--
The target-degree rewritten filtered map still sends quotient-kernel elements
to quotient-kernel elements.
-/
lemma PPDatum.presented_layer_kernel
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {m n k : ℕ}
    (hdegree : m + n = k)
    (a : H.presentedGroupAlgebra rels)
    (ha : a ∈ (H.presentedAugmentationIdeal rels) ^ m)
    {x : H.presentedAugmentationSubmodule (rels := rels) n}
    (hx : x ∈ H.presentedAugmentationKernel (rels := rels) n) :
    H.presentedAugmentationLeft
        (m := m) (n := n) (k := k) hdegree a ha x ∈
      H.presentedAugmentationKernel (rels := rels) k := by
  have hx' :
      H.pres_augpower_leftmul (m := m) (n := n) a ha x ∈
        H.presentedAugmentationKernel (rels := rels) (m + n) :=
    H.presaug_powerleftmul_memlayerkernel
      (m := m) (n := n) a ha hx
  simpa [hdegree, PPDatum.presentedAugmentationLeft,
    PPDatum.pres_augpower_leftmul] using hx'

/--
The same associated-graded multiplication map, with the target degree rewritten
to a specified equal natural number.
-/
noncomputable def PPDatum.presentedLeftMul
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {m n k : ℕ}
    (hdegree : m + n = k)
    (a : H.presentedGroupAlgebra rels)
    (ha : a ∈ (H.presentedAugmentationIdeal rels) ^ m) :
    H.pALayer (rels := rels) n →ₗ[
        ZMod H.realizesFiniteNontrivial.p]
      H.pALayer (rels := rels) k :=
  (H.presentedAugmentationKernel (rels := rels) n).mapQ
    (H.presentedAugmentationKernel (rels := rels) k)
    (H.presentedAugmentationLeft
      (m := m) (n := n) (k := k) hdegree a ha)
    (by
      intro x hx
      exact H.presented_layer_kernel
        (m := m) (n := n) (k := k) hdegree a ha hx)

@[simp]
lemma PPDatum.presented_left_mk
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {m n k : ℕ}
    (hdegree : m + n = k)
    (a : H.presentedGroupAlgebra rels)
    (ha : a ∈ (H.presentedAugmentationIdeal rels) ^ m)
    (x : H.presentedAugmentationSubmodule (rels := rels) n) :
    H.presentedLeftMul
        (m := m) (n := n) (k := k) hdegree a ha
        ((H.presentedAugmentationKernel (rels := rels) n).mkQ x) =
      (H.presentedAugmentationKernel (rels := rels) k).mkQ
        (H.presentedAugmentationLeft
          (m := m) (n := n) (k := k) hdegree a ha x) := rfl

/--
Multiplication on the right by an element of `I^m` sends the `n`th
augmentation power into the `(n + m)`th augmentation power.

This is the orientation compatible with the Fox syzygy
`∑ (∂r/∂x_j) (x_j - 1) = 0`.
-/
lemma PPDatum.presented_right_mul
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {m n : ℕ}
    {a : H.presentedGroupAlgebra rels}
    (ha : a ∈ (H.presentedAugmentationIdeal rels) ^ m)
    (x : H.presentedAugmentationSubmodule (rels := rels) n) :
    (x : H.presentedGroupAlgebra rels) * a ∈
      H.presentedAugmentationSubmodule (rels := rels) (n + m) := by
  let I : Ideal (H.presentedGroupAlgebra rels) :=
    H.presentedAugmentationIdeal rels
  haveI : I.IsTwoSided := by
    change (H.presentedAugmentationIdeal rels).IsTwoSided
    dsimp [PPDatum.presentedAugmentationIdeal,
      GShafar.augmentationIdeal]
    infer_instance
  have hx : (x : H.presentedGroupAlgebra rels) ∈ I ^ n := by
    simp [I, PPDatum.presentedAugmentationSubmodule]
  have hprod : (x : H.presentedGroupAlgebra rels) * a ∈ I ^ n * I ^ m :=
    Ideal.mul_mem_mul hx (by simpa [I] using ha)
  have htarget : (x : H.presentedGroupAlgebra rels) * a ∈ I ^ (n + m) := by
    rw [Ideal.IsTwoSided.pow_add]
    exact hprod
  simpa [I, PPDatum.presentedAugmentationSubmodule] using htarget

/--
The filtered right-multiplication map with the target augmentation power
rewritten to a specified equal degree.
-/
noncomputable def PPDatum.presentedRightMul
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {m n k : ℕ}
    (hdegree : n + m = k)
    (a : H.presentedGroupAlgebra rels)
    (ha : a ∈ (H.presentedAugmentationIdeal rels) ^ m) :
    H.presentedAugmentationSubmodule (rels := rels) n →ₗ[
        ZMod H.realizesFiniteNontrivial.p]
      H.presentedAugmentationSubmodule (rels := rels) k where
  toFun x :=
    ⟨(x : H.presentedGroupAlgebra rels) * a,
      by
        have hx :
            (x : H.presentedGroupAlgebra rels) * a ∈
              H.presentedAugmentationSubmodule (rels := rels) (n + m) :=
          H.presented_right_mul (m := m) (n := n) ha x
        simpa [hdegree] using hx⟩
  map_add' x y := by
    ext
    simp [add_mul]
  map_smul' c x := by
    ext
    simp

@[simp]
lemma PPDatum.presented_augmentation_mul
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {m n k : ℕ}
    (hdegree : n + m = k)
    (a : H.presentedGroupAlgebra rels)
    (ha : a ∈ (H.presentedAugmentationIdeal rels) ^ m)
    (x : H.presentedAugmentationSubmodule (rels := rels) n) :
    (H.presentedRightMul
        (m := m) (n := n) (k := k) hdegree a ha x :
        H.presentedGroupAlgebra rels) =
      (x : H.presentedGroupAlgebra rels) * a := rfl

/--
Right multiplication sends quotient-kernel elements to quotient-kernel
elements, hence descends to the associated graded layer.
-/
lemma PPDatum.presented_augmentation_kernel
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {m n k : ℕ}
    (hdegree : n + m = k)
    (a : H.presentedGroupAlgebra rels)
    (ha : a ∈ (H.presentedAugmentationIdeal rels) ^ m)
    {x : H.presentedAugmentationSubmodule (rels := rels) n}
    (hx : x ∈ H.presentedAugmentationKernel (rels := rels) n) :
    H.presentedRightMul
        (m := m) (n := n) (k := k) hdegree a ha x ∈
      H.presentedAugmentationKernel (rels := rels) k := by
  let I : Ideal (H.presentedGroupAlgebra rels) :=
    H.presentedAugmentationIdeal rels
  haveI : I.IsTwoSided := by
    change (H.presentedAugmentationIdeal rels).IsTwoSided
    dsimp [PPDatum.presentedAugmentationIdeal,
      GShafar.augmentationIdeal]
    infer_instance
  have hxpow : (x : H.presentedGroupAlgebra rels) ∈ I ^ (n + 1) := by
    simpa [I, PPDatum.presentedAugmentationKernel,
      PPDatum.presentedAugmentationSubmodule] using hx
  have hprod :
      (x : H.presentedGroupAlgebra rels) * a ∈ I ^ (n + 1) * I ^ m :=
    Ideal.mul_mem_mul hxpow (by simpa [I] using ha)
  have htarget :
      (x : H.presentedGroupAlgebra rels) * a ∈ I ^ (k + 1) := by
    have hdegree' : (n + 1) + m = k + 1 := by omega
    rw [← hdegree', Ideal.IsTwoSided.pow_add]
    exact hprod
  simpa [I, PPDatum.presentedAugmentationKernel,
    PPDatum.presentedAugmentationSubmodule,
    PPDatum.presentedRightMul] using htarget

/--
The associated-graded right-multiplication map
`I^n / I^(n+1) → I^k / I^(k+1)` induced by an element of `I^m`, where
`k = n + m`.
-/
noncomputable def PPDatum.presentedAugmentationMul
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {m n k : ℕ}
    (hdegree : n + m = k)
    (a : H.presentedGroupAlgebra rels)
    (ha : a ∈ (H.presentedAugmentationIdeal rels) ^ m) :
    H.pALayer (rels := rels) n →ₗ[
        ZMod H.realizesFiniteNontrivial.p]
      H.pALayer (rels := rels) k :=
  (H.presentedAugmentationKernel (rels := rels) n).mapQ
    (H.presentedAugmentationKernel (rels := rels) k)
    (H.presentedRightMul
      (m := m) (n := n) (k := k) hdegree a ha)
    (by
      intro x hx
      exact H.presented_augmentation_kernel
        (m := m) (n := n) (k := k) hdegree a ha hx)

@[simp]
lemma PPDatum.presented_augmentation_mk
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {m n k : ℕ}
    (hdegree : n + m = k)
    (a : H.presentedGroupAlgebra rels)
    (ha : a ∈ (H.presentedAugmentationIdeal rels) ^ m)
    (x : H.presentedAugmentationSubmodule (rels := rels) n) :
    H.presentedAugmentationMul
        (m := m) (n := n) (k := k) hdegree a ha
        ((H.presentedAugmentationKernel (rels := rels) n).mkQ x) =
      (H.presentedAugmentationKernel (rels := rels) k).mkQ
        (H.presentedRightMul
          (m := m) (n := n) (k := k) hdegree a ha x) := rfl

/--
The concrete high-degree multiplication map attached to a chosen list of
degree-one augmentation elements.

For presentation generators this is the map
`(a_j)_j ↦ ∑ⱼ (g_j - 1) a_j` on the associated graded algebra.
-/
noncomputable def PPDatum.presentedGeneratorMultiplication
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (genDiff : Fin H.generatorRank → H.presentedGroupAlgebra rels)
    (hgen : ∀ j, genDiff j ∈ H.presentedAugmentationIdeal rels)
    (n : ℕ)
    (hn : 1 ≤ n) :
    H.pres_highdegree_gensource (rels := rels) n →ₗ[
        ZMod H.realizesFiniteNontrivial.p]
      H.pALayer (rels := rels) n :=
  LinearMap.lsum (ZMod H.realizesFiniteNontrivial.p)
    (fun _ : Fin H.generatorRank =>
      H.pALayer (rels := rels) (n - 1))
    (ZMod H.realizesFiniteNontrivial.p)
    (fun j =>
      H.presentedLeftMul
        (m := 1) (n := n - 1) (k := n)
        (by omega)
        (genDiff j)
      (by
        simpa [Submodule.pow_one] using hgen j))

/--
The right-oriented high-degree multiplication map attached to chosen
degree-one augmentation elements.

For Fox syzygies this is the natural orientation:
`(a_j)_j ↦ ∑ⱼ a_j (g_j - 1)`.
-/
noncomputable def PPDatum.highDegreeMultiplication
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (genDiff : Fin H.generatorRank → H.presentedGroupAlgebra rels)
    (hgen : ∀ j, genDiff j ∈ H.presentedAugmentationIdeal rels)
    (n : ℕ)
    (hn : 1 ≤ n) :
    H.pres_highdegree_gensource (rels := rels) n →ₗ[
        ZMod H.realizesFiniteNontrivial.p]
      H.pALayer (rels := rels) n :=
  LinearMap.lsum (ZMod H.realizesFiniteNontrivial.p)
    (fun _ : Fin H.generatorRank =>
      H.pALayer (rels := rels) (n - 1))
    (ZMod H.realizesFiniteNontrivial.p)
    (fun j =>
      H.presentedAugmentationMul
        (m := 1) (n := n - 1) (k := n)
        (by omega)
        (genDiff j)
        (by
          simpa [Submodule.pow_one] using hgen j))

/--
The right-oriented generator multiplication map on representatives.
-/
lemma PPDatum.presented_multiplication_mk
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (genDiff : Fin H.generatorRank → H.presentedGroupAlgebra rels)
    (hgen : ∀ j, genDiff j ∈ H.presentedAugmentationIdeal rels)
    (n : ℕ)
    (hn : 1 ≤ n)
    (y : Fin H.generatorRank →
      H.presentedAugmentationSubmodule (rels := rels) (n - 1)) :
    H.highDegreeMultiplication
        (rels := rels) genDiff hgen n hn
        (fun j =>
          (H.presentedAugmentationKernel (rels := rels) (n - 1)).mkQ (y j)) =
      (H.presentedAugmentationKernel (rels := rels) n).mkQ
        (∑ j,
          H.presentedRightMul
            (m := 1) (n := n - 1) (k := n)
            (by omega)
            (genDiff j)
            (by simpa [Submodule.pow_one] using hgen j)
            (y j)) := by
  let K := H.presentedAugmentationKernel (rels := rels) n
  calc
    H.highDegreeMultiplication
        (rels := rels) genDiff hgen n hn
        (fun j =>
          (H.presentedAugmentationKernel (rels := rels) (n - 1)).mkQ (y j))
        =
        ∑ j,
          K.mkQ
            (H.presentedRightMul
              (m := 1) (n := n - 1) (k := n)
              (by omega)
              (genDiff j)
              (by simpa [Submodule.pow_one] using hgen j)
              (y j)) := by
          dsimp [PPDatum.highDegreeMultiplication,
            K]
          simp only [LinearMap.sum_apply, LinearMap.comp_apply, LinearMap.proj_apply]
          apply Finset.sum_congr rfl
          intro j _hj
          exact H.presented_augmentation_mk
            (m := 1) (n := n - 1) (k := n)
            (by omega)
            (genDiff j)
            (by simpa [Submodule.pow_one] using hgen j)
            (y j)
    _ =
        K.mkQ
          (∑ j,
            H.presentedRightMul
              (m := 1) (n := n - 1) (k := n)
              (by omega)
              (genDiff j)
              (by simpa [Submodule.pow_one] using hgen j)
              (y j)) := by
          exact (map_sum K.mkQ
            (fun j =>
              H.presentedRightMul
                (m := 1) (n := n - 1) (k := n)
                (by omega)
                (genDiff j)
                (by simpa [Submodule.pow_one] using hgen j)
                (y j))
            Finset.univ).symm

/--
A numerator-level form of the assertion that the degree-one elements generate
the associated graded algebra in degree `n`.

It says that every element of `I^n` is, modulo `I^(n+1)`, a finite sum of
left products of the chosen degree-one elements with elements of `I^(n-1)`.
-/
def PPDatum.presentedAugmentationGenerated
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (genDiff : Fin H.generatorRank → H.presentedGroupAlgebra rels)
    (_hgen : ∀ j, genDiff j ∈ H.presentedAugmentationIdeal rels)
    (n : ℕ)
    (_hn : 1 ≤ n) : Prop :=
  ∀ x : H.presentedAugmentationSubmodule (rels := rels) n,
    ∃ y : Fin H.generatorRank →
        H.presentedAugmentationSubmodule (rels := rels) (n - 1),
      (x : H.presentedGroupAlgebra rels) -
          ∑ j, genDiff j *
            ((y j : H.presentedAugmentationSubmodule (rels := rels) (n - 1)) :
              H.presentedGroupAlgebra rels) ∈
        H.presentedAugmentationSubmodule (rels := rels) (n + 1)

/--
A right-oriented numerator-level generation statement for the associated graded
augmentation algebra in degree `n`.

It says that every element of `I^n` is, modulo `I^(n+1)`, a finite sum of right
products of elements of `I^(n-1)` with the chosen degree-one differences.
-/
def PPDatum.presentedGeneratedDegree
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (genDiff : Fin H.generatorRank → H.presentedGroupAlgebra rels)
    (_hgen : ∀ j, genDiff j ∈ H.presentedAugmentationIdeal rels)
    (n : ℕ)
    (_hn : 1 ≤ n) : Prop :=
  ∀ x : H.presentedAugmentationSubmodule (rels := rels) n,
    ∃ y : Fin H.generatorRank →
        H.presentedAugmentationSubmodule (rels := rels) (n - 1),
      (x : H.presentedGroupAlgebra rels) -
          ∑ j,
            ((y j : H.presentedAugmentationSubmodule (rels := rels) (n - 1)) :
              H.presentedGroupAlgebra rels) *
              genDiff j ∈
        H.presentedAugmentationSubmodule (rels := rels) (n + 1)

/--
An abstract degree-one generation predicate for the augmentation ideal.

It says that every element of the augmentation ideal is, modulo `I²`, a finite
left combination of the chosen degree-one differences. This is the exact
degree-one input needed to generate all higher associated-graded pieces.
-/
def augmentationModuloSquare
    (R G ι : Type*) [CommRing R] [Group G] [Fintype ι]
    (genDiff : ι → MonoidAlgebra R G) : Prop :=
  ∀ x : MonoidAlgebra R G,
    x ∈ GShafar.augmentationIdeal R G →
      ∃ coeff : ι → MonoidAlgebra R G,
        x - ∑ i, genDiff i * coeff i ∈
          ((GShafar.augmentationIdeal R G) ^ (2 : ℕ) :
            Submodule (MonoidAlgebra R G) (MonoidAlgebra R G))

/--
The right-handed analogue of `augmentationModuloSquare`.

The chosen degree-one differences generate `I / I²` by right multiplication.
-/
def generatedModuloSquare
    (R G ι : Type*) [CommRing R] [Group G] [Fintype ι]
    (genDiff : ι → MonoidAlgebra R G) : Prop :=
  ∀ x : MonoidAlgebra R G,
    x ∈ GShafar.augmentationIdeal R G →
      ∃ coeff : ι → MonoidAlgebra R G,
        x - ∑ i, coeff i * genDiff i ∈
          ((GShafar.augmentationIdeal R G) ^ (2 : ℕ) :
            Submodule (MonoidAlgebra R G) (MonoidAlgebra R G))

/--
Spanning in the degree-one quotient `I / I²` gives explicit representatives
modulo `I²`.

This is a quotient-lifting statement: if the classes of the chosen differences
span `I / I²`, then every augmentation-ideal element can be rewritten modulo
`I²` as a finite left combination of those differences.
-/
theorem modulo_square_span
    (R G ι : Type*) [CommRing R] [Group G] [Fintype ι]
    (genDiff : ι → MonoidAlgebra R G)
    (hgen : ∀ i, genDiff i ∈ GShafar.augmentationIdeal R G)
    (hspan :
      Submodule.span R
        (Set.range fun i : ι =>
          augmentationDegreeMk R G (genDiff i) (hgen i)) =
        ⊤) :
    augmentationModuloSquare R G ι genDiff := by
  classical
  intro x hx
  let A := MonoidAlgebra R G
  let I : Ideal A := GShafar.augmentationIdeal R G
  let K : Submodule R (augmentationDegreeSubmodule R G) :=
    augmentationDegreeKernel R G
  let xI : augmentationDegreeSubmodule R G :=
    ⟨x, by
      change x ∈ (I ^ (1 : ℕ) : Submodule A A)
      rw [Submodule.pow_one]
      exact hx⟩
  let genI : ι → augmentationDegreeSubmodule R G :=
    fun i =>
      ⟨genDiff i, by
        change genDiff i ∈ (I ^ (1 : ℕ) : Submodule A A)
        rw [Submodule.pow_one]
        exact hgen i⟩
  have hxmem :
      augmentationDegreeMk R G x hx ∈
        Submodule.span R
          (Set.range fun i : ι =>
            augmentationDegreeMk R G (genDiff i) (hgen i)) := by
    rw [hspan]
    exact Submodule.mem_top
  rcases (Submodule.mem_span_range_iff_exists_fun
      (R := R)
      (v := fun i : ι =>
        augmentationDegreeMk R G (genDiff i) (hgen i))
      (x := augmentationDegreeMk R G x hx)).mp hxmem with
    ⟨c, hc⟩
  let coeff : ι → A := fun i => MonoidAlgebra.single (1 : G) (c i)
  refine ⟨coeff, ?_⟩
  have hc' :
      (∑ i, c i • K.mkQ (genI i)) = K.mkQ xI := by
    simpa [K, xI, genI, augmentationDegreeMk] using hc
  have hquot :
      K.mkQ (∑ i, c i • genI i) = K.mkQ xI := by
    calc
      K.mkQ (∑ i, c i • genI i)
          = ∑ i, K.mkQ (c i • genI i) := by
              exact map_sum K.mkQ (fun i => c i • genI i) Finset.univ
      _ = ∑ i, c i • K.mkQ (genI i) := by
              apply Finset.sum_congr rfl
              intro i _hi
              simp
      _ = K.mkQ xI := hc'
  have hker_sum :
      (∑ i, c i • genI i) - xI ∈ K :=
    (Submodule.Quotient.eq K).mp hquot
  have hker :
      xI - (∑ i, c i • genI i) ∈ K := by
    rw [← neg_sub]
    exact K.neg_mem hker_sum
  have hI2 :
      ((xI - (∑ i, c i • genI i) :
          augmentationDegreeSubmodule R G) : A) ∈
        (I ^ (2 : ℕ) : Submodule A A) := by
    simpa [K, I, augmentationDegreeKernel,
      augmentationSquareSubmodule] using hker
  have hterm : ∀ i, genDiff i * coeff i = c i • genDiff i := by
    intro i
    ext g
    dsimp [coeff]
    rw [MonoidAlgebra.mul_single_one_apply]
    rw [mul_comm]
  have hsum_underlying :
      (((∑ i, c i • genI i) :
          augmentationDegreeSubmodule R G) : A) =
        ∑ i, genDiff i * coeff i := by
    calc
      (((∑ i, c i • genI i) :
          augmentationDegreeSubmodule R G) : A)
          = ∑ i, c i • genDiff i := by
              simp [genI]
      _ = ∑ i, genDiff i * coeff i := by
              apply Finset.sum_congr rfl
              intro i _hi
              exact (hterm i).symm
  change x - ∑ i, genDiff i * coeff i ∈
    (I ^ (2 : ℕ) : Submodule A A)
  simpa [xI, hsum_underlying] using hI2

/--
Spanning in the degree-one quotient also gives right-handed representatives
modulo `I²`.
-/
theorem generated_modulo_square
    (R G ι : Type*) [CommRing R] [Group G] [Fintype ι]
    (genDiff : ι → MonoidAlgebra R G)
    (hgen : ∀ i, genDiff i ∈ GShafar.augmentationIdeal R G)
    (hspan :
      Submodule.span R
        (Set.range fun i : ι =>
          augmentationDegreeMk R G (genDiff i) (hgen i)) =
        ⊤) :
    generatedModuloSquare R G ι genDiff := by
  classical
  intro x hx
  let A := MonoidAlgebra R G
  let I : Ideal A := GShafar.augmentationIdeal R G
  let K : Submodule R (augmentationDegreeSubmodule R G) :=
    augmentationDegreeKernel R G
  let xI : augmentationDegreeSubmodule R G :=
    ⟨x, by
      change x ∈ (I ^ (1 : ℕ) : Submodule A A)
      rw [Submodule.pow_one]
      exact hx⟩
  let genI : ι → augmentationDegreeSubmodule R G :=
    fun i =>
      ⟨genDiff i, by
        change genDiff i ∈ (I ^ (1 : ℕ) : Submodule A A)
        rw [Submodule.pow_one]
        exact hgen i⟩
  have hxmem :
      augmentationDegreeMk R G x hx ∈
        Submodule.span R
          (Set.range fun i : ι =>
            augmentationDegreeMk R G (genDiff i) (hgen i)) := by
    rw [hspan]
    exact Submodule.mem_top
  rcases (Submodule.mem_span_range_iff_exists_fun
      (R := R)
      (v := fun i : ι =>
        augmentationDegreeMk R G (genDiff i) (hgen i))
      (x := augmentationDegreeMk R G x hx)).mp hxmem with
    ⟨c, hc⟩
  let coeff : ι → A := fun i => MonoidAlgebra.single (1 : G) (c i)
  refine ⟨coeff, ?_⟩
  have hc' :
      (∑ i, c i • K.mkQ (genI i)) = K.mkQ xI := by
    simpa [K, xI, genI, augmentationDegreeMk] using hc
  have hquot :
      K.mkQ (∑ i, c i • genI i) = K.mkQ xI := by
    calc
      K.mkQ (∑ i, c i • genI i)
          = ∑ i, K.mkQ (c i • genI i) := by
              exact map_sum K.mkQ (fun i => c i • genI i) Finset.univ
      _ = ∑ i, c i • K.mkQ (genI i) := by
              apply Finset.sum_congr rfl
              intro i _hi
              simp
      _ = K.mkQ xI := hc'
  have hker_sum :
      (∑ i, c i • genI i) - xI ∈ K :=
    (Submodule.Quotient.eq K).mp hquot
  have hker :
      xI - (∑ i, c i • genI i) ∈ K := by
    rw [← neg_sub]
    exact K.neg_mem hker_sum
  have hI2 :
      ((xI - (∑ i, c i • genI i) :
          augmentationDegreeSubmodule R G) : A) ∈
        (I ^ (2 : ℕ) : Submodule A A) := by
    simpa [K, I, augmentationDegreeKernel,
      augmentationSquareSubmodule] using hker
  have hterm : ∀ i, coeff i * genDiff i = c i • genDiff i := by
    intro i
    ext g
    dsimp [coeff]
    rw [MonoidAlgebra.single_mul_apply]
    simp
  have hsum_underlying :
      (((∑ i, c i • genI i) :
          augmentationDegreeSubmodule R G) : A) =
        ∑ i, coeff i * genDiff i := by
    calc
      (((∑ i, c i • genI i) :
          augmentationDegreeSubmodule R G) : A)
          = ∑ i, c i • genDiff i := by
              simp [genI]
      _ = ∑ i, coeff i * genDiff i := by
              apply Finset.sum_congr rfl
              intro i _hi
              exact (hterm i).symm
  change x - ∑ i, coeff i * genDiff i ∈
    (I ^ (2 : ℕ) : Submodule A A)
  simpa [xI, hsum_underlying] using hI2

/--
Degree-one generation modulo `I²` propagates to all positive augmentation
powers.

If `I / I²` is generated by the chosen degree-one differences, then
`I^n / I^(n+1)` is generated by multiplying those differences by `I^(n-1)`.
-/
theorem
    PPDatum.presented_gen_square
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (genDiff : Fin H.generatorRank → H.presentedGroupAlgebra rels)
    (hgen : ∀ j, genDiff j ∈ H.presentedAugmentationIdeal rels)
    (n : ℕ)
    (hn : 1 ≤ n)
    (hleft :
      augmentationModuloSquare
        (ZMod H.realizesFiniteNontrivial.p)
        (H.pGroup rels)
        (Fin H.generatorRank)
        genDiff) :
    H.presentedAugmentationGenerated
      (rels := rels) genDiff hgen n hn := by
  classical
  let A := H.presentedGroupAlgebra rels
  let I : Ideal A := H.presentedAugmentationIdeal rels
  haveI : I.IsTwoSided := by
    change (H.presentedAugmentationIdeal rels).IsTwoSided
    dsimp [PPDatum.presentedAugmentationIdeal,
      GShafar.augmentationIdeal]
    infer_instance
  intro x
  have hxmul : (x : A) ∈ I * I ^ (n - 1) := by
    have hxpow : (x : A) ∈ I ^ n := by
      simp [I, PPDatum.presentedAugmentationSubmodule]
    have hdegree : 1 + (n - 1) = n := by omega
    have hpow : I ^ n = I * I ^ (n - 1) := by
      calc
        I ^ n = I ^ (1 + (n - 1)) := by rw [hdegree]
        _ = I ^ 1 * I ^ (n - 1) := by rw [Ideal.IsTwoSided.pow_add]
        _ = I * I ^ (n - 1) := by rw [Submodule.pow_one]
    simpa [hpow] using hxpow
  let P : A → Prop := fun z =>
    ∃ y : Fin H.generatorRank →
        H.presentedAugmentationSubmodule (rels := rels) (n - 1),
      z - ∑ j, genDiff j *
        ((y j : H.presentedAugmentationSubmodule (rels := rels) (n - 1)) :
          A) ∈ I ^ (n + 1)
  have hxP : P (x : A) := by
    refine Submodule.mul_induction_on hxmul ?mul_mem ?add_mem
    · intro a ha b hb
      rcases hleft a (by simpa [I] using ha) with ⟨coeff, hcoeff⟩
      let y : Fin H.generatorRank →
          H.presentedAugmentationSubmodule (rels := rels) (n - 1) :=
        fun j => ⟨coeff j * b, (I ^ (n - 1)).mul_mem_left (coeff j) hb⟩
      refine ⟨y, ?_⟩
      have hsum_mul :
          (∑ j, genDiff j * coeff j) * b =
            ∑ j, genDiff j *
              ((y j :
                H.presentedAugmentationSubmodule (rels := rels) (n - 1)) :
                A) := by
        dsimp [y]
        rw [Finset.sum_mul]
        apply Finset.sum_congr rfl
        intro j _hj
        rw [mul_assoc]
      have herr_eq :
          a * b -
              ∑ j, genDiff j *
                ((y j :
                  H.presentedAugmentationSubmodule (rels := rels) (n - 1)) :
                  A) =
            (a - ∑ j, genDiff j * coeff j) * b := by
        rw [← hsum_mul]
        noncomm_ring
      rw [herr_eq]
      have herr_prod :
          (a - ∑ j, genDiff j * coeff j) * b ∈
          I ^ (2 : ℕ) * I ^ (n - 1) :=
        Ideal.mul_mem_mul (by simpa [I] using hcoeff) hb
      have hdegree : (2 : ℕ) + (n - 1) = n + 1 := by omega
      rw [← hdegree, Ideal.IsTwoSided.pow_add]
      exact herr_prod
    · intro u v hu hv
      rcases hu with ⟨yu, hyu⟩
      rcases hv with ⟨yv, hyv⟩
      let y : Fin H.generatorRank →
          H.presentedAugmentationSubmodule (rels := rels) (n - 1) :=
        fun j => yu j + yv j
      refine ⟨y, ?_⟩
      have hsum_add :
          ∑ j, genDiff j *
              ((y j :
                H.presentedAugmentationSubmodule (rels := rels) (n - 1)) :
                A) =
            (∑ j, genDiff j *
              ((yu j :
                H.presentedAugmentationSubmodule (rels := rels) (n - 1)) :
                A)) +
            (∑ j, genDiff j *
              ((yv j :
                H.presentedAugmentationSubmodule (rels := rels) (n - 1)) :
                A)) := by
        dsimp [y]
        simp [mul_add, Finset.sum_add_distrib]
      have herr_eq :
          u + v -
              ∑ j, genDiff j *
                ((y j :
                  H.presentedAugmentationSubmodule (rels := rels) (n - 1)) :
                  A) =
            (u -
              ∑ j, genDiff j *
                ((yu j :
                  H.presentedAugmentationSubmodule (rels := rels) (n - 1)) :
                  A)) +
            (v -
              ∑ j, genDiff j *
                ((yv j :
                  H.presentedAugmentationSubmodule (rels := rels) (n - 1)) :
                  A)) := by
        rw [hsum_add]
        noncomm_ring
      rw [herr_eq]
      exact (I ^ (n + 1)).add_mem hyu hyv
  simpa [P, I, PPDatum.presentedAugmentationSubmodule] using hxP

/--
Right-handed degree-one generation modulo `I²` propagates to all positive
augmentation powers.
-/
theorem
    PPDatum.presented_aug_square
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (genDiff : Fin H.generatorRank → H.presentedGroupAlgebra rels)
    (hgen : ∀ j, genDiff j ∈ H.presentedAugmentationIdeal rels)
    (n : ℕ)
    (hn : 1 ≤ n)
    (hright :
      generatedModuloSquare
        (ZMod H.realizesFiniteNontrivial.p)
        (H.pGroup rels)
        (Fin H.generatorRank)
        genDiff) :
    H.presentedGeneratedDegree
      (rels := rels) genDiff hgen n hn := by
  classical
  let A := H.presentedGroupAlgebra rels
  let I : Ideal A := H.presentedAugmentationIdeal rels
  haveI : I.IsTwoSided := by
    change (H.presentedAugmentationIdeal rels).IsTwoSided
    dsimp [PPDatum.presentedAugmentationIdeal,
      GShafar.augmentationIdeal]
    infer_instance
  intro x
  have hxmul : (x : A) ∈ I ^ (n - 1) * I := by
    have hxpow : (x : A) ∈ I ^ n := by
      simp [I, PPDatum.presentedAugmentationSubmodule]
    have hdegree : (n - 1) + 1 = n := by omega
    have hpow : I ^ n = I ^ (n - 1) * I := by
      calc
        I ^ n = I ^ ((n - 1) + 1) := by rw [hdegree]
        _ = I ^ (n - 1) * I ^ 1 := by rw [Ideal.IsTwoSided.pow_add]
        _ = I ^ (n - 1) * I := by rw [Submodule.pow_one]
    simpa [hpow] using hxpow
  let P : A → Prop := fun z =>
    ∃ y : Fin H.generatorRank →
        H.presentedAugmentationSubmodule (rels := rels) (n - 1),
      z - ∑ j,
        ((y j : H.presentedAugmentationSubmodule (rels := rels) (n - 1)) :
          A) * genDiff j ∈ I ^ (n + 1)
  have hxP : P (x : A) := by
    refine Submodule.mul_induction_on hxmul ?mul_mem ?add_mem
    · intro a ha b hb
      rcases hright b (by simpa [I] using hb) with ⟨coeff, hcoeff⟩
      let y : Fin H.generatorRank →
          H.presentedAugmentationSubmodule (rels := rels) (n - 1) :=
        fun j => ⟨a * coeff j, (I ^ (n - 1)).mul_mem_right (coeff j) ha⟩
      refine ⟨y, ?_⟩
      have hmul_sum :
          a * (∑ j, coeff j * genDiff j) =
            ∑ j,
              ((y j :
                H.presentedAugmentationSubmodule (rels := rels) (n - 1)) :
                A) * genDiff j := by
        dsimp [y]
        rw [Finset.mul_sum]
        apply Finset.sum_congr rfl
        intro j _hj
        rw [mul_assoc]
      have herr_eq :
          a * b -
              ∑ j,
                ((y j :
                  H.presentedAugmentationSubmodule (rels := rels) (n - 1)) :
                  A) * genDiff j =
            a * (b - ∑ j, coeff j * genDiff j) := by
        rw [← hmul_sum]
        noncomm_ring
      rw [herr_eq]
      have herr_prod :
          a * (b - ∑ j, coeff j * genDiff j) ∈
            I ^ (n - 1) * I ^ (2 : ℕ) :=
        Ideal.mul_mem_mul ha (by simpa [I] using hcoeff)
      have hdegree : (n - 1) + (2 : ℕ) = n + 1 := by omega
      rw [← hdegree, Ideal.IsTwoSided.pow_add]
      exact herr_prod
    · intro u v hu hv
      rcases hu with ⟨yu, hyu⟩
      rcases hv with ⟨yv, hyv⟩
      let y : Fin H.generatorRank →
          H.presentedAugmentationSubmodule (rels := rels) (n - 1) :=
        fun j => yu j + yv j
      refine ⟨y, ?_⟩
      have hsum_add :
          ∑ j,
              ((y j :
                H.presentedAugmentationSubmodule (rels := rels) (n - 1)) :
                A) * genDiff j =
            (∑ j,
              ((yu j :
                H.presentedAugmentationSubmodule (rels := rels) (n - 1)) :
                A) * genDiff j) +
            (∑ j,
              ((yv j :
                H.presentedAugmentationSubmodule (rels := rels) (n - 1)) :
                A) * genDiff j) := by
        dsimp [y]
        simp [add_mul, Finset.sum_add_distrib]
      have herr_eq :
          u + v -
              ∑ j,
                ((y j :
                  H.presentedAugmentationSubmodule (rels := rels) (n - 1)) :
                  A) * genDiff j =
            (u -
              ∑ j,
                ((yu j :
                  H.presentedAugmentationSubmodule (rels := rels) (n - 1)) :
                  A) * genDiff j) +
            (v -
              ∑ j,
                ((yv j :
                  H.presentedAugmentationSubmodule (rels := rels) (n - 1)) :
                  A) * genDiff j) := by
        rw [hsum_add]
        noncomm_ring
      rw [herr_eq]
      exact (I ^ (n + 1)).add_mem hyu hyv
  simpa [P, I, PPDatum.presentedAugmentationSubmodule] using hxP

/-- The augmentation difference attached to a presentation generator. -/
noncomputable def PPDatum.presentedGeneratorDifference
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (j : Fin H.generatorRank) :
    H.presentedGroupAlgebra rels :=
  augmentationDifference
    (ZMod H.realizesFiniteNontrivial.p)
    (H.pGroup rels)
    (PresentedGroup.of (rels := Set.range rels) j)

/--
The group-algebra map induced by the quotient from the free group to the
presented group.
-/
noncomputable def PPDatum.presentedFreeAlgebra
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)} :
    MonoidAlgebra (ZMod H.realizesFiniteNontrivial.p)
        (FreeGroup (Fin H.generatorRank)) →+*
      H.presentedGroupAlgebra rels :=
  MonoidAlgebra.mapDomainRingHom
    (ZMod H.realizesFiniteNontrivial.p)
    (PresentedGroup.mk (Set.range rels))

/-- The quotient map sends free-group augmentation differences to presented ones. -/
lemma PPDatum.presented_free_difference
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (g : FreeGroup (Fin H.generatorRank)) :
    H.presentedFreeAlgebra (rels := rels)
        (augmentationDifference
          (ZMod H.realizesFiniteNontrivial.p)
          (FreeGroup (Fin H.generatorRank))
          g) =
      augmentationDifference
        (ZMod H.realizesFiniteNontrivial.p)
        (H.pGroup rels)
        (PresentedGroup.mk (Set.range rels) g) := by
  simpa [PPDatum.presentedFreeAlgebra] using
    domain_ring_difference
      (ZMod H.realizesFiniteNontrivial.p)
      (FreeGroup (Fin H.generatorRank))
      (H.pGroup rels)
      (PresentedGroup.mk (Set.range rels))
      g

/--
The quotient map sends the free generator difference `x_j - 1` to the presented
generator difference.
-/
lemma PPDatum.presented_algebra_difference
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (j : Fin H.generatorRank) :
    H.presentedFreeAlgebra (rels := rels)
        (augmentationDifference
          (ZMod H.realizesFiniteNontrivial.p)
          (FreeGroup (Fin H.generatorRank))
          (FreeGroup.of j)) =
      H.presentedGeneratorDifference (rels := rels) j := by
  simpa [PPDatum.presentedGeneratorDifference, PresentedGroup.of] using
    H.presented_free_difference
      (rels := rels)
      (FreeGroup.of j)

/-- A defining relator has zero augmentation difference in the presented algebra. -/
lemma PPDatum.presented_difference_zero
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (i : Fin H.relationRank) :
    H.presentedFreeAlgebra (rels := rels)
        (augmentationDifference
          (ZMod H.realizesFiniteNontrivial.p)
          (FreeGroup (Fin H.generatorRank))
          (rels i)) =
      0 := by
  rw [H.presented_free_difference (rels := rels) (rels i)]
  have hrel :
      PresentedGroup.mk (Set.range rels) (rels i) = 1 :=
    PresentedGroup.one_of_mem (rels := Set.range rels) ⟨i, rfl⟩
  simp [hrel, augmentationDifference, MonoidAlgebra.one_def]

/--
The Fox identity for a defining relator after passing to the presented group
algebra.

This is the numerator-level syzygy behind the relator-to-generator map:
the pushed-forward Fox derivatives of a relator multiply the presentation
generator differences to zero.
-/
theorem PPDatum.presented_relator_syzygy
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (i : Fin H.relationRank) :
    ∑ j,
        H.presentedFreeAlgebra (rels := rels)
          (groupFoxDerivative
            (ZMod H.realizesFiniteNontrivial.p)
            j
            (rels i)) *
          H.presentedGeneratorDifference (rels := rels) j =
      0 := by
  classical
  let R := ZMod H.realizesFiniteNontrivial.p
  let F := FreeGroup (Fin H.generatorRank)
  let A := H.presentedGroupAlgebra rels
  let q : MonoidAlgebra R F →+* A :=
    H.presentedFreeAlgebra (rels := rels)
  have hmap_sum :
      q (∑ j,
          groupFoxDerivative R j (rels i) *
            augmentationDifference R F (FreeGroup.of j)) =
        ∑ j,
          q (groupFoxDerivative R j (rels i)) *
            H.presentedGeneratorDifference (rels := rels) j := by
    rw [map_sum]
    apply Finset.sum_congr rfl
    intro j _hj
    rw [map_mul]
    rw [PPDatum.presented_algebra_difference]
  have hfox :
      augmentationDifference R F (rels i) =
        ∑ j,
          groupFoxDerivative R j (rels i) *
            augmentationDifference R F (FreeGroup.of j) :=
    free_derivative_fundamental R (rels i)
  calc
    ∑ j,
        H.presentedFreeAlgebra (rels := rels)
          (groupFoxDerivative
            (ZMod H.realizesFiniteNontrivial.p)
            j
            (rels i)) *
          H.presentedGeneratorDifference (rels := rels) j
        = q (∑ j,
            groupFoxDerivative R j (rels i) *
              augmentationDifference R F (FreeGroup.of j)) := by
          simpa [R, F, A, q] using hmap_sum.symm
    _ = q (augmentationDifference R F (rels i)) := by
          rw [← hfox]
    _ = 0 := by
          simpa [R, F, A, q] using
            H.presented_difference_zero
              (rels := rels)
              i

/-- The pushed-forward Fox coefficient of a presentation relator. -/
noncomputable def PPDatum.presentedFoxCoefficient
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (i : Fin H.relationRank)
    (j : Fin H.generatorRank) :
    H.presentedGroupAlgebra rels :=
  H.presentedFreeAlgebra (rels := rels)
    (groupFoxDerivative
      (ZMod H.realizesFiniteNontrivial.p)
      j
      (rels i))

/--
The Fox syzygy remains zero after multiplying on the left by any presented
group-algebra element.

This is the numerator identity compatible with the right-oriented associated
graded maps: a shifted class `y` first multiplies by each Fox coefficient and
then by the corresponding generator difference.
-/
theorem PPDatum.presented_fox_syzygy
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    (i : Fin H.relationRank)
    (y : H.presentedGroupAlgebra rels) :
    ∑ j,
        (y * H.presentedFoxCoefficient (rels := rels) i j) *
          H.presentedGeneratorDifference (rels := rels) j =
      0 := by
  classical
  have hsyzygy :=
    H.presented_relator_syzygy (rels := rels) i
  have hsyzygy' :
      (∑ j,
        H.presentedFoxCoefficient (rels := rels) i j *
          H.presentedGeneratorDifference (rels := rels) j) = 0 := by
    simpa [PPDatum.presentedFoxCoefficient] using hsyzygy
  calc
    ∑ j,
        (y * H.presentedFoxCoefficient (rels := rels) i j) *
          H.presentedGeneratorDifference (rels := rels) j
        =
        ∑ j,
          y *
            (H.presentedFoxCoefficient (rels := rels) i j *
              H.presentedGeneratorDifference (rels := rels) j) := by
          apply Finset.sum_congr rfl
          intro j _hj
          rw [mul_assoc]
    _ =
        y *
          (∑ j,
            H.presentedFoxCoefficient (rels := rels) i j *
              H.presentedGeneratorDifference (rels := rels) j) := by
          rw [Finset.mul_sum]
    _ = 0 := by
          rw [hsyzygy', mul_zero]

/--
Fox derivatives lower Zassenhaus degree by one, after passing from the free
group algebra to the presented group algebra.

This is the filtration-theoretic input needed to make the relator map land in
the shifted associated-graded generator source.  Mathematically it is the
standard estimate `r ∈ D_q(F) → ∂r/∂x_j ∈ I^(q-1)` for the Zassenhaus
filtration, followed by functoriality of the augmentation filtration under the
quotient map `F → F/(rels)`.
-/
theorem PPDatum.presented_relator_fox
    (H : PPDatum)
    {rels : Fin H.relationRank → FreeGroup (Fin H.generatorRank)}
    {depth : Fin H.relationRank → ℕ}
    (hmem : ∀ i, rels i ∈ H.relatorZassenhausFiltration (depth i))
    (hdepth : ∀ i, 2 ≤ depth i)
    (i : Fin H.relationRank)
    (j : Fin H.generatorRank) :
    H.presentedFoxCoefficient (rels := rels) i j ∈
      (H.presentedAugmentationIdeal rels) ^ (depth i - 1) := by
  let p := H.realizesFiniteNontrivial.p
  let F := FreeGroup (Fin H.generatorRank)
  let q : F →* H.pGroup rels :=
    PresentedGroup.mk (Set.range rels)
  have hfree :
      groupFoxDerivative (ZMod p) j (rels i) ∈
        (GShafar.augmentationIdeal (ZMod p) F) ^ (depth i - 1) := by
    exact
      fox_derivative_zassenhaus
        (p := p)
        (ι := Fin H.generatorRank)
        (n := depth i)
        (g := rels i)
        (hmem i)
        (hdepth i)
        j
  have hmap :
      MonoidAlgebra.mapDomainRingHom (ZMod p) q
          (groupFoxDerivative (ZMod p) j (rels i)) ∈
        (GShafar.augmentationIdeal (ZMod p) (H.pGroup rels)) ^
          (depth i - 1) := by
    exact
      domain_ring_pow
        (ZMod p)
        F
        (H.pGroup rels)
        q
        hfree
  simpa [PPDatum.presentedFoxCoefficient,
    PPDatum.presentedFreeAlgebra,
    PPDatum.presentedAugmentationIdeal, p, F, q] using hmap


end Towers
