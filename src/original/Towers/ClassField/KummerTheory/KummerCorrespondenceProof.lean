import Towers.ClassField.KummerTheory.KummerPairing
import Towers.ClassField.KummerTheory.KummerPerfectPairing
import Towers.ClassField.KummerTheory.KummerRootInclusion

/-!
# The full Kummer correspondence

This file completes Theorem VII.A.3.  The perfect Kummer pairing identifies
the radical power classes of an abelian exponent-`n` extension with the
character group of its Galois group.  The resulting exact cardinality,
together with the sharp character bound for a field generated by radicals,
upgrades the two evident inclusions to the two reconstruction equalities.
-/

namespace Towers.CField.KTheory

noncomputable section

universe u

variable (K Omega : Type u) [Field K] [Field Omega] [Algebra K Omega]
  [IsAlgClosure K Omega]

namespace PCSubgro

/-- The concrete `card` in the statement of Theorem A.3 agrees with the
type-theoretic cardinality of the subgroup. -/
theorem card_eq_card {n : Nat} (B : PCSubgro K n) :
    B.card = Nat.card B.carrier := by
  letI : Fintype B.carrier := B.finite_carrier.fintype
  rw [Nat.card_eq_fintype_card]
  exact B.finite_carrier.card_toFinset

/-- Two finite power-class subgroup objects are equal as soon as their
underlying subgroups are equal; their finiteness witnesses carry no data. -/
theorem ext_carrier {n : Nat} {B C : PCSubgro K n}
    (h : B.carrier = C.carrier) : B = C := by
  cases B
  cases C
  cases h
  rfl

end PCSubgro

namespace AESubext

omit [IsAlgClosure K Omega] in
/-- Two extension objects are equal as soon as their concrete intermediate
fields are equal; all remaining fields of the structure are propositions. -/
theorem ext_carrier {n : Nat}
    {L M : AESubext K Omega n}
    (h : L.carrier = M.carrier) : L = M := by
  cases L
  cases M
  cases h
  rfl

end AESubext

variable {K Omega}

/-- The forward object in Kummer correspondence: the finite radical
power-class subgroup of an abelian exponent-`n` extension. -/
def radicalSubgroup (n : Nat) (hn : 0 < n)
    (hroots : (primitiveRoots n K).Nonempty)
    (L : AESubext K Omega n) :
    PCSubgro K n where
  carrier := radicalPowerClasses K Omega n L.carrier
  finite_carrier := radical_classes_finite K Omega n L hn hroots

omit [IsAlgClosure K Omega] in
@[simp]
theorem radicalSubgroup_carrier (n : Nat) (hn : 0 < n)
    (hroots : (primitiveRoots n K).Nonempty)
    (L : AESubext K Omega n) :
    (radicalSubgroup n hn hroots L).carrier =
      radicalPowerClasses K Omega n L.carrier :=
  rfl

/-- Exact reconstruction on the subgroup side.  The easy inclusion
`B <= Rad(K[B^(1/n)])` and the two independent character-duality bounds
force equality. -/
theorem radical_classes_field
    (n : Nat) (hn : 0 < n)
    (hroots : (primitiveRoots n K).Nonempty)
    (B : PCSubgro K n) :
    radicalPowerClasses K Omega n (kummerField K Omega n hn B) = B.carrier := by
  let zeta : K := hroots.choose
  have hzeta : IsPrimitiveRoot zeta n :=
    (mem_primitiveRoots hn).mp hroots.choose_spec
  let E : AESubext K Omega n :=
    kummerFieldSubextension K Omega n hn hzeta B
  have hfinite : Set.Finite
      ((radicalPowerClasses K Omega n E.carrier :
        Subgroup (PowerClassGroup K n)) : Set (PowerClassGroup K n)) :=
    radical_classes_finite K Omega n E hn hroots
  letI : Fintype (radicalPowerClasses K Omega n E.carrier) := hfinite.fintype
  letI : Fintype B.carrier := B.finite_carrier.fintype
  have hcard : Nat.card (radicalPowerClasses K Omega n E.carrier) <=
      Nat.card B.carrier := by
    calc
      Nat.card (radicalPowerClasses K Omega n E.carrier) =
          Module.finrank K E.carrier :=
        radical_classes_finrank K Omega n E hn hroots
      _ = Module.finrank K (kummerField K Omega n hn B) := rfl
      _ <= B.card := kummer_field_card K Omega n hn hroots B
      _ = Nat.card B.carrier := PCSubgro.card_eq_card K B
  have heq : B.carrier = radicalPowerClasses K Omega n E.carrier :=
    Subgroup.eq_of_le_of_card_ge
      (radical_classes_kummer K Omega n hn B) hcard
  exact heq.symm

/-- The radical extension attached to `B` has degree exactly `|B|`. -/
theorem finrank_kummer_field
    (n : Nat) (hn : 0 < n)
    (hroots : (primitiveRoots n K).Nonempty)
    (B : PCSubgro K n) :
    Module.finrank K (kummerField K Omega n hn B) = B.card := by
  let zeta : K := hroots.choose
  have hzeta : IsPrimitiveRoot zeta n :=
    (mem_primitiveRoots hn).mp hroots.choose_spec
  let E : AESubext K Omega n :=
    kummerFieldSubextension K Omega n hn hzeta B
  calc
    Module.finrank K (kummerField K Omega n hn B) =
        Module.finrank K E.carrier := rfl
    _ = Nat.card (radicalPowerClasses K Omega n E.carrier) :=
      (radical_classes_finrank K Omega n E hn hroots).symm
    _ = Nat.card B.carrier := by
      rw [show radicalPowerClasses K Omega n E.carrier = B.carrier by
        exact radical_classes_field (K := K) (Omega := Omega) n hn hroots B]
    _ = B.card := (PCSubgro.card_eq_card K B).symm

/-- Exact reconstruction on the extension side.  Radical generation gives
one inclusion.  Perfectness of the pairing and exact subgroup-side degree
give equality of degrees, so the intermediate fields coincide. -/
theorem kummer_radical_subgroup
    (n : Nat) (hn : 0 < n)
    (hroots : (primitiveRoots n K).Nonempty)
    (L : AESubext K Omega n) :
    kummerField K Omega n hn (radicalSubgroup n hn hroots L) = L.carrier := by
  let zeta : K := hroots.choose
  have hzeta : IsPrimitiveRoot zeta n :=
    (mem_primitiveRoots hn).mp hroots.choose_spec
  have hle : kummerField K Omega n hn (radicalSubgroup n hn hroots L) <=
      L.carrier := by
    apply field_radical_classes
      K Omega n hn hzeta L.carrier (radicalSubgroup n hn hroots L)
    intro b hb
    exact hb
  apply IntermediateField.eq_of_le_of_finrank_eq hle
  calc
    Module.finrank K
        (kummerField K Omega n hn (radicalSubgroup n hn hroots L)) =
        (radicalSubgroup n hn hroots L).card :=
      finrank_kummer_field (K := K) (Omega := Omega) n hn hroots
        (radicalSubgroup n hn hroots L)
    _ = Nat.card (radicalPowerClasses K Omega n L.carrier) :=
      PCSubgro.card_eq_card K
        (radicalSubgroup n hn hroots L)
    _ = Module.finrank K L.carrier :=
      radical_classes_finrank K Omega n L hn hroots

/-- The radical subgroup and radical-generation constructions are inverse
equivalences on the concrete objects occurring in Theorem A.3. -/
def kummerCorrespondenceEquiv
    (n : Nat) (hn : 0 < n)
    (hroots : (primitiveRoots n K).Nonempty) :
    AESubext K Omega n ≃
      PCSubgro K n := by
  let zeta : K := hroots.choose
  have hzeta : IsPrimitiveRoot zeta n :=
    (mem_primitiveRoots hn).mp hroots.choose_spec
  refine
    { toFun := radicalSubgroup n hn hroots
      invFun := kummerFieldSubextension K Omega n hn hzeta
      left_inv := ?_
      right_inv := ?_ }
  · intro L
    apply AESubext.ext_carrier K Omega
    exact kummer_radical_subgroup (K := K) (Omega := Omega) n hn hroots L
  · intro B
    apply PCSubgro.ext_carrier K
    exact radical_classes_field (K := K) (Omega := Omega) n hn hroots B

/-- A complete proof of Theorem VII.A.3: finite abelian exponent-`n`
subextensions of a fixed algebraic closure correspond to finite subgroups
of `K^x / K^{x n}`, with the stated concrete maps and exact degree formula. -/
theorem kummerCorrespondence
    (n : Nat) : KummerCorrespondence K Omega n := by
  intro hn hroots
  let e := kummerCorrespondenceEquiv (K := K) (Omega := Omega) n hn hroots
  refine ⟨e, ?_⟩
  refine And.intro ?_ (And.intro ?_ ?_)
  · intro L
    rfl
  · intro B
    rfl
  · intro L
    calc
      Module.finrank K L.carrier =
          Nat.card (radicalPowerClasses K Omega n L.carrier) :=
        (radical_classes_finrank K Omega n L hn hroots).symm
      _ = (e L).card := by
        symm
        exact PCSubgro.card_eq_card K (e L)

end

end Towers.CField.KTheory
