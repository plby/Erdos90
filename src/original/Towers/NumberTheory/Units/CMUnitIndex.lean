import Mathlib.NumberTheory.NumberField.CMField


/-!
# Milne, Algebraic Number Theory, Proposition 5.12

For a CM field, the subgroup generated by roots of unity and units of the maximal real
subfield has index one or two in the full unit group.
-/

namespace Towers.NumberTheory.Milne

open NumberField NumberField.Units
open scoped NumberField

variable (K : Type*) [Field K] [NumberField K] [NumberField.IsCMField K]

/-- A CM field and its maximal real subfield have the same unit rank. -/
theorem cm_real_subfield :
    NumberField.Units.rank K =
      NumberField.Units.rank (NumberField.maximalRealSubfield K) :=
  (NumberField.IsCMField.units_rank_eq_units_rank K).symm

/-- The units of the maximal real subfield have finite index in the units of a CM field. -/
theorem cm_real_index :
    (NumberField.IsCMField.realUnits K).FiniteIndex := by
  rw [NumberField.Units.finiteIndex_iff_sup_torsion_finiteIndex,
    Subgroup.finiteIndex_iff]
  rcases NumberField.IsCMField.indexRealUnits_eq_one_or_two K with h | h
  · rw [show (NumberField.IsCMField.realUnits K ⊔ NumberField.Units.torsion K).index = 1
        from h]
    exact one_ne_zero
  · rw [show (NumberField.IsCMField.realUnits K ⊔ NumberField.Units.torsion K).index = 2
        from h]
    norm_num

/-- **Milne, Proposition 5.12.** The index of the subgroup generated by the roots of unity
of `K` and the units coming from its maximal real subfield is either one or two. -/
theorem cm_sup_or :
    NumberField.IsCMField.indexRealUnits K = 1 ∨
      NumberField.IsCMField.indexRealUnits K = 2 :=
  NumberField.IsCMField.indexRealUnits_eq_one_or_two K

omit [NumberField K] [IsCMField K] in
/-- The subgroup occurring in Proposition 5.12 is precisely the join of the image of the
real-subfield unit group and the torsion subgroup. -/
theorem cm_sup_torsion :
    (NumberField.IsCMField.realUnits K ⊔ NumberField.Units.torsion K).index =
      NumberField.IsCMField.indexRealUnits K := rfl

end Towers.NumberTheory.Milne
