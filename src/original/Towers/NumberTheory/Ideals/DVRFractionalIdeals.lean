import Towers.NumberTheory.Ideals.FractionalFreeAbelian


/-!
# Milne, Algebraic Number Theory, Example 3.19

The nonzero fractional ideals of a discrete valuation ring form an infinite cyclic group,
generated by its maximal ideal.
-/

namespace Towers.NumberTheory.Milne

open scoped nonZeroDivisors

open IsDedekindDomain

variable (A K : Type*) [CommRing A] [IsDomain A] [IsDiscreteValuationRing A]
  [Field K] [Algebra A K] [IsFractionRing A K]

@[reducible] private noncomputable def dvrHeightSpectrum :
    Unique (HeightOneSpectrum A) :=
  Equiv.unique
    (HeightOneSpectrum.equivMaximalSpectrum
      (IsDiscreteValuationRing.not_isField A))

/-- Example 3.19: the group of nonzero fractional ideals of a DVR is isomorphic to the
additive group `ℤ`, written multiplicatively. -/
noncomputable def dvrFractionalIdeal :
    Multiplicative ℤ ≃* (FractionalIdeal A⁰ K)ˣ := by
  letI : Unique (HeightOneSpectrum A) := dvrHeightSpectrum A
  exact
    ((Finsupp.uniqueAddEquiv (IsDiscreteValuationRing.maximalIdeal A)).symm.toMultiplicative).trans
      (fractionalIdealFactorization A K)

/-- Under the equivalence of Example 3.19, `n` is sent to the `n`th power of the maximal
ideal. -/
theorem dvr_fractional_ideal (n : ℤ) :
    ((dvrFractionalIdeal A K (Multiplicative.ofAdd n)) : FractionalIdeal A⁰ K) =
      ((IsDiscreteValuationRing.maximalIdeal A).asIdeal : FractionalIdeal A⁰ K) ^ n := by
  letI : Unique (HeightOneSpectrum A) := dvrHeightSpectrum A
  change
    ((fractionalIdealFactorization A K
      (Multiplicative.ofAdd ((Finsupp.uniqueAddEquiv
        (IsDiscreteValuationRing.maximalIdeal A)).symm n))) : FractionalIdeal A⁰ K) = _
  rw [show (Finsupp.uniqueAddEquiv
      (IsDiscreteValuationRing.maximalIdeal A)).symm n =
      Finsupp.single (IsDiscreteValuationRing.maximalIdeal A) n by
        apply Finsupp.ext
        intro v
        rw [Unique.eq_default v, Unique.eq_default (IsDiscreteValuationRing.maximalIdeal A)]
        simp]
  exact fractional_ideal_single A K
    (IsDiscreteValuationRing.maximalIdeal A) n

/-- If `π` is a prime element, the `n`th fractional power of the maximal ideal is the
principal fractional ideal generated by `π ^ n`, for every integer `n`. -/
theorem dvr_zpow_singleton
    {π : A} (hπ : Irreducible π) (n : ℤ) :
    ((IsDiscreteValuationRing.maximalIdeal A).asIdeal :
        FractionalIdeal A⁰ K) ^ n =
      FractionalIdeal.spanSingleton A⁰ ((algebraMap A K π) ^ n) := by
  change ((IsLocalRing.maximalIdeal A : Ideal A) : FractionalIdeal A⁰ K) ^ n = _
  rw [hπ.maximalIdeal_eq, FractionalIdeal.coeIdeal_span_singleton]
  cases n <;>
    simp [FractionalIdeal.spanSingleton_pow, FractionalIdeal.spanSingleton_inv]

/-- The elementwise uniqueness assertion in Example 3.19: every nonzero fractional ideal
of a DVR is a unique integral power of its maximal ideal. -/
theorem dvr_fractional_unique
    (I : FractionalIdeal A⁰ K) (hI : I ≠ 0) :
    ∃! n : ℤ,
      I = ((IsDiscreteValuationRing.maximalIdeal A).asIdeal :
        FractionalIdeal A⁰ K) ^ n := by
  let U : (FractionalIdeal A⁰ K)ˣ := Units.mk0 I hI
  let n : ℤ := ((dvrFractionalIdeal A K).symm U).toAdd
  have hn : I = ((IsDiscreteValuationRing.maximalIdeal A).asIdeal :
      FractionalIdeal A⁰ K) ^ n := by
    calc
      I = ((dvrFractionalIdeal A K
          (Multiplicative.ofAdd n)) : FractionalIdeal A⁰ K) := by
            simp [n, U]
      _ = ((IsDiscreteValuationRing.maximalIdeal A).asIdeal :
          FractionalIdeal A⁰ K) ^ n := dvr_fractional_ideal A K n
  refine ⟨n, hn, ?_⟩
  intro m hm
  apply Multiplicative.toAdd.injective
  apply (dvrFractionalIdeal A K).injective
  apply Units.ext
  calc
    ((dvrFractionalIdeal A K (Multiplicative.ofAdd m)) :
        FractionalIdeal A⁰ K) =
        ((IsDiscreteValuationRing.maximalIdeal A).asIdeal :
          FractionalIdeal A⁰ K) ^ m := dvr_fractional_ideal A K m
    _ = I := hm.symm
    _ = ((IsDiscreteValuationRing.maximalIdeal A).asIdeal :
          FractionalIdeal A⁰ K) ^ n := hn
    _ = ((dvrFractionalIdeal A K (Multiplicative.ofAdd n)) :
        FractionalIdeal A⁰ K) := (dvr_fractional_ideal A K n).symm

/-- The element normal form in Example 3.19: after fixing a prime element `π`, every
nonzero element of the fraction field is uniquely a unit of the DVR times an integral power
of `π`. -/
theorem dvr_zpow_unique
    {π : A} (hπ : Irreducible π) {x : K} (hx : x ≠ 0) :
    ∃ m : ℤ, ∃ u : Aˣ,
      x = algebraMap A K (u : A) * (algebraMap A K π) ^ m ∧
        ∀ (m' : ℤ) (u' : Aˣ),
          x = algebraMap A K (u' : A) * (algebraMap A K π) ^ m' →
            m' = m ∧ u' = u := by
  let I : FractionalIdeal A⁰ K := FractionalIdeal.spanSingleton A⁰ x
  have hI : I ≠ 0 := FractionalIdeal.spanSingleton_ne_zero_iff.mpr hx
  obtain ⟨m, hm, hmunique⟩ :=
    dvr_fractional_unique A K I hI
  have hspan : FractionalIdeal.spanSingleton A⁰ x =
      FractionalIdeal.spanSingleton A⁰ ((algebraMap A K π) ^ m) :=
    hm.trans (dvr_zpow_singleton A K hπ m)
  obtain ⟨v, hv⟩ := FractionalIdeal.spanSingleton_eq_spanSingleton.mp hspan
  have hv' : algebraMap A K (v : A) * x = (algebraMap A K π) ^ m := by
    simpa only [Units.smul_def, Algebra.smul_def] using hv
  let u : Aˣ := v⁻¹
  have hnormal : x = algebraMap A K (u : A) * (algebraMap A K π) ^ m := by
    rw [← hv']
    simp [u]
  refine ⟨m, u, hnormal, ?_⟩
  intro m' u' hnormal'
  have hspan' : I =
      ((IsDiscreteValuationRing.maximalIdeal A).asIdeal :
        FractionalIdeal A⁰ K) ^ m' := by
    change FractionalIdeal.spanSingleton A⁰ x = _
    rw [dvr_zpow_singleton A K hπ m']
    apply FractionalIdeal.spanSingleton_eq_spanSingleton.mpr
    refine ⟨u'⁻¹, ?_⟩
    rw [hnormal']
    simp [Units.smul_def, Algebra.smul_def]
  have hm' : m' = m := hmunique m' hspan'
  subst m'
  refine ⟨rfl, ?_⟩
  apply Units.ext
  apply IsFractionRing.injective A K
  apply mul_right_cancel₀ (zpow_ne_zero m
    ((map_ne_zero_iff (algebraMap A K) (IsFractionRing.injective A K)).mpr hπ.ne_zero))
  exact hnormal'.symm.trans hnormal

end Towers.NumberTheory.Milne
