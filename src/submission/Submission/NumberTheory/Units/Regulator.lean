import Mathlib.NumberTheory.NumberField.Units.Regulator

/-!
# Milne, Algebraic Number Theory, regulators

The regulator is the covolume of the logarithmic unit lattice.  These statements record
Milne's determinant description and his formula measuring the index generated by a family
of independent units.
-/

namespace Submission.NumberTheory.Milne

open NumberField NumberField.InfinitePlace NumberField.Units
open scoped NumberField

variable (K : Type*) [Field K] [NumberField K]

/-- The regulator is computed from any fixed fundamental system of units. -/
theorem regulator_fundamental_reg :
    regulator K = regOfFamily (fundSystem K) :=
  regulator_eq_regOfFamily_fundSystem K

/-- The regulator of a number field is positive. -/
theorem regulator_pos : 0 < regulator K :=
  NumberField.Units.regulator_pos K

open scoped Classical in
/-- Milne's determinant formula, after omitting one infinite place. -/
theorem regulator_abs_det
    (w' : InfinitePlace K) (e : {w // w ≠ w'} ≃ Fin (rank K)) :
    regulator K =
      |(Matrix.of fun i w : {w // w ≠ w'} ↦ (mult w.val : ℝ) *
        Real.log (w.val (fundSystem K (e i) : K))).det| :=
  NumberField.Units.regulator_eq_det K w' e

/-- The regulator ratio of a full-rank family of units is the index of the subgroup it
generates together with the roots of unity. -/
theorem regulator_ratio_generated
    (u : Fin (rank K) → (𝓞 K)ˣ) :
    regOfFamily u / regulator K =
      (Subgroup.closure (Set.range u) ⊔ torsion K).index :=
  regOfFamily_div_regulator u

end Submission.NumberTheory.Milne
