-- Merged from JacobiIntegralPowerStrictTailCutoffOrderedOuterPacketBoundedDepthActiveSourceWeightPo
-- lynomial.lean

/-!
# Weight-sensitive polynomial bounds for bounded depth schedules

An active depth word contributes to a requested transition subword by choosing
a nonempty subsequence from the transition packet emitted at every active
depth.  A depth-`r` Hall-Witt correction packet contains only carried words of
weight at least `r + 1`.  Therefore the total depth-word grade of an active
source is bounded by the sum of the carried weights of the requested
transitions.

This file turns that packet-level observation into retained- and
crossing-schedule polynomial bounds.  Unlike the cutoff-wide bounds, these
bounds scale with the requested transition subword.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace DASrc

open CWTrace
open WSTrace
open NPTail
open RMRecb
open TODepth
open DRSched
open DCSched
open STSched
open ASTri
open BSRec
open BSPoly
open DRSubseq
open DSPoly
open ASGrade

/-- The word carried by a retained transition, or the right-hand carried word
of a crossed transition, provides the packet-level weight budget. -/
def secondRouteCarried :
    SRTrans → ℕ
  | .retained word =>
      word.weight (fun _ => 1)
  | .crossed _left right =>
      right.weight (fun _ => 1)

/-- A nonempty chosen packet subword carries at least the budget of its source
item whenever every emitted packet entry does. -/
private lemma cost_target_sublists
    {α : Type*}
    (sourceCost : ℕ)
    (targetCost : α → ℕ)
    (packet : List α)
    (selected : List α)
    (hselected : selected ∈ nonemptySublists packet)
    (hcost : ∀ item ∈ packet, sourceCost ≤ targetCost item) :
    sourceCost ≤ (selected.map targetCost).sum := by
  have hselectedSublist :
      List.Sublist selected packet :=
    List.mem_sublists.mp (List.mem_filter.mp hselected).1
  have hselectedNe :
      selected ≠ [] :=
    of_decide_eq_true (List.mem_filter.mp hselected).2
  cases selected with
  | nil =>
      exact False.elim (hselectedNe rfl)
  | cons item tail =>
      simp only [List.map_cons, List.sum_cons]
      exact
        (hcost item (hselectedSublist.subset (by simp))).trans
          (Nat.le_add_right _ _)

/-- Choosing a nonempty packet subword for every active source item bounds the
sum of source costs by the sum of output costs. -/
lemma cost_target_expansions
    {α β : Type*}
    (sourceCost : α → ℕ)
    (targetCost : β → ℕ)
    (packet : α → List β)
    (hpacket :
      ∀ source emitted,
        emitted ∈ packet source →
          sourceCost source ≤ targetCost emitted) :
    ∀ (source : List α) (target : List β),
      target ∈ activeSubsequenceExpansions packet source →
        (source.map sourceCost).sum ≤ (target.map targetCost).sum
  | [], target, htarget => by
      simp [activeSubsequenceExpansions] at htarget
      subst target
      simp
  | item :: source, target, htarget => by
      simp only [activeSubsequenceExpansions] at htarget
      rcases List.mem_flatMap.mp htarget with
        ⟨suffix, hsuffix, htarget⟩
      rcases List.mem_map.mp htarget with
        ⟨head, hhead, rfl⟩
      have hheadCost :
          sourceCost item ≤ (head.map targetCost).sum :=
        cost_target_sublists
          (sourceCost item) targetCost (packet item) head hhead
          (hpacket item)
      have hsuffixCost :
          (source.map sourceCost).sum ≤ (suffix.map targetCost).sum :=
        cost_target_expansions
          sourceCost targetCost packet hpacket source suffix hsuffix
      simp only [List.map_cons, List.sum_cons, List.map_append, List.sum_append]
      exact Nat.add_le_add hheadCost hsuffixCost

/-- The recursive depth-word grade is the sum of the per-depth costs
`depth + 1`. -/
lemma strict_grade_sum :
    ∀ source : List ℕ,
      strictDepthGrade source =
        (source.map fun depth => depth + 1).sum
  | [] => by
      rfl
  | depth :: source => by
      simp only [strictDepthGrade, List.map_cons, List.sum_cons,
        strict_grade_sum source]

/-- Every retained transition emitted at strict depth `depth` carries a word
of weight at least `depth + 1`. -/
lemma depth_carried_packet
    (cutoff : ℕ)
    (selected right : CWord Atom)
    (hselected :
      isFirstCurrent selected = true ∨
        isSecondCurrent selected = true)
    (depth : ℕ)
    (transition : SRTrans)
    (htransition :
      transition ∈
        strictTransitionPacket cutoff selected right depth) :
    depth + 1 ≤ secondRouteCarried transition := by
  rcases List.mem_map.mp htransition with ⟨emitted, hemitted, rfl⟩
  rw [iterated_cutoff_below] at hemitted
  unfold unitBelowTrace at hemitted
  have hemittedLiteral :
      emitted ∈ iteratedMoveTrace selected depth [right] :=
    (List.mem_filter.mp hemitted).1
  have hrightPos :
      1 ≤ right.weight (fun _ : Atom => 1) :=
    CWord.weight_pos (fun _ : Atom => 1) (fun _ => by simp) right
  have hweight :=
    steps_iterated_move
      (fun _ : Atom => 1) 1 selected [right]
      (fun emitted hemitted => by
        simp only [List.mem_singleton] at hemitted
        subst emitted
        exact hrightPos)
      depth emitted hemittedLiteral
  rw [or_second_current selected hselected] at hweight
  change depth + 1 ≤ emitted.weight (fun _ : Atom => 1)
  omega

/-- Every crossed transition emitted at strict depth `depth` carries a
right-hand word of weight at least `depth + 1`. -/
lemma carried_crossing_packet
    (cutoff : ℕ)
    (outer selected right : CWord Atom)
    (hselected :
      isFirstCurrent selected = true ∨
        isSecondCurrent selected = true)
    (depth : ℕ)
    (transition : SRTrans)
    (htransition :
      transition ∈
        strictCrossingPacket
          cutoff outer selected right depth) :
    depth + 1 ≤ secondRouteCarried transition := by
  rcases List.mem_map.mp htransition with ⟨emitted, hemitted, rfl⟩
  rw [iterated_cutoff_below] at hemitted
  unfold unitBelowTrace at hemitted
  have hemittedLiteral :
      emitted ∈ iteratedMoveTrace selected depth [right] :=
    (List.mem_filter.mp hemitted).1
  have hrightPos :
      1 ≤ right.weight (fun _ : Atom => 1) :=
    CWord.weight_pos (fun _ : Atom => 1) (fun _ => by simp) right
  have hweight :=
    steps_iterated_move
      (fun _ : Atom => 1) 1 selected [right]
      (fun emitted hemitted => by
        simp only [List.mem_singleton] at hemitted
        subst emitted
        exact hrightPos)
      depth emitted hemittedLiteral
  rw [or_second_current selected hselected] at hweight
  change depth + 1 ≤ emitted.weight (fun _ : Atom => 1)
  omega

/-- A nonzero retained source-depth coefficient forces its entire depth-word
grade below the carried-weight sum of the requested transition word. -/
lemma strict_grade_subsequence
    (cutoff : ℕ)
    (selected right : CWord Atom)
    (hselected :
      isFirstCurrent selected = true ∨
        isSecondCurrent selected = true)
    (source : List ℕ)
    (target : List SRTrans)
    (hcoefficient :
      activeSubsequenceCoefficient
        cutoff selected right source target ≠
      0) :
    strictDepthGrade source ≤
      (target.map secondRouteCarried).sum := by
  rw [strict_grade_sum]
  apply
    cost_target_expansions
      (fun depth => depth + 1)
      secondRouteCarried
      (strictTransitionPacket cutoff selected right)
  · intro depth transition htransition
    exact
      depth_carried_packet
        cutoff selected right hselected depth transition htransition
  · exact
      List.count_pos_iff.mp
        (Nat.pos_of_ne_zero hcoefficient)

/-- A nonzero crossing source-depth coefficient forces its entire depth-word
grade below the carried-weight sum of the requested transition word. -/
lemma grade_crossing_subsequence
    (cutoff : ℕ)
    (outer selected right : CWord Atom)
    (hselected :
      isFirstCurrent selected = true ∨
        isSecondCurrent selected = true)
    (source : List ℕ)
    (target : List SRTrans)
    (hcoefficient :
      activeCrossingSubsequence
        cutoff outer selected right source target ≠
      0) :
    strictDepthGrade source ≤
      (target.map secondRouteCarried).sum := by
  rw [strict_grade_sum]
  apply
    cost_target_expansions
      (fun depth => depth + 1)
      secondRouteCarried
      (strictCrossingPacket cutoff outer selected right)
  · intro depth transition htransition
    exact
      carried_crossing_packet
        cutoff outer selected right hselected depth transition htransition
  · exact
      List.count_pos_iff.mp
        (Nat.pos_of_ne_zero hcoefficient)

/-- The retained active-source supremum is bounded by the carried-weight sum
of its requested transition word. -/
lemma active_grade_carried
    (cutoff : ℕ)
    (selected right : CWord Atom)
    (hselected :
      isFirstCurrent selected = true ∨
        isSecondCurrent selected = true)
    (target : List SRTrans) :
    activeGradeBound cutoff selected right target ≤
      (target.map secondRouteCarried).sum + 1 := by
  apply active_grade_bound
  intro source _hsource hcoefficient
  exact
    Nat.add_le_add_right
      (strict_grade_subsequence
        cutoff selected right hselected source target hcoefficient)
      1

/-- The crossing active-source supremum is bounded by the carried-weight sum
of its requested transition word. -/
lemma crossing_grade_carried
    (cutoff : ℕ)
    (outer selected right : CWord Atom)
    (hselected :
      isFirstCurrent selected = true ∨
        isSecondCurrent selected = true)
    (target : List SRTrans) :
    crossingGradeBound
        cutoff outer selected right target ≤
      (target.map secondRouteCarried).sum + 1 := by
  apply active_grade_bound
  intro source _hsource hcoefficient
  exact
    Nat.add_le_add_right
      (grade_crossing_subsequence
        cutoff outer selected right hselected source target hcoefficient)
      1

/-- Retained transition-subword multiplicity is polynomial with a degree bound
controlled by its carried-weight sum. -/
lemma subsequenceMultCarried
    (cutoff : ℕ)
    (selected right : CWord Atom)
    (hselected :
      isFirstCurrent selected = true ∨
        isSecondCurrent selected = true)
    (target : List SRTrans) :
    IVMost
      (fun steps : ℕ =>
        (orderedSubsequenceMultiplicity target
          (boundedStrictSchedule cutoff selected right steps) :
            ℤ))
      ((target.map secondRouteCarried).sum + 1) := by
  exact
    mult_grade_bound
      cutoff ((target.map secondRouteCarried).sum + 1)
        selected right target
      (active_grade_carried
        cutoff selected right hselected target)

/-- Crossing transition-subword multiplicity is polynomial with a degree bound
controlled by its carried-weight sum. -/
lemma multCrossingCarried
    (cutoff : ℕ)
    (outer selected right : CWord Atom)
    (hselected :
      isFirstCurrent selected = true ∨
        isSecondCurrent selected = true)
    (target : List SRTrans) :
    IVMost
      (fun steps : ℕ =>
        (orderedSubsequenceMultiplicity target
          (depthCrossingSchedule cutoff outer selected right
            steps) : ℤ))
      ((target.map secondRouteCarried).sum + 1) := by
  exact
    subsequence_mult_grade
      cutoff ((target.map secondRouteCarried).sum + 1)
        outer selected right target
      (crossing_grade_carried
        cutoff outer selected right hselected target)

end DASrc
end TCTex
end Submission

-- Merged from JacobiIntegralPowerStrictTailCutoffOrderedFirstRouteOuterMiddleNestedTransitionJointW
-- eightBudget.lean

/-!
# Joint weight budgets for nested Hall-Witt crossing transitions

A transition emitted by the nested middle route is obtained by first moving
the selected current word across the original right word and then moving the
outer current word across that intermediate result.  Its carried word pays
for both correction depths simultaneously.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace TJBudget

open CWTrace
open WSTrace
open NPTail
open RMRecb
open TODepth
open STSched
open DSRec
open DASrc
open NCSched
open SSSched

/-- A nested emitted transition jointly pays for both correction depths and
the initial right-hand word. -/
lemma outer_crossing_packet
    (cutoff : ℕ)
    (crossed outer selected right innerRight : CWord Atom)
    (innerDepth outerDepth : ℕ)
    (hinnerRight :
      innerRight ∈
        iteratedMoveTrace selected innerDepth [right])
    (transition : SRTrans)
    (htransition :
      transition ∈
        nestedCrossingPacket cutoff crossed outer
          innerRight outerDepth) :
    outerDepth * outer.weight (fun _ : Atom => 1) +
        (innerDepth * selected.weight (fun _ : Atom => 1) +
          right.weight (fun _ : Atom => 1)) ≤
      secondRouteCarried transition := by
  rcases List.mem_map.mp htransition with ⟨emitted, hemitted, rfl⟩
  rw [iterated_cutoff_below] at hemitted
  unfold unitBelowTrace at hemitted
  have hemittedLiteral :
      emitted ∈ iteratedMoveTrace outer outerDepth
        [innerRight] :=
    (List.mem_filter.mp hemitted).1
  have hinnerWeight :
      innerDepth * selected.weight (fun _ : Atom => 1) +
          right.weight (fun _ : Atom => 1) ≤
        innerRight.weight (fun _ : Atom => 1) := by
    exact
      steps_iterated_move
        (fun _ : Atom => 1) (right.weight (fun _ : Atom => 1)) selected
          [right]
          (fun emitted hemitted => by
            simp only [List.mem_singleton] at hemitted
            subst emitted
            exact Nat.le_refl _)
          innerDepth innerRight hinnerRight
  have houterWeight :=
    steps_iterated_move
      (fun _ : Atom => 1)
      (innerDepth * selected.weight (fun _ : Atom => 1) +
        right.weight (fun _ : Atom => 1))
      outer [innerRight]
      (fun emitted hemitted => by
        simp only [List.mem_singleton] at hemitted
        subst emitted
        exact hinnerWeight)
      outerDepth emitted hemittedLiteral
  change
    outerDepth * outer.weight (fun _ : Atom => 1) +
        (innerDepth * selected.weight (fun _ : Atom => 1) +
          right.weight (fun _ : Atom => 1)) ≤
      emitted.weight (fun _ : Atom => 1)
  exact houterWeight

/-- Membership in a bounded nested schedule exposes inner and outer depths
whose joint physical cost is bounded by the carried transition word. -/
lemma joint_budget_crossing
    (cutoff innerSteps outerSteps : ℕ)
    (crossed outer selected right : CWord Atom)
    (transition : SRTrans)
    (htransition :
      transition ∈
        nestedCrossingSchedule cutoff crossed outer selected
          right innerSteps outerSteps) :
    ∃ innerDepth ∈ boundedDepthSchedule cutoff innerSteps,
      ∃ outerDepth ∈ boundedDepthSchedule cutoff outerSteps,
        outerDepth * outer.weight (fun _ : Atom => 1) +
            (innerDepth * selected.weight (fun _ : Atom => 1) +
              right.weight (fun _ : Atom => 1)) ≤
          secondRouteCarried transition := by
  rcases List.mem_flatMap.mp htransition with
    ⟨innerDepth, hinnerDepth, htransition⟩
  rcases List.mem_flatMap.mp htransition with
    ⟨innerRight, hinnerRight, htransition⟩
  rcases List.mem_flatMap.mp htransition with
    ⟨outerDepth, houterDepth, htransition⟩
  exact
    ⟨innerDepth, hinnerDepth, outerDepth, houterDepth,
      outer_crossing_packet
        cutoff crossed outer selected right innerRight innerDepth outerDepth
          hinnerRight transition htransition⟩

/-- For Hall-Witt current words, each correction depth contributes three
units of carried weight. -/
lemma crossing_transition_packet
    (cutoff : ℕ)
    (crossed outer selected right innerRight : CWord Atom)
    (innerDepth outerDepth : ℕ)
    (houter :
      isFirstCurrent outer = true ∨
        isSecondCurrent outer = true)
    (hselected :
      isFirstCurrent selected = true ∨
        isSecondCurrent selected = true)
    (hinnerRight :
      innerRight ∈
        iteratedMoveTrace selected innerDepth [right])
    (transition : SRTrans)
    (htransition :
      transition ∈
        nestedCrossingPacket cutoff crossed outer
          innerRight outerDepth) :
    3 * outerDepth +
        (3 * innerDepth + right.weight (fun _ : Atom => 1)) ≤
      secondRouteCarried transition := by
  have hweight :=
    outer_crossing_packet
      cutoff crossed outer selected right innerRight innerDepth outerDepth
        hinnerRight transition htransition
  rw [or_second_current outer houter,
    or_second_current selected hselected] at hweight
  omega

/-- The weaker unscaled form is convenient when paying recursive depth-word
grades. -/
lemma outer_nested_crossing
    (cutoff : ℕ)
    (crossed outer selected right innerRight : CWord Atom)
    (innerDepth outerDepth : ℕ)
    (houter :
      isFirstCurrent outer = true ∨
        isSecondCurrent outer = true)
    (hselected :
      isFirstCurrent selected = true ∨
        isSecondCurrent selected = true)
    (hinnerRight :
      innerRight ∈
        iteratedMoveTrace selected innerDepth [right])
    (transition : SRTrans)
    (htransition :
      transition ∈
        nestedCrossingPacket cutoff crossed outer
          innerRight outerDepth) :
    outerDepth + innerDepth + right.weight (fun _ : Atom => 1) ≤
      secondRouteCarried transition := by
  have hweight :=
    crossing_transition_packet
      cutoff crossed outer selected right innerRight innerDepth outerDepth
        houter hselected hinnerRight transition htransition
  omega

/-- A bounded nested schedule with current outer and selected words exposes
the corresponding three-weight budget. -/
lemma outer_crossing_schedule
    (cutoff innerSteps outerSteps : ℕ)
