/-- The endpoint obtained by applying a literal compiled trace to the zero
profile is supported on the fixed cutoff vocabulary. -/
lemma supported_cutoff_vocabulary
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (trace : List (CWord Atom)) :
    SCVocabu cutoff
      ((ofTrace cutoff isCurrent trace).apply 0) := by
  have hpreserves :=
    preserves_affine_trace cutoff isCurrent trace
  change
    SCVocabu cutoff
      ((ofTrace cutoff isCurrent trace).linear 0 +
        (ofTrace cutoff isCurrent trace).constant)
  apply SCVocabu.add
  · apply hpreserves.1
    intro word hword
    simp at hword
  · exact hpreserves.2

/-- The positive unshifted orbit-prefix ordinary compiler endpoint has
polynomial cutoff-profile coordinates at its natural retained-schedule
degree bound. -/
lemma positive_compiler_endpoint
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff) :
    CPDataa cutoff
      (cutoff *
          (cutoff + (positiveFilteredPrefix cutoff).length + 1) +
        1)
      (positiveCompilerEndpoint cutoff) := by
  constructor
  · intro steps
    unfold positiveCompilerEndpoint
    exact
      supported_cutoff_vocabulary cutoff isSecondCurrent
        (cutoffMovePrefix cutoff firstConventionalInverse
          (positiveFilteredPrefix cutoff) steps)
  · intro slot
    have hprefix :
        unitBelowTrace cutoff
            (positiveFilteredPrefix cutoff) =
          positiveFilteredPrefix cutoff := by
      unfold positiveFilteredPrefix filteredOuterPrefix
      exact unit_below_idempotent cutoff _
    rw [show
      (fun steps : ℕ =>
        (Multiset.count slot
          (positiveCompilerEndpoint cutoff steps) : ℤ)) =
        fun steps : ℕ =>
          (Multiset.count slot
            ((scheduleAffine cutoff
              ((cutoffMovePrefix cutoff
                firstConventionalInverse
                (unitBelowTrace cutoff
                  (positiveFilteredPrefix cutoff)) steps).map
                    SRTrans.retained)).apply 0) : ℤ) by
      funext steps
      unfold positiveCompilerEndpoint
      rw [hprefix, schedule_affine_retained]]
    exact
      scheduleAffinePoly
        cutoff hcutoff firstConventionalInverse (by simp)
          (positiveFilteredPrefix cutoff) slot

/-- The negative unshifted orbit-prefix ordinary compiler endpoint has
polynomial cutoff-profile coordinates at its natural retained-schedule
degree bound. -/
lemma negative_compiler_endpoint
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff) :
    CPDataa cutoff
      (cutoff *
          (cutoff + (negativeFilteredPrefix cutoff).length + 1) +
        1)
      (emptyCompilerEndpoint cutoff) := by
  constructor
  · intro steps
    unfold emptyCompilerEndpoint
    exact
      supported_cutoff_vocabulary cutoff isSecondCurrent
        (cutoffMovePrefix cutoff firstConventionalWord
          (negativeFilteredPrefix cutoff) steps)
  · intro slot
    have hprefix :
        unitBelowTrace cutoff
            (negativeFilteredPrefix cutoff) =
          negativeFilteredPrefix cutoff := by
      unfold negativeFilteredPrefix filteredOuterPrefix
      exact unit_below_idempotent cutoff _
    rw [show
      (fun steps : ℕ =>
        (Multiset.count slot
          (emptyCompilerEndpoint cutoff steps) : ℤ)) =
        fun steps : ℕ =>
          (Multiset.count slot
            ((scheduleAffine cutoff
              ((cutoffMovePrefix cutoff firstConventionalWord
                (unitBelowTrace cutoff
                  (negativeFilteredPrefix cutoff)) steps).map
                    SRTrans.retained)).apply 0) : ℤ) by
      funext steps
      unfold emptyCompilerEndpoint
      rw [hprefix, schedule_affine_retained]]
    exact
      scheduleAffinePoly
        cutoff hcutoff firstConventionalWord (by simp)
          (negativeFilteredPrefix cutoff) slot

/-- The positive endpoint polynomial data fits the existing full-transition
successor degree budget. -/
lemma empty_compiler_endpoint
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff) :
    CPDataa cutoff
      (naturalFullBound cutoff)
      (positiveCompilerEndpoint cutoff) := by
  exact
    CPDataa.mono
      (cutoff := cutoff)
      (degreeBound :=
        cutoff *
          (cutoff + (positiveFilteredPrefix cutoff).length + 1) +
        1)
      (largerBound := naturalFullBound cutoff)
      (by
        unfold naturalFullBound
        apply Nat.add_le_add_right
        apply Nat.mul_le_mul_left
        omega)
      (positive_compiler_endpoint
        cutoff hcutoff)

/-- The negative endpoint polynomial data fits the existing full-transition
successor degree budget. -/
lemma empty_compiler_bound
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff) :
    CPDataa cutoff
      (negativeFullBound cutoff)
      (emptyCompilerEndpoint cutoff) := by
  exact
    CPDataa.mono
      (cutoff := cutoff)
      (degreeBound :=
        cutoff *
          (cutoff + (negativeFilteredPrefix cutoff).length + 1) +
        1)
      (largerBound := negativeFullBound cutoff)
      (by
        unfold negativeFullBound
        apply Nat.add_le_add_right
        apply Nat.mul_le_mul_left
        omega)
      (negative_compiler_endpoint
        cutoff hcutoff)

/-- The positive fixed-affine successor endpoint satisfies its signed Newton
cancellation kernel. -/
lemma emptySatisfiesNewton
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff) :
    EmptySatisfiesNewton
