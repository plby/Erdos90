/-- A strict packet correction raises weight by any common lower bound for the
weights of its selected packet words. -/
lemma end_raises_selected
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (increment : ℕ) :
    ∀ packet : List (CWord Atom),
      (∀ word ∈ packet,
        isCurrent word = true →
          increment ≤ word.weight (fun _ => 1)) →
        RUWt increment
          (packetCorrectionEnd cutoff isCurrent packet)
  | [], _hpacket => by
      exact RUWt.zero increment
  | word :: words, hpacket => by
      have hwords :
          ∀ next ∈ words,
            isCurrent next = true →
              increment ≤ next.weight (fun _ => 1) := by
        intro next hnext hcurrent
        exact hpacket next (by simp [hnext]) hcurrent
      by_cases hcurrent : isCurrent word = true
      · simp only [packetCorrectionEnd, hcurrent, if_pos]
        apply RUWt.add
        · apply RUWt.mono
          · simpa using hpacket word (by simp) hcurrent
          · simpa using
              RUWt.mul
                (RUWt.correctionEnd cutoff word)
                (RUWt.add
                  ((end_raises_selected
                    cutoff isCurrent increment words hwords).mono
                    (Nat.zero_le increment))
                  RUWt.one)
        · exact
            end_raises_selected
              cutoff isCurrent increment words hwords
      · simpa [packetCorrectionEnd, hcurrent] using
          end_raises_selected
            cutoff isCurrent increment words hwords

/-- The strict correction of one transition raises unit weight by that
transition's carried right-word weight. -/
lemma raises_route_carried
    (cutoff : ℕ) :
    ∀ transition : SRTrans,
      RUWt
        (secondRouteCarried transition)
        (TExp.strictLinear cutoff transition)
  | .retained word => by
      unfold TExp.strictLinear TExp.strictPacket
      apply
        end_raises_selected
      intro next hnext _hcurrent
      change word.weight (fun _ => 1) ≤ next.weight (fun _ => 1)
      simp only [List.mem_cons, List.not_mem_nil, or_false] at hnext
      subst next
      exact Nat.le_refl _
  | .crossed left right => by
      unfold TExp.strictLinear TExp.strictPacket
      apply
        end_raises_selected
      intro next hnext _hcurrent
      change right.weight (fun _ => 1) ≤ next.weight (fun _ => 1)
      change
        next ∈
          unitBelowTrace cutoff
            ([.commutator left right, right] :
              List (CWord Atom)) at hnext
      unfold unitBelowTrace at hnext
      have hnext' :
          next ∈
            ([.commutator left right, right] :
              List (CWord Atom)) :=
        (List.mem_filter.mp hnext).1
      simp only [List.mem_cons, List.not_mem_nil, or_false] at hnext'
      rcases hnext' with rfl | rfl
      · simp only [CWord.weight_commutator]
        omega
      · exact Nat.le_refl _

/-- An ordered product of strict transition corrections raises unit weight by
the sum of the carried weights of its transitions. -/
lemma ordered_raises_carried
    (cutoff : ℕ) :
    ∀ transitions : List SRTrans,
      RUWt
        ((transitions.map secondRouteCarried).sum)
        (orderedStrictProduct cutoff transitions)
  | [] => by
      simpa [orderedStrictProduct] using RUWt.one
  | transition :: transitions => by
      simpa [orderedStrictProduct] using
        RUWt.mul
          (raises_route_carried
            cutoff transition)
          (ordered_raises_carried
            cutoff transitions)

/-- Every occurrence emitted by an evaluated bounded term remembers a source
constant whose weight plus the strict carried-weight sum is no larger than the
emitted weight. -/
lemma constant_sum_carried
    (cutoff : ℕ)
    (term : OCTerm)
    (emitted : CWord Atom)
    (hemitted : emitted ∈ term.eval cutoff) :
    ∃ original ∈ term.constant,
      (term.strictTransitions.map
          secondRouteCarried).sum +
          original.weight (fun _ => 1) ≤
        emitted.weight (fun _ => 1) := by
  exact
    (ordered_raises_carried
      cutoff term.strictTransitions term.constant emitted hemitted) |>.imp
        fun original horiginal => by
          simpa [Nat.add_comm] using horiginal

/-- Every source occurrence in one transition's affine constant has weight at
least the transition's carried right-word weight. -/
lemma second_carried_constant
    (cutoff : ℕ) :
    ∀ (transition : SRTrans)
      (original : CWord Atom),
      original ∈ (transition.affine cutoff).constant →
        secondRouteCarried transition ≤
          original.weight (fun _ => 1)
  | .retained word, original, horiginal => by
      change word.weight (fun _ => 1) ≤ original.weight (fun _ => 1)
      change original ∈ (secondAtomAffine cutoff word).constant at horiginal
      unfold secondAtomAffine at horiginal
      by_cases hcurrent : isSecondCurrent word = true
      · rw [if_pos hcurrent] at horiginal
        simp [CPAffine.selected] at horiginal
      · rw [if_neg hcurrent] at horiginal
        change
          original ∈ cutoffProfile cutoff [word] at horiginal
        unfold cutoffProfile unitBelowTrace at horiginal
        have horiginal' : original ∈ [word] :=
          (List.mem_filter.mp horiginal).1
        have horiginalEq : original = word := by
          simpa only [List.mem_singleton] using horiginal'
        rw [horiginalEq]
  | .crossed left right, original, horiginal => by
      rw [SRTrans.affine, crossedSecondPacket,
        constant_route_nil] at horiginal
      have horiginalRoute :
          original ∈
            routeOnto isSecondCurrent
              (unitBelowTrace cutoff
                ([.commutator left right, right] :
                  List (CWord Atom)))
              [] := by
        unfold cutoffProfile at horiginal
        change
          original ∈
            unitBelowTrace cutoff
              (routeOnto isSecondCurrent
                (unitBelowTrace cutoff
                  ([.commutator left right, right] :
                    List (CWord Atom)))
                []) at horiginal
        unfold unitBelowTrace at horiginal
        exact (List.mem_filter.mp horiginal).1
      rw [← stable_fst_nil] at horiginalRoute
      apply
        stable_route_fst
          (fun _ : Atom => 1) (right.weight (fun _ => 1))
            isSecondCurrent
              (unitBelowTrace cutoff
                ([.commutator left right, right] :
                  List (CWord Atom)))
      · intro source hsource _hcurrent
        unfold unitBelowTrace at hsource
        have hsource' :
            source ∈
              ([.commutator left right, right] :
                List (CWord Atom)) :=
          (List.mem_filter.mp hsource).1
        simp only [List.mem_cons, List.not_mem_nil, or_false] at hsource'
        rcases hsource' with rfl | rfl
        · simp only [CWord.weight_commutator]
          omega
        · exact Nat.le_refl _
      · exact horiginalRoute

/-- If one bounded term emits a slot, the term's strict carried-weight sum plus
the maximum weight of any producer with its affine constant is no larger than
the slot weight. -/
lemma carried_matching_producer
    (cutoff : ℕ)
    (term : OCTerm)
    (emitted : CWord Atom)
    (hemitted : emitted ∈ term.eval cutoff) :
    (term.strictTransitions.map
        secondRouteCarried).sum +
        matchingProducerCarried cutoff term ≤
      emitted.weight (fun _ => 1) := by
  rcases
      constant_sum_carried
        cutoff term emitted hemitted with
    ⟨original, horiginal, horiginalWeight⟩
  apply
    (show
      (term.strictTransitions.map
          secondRouteCarried).sum +
          matchingProducerCarried cutoff term ≤
        (term.strictTransitions.map
          secondRouteCarried).sum +
          original.weight (fun _ => 1) from ?_).trans horiginalWeight
  apply Nat.add_le_add_left
  unfold matchingProducerCarried
  apply Finset.sup_le
  intro producer hproducer
  rcases Finset.mem_filter.mp hproducer with ⟨_hproducer, hconstant⟩
  apply
    second_carried_constant
      cutoff producer original
  rwa [← hconstant]

