/-!
# Finite schedules for Hall-Witt crossing substitutions

One triangular outer-trace step replaces each carried word by its filtered
two-word rightward-move packet.  Crossing an outer first-family word over that
substituted trace is therefore a flatMap of fixed local crossed transition
packets.  Name that schedule and its induced bounded-term vector operator.

This removes the final raw `flatMap` expression from the finite crossing-state
recurrence and leaves a compositional local-substitution compiler.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace OSSched

open WSTrace
open WHNorm
open NPTail
open OFProgra
open OFProgra.FRProgra
open OTSubsti
open STSched
open STState
open OCState

/-- Crossed transition packet emitted when an outer word crosses one local
filtered rightward-move packet. -/
def moveCrossingPacket
    (cutoff : ℕ)
    (outer selected right : CWord Atom) :
    List SRTrans :=
  (cutoffMovePacket cutoff selected right).map
    (SRTrans.crossed outer)

/-- Crossed transition schedule emitted by substituting every carried word
with its local filtered rightward-move packet. -/
def crossingSubstitutionSchedule
    (cutoff : ℕ)
    (outer selected : CWord Atom)
    (trace : List (CWord Atom)) :
    List SRTrans :=
  trace.flatMap (moveCrossingPacket cutoff outer selected)

/-- Mapping crossings over a locally substituted trace is exactly the
crossing-substitution schedule. -/
lemma crossed_flat_move
    (cutoff : ℕ)
    (outer selected : CWord Atom) :
    ∀ trace : List (CWord Atom),
      (trace.flatMap (cutoffMovePacket cutoff selected)).map
          (SRTrans.crossed outer) =
        crossingSubstitutionSchedule cutoff outer selected trace
  | [] => by
      rfl
  | right :: rights => by
      simp only [List.flatMap_cons, List.map_append,
        crossingSubstitutionSchedule, moveCrossingPacket]
      rw [crossed_flat_move cutoff outer selected rights]
      rfl

/-- Crossing-substitution schedules compose across carried-trace
concatenation. -/
lemma crossing_substitution_append
    (cutoff : ℕ)
    (outer selected : CWord Atom)
    (left right : List (CWord Atom)) :
    crossingSubstitutionSchedule cutoff outer selected (left ++ right) =
      crossingSubstitutionSchedule cutoff outer selected left ++
        crossingSubstitutionSchedule cutoff outer selected right := by
  simp [crossingSubstitutionSchedule]

/-- Every transition in a crossing-substitution schedule belongs to the fixed
second-route transition alphabet when the outer crossed word is first-family
current. -/
lemma alphabet_crossing_substitution
    (cutoff : ℕ)
    (outer selected : CWord Atom)
    (houter : isFirstCurrent outer = true)
    (trace : List (CWord Atom))
    (transition : SRTrans)
    (htransition :
      transition ∈ crossingSubstitutionSchedule cutoff outer selected trace) :
    transition ∈ secondRouteAlphabet cutoff := by
  rcases List.mem_flatMap.mp htransition with
    ⟨right, _hright, htransition⟩
  rcases List.mem_map.mp htransition with ⟨word, hword, rfl⟩
  exact
    transition_alphabet_crossed cutoff outer word houter
      (supported_vocabulary_below
        cutoff [.commutator selected right, right] word hword)

/-- Induced finite bounded-term vector operator of one complete local
crossing-substitution schedule. -/
noncomputable def crossingSubstitutionOperator
    (cutoff : ℕ)
    (outer selected : CWord Atom)
    (trace : List (CWord Atom)) :
    List ℕ → List ℕ :=
  boundedConstantOperator cutoff
    (crossingSubstitutionSchedule cutoff outer selected trace)

/-- Crossing-substitution operators compose across carried-trace
concatenation. -/
lemma substitution_operator_append
    (cutoff : ℕ)
    (outer selected : CWord Atom)
    (left right : List (CWord Atom))
