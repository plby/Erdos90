      rfl
  | transition :: transitions, right, state => by
      rw [List.cons_append, boundedStateFold,
        boundedStateFold,
        state_fold_append cutoff transitions right state]

/-- The explicit count-state schedule fold from the empty state computes each
coordinate of the bounded ordered-subsequence expansion. -/
lemma count_constant_fold
    (cutoff : ℕ)
    (transitions : List SRTrans)
    (target : OCTerm) :
    ((boundedConstantTerms cutoff transitions).count target : ℤ) =
      boundedStateFold cutoff transitions
        (boundedCountState []) target := by
  rw [constant_terms_fold]
  exact congrFun (count_state_fold cutoff transitions []) target

/-- Coordinatewise integer-valued polynomiality for a family of explicit
bounded-term count states. -/
def BSData
    (degreeBound : ℕ)
    (family : ℕ → BoundedCountState) :
    Prop :=
  ∀ target,
    IVMost
      (fun steps => family steps target) degreeBound

/-- Every fixed integer-valued constant family is polynomial at every larger
degree bound. -/
lemma valued_most_const
    (degreeBound : ℕ)
    (value : ℤ) :
    IVMost
      (fun _steps : ℕ => value) degreeBound := by
  exact
    ⟨Polynomial.C value, by simp, fun steps => by simp⟩

/-- A fixed strict-predecessor projection preserves coordinatewise
polynomiality. -/
lemma BSData.apply_strict_predececount
    {degreeBound : ℕ}
    {family : ℕ → BoundedCountState}
    (hfamily : BSData degreeBound family)
    (cutoff : ℕ)
    (transition : SRTrans) :
    BSData degreeBound
      (fun steps target =>
        strictPredecessorCount cutoff transition (family steps) target) := by
  intro target
  by_cases hlength : target.strictTransitions.length < cutoff
  · cases hprevious : removePrepended? transition target with
    | none =>
        simpa [strictPredecessorCount, hlength, hprevious] using
          valued_most_const degreeBound 0
    | some previous =>
        simpa [strictPredecessorCount, hlength, hprevious] using
          hfamily previous
  · simpa [strictPredecessorCount, hlength] using
      valued_most_const degreeBound 0

/-- Applying one fixed bounded-term state transition preserves
coordinatewise polynomiality and its common degree bound. -/
lemma BSData.step
    {degreeBound : ℕ}
    {family : ℕ → BoundedCountState}
    (hfamily : BSData degreeBound family)
    (cutoff : ℕ)
    (transition : SRTrans) :
    BSData degreeBound
      (fun steps =>
        boundedStateStep cutoff transition (family steps)) := by
  intro target
  unfold boundedStateStep
  exact
    ((hfamily.apply_strict_predececount cutoff transition) target).add
      (hfamily target) |>.add
        (valued_most_const degreeBound
          (singletonConstantCount cutoff transition target))

/-- Every fixed transition schedule preserves coordinatewise polynomiality. -/
lemma BSData.scheduleFold
    {degreeBound : ℕ}
    {family : ℕ → BoundedCountState}
    (hfamily : BSData degreeBound family)
    (cutoff : ℕ) :
    ∀ transitions : List SRTrans,
      BSData degreeBound
        (fun steps =>
          boundedStateFold cutoff transitions
            (family steps))
  | [] => by
      exact hfamily
  | transition :: transitions => by
      exact
        (hfamily.scheduleFold cutoff transitions).step cutoff transition

end SCState
end TCTex
