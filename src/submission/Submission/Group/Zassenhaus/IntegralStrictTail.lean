lemma concrete_parent_basis
    (d n : ℕ)
    (x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d)))
    (hparent :
      exponentAddressParent x y z + 1 < n)
    (i : AddressParentIndex d x y z) :
    concreteParentBasis
        d n x y z hparent i =
      BCWt.associatedGradedClass (n := n)
        ((concreteCommutatorsWeight.{u} d
          (exponentAddressParent x y z + 1)).commutator i) := by
  exact
    (Classical.choose_spec
      (concrete_forms_associated
        d n (exponentAddressParent x y z + 1)
          (by omega) hparent)) i

/-- Positive Newton recipe for one selected concrete Hall coordinate. -/
noncomputable def addressNaturalParent
    (d n : ℕ)
    (x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d)))
    (cutoff : ℕ)
    (hparent :
      exponentAddressParent x y z + 1 < n)
