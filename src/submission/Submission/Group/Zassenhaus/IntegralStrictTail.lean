theorem cutoff_profile_natural
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff) :
    CPDataa cutoff
      (naturalStrictBound cutoff)
      (fun multiplicity =>
        cutoffProfile cutoff
          (NPTail.strictTrace multiplicity)) := by
  apply
    natural_compiler_endpoint
      cutoff hcutoff
  exact
    empty_compiler_endpoint
      cutoff (by omega)

/-- Global negative strict-tail cutoff-profile polynomiality. -/
theorem cutoff_profile_negative
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff) :
    CPDataa cutoff
      (negativeStrictBound cutoff)
      (fun multiplicity =>
        cutoffProfile cutoff
          (NNPower.strictTrace
