all six substituted Hall-Witt labels do too. -/
lemma input_signed_substitution
    {β : Type*}
    (wt : β → ℕ)
    (x y z : CWord β)
    (inputWeight : ℕ)
    (hx : inputWeight ≤ x.weight wt)
    (hy : inputWeight ≤ y.weight wt)
    (hz : inputWeight ≤ z.weight wt) :
    ∀ atom,
      inputWeight ≤ (signedWordSubstitution x y z atom).weight wt := by
  intro atom
  rw [weight_signed_substitution]
  rcases atom with atom | atom
  · refine Fin.cases ?_ (fun atom => ?_) atom
    · change
        inputWeight ≤
          signedWeight (x.weight wt) (y.weight wt) (z.weight wt) xAtom
      simpa only [signedWeight_x] using hx
    · refine Fin.cases ?_ (fun atom => ?_) atom
      · change
          inputWeight ≤
            signedWeight (x.weight wt) (y.weight wt) (z.weight wt) xInvAtom
        simpa only [signed_x_inv] using hx
      · refine Fin.cases ?_ (fun atom => ?_) atom
        · change
            inputWeight ≤
              signedWeight (x.weight wt) (y.weight wt) (z.weight wt) zAtom
          simpa only [signedWeight_z] using hz
        · exact
            Fin.cases
              (by
                change
                  inputWeight ≤
