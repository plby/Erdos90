      transition ∈
        crossingMiddleSchedule cutoff crossed outer
          selected right emittedPrefix steps) :
    transition ∈ secondRouteAlphabet cutoff := by
  rcases List.mem_append.mp htransition with htransition | htransition
  · exact
      route_crossing_schedule
        cutoff steps crossed outer hcrossed emittedPrefix transition
          htransition
  · exact
      nested_crossing_schedule
        cutoff steps crossed outer selected right hcrossed transition
          htransition

/-- Ordered-subsequence coordinates of a complete outer-middle schedule are
polynomial. -/
lemma subsequence_crossing_middle
    (cutoff : ℕ)
    (crossed outer selected right : CWord Atom)
    (emittedPrefix : List (CWord Atom))
    (target : List SRTrans) :
    IVMost
      (fun steps : ℕ =>
        (orderedSubsequenceMultiplicity target
          (crossingMiddleSchedule cutoff crossed outer
            selected right emittedPrefix steps) : ℤ))
      (target.length * (2 * cutoff + emittedPrefix.length + 4) + 1) := by
  rw [show
    (fun steps : ℕ =>
      (orderedSubsequenceMultiplicity target
        (crossingMiddleSchedule cutoff crossed outer
          selected right emittedPrefix steps) : ℤ)) =
      fun steps : ℕ =>
        ∑ suffix ∈ target.tails.toFinset,
          (orderedSubsequenceMultiplicity
            (target.take (target.length - suffix.length))
            (boundedCrossingSchedule cutoff crossed outer
              emittedPrefix steps) : ℤ) *
          (orderedSubsequenceMultiplicity suffix
            (repeatTransitionSchedule
              (boundedNestedCrossing cutoff crossed outer
                selected right steps) steps) : ℤ) by
    funext steps
    exact_mod_cast
      subsequence_append_tails target
        (boundedCrossingSchedule cutoff crossed outer
          emittedPrefix steps)
        (repeatTransitionSchedule
          (boundedNestedCrossing cutoff crossed outer
            selected right steps) steps)]
  apply IVMost.finsetSum
  intro suffix hsuffix
  have hsuffixMem :
      suffix <:+ target :=
    (List.mem_tails suffix target).mp (List.mem_toFinset.mp hsuffix)
  rcases hsuffixMem with ⟨initial, rfl⟩
  simp only [List.length_append, Nat.add_sub_cancel_right,
    List.take_append_of_le_length (Nat.le_refl initial.length),
    List.take_length]
  apply
    TCTex.IVMost.mono
  · let degree := 2 * cutoff + emittedPrefix.length + 4
    have hleft :
        cutoff + emittedPrefix.length + 1 ≤ degree := by
      dsimp [degree]
      omega
    have hright :
        2 * cutoff + 3 ≤ degree := by
      dsimp [degree]
      omega
    calc
      initial.length * (cutoff + emittedPrefix.length + 1) + 1 +
            suffix.length * (2 * cutoff + 3) ≤
          initial.length * degree + 1 + suffix.length * degree :=
        Nat.add_le_add
          (Nat.add_le_add_right
            (Nat.mul_le_mul_left initial.length hleft) 1)
          (Nat.mul_le_mul_left suffix.length hright)
      _ = (initial.length + suffix.length) * degree + 1 := by
        rw [Nat.add_mul]
        omega
  · exact
      TCTex.IVMost.mul
        (subsequenceMultPoly
          cutoff crossed outer emittedPrefix initial)
        (subsequenceMultDiagonal
          cutoff crossed outer selected right suffix)

end FCPoly
