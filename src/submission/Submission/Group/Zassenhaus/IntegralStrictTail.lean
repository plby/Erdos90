supremum. -/
lemma active_grade_bound
    (sources : Finset (List ℕ))
    (coefficient : List ℕ → ℕ)
    (degreeBound : ℕ)
    (hdegree :
      ∀ source ∈ sources,
        coefficient source ≠ 0 →
          strictDepthGrade source + 1 ≤ degreeBound) :
    sourceGradeBound sources coefficient ≤ degreeBound := by
  unfold sourceGradeBound
  apply Finset.sup_le
  intro source hsource
  exact
    hdegree source (Finset.mem_filter.mp hsource).1
      (Finset.mem_filter.mp hsource).2

/-- Active-source grade bound for one retained transition schedule. -/
def activeGradeBound
    (cutoff : ℕ)
    (selected right : CWord Atom)
    (target : List SRTrans) :
    ℕ :=
  sourceGradeBound
    (wordsUpLength cutoff target.length).toFinset
    fun source =>
      activeSubsequenceCoefficient
        cutoff selected right source target

/-- Active-source grade bound for one crossing transition schedule. -/
def crossingGradeBound
    (cutoff : ℕ)
    (outer selected right : CWord Atom)
    (target : List SRTrans) :
    ℕ :=
  sourceGradeBound
    (wordsUpLength cutoff target.length).toFinset
    fun source =>
      activeCrossingSubsequence
        cutoff outer selected right source target

/-- The active-source retained bound is no larger than the earlier uniform
cutoff-wide estimate. -/
lemma active_grade_length
    (cutoff : ℕ)
    (selected right : CWord Atom)
    (target : List SRTrans) :
    activeGradeBound cutoff selected right target ≤
      target.length * cutoff + 1 := by
  apply active_grade_bound
  intro source hsource _hcoefficient
  have hsourceMem :
      source ∈ wordsUpLength cutoff target.length :=
    List.mem_toFinset.mp hsource
  have hsourceLt :
      ∀ depth ∈ source, depth < cutoff :=
    fun depth hdepth =>
      words_up_length
        cutoff target.length source hsourceMem depth hdepth
  have hlength :
      source.length ≤ target.length :=
    length_words_up
      cutoff target.length source hsourceMem
  exact
    Nat.add_le_add_right
      ((DRSubseq.strictGradeLength
          cutoff source hsourceLt).trans
        (Nat.mul_le_mul_right cutoff hlength))
      1

/-- The active-source crossing bound is no larger than the earlier uniform
cutoff-wide estimate. -/
lemma active_crossing_grade
    (cutoff : ℕ)
    (outer selected right : CWord Atom)
    (target : List SRTrans) :
    crossingGradeBound cutoff outer selected right target ≤
      target.length * cutoff + 1 := by
  apply active_grade_bound
  intro source hsource _hcoefficient
  have hsourceMem :
      source ∈ wordsUpLength cutoff target.length :=
    List.mem_toFinset.mp hsource
  have hsourceLt :
      ∀ depth ∈ source, depth < cutoff :=
    fun depth hdepth =>
      words_up_length
        cutoff target.length source hsourceMem depth hdepth
  have hlength :
      source.length ≤ target.length :=
    length_words_up
      cutoff target.length source hsourceMem
  exact
    Nat.add_le_add_right
      ((DSPoly.strictGradeLength
          cutoff source hsourceLt).trans
        (Nat.mul_le_mul_right cutoff hlength))
      1

/-- Retained transition-subword multiplicity has the exact finite
active-source grade bound. -/
lemma multGradeBound
    (cutoff : ℕ)
    (selected right : CWord Atom)
    (target : List SRTrans) :
    IVMost
      (fun steps : ℕ =>
        (orderedSubsequenceMultiplicity target
          (boundedStrictSchedule cutoff selected right steps) :
            ℤ))
      (activeGradeBound
        cutoff selected right target) := by
  rw [show
    (fun steps : ℕ =>
      (orderedSubsequenceMultiplicity target
        (boundedStrictSchedule cutoff selected right steps) :
          ℤ)) =
      fun steps : ℕ =>
        ∑ source ∈ (wordsUpLength cutoff target.length).toFinset,
          (activeSubsequenceCoefficient
              cutoff selected right source target : ℤ) *
            (orderedSubsequenceMultiplicity source
              (boundedDepthSchedule cutoff steps) : ℤ) by
    funext steps
    exact_mod_cast
      (by
        simpa [nsmul_eq_mul, Nat.mul_comm] using
          ordered_subsequence_words
            cutoff steps selected right target)]
  apply IVMost.finsetSum
  intro source hsource
  have hsourceMem :
      source ∈ wordsUpLength cutoff target.length :=
    List.mem_toFinset.mp hsource
  have hsourceLt :
      ∀ depth ∈ source, depth < cutoff :=
    fun depth hdepth =>
      words_up_length
        cutoff target.length source hsourceMem depth hdepth
  by_cases hcoefficient :
      activeSubsequenceCoefficient
        cutoff selected right source target =
      0
  · simp only [hcoefficient, Int.ofNat_zero, zero_mul]
    exact
      TCTex.IVMost.zero
        (activeGradeBound
          cutoff selected right target)
  · apply
      TCTex.IVMost.smul
    apply
      TCTex.IVMost.mono
    · exact
        strict_grade_bound
          (wordsUpLength cutoff target.length).toFinset
          (fun next =>
            activeSubsequenceCoefficient
              cutoff selected right next target)
          source hsource hcoefficient
    · exact
        subsequence_multiplicity_strict
          cutoff source hsourceLt

/-- Crossing transition-subword multiplicity has the exact finite
active-source grade bound. -/
lemma subsequenceMultGrade
    (cutoff : ℕ)
    (outer selected right : CWord Atom)
    (target : List SRTrans) :
    IVMost
      (fun steps : ℕ =>
        (orderedSubsequenceMultiplicity target
          (depthCrossingSchedule cutoff outer selected right
            steps) : ℤ))
      (crossingGradeBound
        cutoff outer selected right target) := by
  rw [show
    (fun steps : ℕ =>
      (orderedSubsequenceMultiplicity target
        (depthCrossingSchedule cutoff outer selected right steps) :
          ℤ)) =
      fun steps : ℕ =>
        ∑ source ∈ (wordsUpLength cutoff target.length).toFinset,
          (activeCrossingSubsequence
              cutoff outer selected right source target : ℤ) *
            (orderedSubsequenceMultiplicity source
              (boundedDepthSchedule cutoff steps) : ℤ) by
    funext steps
    exact_mod_cast
      (by
        simpa [nsmul_eq_mul, Nat.mul_comm] using
          subsequence_multiplicity_words
            cutoff steps outer selected right target)]
  apply IVMost.finsetSum
  intro source hsource
  have hsourceMem :
      source ∈ wordsUpLength cutoff target.length :=
    List.mem_toFinset.mp hsource
  have hsourceLt :
      ∀ depth ∈ source, depth < cutoff :=
    fun depth hdepth =>
      words_up_length
        cutoff target.length source hsourceMem depth hdepth
  by_cases hcoefficient :
      activeCrossingSubsequence
        cutoff outer selected right source target =
      0
  · simp only [hcoefficient, Int.ofNat_zero, zero_mul]
    exact
      TCTex.IVMost.zero
        (crossingGradeBound
          cutoff outer selected right target)
  · apply
      TCTex.IVMost.smul
    apply
      TCTex.IVMost.mono
    · exact
        strict_grade_bound
          (wordsUpLength cutoff target.length).toFinset
          (fun next =>
            activeCrossingSubsequence
              cutoff outer selected right next target)
          source hsource hcoefficient
    · exact
        subsequence_multiplicity_strict
          cutoff source hsourceLt

/-- Any later bound on the active retained-source grade supremum gives the
corresponding polynomial degree theorem immediately. -/
lemma mult_grade_bound
    (cutoff degreeBound : ℕ)
    (selected right : CWord Atom)
    (target : List SRTrans)
    (hdegree :
      activeGradeBound cutoff selected right target ≤
        degreeBound) :
    IVMost
      (fun steps : ℕ =>
        (orderedSubsequenceMultiplicity target
          (boundedStrictSchedule cutoff selected right steps) :
            ℤ))
      degreeBound := by
  exact
    TCTex.IVMost.mono
      hdegree
      (multGradeBound
        cutoff selected right target)

/-- Any later bound on the active crossing-source grade supremum gives the
corresponding polynomial degree theorem immediately. -/
lemma subsequence_mult_grade
    (cutoff degreeBound : ℕ)
    (outer selected right : CWord Atom)
    (target : List SRTrans)
    (hdegree :
      crossingGradeBound
          cutoff outer selected right target ≤
        degreeBound) :
    IVMost
      (fun steps : ℕ =>
        (orderedSubsequenceMultiplicity target
          (depthCrossingSchedule cutoff outer selected right
            steps) : ℤ))
      degreeBound := by
  exact
    TCTex.IVMost.mono
      hdegree
      (subsequenceMultGrade
        cutoff outer selected right target)

end ASGrade
end TCTex
