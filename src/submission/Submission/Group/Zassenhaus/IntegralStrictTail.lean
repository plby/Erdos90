        (right :: rights) vector =
      boundedConstantOperator cutoff
        (moveCrossingPacket cutoff outer selected right)
        (crossingSubstitutionOperator cutoff outer selected
          rights vector) := by
  rw [show
    right :: rights = [right] ++ rights by rfl,
    substitution_operator_append]
  simp [crossingSubstitutionOperator,
    crossingSubstitutionSchedule]

