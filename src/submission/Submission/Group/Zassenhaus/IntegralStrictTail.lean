lemma map_flatMap
    {α β γ : Type*}
    (mapEntry : β → γ) :
    ∀ (source : List α) (packetAt : α → List β),
      (source.flatMap packetAt).map mapEntry =
        source.flatMap fun item => (packetAt item).map mapEntry
  | [], _packetAt => by
      rfl
  | _item :: source, packetAt => by
      simp only [List.flatMap_cons, List.map_append]
      rw [map_flatMap mapEntry source packetAt]

