/-!
# Affine cutoff profiles for Hall-Witt residual sources

The positive and negative Hall-Witt residual sources are each concatenations
of three repeated fixed packets:

1. one normalized Hall-Witt packet;
2. one first-family descendant singleton;
3. one second-family descendant singleton.

Compile the first stable-routing pass into an explicit composition of three
iterated affine cutoff-profile transformations.  The final strict tail is the
second compiled route applied to that first routed trace.

This file isolates the remaining global polynomial problem: compile the
second route when its literal first-pass input varies with the coefficient.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace ARProf

open WSTrace
open WHNorm
open WNTrace
open WSTail
open NPTail
open TBProf
open ARProfa
open ARProfa.CPAffine

/-- Positive first-pass affine action: normalized packet, `B`, then `C⁻¹`. -/
def naturalPassAffine
  (cutoff multiplicity : ℕ) :
    CPAffine :=
  ((iterate
        (ofTrace cutoff isFirstCurrent WNTrace.trace)
        multiplicity).comp
      (iterate (ofTrace cutoff isFirstCurrent [firstConventionalWord])
        multiplicity)).comp
    (iterate
      (ofTrace cutoff isFirstCurrent [secondConventionalInverse])
        multiplicity)

/-- The positive first routed cutoff profile is the explicit three-block
affine action from zero. -/
lemma profile_routed_fst
    (cutoff multiplicity : ℕ) :
    cutoffProfile cutoff
        (NPTail.firstRouted multiplicity).1 =
      (naturalPassAffine cutoff multiplicity).apply 0 := by
  rw [NPTail.firstRouted,
    profile_stable_fst,
    NPTail.naturalResidualTrace,
    ← repeatTrace_singleton firstConventionalWord multiplicity,
    ← repeatTrace_singleton secondConventionalInverse multiplicity,
    ofTrace_append, ofTrace_append, trace_repeat, trace_repeat,
    trace_repeat]
  rfl

/-- The positive strict tail is the second compiled route applied to the
literal positive first-pass output. -/
lemma cutoff_natural_strict
    (cutoff multiplicity : ℕ) :
    cutoffProfile cutoff
        (NPTail.strictTrace multiplicity) =
      (ofTrace cutoff isSecondCurrent
        (NPTail.firstRouted multiplicity).1).apply
          0 := by
  rw [NPTail.strictTrace,
    NPTail.secondRouted,
    profile_stable_fst]

/-- Negative first-pass affine action: inverse normalized packet, `B⁻¹`, then
`C`. -/
def negativePassAffine
    (cutoff multiplicity : ℕ) :
    CPAffine :=
  ((iterate
        (ofTrace cutoff isFirstCurrent
          NNPower.inverseNormalizedTrace)
        multiplicity).comp
      (iterate
        (ofTrace cutoff isFirstCurrent [firstConventionalInverse])
        multiplicity)).comp
    (iterate (ofTrace cutoff isFirstCurrent [secondConventionalWord])
      multiplicity)

/-- The negative first routed cutoff profile is the explicit three-block
affine action from zero. -/
lemma cutoff_routed_fst
    (cutoff multiplicity : ℕ) :
    cutoffProfile cutoff
        (NNPower.firstRouted
          multiplicity).1 =
      (negativePassAffine cutoff multiplicity).apply 0 := by
  rw [NNPower.firstRouted,
    profile_stable_fst,
    NNPower.naturalResidualTrace,
    ← repeatTrace_singleton firstConventionalInverse multiplicity,
    ← repeatTrace_singleton secondConventionalWord multiplicity,
    ofTrace_append, ofTrace_append, trace_repeat, trace_repeat,
    trace_repeat]
  rfl

/-- The negative strict tail is the second compiled route applied to the
literal negative first-pass output. -/
lemma cutoff_negative_strict
    (cutoff multiplicity : ℕ) :
    cutoffProfile cutoff
        (NNPower.strictTrace
          multiplicity) =
      (ofTrace cutoff isSecondCurrent
        (NNPower.firstRouted
          multiplicity).1).apply 0 := by
  rw [NNPower.strictTrace,
    NNPower.secondRouted,
    profile_stable_fst]

end ARProf
end TCTex
end Submission

