/-- Maximum grade of a finite family of source-depth words with nonzero fixed
coefficient. -/
def sourceGradeBound
    (sources : Finset (List ℕ))
    (coefficient : List ℕ → ℕ) :
    ℕ :=
  (sources.filter fun source => coefficient source ≠ 0).sup
    fun source => strictDepthGrade source + 1

/-- Every active source word lies below the support-sensitive grade bound. -/
lemma strict_grade_bound
    (sources : Finset (List ℕ))
    (coefficient : List ℕ → ℕ)
    (source : List ℕ)
    (hsource : source ∈ sources)
    (hcoefficient : coefficient source ≠ 0) :
    strictDepthGrade source + 1 ≤
      sourceGradeBound sources coefficient := by
  unfold sourceGradeBound
  exact
    Finset.le_sup
      (s := sources.filter fun next => coefficient next ≠ 0)
      (f := fun next => strictDepthGrade next + 1)
      (Finset.mem_filter.mpr ⟨hsource, hcoefficient⟩)

