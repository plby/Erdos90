    (cutoff : ℕ)
    (selected : CWord Atom)
    (trace : List (CWord Atom)) :
    List OCTerm :=
  boundedConstantTerms cutoff
    (trace.map (SRTrans.crossed selected))

/-- Crossing a fixed supported trace prefix preserves bounded-term polynomial
data for a variable crossed suffix. -/
lemma BCDataa.crossing_append
    {cutoff degreeBound : ℕ}
    (selected : CWord Atom)
    (hselected : isFirstCurrent selected = true)
    (left : List (CWord Atom))
    (hleft : TSVocabu cutoff left)
    {right : ℕ → List (CWord Atom)}
    (hright :
      BCDataa cutoff degreeBound
        (fun steps =>
          crossingConstantTerms cutoff selected
            (right steps))) :
    BCDataa cutoff degreeBound
      (fun steps =>
        crossingConstantTerms cutoff selected
          (left ++ right steps)) := by
  apply
    (hright.fixedPrefix
      (left.map (SRTrans.crossed selected))
        (fun transition htransition =>
          second_alphabet_crossed
            cutoff selected hselected left hleft transition htransition)).congr
  intro steps
  simp [crossingConstantTerms]

/-- Polynomiality after one triangular prefix-plus-substitution trace step
reduces to polynomiality of the locally substituted crossing family. -/
lemma iterate_substitution_flat
    (cutoff degreeBound : ℕ)
    (outer selected : CWord Atom)
    (houter : isFirstCurrent outer = true)
    (emittedPrefix : List (CWord Atom))
    (hemittedPrefix :
      TSVocabu cutoff emittedPrefix)
    (tail : ℕ → List (CWord Atom))
    (hsubstitution :
      BCDataa cutoff degreeBound
        (fun steps =>
          crossingConstantTerms cutoff outer
            ((iteratePrefixSubstitution emittedPrefix
              (cutoffMovePacket cutoff selected) steps
                (tail steps)).flatMap
                  (cutoffMovePacket cutoff selected)))) :
    BCDataa cutoff degreeBound
      (fun steps =>
        crossingConstantTerms cutoff outer
          (iteratePrefixSubstitution emittedPrefix
            (cutoffMovePacket cutoff selected) (steps + 1)
              (tail steps))) := by
  apply
    (BCDataa.crossing_append
      outer houter emittedPrefix hemittedPrefix hsubstitution).congr
  intro steps
  rfl

/-- Positive triangular outer-trace substitution preserves crossing
polynomiality once its locally substituted crossing family is polynomial. -/
