/--
Physically filtering a bound trace is unchanged if words outside the formal
unit-label cutoff are discarded before binding.
-/
lemma filter_bind_unit
    {α β : Type*}
    (wt : β → ℕ)
    (substitution : α → CWord β)
    (hsubstitution : ∀ atom, 0 < (substitution atom).weight wt)
    (cutoff : ℕ) :
    ∀ source : List (CWord α),
      ((source.map fun word => word.bind substitution).filter fun word =>
          decide (word.weight wt < cutoff)) =
        (((source.filter fun word =>
            decide (word.weight (fun _ => 1) < cutoff)).map fun word =>
              word.bind substitution).filter fun word =>
                decide (word.weight wt < cutoff))
  | [] => rfl
  | word :: source => by
      simp only [List.map_cons, List.filter_cons, decide_eq_true_eq]
      by_cases hbound : (word.bind substitution).weight wt < cutoff
      · have hbound' :
            word.weight (fun atom => (substitution atom).weight wt) <
              cutoff := by
          simpa only [CWord.weight_bind] using hbound
        have hformal : word.weight (fun _ => 1) < cutoff :=
          (weight_bind_positive
            wt substitution hsubstitution word).trans_lt hbound
        simp [hbound', hformal,
          filter_bind_unit
            wt substitution hsubstitution cutoff source]
      · have hbound' :
            ¬word.weight (fun atom => (substitution atom).weight wt) <
              cutoff := by
          simpa only [CWord.weight_bind] using hbound
        by_cases hformal : word.weight (fun _ => 1) < cutoff <;>
          simp [hbound', hformal,
            filter_bind_unit
              wt substitution hsubstitution cutoff source]

/--
Formal cutoff filtering may be inserted before any positive Hall-Witt label
substitution without changing the physically retained bound trace.
-/
lemma filter_bind_positive
    {β : Type*}
    (wt : β → ℕ)
    (substitution : Atom → CWord β)
    (hsubstitution : ∀ atom, 0 < (substitution atom).weight wt)
    (cutoff : ℕ)
    (coefficient : ℤ) :
    (((unitBelowTrace cutoff (strictTrace coefficient)).map fun word =>
        word.bind substitution).filter fun word =>
          decide (word.weight wt < cutoff)) =
      (bindTrace substitution coefficient).filter fun word =>
        decide (word.weight wt < cutoff) := by
  exact
    (filter_bind_unit
      wt substitution hsubstitution cutoff (strictTrace coefficient)).symm

/--
Evaluate the finite signed Newton family, bind every retained formal slot,
and then retain exactly the physically below-cutoff substituted slots.
-/
noncomputable def bindFilteredReconstructed
    {β : Type*}
    (wt : β → ℕ)
    (substitution : Atom → CWord β)
    (cutoff : ℕ)
    (coefficient : ℤ) :
    Multiset (CWord β) :=
  ((reconstructedIntegralProfile cutoff coefficient).map
      fun word => word.bind substitution).filter fun word =>
        word.weight wt < cutoff

/--
The finite signed Newton family reconstructs the complete physically retained
bound Hall-Witt strict-tail profile after any positive-weight substitution.
-/
lemma bind_reconstructed_profile
    {β : Type*}
    (wt : β → ℕ)
    (substitution : Atom → CWord β)
    (hsubstitution : ∀ atom, 0 < (substitution atom).weight wt)
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (coefficient : ℤ) :
    bindFilteredReconstructed
        wt substitution cutoff coefficient =
      ↑((bindTrace substitution coefficient).filter fun word =>
        decide (word.weight wt < cutoff)) := by
  unfold bindFilteredReconstructed
  rw [reconstructed_integral_profile
    cutoff hcutoff coefficient]
  unfold cutoffProfile
  simpa only [Multiset.map_coe, Multiset.filter_coe] using
    congrArg (fun source : List (CWord β) =>
      (↑source : Multiset (CWord β)))
