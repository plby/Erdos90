-- iatedGradedPolynomialConcreteHallRecipeFullTraceResidual.lean

/-!
# Full strict-tail residual after concrete Hall recollection

At the truncation-compatible cutoff `n`, every strict-tail factor discarded
by the physical cutoff has weight at least `n` and therefore evaluates
trivially in the free lower-central truncation of class `n - 1`.  Thus the
retained-trace residual theorem lifts to the complete signed strict trace and
to its explicit Hall-Witt Jacobi residual.

This file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace
  RTResid

open CWTrace
open STSubsti
open TOCoordi
open
  SAGraded
open
  GPBasis
open
  PRResid

universe u


/--
A Hall-address word whose physical weight reaches the truncation cutoff
evaluates trivially in the free lower-central truncation.
-/
lemma exponent_address_n
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (word : CWord (HEAddres H))
    (hword :
      n ≤ word.weight PEAddres.weight) :
    word.eval
        (PEAddres.freeLowerTruncation (n := n)) =
      1 := by
  apply
    eq_bot_iff.mp
      SPFactora.trunc_last_bot
  exact
    Subgroup.lowerCentralSeries_antitone (Nat.sub_le_sub_right hword 1)
      (CWord.eval_lower_series
        (PEAddres.freeLowerTruncation (n := n))
        PEAddres.weight PEAddres.weight_pos
        PEAddres.free_truncation_series
        word)

/--
Deleting Hall-address words of weight at least the truncation cutoff preserves
the ordered list evaluation in the free lower-central truncation.
-/
lemma filter_address_n
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (words : List (CWord (HEAddres H))) :
    wordListEval
        (PEAddres.freeLowerTruncation (n := n))
        (words.filter fun word =>
          decide (word.weight PEAddres.weight < n)) =
      wordListEval
        (PEAddres.freeLowerTruncation (n := n))
        words := by
  induction words with
  | nil =>
      rfl
  | cons word words ih =>
      by_cases hword :
          word.weight PEAddres.weight < n
      · simp [hword, ih]
      · have hnword :
            n ≤ word.weight PEAddres.weight :=
          Nat.le_of_not_gt hword
        simp [hword, ih,
          exponent_address_n word hnword]

/--
At cutoff `n`, the retained signed trace and the complete signed trace have
the same ordered evaluation in the free lower-central truncation.
-/
lemma address_below_strict
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (coefficient : ℤ) :
    wordListEval
        (PEAddres.freeLowerTruncation (n := n))
        (signedBelowTrace PEAddres.weight
          x y z n coefficient) =
      wordListEval
        (PEAddres.freeLowerTruncation (n := n))
        (signedStrictTrace x y z coefficient) := by
  exact
    filter_address_n
      (signedStrictTrace x y z coefficient)

/--
The attached retained lower-central representatives have exactly the literal
ordered retained-trace product as their underlying group value.
-/
lemma coe_address_below
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (coefficient : ℤ) :
    ((addressBelowTerms
        (n := n) x y z cutoff coefficient).prod :
      LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n) =
        wordListEval
          (PEAddres.freeLowerTruncation (n := n))
          (signedBelowTrace PEAddres.weight
            x y z cutoff coefficient) := by
  simp [addressBelowTerms,
    wordListEval]

/--
If the next strict-tail parent layer survives the truncation, then the
truncation cutoff is automa above three.
-/
lemma address_parent_succ
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (hparent :
      exponentAddressParent x y z + 1 < n) :
    3 < n := by
  have hx :=
    CWord.weight_pos PEAddres.weight
      PEAddres.weight_pos x
  have hy :=
    CWord.weight_pos PEAddres.weight
      PEAddres.weight_pos y
  have hz :=
    CWord.weight_pos PEAddres.weight
      PEAddres.weight_pos z
  change
    x.weight PEAddres.weight +
          y.weight PEAddres.weight +
        z.weight PEAddres.weight + 1 < n at hparent
  omega

/--
Removing the signed concrete Hall recipe segment from the complete strict-tail
product leaves a residual in the next lower-central layer.
-/
theorem address_signed_next
    (d n : ℕ)
    (x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d)))
    (hparent :
      exponentAddressParent x y z + 1 < n)
    (coefficient : ℤ) :
    ((concreteCommutatorsWeight.{u} d
      (exponentAddressParent x y z + 1)).collectedWeightProduct
        (n := n)
        (concreteAddressCoordinates
          d n x y z n coefficient hparent))⁻¹ *
      wordListEval
        (PEAddres.freeLowerTruncation (n := n))
        (signedStrictTrace x y z coefficient) ∈
        Subgroup.lowerCentralSeries
          (LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n)
          (exponentAddressParent x y z + 1) := by
  rw [←
    address_below_strict
      x y z coefficient]
  rw [←
    coe_address_below
      x y z n coefficient]
  exact
    address_prod_next
      d n x y z n
        (address_parent_succ
          x y z hparent)
        hparent coefficient

/--
Explicit Hall-Witt Jacobi-residual form of the complete strict-tail
recollection theorem.
-/
theorem address_jacobi_next
    (d n : ℕ)
    (x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d)))
    (hparent :
      exponentAddressParent x y z + 1 < n)
    (hx : ∃ left right, x = .commutator left right)
    (hy : ∃ left right, y = .commutator left right)
    (hz : ∃ left right, z = .commutator left right)
    (coefficient : ℤ) :
    ((concreteCommutatorsWeight.{u} d
      (exponentAddressParent x y z + 1)).collectedWeightProduct
        (n := n)
        (concreteAddressCoordinates
