                (exponentAddressParent x y z)
                (addressBelowTerms
                  (n := n) x y z cutoff (Int.ofNat multiplicity)).prod) := by
  unfold
    concreteAddressVector
  rw [List.map_map]
  apply List.map_congr_left
  intro i _hi
  rw [Function.comp_apply,
    address_parent_basis
      d n x y z cutoff hcutoff hparent i]

