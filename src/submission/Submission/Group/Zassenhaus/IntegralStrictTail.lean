open PKRed
open FRMiddle

/-- Iterating packet prefixing preserves well-formed moved-node provenance. -/
lemma current_moves_prepend
    (cutoff : ℕ)
    (packet : List (CWord Atom))
    (tail : FRProgra)
    (htail : FirstCurrentMoves tail) :
    ∀ steps,
      FirstCurrentMoves
        (iteratePrepend cutoff isFirstCurrent packet steps tail)
  | 0 =>
      htail
  | steps + 1 =>
      first_moves_prepend cutoff packet
        (iteratePrepend cutoff isFirstCurrent packet steps tail)
          (current_moves_prepend cutoff packet tail htail steps)

/-- Every bounded term generated from an iterated packet program belongs to
the fixed cutoff alphabet. -/
lemma supportedIteratePrepend
    (cutoff : ℕ)
    (packet : List (CWord Atom))
    (tail : FRProgra)
    (htail : FirstCurrentMoves tail)
    (steps : ℕ) :
    SCAlphab cutoff
      (boundedConstantTerms cutoff
        (transitionSchedule cutoff
          (iteratePrepend cutoff isFirstCurrent packet steps tail))) := by
  apply
    supported_alphabet_terms
  intro transition htransition
  exact
    transition_alphabet_schedule cutoff
      (iteratePrepend cutoff isFirstCurrent packet steps tail)
        (current_moves_prepend cutoff packet tail htail steps)
          transition htransition

/-- Slot evaluation of a literal supported count state is the corresponding
evaluated bounded-term profile count. -/
lemma bounded_constant_profile
    (cutoff : ℕ)
    (terms : List OCTerm)
    (hterms :
      SCAlphab cutoff terms)
    (slot : CWord Atom) :
    boundedStateSlot cutoff
        (boundedCountState terms) slot =
      (Multiset.count slot
        (evaluatedConstantProfile cutoff terms) : ℤ) := by
  unfold boundedStateSlot boundedCountState
  rw [
    count_evaluated_alphabet
      cutoff terms hterms slot]
  simp only [Nat.cast_sum, Nat.cast_mul]
  apply Finset.sum_congr rfl
  intro term _hterm
  ring

/-- Slot evaluation commutes with signed Newton evaluation of bounded-term
count states. -/
lemma slot_newton_evaluation
    (cutoff degreeBound : ℕ)
    (family : ℕ → BoundedCountState)
    (slot : CWord Atom) :
    boundedStateSlot cutoff
        (newtonEvaluationState degreeBound family) slot =
      newtonSignedEvaluation degreeBound
        (fun steps =>
          boundedStateSlot cutoff (family steps) slot) := by
  unfold boundedStateSlot newtonEvaluationState
    newtonSignedEvaluation
  simpa using
    (successor_alternating_finset
      degreeBound (boundedConstantAlphabet cutoff).toFinset
        (fun term => (Multiset.count slot (term.eval cutoff) : ℤ))
          (fun term steps => family steps term)).symm

/-- Signed slot evaluation of a supported variable bounded-term schedule is
the signed Newton value of its actual affine endpoint coordinate. -/
lemma schedule_affine_zero
    (cutoff degreeBound : ℕ)
    (hcutoff : 0 < cutoff)
    (schedule : ℕ → List SRTrans)
    (hschedule :
      ∀ steps,
        SCAlphab cutoff
          (boundedConstantTerms cutoff (schedule steps)))
    (slot : CWord Atom) :
    boundedStateSlot cutoff
        (newtonEvaluationState degreeBound
          (fun steps =>
            boundedConstantState
              (boundedConstantTerms cutoff (schedule steps)))) slot =
      newtonSignedEvaluation degreeBound
        (fun steps =>
          (Multiset.count slot
            ((scheduleAffine cutoff (schedule steps)).apply 0) : ℤ)) := by
  rw [slot_newton_evaluation]
  apply congrArg (newtonSignedEvaluation degreeBound)
  funext steps
  unfold boundedConstantState
  rw [
    bounded_constant_profile
      cutoff (boundedConstantTerms cutoff (schedule steps))
        (hschedule steps) slot,
    affine_constant_terms cutoff hcutoff]
  rfl

/-- Positive literal packet-state evaluation is the signed Newton value of
the positive literal packet affine endpoint. -/
lemma natural_schedule_affine
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (slot : CWord Atom) :
    boundedStateSlot cutoff
        (naturalEmptyState cutoff) slot =
      newtonSignedEvaluation
        (naturalFullBound cutoff)
        (fun steps =>
          (Multiset.count slot
            ((scheduleAffine cutoff
              (transitionSchedule cutoff
                (iteratePrepend cutoff isFirstCurrent
                  WNTrace.trace
                    (steps + 1) .empty))).apply 0) : ℤ)) := by
  unfold naturalEmptyState
  apply
    schedule_affine_zero
      cutoff (naturalFullBound cutoff) hcutoff
  intro steps
  exact
    supportedIteratePrepend
      cutoff WNTrace.trace .empty trivial (steps + 1)

/-- Negative literal packet-state evaluation is the signed Newton value of
the negative literal packet affine endpoint. -/
lemma negative_schedule_affine
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (slot : CWord Atom) :
    boundedStateSlot cutoff
        (emptySuccessorState cutoff) slot =
      newtonSignedEvaluation
        (negativeFullBound cutoff)
        (fun steps =>
          (Multiset.count slot
            ((scheduleAffine cutoff
              (transitionSchedule cutoff
                (iteratePrepend cutoff isFirstCurrent
                  NNPower.inverseNormalizedTrace
                    (steps + 1) .empty))).apply 0) : ℤ)) := by
  unfold emptySuccessorState
  apply
    schedule_affine_zero
      cutoff (negativeFullBound cutoff) hcutoff
  intro steps
  exact
    supportedIteratePrepend
      cutoff
        NNPower.inverseNormalizedTrace
          .empty trivial (steps + 1)

/-- Positive packet-local affine endpoint cancellation at formal predecessor
input. -/
def NaturalEmptyNewton
    (cutoff : ℕ) :
    Prop :=
  ∀ slot,
    newtonSignedEvaluation
      (naturalFullBound cutoff)
      (fun steps =>
        (Multiset.count slot
          ((scheduleAffine cutoff
            (transitionSchedule cutoff
              (iteratePrepend cutoff isFirstCurrent
                WNTrace.trace
                  (steps + 1) .empty))).apply 0) : ℤ)) = 0

/-- Negative packet-local affine endpoint cancellation at formal predecessor
input. -/
def SuccessorSatisfiesNewton
    (cutoff : ℕ) :
    Prop :=
  ∀ slot,
    newtonSignedEvaluation
      (negativeFullBound cutoff)
      (fun steps =>
        (Multiset.count slot
          ((scheduleAffine cutoff
            (transitionSchedule cutoff
              (iteratePrepend cutoff isFirstCurrent
                NNPower.inverseNormalizedTrace
                  (steps + 1) .empty))).apply 0) : ℤ)) = 0

/-- Positive packet-state cancellation is exactly the positive literal affine
endpoint Newton-kernel identity. -/
lemma natural_empty_newton
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff) :
    NaturalEmptySuccessor
        cutoff ↔
      NaturalEmptyNewton
        cutoff := by
  apply forall_congr'
  intro slot
  rw [
    natural_schedule_affine
      cutoff hcutoff slot]

/-- Negative packet-state cancellation is exactly the negative literal affine
endpoint Newton-kernel identity. -/
lemma empty_affine_newton
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff) :
    EmptySuccessorState
        cutoff ↔
      SuccessorSatisfiesNewton
        cutoff := by
  apply forall_congr'
  intro slot
  rw [
    negative_schedule_affine
      cutoff hcutoff slot]

/-- The positive literal affine endpoint kernel discharges global positive
strict-tail cutoff-profile polynomiality. -/
lemma natural_affine_newton
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (hkernel :
      NaturalEmptyNewton
        cutoff) :
    CPDataa cutoff
      (naturalStrictBound cutoff)
      (fun multiplicity =>
        cutoffProfile cutoff
          (NPTail.strictTrace multiplicity)) := by
  apply cutoff_natural_prefix
    cutoff hcutoff
  apply
    (empty_successor_prefix
      cutoff).1
  apply
    (natural_empty_newton
      cutoff (by omega)).2
  exact hkernel

/-- The negative literal affine endpoint kernel discharges global negative
strict-tail cutoff-profile polynomiality. -/
lemma affine_endpoint_newton
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (hkernel :
      SuccessorSatisfiesNewton
        cutoff) :
    CPDataa cutoff
      (negativeStrictBound cutoff)
      (fun multiplicity =>
        cutoffProfile cutoff
          (NNPower.strictTrace
            multiplicity)) := by
  apply cutoff_negative_prefix
    cutoff hcutoff
  apply
    (negative_empty_prefix
      cutoff).1
  apply
    (empty_affine_newton
      cutoff (by omega)).2
  exact hkernel

