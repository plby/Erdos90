/-!
# Functional coordinates of associated-graded Hall-Witt profile recipes

The fixed-slot associated-graded Hall-Witt formulas may be tested against any
additive integer-valued functional.  The resulting positive and shifted-negative
coordinates are finite sums of fixed integer multiples of the slot
polynomials, hence are themselves bounded integer-valued polynomials.

This is the coordinate-level handoff needed by later Hall-basis projections.
The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace
  AGFunc

open TEAddres
open PMExp
open
  GSVector
open
  SAGraded
open
  AGPoly

universe u


/-- Finite sums preserve a common integer-valued polynomial degree bound. -/
private lemma polynomial_finsetSum
    {ι : Type*}
    {degreeBound : ℕ}
    (slots : Finset ι)
    (family : ι → ℕ → ℤ)
    (hfamily :
      ∀ slot ∈ slots,
        IVMost
          (family slot) degreeBound) :
    IVMost
      (fun steps : ℕ => ∑ slot ∈ slots, family slot steps)
      degreeBound := by
  classical
  induction slots using Finset.induction_on with
  | empty =>
      simpa using
        TCTex.IVMost.zero
          degreeBound
  | @insert slot slots hslot ih =>
      simpa [Finset.sum_insert hslot] using
        TCTex.IVMost.add
          (hfamily slot (by simp))
          (ih (fun next hnext => hfamily next (by simp [hnext])))

/--
The positive-branch coordinate obtained by applying one fixed additive
functional to the associated-graded Hall-Witt correction profile.
-/
noncomputable def addressGradedFunctional
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (coordinate :
      Additive
          (TBluepr.LowerGradedLayer
            (LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n)
            (x.weight PEAddres.weight +
                y.weight PEAddres.weight +
              z.weight PEAddres.weight)) →+
        ℤ) :
    ℕ → ℤ :=
  fun multiplicity =>
    ∑ word ∈
        (signedDeduplicatedVocabulary x y z cutoff).toFinset,
      coordinate
          (addressSlotClass
            (n := n) x y z word) *
        addressNaturalSlot
          x y z cutoff word multiplicity

/--
The shifted-negative-branch coordinate obtained by applying one fixed
additive functional to the associated-graded Hall-Witt correction profile.
-/
noncomputable def associatedGradedFunctional
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (coordinate :
      Additive
          (TBluepr.LowerGradedLayer
            (LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n)
            (x.weight PEAddres.weight +
                y.weight PEAddres.weight +
              z.weight PEAddres.weight)) →+
        ℤ) :
    ℕ → ℤ :=
  fun magnitude =>
    ∑ word ∈
        (signedDeduplicatedVocabulary x y z cutoff).toFinset,
      coordinate
          (addressSlotClass
            (n := n) x y z word) *
        addressSlotCoefficient
          x y z cutoff word magnitude

/-- Positive functional coordinates satisfy the global strict-tail bound. -/
lemma address_graded_functional
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (coordinate :
      Additive
          (TBluepr.LowerGradedLayer
            (LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n)
            (x.weight PEAddres.weight +
                y.weight PEAddres.weight +
              z.weight PEAddres.weight)) →+
        ℤ) :
    IVMost
      (addressGradedFunctional
        x y z cutoff coordinate)
      (naturalStrictBound cutoff) := by
  unfold
    addressGradedFunctional
  apply polynomial_finsetSum
  intro word _hword
  simpa only [Pi.smul_apply, smul_eq_mul] using
    TCTex.IVMost.smul
      (coordinate
        (addressSlotClass
          (n := n) x y z word))
      (address_natural_slot
        x y z cutoff word)

/--
Shifted-negative functional coordinates satisfy the global strict-tail bound.
-/
lemma associated_graded_functional
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (coordinate :
      Additive
          (TBluepr.LowerGradedLayer
            (LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n)
            (x.weight PEAddres.weight +
                y.weight PEAddres.weight +
              z.weight PEAddres.weight)) →+
        ℤ) :
    IVMost
      (associatedGradedFunctional
        x y z cutoff coordinate)
      (negativeStrictBound cutoff) := by
  unfold
    associatedGradedFunctional
  apply polynomial_finsetSum
  intro word _hword
  simpa only [Pi.smul_apply, smul_eq_mul] using
    TCTex.IVMost.smul
      (coordinate
        (addressSlotClass
          (n := n) x y z word))
      (address_negative_slot
        x y z cutoff word)

/--
On the positive branch, the explicit functional coefficient is the functional
applied to the associated-graded class of the ordered retained product.
-/
lemma address_natural_prod
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (coordinate :
      Additive
          (TBluepr.LowerGradedLayer
            (LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n)
            (x.weight PEAddres.weight +
                y.weight PEAddres.weight +
              z.weight PEAddres.weight)) →+
        ℤ)
    (multiplicity : ℕ) :
    addressGradedFunctional
        x y z cutoff coordinate multiplicity =
      coordinate
        (TBluepr.lowerCentralClass
          (x.weight PEAddres.weight +
              y.weight PEAddres.weight +
            z.weight PEAddres.weight)
          (addressBelowTerms
            (n := n) x y z cutoff (Int.ofNat multiplicity)).prod) := by
  rw [
    lower_cast_poly
      x y z cutoff hcutoff multiplicity]
  simp [addressGradedFunctional,
    mul_comm]

/--
On the negative branch, the explicit functional coefficient is the functional
applied to the associated-graded class of the ordered retained product.
-/
lemma address_negative_prod
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
