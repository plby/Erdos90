/-!
# Polynomial subsequence coordinates for bounded strict-depth schedules

Every predecessor requested by the triangular strict-depth parser remains
below a cutoff whenever the target word does.  The filtered semantic
successor equation can therefore be iterated without leaving the supported
finite alphabet.

This identifies every supported ordered-subsequence coordinate of the
concrete bounded strict-depth schedule with an abstract triangular iterate,
and hence with an integer-valued polynomial of controlled degree.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace BDSubseq

open DSRec
open BSRec
open BSPoly
open DSSem
open SFSem

/-- Every predecessor requested by the strict-depth parser remains below the
same cutoff as its target word. -/
lemma cutoff_predecessor_patterns
    (cutoff : ℕ) :
    ∀ (target previous : List ℕ),
      (∀ depth ∈ target, depth < cutoff) →
        previous ∈ strictPredecessorPatterns target →
          ∀ depth ∈ previous, depth < cutoff
  | [], previous, _htarget, hprevious => by
      rw [strictPredecessorPatterns.eq_def] at hprevious
      simp only [List.mem_singleton] at hprevious
      subst previous
      simp
  | targetHead :: targetTail, previous, htarget, hprevious => by
      rw [strictPredecessorPatterns.eq_def] at hprevious
      simp only [List.mem_append, List.mem_map] at hprevious
      rcases hprevious with (hprevious | hprevious) | hprevious
      · rcases hprevious with ⟨prior, hprior, rfl⟩
        intro depth hdepth
        rw [List.mem_cons] at hdepth
        rcases hdepth with rfl | hdepth
        · exact htarget _ (by simp)
        · exact
            cutoff_predecessor_patterns cutoff
              targetTail prior
              (fun next hnext => htarget next (by simp [hnext]))
              hprior depth hdepth
      · by_cases htargetHeadPos : 0 < targetHead
        · simp only [htargetHeadPos, ↓reduceIte, List.mem_map] at hprevious
          rcases hprevious with ⟨prior, hprior, rfl⟩
          intro depth hdepth
          rw [List.mem_cons] at hdepth
          rcases hdepth with rfl | hdepth
          · have htargetHeadLt :
                targetHead < cutoff :=
              htarget targetHead (by simp)
            omega
          · exact
              cutoff_predecessor_patterns cutoff
                targetTail prior
                (fun next hnext => htarget next (by simp [hnext]))
                hprior depth hdepth
        · simp [htargetHeadPos] at hprevious
      · cases targetTail with
        | nil =>
            simp at hprevious
        | cons targetSecond targetRest =>
            by_cases hdouble : targetHead = targetSecond + 1
            · simp only [hdouble, ↓reduceIte, List.mem_map] at hprevious
              rcases hprevious with ⟨prior, hprior, rfl⟩
              intro depth hdepth
              rw [List.mem_cons] at hdepth
              rcases hdepth with rfl | hdepth
              · exact htarget _ (by simp)
              · exact
                  cutoff_predecessor_patterns
                    cutoff targetRest prior
                    (fun next hnext => htarget next (by simp [hnext]))
                    hprior depth hdepth
            · simp [hdouble] at hprevious
termination_by target => target.length

/-- Supported literal subsequence coordinates of the bounded schedule are
exactly the corresponding abstract triangular iterates. -/
lemma literal_subsequence_iterate
    (cutoff : ℕ) :
    ∀ (steps : ℕ) (target : List ℕ),
      (∀ depth ∈ target, depth < cutoff) →
        literalSubsequenceState
            (boundedDepthSchedule cutoff steps) target =
          iterateSubsequenceState
            (literalSubsequenceState
              (boundedDepthSchedule cutoff 0))
            steps target
  | 0, target, _htarget => by
      rfl
  | steps + 1, target, htarget => by
      rw [
        literal_subsequence_state
          cutoff steps target htarget,
        iterateSubsequenceState]
      unfold strictSubsequenceState
      apply congrArg List.sum
      apply List.map_congr_left
      intro previous hprevious
      exact
        literal_subsequence_iterate
          cutoff steps previous
            (cutoff_predecessor_patterns cutoff
              target previous htarget hprevious)

/-- Every below-cutoff ordered-subsequence coordinate of the bounded
strict-depth schedule is an integer-valued polynomial in the number of
substitution steps. -/
lemma subsequence_multiplicity_strict
    (cutoff : ℕ)
    (target : List ℕ)
    (htarget : ∀ depth ∈ target, depth < cutoff) :
    IVMost
