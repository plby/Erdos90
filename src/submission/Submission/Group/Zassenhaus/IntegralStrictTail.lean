/-!
# Polynomial closure for bounded Hall-Witt term updates

The bounded ordered-subsequence collector has a finite cutoff-dependent term
alphabet.  Package supported list families whose multiplicity at every term is
an integer-valued polynomial of one common degree bound.

The exact scalar recurrence for one transition is triangular: a target keeps
its previous multiplicity, may receive its unique strict-prepend predecessor,
and may receive one constant singleton contribution.  Consequently, every
fixed transition and every fixed schedule preserve coordinatewise
polynomiality without increasing the degree bound.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace STClos

open STSched
open SSExp
open STRec
open SSCoord
open STState

/-- Supported bounded-term families with coordinatewise integer-valued
polynomial multiplicities of one common degree bound. -/
def BCDataa
    (cutoff degreeBound : ℕ)
    (family : ℕ → List OCTerm) :
    Prop :=
  (∀ steps,
    SCAlphab cutoff (family steps)) ∧
      ∀ target,
        IVMost
          (fun steps : ℕ => ((family steps).count target : ℤ))
          degreeBound

/-- Every constant integer function is an integer-valued polynomial at every
requested degree bound. -/
lemma valued_most_constant
    (degreeBound : ℕ)
    (value : ℤ) :
    IVMost
      (fun _steps : ℕ => value) degreeBound := by
  exact ⟨Polynomial.C (value : ℚ), by simp, fun steps => by simp⟩

/-- A constant supported bounded-term family has constant polynomial
coordinates. -/
lemma bounded_constant_data
    (cutoff degreeBound : ℕ)
    (terms : List OCTerm)
    (hterms : SCAlphab cutoff terms) :
    BCDataa cutoff degreeBound
      (fun _steps => terms) := by
  constructor
  · intro _steps
    exact hterms
  · intro target
    exact
      valued_most_constant degreeBound
        (terms.count target : ℤ)

/-- The empty bounded-term family has polynomial coordinates at every degree
bound. -/
lemma bounded_constant_nil
    (cutoff degreeBound : ℕ) :
    BCDataa cutoff degreeBound
      (fun _steps => []) := by
  exact
    bounded_constant_data cutoff degreeBound []
      (supported_alphabet_nil cutoff)

/-- Polynomial data transports across pointwise equality of bounded-term
families. -/
lemma BCDataa.congr
    {cutoff degreeBound : ℕ}
    {left right : ℕ → List OCTerm}
    (hleft :
      BCDataa cutoff degreeBound left)
    (hfamilies : ∀ steps, left steps = right steps) :
    BCDataa cutoff degreeBound right := by
  constructor
  · intro steps
    rw [← hfamilies steps]
    exact hleft.1 steps
  · intro target
    rw [show
      (fun steps : ℕ => ((right steps).count target : ℤ)) =
        fun steps : ℕ => ((left steps).count target : ℤ) by
      funext steps
      rw [hfamilies steps]]
    exact hleft.2 target

/-- A fixed transition preserves supported coordinatewise polynomial
multiplicity data without increasing its degree bound. -/
lemma BCDataa.step
    {cutoff degreeBound : ℕ}
    {family : ℕ → List OCTerm}
    (hfamily :
      BCDataa cutoff degreeBound family)
    (transition : SRTrans)
    (htransition :
      transition ∈ secondRouteAlphabet cutoff) :
    BCDataa cutoff degreeBound
      (fun steps =>
        boundedConstantStep cutoff transition (family steps)) := by
  constructor
  · intro steps
    exact
      SCAlphab.step
        cutoff transition htransition (family steps) (hfamily.1 steps)
  · intro target
    have hpredecessor :
        IVMost
          (fun steps : ℕ =>
            ((if target.strictTransitions.length < cutoff then
                match removePrepended? transition target with
                | none =>
                    0
                | some previous =>
                    (family steps).count previous
              else
                0 : ℕ) : ℤ))
          degreeBound := by
      by_cases hlength : target.strictTransitions.length < cutoff
      · cases hremove : removePrepended? transition target with
        | none =>
            simpa [hlength, hremove] using
              valued_most_constant degreeBound 0
        | some previous =>
            simpa [hlength, hremove] using hfamily.2 previous
      · simpa [hlength] using
          valued_most_constant degreeBound 0
    have hconstant :
        IVMost
          (fun _steps : ℕ =>
            ((if 0 < cutoff ∧
                singletonConstantTerm cutoff transition = target
              then
                1
              else
                0 : ℕ) : ℤ))
          degreeBound := by
      exact
        valued_most_constant degreeBound
          ((if 0 < cutoff ∧
              singletonConstantTerm cutoff transition = target
            then
              1
            else
              0 : ℕ) : ℤ)
    rw [show
      (fun steps : ℕ =>
        ((boundedConstantStep cutoff transition
          (family steps)).count target : ℤ)) =
        (fun steps : ℕ =>
          ((if target.strictTransitions.length < cutoff then
              match removePrepended? transition target with
              | none =>
                  0
              | some previous =>
                  (family steps).count previous
            else
              0 : ℕ) : ℤ)) +
          (fun steps : ℕ => ((family steps).count target : ℤ)) +
            (fun _steps : ℕ =>
              ((if 0 < cutoff ∧
                  singletonConstantTerm cutoff transition = target
                then
                  1
                else
                  0 : ℕ) : ℤ)) by
      funext steps
      simp only [Pi.add_apply]
      exact_mod_cast
        count_constant_step
          cutoff transition (family steps) target]
    exact
      TCTex.IVMost.add
        (TCTex.IVMost.add
          hpredecessor (hfamily.2 target))
        hconstant

/-- Folding any fixed-alphabet transition schedule preserves supported
coordinatewise polynomial data without increasing its degree bound. -/
lemma BCDataa.fold
    {cutoff degreeBound : ℕ}
    {family : ℕ → List OCTerm}
    (hfamily :
      BCDataa cutoff degreeBound family) :
    ∀ (transitions : List SRTrans),
      (∀ transition ∈ transitions,
        transition ∈ secondRouteAlphabet cutoff) →
        BCDataa cutoff degreeBound
          (fun steps =>
            boundedConstantFold cutoff transitions (family steps))
  | [], _htransitions => by
      simpa [boundedConstantFold] using hfamily
  | transition :: transitions, htransitions => by
      rw [show
        (fun steps =>
          boundedConstantFold cutoff
            (transition :: transitions) (family steps)) =
          fun steps =>
            boundedConstantStep cutoff transition
              (boundedConstantFold cutoff transitions
                (family steps)) by
        rfl]
      exact
        (hfamily.fold transitions
          (fun next hnext => htransitions next (by simp [hnext]))).step
            transition (htransitions transition (by simp))

/-- The bounded expansion of a fixed schedule, viewed as a constant family,
has polynomial coordinates at every degree bound. -/
lemma bounded_constant_terms
    (cutoff degreeBound : ℕ)
    (transitions : List SRTrans)
    (htransitions :
      ∀ transition ∈ transitions,
        transition ∈ secondRouteAlphabet cutoff) :
    BCDataa cutoff degreeBound
      (fun _steps => boundedConstantTerms cutoff transitions) := by
  exact
    bounded_constant_data cutoff degreeBound
      (boundedConstantTerms cutoff transitions)
      (supported_alphabet_terms
        cutoff transitions htransitions)

/-- Prefixing a variable schedule family by one fixed transition schedule
preserves bounded-term polynomial data. -/
lemma BCDataa.fixedPrefix
    {cutoff degreeBound : ℕ}
    {right : ℕ → List SRTrans}
    (hright :
      BCDataa cutoff degreeBound
        (fun steps => boundedConstantTerms cutoff (right steps)))
    (left : List SRTrans)
    (hleft :
      ∀ transition ∈ left,
        transition ∈ secondRouteAlphabet cutoff) :
    BCDataa cutoff degreeBound
      (fun steps =>
        boundedConstantTerms cutoff (left ++ right steps)) := by
  apply
    (hright.fold left hleft).congr
  intro steps
  exact (constant_terms_append cutoff left (right steps)).symm

end STClos
end TCTex
end Submission

