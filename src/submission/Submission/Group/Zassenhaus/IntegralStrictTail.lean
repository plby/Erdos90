/-!
# All-natural normal forms for complete Hall-Witt transition schedules

The exact complete second-route schedule is empty at multiplicity zero.  At a
successor multiplicity it is one fixed outer-packet prefix followed by the
successor-skew outer-middle crossing schedule.  Record that boundary explicitly
for both signs and rewrite the strict-tail cutoff profiles through the resulting
all-natural schedules.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace TNForm

open WSTrace
open WHNorm
open WNTrace
open WSTail
open NPTail
open RMRecb
open TBProf
open OFProgra
open OFProgra.FRProgra
open OTSubsti
open OTSched
open STSched
open SSFull

/-- Complete positive transition schedule, with the zero-multiplicity
boundary represented directly rather than through a predecessor. -/
noncomputable def naturalFullSchedule
    (cutoff : ℕ) :
    ℕ → List SRTrans
  | 0 =>
      []
  | steps + 1 =>
      positiveFixedPrefix cutoff ++
        middleSuccessorSkew cutoff
          firstConventionalInverse firstConventionalInverse
            firstConventionalWord secondConventionalInverse
              (positiveFilteredPrefix cutoff) steps

/-- Complete negative transition schedule, with the zero-multiplicity
boundary represented directly rather than through a predecessor. -/
noncomputable def negativeFullSchedule
    (cutoff : ℕ) :
    ℕ → List SRTrans
  | 0 =>
      []
  | steps + 1 =>
      negativeFixedPrefix cutoff ++
        middleSuccessorSkew cutoff
          firstConventionalWord firstConventionalWord
            firstConventionalInverse secondConventionalWord
              (negativeFilteredPrefix cutoff) steps

@[simp]
lemma natural_full_transition
    (cutoff : ℕ) :
    naturalFullSchedule cutoff 0 = [] := by
  rfl

@[simp]
lemma negative_full_transition
    (cutoff : ℕ) :
    negativeFullSchedule cutoff 0 = [] := by
  rfl

@[simp]
lemma natural_full_succ
    (cutoff steps : ℕ) :
    naturalFullSchedule cutoff (steps + 1) =
      positiveFixedPrefix cutoff ++
        middleSuccessorSkew cutoff
          firstConventionalInverse firstConventionalInverse
            firstConventionalWord secondConventionalInverse
              (positiveFilteredPrefix cutoff) steps := by
  rfl

@[simp]
lemma negative_full_succ
    (cutoff steps : ℕ) :
    negativeFullSchedule cutoff (steps + 1) =
      negativeFixedPrefix cutoff ++
        middleSuccessorSkew cutoff
          firstConventionalWord firstConventionalWord
            firstConventionalInverse secondConventionalWord
              (negativeFilteredPrefix cutoff) steps := by
  rfl

/-- The extracted positive schedule is the explicit all-natural normal form. -/
lemma transition_program_full
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff) :
    ∀ multiplicity : ℕ,
      transitionSchedule cutoff
          (naturalRouteProgram cutoff multiplicity) =
        naturalFullSchedule cutoff multiplicity
  | 0 => by
      rw [natural_iterate_prepend]
      rfl
  | steps + 1 => by
      rw [natural_iterate_prepend,
        transition_prepend_succ,
        crossed_iterate_prepend
          cutoff hcutoff steps]
      rfl

/-- The extracted negative schedule is the explicit all-natural normal form. -/
lemma route_program_full
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff) :
    ∀ multiplicity : ℕ,
      transitionSchedule cutoff
          (negativeRouteProgram cutoff multiplicity) =
        negativeFullSchedule cutoff multiplicity
  | 0 => by
      rw [negative_iterate_prepend]
      rfl
  | steps + 1 => by
      rw [negative_iterate_prepend,
        iterate_prepend_negative,
        crossed_prepend_middle
          cutoff hcutoff steps]
      rfl

/-- Positive strict-tail cutoff profiles are affine evaluations of the
all-natural complete transition schedules. -/
lemma natural_affine_transition
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (multiplicity : ℕ) :
    cutoffProfile cutoff
        (NPTail.strictTrace multiplicity) =
      (scheduleAffine cutoff
        (naturalFullSchedule cutoff multiplicity)).apply 0 := by
  rw [profile_natural_affine cutoff hcutoff,
    transition_program_full
      cutoff hcutoff]

/-- Negative strict-tail cutoff profiles are affine evaluations of the
all-natural complete transition schedules. -/
lemma affine_full_transition
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (multiplicity : ℕ) :
    cutoffProfile cutoff
        (NNPower.strictTrace
          multiplicity) =
      (scheduleAffine cutoff
        (negativeFullSchedule cutoff multiplicity)).apply 0 := by
  rw [profile_negative_affine cutoff hcutoff,
    route_program_full
      cutoff hcutoff]

end TNForm
end TCTex
end Submission

