    (cutoff : ℕ)
    (outer selected right : CWord Atom)
    (depth : ℕ) :
    List SRTrans :=
  (iteratedCutoffTrace cutoff selected depth
    (unitBelowTrace cutoff [right])).map
      (SRTrans.crossed outer)

