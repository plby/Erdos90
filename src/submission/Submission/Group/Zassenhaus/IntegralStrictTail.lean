              z.weight PEAddres.weight)
            (addressBelowTerms
              (n := n) x y z cutoff (Int.ofNat multiplicity)).prod))
      (naturalStrictBound cutoff) := by
  rw [← funext fun multiplicity =>
    address_natural_prod
      x y z cutoff hcutoff coordinate multiplicity]
