    (cutoff : ℕ)
    (selected : CWord Atom)
    (rights : List (CWord Atom))
    (slot : CWord Atom)
    (steps : ℕ) :
    ℤ :=
  (iteratedCutoffMove cutoff selected steps
    (unitBelowTrace cutoff rights)).count slot

