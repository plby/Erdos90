open CWTrace
open WSTrace
open NPTail
open TBProf
open ARProfa
open ARProfa.CPAffine
open ARUnipot
open TACompos
open SARec
open OSAffine

/-- Iterating one fixed ordered swap packet from zero has cutoff-bounded
slotwise polynomial data. -/
lemma iterate_second_affine
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (left : CWord Atom)
    (hleft : isFirstCurrent left = true)
    (rights : List (CWord Atom)) :
    CPDataa cutoff cutoff
      (fun steps =>
        (iterate (swapSecondAffine cutoff left rights) steps).apply 0) := by
  constructor
  · intro steps
    change
      SCVocabu cutoff
        ((iterate (swapSecondAffine cutoff left rights) steps).apply 0)
    rw [iterate_move_repeat
      cutoff left hleft rights steps]
    rw [← profile_stable_fst]
    exact supported_vocabulary_profile cutoff _
  · intro slot
    simpa [repeatedSwapMultiplicity] using
      repeated_slot_most
        cutoff hcutoff left rights slot

/-- The varying linear powers of one fixed ordered swap packet preserve
polynomial profile data, increasing the common degree bound by at most the
cutoff. -/
lemma CPDataa.swapsecond_affinelin_powapply
    {cutoff degreeBound : ℕ}
    (hcutoff : 0 < cutoff)
    {family : ℕ → Multiset (CWord Atom)}
    (hfamily : CPDataa cutoff degreeBound family)
    (left : CWord Atom)
    (rights : List (CWord Atom)) :
    CPDataa cutoff (cutoff + degreeBound)
      (fun steps =>
        ((swapSecondAffine cutoff left rights).linear ^ steps)
          (family steps)) := by
  rw [show
    (fun steps =>
      ((swapSecondAffine cutoff left rights).linear ^ steps)
        (family steps)) =
      fun steps =>
        ∑ k ∈ Finset.range cutoff,
          steps.choose k •
            ((packetCorrectionEnd cutoff isSecondCurrent rights) ^ k)
              (family steps) by
      funext steps
      exact
        swap_affine_cutoff
          cutoff hcutoff left rights steps (family steps)]
  apply cutoff_finset_sum
  intro k hk
  have hkLe : k ≤ cutoff := Nat.le_of_lt (Finset.mem_range.mp hk)
  apply CPDataa.mono (Nat.add_le_add_right hkLe degreeBound)
  exact
    (hfamily.apply_fixed
      ((packetCorrectionEnd cutoff isSecondCurrent rights) ^ k)
      (preserves_vocabulary_end
        cutoff isSecondCurrent rights k)).choose_nsmul k

/--
Applying a polynomially repeated fixed ordered swap packet to an
already-polynomial input profile preserves slotwise polynomiality.
-/
lemma CPDataa.iterat_swaps_affin
    {cutoff degreeBound : ℕ}
    (hcutoff : 0 < cutoff)
    {family : ℕ → Multiset (CWord Atom)}
    (hfamily : CPDataa cutoff degreeBound family)
    (left : CWord Atom)
    (hleft : isFirstCurrent left = true)
    (rights : List (CWord Atom)) :
    CPDataa cutoff (cutoff + degreeBound)
      (fun steps =>
        (iterate (swapSecondAffine cutoff left rights) steps).apply
          (family steps)) := by
  rw [show
    (fun steps =>
      (iterate (swapSecondAffine cutoff left rights) steps).apply
        (family steps)) =
      fun steps =>
        ((swapSecondAffine cutoff left rights).linear ^ steps)
            (family steps) +
          (iterate (swapSecondAffine cutoff left rights) steps).apply 0 by
      funext steps
      exact
        iterate_linear_zero
          (swapSecondAffine cutoff left rights) steps (family steps)]
  exact
    (CPDataa.swapsecond_affinelin_powapply
      hcutoff hfamily left rights).add
      ((iterate_second_affine
        cutoff hcutoff left hleft rights).mono
          (Nat.le_add_right cutoff degreeBound))

end SACompos
end TCTex
