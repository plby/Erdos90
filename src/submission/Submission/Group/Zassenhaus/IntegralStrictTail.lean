-- Merged from JacobiIntegralPowerStrictTailCutoffOrderedSecondAffineRecurrence.lean

/-!
# Second-affine recurrences for ordered Hall-Witt first-route programs

Interpret the ordered first-route program directly in the affine compiler for
the second routing pass.  A retained node composes one ordinary source block.
A moved first-family node traverses the already-built tail trace and inserts
one strict bracket correction before each crossed word.

Every inserted first-family bracket correction is unselected by the
second-family compiler.  Once its weight reaches the cutoff, its retained
affine contribution is the identity.  These recurrences expose the
weight-stratified symbolic interpreter still needed for the universal
collection polynomial constructor.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace SARec

open CWTrace
open WSTrace
open NPTail
open RMRecb
open TBProf
open ARProfa
open ARProfa.CPAffine
open ARUnipot
open ASFilt
open OFProgra
open OFProgra.FRProgra

/-- Affine action of one literal source word in the second routing pass. -/
def secondAtomAffine
    (cutoff : ℕ)
    (word : CWord Atom) :
    CPAffine :=
  if isSecondCurrent word = true then
    selected cutoff word
  else
    retained cutoff word

/-- The ordinary affine compiler exposes one second-pass source word at a
time. -/
lemma second_current_cons
    (cutoff : ℕ)
    (word : CWord Atom)
    (words : List (CWord Atom)) :
    ofTrace cutoff isSecondCurrent (word :: words) =
      (secondAtomAffine cutoff word).comp
        (ofTrace cutoff isSecondCurrent words) := by
  rfl

/--
Second-pass compiler for one first-family word moved across an ordered trace.
Each crossed word contributes its unselected bracket correction immediately
before its ordinary second-pass action.
-/
def swapSecondAffine
    (cutoff : ℕ)
    (left : CWord Atom) :
    List (CWord Atom) →
      CPAffine
  | [] =>
      one
  | right :: rights =>
      (retained cutoff (.commutator left right)).comp
        ((secondAtomAffine cutoff right).comp
          (swapSecondAffine cutoff left rights))

/-- The explicit swap fold is exactly compilation of the literal rightward
move trace whenever the moved word belongs to the first current family. -/
lemma move_higher_affine
    (cutoff : ℕ)
    (left : CWord Atom)
    (hleft : isFirstCurrent left = true) :
    ∀ rights : List (CWord Atom),
      ofTrace cutoff isSecondCurrent (moveHigherTrace left rights) =
        swapSecondAffine cutoff left rights
  | [] => by
      rfl
  | right :: rights => by
      simp only [moveHigherTrace, second_current_cons,
        swapSecondAffine]
      rw [show
        secondAtomAffine cutoff (.commutator left right) =
          retained cutoff (.commutator left right) by
        rw [secondAtomAffine,
          current_false_true
            left right hleft]
        rfl]
      rw [move_higher_affine
        cutoff left hleft rights]

/-- The swap fold composes across crossed-trace concatenation. -/
lemma swap_affine_append
    (cutoff : ℕ)
    (left : CWord Atom) :
    ∀ (rights next : List (CWord Atom)),
      swapSecondAffine cutoff left (rights ++ next) =
        (swapSecondAffine cutoff left rights).comp
          (swapSecondAffine cutoff left next)
  | [], next => by
      exact (one_comp (swapSecondAffine cutoff left next)).symm
  | right :: rights, next => by
      simp only [List.cons_append, swapSecondAffine]
      rw [swap_affine_append cutoff left rights next]
      rw [comp_assoc, comp_assoc]

/-- Crossing a repeated fixed packet is iteration of its one-packet swap
affine action. -/
lemma swap_affine_repeat
    (cutoff : ℕ)
    (left : CWord Atom)
    (packet : List (CWord Atom)) :
    ∀ steps : ℕ,
      swapSecondAffine cutoff left (repeatTrace steps packet) =
        iterate (swapSecondAffine cutoff left packet) steps
  | 0 => by
      rfl
  | steps + 1 => by
      rw [repeatTrace, swap_affine_append,
        swap_affine_repeat cutoff left packet steps]
      rfl

/-- Inserting first-route swap corrections changes only affine constants: the
linear part of a swap fold is the ordinary second-pass linear action of its
crossed trace. -/
lemma swap_affine_trace
    (cutoff : ℕ)
    (left : CWord Atom) :
    ∀ rights : List (CWord Atom),
      (swapSecondAffine cutoff left rights).linear =
        (ofTrace cutoff isSecondCurrent rights).linear
  | [] => by
      rfl
  | right :: rights => by
      simp only [swapSecondAffine, second_current_cons,
        CPAffine.comp, CPAffine.retained]
      rw [swap_affine_trace cutoff left rights]
      simp

/-- Consequently, the linear part of one fixed swap packet is identity plus
the ordinary strict packet-correction endomorphism of the crossed trace. -/
lemma swap_affine_end
    (cutoff : ℕ)
    (left : CWord Atom)
    (rights : List (CWord Atom)) :
    (swapSecondAffine cutoff left rights).linear =
      packetCorrectionEnd cutoff isSecondCurrent rights + 1 := by
  rw [swap_affine_trace,
    trace_linear_end]

/-- The strict correction part controlling a fixed swap packet is nilpotent
at every positive cutoff. -/
lemma swap_affine_strict
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (rights : List (CWord Atom)) :
    (packetCorrectionEnd cutoff isSecondCurrent rights) ^ cutoff = 0 :=
  packet_end_zero
    cutoff hcutoff isSecondCurrent rights

/-- The empty ordered first-route program compiles to the affine identity for
the second pass. -/
@[simp]
lemma secondAffine_empty
    (cutoff : ℕ) :
    FRProgra.empty.secondAffine cutoff = CPAffine.one := by
  rfl

/-- A retained first-route node composes its filtered singleton block before
the compiled tail. -/
lemma secondAffine_retained
    (cutoff : ℕ)
    (word : CWord Atom)
    (tail : FRProgra) :
    (FRProgra.retained word tail).secondAffine cutoff =
      (ofTrace cutoff isSecondCurrent
        (unitBelowTrace cutoff [word])).comp
          (tail.secondAffine cutoff) := by
  rw [secondAffine, trace_retained, ofTrace_append]
  rfl

/-- A moved first-family node compiles through the explicit swap fold. -/
lemma secondAffine_moved
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (left : CWord Atom)
    (hleft : isFirstCurrent left = true)
    (tail : FRProgra) :
    (FRProgra.moved left tail).secondAffine cutoff =
      swapSecondAffine cutoff left (tail.trace cutoff) := by
  rw [secondAffine, trace_moved,
    second_current_below cutoff hcutoff,
    move_higher_affine cutoff left hleft]

/-- If an inserted bracket correction is already at or above cutoff, its
retained affine contribution disappears and the swap fold advances directly
to the crossed word. -/
lemma swap_affine_cons
    (cutoff : ℕ)
    (left right : CWord Atom)
    (rights : List (CWord Atom))
    (hweight :
      cutoff ≤ (.commutator left right : CWord Atom).weight
        (fun _ => 1)) :
    swapSecondAffine cutoff left (right :: rights) =
      (secondAtomAffine cutoff right).comp
        (swapSecondAffine cutoff left rights) := by
  rw [swapSecondAffine,
    retained_one_weight cutoff (.commutator left right) hweight,
    one_comp]

/-- A first-family move inserts only corrections whose unit weight is the
crossed word weight plus three. -/
lemma correction_first_current
    (left right : CWord Atom)
    (hleft : isFirstCurrent left = true) :
    (.commutator left right : CWord Atom).weight (fun _ => 1) =
      3 + right.weight (fun _ => 1) := by
  rw [CWord.weight_commutator,
    first_current_true left hleft]

/-- Hence a first-family swap correction disappears as soon as the crossed
word is within three units of the cutoff. -/
lemma swap_cons_current
    (cutoff : ℕ)
    (left right : CWord Atom)
    (rights : List (CWord Atom))
    (hleft : isFirstCurrent left = true)
    (hweight : cutoff ≤ 3 + right.weight (fun _ => 1)) :
    swapSecondAffine cutoff left (right :: rights) =
      (secondAtomAffine cutoff right).comp
        (swapSecondAffine cutoff left rights) := by
  apply swap_affine_cons
  rwa [correction_first_current left right hleft]

/--
If all crossed words are within three units of the cutoff, every inserted
first-family correction disappears and the swap fold is just the ordinary
second-pass compiler of the crossed trace.
-/
lemma swap_second_affine
    (cutoff : ℕ)
    (left : CWord Atom)
    (hleft : isFirstCurrent left = true) :
    ∀ rights : List (CWord Atom),
      (∀ right ∈ rights,
        cutoff ≤ 3 + right.weight (fun _ => 1)) →
        swapSecondAffine cutoff left rights =
          ofTrace cutoff isSecondCurrent rights
  | [], _hrights => by
      rfl
  | right :: rights, hrights => by
      rw [
        swap_cons_current
          cutoff left right rights hleft (hrights right (by simp)),
        second_current_cons,
        swap_second_affine
          cutoff left hleft rights (fun next hnext =>
            hrights next (by simp [hnext]))]

/--
At a terminal weight stratum, a moved first-family program node has the same
second-pass affine interpretation as its tail.
-/
lemma second_affine_moved
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (left : CWord Atom)
    (hleft : isFirstCurrent left = true)
    (tail : FRProgra)
    (htail :
      ∀ right ∈ tail.trace cutoff,
        cutoff ≤ 3 + right.weight (fun _ => 1)) :
    (FRProgra.moved left tail).secondAffine cutoff =
      tail.secondAffine cutoff := by
  rw [secondAffine_moved cutoff hcutoff left hleft tail,
    swap_second_affine
      cutoff left hleft (tail.trace cutoff) htail]
  rfl

end SARec
end TCTex
end Submission

-- Merged from JacobiIntegralPowerStrictTailCutoffOrderedOuterPacketFactorization.lean

/-!
# One-selected-packet factorization for ordered Hall-Witt outer routes

The normalized outer Hall-Witt packet contains exactly one first-family
current word.  Split any such packet into a retained prefix, its selected
singleton, and a retained suffix.  Routing one packet onto a carried ordered
tail then factors into:

* retaining the fixed prefix;
* moving the selected word across the fixed suffix;
* moving the selected word across the carried tail.

After compilation for the second Hall-Witt pass, the first two pieces are one
fixed affine transformation.  All coefficient-dependent order is isolated in
the final `swapSecondAffine` term.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace TOFact

open CWTrace
open WSTrace
open WHNorm
open WNTrace
open WSTail
open NPTail
open RMRecb
open ARProfa
open ARProfa.CPAffine
open ASFilt
open OFProgra
open OFProgra.FRProgra
open SARec

/-- A packet with exactly one selected occurrence splits into a retained
prefix, that selected singleton, and a retained suffix. -/
lemma append_singleton_filter
    {α : Type*}
    (isCurrent : α → Bool)
    (selected : α) :
    ∀ source : List α,
      source.filter isCurrent = [selected] →
        ∃ before suffix,
          source = before ++ [selected] ++ suffix ∧
            (∀ word ∈ before, isCurrent word ≠ true) ∧
              ∀ word ∈ suffix, isCurrent word ≠ true
  | [], hfilter => by
      simp at hfilter
  | word :: words, hfilter => by
      by_cases hword : isCurrent word = true
      · simp only [List.filter_cons, hword, if_true, List.cons.injEq] at hfilter
        rcases hfilter with ⟨rfl, hwords⟩
        refine ⟨[], words, by simp, by simp, ?_⟩
        intro next hnext hnextCurrent
        have : next ∈ words.filter isCurrent := by
          exact List.mem_filter.mpr ⟨hnext, hnextCurrent⟩
        rw [hwords] at this
        simp at this
      · simp only [List.filter_cons, hword] at hfilter
        rcases
            append_singleton_filter
              isCurrent selected words hfilter with
          ⟨before, suffix, rfl, hbefore, hsuffix⟩
        refine ⟨word :: before, suffix, by simp, ?_, hsuffix⟩
        intro next hnext
        simp only [List.mem_cons] at hnext
        rcases hnext with rfl | hnext
        · exact hword
        · exact hbefore next hnext

/-- Routing a wholly unselected source retains it verbatim before the carried
tail. -/
lemma route_forall_current
    (isCurrent : CWord Atom → Bool) :
    ∀ (source rights : List (CWord Atom)),
      (∀ word ∈ source, isCurrent word ≠ true) →
        routeOnto isCurrent source rights = source ++ rights
  | [], rights, _hsource => by
      rfl
  | word :: words, rights, hsource => by
      have hword : isCurrent word ≠ true :=
        hsource word (by simp)
      have hwords :
          ∀ next ∈ words, isCurrent next ≠ true := by
        intro next hnext
        exact hsource next (by simp [hnext])
      simp only [routeOnto, if_neg hword, List.cons_append]
      rw [route_forall_current
        isCurrent words rights hwords]

/-- Routing one packet with one selected occurrence isolates one literal
rightward move between retained prefix and suffix traces. -/
lemma route_move_selected
    (isCurrent : CWord Atom → Bool)
    (packet before suffix rights : List (CWord Atom))
    (selected : CWord Atom)
    (hpacket : packet = before ++ [selected] ++ suffix)
    (hselected : isCurrent selected = true)
    (hbefore : ∀ word ∈ before, isCurrent word ≠ true)
    (hsuffix : ∀ word ∈ suffix, isCurrent word ≠ true) :
    routeOnto isCurrent packet rights =
      before ++ moveHigherTrace selected (suffix ++ rights) := by
  rw [hpacket, routeOnto_append, routeOnto_append]
  rw [route_forall_current isCurrent suffix rights hsuffix]
  simp only [routeOnto, if_pos hselected]
  rw [route_forall_current]
  exact hbefore

/-- Fixed second-pass affine contribution of one retained-prefix,
selected-singleton, retained-suffix packet. -/
def fixedSecondAffine
    (cutoff : ℕ)
    (before : List (CWord Atom))
    (selected : CWord Atom)
    (suffix : List (CWord Atom)) :
    CPAffine :=
  (ofTrace cutoff isSecondCurrent before).comp
    (swapSecondAffine cutoff selected suffix)

/--
Compile one first-route packet with one selected first-family occurrence.
The fixed packet contribution is separated from the sole dynamic term:
swapping that selected occurrence across the carried ordered tail.
-/
lemma second_prepend_swap
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (packet before suffix : List (CWord Atom))
    (selected : CWord Atom)
    (hpacket : packet = before ++ [selected] ++ suffix)
    (hselected : isFirstCurrent selected = true)
    (hbefore : ∀ word ∈ before, isFirstCurrent word ≠ true)
    (hsuffix : ∀ word ∈ suffix, isFirstCurrent word ≠ true)
    (tail : FRProgra) :
    (prepend cutoff isFirstCurrent packet tail).secondAffine cutoff =
      (fixedSecondAffine cutoff before selected suffix).comp
        (swapSecondAffine cutoff selected (tail.trace cutoff)) := by
  rw [FRProgra.secondAffine, trace_prepend]
  rw [route_move_selected
    isFirstCurrent packet before suffix (tail.trace cutoff) selected
    hpacket hselected hbefore hsuffix]
  rw [second_current_below cutoff hcutoff]
  rw [ofTrace_append,
    move_higher_affine cutoff selected hselected,
    swap_affine_append, fixedSecondAffine, comp_assoc]

/-- One more iteration of a one-selected outer packet has the same exact
fixed-prefix/dynamic-swap recurrence. -/
lemma iterate_prepend_swap
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (packet before suffix : List (CWord Atom))
    (selected : CWord Atom)
    (hpacket : packet = before ++ [selected] ++ suffix)
    (hselected : isFirstCurrent selected = true)
    (hbefore : ∀ word ∈ before, isFirstCurrent word ≠ true)
    (hsuffix : ∀ word ∈ suffix, isFirstCurrent word ≠ true)
    (steps : ℕ)
    (tail : FRProgra) :
    (iteratePrepend cutoff isFirstCurrent packet (steps + 1) tail).secondAffine
        cutoff =
      (fixedSecondAffine cutoff before selected suffix).comp
        (swapSecondAffine cutoff selected
          ((iteratePrepend cutoff isFirstCurrent packet steps tail).trace
            cutoff)) := by
  rw [iteratePrepend]
  exact
    second_prepend_swap
      cutoff hcutoff packet before suffix selected hpacket hselected hbefore
        hsuffix _

/-- The normalized positive outer packet admits one retained-prefix,
selected-singleton, retained-suffix decomposition. -/
lemma positive_outer_factorization :
    ∃ before suffix,
      WNTrace.trace =
          before ++ [firstConventionalInverse] ++ suffix ∧
        (∀ word ∈ before, isFirstCurrent word ≠ true) ∧
          ∀ word ∈ suffix, isFirstCurrent word ≠ true := by
  exact
    append_singleton_filter
      isFirstCurrent firstConventionalInverse
        WNTrace.trace filter_trace_current

/-- The inverted negative outer packet admits one retained-prefix,
selected-singleton, retained-suffix decomposition. -/
lemma negative_outer_factorization :
    ∃ before suffix,
      NNPower.inverseNormalizedTrace =
          before ++ [firstConventionalWord] ++ suffix ∧
        (∀ word ∈ before, isFirstCurrent word ≠ true) ∧
          ∀ word ∈ suffix, isFirstCurrent word ≠ true := by
  exact
    append_singleton_filter
      isFirstCurrent firstConventionalWord
        NNPower.inverseNormalizedTrace
          NNPower.filter_first_current

/-- Fixed decomposition data for a packet with one selected occurrence. -/
structure SelectedPacketFactorization
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom))
    (selected : CWord Atom) where
  before :
    List (CWord Atom)
  suffix :
    List (CWord Atom)
  packet_eq :
    packet = before ++ [selected] ++ suffix
  before_not_current :
    ∀ word ∈ before, isCurrent word ≠ true
  suffix_not_current :
    ∀ word ∈ suffix, isCurrent word ≠ true

/-- Choose fixed decomposition data from a singleton selector filter. -/
noncomputable def selectedFilterSingleton
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom))
    (selected : CWord Atom)
    (hfilter : packet.filter isCurrent = [selected]) :
    SelectedPacketFactorization isCurrent packet selected := by
  classical
  let hsplit :=
    append_singleton_filter
      isCurrent selected packet hfilter
  let before := Classical.choose hsplit
  let hsuffix := Classical.choose_spec hsplit
  let suffix := Classical.choose hsuffix
  let hproperties := Classical.choose_spec hsuffix
  exact
    ⟨before, suffix, hproperties.1, hproperties.2.1, hproperties.2.2⟩

/-- Coefficient-independent decomposition data for the positive normalized
outer packet. -/
noncomputable def positiveOuterFactorization :
    SelectedPacketFactorization isFirstCurrent
      WNTrace.trace firstConventionalInverse :=
  selectedFilterSingleton
    isFirstCurrent WNTrace.trace
      firstConventionalInverse filter_trace_current

/-- Coefficient-independent decomposition data for the negative inverted
outer packet. -/
noncomputable def negativeOuterFactorization :
    SelectedPacketFactorization isFirstCurrent
      NNPower.inverseNormalizedTrace
        firstConventionalWord :=
  selectedFilterSingleton
    isFirstCurrent
      NNPower.inverseNormalizedTrace
        firstConventionalWord
          NNPower.filter_first_current

/-- Fixed positive outer-packet affine contribution for the second route. -/
noncomputable def positiveSecondAffine
    (cutoff : ℕ) :
    CPAffine :=
  fixedSecondAffine cutoff
    positiveOuterFactorization.before firstConventionalInverse
      positiveOuterFactorization.suffix

/-- Fixed negative outer-packet affine contribution for the second route. -/
noncomputable def negativeSecondAffine
    (cutoff : ℕ) :
    CPAffine :=
  fixedSecondAffine cutoff
    negativeOuterFactorization.before firstConventionalWord
      negativeOuterFactorization.suffix

/-- Each positive outer packet iteration is one fixed affine prefix followed
by the dynamic swap across the previously emitted ordered tail. -/
lemma affine_iterate_prepend
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (steps : ℕ)
    (tail : FRProgra) :
    (iteratePrepend cutoff isFirstCurrent WNTrace.trace
        (steps + 1) tail).secondAffine cutoff =
      (positiveSecondAffine cutoff).comp
        (swapSecondAffine cutoff firstConventionalInverse
          ((iteratePrepend cutoff isFirstCurrent
            WNTrace.trace steps tail).trace cutoff)) := by
  apply
    iterate_prepend_swap
      cutoff hcutoff WNTrace.trace
        positiveOuterFactorization.before
          positiveOuterFactorization.suffix
            firstConventionalInverse
  · exact positiveOuterFactorization.packet_eq
  · simp
  · exact positiveOuterFactorization.before_not_current
  · exact positiveOuterFactorization.suffix_not_current

/-- Each negative outer packet iteration is one fixed affine prefix followed
by the dynamic swap across the previously emitted ordered tail. -/
lemma second_iterate_prepend
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (steps : ℕ)
    (tail : FRProgra) :
    (iteratePrepend cutoff isFirstCurrent
        NNPower.inverseNormalizedTrace
          (steps + 1) tail).secondAffine cutoff =
      (negativeSecondAffine cutoff).comp
        (swapSecondAffine cutoff firstConventionalWord
          ((iteratePrepend cutoff isFirstCurrent
            NNPower.inverseNormalizedTrace
              steps tail).trace cutoff)) := by
  apply
    iterate_prepend_swap
      cutoff hcutoff
        NNPower.inverseNormalizedTrace
          negativeOuterFactorization.before
            negativeOuterFactorization.suffix firstConventionalWord
  · exact negativeOuterFactorization.packet_eq
  · simp
  · exact negativeOuterFactorization.before_not_current
  · exact negativeOuterFactorization.suffix_not_current

end TOFact
end TCTex
end Submission

-- Merged from
-- JacobiIntegralPowerStrictTailCutoffOrderedSecondAffineStrictCorrectionTermination.lean

/-!
# Termination of deep ordered Hall-Witt strict-correction swaps

The order-sensitive outer collector recursively encounters strict correction
traces.  Every first-family strict correction raises unit-label weight by
three.  Once every crossed word lies at or above the cutoff, its ordinary
second-pass atom and the newly inserted bracket correction both compile to
the affine identity.

This file packages that terminal case directly at the ordered
`swapSecondAffine` level.  It is the finite-depth stopping rule needed by a
weight-stratified symbolic outer collector.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace SATermin

open CWTrace
open WSTrace
open NPTail
open ARProfa
open ARProfa.CPAffine
open ASFilt
open SARec

/-- Above weight three, one second-pass atom at or above cutoff compiles to
the affine identity. -/
lemma second_atom_affine
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (word : CWord Atom)
    (hweight : cutoff ≤ word.weight (fun _ => 1)) :
    secondAtomAffine cutoff word =
      CPAffine.one := by
  rw [secondAtomAffine]
  by_cases hcurrent : isSecondCurrent word = true
  · have :=
      second_current_true word hcurrent
    omega
  · rw [if_neg hcurrent, retained_one_weight cutoff word hweight]

/-- Swapping across a trace entirely at or above cutoff is invisible to the
second-pass affine compiler. -/
lemma swap_affine_forall
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (left : CWord Atom) :
    ∀ rights : List (CWord Atom),
      (∀ right ∈ rights, cutoff ≤ right.weight (fun _ => 1)) →
        swapSecondAffine cutoff left rights =
          CPAffine.one
  | [], _hrights => by
      rfl
  | right :: rights, hrights => by
      have hright :
          cutoff ≤ right.weight (fun _ => 1) :=
        hrights right (by simp)
      have hcorrection :
          cutoff ≤ (.commutator left right : CWord Atom).weight
            (fun _ => 1) := by
        simp only [CWord.weight_commutator]
        omega
      have htail :
          ∀ next ∈ rights, cutoff ≤ next.weight (fun _ => 1) := by
        intro next hnext
        exact hrights next (by simp [hnext])
      rw [swapSecondAffine,
        retained_one_weight cutoff (.commutator left right)
          hcorrection,
        second_atom_affine cutoff hcutoff right hright,
        swap_affine_forall
          cutoff hcutoff left rights htail]
      rfl

/--
After enough strict-correction iterations to reach the cutoff, the ordered
second-pass swap compiler is affine identity.
-/
lemma swap_iterated_move
    (lowerWeight cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (left : CWord Atom)
    (rights : List (CWord Atom))
    (hrights :
      ∀ right ∈ rights, lowerWeight ≤ right.weight (fun _ => 1))
    (steps : ℕ)
    (hsteps :
      cutoff ≤ steps * left.weight (fun _ => 1) + lowerWeight) :
    swapSecondAffine cutoff left
        (iteratedMoveTrace left steps rights) =
      CPAffine.one := by
  apply swap_affine_forall cutoff hcutoff
  intro emitted hemitted
  exact
    hsteps.trans
      (steps_iterated_move
        (fun _ : Atom => 1) lowerWeight left rights hrights steps emitted
          hemitted)

/-- For a first-family current word, `cutoff` strict-correction iterations are
always deep enough to become affine identity. -/
lemma swap_move_current
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (left : CWord Atom)
    (hleft : isFirstCurrent left = true)
    (rights : List (CWord Atom)) :
    swapSecondAffine cutoff left
        (iteratedMoveTrace left cutoff rights) =
      CPAffine.one := by
  apply
    swap_iterated_move
      0 cutoff hcutoff left rights
  · intro right _hright
    omega
  · rw [first_current_true left hleft]
    omega

end SATermin
end TCTex
end Submission

-- Merged from JacobiIntegralPowerStrictTailCutoffOrderedSecondAffineSubstitution.lean

/-!
# Ordered substitution folds for Hall-Witt second-affine swaps

Moving one word rightward replaces each crossed occurrence `right` in place by

`[commutator left right, right]`.

The ordered second-pass swap compiler therefore lifts across one rightward
move by folding the corresponding fixed two-word substitution packet over the
crossed trace.  Strict corrections are the one-word substitution
`[commutator left right]`.

These identities expose the recursive ordered substitution interpreter that
sits between the exact outer-packet recurrence and the finite-depth
strict-correction stopping rule.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace SASubsti

open CWTrace
open WSTrace
open TBProf
open ARProfa
open ARProfa.CPAffine
open SARec

/-- Fold an ordered family of local substitution packets through one outer
swap compiler. -/
def substitutionSwapAffine
    (cutoff : ℕ)
    (outer : CWord Atom)
    (packetAt : CWord Atom → List (CWord Atom)) :
    List (CWord Atom) → CPAffine
  | [] =>
      CPAffine.one
  | right :: rights =>
      (swapSecondAffine cutoff outer (packetAt right)).comp
        (substitutionSwapAffine cutoff outer packetAt rights)

/-- Substitution-swap folding is exactly swapping across the flattened local
packet trace. -/
lemma substitution_affine_flat
    (cutoff : ℕ)
    (outer : CWord Atom)
    (packetAt : CWord Atom → List (CWord Atom)) :
    ∀ rights : List (CWord Atom),
      substitutionSwapAffine cutoff outer packetAt rights =
        swapSecondAffine cutoff outer (rights.flatMap packetAt)
  | [] => by
      rfl
  | right :: rights => by
      rw [substitutionSwapAffine, List.flatMap_cons,
        swap_affine_append,
        substitution_affine_flat
          cutoff outer packetAt rights]

/-- A rightward move is the flattened in-place two-word substitution packet. -/
lemma move_trace_flat
    (left : CWord Atom) :
    ∀ rights : List (CWord Atom),
      moveHigherTrace left rights =
        rights.flatMap fun right => [.commutator left right, right]
  | [] => by
      rfl
  | right :: rights => by
      simp [moveHigherTrace, move_trace_flat left rights]

/-- A strict-correction trace is the flattened one-word substitution packet. -/
lemma move_right_flat
    (left : CWord Atom)
    (rights : List (CWord Atom)) :
    moveCorrectionTrace left rights =
      rights.flatMap fun right => [.commutator left right] := by
  unfold moveCorrectionTrace
  induction rights with
  | nil =>
      rfl
  | cons right rights ih =>
      simp [ih]

/-- Swapping across one interleaved rightward move is a fold of local
two-word substitution swaps. -/
lemma swap_move_higher
    (cutoff : ℕ)
    (outer inner : CWord Atom)
    (rights : List (CWord Atom)) :
    swapSecondAffine cutoff outer (moveHigherTrace inner rights) =
      substitutionSwapAffine cutoff outer
        (fun right => [.commutator inner right, right]) rights := by
  rw [move_trace_flat,
    substitution_affine_flat]

/-- Swapping across one strict-correction trace is a fold of local one-word
substitution swaps. -/
lemma swap_affine_move
    (cutoff : ℕ)
    (outer inner : CWord Atom)
    (rights : List (CWord Atom)) :
    swapSecondAffine cutoff outer (moveCorrectionTrace inner rights) =
      substitutionSwapAffine cutoff outer
        (fun right => [.commutator inner right]) rights := by
  rw [move_right_flat,
    substitution_affine_flat]

/-- Lift the ordered swap compiler across repeated full rightward movement. -/
def iteratedSubstitutionAffine
    (cutoff : ℕ)
    (outer inner : CWord Atom) :
    ℕ → List (CWord Atom) → CPAffine
  | 0, rights =>
      swapSecondAffine cutoff outer rights
  | steps + 1, rights =>
      substitutionSwapAffine cutoff outer
        (fun right => [.commutator inner right, right])
          (iteratedMoveHigher inner steps rights)

/-- The iterated substitution compiler is exactly swapping across the literal
iterated rightward-move trace. -/
lemma iterated_substitution_affine
    (cutoff : ℕ)
    (outer inner : CWord Atom)
    (rights : List (CWord Atom)) :
    ∀ steps : ℕ,
      iteratedSubstitutionAffine cutoff outer inner steps rights =
        swapSecondAffine cutoff outer
          (iteratedMoveHigher inner steps rights)
  | 0 => by
      rfl
  | steps + 1 => by
      rw [iteratedSubstitutionAffine,
        iteratedMoveHigher,
        swap_move_higher]

end SASubsti
end TCTex
end Submission

-- Merged from JacobiIntegralPowerStrictTailCutoffOrderedOuterPacketTraceSubstitution.lean

/-!
# Filtered trace substitutions for factored Hall-Witt outer packets

The normalized Hall-Witt outer packet has one first-family selected word.
At the literal filtered-trace level, one iteration therefore has a triangular
substitution form:

* emit one fixed filtered packet-local prefix;
* replace every word in the previously emitted trace in place by its filtered
  two-word rightward-move packet.

This file records that exact recurrence and its arbitrary iteration.  It is
the trace-level counterpart of the transition-schedule factorization and is
the interface needed for polynomial occurrence counting.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace OTSubsti

open CWTrace
open WSTrace
open WHNorm
open WNTrace
open NPTail
open RMRecb
open OFProgra
open OFProgra.FRProgra
open TOFact
open SASubsti

/-- The local filtered packet emitted when one selected word moves rightward
across one carried word. -/
def cutoffMovePacket
    (cutoff : ℕ)
    (selected right : CWord Atom) :
    List (CWord Atom) :=
  unitBelowTrace cutoff [.commutator selected right, right]

/-- Rightward movement distributes over concatenation of carried traces. -/
lemma move_higher_append
    (selected : CWord Atom) :
    ∀ left right : List (CWord Atom),
      moveHigherTrace selected (left ++ right) =
        moveHigherTrace selected left ++
          moveHigherTrace selected right
  | [], _right => by
      rfl
  | word :: words, right => by
      simp only [List.cons_append, moveHigherTrace, List.cons.injEq, true_and]
      exact move_higher_append selected words right

/-- Filtered rightward movement is a flattened family of local filtered
two-word packets. -/
lemma move_higher_flat
    (cutoff : ℕ)
    (selected : CWord Atom) :
    ∀ rights : List (CWord Atom),
      unitBelowTrace cutoff (moveHigherTrace selected rights) =
        rights.flatMap (cutoffMovePacket cutoff selected)
  | [] => by
      rfl
  | right :: rights => by
      rw [moveHigherTrace]
      change
        unitBelowTrace cutoff
            ([.commutator selected right, right] ++
              moveHigherTrace selected rights) =
          cutoffMovePacket cutoff selected right ++
            rights.flatMap (cutoffMovePacket cutoff selected)
      rw [unit_below_append,
        move_higher_flat
          cutoff selected rights]
      rfl

/-- Fixed filtered trace contributed by one retained-prefix,
selected-singleton, retained-suffix packet before it acts on the carried
trace. -/
def filteredOuterPrefix
    (cutoff : ℕ)
    (before : List (CWord Atom))
    (selected : CWord Atom)
    (suffix : List (CWord Atom)) :
    List (CWord Atom) :=
  unitBelowTrace cutoff
    (before ++ moveHigherTrace selected suffix)

/-- Prefixing one packet with one selected occurrence is a fixed filtered
prefix followed by local substitution throughout the carried trace. -/
lemma prepend_filtered_move
    (cutoff : ℕ)
    (packet before suffix : List (CWord Atom))
    (selected : CWord Atom)
    (hpacket : packet = before ++ [selected] ++ suffix)
    (hselected : isFirstCurrent selected = true)
    (hbefore : ∀ word ∈ before, isFirstCurrent word ≠ true)
    (hsuffix : ∀ word ∈ suffix, isFirstCurrent word ≠ true)
    (tail : FRProgra) :
    (prepend cutoff isFirstCurrent packet tail).trace cutoff =
      filteredOuterPrefix cutoff before selected suffix ++
        (tail.trace cutoff).flatMap (cutoffMovePacket cutoff selected) := by
  rw [trace_prepend]
  rw [route_move_selected
    isFirstCurrent packet before suffix (tail.trace cutoff) selected
      hpacket hselected hbefore hsuffix]
  rw [move_higher_append,
    unit_below_append cutoff before,
    unit_below_append cutoff
      (moveHigherTrace selected suffix),
    move_higher_flat
      cutoff selected suffix,
    move_higher_flat
      cutoff selected (tail.trace cutoff)]
  unfold filteredOuterPrefix
  rw [unit_below_append,
    move_higher_flat,
    List.append_assoc]

/-- Iterate one fixed prefix-plus-substitution operation on a literal ordered
trace. -/
def iteratePrefixSubstitution
    (emittedPrefix : List (CWord Atom))
    (packetAt : CWord Atom → List (CWord Atom)) :
    ℕ → List (CWord Atom) → List (CWord Atom)
  | 0, tail =>
      tail
  | steps + 1, tail =>
      emittedPrefix ++
        (iteratePrefixSubstitution emittedPrefix packetAt steps tail).flatMap
          packetAt

/-- Iterated prefixing by one selected packet is exactly iteration of its
fixed prefix-plus-substitution trace operation. -/
lemma trace_prepend_substitution
    (cutoff : ℕ)
    (packet before suffix : List (CWord Atom))
    (selected : CWord Atom)
    (hpacket : packet = before ++ [selected] ++ suffix)
    (hselected : isFirstCurrent selected = true)
    (hbefore : ∀ word ∈ before, isFirstCurrent word ≠ true)
    (hsuffix : ∀ word ∈ suffix, isFirstCurrent word ≠ true) :
    ∀ (steps : ℕ) (tail : FRProgra),
      (iteratePrepend cutoff isFirstCurrent packet steps tail).trace cutoff =
        iteratePrefixSubstitution
          (filteredOuterPrefix cutoff before selected suffix)
          (cutoffMovePacket cutoff selected) steps (tail.trace cutoff)
  | 0, _tail => by
      rfl
  | steps + 1, tail => by
      rw [iteratePrepend,
        prepend_filtered_move
          cutoff packet before suffix selected hpacket hselected hbefore
            hsuffix,
        trace_prepend_substitution cutoff packet
          before suffix selected hpacket hselected hbefore hsuffix steps tail]
      rfl

/-- Fixed positive normalized outer-packet filtered trace prefix. -/
noncomputable def positiveFilteredPrefix
    (cutoff : ℕ) :
    List (CWord Atom) :=
  filteredOuterPrefix cutoff positiveOuterFactorization.before
    firstConventionalInverse positiveOuterFactorization.suffix

/-- Fixed negative inverted outer-packet filtered trace prefix. -/
noncomputable def negativeFilteredPrefix
    (cutoff : ℕ) :
    List (CWord Atom) :=
  filteredOuterPrefix cutoff negativeOuterFactorization.before
    firstConventionalWord negativeOuterFactorization.suffix

/-- Positive outer-packet prefixing is iteration of one fixed triangular
filtered-trace substitution. -/
lemma prepend_prefix_substitution
    (cutoff steps : ℕ)
    (tail : FRProgra) :
    (iteratePrepend cutoff isFirstCurrent WNTrace.trace
      steps tail).trace cutoff =
        iteratePrefixSubstitution
          (positiveFilteredPrefix cutoff)
          (cutoffMovePacket cutoff firstConventionalInverse)
            steps (tail.trace cutoff) := by
  apply
    trace_prepend_substitution cutoff
      WNTrace.trace positiveOuterFactorization.before
        positiveOuterFactorization.suffix firstConventionalInverse
  · exact positiveOuterFactorization.packet_eq
  · simp
  · exact positiveOuterFactorization.before_not_current
  · exact positiveOuterFactorization.suffix_not_current

/-- Negative outer-packet prefixing is iteration of one fixed triangular
filtered-trace substitution. -/
lemma iterate_prepend_substitution
    (cutoff steps : ℕ)
    (tail : FRProgra) :
    (iteratePrepend cutoff isFirstCurrent
      NNPower.inverseNormalizedTrace
        steps tail).trace cutoff =
      iteratePrefixSubstitution
        (negativeFilteredPrefix cutoff)
        (cutoffMovePacket cutoff firstConventionalWord)
          steps (tail.trace cutoff) := by
  apply
    trace_prepend_substitution cutoff
      NNPower.inverseNormalizedTrace
        negativeOuterFactorization.before
          negativeOuterFactorization.suffix firstConventionalWord
  · exact negativeOuterFactorization.packet_eq
  · simp
  · exact negativeOuterFactorization.before_not_current
  · exact negativeOuterFactorization.suffix_not_current

end OTSubsti
end TCTex
end Submission

-- Merged from JacobiIntegralPowerStrictTailCutoffOrderedOuterPacketCorrectionDepth.lean

/-!
# Strict-correction depth for Hall-Witt outer-packet substitutions

Each local outer-packet substitution replaces a carried word by its strict
bracket correction followed by the retained word.  The strict branch is
cutoff-nilpotent: every iteration brackets once more with the selected
Hall-Witt current word, so after bounded depth no strict branch remains below
the cutoff.

This file packages that stopping rule in the same filtered `flatMap` language
as the exact outer-packet trace substitution.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace TODepth

open CWTrace
open WSTrace
open NPTail
open FSOperat
open RMRecb
open OFProgra
open SASubsti
open OTSubsti

/-- The strict local branch emitted when a selected word crosses one carried
word, filtered below cutoff. -/
def cutoffCorrectionPacket
    (cutoff : ℕ)
    (selected right : CWord Atom) :
    List (CWord Atom) :=
  unitBelowTrace cutoff [.commutator selected right]

/-- One local move packet is its strict correction branch followed by the
filtered retained singleton. -/
lemma cutoff_move_append
    (cutoff : ℕ)
    (selected right : CWord Atom) :
    cutoffMovePacket cutoff selected right =
      cutoffCorrectionPacket cutoff selected right ++
        unitBelowTrace cutoff [right] := by
  unfold cutoffMovePacket cutoffCorrectionPacket
  rw [← unit_below_append]
  rfl

/-- If the carried word is already below cutoff, the retained local branch is
literally that word. -/
lemma move_append_singleton
    (cutoff : ℕ)
    (selected right : CWord Atom)
    (hright : right.weight (fun _ => 1) < cutoff) :
    cutoffMovePacket cutoff selected right =
      cutoffCorrectionPacket cutoff selected right ++ [right] := by
  rw [cutoff_move_append]
  simp [unitBelowTrace, hright]

/-- Flatten the filtered strict branch through a carried trace. -/
def cutoffCorrectionTrace
    (cutoff : ℕ)
    (selected : CWord Atom)
    (rights : List (CWord Atom)) :
    List (CWord Atom) :=
  rights.flatMap (cutoffCorrectionPacket cutoff selected)

/-- The filtered strict-branch `flatMap` is exactly the filtered literal
strict-correction trace. -/
lemma below_move_right
    (cutoff : ℕ)
    (selected : CWord Atom)
    (rights : List (CWord Atom)) :
    cutoffCorrectionTrace cutoff selected rights =
      unitBelowTrace cutoff
        (moveCorrectionTrace selected rights) := by
  unfold cutoffCorrectionTrace cutoffCorrectionPacket
  rw [move_right_flat]
  induction rights with
  | nil =>
      rfl
  | cons right rights ih =>
      rw [List.flatMap_cons, List.flatMap_cons,
        unit_below_append, ih]

/-- Iterate the filtered strict local substitution. -/
def iteratedCutoffTrace
    (cutoff : ℕ)
    (selected : CWord Atom) :
    ℕ → List (CWord Atom) → List (CWord Atom)
  | 0, rights =>
      rights
  | steps + 1, rights =>
      cutoffCorrectionTrace cutoff selected
        (iteratedCutoffTrace cutoff selected steps rights)

/-- Starting from a filtered source, iterated filtered strict substitution is
the filtered literal iterated strict-correction trace. -/
lemma iterated_cutoff_below
    (cutoff : ℕ)
    (selected : CWord Atom)
    (rights : List (CWord Atom)) :
    ∀ steps : ℕ,
      iteratedCutoffTrace cutoff selected steps
          (unitBelowTrace cutoff rights) =
        unitBelowTrace cutoff
          (iteratedMoveTrace selected steps rights)
  | 0 => by
      rfl
  | steps + 1 => by
      rw [iteratedCutoffTrace,
        below_move_right,
        iterated_cutoff_below cutoff selected
          rights steps,
        iteratedMoveTrace]
      exact
        (below_move_correction
          cutoff selected
            (iteratedMoveTrace selected steps rights)).symm

/-- Filtered strict substitution vanishes once its accumulated Hall-Witt
weight increase reaches the cutoff. -/
lemma iterated_below_nil
    (lowerWeight cutoff : ℕ)
    (selected : CWord Atom)
    (hselected :
      isFirstCurrent selected = true ∨
        isSecondCurrent selected = true)
    (rights : List (CWord Atom))
    (hrights :
      ∀ right ∈ rights,
        lowerWeight ≤ right.weight (fun _ => 1))
    (steps : ℕ)
    (hcutoff : cutoff ≤ steps * 3 + lowerWeight) :
    iteratedCutoffTrace cutoff selected steps
        (unitBelowTrace cutoff rights) =
      [] := by
  rw [iterated_cutoff_below]
  exact
    iterated_current_nil
      lowerWeight cutoff selected hselected rights hrights steps hcutoff

/-- The strict branch of a Hall-Witt current local substitution is uniformly
nilpotent modulo cutoff. -/
lemma iterated_cutoff_nil
    (cutoff : ℕ)
    (selected : CWord Atom)
    (hselected :
      isFirstCurrent selected = true ∨
        isSecondCurrent selected = true)
    (rights : List (CWord Atom)) :
    iteratedCutoffTrace cutoff selected cutoff
        (unitBelowTrace cutoff rights) =
      [] := by
  exact
    iterated_below_nil
      0 cutoff selected hselected rights
        (fun right _hright => Nat.zero_le (right.weight (fun _ => 1)))
          cutoff (by omega)

end TODepth
end TCTex
