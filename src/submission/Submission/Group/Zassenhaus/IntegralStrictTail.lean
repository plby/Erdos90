  funext target
  unfold boundedCountState boundedStateStep
    strictPredecessorCount singletonConstantCount
  have hcount :=
    count_constant_step cutoff transition terms target
  by_cases hlength : target.strictTransitions.length < cutoff
  · rw [if_pos hlength] at hcount ⊢
    cases hprevious : removePrepended? transition target with
    | none =>
        rw [hprevious] at hcount
        simp only at hcount ⊢
        by_cases hconstant :
            0 < cutoff ∧ singletonConstantTerm cutoff transition = target
        · rw [if_pos hconstant] at hcount ⊢
          exact_mod_cast hcount
        · rw [if_neg hconstant] at hcount ⊢
          exact_mod_cast hcount
    | some previous =>
        rw [hprevious] at hcount
        simp only at hcount ⊢
        by_cases hconstant :
