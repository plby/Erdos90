lemma nil_parent_succ
    {β : Type*}
    (wt : β → ℕ)
    (hwt : ∀ atom, 0 < wt atom)
    (x y z : CWord β)
    (cutoff : ℕ)
    (coefficient : ℤ)
    (hcutoff :
      cutoff ≤ x.weight wt + y.weight wt + z.weight wt + 1) :
    signedBelowTrace wt x y z cutoff coefficient = [] := by
  apply List.filter_eq_nil_iff.mpr
  intro word hword
  simp only [decide_eq_true_eq]
  intro hwordWeight
  have hparent :=
    parent_succ_trace
      wt hwt x y z coefficient word hword
  omega

/-- Native Hall-address termination form consumed by free-truncation
collection. -/
lemma address_nil_parent
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (coefficient : ℤ)
    (hcutoff :
      cutoff ≤
        x.weight PEAddres.weight +
            y.weight PEAddres.weight +
          z.weight PEAddres.weight + 1) :
    signedBelowTrace PEAddres.weight
      x y z cutoff coefficient = [] := by
  exact
    nil_parent_succ
      PEAddres.weight PEAddres.weight_pos
