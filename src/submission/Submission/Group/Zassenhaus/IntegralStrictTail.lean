/-!
# Polynomial closure for ordered Hall-Witt second-affine compilers

The ordered first-route recurrence produces affine second-route compilers,
not merely additive endomorphisms.  Package the corresponding finite
vocabulary invariant and prove that applying any fixed support-preserving
affine compiler preserves slotwise polynomial profile data.

For a first-family moved word, the dynamic swap compiler may first filter its
crossed trace below cutoff.  This keeps the recursive ordered state inside
the finite cutoff vocabulary without changing its compiled affine action.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace SAClos

open CWTrace
open WSTrace
open NPTail
open RMRecb
open TBProf
open ARProfa
open ARProfa.CPAffine
open ASFilt
open TACompos
open OFProgra
open SARec
open TOFact

/-- An affine cutoff-profile transform preserves the finite vocabulary when
both its linear part and its constant term do. -/
def PVAffine
    (cutoff : ℕ)
    (transform : CPAffine) :
    Prop :=
  PCVocabu cutoff transform.linear ∧
    SCVocabu cutoff transform.constant

/-- The affine identity preserves the finite cutoff vocabulary. -/
lemma preserves_cutoff_vocabulary
    (cutoff : ℕ) :
    PVAffine cutoff CPAffine.one := by
  constructor
  · exact preserves_vocabulary_one cutoff
  · intro word hword
    simp [CPAffine.one] at hword

/-- Affine composition preserves the finite cutoff vocabulary invariant. -/
lemma PVAffine.comp
    {cutoff : ℕ}
    {outer inner : CPAffine}
    (houter : PVAffine cutoff outer)
    (hinner : PVAffine cutoff inner) :
    PVAffine cutoff (outer.comp inner) := by
  constructor
  · exact houter.1.mul hinner.1
  · exact (houter.1 inner.constant hinner.2).add houter.2

/-- A constant supported profile family has constant polynomial coordinates
at every requested degree bound. -/
lemma cutoff_profile_constant
    (cutoff degreeBound : ℕ)
    (source : Multiset (CWord Atom))
    (hsource : SCVocabu cutoff source) :
    CPDataa cutoff degreeBound (fun _steps => source) := by
  constructor
  · intro _steps
    exact hsource
  · intro slot
    refine ⟨Polynomial.C (Multiset.count slot source : ℚ), ?_, ?_⟩
    · simp
    · intro steps
      simp

/-- Applying a fixed support-preserving affine transform preserves slotwise
polynomial profile data and its degree bound. -/
lemma CPDataa.apply_affine
    {cutoff degreeBound : ℕ}
    {family : ℕ → Multiset (CWord Atom)}
    (hfamily : CPDataa cutoff degreeBound family)
    (transform : CPAffine)
    (htransform : PVAffine cutoff transform) :
    CPDataa cutoff degreeBound
      (fun steps => transform.apply (family steps)) := by
  change
    CPDataa cutoff degreeBound
      (fun steps => transform.linear (family steps) + transform.constant)
  exact
    (hfamily.apply_fixed transform.linear htransform.1).add
      (cutoff_profile_constant cutoff degreeBound
        transform.constant htransform.2)

/-- The constant term of a compiled trace is the cutoff profile obtained by
routing that trace onto the empty carried tail. -/
lemma constant_route_nil
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (source : List (CWord Atom)) :
    (ofTrace cutoff isCurrent source).constant =
      cutoffProfile cutoff (routeOnto isCurrent source []) := by
  have hprofile :=
    trace_cutoff_profile cutoff isCurrent [] source
  simpa [CPAffine.apply, cutoffProfile, unitBelowTrace] using
    hprofile

/-- Every literal compiled trace preserves the affine finite-vocabulary
invariant. -/
lemma preserves_affine_trace
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (source : List (CWord Atom)) :
    PVAffine cutoff
      (ofTrace cutoff isCurrent source) := by
  constructor
  · exact preserves_vocabulary_linear cutoff isCurrent source
  · rw [constant_route_nil]
    exact
      supported_vocabulary_profile cutoff
        (routeOnto isCurrent source [])

/-- A first-family dynamic swap may filter its crossed trace below cutoff
before compilation without changing the resulting affine action. -/
lemma swap_affine_below
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (left : CWord Atom)
    (hleft : isFirstCurrent left = true)
    (rights : List (CWord Atom)) :
    swapSecondAffine cutoff left (unitBelowTrace cutoff rights) =
      swapSecondAffine cutoff left rights := by
  rw [← move_higher_affine cutoff left hleft
      (unitBelowTrace cutoff rights),
    ← move_higher_affine cutoff left hleft rights]
  rw [← second_current_below cutoff hcutoff
      (moveHigherTrace left (unitBelowTrace cutoff rights)),
    ← second_current_below cutoff hcutoff
      (moveHigherTrace left rights)]
  rw [unit_move_higher
    cutoff left rights]

/-- Every dynamic swap of a first-family moved word preserves the affine
finite-vocabulary invariant. -/
lemma preserves_swap_second
    (cutoff : ℕ)
    (left : CWord Atom)
    (hleft : isFirstCurrent left = true)
    (rights : List (CWord Atom)) :
    PVAffine cutoff
      (swapSecondAffine cutoff left rights) := by
  rw [← move_higher_affine
    cutoff left hleft rights]
  exact
    preserves_affine_trace cutoff isSecondCurrent
      (moveHigherTrace left rights)

/-- The fixed contribution of a factored outer packet preserves the affine
finite-vocabulary invariant. -/
lemma preserves_vocabulary_affine
    (cutoff : ℕ)
    (before : List (CWord Atom))
    (selected : CWord Atom)
    (suffix : List (CWord Atom))
    (hselected : isFirstCurrent selected = true) :
    PVAffine cutoff
      (fixedSecondAffine cutoff before selected suffix) := by
  exact
    (preserves_affine_trace cutoff isSecondCurrent before).comp
      (preserves_swap_second
        cutoff selected hselected suffix)

/-- The coefficient-independent positive outer-packet prefix preserves the
affine finite-vocabulary invariant. -/
lemma preserves_affine_second
    (cutoff : ℕ) :
    PVAffine cutoff
      (positiveSecondAffine cutoff) := by
  apply preserves_vocabulary_affine
  simp

/-- The coefficient-independent negative outer-packet prefix preserves the
affine finite-vocabulary invariant. -/
lemma preserves_vocabulary_second
    (cutoff : ℕ) :
    PVAffine cutoff
      (negativeSecondAffine cutoff) := by
  apply preserves_vocabulary_affine
  simp

/-- Applying the fixed positive outer-packet contribution preserves profile
polynomial data. -/
lemma CPDataa.applyp_fixed_packs
    {cutoff degreeBound : ℕ}
    {family : ℕ → Multiset (CWord Atom)}
    (hfamily : CPDataa cutoff degreeBound family) :
    CPDataa cutoff degreeBound
      (fun steps =>
        (positiveSecondAffine cutoff).apply (family steps)) :=
  CPDataa.apply_affine hfamily
    (positiveSecondAffine cutoff)
    (preserves_affine_second
      cutoff)

/-- Applying the fixed negative outer-packet contribution preserves profile
polynomial data. -/
lemma CPDataa.applyn_fixed_packs
    {cutoff degreeBound : ℕ}
    {family : ℕ → Multiset (CWord Atom)}
    (hfamily : CPDataa cutoff degreeBound family) :
    CPDataa cutoff degreeBound
      (fun steps =>
        (negativeSecondAffine cutoff).apply (family steps)) :=
  CPDataa.apply_affine hfamily
    (negativeSecondAffine cutoff)
    (preserves_vocabulary_second
      cutoff)

end SAClos
end TCTex
end Submission

