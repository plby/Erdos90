lemma below_move_perm
    (cutoff : ℕ)
    (left : CWord Atom)
    {rights nextRights : List (CWord Atom)}
    (hperm :
      List.Perm
        (unitBelowTrace cutoff rights)
        (unitBelowTrace cutoff nextRights)) :
    List.Perm
      (unitBelowTrace cutoff (moveCorrectionTrace left rights))
      (unitBelowTrace cutoff
        (moveCorrectionTrace left nextRights)) := by
  conv_lhs =>
    rw [
      below_move_correction
        cutoff left rights]
  conv_rhs =>
    rw [
      below_move_correction
        cutoff left nextRights]
  exact
    (hperm.map fun right => CWord.commutator left right).filter
      (fun word : CWord Atom =>
        decide (word.weight (fun _ => 1) < cutoff))

/-- Permuting retained traces preserves their fixed-slot vectors. -/
lemma fixed_slot_perm
    (cutoff : ℕ)
    {left right : List (CWord Atom)}
    (hperm :
      List.Perm
        (unitBelowTrace cutoff left)
        (unitBelowTrace cutoff right)) :
    fixedSlotVector cutoff left =
      fixedSlotVector cutoff right := by
  unfold fixedSlotVector
  apply List.map_congr_left
  intro slot _hslot
  exact hperm.count_eq slot

/--
The fixed-slot strict correction vector depends only on the fixed-slot source
vector.
-/
lemma slot_move_congr
    (cutoff : ℕ)
    (left : CWord Atom)
    {rights nextRights : List (CWord Atom)}
    (hvectors :
      fixedSlotVector cutoff rights =
        fixedSlotVector cutoff nextRights) :
    fixedSlotVector cutoff
        (moveCorrectionTrace left rights) =
      fixedSlotVector cutoff
        (moveCorrectionTrace left nextRights) := by
  apply fixed_slot_perm
  apply below_move_perm
  exact
    perm_slot_vector
      cutoff rights nextRights
      (supportedBelowCutoff cutoff rights)
      (supportedBelowCutoff cutoff nextRights)
      hvectors

/-- The full rightward-move vector also depends only on its source vector. -/
lemma fixed_move_congr
    (cutoff : ℕ)
    (left : CWord Atom)
    {rights nextRights : List (CWord Atom)}
    (hvectors :
      fixedSlotVector cutoff rights =
        fixedSlotVector cutoff nextRights) :
    fixedSlotVector cutoff
        (moveHigherTrace left rights) =
      fixedSlotVector cutoff
        (moveHigherTrace left nextRights) := by
  rw [
    slot_move_higher,
    slot_move_higher,
    slot_move_congr
      cutoff left hvectors,
    hvectors]

/-- Choose one trace realizing a fixed-slot vector when one exists. -/
noncomputable def realizingTrace
    (cutoff : ℕ)
    (vector : List ℕ) :
    List (CWord Atom) := by
  classical
  exact
    if hvector :
        ∃ source,
          fixedSlotVector cutoff source = vector then
      Classical.choose hvector
    else
      []

/-- The chosen realization of a realizable vector has the requested vector. -/
lemma fixed_slot_realizing
    (cutoff : ℕ)
    (source : List (CWord Atom)) :
    fixedSlotVector cutoff
        (realizingTrace cutoff
          (fixedSlotVector cutoff source)) =
      fixedSlotVector cutoff source := by
  classical
  rw [realizingTrace]
  split
  next hvector =>
    exact Classical.choose_spec hvector
  next hvector =>
    exact False.elim (hvector ⟨source, rfl⟩)

/-- Strict correction operator induced on cutoff fixed-slot vectors. -/
noncomputable def cutoffCorrectionOperator
    (cutoff : ℕ)
    (left : CWord Atom)
    (vector : List ℕ) :
    List ℕ :=
  fixedSlotVector cutoff
    (moveCorrectionTrace left (realizingTrace cutoff vector))

/-- On every realizable vector, the induced correction operator agrees with
the literal strict correction trace. -/
lemma operator_slot_vector
    (cutoff : ℕ)
    (left : CWord Atom)
    (rights : List (CWord Atom)) :
    cutoffCorrectionOperator cutoff left
        (fixedSlotVector cutoff rights) =
      fixedSlotVector cutoff
        (moveCorrectionTrace left rights) := by
  unfold cutoffCorrectionOperator
  exact
    slot_move_congr
      cutoff left
      (fixed_slot_realizing cutoff rights)

/-- Full rightward-move operator induced on cutoff fixed-slot vectors. -/
noncomputable def cutoffMoveOperator
    (cutoff : ℕ)
    (left : CWord Atom)
    (vector : List ℕ) :
    List ℕ :=
  pointwiseAdd (cutoffCorrectionOperator cutoff left vector) vector

/-- On every realizable vector, the induced full move operator agrees with
literal rightward routing. -/
lemma move_operator_slot
    (cutoff : ℕ)
    (left : CWord Atom)
    (rights : List (CWord Atom)) :
    cutoffMoveOperator cutoff left
        (fixedSlotVector cutoff rights) =
      fixedSlotVector cutoff
        (moveHigherTrace left rights) := by
  rw [slot_move_higher]
  simp only [cutoffMoveOperator,
    operator_slot_vector]

/-- Iterate the induced strict correction operator. -/
noncomputable def iteratedCutoffOperator
    (cutoff : ℕ)
    (left : CWord Atom) :
    ℕ → List ℕ → List ℕ
  | 0, vector =>
      vector
  | steps + 1, vector =>
      cutoffCorrectionOperator cutoff left
        (iteratedCutoffOperator cutoff left steps vector)

/-- Vector-operator iteration agrees with literal strict correction trace
iteration. -/
lemma iterated_operator_slot
    (cutoff : ℕ)
    (left : CWord Atom)
    (rights : List (CWord Atom)) :
    ∀ steps : ℕ,
      iteratedCutoffOperator cutoff left steps
          (fixedSlotVector cutoff rights) =
        fixedSlotVector cutoff
          (iteratedMoveTrace left steps rights)
  | 0 => by
      rfl
  | steps + 1 => by
      rw [iteratedCutoffOperator,
        iterated_operator_slot
          cutoff left rights steps,
        operator_slot_vector]
      rfl

/--
For either Hall-Witt current family, the induced strict correction operator
is uniformly nilpotent modulo cutoff on every realizable vector.
-/
lemma iterated_operator_current
    (cutoff : ℕ)
    (left : CWord Atom)
    (hleft :
      NPTail.isFirstCurrent left = true ∨
        NPTail.isSecondCurrent left = true)
    (rights : List (CWord Atom)) :
    iteratedCutoffOperator cutoff left cutoff
        (fixedSlotVector cutoff rights) =
      slotMultiplicityVector cutoff := by
  rw [
    iterated_operator_slot,
    slot_iterated_current
      cutoff left hleft rights]

end FSOperat
end TCTex
end Submission

-- Merged from JacobiIntegralPowerStrictTailCutoffBinomialProfile.lean

/-!
# Binomial profiles for Hall-Witt cutoff routing

Forget the order of a below-cutoff formal trace while retaining its
multiplicities as a multiset.  Strict bracket corrections define an additive
endomorphism `C` of these multisets.  One full rightward move is `C + 1`.

Consequently, repeated movement by one Hall-Witt current word is governed by
the binomial theorem.  Because `C` raises weight, all iterated correction
terms at and beyond the cutoff vanish for current words.  This is the finite
binomial-polynomial profile behind one routed Hall-Witt block.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace TBProf

open CWTrace
open WSTrace
open FSOperat
open RMRecb

/-- Multiset multiplicity profile of one formal trace below cutoff. -/
def cutoffProfile
    (cutoff : ℕ)
    (source : List (CWord Atom)) :
    Multiset (CWord Atom) :=
  ↑(unitBelowTrace cutoff source)

/-- Strict bracket-correction endomorphism on below-cutoff multiplicity
profiles. -/
def correctionEnd
    (cutoff : ℕ)
    (left : CWord Atom) :
    AddMonoid.End (Multiset (CWord Atom)) where
  toFun source :=
    (source.map (CWord.commutator left)).filter fun word =>
      word.weight (fun _ => 1) < cutoff
  map_zero' := by
    simp
  map_add' source next := by
    simp

/-- The strict correction endomorphism computes the cutoff profile of the
literal strict correction trace. -/
lemma cutoff_profile_move
    (cutoff : ℕ)
    (left : CWord Atom)
    (rights : List (CWord Atom)) :
    cutoffProfile cutoff (moveCorrectionTrace left rights) =
      correctionEnd cutoff left (cutoffProfile cutoff rights) := by
  unfold cutoffProfile
  rw [
    below_move_correction]
  rfl

/-- The below-cutoff profile of one full rightward move is `C(profile) +
profile`. -/
lemma profile_move_higher
    (cutoff : ℕ)
    (left : CWord Atom)
    (rights : List (CWord Atom)) :
    cutoffProfile cutoff (moveHigherTrace left rights) =
      correctionEnd cutoff left (cutoffProfile cutoff rights) +
        cutoffProfile cutoff rights := by
  rw [← cutoff_profile_move]
  unfold cutoffProfile
  apply Multiset.ext.mpr
  intro slot
  simpa [unitBelowMultiplicity] using
    below_multiplicity_move
      cutoff left slot rights

/-- Powers of the strict correction endomorphism compute iterated literal
strict correction traces. -/
lemma correction_end_profile
    (cutoff : ℕ)
    (left : CWord Atom)
    (rights : List (CWord Atom)) :
    ∀ steps : ℕ,
      ((correctionEnd cutoff left) ^ steps) (cutoffProfile cutoff rights) =
        cutoffProfile cutoff
          (iteratedMoveTrace left steps rights)
  | 0 => by
      rfl
  | steps + 1 => by
      rw [_root_.pow_succ']
      change
        correctionEnd cutoff left
            (((correctionEnd cutoff left) ^ steps)
              (cutoffProfile cutoff rights)) =
          _
      rw [correction_end_profile cutoff left rights steps]
      exact (cutoff_profile_move cutoff left _).symm

/-- Full rightward-move endomorphism `C + 1`. -/
def moveEnd
    (cutoff : ℕ)
    (left : CWord Atom) :
    AddMonoid.End (Multiset (CWord Atom)) :=
  correctionEnd cutoff left + 1

/-- Iterate one literal full rightward move. -/
def iteratedMoveHigher
    (left : CWord Atom) :
    ℕ → List (CWord Atom) → List (CWord Atom)
  | 0, rights =>
      rights
  | steps + 1, rights =>
      moveHigherTrace left
        (iteratedMoveHigher left steps rights)

/-- The full move endomorphism computes one literal rightward move profile. -/
lemma move_end_cutoff
    (cutoff : ℕ)
    (left : CWord Atom)
    (rights : List (CWord Atom)) :
    moveEnd cutoff left (cutoffProfile cutoff rights) =
      cutoffProfile cutoff (moveHigherTrace left rights) := by
  rw [profile_move_higher]
  change
    correctionEnd cutoff left (cutoffProfile cutoff rights) +
        cutoffProfile cutoff rights =
      _
  rfl

/-- Powers of the full move endomorphism compute iterated literal routing
profiles. -/
lemma move_end_profile
    (cutoff : ℕ)
    (left : CWord Atom)
    (rights : List (CWord Atom)) :
    ∀ steps : ℕ,
      ((moveEnd cutoff left) ^ steps) (cutoffProfile cutoff rights) =
        cutoffProfile cutoff (iteratedMoveHigher left steps rights)
  | 0 => by
      rfl
  | steps + 1 => by
      rw [_root_.pow_succ']
      change
        moveEnd cutoff left
            (((moveEnd cutoff left) ^ steps) (cutoffProfile cutoff rights)) =
          _
      rw [move_end_profile cutoff left rights steps]
      exact move_end_cutoff cutoff left _

/-- Endomorphism-level binomial expansion for repeated full moves. -/
lemma move_end_sum
    (cutoff : ℕ)
    (left : CWord Atom)
    (steps : ℕ) :
    (moveEnd cutoff left) ^ steps =
      ∑ k ∈ Finset.range (steps + 1),
        (correctionEnd cutoff left) ^ k *
          (1 :
            AddMonoid.End (Multiset (CWord Atom))) ^ (steps - k) *
            (steps.choose k :
              AddMonoid.End (Multiset (CWord Atom))) := by
  exact (Commute.one_right (correctionEnd cutoff left)).add_pow steps

/-- Evaluate a finite sum of additive endomorphisms pointwise. -/
lemma end_sum_apply
    (source : Multiset (CWord Atom))
    (families :
      ℕ → AddMonoid.End (Multiset (CWord Atom)))
    (slots : Finset ℕ) :
    (∑ k ∈ slots, families k) source =
      ∑ k ∈ slots, families k source := by
  induction slots using Finset.induction_on with
  | empty =>
      rfl
  | @insert k slots hk ih =>
      rw [Finset.sum_insert hk, Finset.sum_insert hk]
      change
        families k source + (∑ x ∈ slots, families x) source =
          families k source + ∑ x ∈ slots, families x source
      rw [ih]

/-- Applying an endomorphism after a natural scalar cast is natural scalar
multiplication of its output. -/
lemma end_nat_cast
    (f : AddMonoid.End (Multiset (CWord Atom)))
    (multiplicity : ℕ)
    (source : Multiset (CWord Atom)) :
    (f *
        (multiplicity :
          AddMonoid.End (Multiset (CWord Atom)))) source =
      multiplicity • f source := by
  change f (multiplicity • source) = multiplicity • f source
  exact map_nsmul f multiplicity source

/--
Repeated rightward movement has an explicit finite binomial multiplicity
profile.
-/
lemma iterated_move_sum
    (cutoff : ℕ)
    (left : CWord Atom)
    (rights : List (CWord Atom))
    (steps : ℕ) :
    cutoffProfile cutoff (iteratedMoveHigher left steps rights) =
      ∑ k ∈ Finset.range (steps + 1),
        steps.choose k •
          cutoffProfile cutoff
            (iteratedMoveTrace left k rights) := by
  rw [← move_end_profile]
  rw [move_end_sum]
  rw [end_sum_apply]
  apply Finset.sum_congr rfl
  intro k _hk
  simp only [one_pow, mul_one]
  rw [end_nat_cast,
    correction_end_profile]

/--
For a Hall-Witt current word, every strict correction profile at or beyond
the cutoff depth vanishes.
-/
lemma cutoff_move_current
    (cutoff : ℕ)
    (left : CWord Atom)
    (hleft :
      NPTail.isFirstCurrent left = true ∨
        NPTail.isSecondCurrent left = true)
    (rights : List (CWord Atom))
    (steps : ℕ)
    (hsteps : cutoff ≤ steps) :
    cutoffProfile cutoff
        (iteratedMoveTrace left steps rights) =
      0 := by
  unfold cutoffProfile
  rw [
    iterated_current_nil
      0 cutoff left hleft rights
      (fun right _hright => Nat.zero_le (right.weight (fun _ => 1)))
      steps]
  · rfl
  · omega

/-- Count one slot across a finite sum of multiset profiles. -/
lemma count_finset_sum
    (slot : CWord Atom)
    (families : ℕ → Multiset (CWord Atom))
    (slots : Finset ℕ) :
    Multiset.count slot (∑ k ∈ slots, families k) =
      ∑ k ∈ slots, Multiset.count slot (families k) := by
  change
    (Multiset.countAddMonoidHom slot) (∑ k ∈ slots, families k) =
      _
  exact map_sum (Multiset.countAddMonoidHom slot) families slots

/--
Every fixed slot in a repeatedly moved trace has an explicit binomial
multiplicity formula.
-/
lemma below_iterated_move
    (cutoff : ℕ)
    (left : CWord Atom)
    (rights : List (CWord Atom))
    (steps : ℕ)
    (slot : CWord Atom) :
    unitBelowMultiplicity cutoff
        (iteratedMoveHigher left steps rights) slot =
      ∑ k ∈ Finset.range (steps + 1),
        steps.choose k *
          unitBelowMultiplicity cutoff
            (iteratedMoveTrace left k rights) slot := by
  have hprofile :=
    congrArg (Multiset.count slot)
      (iterated_move_sum
        cutoff left rights steps)
  rw [count_finset_sum] at hprofile
  simpa [cutoffProfile, unitBelowMultiplicity,
    Multiset.count_nsmul] using hprofile

/-- Scalar fixed-slot coefficients vanish at and beyond the current-family
cutoff depth. -/
lemma iterated_move_current
    (cutoff : ℕ)
    (left : CWord Atom)
    (hleft :
      NPTail.isFirstCurrent left = true ∨
        NPTail.isSecondCurrent left = true)
    (rights : List (CWord Atom))
    (steps : ℕ)
    (hsteps : cutoff ≤ steps)
    (slot : CWord Atom) :
    unitBelowMultiplicity cutoff
        (iteratedMoveTrace left steps rights) slot =
      0 := by
  have hprofile :=
    congrArg (Multiset.count slot)
      (cutoff_move_current
        cutoff left hleft rights steps hsteps)
  simpa [cutoffProfile, unitBelowMultiplicity] using hprofile

end TBProf
end TCTex
end Submission

-- Merged from JacobiIntegralPowerStrictTailCutoffAffineRouteProfile.lean

/-!
# Affine cutoff profiles for stable Hall-Witt routing

Stable routing is naturally stateful: process a source prefix against an
already-routed higher suffix.  Below cutoff, each selected word applies the
linear move operator `1 + C`, while each unselected word adds one retained
singleton profile.  Therefore every fixed source packet compiles to one affine
transformation of cutoff profiles.

This file keeps the literal ordered trace and its multiplicity shadow linked.
In particular, routing a repeated fixed packet is iteration of one fixed
affine profile transformation.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace ARProfa

open CWTrace
open WSTrace
open NPTail
open TBProf

/--
Route one source prefix onto an already-routed higher suffix.  Unlike
`stableRoute`, the selected suffix is deliberately omitted: this is exactly
the state transformer underlying the first component of stable routing.
-/
def routeOnto
    (isCurrent : CWord Atom → Bool) :
    List (CWord Atom) →
      List (CWord Atom) →
        List (CWord Atom)
  | [], rights =>
      rights
  | word :: words, rights =>
      let routed := routeOnto isCurrent words rights
      if isCurrent word = true then
        moveHigherTrace word routed
      else
        word :: routed

/-- Routing onto a suffix composes across source concatenation. -/
lemma routeOnto_append
    (isCurrent : CWord Atom → Bool)
    (left right rights : List (CWord Atom)) :
    routeOnto isCurrent (left ++ right) rights =
      routeOnto isCurrent left (routeOnto isCurrent right rights) := by
  induction left with
  | nil =>
      rfl
  | cons word left ih =>
      simp only [List.cons_append, routeOnto]
      rw [ih]

/-- The first component of stable routing is routing onto the empty higher
suffix. -/
lemma stable_fst_nil
    (isCurrent : CWord Atom → Bool)
    (source : List (CWord Atom)) :
    (stableRoute isCurrent source).1 =
      routeOnto isCurrent source [] := by
  induction source with
  | nil =>
      rfl
  | cons word source ih =>
      simp only [stableRoute, routeOnto]
      rw [ih]
      split <;> rfl

/-- Cutoff profiles turn concatenation into addition. -/
lemma cutoffProfile_append
    (cutoff : ℕ)
    (left right : List (CWord Atom)) :
    cutoffProfile cutoff (left ++ right) =
      cutoffProfile cutoff left + cutoffProfile cutoff right := by
  unfold cutoffProfile
  simp [
    RMRecb.unitBelowTrace]

/-- One affine transformation of cutoff multiplicity profiles. -/
structure CPAffine where
  linear :
    AddMonoid.End (Multiset (CWord Atom))
  constant :
    Multiset (CWord Atom)

namespace CPAffine

/-- Evaluate one affine cutoff-profile transformation. -/
def apply
    (transform : CPAffine)
    (source : Multiset (CWord Atom)) :
    Multiset (CWord Atom) :=
  transform.linear source + transform.constant

/-- Identity affine transformation. -/
def one :
    CPAffine where
  linear := 1
  constant := 0

/-- Composition of affine transformations, with `outer` applied last. -/
def comp
    (outer inner : CPAffine) :
    CPAffine where
  linear := outer.linear * inner.linear
  constant := outer.linear inner.constant + outer.constant

@[simp]
lemma apply_one
    (source : Multiset (CWord Atom)) :
    one.apply source = source := by
  simp [apply, one]

@[simp]
lemma apply_comp
    (outer inner : CPAffine)
    (source : Multiset (CWord Atom)) :
    (outer.comp inner).apply source =
      outer.apply (inner.apply source) := by
  simp [apply, comp, add_assoc]

@[simp]
lemma one_comp
    (transform : CPAffine) :
    one.comp transform = transform := by
  cases transform
  simp [one, comp]

@[simp]
lemma comp_one
    (transform : CPAffine) :
    transform.comp one = transform := by
  cases transform
  simp [one, comp]

lemma comp_assoc
    (outer middle inner : CPAffine) :
    (outer.comp middle).comp inner =
      outer.comp (middle.comp inner) := by
  cases outer
  cases middle
  cases inner
  simp [comp, mul_assoc, add_assoc]

/-- Affine action of one selected current word. -/
def selected
    (cutoff : ℕ)
    (word : CWord Atom) :
    CPAffine where
  linear := moveEnd cutoff word
  constant := 0

/-- Affine action of one retained unselected word. -/
def retained
    (cutoff : ℕ)
    (word : CWord Atom) :
    CPAffine where
  linear := 1
  constant := cutoffProfile cutoff [word]

@[simp]
lemma apply_selected
    (cutoff : ℕ)
    (word : CWord Atom)
    (source : Multiset (CWord Atom)) :
    (selected cutoff word).apply source =
      moveEnd cutoff word source := by
  simp [apply, selected]

@[simp]
lemma apply_retained
    (cutoff : ℕ)
    (word : CWord Atom)
    (source : Multiset (CWord Atom)) :
    (retained cutoff word).apply source =
      cutoffProfile cutoff [word] + source := by
  simp [apply, retained, add_comm]

/-- Compile one literal source trace to its affine cutoff-profile
transformation. -/
def ofTrace
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool) :
    List (CWord Atom) →
      CPAffine
  | [] =>
      one
  | word :: words =>
      (if isCurrent word = true then
          selected cutoff word
        else
          retained cutoff word).comp
        (ofTrace cutoff isCurrent words)

/-- Compiling a concatenated trace composes the compiled affine actions. -/
lemma ofTrace_append
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (left right : List (CWord Atom)) :
    ofTrace cutoff isCurrent (left ++ right) =
      (ofTrace cutoff isCurrent left).comp
        (ofTrace cutoff isCurrent right) := by
  induction left with
  | nil =>
      exact (one_comp (ofTrace cutoff isCurrent right)).symm
  | cons word left ih =>
      simp only [List.cons_append, ofTrace]
      rw [ih, comp_assoc]

/-- The affine compiler exactly computes the cutoff profile of literal
stateful routing. -/
lemma trace_cutoff_profile
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (rights : List (CWord Atom)) :
    ∀ source : List (CWord Atom),
      (ofTrace cutoff isCurrent source).apply (cutoffProfile cutoff rights) =
        cutoffProfile cutoff (routeOnto isCurrent source rights)
  | [] => by
      exact apply_one (cutoffProfile cutoff rights)
  | word :: words => by
      by_cases hcurrent : isCurrent word = true
      · simp only [ofTrace, if_pos hcurrent, routeOnto, apply_comp,
          apply_selected]
        rw [trace_cutoff_profile cutoff isCurrent rights words,
          move_end_cutoff]
      · simp only [ofTrace, if_neg hcurrent, routeOnto, apply_comp,
          apply_retained]
        rw [trace_cutoff_profile cutoff isCurrent rights words]
        exact (cutoffProfile_append cutoff [word]
          (routeOnto isCurrent words rights)).symm

/-- Iteration of one fixed affine cutoff-profile transformation. -/
def iterate
    (transform : CPAffine) :
    ℕ → CPAffine
  | 0 =>
      one
  | steps + 1 =>
      transform.comp (iterate transform steps)

@[simp]
lemma apply_iterate_zero
    (transform : CPAffine)
    (source : Multiset (CWord Atom)) :
    (iterate transform 0).apply source = source := by
  exact apply_one source

lemma apply_iterate_succ
    (transform : CPAffine)
    (steps : ℕ)
    (source : Multiset (CWord Atom)) :
    (iterate transform (steps + 1)).apply source =
      transform.apply ((iterate transform steps).apply source) := by
  exact apply_comp transform (iterate transform steps) source

/-- Repeating one trace compiles to iterating its one-packet affine action. -/
lemma trace_repeat
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom)) :
    ∀ steps : ℕ,
      ofTrace cutoff isCurrent (repeatTrace steps packet) =
        iterate (ofTrace cutoff isCurrent packet) steps
  | 0 => by
      rfl
  | steps + 1 => by
      rw [repeatTrace, ofTrace_append,
        trace_repeat cutoff isCurrent packet steps]
      rfl

/-- Compiling a repeated packet is exactly affine iteration of the compiled
one-packet action. -/
lemma iterate_cutoff_profile
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (packet rights : List (CWord Atom)) :
    ∀ steps : ℕ,
      (iterate (ofTrace cutoff isCurrent packet) steps).apply
          (cutoffProfile cutoff rights) =
        cutoffProfile cutoff
          (routeOnto isCurrent (repeatTrace steps packet) rights)
  | 0 => by
      exact apply_one (cutoffProfile cutoff rights)
  | steps + 1 => by
      rw [apply_iterate_succ,
        iterate_cutoff_profile cutoff isCurrent packet rights
          steps,
        trace_cutoff_profile]
      simp only [repeatTrace, routeOnto_append]

/-- Stable routing of a repeated fixed packet is affine iteration from the
zero cutoff profile. -/
lemma stable_fst_repeat
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom))
    (steps : ℕ) :
    cutoffProfile cutoff
        (stableRoute isCurrent (repeatTrace steps packet)).1 =
      (iterate (ofTrace cutoff isCurrent packet) steps).apply 0 := by
  rw [stable_fst_nil,
    ← iterate_cutoff_profile cutoff isCurrent packet [] steps]
  rfl

/-- The compiled affine action computes the cutoff profile of the first
stable-routing component for every literal source trace. -/
lemma profile_stable_fst
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (source : List (CWord Atom)) :
    cutoffProfile cutoff (stableRoute isCurrent source).1 =
      (ofTrace cutoff isCurrent source).apply 0 := by
  rw [stable_fst_nil,
    ← trace_cutoff_profile cutoff isCurrent [] source]
  rfl

end CPAffine

end ARProfa
end TCTex
