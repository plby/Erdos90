/-- Evaluate a paired strict-tail recipe with the same signed dispatch as the
literal integral strict trace. -/
noncomputable def eval
    {cutoff : ℕ}
    (expansion : ISExp cutoff) :
    ℤ → ℤ
  | .ofNat multiplicity =>
      expansion.natural.eval multiplicity
  | .negSucc multiplicity =>
      expansion.negative.eval (multiplicity + 1)

end ISExp

