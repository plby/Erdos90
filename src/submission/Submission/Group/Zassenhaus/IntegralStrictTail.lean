/-!
# Concrete-slot expansions for substituted global Hall-Witt recipes

After substitution, several formal Hall-Witt slots may bind to the same
concrete commutator word.  This file packages the finite collision sum for one
concrete word as a paired positive-and-negative Newton expansion.  Evaluating
that object recovers the multiplicity of the concrete word in the physically
truncated bound strict tail.

This file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace
  GSExp

open WSTrace
open STSubsti
open TOCoordi
open STVocabu
open PMExp
open
  GRExp
open
  GPRecons
open
  GSRecons
open
  SSExpa

/-- The empty paired positive-and-negative strict-tail expansion. -/
noncomputable def integralSlotExpansion
    (cutoff : ℕ) :
    ISExp cutoff where
  natural :=
    BCExp.zero 1
      (naturalStrictBound cutoff)
  negative :=
    BCExp.zero 1
      (negativeStrictBound cutoff)

/-- Add two paired strict-tail expansions branchwise. -/
noncomputable def integralSlotAdd
    {cutoff : ℕ}
    (left right : ISExp cutoff) :
    ISExp cutoff where
  natural := BCExp.add left.natural right.natural
  negative := BCExp.add left.negative right.negative

/-- Sum a finite list of paired strict-tail expansions. -/
noncomputable def integralSlotSum
    (cutoff : ℕ) :
    List (ISExp cutoff) →
      ISExp cutoff
  | [] => integralSlotExpansion cutoff
  | expansion :: expansions =>
      integralSlotAdd expansion
        (integralSlotSum cutoff expansions)

/-- Sum a finite family of paired strict-tail expansions. -/
noncomputable def slotFinsetSum
    {ι : Type*}
    (cutoff : ℕ)
    (indices : Finset ι)
    (expansion : ι → ISExp cutoff) :
    ISExp cutoff :=
  integralSlotSum cutoff (indices.toList.map expansion)

@[simp]
lemma slot_expansion_zero
    (cutoff : ℕ)
    (coefficient : ℤ) :
    (integralSlotExpansion cutoff).eval coefficient = 0 := by
  cases coefficient <;>
    simp [integralSlotExpansion,
      ISExp.eval,
      BCExp.eval_zero]

@[simp]
lemma slot_expansion_add
    {cutoff : ℕ}
    (left right : ISExp cutoff)
    (coefficient : ℤ) :
    (integralSlotAdd left right).eval coefficient =
      left.eval coefficient + right.eval coefficient := by
  cases coefficient <;>
    simp [integralSlotAdd,
      ISExp.eval,
      BCExp.eval_add]

@[simp]
lemma slot_expansion_sum
    (cutoff : ℕ)
    (expansions : List (ISExp cutoff))
    (coefficient : ℤ) :
    (integralSlotSum cutoff expansions).eval
        coefficient =
      (expansions.map fun expansion => expansion.eval coefficient).sum := by
  induction expansions with
  | nil =>
      simp [integralSlotSum]
  | cons expansion expansions ih =>
      simp [integralSlotSum, ih]

@[simp]
lemma slot_finset_sum
    {ι : Type*}
    (cutoff : ℕ)
    (indices : Finset ι)
    (expansion : ι → ISExp cutoff)
    (coefficient : ℤ) :
    (slotFinsetSum cutoff indices expansion).eval
        coefficient =
      ∑ index ∈ indices, (expansion index).eval coefficient := by
  classical
  rw [slotFinsetSum,
    slot_expansion_sum]
  simp only [List.map_map]
  rw [← List.sum_toFinset _ (Finset.nodup_toList indices)]
  congr 1
  ext index
  simp

/--
The formal cutoff slots that survive physical truncation and bind to one
chosen concrete word.
-/
def bindFilteredSlots
    {β : Type*}
    [DecidableEq β]
    (wt : β → ℕ)
    (substitution : Atom → CWord β)
    (cutoff : ℕ)
    (word : CWord β) :
    Finset (CWord Atom) :=
  (orderedCutoffVocabulary cutoff).toFinset.filter fun slot =>
    (slot.bind substitution).weight wt < cutoff ∧
      slot.bind substitution = word

/--
The paired positive-and-negative Newton expansion for one concrete word after
arbitrary substitution and physical cutoff filtering.
-/
noncomputable def bindFilteredSlot
    {β : Type*}
    [DecidableEq β]
    (wt : β → ℕ)
    (substitution : Atom → CWord β)
    (cutoff : ℕ)
    (word : CWord β) :
    ISExp cutoff :=
  slotFinsetSum cutoff
    (bindFilteredSlots wt substitution cutoff word)
      (strictSlotExpansion cutoff)

/--
The concrete multiplicity in a physically truncated bound strict tail is the
finite collision sum of the corresponding formal signed-Newton recipes.
-/
lemma bind_slot_expansion
    {β : Type*}
    [DecidableEq β]
    (wt : β → ℕ)
    (substitution : Atom → CWord β)
    (hsubstitution : ∀ atom, 0 < (substitution atom).weight wt)
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (coefficient : ℤ)
    (word : CWord β) :
    Multiset.count word
        (↑((bindTrace substitution coefficient).filter fun bound =>
          decide (bound.weight wt < cutoff)) :
          Multiset (CWord β)) =
      ∑ slot ∈ (orderedCutoffVocabulary cutoff).toFinset,
        if
            (slot.bind substitution).weight wt < cutoff ∧
              slot.bind substitution = word then
          Int.toNat
            ((strictSlotExpansion cutoff slot).eval coefficient)
        else
          0 := by
  classical
  rw [← bind_filtered_profile
    wt substitution hsubstitution cutoff hcutoff coefficient]
  unfold bindFilteredExpansion
  change
    (Multiset.countAddMonoidHom word)
        (∑ slot ∈ (orderedCutoffVocabulary cutoff).toFinset,
          if (slot.bind substitution).weight wt < cutoff then
            Int.toNat
                ((strictSlotExpansion cutoff slot).eval
                  coefficient) •
              ({slot.bind substitution} : Multiset (CWord β))
          else
            0) =
      _
  rw [map_sum (Multiset.countAddMonoidHom word)]
  apply Finset.sum_congr rfl
  intro slot _hslot
  exact
    if_nsmul_singleton word (slot.bind substitution)
      ((slot.bind substitution).weight wt < cutoff)
      (Int.toNat
        ((strictSlotExpansion cutoff slot).eval coefficient))

/--
Evaluating the packaged concrete-slot recipe recovers the literal retained
multiplicity after arbitrary positive-weight substitution.
-/
lemma bind_filtered_integral
    {β : Type*}
    [DecidableEq β]
    (wt : β → ℕ)
    (substitution : Atom → CWord β)
    (hsubstitution : ∀ atom, 0 < (substitution atom).weight wt)
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (coefficient : ℤ)
    (word : CWord β) :
    (bindFilteredSlot
        wt substitution cutoff word).eval coefficient =
      (Multiset.count word
        (↑((bindTrace substitution coefficient).filter fun bound =>
          decide (bound.weight wt < cutoff)) :
          Multiset (CWord β)) : ℤ) := by
  rw [bind_slot_expansion
    wt substitution hsubstitution cutoff hcutoff coefficient word]
  rw [bindFilteredSlot,
    slot_finset_sum]
  unfold bindFilteredSlots
  rw [Finset.sum_filter]
  simp only [Nat.cast_sum]
  apply Finset.sum_congr rfl
  intro slot _hslot
  by_cases hslot :
      slot.weight (fun atom => (substitution atom).weight wt) < cutoff ∧
        slot.bind substitution = word
  · have heval :
        0 ≤
          (strictSlotExpansion cutoff slot).eval coefficient :=
      integral_slot_expansion
        cutoff hcutoff slot coefficient
    simp [hslot, Int.toNat_of_nonneg heval]
  · simp [hslot]

/--
The packaged concrete-slot recipe for a signed three-word substitution.
-/
noncomputable def filteredSlotExpansion
    {β : Type*}
    [DecidableEq β]
    (wt : β → ℕ)
    (x y z : CWord β)
    (cutoff : ℕ)
    (word : CWord β) :
    ISExp cutoff :=
  bindFilteredSlot
    wt (signedWordSubstitution x y z) cutoff word

/--
Evaluating the concrete three-word recipe recovers the corresponding retained
signed Hall-Witt strict-tail multiplicity.
-/
lemma filtered_concrete_slot
    {β : Type*}
    [DecidableEq β]
    (wt : β → ℕ)
    (hwt : ∀ atom, 0 < wt atom)
    (x y z : CWord β)
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (coefficient : ℤ)
    (word : CWord β) :
    (filteredSlotExpansion
        wt x y z cutoff word).eval coefficient =
      (Multiset.count word
        (↑(signedBelowTrace wt x y z cutoff coefficient) :
          Multiset (CWord β)) : ℤ) := by
  unfold filteredSlotExpansion
  rw [bind_filtered_integral
    wt (signedWordSubstitution x y z)
      (signed_substitution_pos wt hwt x y z)
        cutoff hcutoff coefficient word]
  rfl

end
