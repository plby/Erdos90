-- Merged from JacobiIntegralPowerStrictTailCutoffOrderedSecondAffineRecipeExpansion.lean

/-!
# Repeated-block recipe expansions for ordered Hall-Witt swaps

Every retained cutoff slot produced by repeatedly applying one fixed ordered
swap packet is an integer-valued polynomial of cutoff-bounded degree.  Normalize
those polynomials into the repository's explicit repeated-block recipe language
and assemble one expansion vector over the ordered cutoff vocabulary.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace SAExp

open CWTrace
open WSTrace
open NPTail
open STVocabu
open TBProf
open OSAffine

/-- Newton-normalized repeated-block expansion for one ordered-swap slot. -/
noncomputable def repeatedSwapExpansion
    (cutoff : ℕ)
    (left : CWord Atom)
    (rights : List (CWord Atom))
    (slot : CWord Atom) :
    BCExp 1 cutoff :=
  BCExp.binomialBasis 1 cutoff (by omega)
    (repeatedSwapMultiplicity cutoff left rights slot)

/-- The normalized repeated-block expansion evaluates to the literal retained
slot multiplicity after any number of fixed ordered-swap iterations. -/
lemma repeated_swap_expansion
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (left : CWord Atom)
    (rights : List (CWord Atom))
    (slot : CWord Atom) :
    (repeatedSwapExpansion cutoff left rights slot).eval =
      repeatedSwapMultiplicity cutoff left rights slot := by
  apply BCExp.eval_binomialBasis
  simpa using
    repeated_slot_most
      cutoff hcutoff left rights slot

/-- Every literal retained ordered-swap slot multiplicity belongs to the
bounded repeated-block recipe span. -/
lemma repeated_swap_span
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (left : CWord Atom)
    (rights : List (CWord Atom))
    (slot : CWord Atom) :
    IntCombinationRecipes
      1 cutoff
      (repeatedSwapMultiplicity cutoff left rights slot) := by
  rw [← repeated_swap_expansion cutoff hcutoff left rights slot]
  exact
    (repeatedSwapExpansion cutoff left rights slot).eval_recipe_span

/-- One coefficient-independent recipe expansion vector for a fixed ordered
swap packet. -/
noncomputable def repeatedSwapVector
    (cutoff : ℕ)
    (left : CWord Atom)
    (rights : List (CWord Atom)) :
    List (BCExp 1 cutoff) :=
  (orderedCutoffVocabulary cutoff).map fun slot =>
    repeatedSwapExpansion cutoff left rights slot

/-- The ordered-swap recipe vector has one coordinate for every formal cutoff
slot. -/
lemma length_repeated_swap
    (cutoff : ℕ)
    (left : CWord Atom)
    (rights : List (CWord Atom)) :
    (repeatedSwapVector cutoff left rights).length =
      (orderedCutoffVocabulary cutoff).length := by
  simp [repeatedSwapVector]

/-- Evaluating the vocabulary-wide ordered-swap recipe vector recovers every
literal retained slot multiplicity. -/
lemma repeated_swap_vector
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (left : CWord Atom)
    (rights : List (CWord Atom))
    (steps : ℕ) :
    (repeatedSwapVector cutoff left rights).map
        (fun expansion => expansion.eval steps) =
      (orderedCutoffVocabulary cutoff).map fun slot =>
        repeatedSwapMultiplicity cutoff left rights slot steps := by
  unfold repeatedSwapVector
  rw [List.map_map]
  apply List.map_congr_left
  intro slot _hslot
  rw [Function.comp_apply,
    repeated_swap_expansion cutoff hcutoff left rights slot]

/-- Evaluating the ordered-swap recipe vector recovers the cutoff profile of
the literal repeated crossing followed by the second stable route. -/
lemma repeated_vocabulary_literal
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (left : CWord Atom)
    (hleft : isFirstCurrent left = true)
    (rights : List (CWord Atom))
    (steps : ℕ) :
    (repeatedSwapVector cutoff left rights).map
        (fun expansion => expansion.eval steps) =
      (orderedCutoffVocabulary cutoff).map fun slot =>
        (Multiset.count slot
          (cutoffProfile cutoff
            (stableRoute isSecondCurrent
              (moveHigherTrace left (repeatTrace steps rights))).1) : ℤ) := by
  rw [repeated_swap_vector
    cutoff hcutoff left rights steps]
  apply List.map_congr_left
  intro slot _hslot
  exact
    repeated_slot_literal
      cutoff left hleft rights slot steps

end SAExp
end TCTex
end Submission

