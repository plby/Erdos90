          (boundedNestedCrossing cutoff crossed outer
            selected right steps) steps) : ℤ)) =
      fun steps : ℕ =>
        ∑ activeCopies ∈ Finset.range (target.length + 1),
          (steps.choose activeCopies : ℤ) *
            (repeatedSubsequenceMultiplicity
              (boundedNestedCrossing cutoff crossed outer
                selected right steps) activeCopies target : ℤ) by
      funext steps
      exact_mod_cast
        repeat_target_length
          (boundedNestedCrossing cutoff crossed outer
            selected right steps) steps target]
