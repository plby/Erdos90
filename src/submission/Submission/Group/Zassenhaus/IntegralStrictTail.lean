    (cutoff : ℕ)
    (crossed outer selected right : CWord Atom)
    (hcrossed : isFirstCurrent crossed = true)
    (target : OCTerm) :
    IVMost
      (fun steps : ℕ =>
        ((boundedConstantTerms cutoff
          (repeatTransitionSchedule
            (boundedNestedCrossing cutoff crossed outer
              selected right steps) steps)).count target : ℤ))
      (cutoff * (2 * cutoff + 3)) := by
  by_cases htarget : target.strictTransitions.length < cutoff
  · rw [show
      (fun steps : ℕ =>
        ((boundedConstantTerms cutoff
          (repeatTransitionSchedule
            (boundedNestedCrossing cutoff crossed outer
              selected right steps) steps)).count target : ℤ)) =
        fun steps : ℕ =>
          ∑ producer ∈
              (secondRouteAlphabet cutoff).toFinset,
            if target.constant = (producer.affine cutoff).constant then
              (orderedSubsequenceMultiplicity
                (target.strictTransitions ++ [producer])
                (repeatTransitionSchedule
                  (boundedNestedCrossing cutoff crossed
                    outer selected right steps) steps) : ℤ)
            else
              0 by
      funext steps
      exact_mod_cast
        constant_ite_producers
          cutoff (secondRouteAlphabet cutoff)
            (repeatTransitionSchedule
              (boundedNestedCrossing cutoff crossed outer
                selected right steps) steps)
            (fun transition htransition =>
              nested_crossing_schedule
                cutoff steps crossed outer selected right hcrossed transition
                  htransition)
            target |>.trans (if_pos htarget)]
    apply IVMost.finsetSum
    intro producer _hproducer
    by_cases hconstant :
        target.constant = (producer.affine cutoff).constant
    · simp only [hconstant, ↓reduceIte]
      apply
        TCTex.IVMost.mono
      · change
          (target.strictTransitions.length + 1) * (2 * cutoff + 3) ≤
            cutoff * (2 * cutoff + 3)
        exact
          Nat.mul_le_mul_right (2 * cutoff + 3)
            (Nat.succ_le_iff.mpr htarget)
      · simpa using
          subsequenceMultDiagonal
            cutoff crossed outer selected right
              (target.strictTransitions ++ [producer])
    · simp only [hconstant, ↓reduceIte]
      exact
        valued_most_constant
          (cutoff * (2 * cutoff + 3)) 0
  · rw [show
      (fun steps : ℕ =>
        ((boundedConstantTerms cutoff
          (repeatTransitionSchedule
            (boundedNestedCrossing cutoff crossed outer
              selected right steps) steps)).count target : ℤ)) =
          fun _steps : ℕ => 0 by
      funext steps
      exact_mod_cast
        constant_ite_producers
          cutoff (secondRouteAlphabet cutoff)
            (repeatTransitionSchedule
              (boundedNestedCrossing cutoff crossed outer
                selected right steps) steps)
            (fun transition htransition =>
              nested_crossing_schedule
                cutoff steps crossed outer selected right hcrossed transition
                  htransition)
            target |>.trans (if_neg htarget)]
    exact
      valued_most_constant
        (cutoff * (2 * cutoff + 3)) 0

/-- The diagonally repeated nested schedule supplies common bounded-term
polynomial data. -/
lemma constantCrossingSchedule
    (cutoff : ℕ)
    (crossed outer selected right : CWord Atom)
    (hcrossed : isFirstCurrent crossed = true) :
    BCDataa cutoff (cutoff * (2 * cutoff + 3))
