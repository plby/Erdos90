/-!
# Associated-graded polynomial Hall-Witt profile recipes

The concrete Hall-Witt profile recipes reconstruct an ordered correction
product after passing to its lower-central associated-graded layer.  This file
strengthens that statement in the form needed by symbolic collection:

* each physical slot has a coefficient-independent associated-graded class;
* slots below the strict-tail parent threshold evaluate identically to zero;
* the positive and shifted-negative scalar slot coefficients are bounded
  integer-valued polynomials;
* the associated-graded correction product is the corresponding finite linear
  combination of fixed slot classes on both signed branches.

This file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace
  AGPoly

open STSubsti
open TOCoordi
open TEAddres
open PMExp
open
  GRExp
open
  GSExp
open
  GSSlot
open
  GSVector
open
  SAGraded

universe u


/--
The coefficient-independent associated-graded class of one physical slot.
Broad cutoff vocabularies contain harmless low-weight words; those words map
to zero.  A word above the strict-tail parent threshold evaluates in the
expected next lower-central layer.
-/
noncomputable def addressSlotClass
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (word : CWord (HEAddres H)) :
    Additive
      (TBluepr.LowerGradedLayer
        (LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n)
        (x.weight PEAddres.weight +
            y.weight PEAddres.weight +
          z.weight PEAddres.weight)) :=
  if hword :
      x.weight PEAddres.weight +
              y.weight PEAddres.weight +
            z.weight PEAddres.weight + 1 ≤
        word.weight PEAddres.weight then
    TBluepr.lowerCentralClass _
      ⟨word.eval
          (PEAddres.freeLowerTruncation (n := n)),
        Subgroup.lowerCentralSeries_antitone
          (by omega)
          (CWord.eval_lower_series
            (PEAddres.freeLowerTruncation
              (n := n))
            PEAddres.weight
            PEAddres.weight_pos
            PEAddres.free_truncation_series
            word)⟩
  else
    0

/--
Every literally retained factor is represented by its actual associated-graded
class under the coefficient-independent slot map.
-/
lemma address_slot_central
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (coefficient : ℤ)
    (word : CWord (HEAddres H))
    (hword :
      word ∈
        signedBelowTrace PEAddres.weight
          x y z cutoff coefficient) :
    addressSlotClass
        (n := n) x y z word =
      TBluepr.lowerCentralClass _
        ⟨word.eval
            (PEAddres.freeLowerTruncation
              (n := n)),
          series_strict_trace
            x y z coefficient word (List.mem_filter.mp hword).1⟩ := by
  have hweight :=
    parent_strict_trace
      x y z coefficient word (List.mem_filter.mp hword).1
  simp [addressSlotClass, hweight]

/--
The additive class list of retained factors is obtained by mapping the fixed
physical-slot class over the retained words.
-/
lemma lower_central_fixed
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (coefficient : ℤ) :
    (addressBelowTerms
        (n := n) x y z cutoff coefficient).map
      (TBluepr.lowerCentralClass
        (x.weight PEAddres.weight +
            y.weight PEAddres.weight +
          z.weight PEAddres.weight)) =
      (signedBelowTrace PEAddres.weight
        x y z cutoff coefficient).map
          (addressSlotClass
            (n := n) x y z) := by
  unfold addressBelowTerms
  simp only [List.map_map]
  conv_rhs => rw [← List.attach_map_val]
  apply List.map_congr_left
  intro entry _hentry
  exact
    (address_slot_central
      (n := n) x y z cutoff coefficient entry.1 entry.2).symm

/--
The associated-graded class of the ordered retained product is a finite sum
over fixed physical slot classes.  Only the scalar recipe evaluations depend
on the integral coefficient.
-/
lemma lower_fixed_profile
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (coefficient : ℤ) :
    TBluepr.lowerCentralClass
        (x.weight PEAddres.weight +
            y.weight PEAddres.weight +
          z.weight PEAddres.weight)
        (addressBelowTerms
          (n := n) x y z cutoff coefficient).prod =
      ∑ word ∈
          (signedDeduplicatedVocabulary x y z cutoff).toFinset,
        Int.toNat
            ((filteredSlotExpansion
              PEAddres.weight
              x y z cutoff word).eval coefficient) •
          addressSlotClass
            (n := n) x y z word := by
  rw [lower_central_prod,
    lower_central_fixed]
  change
    ((↑(signedBelowTrace PEAddres.weight
      x y z cutoff coefficient) :
        Multiset (CWord (HEAddres H))).map
      (addressSlotClass
        (n := n) x y z)).sum =
      _
  exact
    below_concrete_profile
      PEAddres.weight PEAddres.weight_pos
        x y z cutoff hcutoff coefficient
          (addressSlotClass
            (n := n) x y z)

/--
A physical slot strictly below the parent threshold has identically zero
paired recipe evaluation.
-/
lemma filtered_parent_succ
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (coefficient : ℤ)
    (word : CWord (HEAddres H))
    (hword :
      word.weight PEAddres.weight <
        x.weight PEAddres.weight +
              y.weight PEAddres.weight +
            z.weight PEAddres.weight + 1) :
    (filteredSlotExpansion
      PEAddres.weight x y z cutoff word).eval coefficient =
        0 := by
  rw [filtered_concrete_slot
    PEAddres.weight PEAddres.weight_pos
      x y z cutoff hcutoff coefficient word]
  have hwordNot :
      word ∉
        signedBelowTrace PEAddres.weight
          x y z cutoff coefficient := by
    intro hwordMem
    have hweight :=
      parent_strict_trace
        x y z coefficient word (List.mem_filter.mp hwordMem).1
    omega
  simp [List.count_eq_zero_of_not_mem hwordNot]

/-- Positive-branch scalar coefficient of one fixed physical slot. -/
noncomputable def addressNaturalSlot
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (word : CWord (HEAddres H)) :
    ℕ → ℤ :=
  (filteredSlotExpansion
    PEAddres.weight x y z cutoff word).natural.eval

/-- Shifted-negative-branch scalar coefficient of one fixed physical slot. -/
noncomputable def addressSlotCoefficient
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (word : CWord (HEAddres H)) :
    ℕ → ℤ :=
  fun magnitude =>
    (filteredSlotExpansion
      PEAddres.weight x y z cutoff word).negative.eval
        (magnitude + 1)

/--
Every positive-branch physical-slot coefficient is an integer-valued
polynomial with the uniform global strict-tail bound.
-/
lemma address_natural_slot
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (word : CWord (HEAddres H)) :
    IVMost
      (addressNaturalSlot
        x y z cutoff word)
      (naturalStrictBound cutoff) := by
  unfold addressNaturalSlot
  unfold filteredSlotExpansion
  exact
    natural_bind_filtered
      PEAddres.weight
        (signedWordSubstitution x y z) cutoff word

/--
Every shifted-negative-branch physical-slot coefficient is an integer-valued
polynomial with the uniform global strict-tail bound.
-/
lemma address_negative_slot
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (word : CWord (HEAddres H)) :
    IVMost
      (addressSlotCoefficient
        x y z cutoff word)
      (negativeStrictBound cutoff) := by
  unfold addressSlotCoefficient
  apply
    TCTex.IVMost.succ
  unfold filteredSlotExpansion
  exact
    negative_bind_filtered
      PEAddres.weight
        (signedWordSubstitution x y z) cutoff word

/--
On the positive branch, the associated-graded correction product is a finite
linear combination of fixed classes with polynomial scalar coefficients.
-/
lemma lower_cast_poly
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (multiplicity : ℕ) :
    TBluepr.lowerCentralClass
        (x.weight PEAddres.weight +
            y.weight PEAddres.weight +
          z.weight PEAddres.weight)
        (addressBelowTerms
          (n := n) x y z cutoff (Int.ofNat multiplicity)).prod =
      ∑ word ∈
          (signedDeduplicatedVocabulary x y z cutoff).toFinset,
        addressNaturalSlot
            x y z cutoff word multiplicity •
          addressSlotClass
            (n := n) x y z word := by
  rw [
    lower_fixed_profile
      x y z cutoff hcutoff (Int.ofNat multiplicity)]
  apply Finset.sum_congr rfl
  intro word _hword
  have hnonneg :
      0 ≤
        (filteredSlotExpansion
          PEAddres.weight
          x y z cutoff word).natural.eval multiplicity := by
    rw [natural_filtered_slot
      PEAddres.weight PEAddres.weight_pos
        x y z cutoff hcutoff multiplicity word]
    exact Int.natCast_nonneg _
  simp only [ISExp.eval]
  conv_rhs =>
    unfold addressNaturalSlot
    rw [← Int.toNat_of_nonneg hnonneg, natCast_zsmul]

/--
On the negative branch, the associated-graded correction product is a finite
linear combination of fixed classes with shifted polynomial scalar
coefficients.
-/
lemma lower_succ_poly
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (magnitude : ℕ) :
    TBluepr.lowerCentralClass
        (x.weight PEAddres.weight +
            y.weight PEAddres.weight +
          z.weight PEAddres.weight)
        (addressBelowTerms
          (n := n) x y z cutoff (Int.negSucc magnitude)).prod =
      ∑ word ∈
          (signedDeduplicatedVocabulary x y z cutoff).toFinset,
        addressSlotCoefficient
            x y z cutoff word magnitude •
          addressSlotClass
            (n := n) x y z word := by
  rw [
    lower_fixed_profile
      x y z cutoff hcutoff (Int.negSucc magnitude)]
  apply Finset.sum_congr rfl
  intro word _hword
  have hnonneg :
      0 ≤
        (filteredSlotExpansion
          PEAddres.weight
          x y z cutoff word).negative.eval (magnitude + 1) := by
    rw [filtered_slot_expansion
      PEAddres.weight PEAddres.weight_pos
        x y z cutoff hcutoff magnitude word]
    exact Int.natCast_nonneg _
  simp only [ISExp.eval]
  conv_rhs =>
    unfold addressSlotCoefficient
    rw [← Int.toNat_of_nonneg hnonneg, natCast_zsmul]

end
  AGPoly
end TCTex
