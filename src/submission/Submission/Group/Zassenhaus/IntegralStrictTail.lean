    {d n inputWeight : ℕ}
    (x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d)))
    (hparent :
      exponentAddressParent x y z + 1 < n)
    (coefficient : ℕ → ℤ) where
  source :
    List
      (SPFactora
        (concreteBasicCommutators.{u} d) inputWeight)
  source_isTruncated :
    SPFactora.IsTruncated n source
  source_weight_least :
    SPFactora.WordWeightLeast
      (exponentAddressParent x y z + 1) source
  list_eval_residual :
    ∀ q : ℕ,
      SPFactora.listEval (n := n) q source =
        ((concreteCommutatorsWeight.{u} d
          (exponentAddressParent x y z + 1)).collectedWeightProduct
            (n := n)
            (concreteAddressCoordinates
              d n x y z n (coefficient q) hparent))⁻¹ *
          wordListEval
            (PEAddres.freeLowerTruncation
              (n := n))
            (signedStrictTrace x y z (coefficient q))

/-- Positive-multiplicity residual-source certificates. -/
abbrev TruncatedWittNatural
    {d n inputWeight : ℕ}
    (x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d)))
    (hparent :
      exponentAddressParent x y z + 1 < n) :=
  TWSrca
    (inputWeight := inputWeight) x y z hparent Int.ofNat

/-- Shifted-negative-multiplicity residual-source certificates. -/
abbrev TruncatedWittNegative
    {d n inputWeight : ℕ}
    (x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d)))
    (hparent :
      exponentAddressParent x y z + 1 < n) :=
  TWSrca
    (inputWeight := inputWeight) x y z hparent Int.negSucc

namespace TWSrca

/--
A current-stratum semantic normalizer turns a certified Hall-Witt residual
source into an exact source supported one stratum higher.
-/
noncomputable def sourceRecollectionNormalizer
    {d n inputWeight : ℕ}
    {x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d))}
    {hparent :
      exponentAddressParent x y z + 1 < n}
    {coefficient : ℕ → ℤ}
    (residual :
      TWSrca
        (inputWeight := inputWeight) x y z hparent coefficient)
    (hn : 2 ≤ n)
    (normalizer :
      TSNormalb
        (n := n) (inputWeight := inputWeight)
        (lowerWeight :=
          exponentAddressParent x y z + 1)
        (concreteBasicCommutators.{u} d)) :
    TSRecol
      (n := n)
      (lowerWeight :=
        exponentAddressParent x y z + 1 + 1)
      (concreteBasicCommutators.{u} d) residual.source := by
  apply
    normalizer.source_recollection_series
      hn (concreteBasicCommutators.{u} d)
        (fun s hs hsn =>
          concrete_forms_associated d n s hs hsn)
        residual.source (by omega) hparent residual.source_isTruncated
        residual.source_weight_least
