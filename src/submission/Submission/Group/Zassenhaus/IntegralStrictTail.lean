/-!
# Finite substitution recurrence for bounded Hall-Witt strict-depth words

The ordered binary strict-depth word may be truncated after every step:
depths already at or above cutoff can never emit a surviving child.  Thus the
bounded depth word is the orbit of one fixed finite-alphabet substitution,
which replaces `depth` by its surviving strict child `depth + 1` followed by
its retained child `depth`.

This is the finite morphic recurrence needed for order-sensitive subsequence
counting.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace DSRec

open BDExp

/-- Ordered strict-depth word truncated at one fixed cutoff. -/
def boundedDepthSchedule
    (cutoff steps : ℕ) :
    List ℕ :=
  (strictDepthSchedule steps).filter fun depth =>
    decide (depth < cutoff)

/-- Fixed finite-alphabet packet emitted by one bounded strict depth. -/
def strictStepPacket
    (cutoff depth : ℕ) :
    List ℕ :=
  [depth + 1, depth].filter fun nextDepth =>
    decide (nextDepth < cutoff)

/-- Filtering after one binary expansion is equivalent to filtering the
source first and flattening the fixed bounded depth packets. -/
lemma filter_flat_self
    (cutoff : ℕ) :
    ∀ depths : List ℕ,
      ((depths.flatMap fun depth => [depth + 1, depth]).filter fun depth =>
          decide (depth < cutoff)) =
        (depths.filter fun depth => decide (depth < cutoff)).flatMap
          (strictStepPacket cutoff)
  | [] => by
      rfl
  | depth :: depths => by
      rw [List.flatMap_cons, List.filter_append,
        filter_flat_self
          cutoff depths]
      by_cases hdepth : depth < cutoff
      · simp [hdepth, strictStepPacket]
      · have hnextDepth : ¬depth + 1 < cutoff := by
          omega
        simp [hdepth, hnextDepth]

/-- The truncated ordered depth word obeys one fixed finite substitution
recurrence. -/
lemma bounded_schedule_succ
    (cutoff steps : ℕ) :
    boundedDepthSchedule cutoff (steps + 1) =
      (boundedDepthSchedule cutoff steps).flatMap
        (strictStepPacket cutoff) := by
  unfold boundedDepthSchedule
  rw [strictDepthSchedule,
    filter_flat_self]

/-- Every entry of the bounded depth word lies strictly below cutoff. -/
lemma cutoff_bounded_schedule
    (cutoff steps depth : ℕ)
    (hdepth : depth ∈ boundedDepthSchedule cutoff steps) :
    depth < cutoff := by
  exact
    of_decide_eq_true
      (List.mem_filter.mp hdepth).2

/-- Every entry emitted by a bounded depth packet lies strictly below
cutoff. -/
lemma cutoff_strict_packet
    (cutoff depth nextDepth : ℕ)
    (hnextDepth : nextDepth ∈ strictStepPacket cutoff depth) :
    nextDepth < cutoff := by
  exact
    of_decide_eq_true
      (List.mem_filter.mp hnextDepth).2

/-- A bounded source depth emits its optional strict child before its retained
child. -/
lemma optional_append_singleton
    (cutoff depth : ℕ)
    (hdepth : depth < cutoff) :
    strictStepPacket cutoff depth =
      (if depth + 1 < cutoff then [depth + 1] else []) ++ [depth] := by
  by_cases hnextDepth : depth + 1 < cutoff
  · simp [strictStepPacket, hdepth, hnextDepth]
  · simp [strictStepPacket, hdepth, hnextDepth]

/-- A source depth already at or above cutoff emits no bounded child. -/
lemma strict_nil_cutoff
    (cutoff depth : ℕ)
    (hdepth : cutoff ≤ depth) :
    strictStepPacket cutoff depth =
      [] := by
  have hnextDepth : ¬depth + 1 < cutoff := by
    omega
  simp [strictStepPacket, Nat.not_lt.mpr hdepth, hnextDepth]

/-- One step of the finite bounded depth substitution. -/
def boundedStrictSubstitution
    (cutoff : ℕ)
    (depths : List ℕ) :
    List ℕ :=
  depths.flatMap (strictStepPacket cutoff)

/-- Iterate the finite bounded depth substitution. -/
def iteratedBoundedSubstitution
    (cutoff : ℕ) :
    ℕ → List ℕ → List ℕ
  | 0, depths =>
      depths
  | steps + 1, depths =>
      boundedStrictSubstitution cutoff
        (iteratedBoundedSubstitution cutoff steps depths)

/-- The bounded ordered depth word is exactly the orbit of its cutoff-filtered
depth-zero seed under the fixed finite substitution. -/
lemma bounded_iterated_substitution
    (cutoff : ℕ) :
    ∀ steps : ℕ,
      boundedDepthSchedule cutoff steps =
        iteratedBoundedSubstitution cutoff steps
          (boundedDepthSchedule cutoff 0)
  | 0 => by
      rfl
  | steps + 1 => by
      rw [bounded_schedule_succ,
        bounded_iterated_substitution
          cutoff steps]
      rfl

end DSRec
end TCTex
