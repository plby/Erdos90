  simpa [newtonSignedEvaluation] using heval

/-- At positive cutoff, the atomic ordinary-crossing operator at depth zero
is the fold of its single retained depth-zero packet. -/
lemma crossing_state_operator
    (cutoff : ℕ)
    (outer selected right : CWord Atom)
    (hcutoff : 0 < cutoff)
    (state : BoundedCountState) :
    crossingStateOperator cutoff outer selected
        right 0 state =
      strictStateOperator cutoff outer selected right
        0 state := by
  unfold crossingStateOperator
  rw [bounded_strict_depth cutoff, if_pos hcutoff]
  rfl

/-- At positive cutoff, signed successor evaluation of an ordinary crossing
schedule collapses to the single depth-zero packet state. -/
lemma newton_evaluation_state
    (cutoff : ℕ)
    (outer selected right : CWord Atom)
    (hcutoff : 0 < cutoff)
    (houter : isFirstCurrent outer = true) :
    newtonEvaluationState (cutoff * cutoff + 1)
        (fun steps =>
          boundedConstantState
            (boundedConstantTerms cutoff
              (depthCrossingSchedule cutoff outer selected right
                (steps + 1)))) =
      strictStateOperator cutoff outer selected right
        0 (boundedCountState []) := by
  rw [
    newton_evaluation_seed
      cutoff outer selected right houter,
    constant_operator_empty,
    crossing_state_operator cutoff outer
      selected right hcutoff]

