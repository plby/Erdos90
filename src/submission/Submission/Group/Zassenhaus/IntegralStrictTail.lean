/-!
# Cutoff vocabularies for integral Hall-Witt strict tails

Integral Hall-Witt traces grow with the evaluated coefficient: stable routing
may emit increasingly nested correction words.  Below a fixed nilpotent
cutoff, however, every surviving occurrence belongs to one finite vocabulary
independent of that coefficient.

Use the generic finite-alphabet commutator-word enumeration on the six signed
Hall-Witt labels, then bind this formal vocabulary into any chosen triple of
commutator words.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace STVocabu

noncomputable section

open WSTrace
open PSTail
open STSubsti

universe u

/-- The complete six-label Hall-Witt alphabet. -/
def atoms :
    List Atom :=
  [xAtom, xInvAtom, zAtom, zInvAtom, yAtom, yInvAtom]

/-- Every signed Hall-Witt label occurs in the formal alphabet. -/
lemma mem_atoms
    (atom : Atom) :
    atom ∈ atoms := by
  rcases atom with atom | atom
  · fin_cases atom <;>
      simp [atoms, xAtom, xInvAtom, zAtom, zInvAtom, yAtom, yInvAtom]
  · fin_cases atom <;>
      simp [atoms, xAtom, xInvAtom, zAtom, zInvAtom, yAtom, yInvAtom]

/-- Finite formal vocabulary containing every six-label commutator word of
unit-label weight at most `cutoff`. -/
def cutoffVocabulary
    (cutoff : ℕ) :
    List (CWord Atom) :=
  CWord.finiteAlphabetWords atoms cutoff

/-- Deduplicated ordered formal cutoff vocabulary used for fixed slots. -/
def orderedCutoffVocabulary
    (cutoff : ℕ) :
    List (CWord Atom) :=
  (cutoffVocabulary cutoff).dedup

/-- Deduplication does not change formal vocabulary membership. -/
lemma ordered_cutoff_vocabulary
    (cutoff : ℕ)
    (word : CWord Atom) :
    word ∈ orderedCutoffVocabulary cutoff ↔
      word ∈ cutoffVocabulary cutoff := by
  classical
  simp [orderedCutoffVocabulary]

/-- The ordered formal cutoff vocabulary has no repeated slots. -/
lemma nodup_cutoff_vocabulary
    (cutoff : ℕ) :
    (orderedCutoffVocabulary cutoff).Nodup := by
  classical
  exact List.nodup_dedup _

/-- Every formal word of bounded unit-label weight belongs to the fixed
cutoff vocabulary. -/
lemma cutoff_vocabulary_weight
    (cutoff : ℕ)
    (word : CWord Atom)
    (hword : word.weight (fun _ => 1) ≤ cutoff) :
    word ∈ cutoffVocabulary cutoff := by
  exact
    CWord.alphabet_words_weight
      atoms mem_atoms word cutoff hword

/-- Every below-cutoff integral strict occurrence belongs to the fixed formal
vocabulary, independently of its coefficient. -/
lemma cutoff_vocabulary_strict
    (cutoff : ℕ)
    (coefficient : ℤ)
    (word : CWord Atom)
    (_hword : word ∈ strictTrace coefficient)
    (hwordWeight : word.weight (fun _ => 1) < cutoff) :
    word ∈ cutoffVocabulary cutoff :=
  cutoff_vocabulary_weight cutoff word (Nat.le_of_lt hwordWeight)

/-- Bind the finite formal vocabulary into a concrete signed triple. -/
def signedCutoffVocabulary
    {β : Type*}
    (x y z : CWord β)
    (cutoff : ℕ) :
    List (CWord β) :=
  (cutoffVocabulary cutoff).map fun word =>
    word.bind (signedWordSubstitution x y z)

/-- Bind the deduplicated formal fixed slots into a concrete signed triple. -/
def signedOrderedVocabulary
    {β : Type*}
    (x y z : CWord β)
    (cutoff : ℕ) :
    List (CWord β) :=
  (orderedCutoffVocabulary cutoff).map fun word =>
    word.bind (signedWordSubstitution x y z)

/--
Every below-cutoff signed strict occurrence comes from one member of the
fixed formal vocabulary.  The vocabulary depends on the cutoff and the three
substituted words, but not on the integral coefficient.
-/
lemma source_vocabulary_strict
    {β : Type*}
    (wt : β → ℕ)
    (hwt : ∀ atom, 0 < wt atom)
    (x y z : CWord β)
    (cutoff : ℕ)
    (coefficient : ℤ)
    (word : CWord β)
    (hword : word ∈ signedStrictTrace x y z coefficient)
    (hwordWeight : word.weight wt < cutoff) :
    ∃ sourceWord ∈ cutoffVocabulary cutoff,
      word = sourceWord.bind (signedWordSubstitution x y z) := by
  rw [signedStrictTrace, bindTrace] at hword
  rcases List.mem_map.mp hword with ⟨sourceWord, hsourceWord, rfl⟩
  refine ⟨sourceWord, ?_, rfl⟩
  apply cutoff_vocabulary_weight
  exact
    (weight_bind_positive wt
      (signedWordSubstitution x y z)
      (signed_substitution_pos wt hwt x y z)
      sourceWord).trans
        (Nat.le_of_lt hwordWeight)

/-- Every below-cutoff signed strict occurrence belongs to the fixed
coefficient-independent substituted vocabulary. -/
lemma signed_vocabulary_weight
    {β : Type*}
    (wt : β → ℕ)
    (hwt : ∀ atom, 0 < wt atom)
    (x y z : CWord β)
    (cutoff : ℕ)
    (coefficient : ℤ)
    (word : CWord β)
    (hword : word ∈ signedStrictTrace x y z coefficient)
    (hwordWeight : word.weight wt < cutoff) :
    word ∈ signedCutoffVocabulary x y z cutoff := by
  rcases
      source_vocabulary_strict
        wt hwt x y z cutoff coefficient word hword hwordWeight with
    ⟨sourceWord, hsourceWord, rfl⟩
  exact List.mem_map.mpr ⟨sourceWord, hsourceWord, rfl⟩

/-- Every below-cutoff signed strict occurrence belongs to the substituted
deduplicated formal fixed-slot vocabulary. -/
lemma signed_vocabulary_strict
    {β : Type*}
    (wt : β → ℕ)
