/-!
# Polynomial coordinates for repeated bounded-term transitions

One fixed bounded Hall-Witt transition acts triangularly on ordered-term
multiplicities: a coordinate keeps its previous value, receives at most one
strict-prepend predecessor coordinate, and receives one fixed singleton
constant.  Iterating that update therefore sums coordinates with one shorter
strict-transition word.

This file combines that triangular recurrence with the Newton-binomial
partial-sum theorem.  The multiplicity of a term with `r` strict transitions
after `q` repetitions is an integer-valued polynomial in `q` of degree at
most `r + 1`.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace TRTrans

open SSExp
open STSched
open STAlphab
open STState
open SSCoord
open SCState
open STClos

/-- Iterate one fixed bounded-term count-state transition. -/
def iterateStateStep
    (cutoff : ℕ)
    (transition : SRTrans)
    (initial : BoundedCountState) :
    ℕ → BoundedCountState
  | 0 =>
      initial
  | steps + 1 =>
      boundedStateStep cutoff transition
        (iterateStateStep cutoff transition initial steps)

@[simp]
lemma iterate_count_state
    (cutoff : ℕ)
    (transition : SRTrans)
    (initial : BoundedCountState) :
    iterateStateStep cutoff transition initial 0 =
      initial := by
  rfl

lemma iterate_state_succ
    (cutoff steps : ℕ)
    (transition : SRTrans)
    (initial : BoundedCountState) :
    iterateStateStep cutoff transition initial (steps + 1) =
      boundedStateStep cutoff transition
        (iterateStateStep cutoff transition initial steps) := by
  rfl

/-- Iteration is the initial coordinate plus the sum of all predecessor and
singleton increments encountered so far. -/
lemma iterate_state_range
    (cutoff steps : ℕ)
    (transition : SRTrans)
    (initial : BoundedCountState)
    (target : OCTerm) :
    iterateStateStep cutoff transition initial steps target =
      initial target +
        ∑ j ∈ Finset.range steps,
          (strictPredecessorCount cutoff transition
              (iterateStateStep
                cutoff transition initial j) target +
            singletonConstantCount cutoff transition target) := by
  induction steps with
  | zero =>
      simp
  | succ steps ih =>
      rw [iterate_state_succ,
        Finset.sum_range_succ, boundedStateStep, ih]
      ring

/-- Repeated application of one fixed triangular bounded-term transition has
integer-valued polynomial coordinates, graded by strict-transition length. -/
lemma valued_most_iterate
    (cutoff : ℕ)
    (transition : SRTrans)
    (initial : BoundedCountState) :
    ∀ target : OCTerm,
      IVMost
        (fun steps : ℕ =>
          iterateStateStep
            cutoff transition initial steps target)
        (target.strictTransitions.length + 1)
  | target => by
      have hpredecessor :
          IVMost
            (fun steps : ℕ =>
              strictPredecessorCount cutoff transition
                (iterateStateStep
                  cutoff transition initial steps) target)
            target.strictTransitions.length := by
        by_cases hlength : target.strictTransitions.length < cutoff
        · cases hprevious : removePrepended? transition target with
          | none =>
              simpa [strictPredecessorCount, hlength, hprevious] using
                valued_most_const
                  target.strictTransitions.length 0
          | some previous =>
              have hprepend :
                  previous.prepend transition = target :=
                prepend_remove_prepended?_eq_some
                  transition target previous hprevious
              have hpreviousLength :
                  previous.strictTransitions.length + 1 =
                    target.strictTransitions.length := by
                rw [← hprepend]
                simp [OCTerm.prepend]
              have hpreviousLength_lt :
                  previous.strictTransitions.length <
                    target.strictTransitions.length := by
                omega
              simpa [strictPredecessorCount, hlength, hprevious,
                hpreviousLength] using
                valued_most_iterate
                  cutoff transition initial previous
        · simpa [strictPredecessorCount, hlength] using
            valued_most_const
              target.strictTransitions.length 0
      have hincrement :
          IVMost
            (fun steps : ℕ =>
              strictPredecessorCount cutoff transition
                  (iterateStateStep
                    cutoff transition initial steps) target +
                singletonConstantCount cutoff transition target)
            target.strictTransitions.length := by
        exact
          hpredecessor.add
            (valued_most_const
              target.strictTransitions.length
                (singletonConstantCount cutoff transition target))
      rw [show
        (fun steps : ℕ =>
          iterateStateStep
            cutoff transition initial steps target) =
          (fun _steps : ℕ => initial target) +
            (fun steps : ℕ =>
              ∑ j ∈ Finset.range steps,
                (strictPredecessorCount cutoff transition
                    (iterateStateStep
                      cutoff transition initial j) target +
                  singletonConstantCount cutoff transition target)) by
        funext steps
        simp only [Pi.add_apply]
        exact
          iterate_state_range
            cutoff steps transition initial target]
      exact
        (valued_most_const
          (target.strictTransitions.length + 1) (initial target)).add
            hincrement.partialSum
termination_by target => target.strictTransitions.length
decreasing_by
  assumption

/-- The schedule fold of a repeated singleton schedule is fixed-step
iteration. -/
lemma state_fold_replicate
    (cutoff steps : ℕ)
    (transition : SRTrans)
    (initial : BoundedCountState) :
    boundedStateFold cutoff
        (List.replicate steps transition) initial =
      iterateStateStep cutoff transition initial steps := by
  induction steps with
  | zero =>
      rfl
  | succ steps ih =>
      rw [List.replicate_succ, boundedStateFold,
        iterate_state_succ, ih]

/-- Every literal bounded ordered-term coordinate of a repeated singleton
schedule is an integer-valued polynomial with its triangular degree bound. -/
lemma valued_most_replicate
    (cutoff : ℕ)
    (transition : SRTrans)
    (target : OCTerm) :
    IVMost
      (fun steps : ℕ =>
        ((boundedConstantTerms cutoff
          (List.replicate steps transition)).count target : ℤ))
      (target.strictTransitions.length + 1) := by
  rw [show
    (fun steps : ℕ =>
      ((boundedConstantTerms cutoff
        (List.replicate steps transition)).count target : ℤ)) =
      fun steps : ℕ =>
        iterateStateStep cutoff transition
          (boundedCountState []) steps target by
    funext steps
    rw [count_constant_fold,
      state_fold_replicate]]
  exact
    valued_most_iterate
      cutoff transition (boundedCountState []) target

/-- Words enumerated at one fixed length have that length. -/
lemma length_transition_words
    (alphabet : List SRTrans) :
    ∀ (length : ℕ) (transitions : List SRTrans),
      transitions ∈ transitionWordsLength alphabet length →
        transitions.length = length
  | 0, transitions, htransitions => by
      simp [transitionWordsLength] at htransitions
      subst transitions
      rfl
  | length + 1, transitions, htransitions => by
      simp only [transitionWordsLength] at htransitions
      rcases List.mem_flatMap.mp htransitions with
        ⟨_head, _hhead, htransitions⟩
      rcases List.mem_map.mp htransitions with
        ⟨tail, htail, rfl⟩
      simp [length_transition_words alphabet length tail htail]

/-- Every term in the fixed bounded-term alphabet has fewer strict
transitions than the cutoff. -/
lemma length_constant_alphabet
    (cutoff : ℕ)
    (term : OCTerm)
    (hterm : term ∈ boundedConstantAlphabet cutoff) :
    term.strictTransitions.length < cutoff := by
  rcases List.mem_flatMap.mp hterm with
    ⟨strictTransitions, hstrictTransitions, hterm⟩
  rcases List.mem_map.mp hterm with
    ⟨_constantTransition, _hconstantTransition, rfl⟩
  rcases List.mem_flatMap.mp hstrictTransitions with
    ⟨length, hlength, hstrictTransitions⟩
  rw [length_transition_words
    (secondRouteAlphabet cutoff) length strictTransitions
      hstrictTransitions]
  exact List.mem_range.mp hlength

/-- A repeated singleton transition schedule supplies the common
cutoff-bounded polynomial-data interface used by the outer-packet closure
layer. -/
lemma bounded_constant_replicate
    (cutoff : ℕ)
    (transition : SRTrans)
    (htransition :
      transition ∈ secondRouteAlphabet cutoff) :
    BCDataa cutoff cutoff
      (fun steps =>
        boundedConstantTerms cutoff
          (List.replicate steps transition)) := by
  constructor
  · intro steps
    apply
      supported_alphabet_terms
    intro next hnext
    rw [List.eq_of_mem_replicate hnext]
    exact htransition
  · intro target
    by_cases htarget :
        target ∈ boundedConstantAlphabet cutoff
    · apply
        TCTex.IVMost.mono
          (Nat.succ_le_iff.mpr
            (length_constant_alphabet
              cutoff target htarget))
      exact
        valued_most_replicate
          cutoff transition target
    · rw [show
        (fun steps : ℕ =>
          ((boundedConstantTerms cutoff
            (List.replicate steps transition)).count target : ℤ)) =
          fun _steps : ℕ => 0 by
        funext steps
        norm_cast
        apply List.count_eq_zero.mpr
        intro htargetTerms
        exact
          htarget
            (constant_alphabet_terms
              cutoff (List.replicate steps transition)
                (fun next hnext => by
                  rw [List.eq_of_mem_replicate hnext]
                  exact htransition)
                target htargetTerms)]
      exact
        valued_most_constant cutoff 0

end TRTrans
end TCTex
