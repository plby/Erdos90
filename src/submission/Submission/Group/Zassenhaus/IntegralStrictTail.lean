    (cutoff : ℕ) :
    Prop :=
  ∀ slot,
    signedAffineSlot cutoff
      (positiveSecondAffine cutoff)
        (emptyPredecessorProfile cutoff)
          slot = 0

/-- Negative fixed-affine cancellation of the formal-predecessor signed
orbit-swap profile. -/
def EmptyFormalPredecessor
    (cutoff : ℕ) :
    Prop :=
  ∀ slot,
    signedAffineSlot cutoff
      (negativeSecondAffine cutoff)
        (emptyFormalPredecessor cutoff)
          slot = 0

/-- The positive fixed-affine orbit endpoint kernel is exactly cancellation
of the formal-predecessor signed orbit-swap profile. -/
lemma natural_outer_empty
    (cutoff : ℕ) :
    EmptySatisfiesNewton
        cutoff ↔
      NaturalEmptyPredecessor
        cutoff := by
  unfold
    EmptySatisfiesNewton
    NaturalEmptyPredecessor
    emptyPredecessorProfile
  apply forall_congr'
  intro slot
  rw [newton_evaluation_affine cutoff
    (naturalFullBound cutoff)
      (positiveSecondAffine cutoff)
        (positiveEmptyEndpoint cutoff)
          (vocabulary_empty_endpoint
            cutoff) slot]

/-- The negative fixed-affine orbit endpoint kernel is exactly cancellation
of the formal-predecessor signed orbit-swap profile. -/
