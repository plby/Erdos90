/-!
# Fixed-alphabet multiplicity reduction for Hall-Witt second routes

The bounded ordered-subsequence expansion has one fixed finite alphabet below
each cutoff.  Group its summands by alphabet entry.  The exact positive and
negative Hall-Witt strict-tail profiles become finite linear combinations of
fixed evaluated terms whose only coefficient-dependent data are scalar list
counts.

Consequently, proving integer-valued polynomiality for those finitely many
term-count functions is enough to prove slotwise polynomiality of the full
strict-tail cutoff profile.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace TMRed

open WSTrace
open NPTail
open TBProf
open TACompos
open OFProgra
open STSched
open SSExp
open STAlphab

/-- Group a list-valued additive sum by the finitely many entries occurring in
its source list. -/
lemma finset_count_nsmul
    {α M : Type*}
    [DecidableEq α]
    [AddCommMonoid M]
    (terms : List α)
    (value : α → M) :
    (terms.map value).sum =
      ∑ term ∈ terms.toFinset,
        terms.count term • value term := by
  change ((↑terms : Multiset α).map value).sum = _
  rw [← Multiset.toFinset_sum_count_nsmul_eq (↑terms : Multiset α)]
  let aggregate : Multiset α →+ M :=
    Multiset.sumAddMonoidHom.comp (Multiset.mapAddMonoidHom value)
  change
    aggregate
        (∑ term ∈ (↑terms : Multiset α).toFinset,
          Multiset.count term (↑terms : Multiset α) •
            ({term} : Multiset α)) =
      _
  rw [map_sum aggregate]
  apply Finset.sum_congr rfl
  intro term _hterm
  change
    ((Multiset.mapAddMonoidHom value)
      (Multiset.count term (↑terms : Multiset α) •
        ({term} : Multiset α))).sum =
        terms.count term • value term
  rw [map_nsmul]
  simpa using
    (map_nsmul Multiset.sumAddMonoidHom
      (terms.count term) ({value term} : Multiset M))

/-- Enlarge the grouping set from the occurring entries to any fixed finite
alphabet supporting the source list. -/
lemma alphabet_count_nsmul
    {α M : Type*}
    [DecidableEq α]
    [AddCommMonoid M]
    (alphabet terms : List α)
    (value : α → M)
    (hterms : ∀ term ∈ terms, term ∈ alphabet) :
    (terms.map value).sum =
      ∑ term ∈ alphabet.toFinset,
        terms.count term • value term := by
  rw [finset_count_nsmul terms value]
  apply Finset.sum_subset
  · intro term hterm
    exact
      List.mem_toFinset.mpr
        (hterms term (List.mem_toFinset.mp hterm))
  · intro term _htermAlphabet hterm
    have htermNot : term ∉ terms := by
      simpa only [List.mem_toFinset] using hterm
    rw [List.count_eq_zero_of_not_mem htermNot, zero_nsmul]

/-- Positive Hall-Witt bounded-term multiplicity at one fixed alphabet entry. -/
def naturalBoundedMultiplicity
    (cutoff multiplicity : ℕ)
    (term : OCTerm) :
    ℕ :=
  (boundedConstantTerms cutoff
    (transitionSchedule cutoff
      (naturalRouteProgram cutoff multiplicity))).count term

/-- Negative Hall-Witt bounded-term multiplicity at one fixed alphabet entry. -/
def negativeBoundedMultiplicity
    (cutoff multiplicity : ℕ)
    (term : OCTerm) :
    ℕ :=
  (boundedConstantTerms cutoff
    (transitionSchedule cutoff
      (negativeRouteProgram cutoff multiplicity))).count term

/-- The positive strict-tail cutoff profile is a finite fixed-alphabet linear
combination of bounded-term multiplicities. -/
lemma profile_natural_alphabet
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (multiplicity : ℕ) :
    cutoffProfile cutoff
        (NPTail.strictTrace multiplicity) =
      ∑ term ∈ (boundedConstantAlphabet cutoff).toFinset,
        naturalBoundedMultiplicity cutoff multiplicity term •
          term.eval cutoff := by
  rw [profile_natural_affine cutoff hcutoff,
    affine_constant_terms
      cutoff (by omega)]
  exact
    alphabet_count_nsmul
      (boundedConstantAlphabet cutoff)
      (boundedConstantTerms cutoff
        (transitionSchedule cutoff
          (naturalRouteProgram cutoff multiplicity)))
      (OCTerm.eval cutoff)
      (alphabet_natural_terms
        cutoff multiplicity)

/-- The negative strict-tail cutoff profile is a finite fixed-alphabet linear
combination of bounded-term multiplicities. -/
lemma profile_negative_alphabet
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (multiplicity : ℕ) :
    cutoffProfile cutoff
        (NNPower.strictTrace
          multiplicity) =
      ∑ term ∈ (boundedConstantAlphabet cutoff).toFinset,
        negativeBoundedMultiplicity cutoff multiplicity term •
          term.eval cutoff := by
  rw [profile_negative_affine cutoff hcutoff,
    affine_constant_terms
      cutoff (by omega)]
  exact
    alphabet_count_nsmul
      (boundedConstantAlphabet cutoff)
      (boundedConstantTerms cutoff
        (transitionSchedule cutoff
          (negativeRouteProgram cutoff multiplicity)))
      (OCTerm.eval cutoff)
      (alphabet_negative_terms
        cutoff multiplicity)

/-- Slotwise scalar form of the positive fixed-alphabet expansion. -/
lemma count_natural_alphabet
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (multiplicity : ℕ)
    (slot : CWord Atom) :
    Multiset.count slot
        (cutoffProfile cutoff
          (NPTail.strictTrace multiplicity)) =
      ∑ term ∈ (boundedConstantAlphabet cutoff).toFinset,
        naturalBoundedMultiplicity cutoff multiplicity term *
          Multiset.count slot (term.eval cutoff) := by
  rw [profile_natural_alphabet
    cutoff hcutoff]
  change
    (Multiset.countAddMonoidHom slot)
        (∑ term ∈ (boundedConstantAlphabet cutoff).toFinset,
          naturalBoundedMultiplicity cutoff multiplicity term •
            term.eval cutoff) =
      _
  rw [map_sum]
  apply Finset.sum_congr rfl
  intro term _hterm
  simp

/-- Slotwise scalar form of the negative fixed-alphabet expansion. -/
lemma count_negative_alphabet
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (multiplicity : ℕ)
    (slot : CWord Atom) :
    Multiset.count slot
        (cutoffProfile cutoff
          (NNPower.strictTrace
            multiplicity)) =
      ∑ term ∈ (boundedConstantAlphabet cutoff).toFinset,
        negativeBoundedMultiplicity cutoff multiplicity term *
          Multiset.count slot (term.eval cutoff) := by
  rw [profile_negative_alphabet
    cutoff hcutoff]
  change
    (Multiset.countAddMonoidHom slot)
        (∑ term ∈ (boundedConstantAlphabet cutoff).toFinset,
          negativeBoundedMultiplicity cutoff multiplicity term •
            term.eval cutoff) =
      _
  rw [map_sum]
  apply Finset.sum_congr rfl
  intro term _hterm
  simp

/-- Polynomiality of all positive bounded-term multiplicities implies
slotwise polynomiality of the complete positive strict-tail cutoff profile. -/
lemma cutoff_natural_multiplicity
    (cutoff degreeBound : ℕ)
    (hcutoff : 3 < cutoff)
    (hterms :
      ∀ term ∈ (boundedConstantAlphabet cutoff).toFinset,
        IVMost
          (fun multiplicity : ℕ =>
            (naturalBoundedMultiplicity cutoff multiplicity term : ℤ))
          degreeBound) :
    CPDataa cutoff degreeBound
      (fun multiplicity =>
        cutoffProfile cutoff
          (NPTail.strictTrace multiplicity)) := by
  constructor
  · intro multiplicity
    exact supported_vocabulary_profile cutoff _
  · intro slot
    rw [show
      (fun multiplicity : ℕ =>
        (Multiset.count slot
          (cutoffProfile cutoff
            (NPTail.strictTrace
              multiplicity)) : ℤ)) =
        fun multiplicity : ℕ =>
          ∑ term ∈ (boundedConstantAlphabet cutoff).toFinset,
            (naturalBoundedMultiplicity cutoff multiplicity term : ℤ) *
              (Multiset.count slot (term.eval cutoff) : ℤ) by
      funext multiplicity
      exact_mod_cast
        count_natural_alphabet
          cutoff hcutoff multiplicity slot]
    apply IVMost.finsetSum
    intro term hterm
    simpa [mul_comm] using
      TCTex.IVMost.smul
        (Multiset.count slot (term.eval cutoff) : ℤ)
        (hterms term hterm)

/-- Polynomiality of all negative bounded-term multiplicities implies
slotwise polynomiality of the complete negative strict-tail cutoff profile. -/
lemma cutoff_negative_multiplicity
    (cutoff degreeBound : ℕ)
    (hcutoff : 3 < cutoff)
    (hterms :
      ∀ term ∈ (boundedConstantAlphabet cutoff).toFinset,
        IVMost
          (fun multiplicity : ℕ =>
            (negativeBoundedMultiplicity cutoff multiplicity term : ℤ))
          degreeBound) :
    CPDataa cutoff degreeBound
      (fun multiplicity =>
        cutoffProfile cutoff
          (NNPower.strictTrace
            multiplicity)) := by
  constructor
  · intro multiplicity
    exact supported_vocabulary_profile cutoff _
  · intro slot
    rw [show
      (fun multiplicity : ℕ =>
        (Multiset.count slot
          (cutoffProfile cutoff
            (NNPower.strictTrace
              multiplicity)) : ℤ)) =
        fun multiplicity : ℕ =>
          ∑ term ∈ (boundedConstantAlphabet cutoff).toFinset,
            (negativeBoundedMultiplicity cutoff multiplicity term : ℤ) *
              (Multiset.count slot (term.eval cutoff) : ℤ) by
      funext multiplicity
      exact_mod_cast
        count_negative_alphabet
          cutoff hcutoff multiplicity slot]
    apply IVMost.finsetSum
    intro term hterm
    simpa [mul_comm] using
      TCTex.IVMost.smul
        (Multiset.count slot (term.eval cutoff) : ℤ)
        (hterms term hterm)

end TMRed
