          (exponentAddressParent x y z)
          (addressBelowTerms
            (n := n) x y z cutoff (Int.negSucc magnitude)).prod)

/--
The positive recipes reconstruct the retained strict-tail class directly as a
finite sum of canonical Hall commutator classes.
-/
lemma associated_graded_cast
    (d n : ℕ)
    (x y z :
