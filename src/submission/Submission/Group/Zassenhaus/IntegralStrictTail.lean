/-!
# Triangular polynomial depth-word subsequence states

The bounded strict-depth substitution replaces `depth` by its optional strict
child `depth + 1` followed by its retained child `depth`.  Reading a requested
output depth word from left to right gives a finite list of predecessor depth
words.  The all-retained predecessor is the requested word itself; every
other predecessor has strictly smaller total depth-plus-length grade.

This file packages that triangular recurrence abstractly and proves that
iterating it has integer-valued polynomial coordinates.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace BSPoly

/-- Total depth plus word length.  Every non-retained predecessor strictly
lowers this grade. -/
def strictDepthGrade :
    List ℕ → ℕ
  | [] =>
      0
  | depth :: depths =>
      depth + 1 + strictDepthGrade depths

/-- Ordered predecessor depth words for one strict-depth substitution step.
Duplicates are retained because they record distinct local selections. -/
def strictPredecessorPatterns :
    List ℕ → List (List ℕ)
  | [] =>
      [[]]
  | depth :: depths =>
      (strictPredecessorPatterns depths).map (fun previous =>
          depth :: previous)
        ++
      (if 0 < depth then
        (strictPredecessorPatterns depths).map (fun previous =>
          (depth - 1) :: previous)
      else
        [])
        ++
      match depths with
      | [] =>
          []
      | nextDepth :: tail =>
          if depth = nextDepth + 1 then
            (strictPredecessorPatterns tail).map (fun previous =>
              nextDepth :: previous)
          else
            []

/-- All predecessors except the leading all-retained predecessor. -/
def properPredecessorPatterns
    (target : List ℕ) :
    List (List ℕ) :=
  (strictPredecessorPatterns target).tail

/-- The all-retained predecessor is the first predecessor pattern. -/
lemma predecessor_patterns_proper :
    ∀ target : List ℕ,
      strictPredecessorPatterns target =
        target :: properPredecessorPatterns target
  | [] => by
      rfl
  | depth :: depths => by
      unfold properPredecessorPatterns
      rw [strictPredecessorPatterns.eq_def]
      simp only
      rw [predecessor_patterns_proper depths]
      rfl

/-- Proper predecessors of a nonempty target split into retained-tail,
strict-head, and double-output branches. -/
lemma proper_patterns_cons
    (depth : ℕ)
    (depths : List ℕ) :
    properPredecessorPatterns (depth :: depths) =
      (properPredecessorPatterns depths).map (fun previous =>
          depth :: previous)
        ++
      (if 0 < depth then
        (strictPredecessorPatterns depths).map (fun previous =>
          (depth - 1) :: previous)
      else
        [])
        ++
      match depths with
      | [] =>
          []
      | nextDepth :: tail =>
          if depth = nextDepth + 1 then
            (strictPredecessorPatterns tail).map (fun previous =>
              nextDepth :: previous)
          else
            [] := by
  unfold properPredecessorPatterns
  rw [strictPredecessorPatterns.eq_def]
  simp only
  rw [predecessor_patterns_proper depths]
  rfl

/-- Every proper substitution predecessor has strictly smaller
depth-plus-length grade. -/
lemma proper_predecessor_patterns :
    ∀ (target previous : List ℕ),
      previous ∈ properPredecessorPatterns target →
        strictDepthGrade previous < strictDepthGrade target
  | [], previous, hprevious => by
      simp [properPredecessorPatterns,
        strictPredecessorPatterns] at hprevious
  | depth :: depths, previous, hprevious => by
      rw [proper_patterns_cons] at hprevious
      simp only [List.mem_append, List.mem_map] at hprevious
      rcases hprevious with (hprevious | hprevious) | hprevious
      · rcases hprevious with ⟨prior, hprior, rfl⟩
        simp only [strictDepthGrade]
        exact
          Nat.add_lt_add_left
            (proper_predecessor_patterns
              depths prior hprior)
            (depth + 1)
      · by_cases hdepth : 0 < depth
        · simp only [hdepth, ↓reduceIte, List.mem_map] at hprevious
          rcases hprevious with ⟨prior, hprior, rfl⟩
          have hpriorLe :
              strictDepthGrade prior ≤ strictDepthGrade depths := by
            rw [predecessor_patterns_proper] at hprior
            simp only [List.mem_cons] at hprior
            rcases hprior with rfl | hprior
            · exact le_rfl
            · exact
                Nat.le_of_lt
                  (proper_predecessor_patterns
                    depths prior hprior)
          simp only [strictDepthGrade]
          omega
        · simp [hdepth] at hprevious
      · cases depths with
        | nil =>
            simp at hprevious
        | cons nextDepth tail =>
            by_cases hnextDepth : depth = nextDepth + 1
            · simp only [hnextDepth, ↓reduceIte, List.mem_map] at hprevious
              rcases hprevious with ⟨prior, hprior, rfl⟩
              have hpriorLe :
                  strictDepthGrade prior ≤ strictDepthGrade tail := by
                rw [predecessor_patterns_proper] at hprior
                simp only [List.mem_cons] at hprior
                rcases hprior with rfl | hprior
                · exact le_rfl
                · exact
                    Nat.le_of_lt
                      (proper_predecessor_patterns
                        tail prior hprior)
              simp only [strictDepthGrade]
              omega
            · simp [hnextDepth] at hprevious
termination_by target => target.length

/-- Integer-valued state indexed by ordered depth words. -/
abbrev StrictSubsequenceState :=
  List ℕ → ℤ

/-- One triangular predecessor-state step. -/
def strictSubsequenceState
    (state : StrictSubsequenceState) :
    StrictSubsequenceState :=
  fun target =>
    ((strictPredecessorPatterns target).map state).sum

/-- One state step is the retained self-coordinate plus its proper,
strictly-lower-grade predecessor coordinates. -/
lemma subsequence_state_proper
    (state : StrictSubsequenceState)
    (target : List ℕ) :
    strictSubsequenceState state target =
      state target +
        ((properPredecessorPatterns target).map state).sum := by
  rw [strictSubsequenceState,
    predecessor_patterns_proper]
  rfl

/-- Iterate the abstract triangular depth-word state transformer. -/
def iterateSubsequenceState
    (initial : StrictSubsequenceState) :
    ℕ → StrictSubsequenceState
  | 0 =>
      initial
  | steps + 1 =>
      strictSubsequenceState
        (iterateSubsequenceState initial steps)

/-- Iterated coordinates are their initial value plus the partial sum of
proper-predecessor increments. -/
lemma iterate_subsequence_state
    (initial : StrictSubsequenceState)
    (target : List ℕ) :
    ∀ steps : ℕ,
      iterateSubsequenceState initial steps target =
        initial target +
          ∑ j ∈ Finset.range steps,
            ((properPredecessorPatterns target).map fun previous =>
              iterateSubsequenceState initial j previous).sum
  | 0 => by
      simp [iterateSubsequenceState]
  | steps + 1 => by
      rw [iterateSubsequenceState,
        subsequence_state_proper,
        Finset.sum_range_succ]
      have hprevious :=
        iterate_subsequence_state
          initial target steps
      linear_combination hprevious

/-- A finite sum of common-degree integer-valued polynomial families has
that same degree bound. -/
lemma valued_most_sum
    {α : Type*}
    (degreeBound : ℕ)
    (items : List α)
    (family : α → ℕ → ℤ)
    (hfamily :
      ∀ item ∈ items,
        IVMost
          (family item) degreeBound) :
    IVMost
      (fun steps : ℕ =>
        (items.map fun item => family item steps).sum)
      degreeBound := by
  induction items with
  | nil =>
      simpa using
        TCTex.IVMost.zero
          degreeBound
  | cons item items ih =>
      simpa using
        (hfamily item (by simp)).add
          (ih (fun previous hprevious =>
            hfamily previous (by simp [hprevious])))

/-- Every fixed integer state value is a degree-zero polynomial and hence
fits any requested degree bound. -/
lemma valued_most_const
    (degreeBound : ℕ)
    (value : ℤ) :
    IVMost
      (fun _steps : ℕ => value) degreeBound := by
  exact
    ⟨Polynomial.C value, by simp, fun steps => by simp⟩

/-- Iterating the triangular depth-word operator from any fixed state has
integer-valued polynomial coordinates with their natural grade bounds. -/
lemma iterate_subsequence_count
    (initial : StrictSubsequenceState) :
    ∀ target : List ℕ,
      IVMost
        (fun steps : ℕ =>
          iterateSubsequenceState initial steps target)
        (strictDepthGrade target + 1)
  | target => by
      have hincrement :
          IVMost
            (fun steps : ℕ =>
              ((properPredecessorPatterns target).map fun previous =>
                iterateSubsequenceState
                  initial steps previous).sum)
            (strictDepthGrade target) := by
        apply valued_most_sum
        intro previous hprevious
        apply
          TCTex.IVMost.mono
            (Nat.succ_le_iff.mpr
              (proper_predecessor_patterns
                target previous hprevious))
        exact
          iterate_subsequence_count
            initial previous
      rw [show
        (fun steps : ℕ =>
          iterateSubsequenceState initial steps target) =
        (fun _steps : ℕ => initial target) +
          (fun steps : ℕ =>
            ∑ j ∈ Finset.range steps,
              ((properPredecessorPatterns target).map fun previous =>
                iterateSubsequenceState
                  initial j previous).sum) by
        funext steps
        simp only [Pi.add_apply]
        exact
          iterate_subsequence_state
            initial target steps]
      exact
        (valued_most_const
          (strictDepthGrade target + 1) (initial target)).add
            hincrement.partialSum
termination_by target => strictDepthGrade target
decreasing_by
  exact
    proper_predecessor_patterns
      target previous hprevious

end BSPoly
end TCTex
end Submission

