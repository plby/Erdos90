/-- Newton-normalized repeated-block expansion for one retained slot. -/
noncomputable def repeatedMoveExpansion
    (cutoff : ℕ)
    (left : CWord Atom)
    (rights : List (CWord Atom))
    (slot : CWord Atom) :
    BCExp 1 cutoff :=
  BCExp.binomialBasis 1 cutoff (by omega)
    (repeatedMoveMultiplicity cutoff left rights slot)

/-- The normalized repeated-block expansion evaluates to the literal retained
slot multiplicity after any number of rightward moves. -/
lemma repeated_move_expansion
    (cutoff : ℕ)
    (left : CWord Atom)
    (hleft :
      NPTail.isFirstCurrent left = true ∨
        NPTail.isSecondCurrent left = true)
    (rights : List (CWord Atom))
    (slot : CWord Atom) :
    (repeatedMoveExpansion cutoff left rights slot).eval =
      repeatedMoveMultiplicity cutoff left rights slot := by
  apply BCExp.eval_binomialBasis
  simpa using
    repeated_move_most
      cutoff left hleft rights slot

/-- Every literal retained slot multiplicity belongs to the bounded
repeated-block recipe span. -/
lemma repeated_move_span
    (cutoff : ℕ)
    (left : CWord Atom)
    (hleft :
      NPTail.isFirstCurrent left = true ∨
        NPTail.isSecondCurrent left = true)
    (rights : List (CWord Atom))
    (slot : CWord Atom) :
    IntCombinationRecipes
      1 cutoff
      (repeatedMoveMultiplicity cutoff left rights slot) := by
  rw [← repeated_move_expansion cutoff left hleft rights slot]
  exact (repeatedMoveExpansion cutoff left rights slot).eval_recipe_span

/-- One coefficient-independent list of recipe expansions, indexed by the
ordered cutoff vocabulary. -/
noncomputable def repeatedMoveVector
    (cutoff : ℕ)
    (left : CWord Atom)
    (rights : List (CWord Atom)) :
    List (BCExp 1 cutoff) :=
  (orderedCutoffVocabulary cutoff).map fun slot =>
    repeatedMoveExpansion cutoff left rights slot

/-- The repeated-move recipe vector has one coordinate for every formal
cutoff slot. -/
lemma length_repeated_move
    (cutoff : ℕ)
    (left : CWord Atom)
    (rights : List (CWord Atom)) :
    (repeatedMoveVector cutoff left rights).length =
      (orderedCutoffVocabulary cutoff).length := by
  simp [repeatedMoveVector]

/-- Evaluating the vocabulary-wide recipe vector recovers every literal
retained-slot multiplicity after repeated movement. -/
lemma repeated_move_vector
    (cutoff : ℕ)
    (left : CWord Atom)
    (hleft :
      NPTail.isFirstCurrent left = true ∨
        NPTail.isSecondCurrent left = true)
    (rights : List (CWord Atom))
    (steps : ℕ) :
    (repeatedMoveVector cutoff left rights).map
        (fun expansion => expansion.eval steps) =
      (orderedCutoffVocabulary cutoff).map fun slot =>
        (unitBelowMultiplicity cutoff
          (iteratedMoveHigher left steps rights) slot : ℤ) := by
  unfold repeatedMoveVector
  rw [List.map_map]
  apply List.map_congr_left
  intro slot _hslot
  rw [Function.comp_apply, repeated_move_expansion
    cutoff left hleft rights slot]
  rfl

end RMExp
