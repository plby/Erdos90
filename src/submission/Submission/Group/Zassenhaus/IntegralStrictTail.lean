its induced crossing-substitution schedule operator from the zero vector. -/
lemma crossing_flat_move
    (cutoff : ℕ)
    (outer selected : CWord Atom)
    (houter : isFirstCurrent outer = true)
    (trace : List (CWord Atom)) :
