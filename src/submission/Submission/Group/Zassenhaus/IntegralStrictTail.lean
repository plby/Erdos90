-- omposition.lean

/-!
# Active-source decomposition of bounded Hall-Witt subsequences

Every subsequence of a packet-substituted word has a unique set of active
source positions: the positions whose emitted packets contribute a nonempty
subsequence.  Regrouping by that active source word turns one substitution
step into a finite linear recurrence on ordered-subsequence multiplicities.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace ASDecomp

open DSRec
open BSRec
open ASTri

/-- Regroup packet-subsequence expansions by the active source subword whose
packets contribute nonempty choices. -/
def regroupedSubsequenceExpansions
    {α β : Type*}
    (packet : α → List β)
    (source : List α) :
    List (List β) :=
  source.sublists.flatMap
    (activeSubsequenceExpansions packet)

/-- The empty packet subsequence is the first subsequence, and every remaining
packet subsequence is nonempty. -/
lemma sublists_cons_nonempty
    {α : Type*} :
    ∀ items : List α,
      items.sublists =
        [] :: nonemptySublists items
  | [] => by
      rfl
  | item :: items => by
      have hactive :
          ∀ selected ∈ nonemptySublists items,
            selected ≠ [] := by
        intro selected hselected
        exact
          of_decide_eq_true
            (List.mem_filter.mp hselected).2
      have hflat :
          ((nonemptySublists items).flatMap fun selected =>
            [selected, item :: selected]).filter
              (fun selected => decide (selected ≠ [])) =
            (nonemptySublists items).flatMap fun selected =>
              [selected, item :: selected] := by
        apply List.filter_eq_self.mpr
        intro selected hselected
        rcases List.mem_flatMap.mp hselected with
          ⟨source, hsource, hselected⟩
        simp only [List.mem_cons] at hselected
        rcases hselected with rfl | rfl | hselected
        · exact decide_eq_true (hactive selected hsource)
        · simp
        · simp at hselected
      calc
        (item :: items).sublists =
            ([] :: nonemptySublists items).flatMap fun selected =>
              [selected, item :: selected] := by
          rw [List.sublists_cons,
            sublists_cons_nonempty items]
          rfl
        _ =
            [] :: [item] ::
              (nonemptySublists items).flatMap fun selected =>
                [selected, item :: selected] := by
          rfl
        _ =
            [] :: nonemptySublists (item :: items) := by
          change
            [] :: [item] ::
                (nonemptySublists items).flatMap (fun selected =>
                  [selected, item :: selected]) =
              [] ::
                ((item :: items).sublists.filter fun selected =>
                  decide (selected ≠ []))
          congr 1
          rw [List.sublists_cons,
            sublists_cons_nonempty items]
          change
            [item] ::
                (nonemptySublists items).flatMap (fun selected =>
                  [selected, item :: selected]) =
              ([[], [item]] ++
                (nonemptySublists items).flatMap (fun selected =>
                  [selected, item :: selected])).filter fun selected =>
                    decide (selected ≠ [])
          rw [List.filter_append, hflat]
          rfl

/-- Regrouping by active source positions preserves the duplicate-sensitive
packet-subsequence list up to permutation. -/
lemma regrouped_expansions_perm
    {α β : Type*}
    (packet : α → List β) :
    ∀ source : List α,
      List.Perm
        (regroupedSubsequenceExpansions packet source)
        (packetSubsequenceExpansions packet source)
  | [] => by
      rfl
  | item :: items => by
      let appendPacketHeads : List β → List (List β) :=
        fun suffix =>
          (nonemptySublists (packet item)).map fun head =>
            head ++ suffix
      have hsublists :
          List.Perm
            (item :: items).sublists
            (items.sublists ++
              items.sublists.map (List.cons item)) :=
        List.sublists_cons_perm_append item items
      have hregroup :
          List.Perm
            (regroupedSubsequenceExpansions packet (item :: items))
            (regroupedSubsequenceExpansions packet items ++
              (regroupedSubsequenceExpansions packet items).flatMap
                appendPacketHeads) := by
        calc
          List.Perm
              (regroupedSubsequenceExpansions packet (item :: items))
              ((items.sublists ++
                items.sublists.map (List.cons item)).flatMap
                  (activeSubsequenceExpansions packet)) := by
            exact hsublists.flatMap
              (fun _source _hsource => List.Perm.refl _)
          _ =
              items.sublists.flatMap
                  (activeSubsequenceExpansions packet) ++
                (items.sublists.map (List.cons item)).flatMap
                  (activeSubsequenceExpansions packet) := by
            rw [List.flatMap_append]
          _ =
              regroupedSubsequenceExpansions packet items ++
                items.sublists.flatMap (fun source =>
                  activeSubsequenceExpansions packet
                    (item :: source)) := by
            simp [regroupedSubsequenceExpansions,
              List.flatMap_map]
          _ =
              regroupedSubsequenceExpansions packet items ++
                items.sublists.flatMap (fun source =>
                  (activeSubsequenceExpansions packet source).flatMap
                    appendPacketHeads) := by
            rfl
          _ =
              regroupedSubsequenceExpansions packet items ++
                (regroupedSubsequenceExpansions packet items).flatMap
                  appendPacketHeads := by
            rw [regroupedSubsequenceExpansions, List.flatMap_assoc]
      have hpacketHeads
          (suffix : List β) :
          suffix :: appendPacketHeads suffix =
            (packet item).sublists.map fun head =>
              head ++ suffix := by
        rw [sublists_cons_nonempty]
        rfl
      have hcombine :
          List.Perm
            (regroupedSubsequenceExpansions packet items ++
              (regroupedSubsequenceExpansions packet items).flatMap
                appendPacketHeads)
            ((regroupedSubsequenceExpansions packet items).flatMap
              (fun suffix => suffix :: appendPacketHeads suffix)) := by
        simpa using
          List.map_append_flatMap_perm
            (regroupedSubsequenceExpansions packet items)
            id appendPacketHeads
      apply hregroup.trans
      apply hcombine.trans
      rw [show
        (fun suffix : List β => suffix :: appendPacketHeads suffix) =
          fun suffix =>
            (packet item).sublists.map fun head =>
              head ++ suffix by
        funext suffix
        exact hpacketHeads suffix]
      simpa [packetSubsequenceExpansions] using
        (regrouped_expansions_perm packet items).flatMap
          (fun _suffix _hsuffix => List.Perm.refl
            ((packet item).sublists.map fun head =>
              head ++ _suffix))

/-- Counting one target through a flattened family is the sum of its counts
inside the family members. -/
lemma count_flat_sum
    {α β : Type*}
    [BEq β] [LawfulBEq β]
    (family : α → List β)
    (target : β) :
    ∀ source : List α,
      (source.flatMap family).count target =
        (source.map fun item => (family item).count target).sum
  | [] => by
      rfl
  | item :: items => by
      rw [List.flatMap_cons, List.count_append,
        count_flat_sum family target items]
      rfl

/-- Exact active-source convolution formula for packet-subsequence
multiplicities. -/
lemma count_subsequence_expansions
    {α β : Type*}
    [BEq β] [LawfulBEq β]
    (packet : α → List β)
    (source : List α)
    (target : List β) :
    (packetSubsequenceExpansions packet source).count target =
      (source.sublists.map fun activeSource =>
        (activeSubsequenceExpansions packet activeSource).count
          target).sum := by
  rw [←
    (regrouped_expansions_perm packet source).count_eq
      target]
  exact
    count_flat_sum
      (activeSubsequenceExpansions packet) target source.sublists

/-- One bounded Hall-Witt depth-substitution successor is the exact
active-source convolution for the fixed finite packet family. -/
lemma ordered_subsequence_multiplicity
    (cutoff steps : ℕ)
    (target : List ℕ) :
    orderedSubsequenceMultiplicity target
        (boundedDepthSchedule cutoff (steps + 1)) =
      ((boundedDepthSchedule cutoff steps).sublists.map
        fun activeSource =>
          (activeSubsequenceExpansions
            (strictStepPacket cutoff) activeSource).count target).sum := by
  rw [
    ordered_subsequence_succ,
    count_subsequence_expansions]

end ASDecomp
end TCTex
end Submission

