        ∑ source ∈ (wordsUpLength cutoff target.length).toFinset,
          orderedSubsequenceMultiplicity source
              (boundedDepthSchedule cutoff steps) •
            activeSubsequenceCoefficient
              cutoff selected right source target := by
      apply Finset.sum_congr rfl
      intro source hsource
      have hlength :
          source.length ≤ target.length :=
        length_words_up
          cutoff target.length source (List.mem_toFinset.mp hsource)
      rw [show
        boundedSourceSublists.count source =
          orderedSubsequenceMultiplicity source
            (boundedDepthSchedule cutoff steps) by
        unfold boundedSourceSublists sourceSublists
          orderedSubsequenceMultiplicity
        exact List.count_filter (decide_eq_true hlength)]

/-- The depth-plus-length grade of a below-cutoff depth word is bounded by its
length times the cutoff. -/
lemma strictGradeLength
    (cutoff : ℕ) :
    ∀ source : List ℕ,
      (∀ depth ∈ source, depth < cutoff) →
        strictDepthGrade source ≤ source.length * cutoff
  | [], _hsource => by
      simp [strictDepthGrade]
  | depth :: source, hsource => by
      have hdepth :
          depth + 1 ≤ cutoff :=
        Nat.succ_le_iff.mpr (hsource depth (by simp))
      have htail :
          strictDepthGrade source ≤ source.length * cutoff :=
        strictGradeLength cutoff source
          (fun next hnext => hsource next (by simp [hnext]))
      simpa [strictDepthGrade, Nat.succ_mul, Nat.add_comm] using
        Nat.add_le_add hdepth htail

/-- Every fixed transition word has an integer-valued polynomial ordered
subsequence multiplicity along a bounded depth-retained schedule. -/
lemma subsequence_multiplicity_bounded
    (cutoff : ℕ)
    (selected right : CWord Atom)
    (target : List SRTrans) :
    IVMost
      (fun steps : ℕ =>
        (orderedSubsequenceMultiplicity target
          (boundedStrictSchedule cutoff selected right steps) :
            ℤ))
      (target.length * cutoff + 1) := by
  rw [show
    (fun steps : ℕ =>
      (orderedSubsequenceMultiplicity target
        (boundedStrictSchedule cutoff selected right steps) :
          ℤ)) =
      fun steps : ℕ =>
        ∑ source ∈ (wordsUpLength cutoff target.length).toFinset,
          (activeSubsequenceCoefficient
              cutoff selected right source target : ℤ) *
            (orderedSubsequenceMultiplicity source
              (boundedDepthSchedule cutoff steps) : ℤ) by
    funext steps
    exact_mod_cast
      (by
        simpa [nsmul_eq_mul, Nat.mul_comm] using
          ordered_subsequence_words
            cutoff steps selected right target)]
  apply IVMost.finsetSum
  intro source hsource
  have hsourceMem :
      source ∈ wordsUpLength cutoff target.length :=
    List.mem_toFinset.mp hsource
  have hsourceLt :
      ∀ depth ∈ source, depth < cutoff :=
    fun depth hdepth =>
      words_up_length
        cutoff target.length source hsourceMem depth hdepth
  have hlength :
      source.length ≤ target.length :=
    length_words_up
      cutoff target.length source hsourceMem
  apply
    TCTex.IVMost.smul
  apply
    TCTex.IVMost.mono
  · exact
      Nat.add_le_add_right
        ((strictGradeLength cutoff source hsourceLt).trans
          (Nat.mul_le_mul_right cutoff hlength))
        1
  · exact
      subsequence_multiplicity_strict
        cutoff source hsourceLt

end DRSubseq
