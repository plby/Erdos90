-- Merged from JacobiIntegralPowerStrictTailCutoffOrderedSecondRouteBoundedTermAlphabet.lean

/-!
# Finite bounded-term alphabets for Hall-Witt second routes

The bounded ordered-subsequence expansion of a second-route schedule still
produces a coefficient-dependent list of summands.  Its summand *types* are
nevertheless drawn from one finite cutoff-dependent alphabet:

* a strict-transition word of length below `cutoff`;
* the affine constant of one transition in the fixed transition alphabet.

This file constructs that alphabet and proves support for arbitrary
well-formed first-route programs, then specializes it to the positive and
negative Hall-Witt programs.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace STAlphab

open WSTrace
open NPTail
open TBProf
open OFProgra
open OFProgra.FRProgra
open STSched
open SSExp

/-- Enumerate all words of one fixed length over a finite transition alphabet. -/
def transitionWordsLength
    (alphabet : List SRTrans) :
    ℕ → List (List SRTrans)
  | 0 =>
      [[]]
  | length + 1 =>
      alphabet.flatMap fun transition =>
        (transitionWordsLength alphabet length).map
          (List.cons transition)

/-- Every word over an alphabet belongs to the enumeration at its own length. -/
lemma transition_words_forall
    (alphabet : List SRTrans) :
    ∀ transitions : List SRTrans,
      (∀ transition ∈ transitions, transition ∈ alphabet) →
        transitions ∈ transitionWordsLength alphabet transitions.length
  | [], _htransitions => by
      simp [transitionWordsLength]
  | transition :: transitions, htransitions => by
      simp only [transitionWordsLength]
      apply List.mem_flatMap.mpr
      refine ⟨transition, htransitions transition (by simp), ?_⟩
      apply List.mem_map.mpr
      exact
        ⟨transitions,
          transition_words_forall alphabet transitions
            (fun next hnext =>
              htransitions next (by simp [hnext])),
          rfl⟩

/-- Enumerate all transition words whose length is strictly below one cutoff. -/
def wordsBelowLength
    (alphabet : List SRTrans)
    (cutoff : ℕ) :
    List (List SRTrans) :=
  (List.range cutoff).flatMap (transitionWordsLength alphabet)

/-- Every alphabet-supported word shorter than the cutoff belongs to the
bounded word enumeration. -/
lemma words_below_forall
    (alphabet : List SRTrans)
    (cutoff : ℕ)
    (transitions : List SRTrans)
    (hlength : transitions.length < cutoff)
    (htransitions : ∀ transition ∈ transitions, transition ∈ alphabet) :
    transitions ∈ wordsBelowLength alphabet cutoff := by
  apply List.mem_flatMap.mpr
  exact
    ⟨transitions.length, List.mem_range.mpr hlength,
      transition_words_forall alphabet transitions
        htransitions⟩

/--
One fixed finite alphabet containing every surviving ordered-subsequence
constant term below a cutoff.
-/
def boundedConstantAlphabet
    (cutoff : ℕ) :
    List OCTerm :=
  (wordsBelowLength
      (secondRouteAlphabet cutoff) cutoff).flatMap
    fun strictTransitions =>
      (secondRouteAlphabet cutoff).map fun transition =>
        { strictTransitions := strictTransitions
          constant := (transition.affine cutoff).constant }

/-- Support predicate for a bounded constant term relative to one transition
alphabet. -/
def TermSupportedBy
    (cutoff : ℕ)
    (alphabet : List SRTrans)
    (term : OCTerm) :
    Prop :=
  (∀ transition ∈ term.strictTransitions, transition ∈ alphabet) ∧
    ∃ transition ∈ alphabet,
      term.constant = (transition.affine cutoff).constant

/-- Every constant term expanded from an alphabet-supported schedule is
supported by that same transition alphabet. -/
lemma supported_constant_terms
    (cutoff : ℕ)
    (alphabet : List SRTrans) :
    ∀ schedule : List SRTrans,
      (∀ transition ∈ schedule, transition ∈ alphabet) →
        ∀ term ∈ orderedConstantTerms cutoff schedule,
          TermSupportedBy cutoff alphabet term
  | [], _hschedule, term, hterm => by
      simp [orderedConstantTerms] at hterm
  | transition :: schedule, hschedule, term, hterm => by
      simp only [orderedConstantTerms, List.mem_append] at hterm
      rcases hterm with (hterm | hterm) | hterm
      · rcases List.mem_map.mp hterm with ⟨tailTerm, htailTerm, rfl⟩
        rcases
            supported_constant_terms
              cutoff alphabet schedule
                (fun next hnext => hschedule next (by simp [hnext]))
                tailTerm htailTerm with
          ⟨hstrict, hconstant⟩
        constructor
        · intro next hnext
          simp only [OCTerm.prepend, List.mem_cons] at hnext
          rcases hnext with rfl | hnext
          · exact hschedule next (by simp)
          · exact hstrict next hnext
        · exact hconstant
      · exact
          supported_constant_terms
            cutoff alphabet schedule
              (fun next hnext => hschedule next (by simp [hnext]))
              term hterm
      · rw [List.mem_singleton] at hterm
        subst term
        exact
          ⟨by simp,
            ⟨transition, hschedule transition (by simp), rfl⟩⟩

/-- Every bounded term expanded from an alphabet-supported schedule belongs
to the fixed bounded-term alphabet generated by that transition alphabet. -/
lemma constant_alphabet_terms
    (cutoff : ℕ)
    (schedule : List SRTrans)
    (hschedule :
      ∀ transition ∈ schedule,
        transition ∈ secondRouteAlphabet cutoff)
    (term : OCTerm)
    (hterm : term ∈ boundedConstantTerms cutoff schedule) :
    term ∈ boundedConstantAlphabet cutoff := by
  have hlength :
      term.strictTransitions.length < cutoff :=
    length_constant_terms
      cutoff schedule term hterm
  have hordered :
      term ∈ orderedConstantTerms cutoff schedule :=
    (List.mem_filter.mp hterm).1
  rcases
      supported_constant_terms
        cutoff (secondRouteAlphabet cutoff)
          schedule hschedule term hordered with
    ⟨hstrict, ⟨constantTransition, hconstantTransition, hconstant⟩⟩
  apply List.mem_flatMap.mpr
  refine
    ⟨term.strictTransitions,
      words_below_forall
        (secondRouteAlphabet cutoff) cutoff
          term.strictTransitions hlength hstrict,
      ?_⟩
  apply List.mem_map.mpr
  refine ⟨constantTransition, hconstantTransition, ?_⟩
  cases term with
  | mk strictTransitions constant =>
      simp only at hconstant ⊢
      rw [hconstant]

/-- Every bounded term extracted from a well-formed first-route program lies
in one fixed cutoff-dependent alphabet. -/
lemma constant_alphabet_schedule
    (cutoff : ℕ)
    (program : FRProgra)
    (hprogram : FirstCurrentMoves program)
    (term : OCTerm)
    (hterm :
      term ∈ boundedConstantTerms cutoff
        (transitionSchedule cutoff program)) :
    term ∈ boundedConstantAlphabet cutoff := by
  exact
    constant_alphabet_terms
      cutoff (transitionSchedule cutoff program)
        (transition_alphabet_schedule
          cutoff program hprogram)
        term hterm

/-- Every positive Hall-Witt bounded second-route term lies in the fixed
cutoff-dependent term alphabet. -/
lemma alphabet_natural_terms
    (cutoff multiplicity : ℕ)
    (term : OCTerm)
    (hterm :
      term ∈ boundedConstantTerms cutoff
        (transitionSchedule cutoff
          (naturalRouteProgram cutoff multiplicity))) :
    term ∈ boundedConstantAlphabet cutoff := by
  exact
    constant_alphabet_terms
      cutoff
        (transitionSchedule cutoff
          (naturalRouteProgram cutoff multiplicity))
        (alphabet_natural_schedule
          cutoff multiplicity)
        term hterm

/-- Every negative Hall-Witt bounded second-route term lies in the fixed
cutoff-dependent term alphabet. -/
lemma alphabet_negative_terms
    (cutoff multiplicity : ℕ)
    (term : OCTerm)
    (hterm :
      term ∈ boundedConstantTerms cutoff
        (transitionSchedule cutoff
          (negativeRouteProgram cutoff multiplicity))) :
    term ∈ boundedConstantAlphabet cutoff := by
  exact
    constant_alphabet_terms
      cutoff
        (transitionSchedule cutoff
          (negativeRouteProgram cutoff multiplicity))
        (alphabet_negative_schedule
          cutoff multiplicity)
        term hterm

end STAlphab
end TCTex
end Submission

-- Merged from JacobiIntegralPowerStrictTailCutoffOrderedOuterPacketTransitionSchedule.lean

/-!
# Transition schedules for factored Hall-Witt outer packets

The normalized Hall-Witt outer packet has one first-family selected word.
At the affine level its second-pass action factors into one fixed prefix and
one dynamic swap.  Retain the finer transition schedule: one outer packet
contributes a fixed schedule followed by crossings of the selected word over
the previously emitted ordered tail.

This is the schedule recurrence needed by the bounded ordered-subsequence
counter.  It keeps the coefficient-dependent order explicit while isolating
all packet-local transitions in one fixed list.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace OTSched

open WSTrace
open WHNorm
open WNTrace
open NPTail
open RMRecb
open OFProgra
open OFProgra.FRProgra
open TOFact
open STSched

/-- Prefixing a wholly unselected source emits retained transitions before
the existing schedule. -/
lemma transition_prepend_current
    (cutoff : ℕ) :
    ∀ (source : List (CWord Atom))
      (tail : FRProgra),
      (∀ word ∈ source, isFirstCurrent word ≠ true) →
        transitionSchedule cutoff
            (prepend cutoff isFirstCurrent source tail) =
          (unitBelowTrace cutoff source).map
              SRTrans.retained ++
            transitionSchedule cutoff tail
  | [], tail, _hsource => by
      rfl
  | word :: words, tail, hsource => by
      have hword : isFirstCurrent word ≠ true :=
        hsource word (by simp)
      have hwords :
          ∀ next ∈ words, isFirstCurrent next ≠ true := by
        intro next hnext
        exact hsource next (by simp [hnext])
      rw [prepend, if_neg hword, transitionSchedule]
      rw [
        transition_prepend_current
          cutoff words tail hwords]
      simp only [unitBelowTrace, List.filter_cons]
      split <;> simp

/-- Prefixing a wholly unselected source emits its filtered trace before the
existing ordered tail. -/
lemma prepend_forall_current
    (cutoff : ℕ)
    (source : List (CWord Atom))
    (tail : FRProgra)
    (hsource : ∀ word ∈ source, isFirstCurrent word ≠ true) :
    (prepend cutoff isFirstCurrent source tail).trace cutoff =
      unitBelowTrace cutoff source ++ tail.trace cutoff := by
  rw [trace_prepend]
  rw [route_forall_current
    isFirstCurrent source (tail.trace cutoff) hsource]
  rw [unit_below_append, unit_below_trace]

/-- Packet-local schedule contributed by one factored outer packet before its
selected word crosses the previously emitted tail. -/
def fixedTransitionPrefix
    (cutoff : ℕ)
    (before : List (CWord Atom))
    (selected : CWord Atom)
    (suffix : List (CWord Atom)) :
    List SRTrans :=
  (unitBelowTrace cutoff before).map SRTrans.retained ++
    (unitBelowTrace cutoff suffix).map
      (SRTrans.crossed selected)

/-- One factored outer packet emits its fixed packet-local schedule followed
by crossings over the previously emitted ordered tail. -/
lemma prepend_prefix_append
    (cutoff : ℕ)
    (packet before suffix : List (CWord Atom))
    (selected : CWord Atom)
    (hpacket : packet = before ++ [selected] ++ suffix)
    (hselected : isFirstCurrent selected = true)
    (hbefore : ∀ word ∈ before, isFirstCurrent word ≠ true)
    (hsuffix : ∀ word ∈ suffix, isFirstCurrent word ≠ true)
    (tail : FRProgra) :
    transitionSchedule cutoff (prepend cutoff isFirstCurrent packet tail) =
      fixedTransitionPrefix cutoff before selected suffix ++
        (tail.trace cutoff).map (SRTrans.crossed selected) := by
  rw [hpacket, prepend_append, prepend_append]
  rw [
    transition_prepend_current
      cutoff before _ hbefore]
  simp only [prepend, if_pos hselected, transitionSchedule]
  rw [
    prepend_forall_current
      cutoff suffix tail hsuffix,
    List.map_append]
  simp [fixedTransitionPrefix, List.append_assoc]

/-- One more iteration of a factored outer packet satisfies the same exact
transition-schedule recurrence. -/
lemma transition_prepend_append
    (cutoff : ℕ)
    (packet before suffix : List (CWord Atom))
    (selected : CWord Atom)
    (hpacket : packet = before ++ [selected] ++ suffix)
    (hselected : isFirstCurrent selected = true)
    (hbefore : ∀ word ∈ before, isFirstCurrent word ≠ true)
    (hsuffix : ∀ word ∈ suffix, isFirstCurrent word ≠ true)
    (steps : ℕ)
    (tail : FRProgra) :
    transitionSchedule cutoff
        (iteratePrepend cutoff isFirstCurrent packet (steps + 1) tail) =
      fixedTransitionPrefix cutoff before selected suffix ++
        ((iteratePrepend cutoff isFirstCurrent packet steps tail).trace
          cutoff).map (SRTrans.crossed selected) := by
  rw [iteratePrepend]
  exact
    prepend_prefix_append
      cutoff packet before suffix selected hpacket hselected hbefore hsuffix _

/-- Fixed positive normalized outer-packet transition prefix. -/
noncomputable def positiveFixedPrefix
    (cutoff : ℕ) :
    List SRTrans :=
  fixedTransitionPrefix cutoff
    positiveOuterFactorization.before firstConventionalInverse
      positiveOuterFactorization.suffix

/-- Fixed negative inverted outer-packet transition prefix. -/
noncomputable def negativeFixedPrefix
    (cutoff : ℕ) :
    List SRTrans :=
  fixedTransitionPrefix cutoff
    negativeOuterFactorization.before firstConventionalWord
      negativeOuterFactorization.suffix

/-- Each positive outer-packet iteration emits one fixed transition prefix
followed by crossings over the previously emitted tail trace. -/
lemma transition_prepend_succ
    (cutoff steps : ℕ)
    (tail : FRProgra) :
    transitionSchedule cutoff
        (iteratePrepend cutoff isFirstCurrent WNTrace.trace
          (steps + 1) tail) =
      positiveFixedPrefix cutoff ++
        ((iteratePrepend cutoff isFirstCurrent
          WNTrace.trace steps tail).trace cutoff).map
            (SRTrans.crossed firstConventionalInverse) := by
  apply
    transition_prepend_append
      cutoff WNTrace.trace
        positiveOuterFactorization.before
          positiveOuterFactorization.suffix
            firstConventionalInverse
  · exact positiveOuterFactorization.packet_eq
  · simp
  · exact positiveOuterFactorization.before_not_current
  · exact positiveOuterFactorization.suffix_not_current

/-- Each negative outer-packet iteration emits one fixed transition prefix
followed by crossings over the previously emitted tail trace. -/
lemma iterate_prepend_negative
    (cutoff steps : ℕ)
    (tail : FRProgra) :
    transitionSchedule cutoff
        (iteratePrepend cutoff isFirstCurrent
          NNPower.inverseNormalizedTrace
            (steps + 1) tail) =
      negativeFixedPrefix cutoff ++
        ((iteratePrepend cutoff isFirstCurrent
          NNPower.inverseNormalizedTrace
            steps tail).trace cutoff).map
              (SRTrans.crossed firstConventionalWord) := by
  apply
    transition_prepend_append
      cutoff
        NNPower.inverseNormalizedTrace
          negativeOuterFactorization.before
            negativeOuterFactorization.suffix firstConventionalWord
  · exact negativeOuterFactorization.packet_eq
  · simp
  · exact negativeOuterFactorization.before_not_current
  · exact negativeOuterFactorization.suffix_not_current

end OTSched
end TCTex
end Submission

-- Merged from JacobiIntegralPowerStrictTailCutoffOrderedSecondRouteBoundedTermRecurrence.lean

/-!
# Finite recurrences for bounded Hall-Witt second-route terms

The ordered-subsequence expansion can discard cutoff-long terms after every
transition rather than only after expanding the whole schedule.  Package that
one-transition update and its right fold.  Concatenating transition schedules
then becomes composition of finite bounded-term updates.

Combining this fold with the factored outer-packet schedule recurrence gives
an exact finite-state recurrence for the surviving positive and negative
Hall-Witt outer terms.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace STRec

open WSTrace
open WHNorm
open WNTrace
open NPTail
open OFProgra
open OFProgra.FRProgra
open OTSched
open STSched
open SSExp

/-- The new empty-subsequence term contributed by one affine transition. -/
def singletonConstantTerm
    (cutoff : ℕ)
    (transition : SRTrans) :
    OCTerm where
  strictTransitions := []
  constant := (transition.affine cutoff).constant

/-- One transition updates an already bounded list of ordered-subsequence
terms.  Terms lengthened past the cutoff are immediately discarded. -/
def boundedConstantStep
    (cutoff : ℕ)
    (transition : SRTrans)
    (terms : List OCTerm) :
    List OCTerm :=
  (terms.map (OCTerm.prepend transition)).filter (fun term =>
      decide (term.strictTransitions.length < cutoff)) ++
    terms ++
      ([singletonConstantTerm cutoff transition].filter (fun term =>
        decide (term.strictTransitions.length < cutoff)))

/-- A term surviving after prepending one strict transition already survived
before that transition was prepended. -/
lemma length_prepend
    (cutoff : ℕ)
    (transition : SRTrans)
    (term : OCTerm)
    (hterm :
      (term.prepend transition).strictTransitions.length < cutoff) :
    term.strictTransitions.length < cutoff := by
  simp only [OCTerm.prepend, List.length_cons] at hterm
  omega

/-- Filtering bounded terms before mapping a strict prepend does not change
the filtered mapped result. -/
lemma filter_prepend
    (cutoff : ℕ)
    (transition : SRTrans) :
    ∀ terms : List OCTerm,
      (terms.map (OCTerm.prepend transition)).filter
          (fun term => decide (term.strictTransitions.length < cutoff)) =
        ((terms.filter fun term =>
            decide (term.strictTransitions.length < cutoff)).map
              (OCTerm.prepend transition)).filter
                (fun term =>
                  decide (term.strictTransitions.length < cutoff))
  | [] => by
      rfl
  | term :: terms => by
      have ih :=
        filter_prepend cutoff transition terms
      by_cases hterm : term.strictTransitions.length < cutoff
      · by_cases hprepend :
            (term.prepend transition).strictTransitions.length < cutoff
        · simp [hterm, hprepend, ih]
        · simp [hterm, hprepend, ih]
      · have hprepend :
            ¬(term.prepend transition).strictTransitions.length < cutoff := by
          intro hprepend
          exact hterm
            (length_prepend cutoff transition term hprepend)
        simp [hterm, hprepend, ih]

/-- The global bounded expansion obeys the local one-transition update. -/
lemma constant_terms_cons
    (cutoff : ℕ)
    (transition : SRTrans)
    (transitions : List SRTrans) :
    boundedConstantTerms cutoff (transition :: transitions) =
      boundedConstantStep cutoff transition
        (boundedConstantTerms cutoff transitions) := by
  unfold boundedConstantTerms boundedConstantStep
  simp only [orderedConstantTerms, List.filter_append]
  rw [filter_prepend]
  rfl

/-- Fold a transition schedule through the finite bounded-term update. -/
def boundedConstantFold
    (cutoff : ℕ) :
    List SRTrans →
      List OCTerm →
        List OCTerm
  | [], terms =>
      terms
  | transition :: transitions, terms =>
      boundedConstantStep cutoff transition
        (boundedConstantFold cutoff transitions terms)

/-- The bounded expansion of a schedule is its finite update fold from the
empty term state. -/
lemma constant_terms_fold
    (cutoff : ℕ) :
    ∀ transitions : List SRTrans,
      boundedConstantTerms cutoff transitions =
        boundedConstantFold cutoff transitions []
  | [] => by
      rfl
  | transition :: transitions => by
      rw [constant_terms_cons,
        boundedConstantFold,
        constant_terms_fold cutoff transitions]

/-- Folding concatenated schedules composes their finite bounded-term
updates. -/
lemma constant_fold_append
    (cutoff : ℕ) :
    ∀ (left right : List SRTrans)
      (terms : List OCTerm),
      boundedConstantFold cutoff (left ++ right) terms =
        boundedConstantFold cutoff left
          (boundedConstantFold cutoff right terms)
  | [], right, terms => by
      rfl
  | transition :: transitions, right, terms => by
      rw [List.cons_append, boundedConstantFold,
        boundedConstantFold,
        constant_fold_append cutoff transitions right terms]

/-- The bounded expansion of concatenated schedules is obtained by folding
the left prefix over the bounded expansion of the right suffix. -/
lemma constant_terms_append
    (cutoff : ℕ)
    (left right : List SRTrans) :
    boundedConstantTerms cutoff (left ++ right) =
      boundedConstantFold cutoff left
        (boundedConstantTerms cutoff right) := by
  rw [constant_terms_fold,
    constant_fold_append,
    ← constant_terms_fold]

/-- One positive outer-packet iteration updates bounded terms by folding its
fixed transition prefix over the dynamic crossing schedule of the previous
tail trace. -/
lemma iterate_prepend_succ
    (cutoff steps : ℕ)
    (tail : FRProgra) :
    boundedConstantTerms cutoff
        (transitionSchedule cutoff
          (iteratePrepend cutoff isFirstCurrent
            WNTrace.trace (steps + 1) tail)) =
      boundedConstantFold cutoff
        (positiveFixedPrefix cutoff)
        (boundedConstantTerms cutoff
          (((iteratePrepend cutoff isFirstCurrent
            WNTrace.trace steps tail).trace cutoff).map
              (SRTrans.crossed
                firstConventionalInverse))) := by
  rw [transition_prepend_succ,
    constant_terms_append]

/-- One negative outer-packet iteration updates bounded terms by folding its
fixed transition prefix over the dynamic crossing schedule of the previous
tail trace. -/
lemma constant_iterate_prepend
    (cutoff steps : ℕ)
    (tail : FRProgra) :
    boundedConstantTerms cutoff
        (transitionSchedule cutoff
          (iteratePrepend cutoff isFirstCurrent
            NNPower.inverseNormalizedTrace
              (steps + 1) tail)) =
      boundedConstantFold cutoff
        (negativeFixedPrefix cutoff)
        (boundedConstantTerms cutoff
          (((iteratePrepend cutoff isFirstCurrent
            NNPower.inverseNormalizedTrace
              steps tail).trace cutoff).map
                (SRTrans.crossed firstConventionalWord))) := by
  rw [iterate_prepend_negative,
    constant_terms_append]

end STRec
end TCTex
end Submission

-- Merged from JacobiIntegralPowerStrictTailCutoffOrderedSecondRouteBoundedTermFiniteState.lean

/-!
# Finite multiplicity states for bounded Hall-Witt second-route terms

Below a fixed cutoff, every surviving ordered-subsequence term belongs to one
finite alphabet.  Record only the multiplicity of each alphabet term.  For
supported term lists this vector is complete up to permutation, so the local
bounded-term update descends to a well-defined operator on finite vectors.

Folding those induced operators recovers the exact bounded-term multiplicity
vector of every fixed-alphabet transition schedule, including the positive
and negative Hall-Witt schedules.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace STState

open OFProgra
open STSched
open SSExp
open STAlphab
open STRec

/-- Every word enumerated from a transition alphabet uses only entries of
that alphabet. -/
lemma forall_transition_words
    (alphabet : List SRTrans) :
    ∀ (length : ℕ) (transitions : List SRTrans),
      transitions ∈ transitionWordsLength alphabet length →
        ∀ transition ∈ transitions, transition ∈ alphabet
  | 0, transitions, htransitions => by
      simp [transitionWordsLength] at htransitions
      subst transitions
      simp
  | length + 1, transitions, htransitions => by
      simp only [transitionWordsLength] at htransitions
      rcases List.mem_flatMap.mp htransitions with
        ⟨head, hhead, htransitions⟩
      rcases List.mem_map.mp htransitions with ⟨tail, htail, rfl⟩
      intro transition htransition
      simp only [List.mem_cons] at htransition
      rcases htransition with rfl | htransition
      · exact hhead
      · exact
          forall_transition_words alphabet length tail htail
            transition htransition

/-- Every word in the bounded transition-word enumeration uses only entries
of the source transition alphabet. -/
lemma forall_words_length
    (alphabet : List SRTrans)
    (cutoff : ℕ)
    (transitions : List SRTrans)
    (htransitions : transitions ∈ wordsBelowLength alphabet cutoff) :
    ∀ transition ∈ transitions, transition ∈ alphabet := by
  rcases List.mem_flatMap.mp htransitions with
    ⟨length, _hlength, htransitions⟩
  exact
    forall_transition_words alphabet length transitions
      htransitions

/-- Membership in the fixed bounded-term alphabet implies its structural
support predicate. -/
lemma supported_constant_alphabet
    (cutoff : ℕ)
    (term : OCTerm)
    (hterm : term ∈ boundedConstantAlphabet cutoff) :
    TermSupportedBy cutoff (secondRouteAlphabet cutoff)
      term := by
  rcases List.mem_flatMap.mp hterm with
    ⟨strictTransitions, hstrictTransitions, hterm⟩
  rcases List.mem_map.mp hterm with
    ⟨constantTransition, hconstantTransition, rfl⟩
  exact
    ⟨forall_words_length
        (secondRouteAlphabet cutoff) cutoff
          strictTransitions hstrictTransitions,
      ⟨constantTransition, hconstantTransition, rfl⟩⟩

/-- A structurally supported term with a short strict-transition word belongs
to the fixed bounded-term alphabet. -/
lemma constant_alphabet_supported
    (cutoff : ℕ)
    (term : OCTerm)
    (hlength : term.strictTransitions.length < cutoff)
    (hterm :
      TermSupportedBy cutoff (secondRouteAlphabet cutoff)
        term) :
    term ∈ boundedConstantAlphabet cutoff := by
  rcases hterm with
    ⟨hstrictTransitions,
      ⟨constantTransition, hconstantTransition, hconstant⟩⟩
  apply List.mem_flatMap.mpr
  refine
    ⟨term.strictTransitions,
      words_below_forall
        (secondRouteAlphabet cutoff) cutoff
          term.strictTransitions hlength hstrictTransitions,
      ?_⟩
  apply List.mem_map.mpr
  refine ⟨constantTransition, hconstantTransition, ?_⟩
  cases term with
  | mk strictTransitions constant =>
      simp only at hconstant ⊢
      rw [hconstant]

/-- A bounded-term list is supported when every entry belongs to the fixed
cutoff-dependent bounded-term alphabet. -/
def SCAlphab
    (cutoff : ℕ)
    (terms : List OCTerm) :
    Prop :=
  ∀ term ∈ terms, term ∈ boundedConstantAlphabet cutoff

/-- The empty bounded-term state is supported. -/
lemma supported_alphabet_nil
    (cutoff : ℕ) :
    SCAlphab cutoff [] := by
  intro term hterm
  simp at hterm

/-- One fixed-alphabet transition preserves support of the bounded-term
state. -/
lemma SCAlphab.step
    (cutoff : ℕ)
    (transition : SRTrans)
    (htransition :
      transition ∈ secondRouteAlphabet cutoff)
    (terms : List OCTerm)
    (hterms : SCAlphab cutoff terms) :
    SCAlphab cutoff
      (boundedConstantStep cutoff transition terms) := by
  intro term hterm
  unfold boundedConstantStep at hterm
  simp only [List.mem_append] at hterm
  rcases hterm with (hterm | hterm) | hterm
  · rcases List.mem_filter.mp hterm with ⟨hterm, hlength⟩
    rcases List.mem_map.mp hterm with ⟨previous, hprevious, rfl⟩
    apply
      constant_alphabet_supported
        cutoff
    · exact of_decide_eq_true hlength
    · rcases
          supported_constant_alphabet
            cutoff previous (hterms previous hprevious) with
        ⟨hstrictTransitions, hconstant⟩
      constructor
      · intro next hnext
        simp only [OCTerm.prepend, List.mem_cons] at hnext
        rcases hnext with rfl | hnext
        · exact htransition
        · exact hstrictTransitions next hnext
      · exact hconstant
  · exact hterms term hterm
  · rcases List.mem_filter.mp hterm with ⟨hterm, hlength⟩
    rw [List.mem_singleton] at hterm
    subst term
    apply
      constant_alphabet_supported
        cutoff
    · exact of_decide_eq_true hlength
    · exact ⟨by simp [singletonConstantTerm],
        ⟨transition, htransition, rfl⟩⟩

/-- Folding a fixed-alphabet schedule preserves bounded-term support. -/
lemma SCAlphab.fold
    (cutoff : ℕ) :
    ∀ (transitions : List SRTrans)
      (terms : List OCTerm),
      (∀ transition ∈ transitions,
        transition ∈ secondRouteAlphabet cutoff) →
        SCAlphab cutoff terms →
          SCAlphab cutoff
            (boundedConstantFold cutoff transitions terms)
  | [], terms, _htransitions, hterms => by
      exact hterms
  | transition :: transitions, terms, htransitions, hterms => by
      rw [boundedConstantFold]
      apply SCAlphab.step
      · exact htransitions transition (by simp)
      · apply SCAlphab.fold
        · intro next hnext
          exact htransitions next (by simp [hnext])
        · exact hterms

/-- Every fixed-alphabet schedule has a supported bounded expansion. -/
lemma supported_alphabet_terms
    (cutoff : ℕ)
    (transitions : List SRTrans)
    (htransitions :
      ∀ transition ∈ transitions,
        transition ∈ secondRouteAlphabet cutoff) :
    SCAlphab cutoff
      (boundedConstantTerms cutoff transitions) := by
  intro term hterm
  exact
    constant_alphabet_terms
      cutoff transitions htransitions term hterm

/-- Fixed-alphabet multiplicity vector of one bounded-term list. -/
def boundedConstantVector
    (cutoff : ℕ)
    (terms : List OCTerm) :
    List ℕ :=
  (boundedConstantAlphabet cutoff).map fun term =>
    terms.count term

/-- The bounded-term multiplicity vector has cutoff-dependent fixed length. -/
lemma length_constant_vector
    (cutoff : ℕ)
    (terms : List OCTerm) :
    (boundedConstantVector cutoff terms).length =
      (boundedConstantAlphabet cutoff).length := by
  simp [boundedConstantVector]

/-- Equality of aligned maps gives equality at each listed entry. -/
lemma eq_eq_mem
    {α β : Type*}
    (entries : List α)
    (left right : α → β)
    (hmap : entries.map left = entries.map right)
    (entry : α)
    (hentry : entry ∈ entries) :
    left entry = right entry := by
  induction entries generalizing entry with
  | nil =>
      simp at hentry
  | cons head entries ih =>
      simp only [List.map_cons] at hmap
      injection hmap with hhead htail
      simp only [List.mem_cons] at hentry
      rcases hentry with rfl | hentry
      · exact hhead
      · exact ih htail entry hentry

/-- Equal bounded-term vectors agree on the multiplicity of every alphabet
entry. -/
lemma count_constant_vector
    (cutoff : ℕ)
    (left right : List OCTerm)
    (hvectors :
      boundedConstantVector cutoff left =
        boundedConstantVector cutoff right)
    (term : OCTerm)
    (hterm : term ∈ boundedConstantAlphabet cutoff) :
    left.count term = right.count term := by
  exact
    eq_eq_mem
      (boundedConstantAlphabet cutoff)
      (fun next => left.count next) (fun next => right.count next)
        hvectors term hterm

/-- On supported lists, the fixed bounded-term vector is complete up to
permutation. -/
lemma perm_constant_vector
    (cutoff : ℕ)
    (left right : List OCTerm)
    (hleft : SCAlphab cutoff left)
    (hright : SCAlphab cutoff right)
    (hvectors :
      boundedConstantVector cutoff left =
        boundedConstantVector cutoff right) :
    left.Perm right := by
  rw [List.perm_iff_count]
  intro term
  by_cases hterm : term ∈ boundedConstantAlphabet cutoff
  · exact
      count_constant_vector
        cutoff left right hvectors term hterm
  · have hleftNot : term ∉ left := by
      intro htermLeft
      exact hterm (hleft term htermLeft)
    have hrightNot : term ∉ right := by
      intro htermRight
      exact hterm (hright term htermRight)
    rw [List.count_eq_zero.mpr hleftNot, List.count_eq_zero.mpr hrightNot]

/-- The local bounded-term update respects input permutation. -/
lemma bounded_constant_perm
    (cutoff : ℕ)
    (transition : SRTrans)
    {left right : List OCTerm}
    (hterms : left.Perm right) :
    (boundedConstantStep cutoff transition left).Perm
      (boundedConstantStep cutoff transition right) := by
  unfold boundedConstantStep
  exact
    (((hterms.map (OCTerm.prepend transition)).filter
      (fun term => decide (term.strictTransitions.length < cutoff))).append
        hterms).append
          (List.Perm.refl _)

/-- The local bounded-term vector update depends only on the input vector for
supported states. -/
lemma constant_vector_congr
    (cutoff : ℕ)
    (transition : SRTrans)
    {left right : List OCTerm}
    (hleft : SCAlphab cutoff left)
    (hright : SCAlphab cutoff right)
    (hvectors :
      boundedConstantVector cutoff left =
        boundedConstantVector cutoff right) :
    boundedConstantVector cutoff
        (boundedConstantStep cutoff transition left) =
      boundedConstantVector cutoff
        (boundedConstantStep cutoff transition right) := by
  unfold boundedConstantVector
  apply List.map_congr_left
  intro term _hterm
  exact
    (bounded_constant_perm cutoff transition
      (perm_constant_vector
        cutoff left right hleft hright hvectors)).count_eq term

/-- Choose one supported bounded-term list realizing a vector when one
exists. -/
noncomputable def realizingConstantTerms
    (cutoff : ℕ)
    (vector : List ℕ) :
    List OCTerm := by
  classical
  exact
    if hvector :
        ∃ terms,
          SCAlphab cutoff terms ∧
            boundedConstantVector cutoff terms =
              vector then
      Classical.choose hvector
    else
      []

/-- The chosen realization of a supported vector remains supported. -/
lemma supported_alphabet_realizing
    (cutoff : ℕ)
    (terms : List OCTerm)
    (hterms : SCAlphab cutoff terms) :
    SCAlphab cutoff
      (realizingConstantTerms cutoff
        (boundedConstantVector cutoff terms)) := by
  classical
  rw [realizingConstantTerms]
  split
  next hvector =>
    exact (Classical.choose_spec hvector).1
  next hvector =>
    exact
      False.elim
        (hvector ⟨terms, hterms, rfl⟩)

/-- The chosen realization of a supported vector has the requested vector. -/
lemma constant_vector_realizing
    (cutoff : ℕ)
    (terms : List OCTerm)
    (hterms : SCAlphab cutoff terms) :
    boundedConstantVector cutoff
        (realizingConstantTerms cutoff
          (boundedConstantVector cutoff terms)) =
      boundedConstantVector cutoff terms := by
  classical
  rw [realizingConstantTerms]
  split
  next hvector =>
    exact (Classical.choose_spec hvector).2
  next hvector =>
    exact
      False.elim
        (hvector ⟨terms, hterms, rfl⟩)

/-- One transition induces a deterministic operator on bounded-term
multiplicity vectors. -/
noncomputable def constantTermOperator
    (cutoff : ℕ)
    (transition : SRTrans)
    (vector : List ℕ) :
    List ℕ :=
  boundedConstantVector cutoff
    (boundedConstantStep cutoff transition
      (realizingConstantTerms cutoff vector))

/-- On supported states, the induced transition operator agrees with the
literal bounded-term update. -/
lemma term_operator_vector
    (cutoff : ℕ)
    (transition : SRTrans)
    (terms : List OCTerm)
    (hterms : SCAlphab cutoff terms) :
    constantTermOperator cutoff transition
        (boundedConstantVector cutoff terms) =
      boundedConstantVector cutoff
        (boundedConstantStep cutoff transition terms) := by
  unfold constantTermOperator
  apply constant_vector_congr
  · exact
      supported_alphabet_realizing
        cutoff terms hterms
  · exact hterms
  · exact
      constant_vector_realizing
        cutoff terms hterms

/-- Fold induced transition operators over a schedule. -/
noncomputable def boundedConstantOperator
    (cutoff : ℕ) :
    List SRTrans → List ℕ → List ℕ
  | [], vector =>
      vector
  | transition :: transitions, vector =>
      constantTermOperator cutoff transition
        (boundedConstantOperator cutoff transitions vector)

/-- Induced schedule operators compose across transition-schedule
concatenation. -/
lemma constant_operator_append
    (cutoff : ℕ) :
    ∀ (left right : List SRTrans)
      (vector : List ℕ),
      boundedConstantOperator cutoff (left ++ right)
          vector =
        boundedConstantOperator cutoff left
          (boundedConstantOperator cutoff right vector)
  | [], right, vector => by
      rfl
  | transition :: transitions, right, vector => by
      rw [List.cons_append, boundedConstantOperator,
        boundedConstantOperator,
        constant_operator_append cutoff transitions
          right vector]

/-- On supported states, folding induced transition operators agrees with
the literal bounded-term fold. -/
lemma schedule_operator_vector
    (cutoff : ℕ) :
    ∀ (transitions : List SRTrans)
      (terms : List OCTerm),
      (∀ transition ∈ transitions,
        transition ∈ secondRouteAlphabet cutoff) →
        SCAlphab cutoff terms →
          boundedConstantOperator cutoff transitions
              (boundedConstantVector cutoff terms) =
            boundedConstantVector cutoff
              (boundedConstantFold cutoff transitions terms)
  | [], terms, _htransitions, _hterms => by
      rfl
  | transition :: transitions, terms, htransitions, hterms => by
      rw [boundedConstantOperator,
        schedule_operator_vector cutoff transitions
          terms (fun next hnext => htransitions next (by simp [hnext])) hterms]
      exact
        term_operator_vector cutoff transition
          (boundedConstantFold cutoff transitions terms)
          (SCAlphab.fold
            cutoff transitions terms
              (fun next hnext => htransitions next (by simp [hnext]))
                hterms)

/-- The induced finite-state schedule operator computes the exact vector of
the bounded ordered-subsequence expansion. -/
lemma bounded_operator_vector
    (cutoff : ℕ)
    (transitions : List SRTrans)
    (htransitions :
      ∀ transition ∈ transitions,
        transition ∈ secondRouteAlphabet cutoff) :
    boundedConstantOperator cutoff transitions
        (boundedConstantVector cutoff []) =
      boundedConstantVector cutoff
        (boundedConstantTerms cutoff transitions) := by
  rw [schedule_operator_vector cutoff transitions []
    htransitions (supported_alphabet_nil cutoff)]
  rw [constant_terms_fold]

/-- The positive Hall-Witt schedule is computed exactly by the induced finite
bounded-term state operator. -/
lemma constant_operator_natural
    (cutoff multiplicity : ℕ) :
    boundedConstantOperator cutoff
        (transitionSchedule cutoff
          (naturalRouteProgram cutoff multiplicity))
        (boundedConstantVector cutoff []) =
      boundedConstantVector cutoff
        (boundedConstantTerms cutoff
          (transitionSchedule cutoff
            (naturalRouteProgram cutoff multiplicity))) := by
  apply bounded_operator_vector
  exact
    alphabet_natural_schedule
      cutoff multiplicity

/-- The negative Hall-Witt schedule is computed exactly by the induced finite
bounded-term state operator. -/
lemma constant_operator_negative
    (cutoff multiplicity : ℕ) :
    boundedConstantOperator cutoff
        (transitionSchedule cutoff
          (negativeRouteProgram cutoff multiplicity))
        (boundedConstantVector cutoff []) =
      boundedConstantVector cutoff
        (boundedConstantTerms cutoff
          (transitionSchedule cutoff
            (negativeRouteProgram cutoff multiplicity))) := by
  apply bounded_operator_vector
  exact
    alphabet_negative_schedule
      cutoff multiplicity

end STState
end TCTex
end Submission

