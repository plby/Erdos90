/-- The fixed symbolic three-head Jacobi packet. -/
def headSource
    {d inputWeight : ℕ}
    {x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d))}
    {coefficient : ℕ → ℤ}
    (head :
      CHExp
        (inputWeight := inputWeight) x y z coefficient) :
    List
      (SPFactora
        (concreteBasicCommutators.{u} d) inputWeight) :=
  SPFactora.inverseList
      (head.originalExpansion.symbolicPowerFactors
        (addressJacobiOriginal x y z)) ++
    head.firstExpansion.symbolicPowerFactors
        (exponentAddressJacobi x y z) ++
      SPFactora.inverseList
        (head.secondExpansion.symbolicPowerFactors
          (addressJacobiSecond x y z))

/-- The fixed three-head packet evaluates exactly to the complete strict trace. -/
lemma head_full_trace
    {d n inputWeight : ℕ}
    {x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d))}
    {coefficient : ℕ → ℤ}
    (head :
      CHExp
        (inputWeight := inputWeight) x y z coefficient)
    (hx : ∃ left right, x = .commutator left right)
    (hy : ∃ left right, y = .commutator left right)
    (hz : ∃ left right, z = .commutator left right)
    (q : ℕ) :
    SPFactora.listEval (n := n) q head.headSource =
      wordListEval
        (PEAddres.freeLowerTruncation
          (n := n))
        (signedStrictTrace x y z (coefficient q)) := by
  rw [headSource, SPFactora.listEval_append,
    SPFactora.listEval_append,
    SPFactora.list_eval_inverse,
    SPFactora.list_eval_inverse,
    BCExp.list_power_factors,
    BCExp.list_power_factors,
    BCExp.list_power_factors,
    congrFun head.eval_originalExpansion q,
    congrFun head.eval_firstExpansion q,
    congrFun head.eval_secondExpansion q,
    signed_strict_trace
      (PEAddres.freeLowerTruncation (n := n))
        x y z hx hy hz (coefficient q)]
  simp only [addressJacobiOriginal,
    exponentAddressJacobi, addressJacobiSecond]
  rw [← inv_zpow, ← inv_zpow, mul_assoc]

/-- Every factor emitted for one head word retains that head word. -/
private lemma least_symbolic_factors
    {d inputWeight lowerWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (word : CWord (HEAddres H))
    (hword :
      lowerWeight ≤ word.weight PEAddres.weight)
    (expansion :
      BCExp inputWeight
        (word.weight PEAddres.weight)) :
    SPFactora.WordWeightLeast lowerWeight
      (expansion.symbolicPowerFactors word) := by
  intro factor hfactor
  rw [BCExp.symbolic_power_factors
    word expansion hfactor]
  exact hword

/-- Every factor emitted for one head word is physically truncated with it. -/
private lemma truncated_power_factors
    {d n inputWeight : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (word : CWord (HEAddres H))
    (hword : word.weight PEAddres.weight < n)
    (expansion :
      BCExp inputWeight
        (word.weight PEAddres.weight)) :
    SPFactora.IsTruncated n
      (expansion.symbolicPowerFactors word) := by
  intro factor hfactor
  rw [BCExp.symbolic_power_factors
    word expansion hfactor]
  exact hword

/-- The fixed head packet is supported in its parent Hall layer. -/
lemma least_head_source
    {d inputWeight : ℕ}
    {x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d))}
    {coefficient : ℕ → ℤ}
    (head :
      CHExp
        (inputWeight := inputWeight) x y z coefficient) :
    SPFactora.WordWeightLeast
      (exponentAddressParent x y z) head.headSource := by
  intro factor hfactor
  rw [headSource] at hfactor
  rcases List.mem_append.mp hfactor with hfactor | hfactor
  · rcases List.mem_append.mp hfactor with hfactor | hfactor
    · exact
        SPFactora.least_inverse_list
          (least_symbolic_factors
            (addressJacobiOriginal x y z) (by simp)
              head.originalExpansion)
          factor hfactor
    · exact
        least_symbolic_factors
          (exponentAddressJacobi x y z) (by simp)
            head.firstExpansion factor hfactor
  · exact
      SPFactora.least_inverse_list
        (least_symbolic_factors
          (addressJacobiSecond x y z) (by simp)
            head.secondExpansion)
        factor hfactor

/-- A below-cutoff parent layer physically truncates the fixed head packet. -/
lemma truncated_head_source
    {d n inputWeight : ℕ}
    {x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d))}
    {coefficient : ℕ → ℤ}
    (head :
      CHExp
        (inputWeight := inputWeight) x y z coefficient)
    (hparent :
      exponentAddressParent x y z < n) :
    SPFactora.IsTruncated n head.headSource := by
  intro factor hfactor
  rw [headSource] at hfactor
  rcases List.mem_append.mp hfactor with hfactor | hfactor
  · rcases List.mem_append.mp hfactor with hfactor | hfactor
    · exact
        SPFactora.truncated_inverse_list
          (truncated_power_factors
            (addressJacobiOriginal x y z) (by simpa)
              head.originalExpansion)
          factor hfactor
    · exact
        truncated_power_factors
          (exponentAddressJacobi x y z) (by simpa)
            head.firstExpansion factor hfactor
  · exact
      SPFactora.truncated_inverse_list
        (truncated_power_factors
          (addressJacobiSecond x y z) (by simpa)
            head.secondExpansion)
        factor hfactor

/--
A bounded polynomial coefficient function supplies a physical parent-layer
head expansion by Newton normalization.
-/
noncomputable def ofPolynomial
    {d inputWeight : ℕ}
    {x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d))}
    {coefficient : ℕ → ℤ}
    (hinputWeight : 0 < inputWeight)
    (hpolynomial :
      IVMost coefficient
        (exponentAddressParent x y z / inputWeight)) :
    CHExp
      (inputWeight := inputWeight) x y z coefficient where
  expansion :=
    BCExp.binomialBasis inputWeight
      (exponentAddressParent x y z)
      hinputWeight coefficient
  eval_expansion :=
    BCExp.eval_binomialBasis hinputWeight hpolynomial

end CHExp

namespace TWSrc

/--
Normalize the fixed parent-layer Hall-Witt head packet and discard its
vanishing active block.  The result is an exact strict-trace source supported
one layer higher.
-/
noncomputable def headExpansionNormalizer
    {d n inputWeight : ℕ}
    {x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d))}
    {coefficient : ℕ → ℤ}
    (hn : 2 ≤ n)
    (hx : ∃ left right, x = .commutator left right)
    (hy : ∃ left right, y = .commutator left right)
    (hz : ∃ left right, z = .commutator left right)
    (hparent :
      exponentAddressParent x y z + 1 < n)
    (head :
      CHExp
        (inputWeight := inputWeight) x y z coefficient)
    (normalizer :
      TSNormalb
        (n := n) (inputWeight := inputWeight)
        (lowerWeight := exponentAddressParent x y z)
        (concreteBasicCommutators.{u} d)) :
    TWSrc
      (n := n) (inputWeight := inputWeight) x y z coefficient := by
  have hparentPos :
      1 ≤ exponentAddressParent x y z := by
    have hxWeight :
        0 < x.weight PEAddres.weight :=
      CWord.weight_pos
        PEAddres.weight PEAddres.weight_pos x
    have hyWeight :
        0 < y.weight PEAddres.weight :=
      CWord.weight_pos
        PEAddres.weight PEAddres.weight_pos y
    have hzWeight :
        0 < z.weight PEAddres.weight :=
      CWord.weight_pos
        PEAddres.weight PEAddres.weight_pos z
    simp only [exponentAddressParent]
    omega
  let recollection :=
    normalizer.source_recollection_series hn
      (concreteBasicCommutators.{u} d)
      (fun s hs hsn =>
        concrete_forms_associated d n s hs hsn)
      head.headSource hparentPos (by omega)
      (head.truncated_head_source (by omega))
      head.least_head_source
      (by
        intro q
        rw [head.head_full_trace hx hy hz q]
        exact
          signed_strict_series
            x y z (coefficient q))
  exact
    {
      source := recollection.higherSource
      source_isTruncated := recollection.higher_source_truncated
      source_weight_least := by
        simpa only [Nat.add_assoc] using
          recollection.higher_weight_least
      list_full_trace := by
        intro q
        rw [recollection.list_higher_raw,
          head.head_full_trace hx hy hz q]
    }

/--
Polynomial normalization of the coefficient function feeds the fixed-head
strict-trace compiler directly.
-/
noncomputable def headCoefficientNormalizer
    {d n inputWeight : ℕ}
    {x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d))}
    {coefficient : ℕ → ℤ}
    (hn : 2 ≤ n)
    (hx : ∃ left right, x = .commutator left right)
    (hy : ∃ left right, y = .commutator left right)
    (hz : ∃ left right, z = .commutator left right)
    (hparent :
      exponentAddressParent x y z + 1 < n)
    (hinputWeight : 0 < inputWeight)
    (hpolynomial :
      IVMost coefficient
        (exponentAddressParent x y z / inputWeight))
    (normalizer :
      TSNormalb
        (n := n) (inputWeight := inputWeight)
        (lowerWeight := exponentAddressParent x y z)
        (concreteBasicCommutators.{u} d)) :
    TWSrc
      (n := n) (inputWeight := inputWeight) x y z coefficient :=
  headExpansionNormalizer hn hx hy hz hparent
    (CHExp.ofPolynomial
      hinputWeight hpolynomial)
    normalizer

/--
The parent-layer normalizer and both physical polynomial estimates compile
all the way to the residual-source certificate consumed by next-layer
recollection.
-/
noncomputable def coordPolyBounds
    {d n inputWeight : ℕ}
    {x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d))}
    {coefficient : ℕ → ℤ}
    (hn : 2 ≤ n)
    (hx : ∃ left right, x = .commutator left right)
    (hy : ∃ left right, y = .commutator left right)
    (hz : ∃ left right, z = .commutator left right)
    (hparent :
      exponentAddressParent x y z + 1 < n)
    (hinputWeight : 0 < inputWeight)
    (hheadPolynomial :
      IVMost coefficient
        (exponentAddressParent x y z / inputWeight))
    (hcoordinatePolynomial :
      ∀ i : AddressParentIndex d x y z,
        IVMost
          (fun q : ℕ =>
            concreteAddressCoordinates
              d n x y z n (coefficient q) hparent i)
          ((exponentAddressParent x y z + 1) /
            inputWeight))
    (normalizer :
      TSNormalb
        (n := n) (inputWeight := inputWeight)
        (lowerWeight := exponentAddressParent x y z)
        (concreteBasicCommutators.{u} d)) :
    TWSrca
      (inputWeight := inputWeight) x y z hparent coefficient :=
  (headCoefficientNormalizer hn hx hy hz hparent hinputWeight
    hheadPolynomial normalizer).residualCoordinateBounds
      hinputWeight hcoordinatePolynomial

end TWSrc

