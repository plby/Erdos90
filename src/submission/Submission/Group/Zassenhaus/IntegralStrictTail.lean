    (wt : β → ℕ)
    (hwt : ∀ atom, 0 < wt atom)
    (x y z : CWord β)
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (coefficient : ℤ)
    (word : CWord β)
