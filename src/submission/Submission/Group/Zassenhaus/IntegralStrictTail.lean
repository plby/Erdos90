                d n x y z hparent) i
              (TBluepr.lowerCentralClass
                (exponentAddressParent x y z)
                (addressBelowTerms
                  (n := n) x y z cutoff (Int.negSucc magnitude)).prod) := by
  unfold
    addressParentVector
  rw [List.map_map]
  apply List.map_congr_left
  intro i _hi
  rw [Function.comp_apply,
