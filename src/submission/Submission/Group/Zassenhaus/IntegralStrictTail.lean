    (cutoff inputWeight : ℕ)
    (hcutoff : 3 < cutoff)
    (hinputWeight : 0 < inputWeight)
    (hx : inputWeight ≤ x.weight PEAddres.weight)
    (hy : inputWeight ≤ y.weight PEAddres.weight)
    (hz : inputWeight ≤ z.weight PEAddres.weight)
