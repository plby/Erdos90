/-!
# Literal semantics for triangular strict-depth subsequence states

The triangular predecessor parser has a direct finite-word semantics.  A
source depth emits a nonempty local selection from `[depth + 1, depth]`.
The resulting ordered target multiplicity is the transpose coordinate of the
inverse predecessor parser.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace DSSem

open BSPoly
open DSRec

/-- Nonempty ordered outputs of unfiltered strict-depth packets, extended
across an ordered predecessor word. -/
def strictPatternExpansions :
    List ℕ → List (List ℕ)
  | [] =>
      [[]]
  | depth :: depths =>
      (strictPatternExpansions depths).map (fun suffix =>
          (depth + 1) :: suffix)
        ++
      (strictPatternExpansions depths).map (fun suffix =>
          depth :: suffix)
        ++
      (strictPatternExpansions depths).map (fun suffix =>
          (depth + 1) :: depth :: suffix)

/-- Counting after prepending one fixed entry to every listed word. -/
lemma count_map_cons
    (head : ℕ)
    (words : List (List ℕ)) :
    ∀ target : List ℕ,
      (words.map fun word => head :: word).count target =
        match target with
        | [] =>
            0
        | targetHead :: targetTail =>
            if targetHead = head then
              words.count targetTail
            else
              0
  | [] => by
      apply List.count_eq_zero.mpr
      simp
  | targetHead :: targetTail => by
      simp only
      by_cases hhead : targetHead = head
      · rw [if_pos hhead]
        subst targetHead
        rw [List.count_map_of_injective words (fun word => head :: word)]
        intro left right heq
        exact (List.cons.inj heq).2
      · rw [if_neg hhead]
        apply List.count_eq_zero.mpr
        intro htarget
        rcases List.mem_map.mp htarget with ⟨word, _hword, heq⟩
        exact hhead (List.cons.inj heq).1.symm

/-- Counting after prepending two fixed entries to every listed word. -/
lemma map_cons_cons
    (first second : ℕ)
    (words : List (List ℕ)) :
    ∀ target : List ℕ,
      (words.map fun word => first :: second :: word).count target =
        match target with
        | [] =>
            0
        | [_targetHead] =>
            0
        | targetHead :: targetSecond :: targetTail =>
            if targetHead = first ∧ targetSecond = second then
              words.count targetTail
            else
              0
  | [] => by
      apply List.count_eq_zero.mpr
      simp
  | [_targetHead] => by
      apply List.count_eq_zero.mpr
      simp
  | targetHead :: targetSecond :: targetTail => by
      simp only
      by_cases hhead :
          targetHead = first ∧ targetSecond = second
      · rw [if_pos hhead]
        rcases hhead with ⟨rfl, rfl⟩
        rw [List.count_map_of_injective words
          (fun word => targetHead :: targetSecond :: word)]
        intro left right heq
        exact (List.cons.inj (List.cons.inj heq).2).2
      · rw [if_neg hhead]
        apply List.count_eq_zero.mpr
        intro htarget
        rcases List.mem_map.mp htarget with ⟨word, _hword, heq⟩
        exact
          hhead
            ⟨(List.cons.inj heq).1.symm,
              (List.cons.inj (List.cons.inj heq).2).1.symm⟩

@[simp]
lemma nil_cons
    (head : ℕ)
    (words : List (List ℕ)) :
    (words.map fun word => head :: word).count [] =
      0 :=
  count_map_cons head words []

@[simp]
lemma count_nil_cons
    (first second : ℕ)
    (words : List (List ℕ)) :
    (words.map fun word => first :: second :: word).count [] =
      0 :=
  map_cons_cons first second words []

lemma count_cons_singleton
    (sourceHead : ℕ)
    (sourceTail : List ℕ)
    (head : ℕ) :
    [[head]].count (sourceHead :: sourceTail) =
      if sourceHead = head then
        [[]].count sourceTail
      else
        0 := by
  simpa using
    count_map_cons head [[]] (sourceHead :: sourceTail)

lemma strict_patterns_nil :
    strictPredecessorPatterns [] =
      [[]] := by
  rw [strictPredecessorPatterns.eq_def]

/-- A nonempty target cannot have the empty word as a packet predecessor. -/
lemma predecessor_patterns_cons
    (targetHead : ℕ)
    (targetTail : List ℕ) :
    [] ∉ strictPredecessorPatterns (targetHead :: targetTail) := by
  rw [strictPredecessorPatterns.eq_def]
  simp only
  cases targetTail <;> simp

/-- Forward nonempty packet selections and inverse predecessor parsing have
the same duplicate-preserving multiplicities. -/
lemma pattern_predecessor_patterns :
    ∀ (previous target : List ℕ),
      (strictPatternExpansions previous).count target =
        (strictPredecessorPatterns target).count previous
  | [], [] => by
      rfl
  | [], targetHead :: targetTail => by
      simp [strictPatternExpansions,
        List.count_eq_zero.mpr
          (predecessor_patterns_cons
            targetHead targetTail)]
  | _depth :: _depths, [] => by
      simp [strictPatternExpansions,
        strict_patterns_nil,
        count_map_cons, map_cons_cons]
  | depth :: depths, targetHead :: targetTail => by
      cases targetTail with
      | nil =>
          rw [strictPredecessorPatterns.eq_def]
          simp only
          simp only [strictPatternExpansions]
          simp only [List.count_append, count_map_cons,
            map_cons_cons, List.count_nil]
          simp only [
            pattern_predecessor_patterns
              depths [],
            strict_patterns_nil]
          by_cases htargetHead : 0 < targetHead
          · have hstrict :
                (depth = targetHead - 1) ↔ targetHead = depth + 1 := by
              omega
            rw [if_pos htargetHead]
            rw [count_map_cons]
            simp [hstrict, eq_comm] ; omega
          · have hzero : targetHead = 0 := by
              omega
            simp [hzero, eq_comm]
      | cons targetSecond targetRest =>
          rw [strictPredecessorPatterns.eq_def]
          simp only
          simp only [strictPatternExpansions]
          simp only [List.count_append, count_map_cons,
            map_cons_cons]
          simp only [
            pattern_predecessor_patterns
              depths (targetSecond :: targetRest),
            pattern_predecessor_patterns
              depths targetRest,
            ]
          by_cases htargetHead : 0 < targetHead
          · have hstrict :
                (depth = targetHead - 1) ↔ targetHead = depth + 1 := by
              omega
            by_cases hdouble : targetHead = targetSecond + 1
            · by_cases hsource : depth = targetSecond
              · simp [hdouble, hsource,
                  eq_comm]
              · have hnotSelection :
                    ¬(targetHead = depth + 1 ∧ targetSecond = depth) := by
                  omega
                simp [hdouble, hsource,
                  count_map_cons, eq_comm]
            · have hnotSelection :
                  ¬(targetHead = depth + 1 ∧ targetSecond = depth) := by
                omega
              have hnotSelection' :
                  ¬(targetHead = depth + 1 ∧ depth = targetSecond) := by
                omega
              simp [htargetHead, hstrict, hdouble,                 hnotSelection',
                count_map_cons, eq_comm] ; omega
          · have hzero : targetHead = 0 := by
              omega
            simp [hzero, eq_comm]
termination_by previous target => previous.length + target.length

/-- Counting one target after flattening a list of finite expansions is the
sum of its counts in the individual expansions. -/
lemma count_flat_sum
    {α β : Type*} [BEq β] [LawfulBEq β]
    (expansions : α → List β)
    (target : β) :
    ∀ sources : List α,
      (sources.flatMap expansions).count target =
        (sources.map fun source =>
          (expansions source).count target).sum
  | [] => by
      rfl
  | source :: sources => by
      rw [List.flatMap_cons, List.count_append, List.map_cons,
        List.sum_cons, count_flat_sum expansions target sources]

/-- Summing pairwise list multiplicities can be exchanged between the two
finite lists. -/
lemma sum_beq_count
    {α : Type*} [BEq α] [LawfulBEq α]
    (item : α) :
    ∀ right : List α,
      (right.map fun previous =>
        if item == previous then 1 else 0).sum =
          right.count item
  | [] => by
      rfl
  | previous :: previouses => by
      rw [List.map_cons, List.sum_cons, List.count_cons,
        sum_beq_count item previouses]
      have hbeq :
          (item == previous) =
            (previous == item) := by
        apply beq_eq_beq.mpr
        constructor <;> intro h <;> exact h.symm
      rw [← hbeq]
      exact Nat.add_comm _ _

lemma sum_count_comm
    {α : Type*} [BEq α] [LawfulBEq α] :
    ∀ (left right : List α),
      (left.map fun item => right.count item).sum =
        (right.map fun item => left.count item).sum
  | [], right => by
      simp
  | item :: items, right => by
      rw [List.map_cons, List.sum_cons, sum_count_comm items right]
      simp_rw [List.count_cons]
      rw [List.sum_map_add, sum_beq_count]
      exact Nat.add_comm _ _

/-- Expanding every selected predecessor pattern and then counting one
target is the sum of the literal predecessor-pattern coordinates requested
by the inverse parser. -/
lemma pattern_expansions_predecessors
    (source target : List ℕ) :
    (source.sublists.flatMap strictPatternExpansions).count target =
      ((strictPredecessorPatterns target).map fun previous =>
        source.sublists.count previous).sum := by
  rw [count_flat_sum]
  simp_rw [
    pattern_predecessor_patterns]
  exact
    sum_count_comm source.sublists
      (strictPredecessorPatterns target)

/-- Literal ordered-subsequence count state of one source depth word. -/
def literalSubsequenceState
    (source : List ℕ) :
    StrictSubsequenceState :=
  fun target =>
    source.sublists.count target

/-- Count state obtained by expanding each selected source pattern through
the unfiltered strict-depth packet. -/
def expandedSubsequenceState
    (source : List ℕ) :
    StrictSubsequenceState :=
  fun target =>
    (source.sublists.flatMap strictPatternExpansions).count target

/-- Casting a finite sum of natural multiplicities to integers agrees with
summing their individual casts. -/
lemma int_cast_count
    (patterns sources : List (List ℕ)) :
    (((patterns.map fun pattern => sources.count pattern).sum : ℕ) : ℤ) =
      (patterns.map fun pattern => (sources.count pattern : ℤ)).sum := by
  induction patterns with
  | nil =>
      rfl
  | cons pattern patterns ih =>
      rw [List.map_cons, List.sum_cons, List.map_cons, List.sum_cons,
        Nat.cast_add, ih]

/-- Pattern expansion is exactly one triangular predecessor-state step. -/
lemma expanded_subsequence_state
    (source : List ℕ) :
    expandedSubsequenceState source =
      strictSubsequenceState
        (literalSubsequenceState source) := by
  funext target
  unfold expandedSubsequenceState
    strictSubsequenceState
    literalSubsequenceState
  rw [← int_cast_count]
  exact_mod_cast
    pattern_expansions_predecessors source target

/-- Four ordered local packet choices applied to a list of suffix words. -/
def strictExpansionStep
    (depth : ℕ)
    (words : List (List ℕ)) :
    List (List ℕ) :=
  words ++
    words.map (fun word => (depth + 1) :: word) ++
      words.map (fun word => depth :: word) ++
        words.map (fun word => (depth + 1) :: depth :: word)

/-- Flattening pointwise singleton lists is ordinary mapping. -/
lemma flat_singleton
    {α β : Type*}
    (items : List α)
    (f : α → β) :
    (items.flatMap fun item => [f item]) =
      items.map f := by
  induction items with
  | nil =>
      rfl
  | cons item items ih =>
      rw [List.flatMap_cons, List.map_cons, ih]
      rfl

/-- Flattening four pointwise local choices is a permutation of the grouped
four-block expansion step. -/
lemma flat_choices_perm
    (depth : ℕ)
    (words : List (List ℕ)) :
    List.Perm
      (words.flatMap fun word =>
        [word, (depth + 1) :: word, depth :: word,
          (depth + 1) :: depth :: word])
      (strictExpansionStep depth words) := by
  calc
    List.Perm _
        (words.map id ++
          words.flatMap (fun word =>
              [(depth + 1) :: word, depth :: word,
                (depth + 1) :: depth :: word])) :=
      (List.map_append_flatMap_perm words id
        (fun word =>
          [(depth + 1) :: word, depth :: word,
            (depth + 1) :: depth :: word])).symm
    List.Perm _
        (words.map id ++
          (words.map (fun word => (depth + 1) :: word) ++
            words.flatMap (fun word =>
              [depth :: word, (depth + 1) :: depth :: word]))) :=
      ((List.map_append_flatMap_perm words
        (fun word => (depth + 1) :: word)
        (fun word =>
          [depth :: word, (depth + 1) :: depth :: word])).symm).append_left _
    List.Perm _
        (words.map id ++
          (words.map (fun word => (depth + 1) :: word) ++
            (words.map (fun word => depth :: word) ++
              words.flatMap (fun word =>
                [(depth + 1) :: depth :: word])))) :=
      (((List.map_append_flatMap_perm words
        (fun word => depth :: word)
        (fun word => [(depth + 1) :: depth :: word])).symm).append_left _).append_left _
    _ = strictExpansionStep depth words := by
      rw [flat_singleton]
      simp [strictExpansionStep]

/-- The grouped expansion step preserves permutations of its suffix-word
input. -/
lemma strict_expansion_perm
    (depth : ℕ)
    {left right : List (List ℕ)}
    (hwords : List.Perm left right) :
    List.Perm
      (strictExpansionStep depth left)
      (strictExpansionStep depth right) := by
  simpa [strictExpansionStep, List.append_assoc] using
    hwords.append
      ((hwords.map fun word => (depth + 1) :: word).append
        ((hwords.map fun word => depth :: word).append
          (hwords.map fun word => (depth + 1) :: depth :: word)))

/-- Selected-pattern expansion of a source word. -/
def selectedPatternExpansions
    (source : List ℕ) :
    List (List ℕ) :=
  source.sublists.flatMap strictPatternExpansions

/-- Adding one source depth applies the grouped four-choice expansion step
up to permutation. -/
lemma selected_pattern_perm
    (depth : ℕ)
    (depths : List ℕ) :
    List.Perm
      (selectedPatternExpansions (depth :: depths))
      (strictExpansionStep depth
        (selectedPatternExpansions depths)) := by
  unfold selectedPatternExpansions
  refine
    ((List.sublists_cons_perm_append depth depths).flatMap_right
      strictPatternExpansions).trans ?_
  simp only [List.flatMap_append, List.flatMap_map,
    strictPatternExpansions, List.map_flatMap,
    strictExpansionStep]
  have hfirst :=
    (List.flatMap_append_perm depths.sublists
      (fun a =>
        List.map (fun suffix => (depth + 1) :: suffix)
          (strictPatternExpansions a))
      (fun a =>
        List.map (fun suffix => depth :: suffix)
            (strictPatternExpansions a) ++
          List.map (fun suffix => (depth + 1) :: depth :: suffix)
            (strictPatternExpansions a))).symm
  have hsecond :=
    (List.flatMap_append_perm depths.sublists
      (fun a =>
        List.map (fun suffix => depth :: suffix)
          (strictPatternExpansions a))
      (fun a =>
        List.map (fun suffix => (depth + 1) :: depth :: suffix)
          (strictPatternExpansions a))).symm
  simpa [List.append_assoc] using
    (hfirst.trans ((List.Perm.refl _).append hsecond)).append_left
      (depths.sublists.flatMap strictPatternExpansions)

/-- Literal subsequences of one unfiltered strict packet followed by a suffix
word are the grouped four-choice expansion step, up to permutation. -/
lemma sublists_unfiltered_perm
    (depth : ℕ)
    (suffix : List ℕ) :
    List.Perm
      (([depth + 1, depth] ++ suffix).sublists)
      (strictExpansionStep depth suffix.sublists) := by
  rw [List.sublists_append]
  simpa using
    flat_choices_perm
      depth suffix.sublists

/-- Selected-pattern expansion enumerates literal subsequences of the
unfiltered flattened strict-depth substitution, with multiplicity. -/
lemma pattern_sublists_flat :
    ∀ source : List ℕ,
      List.Perm
        (selectedPatternExpansions source)
        ((source.flatMap fun depth => [depth + 1, depth]).sublists)
  | [] => by
      rfl
  | depth :: depths => by
      calc
        List.Perm (selectedPatternExpansions (depth :: depths))
            (strictExpansionStep depth
              (selectedPatternExpansions depths)) :=
          selected_pattern_perm depth depths
        List.Perm _
            (strictExpansionStep depth
              ((depths.flatMap fun depth => [depth + 1, depth]).sublists)) :=
          strict_expansion_perm depth
            (pattern_sublists_flat depths)
        List.Perm _
            ([depth + 1, depth] ++
              (depths.flatMap fun depth => [depth + 1, depth])).sublists :=
          (sublists_unfiltered_perm depth
            (depths.flatMap fun depth => [depth + 1, depth])).symm
        _ =
            ((depth :: depths).flatMap fun depth =>
              [depth + 1, depth]).sublists := by
          rfl

/-- Literal ordered-subsequence states transform by the triangular parser
under the unfiltered strict-depth substitution. -/
lemma literal_flat_unfiltered
    (source : List ℕ) :
    literalSubsequenceState
        (source.flatMap fun depth => [depth + 1, depth]) =
      strictSubsequenceState
        (literalSubsequenceState source) := by
  rw [← expanded_subsequence_state]
  funext target
  unfold literalSubsequenceState
    expandedSubsequenceState
  exact_mod_cast
    (pattern_sublists_flat
      source).count_eq target |>.symm

/-- Ordered subsequence multiplicities after prepending one source entry. -/
lemma count_sublists_cons
    (item : ℕ)
    (source target : List ℕ) :
    (item :: source).sublists.count target =
      source.sublists.count target +
        match target with
        | [] =>
            0
        | targetHead :: targetTail =>
            if targetHead = item then
              source.sublists.count targetTail
            else
              0 := by
  rw [(List.sublists_cons_perm_append item source).count_eq target,
    List.count_append]
  cases target with
  | nil =>
      simp
  | cons targetHead targetTail =>
      rw [count_map_cons]

/-- Removing source entries rejected by a predicate does not change the
multiplicity of a target word whose entries all satisfy that predicate. -/
lemma count_sublists_filter
    (predicate : ℕ → Bool)
    (target : List ℕ)
    (htarget :
      ∀ item ∈ target,
        predicate item = true) :
    ∀ source : List ℕ,
      (source.filter predicate).sublists.count target =
        source.sublists.count target
  | [] => by
      rfl
  | item :: source => by
      cases hitem : predicate item with
      | false =>
          rw [List.filter_cons_of_neg (by simp [hitem]),
            count_sublists_cons,
            count_sublists_filter predicate target htarget source]
          cases target with
          | nil =>
              rfl
          | cons targetHead targetTail =>
              by_cases htargetHead : targetHead = item
              · subst targetHead
                have := htarget item (by simp)
                simp [hitem] at this
              · simp only
                simp [htargetHead]
      | true =>
          rw [List.filter_cons_of_pos hitem,
            count_sublists_cons, count_sublists_cons,
            count_sublists_filter predicate target htarget source]
          cases target with
          | nil =>
              rfl
          | cons targetHead targetTail =>
              simp only
              by_cases htargetHead : targetHead = item
              · rw [if_pos htargetHead, if_pos htargetHead]
                apply congrArg
                apply count_sublists_filter predicate targetTail
                intro tailItem htailItem
                exact htarget tailItem (by simp [htailItem])
              · simp [htargetHead]

/-- Flattening bounded strict-depth packets is filtering the unfiltered
binary strict-depth substitution. -/
lemma flat_strict_filter
    (cutoff : ℕ) :
    ∀ source : List ℕ,
      source.flatMap (strictStepPacket cutoff) =
        (source.flatMap fun depth => [depth + 1, depth]).filter
          fun depth => decide (depth < cutoff)
  | [] => by
      rfl
  | depth :: depths => by
      rw [List.flatMap_cons, List.flatMap_cons,
        List.filter_append,
        flat_strict_filter cutoff depths]
      rfl

/-- Every bounded target coordinate sees the filtered strict-depth
substitution as the same triangular parser-state step. -/
lemma literal_subsequence_flat
    (cutoff : ℕ)
    (source target : List ℕ)
    (htarget :
      ∀ depth ∈ target,
        depth < cutoff) :
    literalSubsequenceState
        (source.flatMap (strictStepPacket cutoff)) target =
      strictSubsequenceState
        (literalSubsequenceState source) target := by
  rw [flat_strict_filter]
  rw [show
    literalSubsequenceState
        ((source.flatMap fun depth => [depth + 1, depth]).filter
          fun depth => decide (depth < cutoff)) target =
      literalSubsequenceState
        (source.flatMap fun depth => [depth + 1, depth]) target by
    unfold literalSubsequenceState
    exact_mod_cast
      count_sublists_filter
        (fun depth => decide (depth < cutoff))
        target
        (by
          intro depth hdepth
          simp [htarget depth hdepth])
        (source.flatMap fun depth => [depth + 1, depth])]
  exact
    congrFun
      (literal_flat_unfiltered
        source)
      target

end DSSem
end TCTex
