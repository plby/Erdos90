/-!
# Signed seed recovery for the successor-repeated nested suffix

The nested suffix repeats a dynamic transition block `steps + 1` times.
Regrouping a requested transition subsequence by its nonempty active copies
introduces a factor `choose (steps + 1) activeCopies`.  At formal predecessor
input `-1`, every positive-active-copy term vanishes.  Only the zero-copy
empty-subsequence seed survives.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace SSRecova

open WSTrace
open TACompos
open STSched
open BTRepeat
open BSRec
open ASTri
open DDRepeat
open SSSched
open NDRepeat
open CSFold

/-- If an explicit polynomial witness vanishes at `-1`, then its truncated
signed Newton evaluation vanishes as well. -/
lemma newton_evaluation_neg
    (degreeBound : ℕ)
    (family : ℕ → ℤ)
    (P : Polynomial ℚ)
    (hdegree : P.natDegree ≤ degreeBound)
    (heval : ∀ steps : ℕ, P.eval (steps : ℚ) = (family steps : ℚ))
    (hnegOne : P.eval (-1) = 0) :
    newtonSignedEvaluation degreeBound family = 0 := by
  have hcanonical :
      P = natBinomialExpansion family degreeBound :=
    polynomial_binomial_expansion P hdegree heval
  have hneg :=
    congrArg (fun Q : Polynomial ℚ => Q.eval (-1)) hcanonical
  change P.eval (-1) =
    (natBinomialExpansion family degreeBound).eval (-1) at hneg
  rw [hnegOne, binomial_expansion_neg] at hneg
  unfold newtonSignedEvaluation
  exact_mod_cast hneg.symm

/-- A successor-shifted positive binomial factor annihilates signed Newton
evaluation at formal predecessor input `-1`. -/
lemma newton_evaluation_pos
    (largerBound k familyDegree : ℕ)
    (hk : 0 < k)
    (hdegree : k + familyDegree ≤ largerBound)
    (family : ℕ → ℤ)
    (hfamily :
      IVMost family familyDegree) :
    newtonSignedEvaluation largerBound
        (fun steps : ℕ => ((steps + 1).choose k : ℤ) * family steps) =
      0 := by
  rcases hfamily with ⟨P, hPdegree, hPeval⟩
  let shift : Polynomial ℚ := Polynomial.X + Polynomial.C 1
  let Q : Polynomial ℚ := (natChoosePolynomial k).comp shift * P
  apply
    newton_evaluation_neg largerBound
      (fun steps : ℕ => ((steps + 1).choose k : ℤ) * family steps) Q
  · dsimp [Q]
    refine Polynomial.natDegree_mul_le.trans ?_
    have hshift : shift.natDegree ≤ 1 := by
      dsimp [shift]
      rw [Polynomial.natDegree_X_add_C]
    have hcomp : ((natChoosePolynomial k).comp shift).natDegree ≤ k := by
      apply Polynomial.natDegree_comp_le.trans
      calc
        (natChoosePolynomial k).natDegree * shift.natDegree ≤ k * 1 :=
          Nat.mul_le_mul (degree_choose_polynomial k) hshift
        _ = k := by simp
    exact (Nat.add_le_add hcomp hPdegree).trans hdegree
  · intro steps
    dsimp [Q]
    rw [Polynomial.eval_mul, Polynomial.eval_comp]
    rw [show shift.eval (steps : ℚ) = ((steps + 1 : ℕ) : ℚ) by
        dsimp [shift]
        simp]
    rw [eval_nat_choose, hPeval]
    norm_cast
  · dsimp [Q, shift]
    rw [Polynomial.eval_mul, Polynomial.eval_comp]
    rw [show
      Polynomial.eval (-1 : ℚ)
          (Polynomial.X + Polynomial.C (1 : ℚ)) =
        0 by
      norm_num]
    have hchoose : (natChoosePolynomial k).eval (0 : ℚ) = 0 := by
      calc
        (natChoosePolynomial k).eval (0 : ℚ) =
            (natChoosePolynomial k).eval ((0 : ℕ) : ℚ) := by
              norm_num
        _ = (Nat.choose 0 k : ℚ) := eval_nat_choose 0 k
        _ = 0 := by simp [Nat.choose_eq_zero_of_lt hk]
    rw [hchoose]
    simp

/-- Signed Newton evaluation commutes with a finite pointwise sum. -/
lemma newton_evaluation_finset
    {ι : Type*}
    (degreeBound : ℕ)
    (indices : Finset ι)
    (family : ι → ℕ → ℤ) :
    newtonSignedEvaluation degreeBound
        (fun steps => ∑ index ∈ indices, family index steps) =
      ∑ index ∈ indices, newtonSignedEvaluation degreeBound (family index) := by
  classical
  induction indices using Finset.induction_on with
  | empty =>
      simpa using newton_evaluation_const degreeBound 0
  | @insert index indices hindex ih =>
      simp only [Finset.sum_insert hindex]
      rw [newton_evaluation_add, ih]

/-- At formal predecessor input `-1`, a successor-repeated dynamic nested
schedule has only its empty transition-subsequence seed. -/
lemma newton_schedule_seed
    (cutoff : ℕ)
    (crossed outer selected right : CWord Atom)
    (target : List SRTrans) :
    newtonSignedEvaluation (target.length * (2 * cutoff + 3))
        (fun steps : ℕ =>
          (orderedSubsequenceMultiplicity target
            (repeatTransitionSchedule
              (successorSkewCrossing cutoff
                crossed outer selected right steps) (steps + 1)) : ℤ)) =
      ([[]].count target : ℤ) := by
  rw [show
    (fun steps : ℕ =>
      (orderedSubsequenceMultiplicity target
        (repeatTransitionSchedule
          (successorSkewCrossing cutoff crossed
            outer selected right steps) (steps + 1)) : ℤ)) =
      fun steps : ℕ =>
        ∑ activeCopies ∈ Finset.range (target.length + 1),
          ((steps + 1).choose activeCopies : ℤ) *
            (repeatedSubsequenceMultiplicity
              (successorSkewCrossing cutoff
                crossed outer selected right steps) activeCopies target : ℤ) by
      funext steps
      exact_mod_cast
        repeat_target_length
          (successorSkewCrossing cutoff crossed
            outer selected right steps) (steps + 1) target]
  rw [newton_evaluation_finset]
  rw [Finset.sum_eq_single 0]
  · simpa [repeatedSubsequenceMultiplicity,
      activeSubsequenceExpansions] using
        newton_evaluation_const
          (target.length * (2 * cutoff + 3)) ([[]].count target : ℤ)
  · intro activeCopies hactiveCopies hactiveCopiesNe
    have hactiveCopiesPos : 0 < activeCopies :=
      Nat.pos_of_ne_zero hactiveCopiesNe
    have hactiveCopiesLe :
        activeCopies ≤ target.length :=
      Nat.lt_succ_iff.mp (Finset.mem_range.mp hactiveCopies)
    apply newton_evaluation_pos
      (target.length * (2 * cutoff + 3))
      activeCopies
      (target.length * (2 * cutoff + 1) + activeCopies)
      hactiveCopiesPos
    · calc
        activeCopies +
              (target.length * (2 * cutoff + 1) + activeCopies) =
            target.length * (2 * cutoff + 1) + activeCopies * 2 := by
              omega
        _ ≤ target.length * (2 * cutoff + 1) + target.length * 2 :=
          Nat.add_le_add_left
            (Nat.mul_le_mul_right 2 hactiveCopiesLe)
            (target.length * (2 * cutoff + 1))
        _ = target.length * (2 * cutoff + 3) := by
          simp [show 2 * cutoff + 3 = (2 * cutoff + 1) + 2 by omega,
            Nat.mul_add]
    · exact
        repeatedSubsequenceSuccessor
          cutoff crossed outer selected right activeCopies target
  · simp

