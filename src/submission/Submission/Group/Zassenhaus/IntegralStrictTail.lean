/-!
# Finite-state realization of Hall-Witt bounded-term multiplicities

The fixed-alphabet scalar multiplicities used by the strict-tail polynomial
reduction are exactly the coordinates of the induced bounded-term finite
state.  This leaf records that bridge for both signs.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace SSBridge

open OFProgra
open STSched
open SSExp
open STAlphab
open TMRed
open STState

/-- Fixed vector of positive bounded-term multiplicities. -/
def naturalMultiplicityVector
    (cutoff multiplicity : ℕ) :
    List ℕ :=
  (boundedConstantAlphabet cutoff).map
    (naturalBoundedMultiplicity cutoff multiplicity)

/-- Fixed vector of negative bounded-term multiplicities. -/
def negativeMultiplicityVector
    (cutoff multiplicity : ℕ) :
    List ℕ :=
  (boundedConstantAlphabet cutoff).map
    (negativeBoundedMultiplicity cutoff multiplicity)

/-- The positive scalar multiplicity vector is the generic bounded-term
coordinate vector of the positive transition schedule. -/
lemma natural_multiplicity_vector
    (cutoff multiplicity : ℕ) :
    naturalMultiplicityVector cutoff multiplicity =
      boundedConstantVector cutoff
        (boundedConstantTerms cutoff
          (transitionSchedule cutoff
            (naturalRouteProgram cutoff multiplicity))) := by
  rfl

/-- The negative scalar multiplicity vector is the generic bounded-term
coordinate vector of the negative transition schedule. -/
lemma negative_multiplicity_vector
    (cutoff multiplicity : ℕ) :
    negativeMultiplicityVector cutoff multiplicity =
      boundedConstantVector cutoff
        (boundedConstantTerms cutoff
          (transitionSchedule cutoff
            (negativeRouteProgram cutoff multiplicity))) := by
  rfl

/-- The induced finite-state schedule operator computes the positive scalar
multiplicity vector. -/
lemma operator_natural_vector
    (cutoff multiplicity : ℕ) :
    boundedConstantOperator cutoff
        (transitionSchedule cutoff
          (naturalRouteProgram cutoff multiplicity))
        (boundedConstantVector cutoff []) =
      naturalMultiplicityVector cutoff multiplicity := by
  rw [constant_operator_natural,
    natural_multiplicity_vector]

/-- The induced finite-state schedule operator computes the negative scalar
multiplicity vector. -/
lemma constant_operator_vector
    (cutoff multiplicity : ℕ) :
    boundedConstantOperator cutoff
        (transitionSchedule cutoff
          (negativeRouteProgram cutoff multiplicity))
        (boundedConstantVector cutoff []) =
      negativeMultiplicityVector cutoff multiplicity := by
  rw [constant_operator_negative,
    negative_multiplicity_vector]

end SSBridge
end TCTex
