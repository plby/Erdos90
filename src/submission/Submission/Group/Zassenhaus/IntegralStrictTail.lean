-- SubsequencePolynomial.lean

/-!
# Polynomial subsequences for nested Hall-Witt crossing schedules

The nested two-depth schedule is the bounded inner depth word flattened
through ordinary outer bounded-depth crossing schedules.  Regroup transition
subsequences by the active inner-depth source word.  Each fixed active word
has polynomial coefficients by the one-depth crossing compiler, and only a
finite bounded family of inner-depth words can contribute.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace NSPoly

open WSTrace
open NPTail
open TACompos
open BDExp
open DCSched
open STSched
open STClos
open DSRec
open BSRec
open BSPoly
open ASTri
open ASDecomp
open DSReca
open BDSubseq
open DSPoly
open BDPoly
open DDRepeat
open NCSched

/-- Fixed-active-inner-depth contribution to one nested crossing-schedule
subsequence coordinate. -/
def crossingSubsequenceCoefficient
    (cutoff : ℕ)
    (crossed outer selected right : CWord Atom)
    (source : List ℕ)
    (target : List SRTrans)
    (steps : ℕ) :
    ℕ :=
  (activeSubsequenceExpansions
    (fun innerDepth =>
      depthCrossingSchedule cutoff crossed outer
        (iteratedLeftCommutator selected innerDepth right) steps)
    source).count target

/-- An active inner-depth source word longer than the target transition word
cannot contribute. -/
lemma crossing_subsequence_length
    (cutoff : ℕ)
    (crossed outer selected right : CWord Atom)
    (source : List ℕ)
    (target : List SRTrans)
    (steps : ℕ)
    (hlength : target.length < source.length) :
    crossingSubsequenceCoefficient cutoff crossed outer
        selected right source target steps = 0 := by
  apply List.count_eq_zero.mpr
  intro htarget
  have :=
    length_subsequence_expansions
      (fun innerDepth =>
        depthCrossingSchedule cutoff crossed outer
          (iteratedLeftCommutator selected innerDepth right) steps)
      source target htarget
  omega

/-- Every fixed active inner-depth word has polynomial nested crossing
coefficient. -/
lemma active_crossing_subsequence
    (cutoff : ℕ)
    (crossed outer selected right : CWord Atom) :
    ∀ (source : List ℕ) (target : List SRTrans),
      IVMost
        (fun steps : ℕ =>
          (crossingSubsequenceCoefficient cutoff crossed
            outer selected right source target steps : ℤ))
        (target.length * cutoff + source.length)
  | [], target => by
      simpa [crossingSubsequenceCoefficient,
        activeSubsequenceExpansions] using
          valued_most_constant
            (target.length * cutoff) (([[]].count target : ℕ) : ℤ)
  | innerDepth :: source, target => by
      rw [show
        (fun steps : ℕ =>
          (crossingSubsequenceCoefficient cutoff crossed
            outer selected right (innerDepth :: source) target steps : ℤ)) =
        fun steps : ℕ =>
          ∑ suffix ∈ target.tails.toFinset,
