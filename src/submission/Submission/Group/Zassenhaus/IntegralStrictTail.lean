/-!
# Scalar coordinates for bounded Hall-Witt term updates

One ordered second-route transition acts on the bounded ordered-subsequence
terms by:

* prepending the transition to each surviving strict-transition word;
* retaining every existing term;
* adjoining the transition's new affine constant.

For a fixed transition, strict-prepending is injective and each target term
has at most one predecessor.  This file records that partial inverse and the
resulting exact scalar affine recurrence for every bounded-term coordinate.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace SSCoord

open CWTrace
open RMRecb
open STSched
open SSExp
open STRec

/-- Remove one prescribed leading strict transition when it is present. -/
def removePrepended?
    (transition : SRTrans)
    (term : OCTerm) :
    Option OCTerm :=
  match term.strictTransitions with
  | [] =>
      none
  | head :: tail =>
      if head = transition then
        some { strictTransitions := tail, constant := term.constant }
      else
        none

/-- Removing a transition immediately after prepending it recovers the source
term. -/
@[simp]
lemma removePrepended?_prepend
    (transition : SRTrans)
    (term : OCTerm) :
    removePrepended? transition (term.prepend transition) =
      some term := by
  cases term
  simp [removePrepended?, OCTerm.prepend]

/-- A successful removal witnesses the corresponding strict prepend. -/
lemma prepend_remove_prepended?_eq_some
    (transition : SRTrans)
    (term previous : OCTerm)
    (hprevious : removePrepended? transition term = some previous) :
    previous.prepend transition = term := by
  cases term with
  | mk strictTransitions constant =>
      cases strictTransitions with
      | nil =>
          simp [removePrepended?] at hprevious
      | cons head tail =>
          by_cases hhead : head = transition
          · subst head
            have hprevious' :
                ({ strictTransitions := tail, constant := constant } :
                  OCTerm) =
                    previous := by
              simpa [removePrepended?] using hprevious
            rw [← hprevious']
            rfl
          · simp [removePrepended?, hhead] at hprevious

/-- Strict-prepending by a fixed transition is injective. -/
lemma prepend_injective
    (transition : SRTrans) :
    Function.Injective (OCTerm.prepend transition) := by
  intro left right hterms
  have :=
    congrArg (removePrepended? transition) hterms
  simpa using this

/-- The count of a target in a strict-prepended list is the count of its
unique predecessor when that predecessor exists. -/
lemma count_map_prepend
    (transition : SRTrans) :
    ∀ (terms : List OCTerm) (target : OCTerm),
      (terms.map (OCTerm.prepend transition)).count target =
        match removePrepended? transition target with
        | none =>
            0
        | some previous =>
            terms.count previous
  | [], target => by
      cases removePrepended? transition target <;>
        rfl
  | term :: terms, target => by
      rw [List.map_cons, List.count_cons,
        count_map_prepend transition terms target]
      cases htarget : removePrepended? transition target with
      | none =>
          have hne : term.prepend transition ≠ target := by
            intro heq
            have :=
              congrArg (removePrepended? transition) heq
            simp [htarget] at this
          simp [hne]
      | some previous =>
          have heq :
              term.prepend transition = target ↔
                term = previous := by
            constructor
            · intro hterm
              have :=
                congrArg (removePrepended? transition) hterm
              simpa [htarget] using this
            · intro hterm
              subst term
              exact
                prepend_remove_prepended?_eq_some
                  transition target previous htarget
          change
            terms.count previous +
                (if term.prepend transition == target then 1 else 0) =
              (term :: terms).count previous
          rw [List.count_cons]
          by_cases hterm : term = previous
          · subst term
            have hpre :
                previous.prepend transition = target :=
              heq.mpr rfl
            simp only [beq_iff_eq, hpre, if_true]
          · have hpre :
                term.prepend transition ≠ target := by
              intro hpre
              exact hterm (heq.mp hpre)
            simp only [beq_iff_eq, hpre, hterm, if_false, add_zero]

/-- After the cutoff filter, a strict-prepended coordinate is either its
unique predecessor count or zero. -/
lemma count_filter_prepend
    (cutoff : ℕ)
    (transition : SRTrans)
    (terms : List OCTerm)
    (target : OCTerm) :
    ((terms.map (OCTerm.prepend transition)).filter fun term =>
      decide (term.strictTransitions.length < cutoff)).count target =
        if target.strictTransitions.length < cutoff then
          match removePrepended? transition target with
          | none =>
              0
          | some previous =>
              terms.count previous
        else
          0 := by
  rw [count_filter_ite, count_map_prepend]
  simp only [decide_eq_true_eq]

/-- The new affine constant contributes exactly one empty-subsequence target
when the positive cutoff filter retains it. -/
lemma count_filter_singleton
    (cutoff : ℕ)
    (transition : SRTrans)
    (target : OCTerm) :
    ([singletonConstantTerm cutoff transition].filter fun term =>
      decide (term.strictTransitions.length < cutoff)).count target =
        if 0 < cutoff ∧ singletonConstantTerm cutoff transition = target
        then 1
        else 0 := by
  by_cases hcutoff : 0 < cutoff
  · have hfilter :
        [singletonConstantTerm cutoff transition].filter (fun term =>
          decide (term.strictTransitions.length < cutoff)) =
            [singletonConstantTerm cutoff transition] := by
      simp [singletonConstantTerm, hcutoff]
    rw [hfilter]
    by_cases htarget :
        singletonConstantTerm cutoff transition = target
    · subst target
      simp [singletonConstantTerm, hcutoff]
    · simp [htarget]
  · have hzero : cutoff = 0 := by omega
    subst cutoff
    simp [singletonConstantTerm]

/-- Exact scalar affine recurrence for one local bounded-term transition. -/
lemma count_constant_step
    (cutoff : ℕ)
    (transition : SRTrans)
    (terms : List OCTerm)
    (target : OCTerm) :
    (boundedConstantStep cutoff transition terms).count target =
      (if target.strictTransitions.length < cutoff then
          match removePrepended? transition target with
          | none =>
              0
          | some previous =>
              terms.count previous
        else
          0) +
        terms.count target +
          (if 0 < cutoff ∧
              singletonConstantTerm cutoff transition = target
            then 1
            else 0) := by
  unfold boundedConstantStep
  rw [List.count_append, List.count_append,
    count_filter_prepend,
    count_filter_singleton]

end SSCoord
end TCTex
