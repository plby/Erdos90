namespace TCTex
namespace ASTri

open DSRec

/-- Nonempty subsequences of one emitted packet. -/
def nonemptySublists
    {α : Type*}
    (items : List α) :
    List (List α) :=
  items.sublists.filter fun selected =>
    decide (selected ≠ [])

/-- Output words obtained by choosing a nonempty subsequence from every
active source packet.  Duplicates are retained because they record distinct
ordered embeddings. -/
def activeSubsequenceExpansions
    {α β : Type*}
    (packet : α → List β) :
    List α → List (List β)
  | [] =>
      [[]]
  | item :: items =>
      (activeSubsequenceExpansions packet items).flatMap fun suffix =>
        (nonemptySublists (packet item)).map fun head =>
          head ++ suffix

/-- Rank used for the bounded depth-word triangular recurrence. -/
def depthWordRank
    (depths : List ℕ) :
    ℕ :=
  (depths.map fun depth => depth + 1).sum

@[simp]
lemma depth_rank_nil :
    depthWordRank [] = 0 := by
  rfl

@[simp]
lemma depth_rank_cons
    (depth : ℕ)
    (depths : List ℕ) :
    depthWordRank (depth :: depths) =
      depth + 1 + depthWordRank depths := by
  rfl

lemma depth_rank_append
    (left right : List ℕ) :
    depthWordRank (left ++ right) =
      depthWordRank left + depthWordRank right := by
  simp [depthWordRank, List.sum_append]

