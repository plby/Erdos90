/-- Counting concatenations ending in a fixed suffix selects the unique
complementary prefix when the suffix is present. -/
lemma count_append_right
    {α : Type*}
    [BEq α] [LawfulBEq α] [DecidableEq α]
    (words : List (List α))
    (suffix target : List α) :
    (words.map fun initial => initial ++ suffix).count target =
      if suffix <:+ target then
        words.count (target.take (target.length - suffix.length))
      else
        0 := by
  classical
  by_cases hsuffix : suffix <:+ target
  · rw [if_pos hsuffix]
    rcases hsuffix with ⟨initial, rfl⟩
    simp only [List.length_append, Nat.add_sub_cancel_right]
    rw [List.take_append_of_le_length (Nat.le_refl initial.length)]
    rw [List.count_map_of_injective words (fun word => word ++ suffix)
      (List.append_left_injective suffix)]
    simp
  · rw [if_neg hsuffix]
    apply List.count_eq_zero.mpr
    intro htarget
    rcases List.mem_map.mp htarget with ⟨initial, _hinitial, heq⟩
    apply hsuffix
    rw [← heq]
    exact ⟨initial, rfl⟩

/-- Counting a target through a family of right-appended words is a finite
convolution over the literal suffixes of the target. -/
lemma count_flat_tails
    {α : Type*}
    [BEq α] [LawfulBEq α] [DecidableEq α]
    (leftWords rightWords : List (List α))
    (target : List α) :
    (rightWords.flatMap fun suffix =>
      leftWords.map fun initial => initial ++ suffix).count target =
        ∑ suffix ∈ target.tails.toFinset,
          rightWords.count suffix *
            leftWords.count
              (target.take (target.length - suffix.length)) := by
  classical
  rw [count_flat_sum]
  induction rightWords with
  | nil =>
      simp
  | cons suffix rightWords ih =>
      simp only [List.map_cons, List.sum_cons, List.count_cons]
      rw [count_append_right]
      by_cases hsuffix : suffix <:+ target
      · rw [if_pos hsuffix, ih]
        have hsuffixMem : suffix ∈ target.tails.toFinset := by
          exact
            List.mem_toFinset.mpr
              ((List.mem_tails suffix target).mpr hsuffix)
        simp_rw [add_mul]
        rw [Finset.sum_add_distrib]
        have hindicator :
            (∑ other ∈ target.tails.toFinset,
              (if suffix == other then 1 else 0) *
                leftWords.count
                  (target.take (target.length - other.length))) =
              leftWords.count
                (target.take (target.length - suffix.length)) := by
          rw [Finset.sum_eq_single suffix]
          · simp
          · intro other _hother hother
            simp [Ne.symm hother]
          · simp [hsuffixMem]
        rw [hindicator]
        omega
      · rw [if_neg hsuffix, ih, zero_add]
        simp_rw [add_mul]
        rw [Finset.sum_add_distrib]
        have hindicator :
            (∑ other ∈ target.tails.toFinset,
              (if suffix == other then 1 else 0) *
                leftWords.count
                  (target.take (target.length - other.length))) =
              0 := by
          apply Finset.sum_eq_zero
          intro other hother
          have hotherNe : suffix ≠ other := by
            intro heq
            apply hsuffix
            rw [heq]
            exact
              (List.mem_tails other target).mp
                (List.mem_toFinset.mp hother)
          simp [hotherNe]
        rw [hindicator, add_zero]

/-- Ordered subsequence multiplicity across concatenation is convolution over
the literal suffixes of the target word. -/
lemma subsequence_append_tails
    {α : Type*}
    [BEq α] [LawfulBEq α] [DecidableEq α]
    (target left right : List α) :
    orderedSubsequenceMultiplicity target (left ++ right) =
      ∑ suffix ∈ target.tails.toFinset,
        orderedSubsequenceMultiplicity
            (target.take (target.length - suffix.length)) left *
          orderedSubsequenceMultiplicity suffix right := by
  classical
  unfold orderedSubsequenceMultiplicity
  rw [List.sublists_append]
  calc
    (List.count target do
        let suffix ← right.sublists
        left.sublists.map fun initial => initial ++ suffix) =
        ∑ suffix ∈ target.tails.toFinset,
          right.sublists.count suffix *
            left.sublists.count
              (target.take (target.length - suffix.length)) := by
      exact
        count_flat_tails
          left.sublists right.sublists target
    _ = _ := by
      apply Finset.sum_congr rfl
      intro suffix _hsuffix
      exact Nat.mul_comm _ _

/-- Every fixed transition word has polynomial ordered-subsequence
multiplicity across the bounded crossing schedules of a fixed carried trace.
-/
lemma subsequenceMultFlat
    (cutoff : ℕ)
    (outer selected : CWord Atom) :
    ∀ (trace : List (CWord Atom))
      (target : List SRTrans),
      IVMost
        (fun steps : ℕ =>
          (orderedSubsequenceMultiplicity target
            (trace.flatMap fun right =>
              depthCrossingSchedule cutoff outer selected right
                steps) : ℤ))
        (target.length * cutoff + trace.length)
  | [], target => by
      simpa using
        valued_most_constant
          (target.length * cutoff) (orderedSubsequenceMultiplicity target [] : ℤ)
  | right :: trace, target => by
      rw [show
        (fun steps : ℕ =>
          (orderedSubsequenceMultiplicity target
            ((right :: trace).flatMap fun next =>
              depthCrossingSchedule cutoff outer selected next
                steps) : ℤ)) =
          fun steps : ℕ =>
            ∑ suffix ∈ target.tails.toFinset,
              (orderedSubsequenceMultiplicity
                (target.take (target.length - suffix.length))
                (depthCrossingSchedule cutoff outer selected
                  right steps) : ℤ) *
              (orderedSubsequenceMultiplicity suffix
                (trace.flatMap fun next =>
                  depthCrossingSchedule cutoff outer selected
                    next steps) : ℤ) by
        funext steps
        exact_mod_cast
          subsequence_append_tails
            target
              (depthCrossingSchedule cutoff outer selected right
                steps)
              (trace.flatMap fun next =>
                depthCrossingSchedule cutoff outer selected next
                  steps)]
      apply IVMost.finsetSum
      intro suffix hsuffix
      have hdegree :
          (target.take (target.length - suffix.length)).length * cutoff + 1 +
              (suffix.length * cutoff + trace.length) ≤
            target.length * cutoff + (right :: trace).length := by
        have hsuffixMem :
            suffix <:+ target :=
          (List.mem_tails suffix target).mp
            (List.mem_toFinset.mp hsuffix)
        rcases hsuffixMem with ⟨initial, htarget⟩
        subst target
        simp only [List.length_append, Nat.add_sub_cancel_right,
          List.take_append_of_le_length (Nat.le_refl initial.length),
          List.take_length, List.length_cons]
        simp only [Nat.add_mul]
        omega
      apply
        TCTex.IVMost.mono
      · exact hdegree
      · exact
          TCTex.IVMost.mul
            (subsequence_multiplicity_crossing
              cutoff outer selected right
                (target.take (target.length - suffix.length)))
            (subsequenceMultFlat
              cutoff outer selected trace suffix)

/-- Every transition in the fixed-trace flattened crossing schedule belongs
to the finite second-route transition alphabet. -/
lemma route_flat_crossing
    (cutoff steps : ℕ)
    (outer selected : CWord Atom)
    (houter : isFirstCurrent outer = true)
    (trace : List (CWord Atom))
    (transition : SRTrans)
    (htransition :
      transition ∈
        trace.flatMap fun right =>
          depthCrossingSchedule cutoff outer selected right
            steps) :
    transition ∈ secondRouteAlphabet cutoff := by
  rcases List.mem_flatMap.mp htransition with
    ⟨right, _hright, htransition⟩
  exact
    route_alphabet_schedule
      cutoff steps outer selected right houter transition htransition

/-- Bounded ordered affine-term multiplicities for the fixed-trace flattened
crossing schedule are polynomial in the strict-correction depth. -/
lemma constant_flat_crossing
    (cutoff : ℕ)
    (outer selected : CWord Atom)
    (houter : isFirstCurrent outer = true)
    (trace : List (CWord Atom))
    (target : OCTerm) :
    IVMost
      (fun steps : ℕ =>
        ((boundedConstantTerms cutoff
          (trace.flatMap fun right =>
            depthCrossingSchedule cutoff outer selected right
              steps)).count target : ℤ))
      (cutoff * cutoff + trace.length) := by
  by_cases htarget : target.strictTransitions.length < cutoff
  · rw [show
      (fun steps : ℕ =>
        ((boundedConstantTerms cutoff
          (trace.flatMap fun right =>
            depthCrossingSchedule cutoff outer selected right
              steps)).count target : ℤ)) =
        fun steps : ℕ =>
          ∑ producer ∈
              (secondRouteAlphabet cutoff).toFinset,
            if target.constant = (producer.affine cutoff).constant then
              (orderedSubsequenceMultiplicity
                (target.strictTransitions ++ [producer])
                (trace.flatMap fun right =>
                  depthCrossingSchedule cutoff outer selected
                    right steps) : ℤ)
            else
              0 by
      funext steps
      exact_mod_cast
        constant_ite_producers
          cutoff (secondRouteAlphabet cutoff)
            (trace.flatMap fun right =>
              depthCrossingSchedule cutoff outer selected right
                steps)
            (fun transition htransition =>
              route_flat_crossing
                cutoff steps outer selected houter trace transition
                  htransition)
            target |>.trans (if_pos htarget)]
    apply IVMost.finsetSum
    intro producer _hproducer
    by_cases hconstant :
        target.constant = (producer.affine cutoff).constant
    · simp only [hconstant, ↓reduceIte]
      apply
        TCTex.IVMost.mono
      · change
          (target.strictTransitions.length + 1) * cutoff + trace.length ≤
            cutoff * cutoff + trace.length
        exact
          Nat.add_le_add_right
            (Nat.mul_le_mul_right cutoff (Nat.succ_le_iff.mpr htarget))
            trace.length
      · simpa using
          subsequenceMultFlat
            cutoff outer selected trace
              (target.strictTransitions ++ [producer])
    · simp only [hconstant, ↓reduceIte]
      exact
        valued_most_constant
          (cutoff * cutoff + trace.length) 0
  · rw [show
      (fun steps : ℕ =>
        ((boundedConstantTerms cutoff
          (trace.flatMap fun right =>
            depthCrossingSchedule cutoff outer selected right
              steps)).count target : ℤ)) =
          fun _steps : ℕ => 0 by
      funext steps
      exact_mod_cast
        constant_ite_producers
          cutoff (secondRouteAlphabet cutoff)
            (trace.flatMap fun right =>
              depthCrossingSchedule cutoff outer selected right
                steps)
            (fun transition htransition =>
              route_flat_crossing
                cutoff steps outer selected houter trace transition
                  htransition)
            target |>.trans (if_neg htarget)]
    exact
      valued_most_constant
        (cutoff * cutoff + trace.length) 0

/-- A fixed carried trace supplies common polynomial bounded-term data after
flattening its bounded depth-crossing schedules. -/
lemma flat_crossing_schedule
    (cutoff : ℕ)
    (outer selected : CWord Atom)
    (houter : isFirstCurrent outer = true)
    (trace : List (CWord Atom)) :
    BCDataa cutoff
      (cutoff * cutoff + trace.length)
      (fun steps =>
        boundedConstantTerms cutoff
          (trace.flatMap fun right =>
            depthCrossingSchedule cutoff outer selected right
              steps)) := by
  constructor
  · intro steps
    apply
      supported_alphabet_terms
    intro transition htransition
    exact
      route_flat_crossing
        cutoff steps outer selected houter trace transition htransition
  · exact
      constant_flat_crossing
        cutoff outer selected houter trace

/-- Crossing over an iterated local substitution of an arbitrary filtered
fixed trace has polynomial bounded affine-term coordinates. -/
lemma iterated_move_below
    (cutoff : ℕ)
    (outer selected : CWord Atom)
    (houter : isFirstCurrent outer = true)
    (hselected :
      isFirstCurrent selected = true ∨
        isSecondCurrent selected = true)
    (trace : List (CWord Atom)) :
    BCDataa cutoff
      (cutoff * cutoff + trace.length)
      (fun steps =>
        crossingConstantTerms cutoff outer
          (iteratedCutoffMove cutoff selected steps
            (unitBelowTrace cutoff trace))) := by
  apply
    (flat_crossing_schedule
      cutoff outer selected houter trace).congr
  intro steps
  unfold crossingConstantTerms
  rw [
    crossed_iterated_below
      cutoff steps outer selected hselected trace]

