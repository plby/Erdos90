-- EndpointCountStateTailDecomposition.lean

/-!
# Decomposing signed successor-skew endpoint count states

The successor-skew tail schedule is an orbit prefix followed by a repeated
nested schedule.  This file exposes that source decomposition at the finite
bounded-term count-state level.  The repeated nested suffix is represented by
iteration of its one-block affine count-state operator.

The positive and negative endpoint kernel conditions can consequently be
stated directly against the decomposed signed tail states.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace ECDecomp

open WSTrace
open WHNorm
open WNTrace
open WSTail
open NPTail
open TBProf
open TACompos
open OTSubsti
open OTSched
open STSched
open SSExp
open STRec
open SCState
open EOPrefix
open ECSched
open BTRepeat
open SSSched
open PMExp
open SSFull
open FTVector
open CSFold

/-- Count state of the repeated nested suffix inside a successor-skew tail,
represented as iteration of its one-block affine count-state operator. -/
def successorSkewRepeated
    (cutoff : ℕ)
    (crossed outer selected right : CWord Atom)
    (steps : ℕ) :
    BoundedCountState :=
  iterateStateOperator
    (boundedStateFold cutoff
      (successorSkewCrossing cutoff crossed
        outer selected right steps))
    (boundedCountState []) (steps + 1)

/-- Count state of a successor-skew tail after splitting its dynamic orbit
prefix from its repeated nested suffix. -/
def decomposedCountState
    (cutoff : ℕ)
    (crossed outer selected right : CWord Atom)
    (emittedPrefix : List (CWord Atom))
    (steps : ℕ) :
    BoundedCountState :=
  boundedStateFold cutoff
    (boundedCrossingSchedule cutoff crossed outer
      emittedPrefix steps)
    (successorSkewRepeated cutoff crossed outer selected
      right steps)

/-- The bounded-term state of a repeated nested suffix is iteration of its
one-block count-state operator. -/
lemma state_repeat_iterate
    (cutoff : ℕ)
    (schedule : List SRTrans)
    (steps : ℕ) :
    boundedConstantState
        (boundedConstantTerms cutoff
          (repeatTransitionSchedule schedule steps)) =
      iterateStateOperator
        (boundedStateFold cutoff schedule)
        (boundedCountState []) steps := by
  funext target
  unfold boundedConstantState boundedCountState
  rw [count_constant_fold,
    fold_repeat_transition]
  rfl

/-- The bounded-term state of a successor-skew tail is its orbit-prefix fold
applied to the iterated nested-suffix state. -/
lemma state_skew_decomposed
    (cutoff : ℕ)
    (crossed outer selected right : CWord Atom)
    (emittedPrefix : List (CWord Atom))
    (steps : ℕ) :
    boundedConstantState
        (boundedConstantTerms cutoff
          (middleSuccessorSkew cutoff
            crossed outer selected right emittedPrefix steps)) =
      decomposedCountState cutoff crossed outer selected
        right emittedPrefix steps := by
  unfold middleSuccessorSkew
    decomposedCountState
    successorSkewRepeated
  rw [constant_state_append,
    state_repeat_iterate]

/-- Positive decomposed signed successor-skew tail state. -/
noncomputable def naturalDecomposedState
    (cutoff : ℕ) :
    BoundedCountState :=
  newtonEvaluationState
    (naturalFullBound cutoff)
    (fun steps =>
      decomposedCountState cutoff
        firstConventionalInverse firstConventionalInverse
          firstConventionalWord secondConventionalInverse
            (positiveFilteredPrefix cutoff) steps)

/-- Negative decomposed signed successor-skew tail state. -/
noncomputable def successorDecomposedState
    (cutoff : ℕ) :
    BoundedCountState :=
  newtonEvaluationState
    (negativeFullBound cutoff)
    (fun steps =>
      decomposedCountState cutoff
        firstConventionalWord firstConventionalWord
          firstConventionalInverse secondConventionalWord
            (negativeFilteredPrefix cutoff) steps)

/-- The positive signed successor-skew tail state has the explicit
orbit-prefix and iterated-nested-suffix decomposition. -/
lemma successor_state_decomposed
    (cutoff : ℕ) :
    naturalSuccessorSkew cutoff =
      naturalDecomposedState cutoff := by
  unfold naturalSuccessorSkew
    naturalDecomposedState
  apply congrArg
  funext steps
  exact
      state_skew_decomposed
        cutoff firstConventionalInverse firstConventionalInverse
          firstConventionalWord secondConventionalInverse
            (positiveFilteredPrefix cutoff) steps

/-- The negative signed successor-skew tail state has the explicit
orbit-prefix and iterated-nested-suffix decomposition. -/
lemma negative_skew_decomposed
    (cutoff : ℕ) :
    negativeSuccessorSkew cutoff =
      successorDecomposedState cutoff := by
  unfold negativeSuccessorSkew
    successorDecomposedState
  apply congrArg
  funext steps
  exact
      state_skew_decomposed
        cutoff firstConventionalWord firstConventionalWord
          firstConventionalInverse secondConventionalWord
            (negativeFilteredPrefix cutoff) steps

/-- Positive endpoint cancellation expressed against the decomposed signed
successor-skew tail state. -/
def SkewDecomposedSatisfies
    (cutoff : ℕ) :
    Prop :=
  ∀ slot,
    boundedStateSlot cutoff
      (boundedStateFold cutoff
        (positiveFixedPrefix cutoff)
          (naturalDecomposedState cutoff)) slot = 0

/-- Negative endpoint cancellation expressed against the decomposed signed
successor-skew tail state. -/
def SkewDecomposedState
    (cutoff : ℕ) :
    Prop :=
  ∀ slot,
    boundedStateSlot cutoff
      (boundedStateFold cutoff
        (negativeFixedPrefix cutoff)
          (successorDecomposedState cutoff)) slot = 0

/-- The positive prefix-kernel obligation is unchanged by exposing the
successor-skew tail decomposition. -/
lemma skew_satisfies_decomposed
    (cutoff : ℕ) :
    SuccessorSkewSatisfies cutoff ↔
      SkewDecomposedSatisfies
