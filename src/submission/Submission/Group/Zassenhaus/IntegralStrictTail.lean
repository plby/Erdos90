/-!
# Polynomial crossing schedules for repeated Hall-Witt middle blocks

The signed middle first-route programs are repetitions of one filtered
moved-singleton block.  Crossing a fixed outer word over that block is the
bounded strict-depth schedule, and mapping over the repeated trace gives its
diagonal repetition.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace FDCross

open CWTrace
open WSTrace
open WHNorm
open WSTail
open NPTail
open RMRecb
open TBProf
open ARProfa
open OFProgra
open OFProgra.FRProgra
open ORBlock
open OTDecomp
open DCSched
open OCClosa
open STSched
open STClos
open DDRepeat
open BTRepeat

/-- Mapping a repeated trace is repetition of its mapped schedule. -/
lemma map_repeatTrace
    (mapEntry : CWord Atom → SRTrans)
    (trace : List (CWord Atom)) :
    ∀ copies : ℕ,
      (repeatTrace copies trace).map mapEntry =
        repeatTransitionSchedule (trace.map mapEntry) copies
  | 0 => by
      rfl
  | copies + 1 => by
      rw [repeatTrace, List.map_append, repeatTransitionSchedule,
        map_repeatTrace mapEntry trace copies]

/-- Filtering may be performed before an arbitrary number of literal
rightward moves. -/
lemma below_move_higher
    (cutoff : ℕ)
    (selected : CWord Atom) :
    ∀ (steps : ℕ) (rights : List (CWord Atom)),
      unitBelowTrace cutoff
          (iteratedMoveHigher selected steps rights) =
        unitBelowTrace cutoff
          (iteratedMoveHigher selected steps
            (unitBelowTrace cutoff rights))
  | 0, rights => by
      exact (unit_below_idem cutoff rights).symm
  | steps + 1, rights => by
      rw [iteratedMoveHigher, iteratedMoveHigher]
      calc
        unitBelowTrace cutoff
            (moveHigherTrace selected
              (iteratedMoveHigher selected steps rights)) =
          unitBelowTrace cutoff
            (moveHigherTrace selected
              (unitBelowTrace cutoff
                (iteratedMoveHigher selected steps rights))) :=
          unit_move_higher
            cutoff selected
              (iteratedMoveHigher selected steps rights)
        _ =
          unitBelowTrace cutoff
            (moveHigherTrace selected
              (unitBelowTrace cutoff
                (iteratedMoveHigher selected steps
                  (unitBelowTrace cutoff rights)))) := by
          rw [
            below_move_higher
              cutoff selected steps rights]
        _ =
          unitBelowTrace cutoff
            (moveHigherTrace selected
              (iteratedMoveHigher selected steps
                (unitBelowTrace cutoff rights))) :=
          (unit_move_higher
            cutoff selected
              (iteratedMoveHigher selected steps
                (unitBelowTrace cutoff rights))).symm

/-- The filtered literal moved-singleton block is the homogeneous cutoff
orbit used by the bounded strict-depth expansion. -/
lemma iterated_move_literal
    (cutoff steps : ℕ)
    (selected right : CWord Atom) :
    iteratedCutoffMove cutoff selected steps
        (unitBelowTrace cutoff [right]) =
      unitBelowTrace cutoff
        (iteratedMoveHigher selected steps [right]) := by
  calc
    iteratedCutoffMove cutoff selected steps
        (unitBelowTrace cutoff [right]) =
      unitBelowTrace cutoff
        (iteratedMoveHigher selected steps
          (unitBelowTrace cutoff [right])) :=
      iterated_below_higher
        cutoff selected (unitBelowTrace cutoff [right])
          (unit_below_idem cutoff [right]) steps
    _ =
      unitBelowTrace cutoff
        (iteratedMoveHigher selected steps [right]) :=
      (below_move_higher
        cutoff selected steps [right]).symm

/-- Crossing one filtered moved-singleton block is its bounded strict-depth
schedule. -/
lemma crossed_move_singleton
    (cutoff steps : ℕ)
    (outer selected right : CWord Atom)
    (hselected :
      isFirstCurrent selected = true ∨
        isSecondCurrent selected = true) :
    (unitBelowTrace cutoff
      (iteratedMoveHigher selected steps [right])).map
        (SRTrans.crossed outer) =
      depthCrossingSchedule cutoff outer selected right steps := by
  rw [←
    iterated_move_literal
      cutoff steps selected right]
  exact
    crossed_iterated_singleton
      cutoff steps outer selected right hselected

/-- Crossing the repeated moved-singleton middle block is the diagonal
repetition compiled by the bounded-depth polynomial theorem. -/
lemma crossed_repeat_repeated
    (cutoff steps : ℕ)
    (outer selected right : CWord Atom)
    (hselected :
      isFirstCurrent selected = true ∨
        isSecondCurrent selected = true) :
    (repeatTrace steps
      (unitBelowTrace cutoff
        (iteratedMoveHigher selected steps [right]))).map
          (SRTrans.crossed outer) =
      repeatTransitionSchedule
        (depthCrossingSchedule cutoff outer selected right steps)
          steps := by
  rw [map_repeatTrace,
    crossed_move_singleton
      cutoff steps outer selected right hselected]

/-- Any repeated moved-singleton middle block supplies bounded-term
polynomial data after crossing a fixed first-family outer word. -/
lemma repeat_moved_singleton
    (cutoff : ℕ)
    (outer selected right : CWord Atom)
    (houter : isFirstCurrent outer = true)
    (hselected :
      isFirstCurrent selected = true ∨
        isSecondCurrent selected = true) :
    BCDataa cutoff (cutoff * (cutoff + 2))
      (fun steps =>
        crossingConstantTerms cutoff outer
          (repeatTrace steps
            (unitBelowTrace cutoff
              (iteratedMoveHigher selected steps [right])))) := by
  apply
    (diagonal_repeated_crossing
      cutoff outer selected right houter).congr
  intro steps
  unfold crossingConstantTerms
  rw [
    crossed_repeat_repeated
      cutoff steps outer selected right hselected]

/-- The positive middle first-route program has bounded-term polynomial
crossing data for the positive outer selected word. -/
lemma constant_middle_program
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff) :
    BCDataa cutoff (cutoff * (cutoff + 2))
      (fun steps =>
        crossingConstantTerms cutoff firstConventionalInverse
          ((iteratePrepend cutoff isFirstCurrent [firstConventionalWord] steps
            (iteratePrepend cutoff isFirstCurrent
              [secondConventionalInverse] steps .empty)).trace cutoff)) := by
  apply
    (repeat_moved_singleton
      cutoff firstConventionalInverse firstConventionalWord
        secondConventionalInverse (by simp) (by simp)).congr
  intro steps
  unfold crossingConstantTerms
  rw [middle_repeat_singleton
    cutoff hcutoff steps]

/-- The negative middle first-route program has bounded-term polynomial
crossing data for the negative outer selected word. -/
lemma crossing_middle_program
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff) :
    BCDataa cutoff (cutoff * (cutoff + 2))
      (fun steps =>
        crossingConstantTerms cutoff firstConventionalWord
          ((iteratePrepend cutoff isFirstCurrent
              [firstConventionalInverse] steps
            (iteratePrepend cutoff isFirstCurrent [secondConventionalWord]
              steps .empty)).trace cutoff)) := by
  apply
    (repeat_moved_singleton
      cutoff firstConventionalWord firstConventionalInverse
        secondConventionalWord (by simp) (by simp)).congr
  intro steps
  unfold crossingConstantTerms
  rw [middle_moved_singleton
    cutoff hcutoff steps]

end FDCross
end TCTex
end Submission

