/-!
# Finite recurrence for bounded Hall-Witt depth-word subsequences

Regroup the active-source convolution over one fixed finite alphabet of
bounded depth words.  For a target word, active sources longer than that
target contribute zero.  Every remaining active source is a word of bounded
length over `List.range cutoff`.

The resulting successor formula is a finite linear recurrence whose
coefficients depend only on the bounded depth substitution.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace DSReca

open TMRed
open DSRec
open BSRec
open ASTri
open ASDecomp

/-- Enumerate depth words of one fixed length over `List.range cutoff`. -/
def depthWordsLength
    (cutoff : ℕ) :
    ℕ → List (List ℕ)
  | 0 =>
      [[]]
  | length + 1 =>
      (List.range cutoff).flatMap fun depth =>
        (depthWordsLength cutoff length).map
          (List.cons depth)

/-- Enumerate depth words whose length is at most one fixed bound. -/
def wordsUpLength
    (cutoff maxLength : ℕ) :
    List (List ℕ) :=
  (List.range (maxLength + 1)).flatMap
    (depthWordsLength cutoff)

/-- Every enumerated fixed-length depth word has the advertised length. -/
lemma length_depth_words
    (cutoff : ℕ) :
    ∀ (length : ℕ) (word : List ℕ),
      word ∈ depthWordsLength cutoff length →
        word.length = length
  | 0, word, hword => by
      simp [depthWordsLength] at hword
      subst word
      rfl
  | length + 1, word, hword => by
      simp only [depthWordsLength] at hword
      rcases List.mem_flatMap.mp hword with
        ⟨depth, _hdepth, hword⟩
      rcases List.mem_map.mp hword with
        ⟨tail, htail, rfl⟩
      simp [length_depth_words cutoff length tail htail]

/-- Every enumerated fixed-length depth word lies in the finite cutoff
alphabet. -/
lemma cutoff_words_length
    (cutoff : ℕ) :
    ∀ (length : ℕ) (word : List ℕ),
      word ∈ depthWordsLength cutoff length →
        ∀ depth ∈ word, depth < cutoff
  | 0, word, hword, depth, hdepth => by
      simp [depthWordsLength] at hword
      subst word
      simp at hdepth
  | length + 1, word, hword, depth, hdepth => by
      simp only [depthWordsLength] at hword
      rcases List.mem_flatMap.mp hword with
        ⟨head, hhead, hword⟩
      rcases List.mem_map.mp hword with
        ⟨tail, htail, rfl⟩
      simp only [List.mem_cons] at hdepth
      rcases hdepth with rfl | hdepth
      · exact List.mem_range.mp hhead
      · exact
          cutoff_words_length
            cutoff length tail htail depth hdepth

/-- Every supported word occurs in its fixed-length depth-word enumeration. -/
lemma words_length_forall
    (cutoff : ℕ) :
    ∀ word : List ℕ,
      (∀ depth ∈ word, depth < cutoff) →
        word ∈ depthWordsLength cutoff word.length
  | [], _hword => by
      simp [depthWordsLength]
  | depth :: word, hword => by
      simp only [depthWordsLength]
      apply List.mem_flatMap.mpr
      refine
        ⟨depth, List.mem_range.mpr (hword depth (by simp)), ?_⟩
      apply List.mem_map.mpr
      exact
        ⟨word,
          words_length_forall cutoff word
            (fun next hnext => hword next (by simp [hnext])),
          rfl⟩

/-- Every enumerated bounded-length depth word has length at most the fixed
bound. -/
lemma length_words_up
    (cutoff maxLength : ℕ)
    (word : List ℕ)
    (hword : word ∈ wordsUpLength cutoff maxLength) :
    word.length ≤ maxLength := by
  unfold wordsUpLength at hword
  rcases List.mem_flatMap.mp hword with
    ⟨length, hlength, hword⟩
  rw [length_depth_words cutoff length word hword]
  exact Nat.lt_succ_iff.mp (List.mem_range.mp hlength)

/-- Every enumerated bounded-length depth word lies in the finite cutoff
alphabet. -/
lemma words_up_length
    (cutoff maxLength : ℕ)
    (word : List ℕ)
    (hword : word ∈ wordsUpLength cutoff maxLength)
    (depth : ℕ)
    (hdepth : depth ∈ word) :
    depth < cutoff := by
  unfold wordsUpLength at hword
  rcases List.mem_flatMap.mp hword with
    ⟨length, _hlength, hword⟩
  exact
    cutoff_words_length
      cutoff length word hword depth hdepth

/-- Every supported word of bounded length occurs in the bounded depth-word
enumeration. -/
lemma words_up_forall
    (cutoff maxLength : ℕ)
    (word : List ℕ)
    (hlength : word.length ≤ maxLength)
    (hword : ∀ depth ∈ word, depth < cutoff) :
    word ∈ wordsUpLength cutoff maxLength := by
  unfold wordsUpLength
  apply List.mem_flatMap.mpr
  exact
    ⟨word.length, List.mem_range.mpr (by omega),
      words_length_forall cutoff word hword⟩

/-- Fixed coefficient for one active source depth word to emit one target
depth word in a single bounded substitution step. -/
def activeSubstitutionCoefficient
    (cutoff : ℕ)
    (source target : List ℕ) :
    ℕ :=
  (activeSubsequenceExpansions
    (strictStepPacket cutoff) source).count target

/-- An active source longer than its target has zero substitution
coefficient. -/
lemma active_substitution_length
    (cutoff : ℕ)
    (source target : List ℕ)
    (hlength : target.length < source.length) :
    activeSubstitutionCoefficient cutoff source target = 0 := by
  apply List.count_eq_zero.mpr
  intro htarget
  have :=
    length_subsequence_expansions
      (strictStepPacket cutoff) source target htarget
  omega

/-- Filtering away entries whose mapped value is zero does not change a
list-valued additive sum. -/
lemma sum_filter_zero
    {α M : Type*}
    [AddMonoid M]
    (keep : α → Bool)
    (value : α → M) :
    ∀ source : List α,
      (∀ item ∈ source, keep item = false → value item = 0) →
        (source.map value).sum =
          ((source.filter keep).map value).sum
  | [], _hzero => by
      rfl
  | item :: items, hzero => by
      by_cases hitem : keep item = true
      · simp [hitem,
          sum_filter_zero keep value items
            (fun next hnext => hzero next (by simp [hnext]))]
      · have hitemFalse : keep item = false := by
          exact Bool.eq_false_of_not_eq_true hitem
        rw [List.map_cons, List.sum_cons, hzero item (by simp) hitemFalse,
          zero_add, List.filter_cons_of_neg hitem,
          sum_filter_zero keep value items
            (fun next hnext => hzero next (by simp [hnext]))]

/-- Group an additive list sum over a supporting finite alphabet while using
the ambient lawful Boolean equality instance for list counts. -/
lemma alphabet_bcount_nsmul
    {α M : Type*}
    [BEq α] [LawfulBEq α]
    [DecidableEq α]
    [AddCommMonoid M]
    (alphabet : List α)
    (value : α → M) :
    ∀ terms : List α,
      (∀ term ∈ terms, term ∈ alphabet) →
        (terms.map value).sum =
          ∑ term ∈ alphabet.toFinset,
            terms.count term • value term
  | [], _hterms => by
      simp
  | item :: terms, hterms => by
      have hitem : item ∈ alphabet :=
        hterms item (by simp)
      have htail :
          ∀ term ∈ terms, term ∈ alphabet :=
        fun term hterm => hterms term (by simp [hterm])
      have hindicator :
          (∑ term ∈ alphabet.toFinset,
              (if item == term then 1 else 0) • value term) =
            value item := by
        calc
          (∑ term ∈ alphabet.toFinset,
              (if item == term then 1 else 0) • value term) =
              ∑ term ∈ alphabet.toFinset,
                if item = term then value term else 0 := by
            apply Finset.sum_congr rfl
            intro term _hterm
            by_cases heq : item = term
            · simp [heq]
            · simp [heq]
          _ = value item := by
            simp [List.mem_toFinset.mpr hitem]
      rw [List.map_cons, List.sum_cons,
        alphabet_bcount_nsmul alphabet value terms htail]
      simp only [List.count_cons, add_nsmul, Finset.sum_add_distrib]
      rw [hindicator]
      exact add_comm _ _

/-- Every subword of the bounded depth schedule lies in the finite cutoff
alphabet. -/
lemma cutoff_sublists_schedule
    (cutoff steps : ℕ)
    (word : List ℕ)
    (hword :
      word ∈ (boundedDepthSchedule cutoff steps).sublists)
    (depth : ℕ)
    (hdepth : depth ∈ word) :
    depth < cutoff := by
  exact
    cutoff_bounded_schedule
      cutoff steps depth (List.mem_sublists.mp hword |>.subset hdepth)

/-- The exact successor recurrence grouped over one fixed finite depth-word
alphabet. -/
lemma subsequence_multiplicity_alphabet
    (cutoff steps : ℕ)
    (target : List ℕ) :
    orderedSubsequenceMultiplicity target
        (boundedDepthSchedule cutoff (steps + 1)) =
      ∑ source ∈ (wordsUpLength cutoff target.length).toFinset,
        orderedSubsequenceMultiplicity source
            (boundedDepthSchedule cutoff steps) •
          activeSubstitutionCoefficient cutoff source target := by
  classical
  rw [
    ordered_subsequence_multiplicity]
  let sourceSublists :=
    (boundedDepthSchedule cutoff steps).sublists
  let boundedSourceSublists :=
    sourceSublists.filter fun source =>
      decide (source.length ≤ target.length)
  let value : List ℕ → ℕ :=
    fun source =>
      activeSubstitutionCoefficient cutoff source target
  calc
    (sourceSublists.map value).sum =
        (boundedSourceSublists.map value).sum := by
      apply sum_filter_zero
      intro source hsource hlength
      apply active_substitution_length
      exact
        Nat.lt_of_not_ge
          (of_decide_eq_false hlength)
    _ =
        ∑ source ∈ (wordsUpLength cutoff target.length).toFinset,
          boundedSourceSublists.count source • value source := by
      exact
        alphabet_bcount_nsmul
          (wordsUpLength cutoff target.length)
          value boundedSourceSublists
          (fun source hsource => by
            have hsourceFilter := List.mem_filter.mp hsource
            apply
              words_up_forall
                cutoff target.length source
            · exact of_decide_eq_true hsourceFilter.2
            · intro depth hdepth
              exact
                cutoff_sublists_schedule
                  cutoff steps source hsourceFilter.1 depth hdepth)
    _ =
        ∑ source ∈ (wordsUpLength cutoff target.length).toFinset,
          orderedSubsequenceMultiplicity source
              (boundedDepthSchedule cutoff steps) •
            activeSubstitutionCoefficient cutoff source target := by
      apply Finset.sum_congr rfl
      intro source hsource
      have hlength :
          source.length ≤ target.length :=
        length_words_up
          cutoff target.length source (List.mem_toFinset.mp hsource)
      rw [show
        boundedSourceSublists.count source =
          orderedSubsequenceMultiplicity source
            (boundedDepthSchedule cutoff steps) by
        unfold boundedSourceSublists sourceSublists
          orderedSubsequenceMultiplicity
        exact List.count_filter (decide_eq_true hlength)]

end DSReca
