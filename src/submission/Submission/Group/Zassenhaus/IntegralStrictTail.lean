/-- Integer-valued multiplicity state indexed by all bounded-term shapes. -/
abbrev BoundedCountState :=
  OCTerm → ℤ

/-- Literal multiplicity state of a bounded-term list. -/
def boundedCountState
    (terms : List OCTerm) :
    BoundedCountState :=
  fun target => terms.count target

/-- Coordinate inherited from the unique strict-prepend predecessor, when
that predecessor exists and survives the cutoff. -/
def strictPredecessorCount
    (cutoff : ℕ)
    (transition : SRTrans)
    (state : BoundedCountState)
    (target : OCTerm) :
    ℤ :=
  if target.strictTransitions.length < cutoff then
    match removePrepended? transition target with
    | none =>
        0
    | some previous =>
        state previous
  else
    0

/-- Constant empty-subsequence contribution of one affine transition. -/
def singletonConstantCount
    (cutoff : ℕ)
    (transition : SRTrans)
    (target : OCTerm) :
    ℤ :=
  if 0 < cutoff ∧ singletonConstantTerm cutoff transition = target then
    1
  else
    0

