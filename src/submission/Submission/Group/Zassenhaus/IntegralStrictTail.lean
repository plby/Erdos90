    (cutoff : ℕ)
    (selected : CWord Atom)
    (rights : List (CWord Atom))
    (slot : CWord Atom)
    (steps : ℕ) :
    homogeneousMoveMultiplicity cutoff selected rights slot steps =
      repeatedMoveMultiplicity cutoff selected rights slot steps := by
  unfold homogeneousMoveMultiplicity repeatedMoveMultiplicity
    unitBelowMultiplicity
  rw [iterated_unit_below]

