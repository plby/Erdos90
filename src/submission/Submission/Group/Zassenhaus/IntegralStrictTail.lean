singleton is exactly its bounded strict-depth crossing schedule. -/
lemma crossed_iterated_singleton
    (cutoff steps : ℕ)
    (outer selected right : CWord Atom)
    (hselected :
      isFirstCurrent selected = true ∨
        isSecondCurrent selected = true) :
    (iteratedCutoffMove cutoff selected steps
      (unitBelowTrace cutoff [right])).map
        (SRTrans.crossed outer) =
      depthCrossingSchedule cutoff outer selected right steps := by
  rw [
    iterated_move_schedule
      cutoff steps selected right hselected,
    map_flatMap]
  rfl

/-- Crossing the homogeneous local substitution of an arbitrary filtered
trace is the flattened family of its bounded singleton depth schedules. -/
lemma crossed_iterated_below
    (cutoff steps : ℕ)
    (outer selected : CWord Atom)
    (hselected :
      isFirstCurrent selected = true ∨
        isSecondCurrent selected = true)
    (trace : List (CWord Atom)) :
    (iteratedCutoffMove cutoff selected steps
      (unitBelowTrace cutoff trace)).map
        (SRTrans.crossed outer) =
      trace.flatMap fun right =>
        depthCrossingSchedule cutoff outer selected right
          steps := by
  rw [
    iterated_below_schedule
      cutoff steps selected hselected trace,
    map_flatMap]
  apply List.flatMap_congr
  intro right _hright
  rw [map_flatMap]
  rfl

/-- Every transition in one fixed strict-depth packet belongs to the global
finite transition alphabet when the crossed outer word is first-family
current. -/
lemma route_alphabet_crossing
    (cutoff : ℕ)
    (outer selected right : CWord Atom)
    (houter : isFirstCurrent outer = true)
    (depth : ℕ)
    (transition : SRTrans)
    (htransition :
      transition ∈ strictCrossingPacket
        cutoff outer selected right depth) :
    transition ∈ secondRouteAlphabet cutoff := by
  apply
    second_alphabet_crossed
      cutoff outer houter
        (iteratedCutoffTrace cutoff selected depth
          (unitBelowTrace cutoff [right]))
  · rw [iterated_cutoff_below]
    exact
      supported_vocabulary_below cutoff
        (iteratedMoveTrace selected depth [right])
  · exact htransition

/-- Every transition in a bounded strict-depth crossing schedule belongs to
the global finite transition alphabet. -/
lemma route_alphabet_schedule
    (cutoff steps : ℕ)
    (outer selected right : CWord Atom)
    (houter : isFirstCurrent outer = true)
    (transition : SRTrans)
    (htransition :
      transition ∈
        depthCrossingSchedule cutoff outer selected right steps) :
    transition ∈ secondRouteAlphabet cutoff := by
  rcases List.mem_flatMap.mp htransition with
    ⟨depth, _hdepth, htransition⟩
  exact
    route_alphabet_crossing
      cutoff outer selected right houter depth transition htransition

