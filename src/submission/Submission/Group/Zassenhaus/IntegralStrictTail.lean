/-- Integer-valued cutoff-profile coordinates, allowing formal signed
multiplicities. -/
abbrev SignedCutoffProfile :=
  CWord Atom → ℤ

/-- Formal-predecessor signed slot profile of a natural multiset family. -/
noncomputable def profileFormalPredecessor
    (degreeBound : ℕ)
    (family : ℕ → Multiset (CWord Atom)) :
    SignedCutoffProfile :=
  fun slot =>
    newtonSignedEvaluation degreeBound
      (fun steps => (Multiset.count slot (family steps) : ℤ))

/-- Extend one affine cutoff-profile transformation to a single slot of an
integer-valued signed profile using the finite cutoff vocabulary. -/
noncomputable def signedAffineSlot
    (cutoff : ℕ)
    (transform : CPAffine)
    (source : SignedCutoffProfile)
    (slot : CWord Atom) :
    ℤ :=
  ∑ input ∈ (orderedCutoffVocabulary cutoff).toFinset,
      (Multiset.count slot (transform.linear {input}) : ℤ) * source input +
    (Multiset.count slot transform.constant : ℤ)

/-- Formal-predecessor slot evaluation commutes with every fixed affine
cutoff-profile map on a supported natural multiset family. -/
lemma newton_evaluation_affine
    (cutoff degreeBound : ℕ)
    (transform : CPAffine)
    (family : ℕ → Multiset (CWord Atom))
    (hfamily :
      ∀ steps,
        SCVocabu cutoff (family steps))
    (slot : CWord Atom) :
    newtonSignedEvaluation degreeBound
        (fun steps =>
          (Multiset.count slot (transform.apply (family steps)) : ℤ)) =
      signedAffineSlot cutoff transform
        (profileFormalPredecessor degreeBound family) slot := by
  rw [show
    (fun steps =>
      (Multiset.count slot (transform.apply (family steps)) : ℤ)) =
      fun steps =>
        (∑ input ∈ (orderedCutoffVocabulary cutoff).toFinset,
          (Multiset.count slot (transform.linear {input}) : ℤ) *
            (Multiset.count input (family steps) : ℤ)) +
          (Multiset.count slot transform.constant : ℤ) by
    funext steps
    unfold CPAffine.apply
    rw [Multiset.count_add, Nat.cast_add,
      count_cutoff_vocabulary cutoff transform.linear
        (family steps) (hfamily steps) slot, Nat.cast_sum]
    apply congrArg (· + (Multiset.count slot transform.constant : ℤ))
    apply Finset.sum_congr rfl
    intro input _hinput
    norm_cast]
  rw [newton_evaluation_add, newton_evaluation_const]
  unfold signedAffineSlot profileFormalPredecessor
  congr 1
  unfold newtonSignedEvaluation
  exact
    successor_alternating_finset degreeBound
      (orderedCutoffVocabulary cutoff).toFinset
        (fun input =>
          (Multiset.count slot (transform.linear {input}) : ℤ))
        (fun input steps =>
          (Multiset.count input (family steps) : ℤ))

