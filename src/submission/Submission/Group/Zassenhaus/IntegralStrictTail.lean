    (head :
      CHExp
        (inputWeight := inputWeight) x y z coefficient) :
    head.originalExpansion.eval = coefficient := by
  rw [originalExpansion, BCExp.eval_reweight,
    head.eval_expansion]

@[simp]
lemma eval_firstExpansion
    {d inputWeight : ℕ}
