    (cutoff steps : ℕ)
    (selected right : CWord Atom)
    (target : List SRTrans) :
    orderedSubsequenceMultiplicity target
        (boundedStrictSchedule cutoff selected right steps) =
      ∑ source ∈ (wordsUpLength cutoff target.length).toFinset,
        orderedSubsequenceMultiplicity source
            (boundedDepthSchedule cutoff steps) •
          activeSubsequenceCoefficient
            cutoff selected right source target := by
  classical
  rw [
    bounded_strict_flat,
    subsequence_multiplicity_flat,
    count_subsequence_expansions]
  let sourceSublists :=
    (boundedDepthSchedule cutoff steps).sublists
  let boundedSourceSublists :=
    sourceSublists.filter fun source =>
      decide (source.length ≤ target.length)
  let value : List ℕ → ℕ :=
    fun source =>
      activeSubsequenceCoefficient
        cutoff selected right source target
  calc
    (sourceSublists.map value).sum =
        (boundedSourceSublists.map value).sum := by
      apply sum_filter_zero
      intro source hsource hlength
      apply
        subsequence_coefficient_length
      exact Nat.lt_of_not_ge (of_decide_eq_false hlength)
    _ =
        ∑ source ∈ (wordsUpLength cutoff target.length).toFinset,
          boundedSourceSublists.count source • value source := by
      exact
        alphabet_bcount_nsmul
          (wordsUpLength cutoff target.length)
          value boundedSourceSublists
          (fun source hsource => by
            have hsourceFilter := List.mem_filter.mp hsource
            apply
              words_up_forall
                cutoff target.length source
            · exact of_decide_eq_true hsourceFilter.2
            · intro depth hdepth
              exact
                cutoff_sublists_schedule
                  cutoff steps source hsourceFilter.1 depth hdepth)
