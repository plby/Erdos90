namespace TCTex
namespace ORBlock

open WSTrace
open WHNorm
open WSTail
open NPTail
open RMRecb
open TBProf
open ARProfa
open OFProgra
open OFProgra.FRProgra
open OSIterat
open OTSubsti

/-- Iterated literal movement preserves the empty carried trace. -/
lemma iterated_move_nil
    (selected : CWord Atom) :
    ∀ steps : ℕ,
      iteratedMoveHigher selected steps [] = []
  | 0 => by
      rfl
  | steps + 1 => by
      rw [iteratedMoveHigher,
        iterated_move_nil selected steps]
      rfl

/-- Iterated literal movement distributes over concatenation. -/
lemma iterated_move_append
    (selected : CWord Atom) :
    ∀ (steps : ℕ) (left right : List (CWord Atom)),
      iteratedMoveHigher selected steps (left ++ right) =
        iteratedMoveHigher selected steps left ++
          iteratedMoveHigher selected steps right
  | 0, _left, _right => by
      rfl
  | steps + 1, left, right => by
      rw [iteratedMoveHigher,
        iterated_move_append selected steps left right,
        move_higher_append]
      rfl

/-- Iterated literal movement commutes with finite trace repetition. -/
lemma iterated_higher_repeat
    (selected : CWord Atom)
    (trace : List (CWord Atom))
    (steps : ℕ) :
    ∀ copies : ℕ,
      iteratedMoveHigher selected steps (repeatTrace copies trace) =
        repeatTrace copies
          (iteratedMoveHigher selected steps trace)
  | 0 => by
      rw [repeatTrace, iterated_move_nil]
      rfl
  | copies + 1 => by
      rw [repeatTrace, iterated_move_append,
        iterated_higher_repeat selected trace steps copies,
        repeatTrace]

/-- Filtering below cutoff commutes with finite trace repetition. -/
lemma unit_below_repeat
    (cutoff : ℕ)
    (trace : List (CWord Atom))
    (copies : ℕ) :
    unitBelowTrace cutoff (repeatTrace copies trace) =
      repeatTrace copies (unitBelowTrace cutoff trace) := by
  exact filter_repeatTrace
    (fun word => decide (word.weight (fun _ => 1) < cutoff)) trace copies

/-- Filtered iterated movement across a repeated trace is repetition of the
filtered moved block. -/
lemma iterated_move_repeat
    (cutoff : ℕ)
    (selected : CWord Atom)
    (trace : List (CWord Atom))
    (steps copies : ℕ) :
    unitBelowTrace cutoff
        (iteratedMoveHigher selected steps
          (repeatTrace copies trace)) =
      repeatTrace copies
        (unitBelowTrace cutoff
          (iteratedMoveHigher selected steps trace)) := by
  rw [iterated_higher_repeat, unit_below_repeat]

/-- The positive middle program is a repeated moved-singleton block. -/
lemma middle_repeat_singleton
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (steps : ℕ) :
    (iteratePrepend cutoff isFirstCurrent [firstConventionalWord] steps
        (iteratePrepend cutoff isFirstCurrent [secondConventionalInverse]
          steps .empty)).trace cutoff =
      repeatTrace steps
        (unitBelowTrace cutoff
          (iteratedMoveHigher firstConventionalWord steps
            [secondConventionalInverse])) := by
  rw [positive_middle_program cutoff hcutoff steps,
    iterated_move_repeat]

/-- The negative middle program is a repeated moved-singleton block. -/
lemma middle_moved_singleton
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (steps : ℕ) :
    (iteratePrepend cutoff isFirstCurrent [firstConventionalInverse] steps
        (iteratePrepend cutoff isFirstCurrent [secondConventionalWord]
          steps .empty)).trace cutoff =
      repeatTrace steps
        (unitBelowTrace cutoff
          (iteratedMoveHigher firstConventionalInverse steps
            [secondConventionalWord])) := by
  rw [negative_middle_program cutoff hcutoff steps,
    iterated_move_repeat]

/-- The complete positive first route has an explicit repeated-block carried
trace at its outer routing boundary. -/
lemma route_repeated_moved
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (steps : ℕ) :
    (naturalRouteProgram cutoff steps).trace cutoff =
      unitBelowTrace cutoff
        (routeOnto isFirstCurrent
          (repeatTrace steps WNTrace.trace)
          (repeatTrace steps
            (unitBelowTrace cutoff
              (iteratedMoveHigher firstConventionalWord steps
                [secondConventionalInverse])))) := by
  rw [natural_program_middle
    cutoff hcutoff steps,
    iterated_move_repeat]

/-- The complete negative first route has an explicit repeated-block carried
trace at its outer routing boundary. -/
lemma repeated_moved_singleton
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (steps : ℕ) :
    (negativeRouteProgram cutoff steps).trace cutoff =
      unitBelowTrace cutoff
        (routeOnto isFirstCurrent
          (repeatTrace steps
            NNPower.inverseNormalizedTrace)
          (repeatTrace steps
            (unitBelowTrace cutoff
              (iteratedMoveHigher firstConventionalInverse steps
                [secondConventionalWord])))) := by
  rw [route_program_middle
    cutoff hcutoff steps,
    iterated_move_repeat]

end ORBlock
end TCTex
