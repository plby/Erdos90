-- Merged from JacobiIntegralPowerStrictTailCutoffOrderedOuterPacketBoundedDepthExpansion.lean

/-!
# Bounded strict-depth expansions for Hall-Witt local substitutions

One filtered local move packet emits its strict correction branch before its
retained branch.  Iterating the packet therefore has an exact ordered binary
depth schedule.  Below a fixed cutoff, every schedule entry at depth at least
the cutoff vanishes for a Hall-Witt current selected word.

This file records the resulting coefficient-independent bounded-depth
expansion without forgetting the order of occurrences.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace BDExp

open CWTrace
open WSTrace
open NPTail
open RMRecb
open TBProf
open OFProgra
open OTSubsti
open OTDecomp
open TODepth

/-- Repeated left bracketing by one selected word. -/
def iteratedLeftCommutator
    (selected : CWord Atom) :
    ℕ → CWord Atom → CWord Atom
  | 0, right =>
      right
  | depth + 1, right =>
      .commutator selected (iteratedLeftCommutator selected depth right)

/-- Literal iterated strict correction of a singleton remains a singleton. -/
lemma iterated_correction_singleton
    (selected right : CWord Atom) :
    ∀ depth : ℕ,
      iteratedMoveTrace selected depth [right] =
        [iteratedLeftCommutator selected depth right]
  | 0 => by
      rfl
  | depth + 1 => by
      rw [iteratedMoveTrace,
        iterated_correction_singleton selected right depth]
      rfl

/-- Filtered iterated strict correction of a singleton is the filtered
singleton of its repeated left bracket. -/
lemma iterated_below_singleton
    (cutoff depth : ℕ)
    (selected right : CWord Atom) :
    iteratedCutoffTrace cutoff selected depth
        (unitBelowTrace cutoff [right]) =
      unitBelowTrace cutoff
        [iteratedLeftCommutator selected depth right] := by
  rw [iterated_cutoff_below,
    iterated_correction_singleton]

/-- On a filtered singleton, one full local move is its strict branch followed
by its retained branch. -/
lemma cutoff_move_singleton
    (cutoff : ℕ)
    (selected right : CWord Atom) :
    cutoffMoveTrace cutoff selected (unitBelowTrace cutoff [right]) =
      cutoffCorrectionTrace cutoff selected
          (unitBelowTrace cutoff [right]) ++
        unitBelowTrace cutoff [right] := by
  by_cases hright : right.weight (fun _ => 1) < cutoff
  · simp [unitBelowTrace, hright, cutoffMoveTrace,
      cutoffCorrectionTrace,
      move_append_singleton
        cutoff selected right hright]
  · simp [unitBelowTrace, hright, cutoffMoveTrace,
      cutoffCorrectionTrace]

/-- Moving one repeatedly corrected singleton emits the next strict depth
before retaining its current depth. -/
lemma move_iterated_singleton
    (cutoff depth : ℕ)
    (selected right : CWord Atom) :
    cutoffMoveTrace cutoff selected
        (iteratedCutoffTrace cutoff selected depth
          (unitBelowTrace cutoff [right])) =
      iteratedCutoffTrace cutoff selected (depth + 1)
          (unitBelowTrace cutoff [right]) ++
        iteratedCutoffTrace cutoff selected depth
          (unitBelowTrace cutoff [right]) := by
  rw [iteratedCutoffTrace,
    iterated_below_singleton]
  exact
    cutoff_move_singleton cutoff selected
      (iteratedLeftCommutator selected depth right)

/-- The homogeneous local substitution distributes through a flattened
family of traces. -/
lemma cutoff_move_flat
    (cutoff : ℕ)
    (selected : CWord Atom)
    {α : Type*}
    (source : List α)
    (packetAt : α → List (CWord Atom)) :
    cutoffMoveTrace cutoff selected (source.flatMap packetAt) =
      source.flatMap fun item =>
        cutoffMoveTrace cutoff selected (packetAt item) := by
  simp [cutoffMoveTrace, List.flatMap_assoc]

/-- Ordered strict-depth schedule of a repeated two-branch local move. -/
def strictDepthSchedule : ℕ → List ℕ
  | 0 =>
      [0]
  | steps + 1 =>
      (strictDepthSchedule steps).flatMap fun depth =>
        [depth + 1, depth]

/-- Iterating one filtered singleton local packet has the exact ordered
strict-depth schedule. -/
lemma iterated_move_singleton
    (cutoff : ℕ)
    (selected right : CWord Atom) :
    ∀ steps : ℕ,
      iteratedCutoffMove cutoff selected steps
          (unitBelowTrace cutoff [right]) =
        (strictDepthSchedule steps).flatMap fun depth =>
          iteratedCutoffTrace cutoff selected depth
            (unitBelowTrace cutoff [right])
  | 0 => by
      simp [iteratedCutoffMove, strictDepthSchedule,
        iteratedCutoffTrace]
  | steps + 1 => by
      rw [iteratedCutoffMove,
        iterated_move_singleton
          cutoff selected right steps,
        cutoff_move_flat]
      simp [strictDepthSchedule,
        move_iterated_singleton,
        List.flatMap_assoc]

/-- A strict local branch at depth at least the cutoff vanishes for a
Hall-Witt current selected word. -/
lemma iterated_singleton_nil
    (cutoff depth : ℕ)
    (selected right : CWord Atom)
    (hselected :
      isFirstCurrent selected = true ∨
        isSecondCurrent selected = true)
    (hdepth : cutoff ≤ depth) :
    iteratedCutoffTrace cutoff selected depth
        (unitBelowTrace cutoff [right]) =
      [] := by
  apply
    iterated_below_nil
      0 cutoff selected hselected [right]
  · intro next _hnext
    exact Nat.zero_le (next.weight (fun _ => 1))
  · omega

/-- Removing strict depths at or above cutoff does not change a flattened
singleton expansion. -/
lemma filter_flat_trace
    (cutoff : ℕ)
    (selected right : CWord Atom)
    (hselected :
      isFirstCurrent selected = true ∨
        isSecondCurrent selected = true) :
    ∀ depths : List ℕ,
      (depths.filter fun depth =>
        decide (depth < cutoff)).flatMap (fun depth =>
          iteratedCutoffTrace cutoff selected depth
            (unitBelowTrace cutoff [right])) =
        depths.flatMap fun depth =>
        iteratedCutoffTrace cutoff selected depth
          (unitBelowTrace cutoff [right])
  | [] => by
      rfl
  | depth :: depths => by
      by_cases hdepth : depth < cutoff
      · simp [hdepth,
          filter_flat_trace cutoff selected
            right hselected depths]
      · have hnil :
            iteratedCutoffTrace cutoff selected depth
                (unitBelowTrace cutoff [right]) =
              [] :=
          iterated_singleton_nil
            cutoff depth selected right hselected (Nat.le_of_not_gt hdepth)
        simp [hdepth, hnil,
          filter_flat_trace cutoff selected
            right hselected depths]

/-- Removing strict depths at or above cutoff does not change the flattened
singleton depth-schedule expansion. -/
lemma filter_flat_iterated
    (cutoff steps : ℕ)
    (selected right : CWord Atom)
    (hselected :
      isFirstCurrent selected = true ∨
        isSecondCurrent selected = true) :
    ((strictDepthSchedule steps).filter fun depth =>
        decide (depth < cutoff)).flatMap (fun depth =>
          iteratedCutoffTrace cutoff selected depth
            (unitBelowTrace cutoff [right])) =
      (strictDepthSchedule steps).flatMap fun depth =>
        iteratedCutoffTrace cutoff selected depth
          (unitBelowTrace cutoff [right]) := by
  exact
    filter_flat_trace cutoff selected right
      hselected (strictDepthSchedule steps)

/-- The exact ordered local expansion has a coefficient-independent
strict-depth alphabet `Fin cutoff`. -/
lemma iterated_move_schedule
    (cutoff steps : ℕ)
    (selected right : CWord Atom)
    (hselected :
      isFirstCurrent selected = true ∨
        isSecondCurrent selected = true) :
    iteratedCutoffMove cutoff selected steps
        (unitBelowTrace cutoff [right]) =
      ((strictDepthSchedule steps).filter fun depth =>
          decide (depth < cutoff)).flatMap (fun depth =>
        iteratedCutoffTrace cutoff selected depth
          (unitBelowTrace cutoff [right])) := by
  rw [
    iterated_move_singleton]
  exact
    (filter_flat_iterated
      cutoff steps selected right hselected).symm

/-- Iterated homogeneous local substitution distributes over a flattened
family of source traces. -/
lemma iterated_move_flat
    (cutoff steps : ℕ)
    (selected : CWord Atom)
    {α : Type*}
    (source : List α)
    (packetAt : α → List (CWord Atom)) :
    iteratedCutoffMove cutoff selected steps (source.flatMap packetAt) =
      source.flatMap fun item =>
        iteratedCutoffMove cutoff selected steps (packetAt item) := by
  induction steps with
  | zero =>
      rfl
  | succ steps ih =>
      rw [iteratedCutoffMove, ih, cutoff_move_flat]
      rfl

/-- Filtering a trace below cutoff is the flattened family of its filtered
singletons. -/
lemma below_flat_singleton
    (cutoff : ℕ) :
    ∀ trace : List (CWord Atom),
      unitBelowTrace cutoff trace =
        trace.flatMap fun right =>
          unitBelowTrace cutoff [right]
  | [] => by
      rfl
  | right :: rights => by
      rw [show right :: rights = [right] ++ rights by rfl,
        unit_below_append,
        below_flat_singleton cutoff rights]
      rfl

/-- The ordered bounded strict-depth expansion extends pointwise across an
arbitrary source trace. -/
lemma iterated_below_schedule
    (cutoff steps : ℕ)
    (selected : CWord Atom)
    (hselected :
      isFirstCurrent selected = true ∨
        isSecondCurrent selected = true)
    (trace : List (CWord Atom)) :
    iteratedCutoffMove cutoff selected steps
        (unitBelowTrace cutoff trace) =
      trace.flatMap fun right =>
        ((strictDepthSchedule steps).filter fun depth =>
            decide (depth < cutoff)).flatMap (fun depth =>
          iteratedCutoffTrace cutoff selected depth
            (unitBelowTrace cutoff [right])) := by
  rw [below_flat_singleton,
    iterated_move_flat]
  apply List.flatMap_congr
  intro right _hright
  exact
    iterated_move_schedule
      cutoff steps selected right hselected

end BDExp
end TCTex
end Submission

