    (cutoff : ℕ) :
    SignedCutoffProfile :=
  profileFormalPredecessor
    (negativeFullBound cutoff)
      (negativeEmptyEndpoint cutoff)

/-- Positive fixed-affine cancellation of the formal-predecessor signed
orbit-swap profile. -/
