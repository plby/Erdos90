/-!
# Diagonal repetition of bounded-depth crossing schedules

The middle Hall-Witt first-route program repeats a carried block `steps`
times, while the block itself is the depth-`steps` homogeneous orbit of one
singleton.  Thus the crossed second-route schedule is a diagonal repetition
`S(steps) ^ steps`, not repetition of one fixed schedule.

Regroup ordered subsequences by the copies contributing a nonempty subword.
For a target of length `r`, only at most `r` copies can contribute.  The
resulting finite sum has coefficients `choose steps copies` and fixed-copy
active-block coordinates.  This gives polynomial bounded-term data for the
diagonally repeated schedule.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace DDRepeat

open WSTrace
open NPTail
open TACompos
open STSched
open SSExp
open STState
open STClos
open DCSched
open BSRec
open ASTri
open ASDecomp
open DSPoly
open DTPoly
open BDPoly
open BTRepeat

/-- Repeating a schedule is flattening a replicated family of copies. -/
lemma repeat_flat_replicate
    (schedule : List SRTrans) :
    ∀ copies : ℕ,
      repeatTransitionSchedule schedule copies =
        (List.replicate copies ()).flatMap fun _ => schedule
  | 0 => by
      rfl
  | copies + 1 => by
      rw [repeatTransitionSchedule, List.replicate_succ, List.flatMap_cons,
        repeat_flat_replicate schedule copies]

/-- Every list of unit values is determined by its length. -/
lemma unit_replicate_length :
    ∀ source : List Unit,
      source = List.replicate source.length ()
  | [] => by
      rfl
  | () :: source => by
      rw [List.length_cons, List.replicate_succ,
        ← unit_replicate_length source]

/-- Summing a flattened family is summing its member sums. -/
lemma sum_flatMap
    {α M : Type*}
    [AddMonoid M]
    (family : α → List M) :
    ∀ source : List α,
      (source.flatMap family).sum =
        (source.map fun item => (family item).sum).sum
  | [] => by
      rfl
  | item :: source => by
      rw [List.flatMap_cons, List.sum_append, List.map_cons, List.sum_cons,
        sum_flatMap family source]

/-- Fixed-copy active-block contribution to one ordered subsequence
coordinate. -/
def repeatedSubsequenceMultiplicity
    (schedule : List SRTrans)
    (copies : ℕ)
    (target : List SRTrans) :
    ℕ :=
  (activeSubsequenceExpansions (fun _ : Unit => schedule)
    (List.replicate copies ())).count target

/-- The active-block contribution depends only on the number of unit source
copies. -/
lemma subsequence_expansions_unit
    (schedule : List SRTrans)
    (source : List Unit)
    (target : List SRTrans) :
    (activeSubsequenceExpansions (fun _ : Unit => schedule)
      source).count target =
        repeatedSubsequenceMultiplicity schedule source.length
          target := by
  rw [unit_replicate_length source]
  simp [repeatedSubsequenceMultiplicity]

/-- Too many active copies cannot emit a shorter transition word. -/
lemma repeated_subsequence_length
    (schedule : List SRTrans)
    (copies : ℕ)
    (target : List SRTrans)
    (hlength : target.length < copies) :
    repeatedSubsequenceMultiplicity schedule copies target =
      0 := by
  apply List.count_eq_zero.mpr
  intro htarget
  have hle :=
    length_subsequence_expansions
      (fun _ : Unit => schedule) (List.replicate copies ()) target htarget
  simp only [List.length_replicate] at hle
  omega

/-- Regroup a sum over all sublists by their lengths. -/
lemma sublists_range_len
    {α M : Type*}
    [AddCommMonoid M]
    (source : List α)
    (value : List α → M) :
    (source.sublists.map value).sum =
      ((List.range (source.length + 1)).flatMap fun length =>
        (source.sublistsLen length).map value).sum := by
  calc
    (source.sublists.map value).sum =
        (source.sublists'.map value).sum :=
      ((List.sublists_perm_sublists' source).map value).sum_eq
    _ =
        (((List.range (source.length + 1)).flatMap fun length =>
          source.sublistsLen length).map value).sum :=
      ((List.range_bind_sublistsLen_perm source).map value).sum_eq.symm
    _ =
        ((List.range (source.length + 1)).flatMap fun length =>
          (source.sublistsLen length).map value).sum := by
      rw [List.map_flatMap]

/-- Summing a length-only value over fixed-length sublists produces a
binomial coefficient. -/
lemma sublists_len_length
    {α : Type*}
    (source : List α)
    (length : ℕ)
    (value : ℕ → ℕ) :
    ((source.sublistsLen length).map fun selected =>
      value selected.length).sum =
        source.length.choose length * value length := by
  rw [show
    (source.sublistsLen length).map (fun selected => value selected.length) =
      (source.sublistsLen length).map (fun _selected => value length) by
    apply List.map_congr_left
    intro selected hselected
    rw [List.length_of_sublistsLen hselected]]
  simp [List.length_sublistsLen]

/-- List and finset range sums agree. -/
lemma map_eq_range
    (limit : ℕ)
    (value : ℕ → ℕ) :
    ((List.range limit).map value).sum =
      ∑ index ∈ Finset.range limit, value index := by
  induction limit with
  | zero => simp
  | succ limit ih =>
      rw [List.sum_range_succ, Finset.sum_range_succ, ih]

/-- A length-only sum over sublists of a replicated unit list is the
corresponding finite binomial sum. -/
lemma sublists_replicate_length
    (copies : ℕ)
    (value : ℕ → ℕ) :
    (((List.replicate copies ()).sublists.map fun source =>
      value source.length).sum) =
        ∑ activeCopies ∈ Finset.range (copies + 1),
          copies.choose activeCopies * value activeCopies := by
  rw [sublists_range_len]
  simp only [List.length_replicate]
  rw [sum_flatMap]
  change
    ((List.range (copies + 1)).map fun activeCopies =>
      (((List.replicate copies ()).sublistsLen activeCopies).map fun source =>
        value source.length).sum).sum =
      _
  simp_rw [sublists_len_length]
  simpa only [List.length_replicate] using
    (map_eq_range (copies + 1)
      (fun activeCopies => copies.choose activeCopies * value activeCopies))

/-- Ordered subsequences of a repeated variable block are a finite binomial
sum of fixed-active-copy contributions. -/
lemma subsequence_repeat_range
    (schedule : List SRTrans)
    (copies : ℕ)
    (target : List SRTrans) :
    orderedSubsequenceMultiplicity target
        (repeatTransitionSchedule schedule copies) =
      ∑ activeCopies ∈ Finset.range (copies + 1),
        copies.choose activeCopies *
          repeatedSubsequenceMultiplicity schedule activeCopies
            target := by
  rw [repeat_flat_replicate,
    subsequence_multiplicity_flat,
    count_subsequence_expansions]
  rw [show
    (((List.replicate copies ()).sublists.map fun source =>
      (activeSubsequenceExpansions (fun _ : Unit => schedule)
        source).count target).sum) =
      (((List.replicate copies ()).sublists.map fun source =>
        repeatedSubsequenceMultiplicity schedule source.length
          target).sum) by
    apply congrArg List.sum
    apply List.map_congr_left
    intro source _hsource
    exact subsequence_expansions_unit schedule source target]
  exact
    sublists_replicate_length copies
      (fun activeCopies =>
        repeatedSubsequenceMultiplicity schedule activeCopies
          target)

/-- The dynamic binomial sum may be truncated at the target length because
larger active-copy counts vanish. -/
lemma repeat_target_length
    (schedule : List SRTrans)
    (copies : ℕ)
    (target : List SRTrans) :
    orderedSubsequenceMultiplicity target
        (repeatTransitionSchedule schedule copies) =
      ∑ activeCopies ∈ Finset.range (target.length + 1),
        copies.choose activeCopies *
          repeatedSubsequenceMultiplicity schedule activeCopies
            target := by
  rw [subsequence_repeat_range]
  by_cases hcopies : copies ≤ target.length
  · apply Finset.sum_subset
    · intro activeCopies hactive
      exact Finset.mem_range.mpr
        ((Finset.mem_range.mp hactive).trans_le (Nat.succ_le_succ hcopies))
    · intro activeCopies hactiveTarget hactiveCopies
      have hcopiesLt : copies < activeCopies := by
        have := Finset.mem_range.mp hactiveTarget
        have hnot := hactiveCopies
        simp only [Finset.mem_range, not_lt] at hnot
        omega
      simp [Nat.choose_eq_zero_of_lt hcopiesLt]
  · apply Eq.symm
    apply Finset.sum_subset
    · intro activeCopies hactive
      exact Finset.mem_range.mpr
        ((Finset.mem_range.mp hactive).trans_le
          (Nat.succ_le_succ (Nat.le_of_not_ge hcopies)))
    · intro activeCopies hactiveCopies hactiveTarget
      have htargetLt : target.length < activeCopies := by
        have := Finset.mem_range.mp hactiveCopies
        have hnot := hactiveTarget
        simp only [Finset.mem_range, not_lt] at hnot
        omega
      rw [
        repeated_subsequence_length
          schedule activeCopies target htargetLt,
        mul_zero]

/-- Nonempty sublists of one bounded-depth crossing schedule have polynomial
multiplicity coordinates. -/
lemma count_nonempty_sublists
    (cutoff : ℕ)
    (outer selected right : CWord Atom)
    (target : List SRTrans) :
    IVMost
      (fun steps : ℕ =>
        ((nonemptySublists
          (depthCrossingSchedule cutoff outer selected right
            steps)).count target : ℤ))
      (target.length * cutoff + 1) := by
  by_cases htarget : target = []
  · subst target
    rw [show
      (fun steps : ℕ =>
        ((nonemptySublists
          (depthCrossingSchedule cutoff outer selected right
            steps)).count [] : ℤ)) =
          fun _steps : ℕ => 0 by
      funext steps
      norm_cast
      apply List.count_eq_zero.mpr
      intro hnil
      have hkeep := (List.mem_filter.mp hnil).2
      simp at hkeep]
    simpa using
      valued_most_constant 1 0
  · rw [show
      (fun steps : ℕ =>
        ((nonemptySublists
          (depthCrossingSchedule cutoff outer selected right
            steps)).count target : ℤ)) =
        fun steps : ℕ =>
          (orderedSubsequenceMultiplicity target
            (depthCrossingSchedule cutoff outer selected right
              steps) : ℤ) by
      funext steps
      simp [nonemptySublists, orderedSubsequenceMultiplicity, htarget]]
    exact
      subsequence_multiplicity_crossing
        cutoff outer selected right target

/-- Each fixed-active-copy contribution of the variable bounded-depth block
is polynomial. -/
lemma repeatedCrossingPoly
    (cutoff : ℕ)
    (outer selected right : CWord Atom) :
    ∀ (activeCopies : ℕ) (target : List SRTrans),
      IVMost
        (fun steps : ℕ =>
          (repeatedSubsequenceMultiplicity
            (depthCrossingSchedule cutoff outer selected right
              steps) activeCopies target : ℤ))
        (target.length * cutoff + activeCopies)
  | 0, target => by
      simpa [repeatedSubsequenceMultiplicity,
        activeSubsequenceExpansions] using
          valued_most_constant
            (target.length * cutoff) (([[]].count target : ℕ) : ℤ)
  | activeCopies + 1, target => by
      rw [show
        (fun steps : ℕ =>
          (repeatedSubsequenceMultiplicity
            (depthCrossingSchedule cutoff outer selected right
              steps) (activeCopies + 1) target : ℤ)) =
        fun steps : ℕ =>
          ∑ suffix ∈ target.tails.toFinset,
            ((nonemptySublists
              (depthCrossingSchedule cutoff outer selected right
                steps)).count
                (target.take (target.length - suffix.length)) : ℤ) *
              (repeatedSubsequenceMultiplicity
                (depthCrossingSchedule cutoff outer selected
                  right steps) activeCopies suffix : ℤ) by
        funext steps
        exact_mod_cast
          (by
            simpa [repeatedSubsequenceMultiplicity,
              List.replicate_succ, activeSubsequenceExpansions,
              Nat.mul_comm] using
              (count_flat_tails
                (nonemptySublists
                  (depthCrossingSchedule cutoff outer selected
                    right steps))
                (activeSubsequenceExpansions
                  (fun _ : Unit =>
                    depthCrossingSchedule cutoff outer selected
                      right steps)
                  (List.replicate activeCopies ()))
                target))]
      apply IVMost.finsetSum
      intro suffix hsuffix
      have hsuffixMem :
          suffix <:+ target :=
        (List.mem_tails suffix target).mp (List.mem_toFinset.mp hsuffix)
      rcases hsuffixMem with ⟨initial, rfl⟩
      simp only [List.length_append, Nat.add_sub_cancel_right,
        List.take_append_of_le_length (Nat.le_refl initial.length),
        List.take_length]
      exact
        TCTex.IVMost.mono
          (by simp [Nat.add_mul, Nat.add_assoc, Nat.add_left_comm,
            Nat.add_comm])
          (TCTex.IVMost.mul
            (count_nonempty_sublists
              cutoff outer selected right initial)
            (repeatedCrossingPoly
              cutoff outer selected right activeCopies suffix))

/-- Every transition-word subsequence coordinate of the diagonal repetition
of a bounded-depth crossing schedule is polynomial. -/
lemma multDiagonalPoly
    (cutoff : ℕ)
    (outer selected right : CWord Atom)
    (target : List SRTrans) :
    IVMost
      (fun steps : ℕ =>
        (orderedSubsequenceMultiplicity target
          (repeatTransitionSchedule
            (depthCrossingSchedule cutoff outer selected right
              steps) steps) : ℤ))
      (target.length * (cutoff + 2)) := by
  rw [show
    (fun steps : ℕ =>
      (orderedSubsequenceMultiplicity target
        (repeatTransitionSchedule
          (depthCrossingSchedule cutoff outer selected right
            steps) steps) : ℤ)) =
      fun steps : ℕ =>
        ∑ activeCopies ∈ Finset.range (target.length + 1),
          (steps.choose activeCopies : ℤ) *
            (repeatedSubsequenceMultiplicity
              (depthCrossingSchedule cutoff outer selected right
                steps) activeCopies target : ℤ) by
      funext steps
      exact_mod_cast
        repeat_target_length
          (depthCrossingSchedule cutoff outer selected right
            steps) steps target]
  apply IVMost.finsetSum
  intro activeCopies hactiveCopies
  have hactiveCopiesLe :
      activeCopies ≤ target.length :=
    Nat.lt_succ_iff.mp (Finset.mem_range.mp hactiveCopies)
  exact
    TCTex.IVMost.mono
      (by
        calc
          activeCopies + (target.length * cutoff + activeCopies) =
              target.length * cutoff + activeCopies * 2 := by omega
          _ ≤ target.length * cutoff + target.length * 2 :=
            Nat.add_le_add_left
              (Nat.mul_le_mul_right 2 hactiveCopiesLe)
              (target.length * cutoff)
          _ = target.length * (cutoff + 2) := by rw [Nat.mul_add])
      (TCTex.IVMost.mul
        (choose_valued_most activeCopies)
        (repeatedCrossingPoly
          cutoff outer selected right activeCopies target))

/-- Every transition in the diagonal repeated bounded-depth schedule belongs
to the fixed second-route transition alphabet. -/
lemma diagonal_crossing_schedule
    (cutoff steps : ℕ)
    (outer selected right : CWord Atom)
    (houter : isFirstCurrent outer = true)
    (transition : SRTrans)
    (htransition :
      transition ∈
        repeatTransitionSchedule
          (depthCrossingSchedule cutoff outer selected right
            steps) steps) :
    transition ∈ secondRouteAlphabet cutoff := by
  exact
    route_alphabet_schedule
      cutoff steps outer selected right houter transition
        (repeat_transition_schedule
          (depthCrossingSchedule cutoff outer selected right
            steps) steps transition htransition)

/-- Bounded ordered-term coordinates of the diagonal repeated bounded-depth
schedule are polynomial. -/
lemma constantCrossingPoly
    (cutoff : ℕ)
    (outer selected right : CWord Atom)
    (houter : isFirstCurrent outer = true)
    (target : OCTerm) :
    IVMost
      (fun steps : ℕ =>
        ((boundedConstantTerms cutoff
          (repeatTransitionSchedule
            (depthCrossingSchedule cutoff outer selected right
              steps) steps)).count target : ℤ))
      (cutoff * (cutoff + 2)) := by
  by_cases htarget : target.strictTransitions.length < cutoff
  · rw [show
      (fun steps : ℕ =>
        ((boundedConstantTerms cutoff
          (repeatTransitionSchedule
            (depthCrossingSchedule cutoff outer selected right
              steps) steps)).count target : ℤ)) =
        fun steps : ℕ =>
          ∑ producer ∈
              (secondRouteAlphabet cutoff).toFinset,
            if target.constant = (producer.affine cutoff).constant then
              (orderedSubsequenceMultiplicity
                (target.strictTransitions ++ [producer])
                (repeatTransitionSchedule
                  (depthCrossingSchedule cutoff outer selected
                    right steps) steps) : ℤ)
            else
              0 by
      funext steps
      exact_mod_cast
        constant_ite_producers
          cutoff (secondRouteAlphabet cutoff)
            (repeatTransitionSchedule
              (depthCrossingSchedule cutoff outer selected right
                steps) steps)
            (fun transition htransition =>
              diagonal_crossing_schedule
                cutoff steps outer selected right houter transition
                  htransition)
            target |>.trans (if_pos htarget)]
    apply IVMost.finsetSum
    intro producer _hproducer
    by_cases hconstant :
        target.constant = (producer.affine cutoff).constant
    · simp only [hconstant, ↓reduceIte]
      apply
        TCTex.IVMost.mono
      · change
          (target.strictTransitions.length + 1) * (cutoff + 2) ≤
            cutoff * (cutoff + 2)
        exact
          Nat.mul_le_mul_right (cutoff + 2) (Nat.succ_le_iff.mpr htarget)
      · simpa using
          multDiagonalPoly
            cutoff outer selected right
              (target.strictTransitions ++ [producer])
    · simp only [hconstant, ↓reduceIte]
      exact
        valued_most_constant
          (cutoff * (cutoff + 2)) 0
  · rw [show
      (fun steps : ℕ =>
        ((boundedConstantTerms cutoff
          (repeatTransitionSchedule
            (depthCrossingSchedule cutoff outer selected right
              steps) steps)).count target : ℤ)) =
          fun _steps : ℕ => 0 by
      funext steps
      exact_mod_cast
        constant_ite_producers
          cutoff (secondRouteAlphabet cutoff)
            (repeatTransitionSchedule
              (depthCrossingSchedule cutoff outer selected right
                steps) steps)
            (fun transition htransition =>
              diagonal_crossing_schedule
                cutoff steps outer selected right houter transition
                  htransition)
            target |>.trans (if_neg htarget)]
    exact
      valued_most_constant
        (cutoff * (cutoff + 2)) 0

/-- The diagonal repeated bounded-depth crossing schedule supplies common
bounded-term polynomial data. -/
lemma diagonal_repeated_crossing
    (cutoff : ℕ)
    (outer selected right : CWord Atom)
    (houter : isFirstCurrent outer = true) :
    BCDataa cutoff (cutoff * (cutoff + 2))
      (fun steps =>
        boundedConstantTerms cutoff
          (repeatTransitionSchedule
            (depthCrossingSchedule cutoff outer selected right
              steps) steps)) := by
  constructor
  · intro steps
    apply
      supported_alphabet_terms
    intro transition htransition
    exact
      diagonal_crossing_schedule
        cutoff steps outer selected right houter transition htransition
  · exact
      constantCrossingPoly
        cutoff outer selected right houter

