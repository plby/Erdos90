/-- A globally polynomial integer family automa satisfies the
missing-origin equation for its successor-precomposition. -/
lemma successor_polynomials_match
    {family : ℕ → ℤ}
    {degreeBound : ℕ}
    (hfamily :
      IVMost family degreeBound) :
    SuccessorPolynomialsOrigin family := by
  rcases hfamily with ⟨Q, _hQdegree, hQeval⟩
  intro P hPeval
  have hPQ :
      P = Q.comp (Polynomial.X + Polynomial.C 1) := by
    apply Polynomial.eq_of_infinite_eval_eq
    apply Set.infinite_of_injective_forall_mem
      (Nat.cast_injective :
        Function.Injective (fun steps : ℕ => (steps : ℚ)))
    intro steps
    change
      P.eval (steps : ℚ) =
        (Q.comp (Polynomial.X + Polynomial.C 1)).eval (steps : ℚ)
    rw [hPeval steps, Polynomial.eval_comp]
    simpa using (hQeval (steps + 1)).symm
  rw [hPQ, Polynomial.eval_comp]
  simpa using hQeval 0

