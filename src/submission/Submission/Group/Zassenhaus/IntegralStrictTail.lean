  apply Finset.sum_congr rfl
  intro word _hword
  change
    ((Multiset.mapAddMonoidHom value)
      (Int.toNat
          ((filteredSlotExpansion
            wt x y z cutoff word).eval coefficient) •
        ({word} : Multiset (CWord β)))).sum =
      _
  rw [map_nsmul]
  simpa using
    (map_nsmul Multiset.sumAddMonoidHom
      (Int.toNat
        ((filteredSlotExpansion
          wt x y z cutoff word).eval coefficient))
      ({value word} : Multiset M))

/--
Map the literal retained signed Hall-Witt trace into any additive commutative
monoid.  Exact physical-profile reconstruction supplies a finite recipe sum.
-/
lemma below_concrete_profile
    {β M : Type*}
    [DecidableEq β]
    [AddCommMonoid M]
    (wt : β → ℕ)
    (hwt : ∀ atom, 0 < wt atom)
    (x y z : CWord β)
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (coefficient : ℤ)
    (value : CWord β → M) :
    ((↑(signedBelowTrace wt x y z cutoff coefficient) :
        Multiset (CWord β)).map value).sum =
      ∑ word ∈
          (signedDeduplicatedVocabulary x y z cutoff).toFinset,
        Int.toNat
            ((filteredSlotExpansion
              wt x y z cutoff word).eval coefficient) •
          value word := by
  rw [← reconstructed_concrete_profile
    wt hwt x y z cutoff hcutoff coefficient]
  exact
    reconstructed_below_profile
      wt x y z cutoff coefficient value

/--
The fixed physical vocabulary contains inactive slots.  Send those slots to
zero; an active slot is sent to the lower-central associated-graded class of
its evaluated Hall-address word.
-/
noncomputable def addressBelowSlot
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (coefficient : ℤ)
    (word : CWord (HEAddres H)) :
    Additive
      (TBluepr.LowerGradedLayer
        (LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n)
        (x.weight PEAddres.weight +
            y.weight PEAddres.weight +
          z.weight PEAddres.weight)) :=
  if hword :
      word ∈
        signedBelowTrace PEAddres.weight
          x y z cutoff coefficient then
    TBluepr.lowerCentralClass _
      ⟨word.eval
          (PEAddres.freeLowerTruncation (n := n)),
        series_strict_trace
          x y z coefficient word (List.mem_filter.mp hword).1⟩
  else
    0

/-- On an actually retained factor, the zero-default class map is the literal
associated-graded class. -/
lemma address_below_slot
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (coefficient : ℤ)
    (word : CWord (HEAddres H))
    (hword :
      word ∈
        signedBelowTrace PEAddres.weight
          x y z cutoff coefficient) :
    addressBelowSlot
        (n := n) x y z cutoff coefficient word =
      TBluepr.lowerCentralClass _
        ⟨word.eval
            (PEAddres.freeLowerTruncation
              (n := n)),
          series_strict_trace
            x y z coefficient word (List.mem_filter.mp hword).1⟩ := by
  simp [addressBelowSlot, hword]

/--
Attach each retained word to its proof that its evaluation belongs to the
expected lower-central layer.
-/
noncomputable def addressBelowTerms
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (coefficient : ℤ) :
    List
      (Subgroup.lowerCentralSeries
        (LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n)
        (x.weight PEAddres.weight +
            y.weight PEAddres.weight +
          z.weight PEAddres.weight)) :=
  (signedBelowTrace PEAddres.weight
    x y z cutoff coefficient).attach.map fun entry =>
      ⟨entry.1.eval
          (PEAddres.freeLowerTruncation (n := n)),
        series_strict_trace
          x y z coefficient entry.1 (List.mem_filter.mp entry.2).1⟩

/--
The additive class list of attached retained factors is the list obtained by
mapping the fixed zero-default physical-slot class over the retained words.
-/
lemma address_below_terms
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (coefficient : ℤ) :
    (addressBelowTerms
        (n := n) x y z cutoff coefficient).map
      (TBluepr.lowerCentralClass
        (x.weight PEAddres.weight +
            y.weight PEAddres.weight +
          z.weight PEAddres.weight)) =
      (signedBelowTrace PEAddres.weight
        x y z cutoff coefficient).map
          (addressBelowSlot
            (n := n) x y z cutoff coefficient) := by
  unfold addressBelowTerms
  simp only [List.map_map]
  conv_rhs => rw [← List.attach_map_val]
  apply List.map_congr_left
  intro entry _hentry
  exact
    (address_below_slot
      (n := n) x y z cutoff coefficient entry.1 entry.2).symm

/--
The associated-graded class of the ordered retained product is the explicit
finite concrete-recipe sum.  This is the precise boundary at which physical
multiset reconstruction may safely forget packet order.
-/
lemma lower_terms_profile
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (coefficient : ℤ) :
    TBluepr.lowerCentralClass
        (x.weight PEAddres.weight +
            y.weight PEAddres.weight +
          z.weight PEAddres.weight)
        (addressBelowTerms
          (n := n) x y z cutoff coefficient).prod =
      ∑ word ∈
          (signedDeduplicatedVocabulary x y z cutoff).toFinset,
        Int.toNat
            ((filteredSlotExpansion
              PEAddres.weight
              x y z cutoff word).eval coefficient) •
          addressBelowSlot
            (n := n) x y z cutoff coefficient word := by
  rw [lower_central_prod,
    address_below_terms]
  change
    ((↑(signedBelowTrace PEAddres.weight
      x y z cutoff coefficient) :
        Multiset (CWord (HEAddres H))).map
      (addressBelowSlot
        (n := n) x y z cutoff coefficient)).sum =
      _
  exact
    below_concrete_profile
      PEAddres.weight PEAddres.weight_pos
        x y z cutoff hcutoff coefficient
          (addressBelowSlot
            (n := n) x y z cutoff coefficient)

end
  SAGraded
end TCTex
end Submission

