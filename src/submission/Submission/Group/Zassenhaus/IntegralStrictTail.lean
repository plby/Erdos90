/-- The finite Newton-coefficient condition asserting that the polynomial
selected by the positive-input values of `f` vanishes at formal predecessor
input `-1`. -/
def SuccessorAlternatingVanishes
    (degreeBound : ℕ)
    (f : ℕ → ℤ) :
    Prop :=
  ∑ k ∈ Finset.range (degreeBound + 1),
      natBinomialCoefficient (fun steps : ℕ => f (steps + 1)) k *
        (-1 : ℤ) ^ k = 0

/-- For a polynomial successor-precomposition, vanishing at `-1` is exactly
the finite alternating Newton-coefficient identity. -/
lemma vanish_alternating_vanishes
    {degreeBound : ℕ}
    {f : ℕ → ℤ}
    (hsucc :
      IVMost
        (fun steps : ℕ => f (steps + 1)) degreeBound) :
    SuccessorVanishNeg f ↔
      SuccessorAlternatingVanishes degreeBound f := by
  let g : ℕ → ℤ := fun steps => f (steps + 1)
  let Q : Polynomial ℚ := natBinomialExpansion g degreeBound
  have hQeval :
      ∀ steps : ℕ, Q.eval (steps : ℚ) = (f (steps + 1) : ℚ) := by
    intro steps
    dsimp only [Q]
    rw [binomial_expansion_polynomial]
    norm_cast
    exact (hsucc.nat_binomial_basisexpansion steps).symm
  constructor
  · intro hvanish
    have hQnegOne := hvanish Q hQeval
    dsimp only [Q] at hQnegOne
    rw [binomial_expansion_neg] at hQnegOne
    exact_mod_cast hQnegOne
  · intro hsum P hPeval
    have hPQ : P = Q := by
      apply Polynomial.eq_of_infinite_eval_eq
      apply Set.infinite_of_injective_forall_mem
        (Nat.cast_injective :
          Function.Injective (fun steps : ℕ => (steps : ℚ)))
      intro steps
      change P.eval (steps : ℚ) = Q.eval (steps : ℚ)
      rw [hPeval steps, hQeval steps]
    rw [hPQ]
    dsimp only [Q]
    rw [binomial_expansion_neg]
    exact_mod_cast hsum

