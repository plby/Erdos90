/-!
# Finite-state outer-packet recurrences for Hall-Witt strict tails

The factored outer-packet schedule consists of one fixed packet-local prefix
followed by dynamic crossings over the previously emitted first-route trace.
Descend this schedule factorization to the fixed bounded-term multiplicity
vector.  The packet-local part becomes one fixed finite-state schedule
operator; the sole dynamic input is the bounded state of the crossing list.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace OFState

open WSTrace
open WHNorm
open WNTrace
open NPTail
open RMRecb
open ASFilt
open OFProgra
open OFProgra.FRProgra
open TOFact
open OTSched
open STSched
open SSExp
open STRec
open STState

/-- Every transition in a packet-local outer prefix belongs to the fixed
cutoff-dependent transition alphabet. -/
lemma route_alphabet_prefix
    (cutoff : ℕ)
    (before : List (CWord Atom))
    (selected : CWord Atom)
    (suffix : List (CWord Atom))
    (hselected : isFirstCurrent selected = true)
    (transition : SRTrans)
    (htransition :
      transition ∈
        fixedTransitionPrefix cutoff before selected suffix) :
    transition ∈ secondRouteAlphabet cutoff := by
  unfold fixedTransitionPrefix at htransition
  rw [List.mem_append] at htransition
  rcases htransition with htransition | htransition
  · rcases List.mem_map.mp htransition with ⟨word, hword, rfl⟩
    exact
      route_alphabet_retained cutoff word
        (ordered_vocabulary_below
          cutoff before word hword)
  · rcases List.mem_map.mp htransition with ⟨word, hword, rfl⟩
    exact
      transition_alphabet_crossed cutoff selected word
        hselected
        (ordered_vocabulary_below
          cutoff suffix word hword)

/-- Every crossing over an emitted program trace belongs to the fixed
transition alphabet when its moved word is first-family current. -/
lemma route_alphabet_crossed
    (cutoff : ℕ)
    (selected : CWord Atom)
    (hselected : isFirstCurrent selected = true)
    (program : FRProgra)
    (transition : SRTrans)
    (htransition :
      transition ∈
        (program.trace cutoff).map (SRTrans.crossed selected)) :
    transition ∈ secondRouteAlphabet cutoff := by
  rcases List.mem_map.mp htransition with ⟨word, hword, rfl⟩
  exact
    transition_alphabet_crossed cutoff selected word
      hselected
      (ordered_vocabulary_program
        cutoff program word hword)

/-- The bounded-term multiplicity vector of one more factored outer-packet
iteration is obtained by applying a fixed packet-local finite-state operator
to the dynamic crossing state of the previous trace. -/
lemma vector_iterate_prepend
    (cutoff : ℕ)
    (packet before suffix : List (CWord Atom))
    (selected : CWord Atom)
    (hpacket : packet = before ++ [selected] ++ suffix)
    (hselected : isFirstCurrent selected = true)
    (hbefore : ∀ word ∈ before, isFirstCurrent word ≠ true)
    (hsuffix : ∀ word ∈ suffix, isFirstCurrent word ≠ true)
    (steps : ℕ)
    (tail : FRProgra) :
    boundedConstantVector cutoff
        (boundedConstantTerms cutoff
          (transitionSchedule cutoff
            (iteratePrepend cutoff isFirstCurrent packet (steps + 1) tail))) =
      boundedConstantOperator cutoff
        (fixedTransitionPrefix cutoff before selected suffix)
        (boundedConstantVector cutoff
          (boundedConstantTerms cutoff
            (((iteratePrepend cutoff isFirstCurrent packet steps tail).trace
              cutoff).map (SRTrans.crossed selected)))) := by
  rw [
    transition_prepend_append
      cutoff packet before suffix selected hpacket hselected hbefore hsuffix
        steps tail,
    constant_terms_append]
  symm
  apply schedule_operator_vector
  · intro transition htransition
    exact
      route_alphabet_prefix
        cutoff before selected suffix hselected transition htransition
  · apply
      supported_alphabet_terms
    intro transition htransition
    exact
      route_alphabet_crossed
        cutoff selected hselected
          (iteratePrepend cutoff isFirstCurrent packet steps tail)
            transition htransition

/-- The positive normalized outer-packet recurrence on finite bounded-term
multiplicity vectors. -/
lemma iterate_prepend_positive
    (cutoff steps : ℕ)
    (tail : FRProgra) :
    boundedConstantVector cutoff
        (boundedConstantTerms cutoff
          (transitionSchedule cutoff
            (iteratePrepend cutoff isFirstCurrent
              WNTrace.trace (steps + 1) tail))) =
      boundedConstantOperator cutoff
        (positiveFixedPrefix cutoff)
        (boundedConstantVector cutoff
          (boundedConstantTerms cutoff
            (((iteratePrepend cutoff isFirstCurrent
              WNTrace.trace steps tail).trace cutoff).map
                (SRTrans.crossed
                  firstConventionalInverse)))) := by
  apply
    vector_iterate_prepend
      cutoff WNTrace.trace
        positiveOuterFactorization.before
          positiveOuterFactorization.suffix
            firstConventionalInverse
  · exact positiveOuterFactorization.packet_eq
  · simp
  · exact positiveOuterFactorization.before_not_current
  · exact positiveOuterFactorization.suffix_not_current

/-- The negative inverted outer-packet recurrence on finite bounded-term
multiplicity vectors. -/
lemma bounded_iterate_prepend
    (cutoff steps : ℕ)
    (tail : FRProgra) :
    boundedConstantVector cutoff
        (boundedConstantTerms cutoff
          (transitionSchedule cutoff
            (iteratePrepend cutoff isFirstCurrent
              NNPower.inverseNormalizedTrace
                (steps + 1) tail))) =
      boundedConstantOperator cutoff
        (negativeFixedPrefix cutoff)
        (boundedConstantVector cutoff
          (boundedConstantTerms cutoff
            (((iteratePrepend cutoff isFirstCurrent
              NNPower.inverseNormalizedTrace
                steps tail).trace cutoff).map
                  (SRTrans.crossed firstConventionalWord)))) := by
  apply
    vector_iterate_prepend
      cutoff
        NNPower.inverseNormalizedTrace
          negativeOuterFactorization.before
            negativeOuterFactorization.suffix firstConventionalWord
  · exact negativeOuterFactorization.packet_eq
  · simp
  · exact negativeOuterFactorization.before_not_current
  · exact negativeOuterFactorization.suffix_not_current

end OFState
end TCTex
end Submission

