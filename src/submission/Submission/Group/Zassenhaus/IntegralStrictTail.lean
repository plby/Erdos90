/-- Signed bounded-term state of the negative emitted orbit prefix alone. -/
noncomputable def negativeSkewState
    (cutoff : ℕ) :
    BoundedCountState :=
  newtonEvaluationState
    (negativeFullBound cutoff)
    (fun steps =>
      boundedConstantState
        (boundedConstantTerms cutoff
          (boundedCrossingSchedule cutoff
            firstConventionalWord firstConventionalWord
              (negativeFilteredPrefix cutoff) steps)))

