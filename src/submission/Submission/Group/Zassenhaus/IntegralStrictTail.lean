-- EndpointRecipeAggregation.lean

/-!
# Aggregated endpoint recipes for complete Hall-Witt schedules

Individual bounded affine terms need not vanish at the missing origin.  Their
evaluated endpoint contributions can cancel.  This file keeps the finite
bounded-term decomposition while aggregating signed recipe evaluation after
each term has been evaluated in a cutoff-profile slot.

The resulting finite endpoint conditions are exactly the profile-level
alternating Newton boundaries.  They are therefore sufficient for global
strict-tail cutoff-profile polynomiality without imposing termwise origin
compatibility.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace TEAggreg

open WSTrace
open STVocabu
open TBProf
open TACompos
open OTSubsti
open TMRed
open SSExp
open STAlphab
open PMExp
open ASAdapt
open TNForm
open FTVector

/-- Newton coefficients preserve addition of integer-valued functions. -/
lemma nat_binomial_add
    (f g : ℕ → ℤ) :
    ∀ k : ℕ,
      natBinomialCoefficient (fun steps => f steps + g steps) k =
        natBinomialCoefficient f k + natBinomialCoefficient g k := by
  intro k
  induction k using Nat.strong_induction_on with
  | h k ih =>
      cases k with
      | zero =>
          simp [natBinomialCoefficient]
      | succ k =>
          simp only [natBinomialCoefficient]
          have hcoeff :
              ∀ i : Fin (k + 1),
                natBinomialCoefficient (fun steps => f steps + g steps) i =
                  natBinomialCoefficient f i +
                    natBinomialCoefficient g i := by
            intro i
            exact ih i i.isLt
          simp_rw [hcoeff, add_mul, Finset.sum_add_distrib]
          ring

/-- Newton coefficients preserve integer scalar multiplication. -/
lemma nat_binomial_coefficient
    (coefficient : ℤ)
    (f : ℕ → ℤ) :
    ∀ k : ℕ,
      natBinomialCoefficient
          (fun steps => coefficient * f steps) k =
        coefficient * natBinomialCoefficient f k := by
  intro k
  induction k using Nat.strong_induction_on with
  | h k ih =>
      cases k with
      | zero =>
          simp [natBinomialCoefficient]
      | succ k =>
          simp only [natBinomialCoefficient]
          have hcoeff :
              ∀ i : Fin (k + 1),
                natBinomialCoefficient
                    (fun steps => coefficient * f steps) i =
                  coefficient * natBinomialCoefficient f i := by
            intro i
            exact ih i i.isLt
          simp_rw [hcoeff, mul_assoc, ← Finset.mul_sum]
          ring

/-- Newton coefficients commute with finite integer linear combinations. -/
lemma nat_binomial_finset
    {ι : Type*}
    (indices : Finset ι)
    (coefficient : ι → ℤ)
    (family : ι → ℕ → ℤ)
    (k : ℕ) :
    natBinomialCoefficient
        (fun steps =>
          ∑ index ∈ indices, coefficient index * family index steps) k =
      ∑ index ∈ indices,
        coefficient index * natBinomialCoefficient (family index) k := by
  classical
  induction indices using Finset.induction_on with
  | empty =>
      simp [nat_binomial_family]
  | @insert index indices hindex ih =>
      simp only [Finset.sum_insert hindex]
      rw [nat_binomial_add, nat_binomial_coefficient, ih]

/-- Alternating Newton evaluation at `-1` commutes with finite integer linear
combinations. -/
lemma successor_alternating_finset
    {ι : Type*}
    (degreeBound : ℕ)
    (indices : Finset ι)
    (coefficient : ι → ℤ)
    (family : ι → ℕ → ℤ) :
    (∑ k ∈ Finset.range (degreeBound + 1),
        natBinomialCoefficient
            (fun steps =>
              ∑ index ∈ indices,
                coefficient index * family index steps) k *
          (-1 : ℤ) ^ k) =
      ∑ index ∈ indices,
        coefficient index *
          ∑ k ∈ Finset.range (degreeBound + 1),
            natBinomialCoefficient (family index) k * (-1 : ℤ) ^ k := by
  classical
  simp_rw [nat_binomial_finset]
  simp_rw [Finset.sum_mul]
  rw [Finset.sum_comm]
  apply Finset.sum_congr rfl
  intro index _hindex
  rw [Finset.mul_sum]
  apply Finset.sum_congr rfl
  intro k _hk
  ring

/-- Positive strict-tail slot counts are the weighted endpoint aggregation of
the all-natural complete schedule's bounded affine terms. -/
lemma natural_full_schedule
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (multiplicity : ℕ)
    (slot : CWord Atom) :
    (Multiset.count slot
        (cutoffProfile cutoff
          (NPTail.strictTrace
            multiplicity)) : ℤ) =
      ∑ term ∈ (boundedConstantAlphabet cutoff).toFinset,
        (Multiset.count slot (term.eval cutoff) : ℤ) *
          ((boundedConstantTerms cutoff
            (naturalFullSchedule cutoff multiplicity)).count
              term : ℤ) := by
  have hcount :=
    count_natural_alphabet
      cutoff hcutoff multiplicity slot
  simp only [naturalBoundedMultiplicity,
    transition_program_full
      cutoff hcutoff] at hcount
  calc
    (Multiset.count slot
        (cutoffProfile cutoff
          (NPTail.strictTrace
            multiplicity)) : ℤ) =
        (↑(∑ term ∈ (boundedConstantAlphabet cutoff).toFinset,
          (boundedConstantTerms cutoff
            (naturalFullSchedule cutoff multiplicity)).count term *
              Multiset.count slot (term.eval cutoff)) : ℤ) := by
      exact_mod_cast hcount
    _ = _ := by
      push_cast
      apply Finset.sum_congr rfl
      intro term _hterm
      ring

/-- Negative strict-tail slot counts are the weighted endpoint aggregation of
the all-natural complete schedule's bounded affine terms. -/
lemma int_full_schedule
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (multiplicity : ℕ)
    (slot : CWord Atom) :
    (Multiset.count slot
        (cutoffProfile cutoff
          (NNPower.strictTrace
            multiplicity)) : ℤ) =
      ∑ term ∈ (boundedConstantAlphabet cutoff).toFinset,
        (Multiset.count slot (term.eval cutoff) : ℤ) *
          ((boundedConstantTerms cutoff
            (negativeFullSchedule cutoff multiplicity)).count
              term : ℤ) := by
  have hcount :=
    count_negative_alphabet
      cutoff hcutoff multiplicity slot
  simp only [negativeBoundedMultiplicity,
    route_program_full
      cutoff hcutoff] at hcount
  calc
    (Multiset.count slot
        (cutoffProfile cutoff
          (NNPower.strictTrace
            multiplicity)) : ℤ) =
        (↑(∑ term ∈ (boundedConstantAlphabet cutoff).toFinset,
          (boundedConstantTerms cutoff
            (negativeFullSchedule cutoff multiplicity)).count term *
              Multiset.count slot (term.eval cutoff)) : ℤ) := by
      exact_mod_cast hcount
    _ = _ := by
      push_cast
      apply Finset.sum_congr rfl
      intro term _hterm
      ring

/-- Aggregate positive bounded-term signed recipes after evaluation at one
cutoff-profile slot. -/
noncomputable def naturalFullEndpoint
    (cutoff : ℕ)
    (slot : CWord Atom) :
    ℤ :=
  ∑ term ∈ (boundedConstantAlphabet cutoff).toFinset,
    (Multiset.count slot (term.eval cutoff) : ℤ) *
      (naturalFullExpansion cutoff term).evalInt (-1)

/-- Aggregate negative bounded-term signed recipes after evaluation at one
cutoff-profile slot. -/
noncomputable def negativeFullEndpoint
    (cutoff : ℕ)
    (slot : CWord Atom) :
    ℤ :=
  ∑ term ∈ (boundedConstantAlphabet cutoff).toFinset,
    (Multiset.count slot (term.eval cutoff) : ℤ) *
      (negativeFullExpansion cutoff term).evalInt (-1)

/-- Positive profile-slot signed evaluation is exactly the finite aggregate
of bounded-term signed recipe evaluations. -/
lemma natural_newton_alternating
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (slot : CWord Atom) :
    (∑ k ∈ Finset.range (naturalStrictBound cutoff + 1),
        natBinomialCoefficient
            (fun steps : ℕ =>
              (Multiset.count slot
                (cutoffProfile cutoff
                  (NPTail.strictTrace
                    (steps + 1))) : ℤ)) k *
          (-1 : ℤ) ^ k) =
      naturalFullEndpoint cutoff slot := by
  rw [show
    (fun steps : ℕ =>
      (Multiset.count slot
        (cutoffProfile cutoff
          (NPTail.strictTrace
            (steps + 1))) : ℤ)) =
      fun steps : ℕ =>
        ∑ term ∈ (boundedConstantAlphabet cutoff).toFinset,
          (Multiset.count slot (term.eval cutoff) : ℤ) *
            ((boundedConstantTerms cutoff
              (naturalFullSchedule cutoff (steps + 1))).count
                term : ℤ) by
    funext steps
    exact
      natural_full_schedule
        cutoff hcutoff (steps + 1) slot]
  rw [successor_alternating_finset]
  unfold naturalFullEndpoint
  apply Finset.sum_congr rfl
  intro term _hterm
  rw [naturalFullExpansion,
    BCExp.eval_int_binomial]
  simp [naturalStrictBound,
    naturalFullBound]

/-- Negative profile-slot signed evaluation is exactly the finite aggregate
of bounded-term signed recipe evaluations. -/
lemma successor_newton_alternating
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (slot : CWord Atom) :
    (∑ k ∈ Finset.range (negativeStrictBound cutoff + 1),
        natBinomialCoefficient
            (fun steps : ℕ =>
              (Multiset.count slot
                (cutoffProfile cutoff
                  (NNPower.strictTrace
                    (steps + 1))) : ℤ)) k *
          (-1 : ℤ) ^ k) =
      negativeFullEndpoint cutoff slot := by
  rw [show
    (fun steps : ℕ =>
      (Multiset.count slot
        (cutoffProfile cutoff
          (NNPower.strictTrace
            (steps + 1))) : ℤ)) =
      fun steps : ℕ =>
        ∑ term ∈ (boundedConstantAlphabet cutoff).toFinset,
          (Multiset.count slot (term.eval cutoff) : ℤ) *
            ((boundedConstantTerms cutoff
              (negativeFullSchedule cutoff (steps + 1))).count
                term : ℤ) by
    funext steps
    exact
      int_full_schedule
        cutoff hcutoff (steps + 1) slot]
  rw [successor_alternating_finset]
  unfold negativeFullEndpoint
  apply Finset.sum_congr rfl
  intro term _hterm
  rw [negativeFullExpansion,
    BCExp.eval_int_binomial]
  simp [negativeStrictBound,
    negativeFullBound]

/-- Every positive cutoff-profile slot has zero aggregate signed endpoint
recipe. -/
def NaturalSumsVanish
    (cutoff : ℕ) :
    Prop :=
  ∀ slot,
    naturalFullEndpoint cutoff slot = 0

/-- Every negative cutoff-profile slot has zero aggregate signed endpoint
recipe. -/
def NegativeSumsVanish
    (cutoff : ℕ) :
    Prop :=
  ∀ slot,
    negativeFullEndpoint cutoff slot = 0

/-- The positive profile-level Newton boundary is exactly aggregate signed
endpoint cancellation. -/
lemma successor_newton_vanish
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff) :
    NewtonAlternatingVanish
        (naturalStrictBound cutoff)
        (fun multiplicity =>
          cutoffProfile cutoff
            (NPTail.strictTrace multiplicity)) ↔
      NaturalSumsVanish
        cutoff := by
  constructor
  · intro hprofile slot
    have hslot := hprofile slot
    unfold SuccessorAlternatingVanishes at hslot
    rw [
      natural_newton_alternating
        cutoff hcutoff slot] at hslot
    exact hslot
  · intro hendpoint slot
    unfold SuccessorAlternatingVanishes
    rw [
      natural_newton_alternating
        cutoff hcutoff slot]
    exact hendpoint slot

/-- The negative profile-level Newton boundary is exactly aggregate signed
endpoint cancellation. -/
lemma successor_sums_vanish
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff) :
    NewtonAlternatingVanish
        (negativeStrictBound cutoff)
        (fun multiplicity =>
          cutoffProfile cutoff
            (NNPower.strictTrace
              multiplicity)) ↔
      NegativeSumsVanish
        cutoff := by
  constructor
  · intro hprofile slot
    have hslot := hprofile slot
    unfold SuccessorAlternatingVanishes at hslot
    rw [
      successor_newton_alternating
        cutoff hcutoff slot] at hslot
    exact hslot
  · intro hendpoint slot
    unfold SuccessorAlternatingVanishes
    rw [
      successor_newton_alternating
        cutoff hcutoff slot]
    exact hendpoint slot

/-- Aggregate positive endpoint cancellation discharges global positive
strict-tail cutoff-profile polynomiality. -/
lemma natural_sums_vanish
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (hendpoint :
      NaturalSumsVanish
        cutoff) :
    CPDataa cutoff
      (naturalStrictBound cutoff)
      (fun multiplicity =>
        cutoffProfile cutoff
          (NPTail.strictTrace multiplicity)) := by
  apply
    newton_sums_vanish
      cutoff hcutoff
  exact
    (successor_newton_vanish
      cutoff hcutoff).2 hendpoint

/-- Aggregate negative endpoint cancellation discharges global negative
strict-tail cutoff-profile polynomiality. -/
lemma endpoint_sums_vanish
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (hendpoint :
      NegativeSumsVanish
        cutoff) :
    CPDataa cutoff
      (negativeStrictBound cutoff)
      (fun multiplicity =>
        cutoffProfile cutoff
          (NNPower.strictTrace
            multiplicity)) := by
  apply
    alternating_sums_vanish
      cutoff hcutoff
  exact
    (successor_sums_vanish
      cutoff hcutoff).2 hendpoint

end TEAggreg
end TCTex
end Submission

