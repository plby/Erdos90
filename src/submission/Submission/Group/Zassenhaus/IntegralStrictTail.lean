          (boundedConstantVector cutoff [])) := by
  rw [crossing_vector_substitution]
  rw [crossing_flat_move
    cutoff firstConventionalInverse firstConventionalInverse (by simp)]

/-- One negative triangular trace-substitution step is a fixed crossed-prefix
operator applied to one named local crossing-substitution compiler. -/
lemma crossing_substitution_operator
    (cutoff steps : ℕ)
    (tail : FRProgra) :
