/-- Enlarging a Newton truncation bound does not change signed evaluation
once a polynomial witness already fits the smaller bound. -/
lemma newton_signed_evaluation
    (smallerBound largerBound : ℕ)
    (hle : smallerBound ≤ largerBound)
    (family : ℕ → ℤ)
    (hfamily :
      IVMost family smallerBound) :
    newtonSignedEvaluation largerBound family =
      newtonSignedEvaluation smallerBound family := by
  rcases hfamily with ⟨P, hPdegree, hPeval⟩
  have hsmall :
      P = natBinomialExpansion family smallerBound :=
    polynomial_binomial_expansion P hPdegree hPeval
  have hlarge :
      P = natBinomialExpansion family largerBound :=
    polynomial_binomial_expansion P (hPdegree.trans hle) hPeval
  have hneg :=
    congrArg (fun Q : Polynomial ℚ => Q.eval (-1))
      (hlarge.symm.trans hsmall)
  change
    (natBinomialExpansion family largerBound).eval (-1) =
      (natBinomialExpansion family smallerBound).eval (-1) at hneg
  rw [binomial_expansion_neg,
    binomial_expansion_neg] at hneg
  unfold newtonSignedEvaluation
  exact_mod_cast hneg

/-- The empty-subsequence seed theorem for the repeated nested suffix remains
valid at every larger Newton bound. -/
lemma newton_empty_seed
    (cutoff largerBound : ℕ)
    (crossed outer selected right : CWord Atom)
    (target : List SRTrans)
    (hle : target.length * (2 * cutoff + 3) ≤ largerBound) :
    newtonSignedEvaluation largerBound
        (fun steps : ℕ =>
          (orderedSubsequenceMultiplicity target
            (repeatTransitionSchedule
              (successorSkewCrossing cutoff
                crossed outer selected right steps) (steps + 1)) : ℤ)) =
      ([[]].count target : ℤ) := by
  rw [newton_signed_evaluation
    (target.length * (2 * cutoff + 3)) largerBound hle]
  · exact
      newton_schedule_seed
        cutoff crossed outer selected right target
  · exact
      multSuccessorPoly
        cutoff crossed outer selected right target

/-- At formal predecessor input `-1`, the cutoff-bounded affine-term state of
the successor-repeated nested suffix is the empty count state. -/
lemma newton_state_empty
    (cutoff : ℕ)
    (crossed outer selected right : CWord Atom)
    (hcrossed : isFirstCurrent crossed = true) :
    newtonEvaluationState (cutoff * (2 * cutoff + 3))
        (fun steps =>
          boundedConstantState
            (boundedConstantTerms cutoff
              (repeatTransitionSchedule
                (successorSkewCrossing cutoff
                  crossed outer selected right steps) (steps + 1)))) =
      boundedCountState [] := by
  funext target
  unfold newtonEvaluationState boundedConstantState
    boundedCountState
  simp only [List.count_nil]
  by_cases htarget : target.strictTransitions.length < cutoff
  · rw [show
      (fun steps : ℕ =>
        ((boundedConstantTerms cutoff
          (repeatTransitionSchedule
            (successorSkewCrossing cutoff
              crossed outer selected right steps) (steps + 1))).count
                target : ℤ)) =
        fun steps : ℕ =>
          ∑ producer ∈
              (secondRouteAlphabet cutoff).toFinset,
            if target.constant = (producer.affine cutoff).constant then
              (orderedSubsequenceMultiplicity
                (target.strictTransitions ++ [producer])
                (repeatTransitionSchedule
                  (successorSkewCrossing cutoff
                    crossed outer selected right steps) (steps + 1)) : ℤ)
            else
              0 by
      funext steps
      exact_mod_cast
        constant_ite_producers
          cutoff (secondRouteAlphabet cutoff)
            (repeatTransitionSchedule
              (successorSkewCrossing cutoff
                crossed outer selected right steps) (steps + 1))
            (fun transition htransition =>
              successor_skew_crossing
                cutoff steps crossed outer selected right hcrossed transition
                  htransition)
            target |>.trans (if_pos htarget)]
    rw [newton_evaluation_finset]
    apply Finset.sum_eq_zero
    intro producer _hproducer
    by_cases hconstant :
        target.constant = (producer.affine cutoff).constant
    · simp only [hconstant, ↓reduceIte]
      rw [
        newton_empty_seed
          cutoff (cutoff * (2 * cutoff + 3)) crossed outer selected right
            (target.strictTransitions ++ [producer])]
      · simp
      · simpa using
          Nat.mul_le_mul_right (2 * cutoff + 3)
            (Nat.succ_le_iff.mpr htarget)
    · simp only [hconstant, ↓reduceIte]
      exact newton_evaluation_const (cutoff * (2 * cutoff + 3)) 0
  · rw [show
      (fun steps : ℕ =>
        ((boundedConstantTerms cutoff
          (repeatTransitionSchedule
            (successorSkewCrossing cutoff
              crossed outer selected right steps) (steps + 1))).count
                target : ℤ)) =
          fun _steps : ℕ => 0 by
      funext steps
      exact_mod_cast
        constant_ite_producers
          cutoff (secondRouteAlphabet cutoff)
            (repeatTransitionSchedule
              (successorSkewCrossing cutoff
                crossed outer selected right steps) (steps + 1))
            (fun transition htransition =>
              successor_skew_crossing
                cutoff steps crossed outer selected right hcrossed transition
                  htransition)
            target |>.trans (if_neg htarget)]
    exact newton_evaluation_const (cutoff * (2 * cutoff + 3)) 0

