-- Merged from JacobiIntegralPowerStrictTail.lean

/-!
# Integral-power strict tails for the Jacobi packet

Dispatch the exact positive and negative natural-power Hall-Witt traces on an
integer exponent.  The resulting finite trace evaluates to the signed Jacobi
residual

`A⁻ᶻ Bᶻ C⁻ᶻ`

and every emitted factor has formal weight at least four.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace PSTail

open TCTex
open HACoeff
open CWTrace
open WSTrace
open WHNorm
open WNTrace
open WSTail

/-- Exact all-higher Jacobi trace for an arbitrary integer coefficient. -/
def strictTrace :
    ℤ → List (CWord Atom)
  | .ofNat multiplicity =>
      NPTail.strictTrace multiplicity
  | .negSucc multiplicity =>
      NNPower.strictTrace
        (multiplicity + 1)

/-- Exact strict-tail evaluation for every integral Jacobi coefficient. -/
lemma word_strict_trace
    {G : Type*}
    [Group G]
    (x y z : G)
    (coefficient : ℤ) :
    wordListEval (signedEval x y z) (strictTrace coefficient) =
      (originalWord.eval (signedEval x y z))⁻¹ ^ coefficient *
        (firstConventionalWord.eval (signedEval x y z) ^ coefficient *
          (secondConventionalWord.eval (signedEval x y z))⁻¹ ^
            coefficient) := by
  cases coefficient with
  | ofNat multiplicity =>
      simpa only [strictTrace, Int.ofNat_eq_natCast, zpow_natCast] using
        NPTail.word_strict_trace
          x y z multiplicity
  | negSucc multiplicity =>
      simpa only [strictTrace, zpow_negSucc, inv_pow, inv_inv] using
        NNPower.word_strict_trace
          x y z (multiplicity + 1)

/-- Every integral-power strict-tail factor has weight at least four. -/
lemma four_weight_strict
    (coefficient : ℤ)
    (word : CWord Atom)
    (hword : word ∈ strictTrace coefficient) :
    4 ≤ word.weight (fun _ => 1) := by
  cases coefficient with
  | ofNat multiplicity =>
      exact
        NPTail.four_weight_strict
          multiplicity word hword
  | negSucc multiplicity =>
      exact
        NNPower.four_weight_strict
          (multiplicity + 1) word hword

end PSTail
end TCTex
end Submission

-- Merged from JacobiIntegralPowerStrictTailSubstitution.lean

/-!
# Substitution into integral Hall-Witt strict tails

Substitute arbitrary commutator words for the six signed Hall-Witt labels.
The generic bound trace preserves exact evaluation by
`CWord.eval_bind`.  If each substituted atom has positive formal
weight, every bound trace factor still has weight at least four.

A signed three-word specialization maps inverse labels to root-swapped
commutator words and exposes the concrete residual

`[[x,y],z]⁻ᶻ [[x,z],y]ᶻ [[y,z],x]⁻ᶻ`.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace STSubsti

open HACoeff
open CWTrace
open WSTrace
open WHNorm
open PSTail

/-- Substitute arbitrary words for every label in an integral strict trace. -/
def bindTrace
    {β : Type*}
    (substitution : Atom → CWord β)
    (coefficient : ℤ) :
    List (CWord β) :=
  (strictTrace coefficient).map fun word => word.bind substitution

/-- Exact evaluation of a bound strict trace. -/
lemma word_bind_trace
    {β G : Type*}
    [Group G]
    (f : β → G)
    (substitution : Atom → CWord β)
    (coefficient : ℤ) :
    wordListEval f (bindTrace substitution coefficient) =
      wordListEval (fun atom => (substitution atom).eval f)
        (strictTrace coefficient) := by
  simp [bindTrace, wordListEval, List.map_map, Function.comp_def]

/-- Replacing every atom by a positive-weight word cannot decrease formal
weight. -/
lemma weight_bind_positive
    {α β : Type*}
    (wt : β → ℕ)
    (substitution : α → CWord β)
    (hsubstitution : ∀ atom, 0 < (substitution atom).weight wt) :
    ∀ word : CWord α,
      word.weight (fun _ => 1) ≤
        (word.bind substitution).weight wt
  | .atom atom => by
      simpa using hsubstitution atom
  | .commutator left right => by
      simp only [CWord.weight_commutator,
        CWord.bind_commutator]
      exact
        Nat.add_le_add
          (weight_bind_positive wt substitution
            hsubstitution left)
          (weight_bind_positive wt substitution
            hsubstitution right)

/-- Every bound strict-tail factor retains the unit-label lower bound four. -/
lemma four_bind_trace
    {β : Type*}
    (wt : β → ℕ)
    (substitution : Atom → CWord β)
    (hsubstitution : ∀ atom, 0 < (substitution atom).weight wt)
    (coefficient : ℤ)
    (word : CWord β)
    (hword : word ∈ bindTrace substitution coefficient) :
    4 ≤ word.weight wt := by
  rw [bindTrace] at hword
  rcases List.mem_map.mp hword with ⟨sourceWord, hsourceWord, rfl⟩
  exact
    (four_weight_strict coefficient sourceWord hsourceWord).trans
      (weight_bind_positive wt substitution hsubstitution
        sourceWord)

/-- Map the six signed labels to three words and their root-swapped inverses. -/
def signedWordSubstitution
    {β : Type*}
    (x y z : CWord β) :
    Atom → CWord β
  | .inl index =>
      Fin.cases x
        (fun index =>
          Fin.cases (rootSwapWord x)
            (fun index =>
              Fin.cases z (fun _ => rootSwapWord z) index)
            index)
        index
  | .inr index =>
      Fin.cases y (fun _ => rootSwapWord y) index

@[simp] lemma signed_substitution_x
    {β : Type*}
    (x y z : CWord β) :
    signedWordSubstitution x y z xAtom = x :=
  rfl

@[simp] lemma substitution_x_inv
    {β : Type*}
    (x y z : CWord β) :
    signedWordSubstitution x y z xInvAtom = rootSwapWord x :=
  rfl

@[simp] lemma signed_substitution_z
    {β : Type*}
    (x y z : CWord β) :
    signedWordSubstitution x y z zAtom = z :=
  rfl

@[simp] lemma substitution_z_inv
    {β : Type*}
    (x y z : CWord β) :
    signedWordSubstitution x y z zInvAtom = rootSwapWord z :=
  rfl

@[simp] lemma signed_substitution_y
    {β : Type*}
    (x y z : CWord β) :
    signedWordSubstitution x y z yAtom = y :=
  rfl

@[simp] lemma substitution_y_inv
    {β : Type*}
    (x y z : CWord β) :
    signedWordSubstitution x y z yInvAtom = rootSwapWord y :=
  rfl

/-- Positive atomic weights make every signed substituted label positive. -/
lemma signed_substitution_pos
    {β : Type*}
    (wt : β → ℕ)
    (hwt : ∀ atom, 0 < wt atom)
    (x y z : CWord β) :
    ∀ atom, 0 < (signedWordSubstitution x y z atom).weight wt := by
  intro atom
  rcases atom with atom | atom
  · fin_cases atom <;>
      simp [signedWordSubstitution,
        CWord.weight_pos wt hwt]
  · fin_cases atom <;>
      simp [signedWordSubstitution,
        CWord.weight_pos wt hwt]

/-- Evaluation of the signed word substitution is the signed value
substitution when the three words are genuine commutators. -/
lemma eval_signed_substitution
    {β G : Type*}
    [Group G]
    (f : β → G)
    (x y z : CWord β)
    (hx : ∃ left right, x = .commutator left right)
    (hy : ∃ left right, y = .commutator left right)
    (hz : ∃ left right, z = .commutator left right) :
    (fun atom => (signedWordSubstitution x y z atom).eval f) =
      signedEval (x.eval f) (y.eval f) (z.eval f) := by
  rcases hx with ⟨xLeft, xRight, rfl⟩
  rcases hy with ⟨yLeft, yRight, rfl⟩
  rcases hz with ⟨zLeft, zRight, rfl⟩
  funext atom
  rcases atom with atom | atom
  · refine Fin.cases rfl (fun atom => ?_) atom
    refine Fin.cases (root_swap_commutator f xLeft xRight)
      (fun atom => ?_) atom
    refine Fin.cases rfl (fun atom => ?_) atom
    exact Fin.cases (root_swap_commutator f zLeft zRight)
      (fun atom => Fin.elim0 atom) atom
  · refine Fin.cases rfl (fun atom => ?_) atom
    exact Fin.cases (root_swap_commutator f yLeft yRight)
      (fun atom => Fin.elim0 atom) atom

/-- Signed concrete specialization of the integral strict trace. -/
def signedStrictTrace
    {β : Type*}
    (x y z : CWord β)
    (coefficient : ℤ) :
    List (CWord β) :=
  bindTrace (signedWordSubstitution x y z) coefficient

/-- Exact evaluation of the signed concrete strict trace. -/
lemma signed_strict_trace
    {β G : Type*}
    [Group G]
    (f : β → G)
    (x y z : CWord β)
    (hx : ∃ left right, x = .commutator left right)
    (hy : ∃ left right, y = .commutator left right)
    (hz : ∃ left right, z = .commutator left right)
    (coefficient : ℤ) :
    wordListEval f (signedStrictTrace x y z coefficient) =
      ((CWord.commutator (.commutator x y) z).eval f)⁻¹ ^
          coefficient *
        ((CWord.commutator (.commutator x z) y).eval f ^
            coefficient *
          ((CWord.commutator (.commutator y z) x).eval f)⁻¹ ^
            coefficient) := by
  rw [signedStrictTrace, word_bind_trace,
    eval_signed_substitution f x y z hx hy hz,
    word_strict_trace]
  rfl

/-- Every signed concrete strict-tail factor has weight at least four. -/
lemma four_strict_trace
    {β : Type*}
    (wt : β → ℕ)
    (hwt : ∀ atom, 0 < wt atom)
    (x y z : CWord β)
    (coefficient : ℤ)
    (word : CWord β)
    (hword : word ∈ signedStrictTrace x y z coefficient) :
    4 ≤ word.weight wt := by
  exact
    four_bind_trace wt (signedWordSubstitution x y z)
      (signed_substitution_pos wt hwt x y z) coefficient word hword

end STSubsti
end TCTex
end Submission

-- Merged from JacobiIntegralPowerStrictTailMultidegree.lean

/-!
# Multidegree bounds for integral Hall-Witt strict tails

The strict Hall-Witt traces need a sharper bound after substitution than
unit-label weight at least four.  Track the three unsigned source
multidegrees separately.  Every retained strict factor contains each of
`x`, `y`, and `z`, and contains at least one additional signed label.

Consequently, substituting positive-weight words `x`, `y`, and `z` into any
integral strict-tail factor produces a word of weight at least

`weight(x) + weight(y) + weight(z) + 1`.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace STMultid

open HACoeff
open CWTrace
open WSTrace
open WHNorm
open WNTrace
open WSTail
open NPTail
open NNPower
open STSubsti

/-- Count occurrences of `x` and `x⁻¹`. -/
def xDegree :
    Atom → ℕ
  | .inl index =>
      Fin.cases 1 (fun index => Fin.cases 1 (fun _ => 0) index) index
  | .inr _ => 0

/-- Count occurrences of `y` and `y⁻¹`. -/
def yDegree :
    Atom → ℕ
  | .inl _ => 0
  | .inr _ => 1

/-- Count occurrences of `z` and `z⁻¹`. -/
def zDegree :
    Atom → ℕ
  | .inl index =>
      Fin.cases 0 (fun index => Fin.cases 0 (fun _ => 1) index) index
  | .inr _ => 0

/-- A strict factor contains all three unsigned letters and at least four
signed labels in total. -/
def StrictlyHigher
    (word : CWord Atom) :
    Prop :=
  1 ≤ word.weight xDegree ∧
    1 ≤ word.weight yDegree ∧
      1 ≤ word.weight zDegree ∧
        4 ≤ word.weight (fun _ => 1)

lemma x_normalized_trace :
    ∀ word ∈ WNTrace.trace,
      1 ≤ word.weight xDegree := by
  decide

lemma y_normalized_trace :
    ∀ word ∈ WNTrace.trace,
      1 ≤ word.weight yDegree := by
  decide

lemma z_normalized_trace :
    ∀ word ∈ WNTrace.trace,
      1 ≤ word.weight zDegree := by
  decide

/-- Any normalized Hall-Witt factor outside its two current heads is
multidegree-strict. -/
lemma strictly_higher_normalized
    (word : CWord Atom)
    (hword : word ∈ WNTrace.trace) :
    word = firstConventionalInverse ∨
      word = secondConventionalWord ∨
        StrictlyHigher word := by
  rcases
      conventional_or_second
        word hword with
    heq | heq | hfour
  · exact Or.inl heq
  · exact Or.inr (Or.inl heq)
  · exact
      Or.inr
        (Or.inr
          ⟨x_normalized_trace word hword,
            y_normalized_trace word hword,
            z_normalized_trace word hword, hfour⟩)

/-- The two first-family words have multidegree `(1, 1, 1)` and unit weight
three. -/
lemma degrees_first_true
    (word : CWord Atom)
    (hword : isFirstCurrent word = true) :
    word.weight xDegree = 1 ∧
      word.weight yDegree = 1 ∧
        word.weight zDegree = 1 ∧
          word.weight (fun _ => 1) = 3 := by
  simp only [isFirstCurrent, decide_eq_true_eq] at hword
  rcases hword with rfl | rfl <;>
    decide

/-- The two second-family words have multidegree `(1, 1, 1)` and unit weight
three. -/
lemma degrees_current_true
    (word : CWord Atom)
    (hword : isSecondCurrent word = true) :
    word.weight xDegree = 1 ∧
      word.weight yDegree = 1 ∧
        word.weight zDegree = 1 ∧
          word.weight (fun _ => 1) = 3 := by
  simp only [isSecondCurrent, decide_eq_true_eq] at hword
  rcases hword with rfl | rfl <;>
    decide

/-- A first-family swap against either a second-family word or an already
strict word is strict. -/
lemma strictly_current_or
    (left right : CWord Atom)
    (hleft : isFirstCurrent left = true)
    (hright : isSecondCurrent right = true ∨ StrictlyHigher right) :
    StrictlyHigher (.commutator left right) := by
  rcases degrees_first_true left hleft with
    ⟨hleftX, hleftY, hleftZ, hleftOne⟩
  rcases hright with hright | hright
  · rcases degrees_current_true right hright with
      ⟨hrightX, hrightY, hrightZ, hrightOne⟩
    simp only [StrictlyHigher, CWord.weight_commutator]
    omega
  · rcases hright with ⟨hrightX, hrightY, hrightZ, hrightOne⟩
    simp only [StrictlyHigher, CWord.weight_commutator]
    omega

/-- A second-family swap against an already strict word remains strict. -/
lemma strictly_higher_current
    (left right : CWord Atom)
    (hleft : isSecondCurrent left = true)
    (hright : StrictlyHigher right) :
    StrictlyHigher (.commutator left right) := by
  rcases degrees_current_true left hleft with
    ⟨hleftX, hleftY, hleftZ, hleftOne⟩
  rcases hright with ⟨hrightX, hrightY, hrightZ, hrightOne⟩
  simp only [StrictlyHigher, CWord.weight_commutator]
  omega

/-- Every positive natural residual source belongs to one current family or
is multidegree-strict. -/
lemma current_strictly_higher
    (multiplicity : ℕ)
    (word : CWord Atom)
    (hword :
      word ∈
        NPTail.naturalResidualTrace
          multiplicity) :
    isFirstCurrent word = true ∨
      isSecondCurrent word = true ∨
        StrictlyHigher word := by
  simp only [NPTail.naturalResidualTrace,
    List.mem_append] at hword
  rcases hword with hrest | hsecond
  · rcases hrest with htrace | hfirst
    · have htrace' := repeat_trace htrace
      rcases
          strictly_higher_normalized
            word htrace' with
        rfl | rfl | hstrict
      · exact Or.inl (by simp)
      · exact Or.inr (Or.inl (by simp))
      · exact Or.inr (Or.inr hstrict)
    · have heq : word = firstConventionalWord :=
        (List.mem_replicate.mp hfirst).2
      subst word
      exact Or.inl (by simp)
  · have heq : word = secondConventionalInverse :=
      (List.mem_replicate.mp hsecond).2
    subst word
    exact Or.inr (Or.inl (by simp))

/-- After the first positive pass, retained words are second-family or
strict. -/
lemma or_strictly_routed
    (multiplicity : ℕ)
    (word : CWord Atom)
    (hword :
      word ∈
        (NPTail.firstRouted multiplicity).1) :
    isSecondCurrent word = true ∨ StrictlyHigher word := by
  exact
    property_stable_fst
      (fun word => isSecondCurrent word = true ∨ StrictlyHigher word)
      isFirstCurrent
      (NPTail.naturalResidualTrace multiplicity)
      (fun source hsource hsourceFirst => by
        rcases
            current_strictly_higher
              multiplicity source hsource with
          hfirst | hsecond | hstrict
        · rw [hfirst] at hsourceFirst
          contradiction
        · exact Or.inl hsecond
        · exact Or.inr hstrict)
      (fun left right hleft hright =>
        Or.inr
          (strictly_current_or
            left right hleft hright))
      word hword

/-- Every positive natural strict-tail occurrence is multidegree-strict. -/
lemma strictly_higher_positive
    (multiplicity : ℕ)
    (word : CWord Atom)
    (hword :
      word ∈ NPTail.strictTrace multiplicity) :
    StrictlyHigher word := by
  rw [NPTail.strictTrace] at hword
  exact
    property_stable_fst StrictlyHigher isSecondCurrent
      (NPTail.firstRouted multiplicity).1
      (fun source hsource hsourceSecond => by
        rcases
            or_strictly_routed
              multiplicity source hsource with
          hsecond | hstrict
        · rw [hsecond] at hsourceSecond
          contradiction
        · exact hstrict)
      strictly_higher_current
      word hword

/-- Inverting the normalized Hall-Witt trace preserves its three positive
unsigned multidegrees. -/
lemma inverse_normalized_trace
    (degree : Atom → ℕ)
    (hdegree :
      ∀ word ∈ WNTrace.trace,
        1 ≤ word.weight degree)
    (word : CWord Atom)
    (hword :
      word ∈
        NNPower.inverseNormalizedTrace) :
    1 ≤ word.weight degree := by
  rcases
      NNPower.source_inverse_trace
        hword with
    ⟨sourceWord, hsourceWord, rfl⟩
  simpa only [weight_root_swap] using hdegree sourceWord hsourceWord

/-- Every inverted normalized factor outside its two current heads is
multidegree-strict. -/
lemma or_strictly_normalized
    (word : CWord Atom)
    (hword :
      word ∈
        NNPower.inverseNormalizedTrace) :
    word = firstConventionalWord ∨
      word = secondConventionalInverse ∨
        StrictlyHigher word := by
  rcases
      current_or_normalized
        word hword with
    heq | heq | hfour
  · exact Or.inl heq
  · exact Or.inr (Or.inl heq)
  · exact
      Or.inr
        (Or.inr
          ⟨inverse_normalized_trace xDegree
              x_normalized_trace word hword,
            inverse_normalized_trace yDegree
              y_normalized_trace word hword,
            inverse_normalized_trace zDegree
              z_normalized_trace word hword,
            hfour⟩)

/-- Every negative natural residual source belongs to one current family or
is multidegree-strict. -/
lemma current_or_strictly
    (multiplicity : ℕ)
    (word : CWord Atom)
    (hword :
      word ∈
        NNPower.naturalResidualTrace
          multiplicity) :
    isFirstCurrent word = true ∨
      isSecondCurrent word = true ∨
        StrictlyHigher word := by
  simp only [NNPower.naturalResidualTrace,
    List.mem_append] at hword
  rcases hword with hrest | hsecond
  · rcases hrest with htrace | hfirst
    · have htrace' := repeat_trace htrace
      rcases
          or_strictly_normalized
            word htrace' with
        rfl | rfl | hstrict
      · exact Or.inl (by simp)
      · exact Or.inr (Or.inl (by simp))
      · exact Or.inr (Or.inr hstrict)
    · have heq : word = firstConventionalInverse :=
        (List.mem_replicate.mp hfirst).2
      subst word
      exact Or.inl (by simp)
  · have heq : word = secondConventionalWord :=
      (List.mem_replicate.mp hsecond).2
    subst word
    exact Or.inr (Or.inl (by simp))

/-- After the first negative pass, retained words are second-family or
strict. -/
lemma current_strictly_routed
    (multiplicity : ℕ)
    (word : CWord Atom)
    (hword :
      word ∈
        (NNPower.firstRouted
          multiplicity).1) :
    isSecondCurrent word = true ∨ StrictlyHigher word := by
  exact
    property_stable_fst
      (fun word => isSecondCurrent word = true ∨ StrictlyHigher word)
      isFirstCurrent
      (NNPower.naturalResidualTrace
        multiplicity)
      (fun source hsource hsourceFirst => by
        rcases
            current_or_strictly
              multiplicity source hsource with
          hfirst | hsecond | hstrict
        · rw [hfirst] at hsourceFirst
          contradiction
        · exact Or.inl hsecond
        · exact Or.inr hstrict)
      (fun left right hleft hright =>
        Or.inr
          (strictly_current_or
            left right hleft hright))
      word hword

/-- Every negative natural strict-tail occurrence is multidegree-strict. -/
lemma strictly_higher_negative
    (multiplicity : ℕ)
    (word : CWord Atom)
    (hword :
      word ∈
        NNPower.strictTrace
          multiplicity) :
    StrictlyHigher word := by
  rw [NNPower.strictTrace] at hword
  exact
    property_stable_fst StrictlyHigher isSecondCurrent
      (NNPower.firstRouted multiplicity).1
      (fun source hsource hsourceSecond => by
        rcases
            current_strictly_routed
              multiplicity source hsource with
          hsecond | hstrict
        · rw [hsecond] at hsourceSecond
          contradiction
        · exact hstrict)
      strictly_higher_current
      word hword

/-- Every integral strict-tail occurrence is multidegree-strict. -/
lemma strictly_higher_strict
    (coefficient : ℤ)
    (word : CWord Atom)
    (hword :
      word ∈ PSTail.strictTrace coefficient) :
    StrictlyHigher word := by
  cases coefficient with
  | ofNat multiplicity =>
      exact strictly_higher_positive multiplicity word hword
  | negSucc multiplicity =>
      exact
        strictly_higher_negative (multiplicity + 1) word
          hword

/-- Combine the three unsigned multidegrees with chosen source weights. -/
def signedWeight
    (xWeight yWeight zWeight : ℕ)
    (atom : Atom) :
    ℕ :=
  xDegree atom * xWeight +
    yDegree atom * yWeight +
      zDegree atom * zWeight

@[simp] lemma signedWeight_x
    (xWeight yWeight zWeight : ℕ) :
    signedWeight xWeight yWeight zWeight xAtom = xWeight := by
  simp only [signedWeight, xDegree, yDegree, zDegree, xAtom, Fin.cases_zero]
  omega

@[simp] lemma signed_x_inv
    (xWeight yWeight zWeight : ℕ) :
    signedWeight xWeight yWeight zWeight xInvAtom = xWeight := by
  have hindex : (1 : Fin 4) = (0 : Fin 3).succ :=
    rfl
  simp only [signedWeight, xDegree, yDegree, zDegree, xInvAtom, hindex,
    Fin.cases_succ, Fin.cases_zero]
  omega

@[simp] lemma signedWeight_z
    (xWeight yWeight zWeight : ℕ) :
    signedWeight xWeight yWeight zWeight zAtom = zWeight := by
  have hindex : (2 : Fin 4) = (1 : Fin 3).succ :=
    rfl
  have htail : (1 : Fin 3) = (0 : Fin 2).succ :=
    rfl
  simp only [signedWeight, xDegree, yDegree, zDegree, zAtom, hindex, htail,
    Fin.cases_succ]
  omega

@[simp] lemma signed_z_inv
    (xWeight yWeight zWeight : ℕ) :
    signedWeight xWeight yWeight zWeight zInvAtom = zWeight := by
  have hindex : (3 : Fin 4) = (2 : Fin 3).succ :=
    rfl
  have htail : (2 : Fin 3) = (1 : Fin 2).succ :=
    rfl
  have hlast : (1 : Fin 2) = (0 : Fin 1).succ :=
    rfl
  simp only [signedWeight, xDegree, yDegree, zDegree, zInvAtom, hindex, htail,
    hlast, Fin.cases_succ]
  omega

@[simp] lemma signedWeight_y
    (xWeight yWeight zWeight : ℕ) :
    signedWeight xWeight yWeight zWeight yAtom = yWeight := by
  simp [signedWeight, xDegree, yDegree, zDegree, yAtom]

@[simp] lemma signed_y_inv
    (xWeight yWeight zWeight : ℕ) :
    signedWeight xWeight yWeight zWeight yInvAtom = yWeight := by
  simp [signedWeight, xDegree, yDegree, zDegree, yInvAtom]

/-- Weighted evaluation splits as the sum of the three unsigned
multidegrees. -/
lemma weight_signedWeight
    (xWeight yWeight zWeight : ℕ) :
    ∀ word : CWord Atom,
      word.weight (signedWeight xWeight yWeight zWeight) =
        word.weight xDegree * xWeight +
          word.weight yDegree * yWeight +
            word.weight zDegree * zWeight
  | .atom (.inl atom) => by
      refine Fin.cases ?_ (fun atom => ?_) atom
      · simp [signedWeight, xDegree, yDegree, zDegree]
      · refine Fin.cases ?_ (fun atom => ?_) atom
        · simp [signedWeight, xDegree, yDegree, zDegree]
        · refine Fin.cases ?_ (fun atom => ?_) atom
          · simp [signedWeight, xDegree, yDegree, zDegree]
          · exact
              Fin.cases (by simp [signedWeight, xDegree, yDegree, zDegree])
                (fun atom => Fin.elim0 atom) atom
  | .atom (.inr atom) => by
      refine Fin.cases ?_ (fun atom => ?_) atom
      · simp [signedWeight, xDegree, yDegree, zDegree]
      · exact
          Fin.cases (by simp [signedWeight, xDegree, yDegree, zDegree])
            (fun atom => Fin.elim0 atom) atom
  | .commutator left right => by
      simp only [CWord.weight_commutator,
        weight_signedWeight xWeight yWeight zWeight left,
        weight_signedWeight xWeight yWeight zWeight right]
      ring

/-- Unit-label weight is the sum of the three unsigned multidegrees. -/
lemma weight_sum_degrees :
    ∀ word : CWord Atom,
      word.weight (fun _ => 1) =
        word.weight xDegree + word.weight yDegree + word.weight zDegree
  | .atom atom => by
      rcases atom with atom | atom
      · fin_cases atom <;> decide
      · fin_cases atom <;> decide
  | .commutator left right => by
      simp only [CWord.weight_commutator,
        weight_sum_degrees left, weight_sum_degrees right]
      omega

/-- A multidegree-strict word gains at least one unit over the parent weight
after assigning positive weights to `x`, `y`, and `z`. -/
lemma parent_strictly_higher
    (xWeight yWeight zWeight : ℕ)
    (hxWeight : 0 < xWeight)
    (hyWeight : 0 < yWeight)
    (hzWeight : 0 < zWeight)
    (word : CWord Atom)
    (hword : StrictlyHigher word) :
    xWeight + yWeight + zWeight + 1 ≤
      word.weight (signedWeight xWeight yWeight zWeight) := by
  rcases hword with ⟨hx, hy, hz, hone⟩
  rw [weight_signedWeight]
  have hsum :
      4 ≤ word.weight xDegree + word.weight yDegree + word.weight zDegree := by
    rw [← weight_sum_degrees]
    exact hone
  nlinarith

/-- The signed word substitution carries exactly the unsigned weighted
multidegree. -/
lemma weight_signed_substitution
    {β : Type*}
    (wt : β → ℕ)
    (x y z : CWord β)
    (atom : Atom) :
    (signedWordSubstitution x y z atom).weight wt =
      signedWeight (x.weight wt) (y.weight wt) (z.weight wt) atom := by
  rcases atom with atom | atom
  · refine Fin.cases ?_ (fun atom => ?_) atom
    · change
        (signedWordSubstitution x y z xAtom).weight wt =
          signedWeight (x.weight wt) (y.weight wt) (z.weight wt) xAtom
      rw [signed_substitution_x, signedWeight_x]
    · refine Fin.cases ?_ (fun atom => ?_) atom
      · change
          (signedWordSubstitution x y z xInvAtom).weight wt =
            signedWeight (x.weight wt) (y.weight wt) (z.weight wt) xInvAtom
        rw [substitution_x_inv, signed_x_inv,
          weight_root_swap]
      · refine Fin.cases ?_ (fun atom => ?_) atom
        · change
            (signedWordSubstitution x y z zAtom).weight wt =
              signedWeight (x.weight wt) (y.weight wt) (z.weight wt) zAtom
          rw [signed_substitution_z, signedWeight_z]
        · exact
            Fin.cases
              (by
                change
                  (signedWordSubstitution x y z zInvAtom).weight wt =
                    signedWeight (x.weight wt) (y.weight wt) (z.weight wt)
                      zInvAtom
                rw [substitution_z_inv, signed_z_inv,
                  weight_root_swap])
              (fun atom => Fin.elim0 atom) atom
  · refine Fin.cases ?_ (fun atom => ?_) atom
    · change
        (signedWordSubstitution x y z yAtom).weight wt =
          signedWeight (x.weight wt) (y.weight wt) (z.weight wt) yAtom
      rw [signed_substitution_y, signedWeight_y]
    · exact
        Fin.cases
          (by
            change
              (signedWordSubstitution x y z yInvAtom).weight wt =
                signedWeight (x.weight wt) (y.weight wt) (z.weight wt)
                  yInvAtom
            rw [substitution_y_inv, signed_y_inv,
              weight_root_swap])
          (fun atom => Fin.elim0 atom) atom

/--
Every signed substituted integral strict-tail factor lies at least one
physical weight above its parent triple.
-/
lemma parent_succ_trace
    {β : Type*}
    (wt : β → ℕ)
    (hwt : ∀ atom, 0 < wt atom)
    (x y z : CWord β)
    (coefficient : ℤ)
    (word : CWord β)
    (hword : word ∈ signedStrictTrace x y z coefficient) :
    x.weight wt + y.weight wt + z.weight wt + 1 ≤ word.weight wt := by
  rw [signedStrictTrace, bindTrace] at hword
  rcases List.mem_map.mp hword with ⟨sourceWord, hsourceWord, rfl⟩
  rw [CWord.weight_bind]
  change
    x.weight wt + y.weight wt + z.weight wt + 1 ≤
      sourceWord.weight
        (fun atom => (signedWordSubstitution x y z atom).weight wt)
  rw [show
      (fun atom => (signedWordSubstitution x y z atom).weight wt) =
        signedWeight (x.weight wt) (y.weight wt) (z.weight wt) by
      funext atom
      exact weight_signed_substitution wt x y z atom]
  exact
    parent_strictly_higher
      (x.weight wt) (y.weight wt) (z.weight wt)
      (CWord.weight_pos wt hwt x)
      (CWord.weight_pos wt hwt y)
      (CWord.weight_pos wt hwt z)
      sourceWord
      (strictly_higher_strict coefficient sourceWord hsourceWord)

end STMultid
end TCTex
