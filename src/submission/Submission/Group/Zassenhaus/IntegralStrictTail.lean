lemma flat_iterated_move
    (cutoff : ℕ)
    (selected : CWord Atom)
    (emittedPrefix : List (CWord Atom)) :
    ∀ steps : ℕ,
      (List.range (steps + 1)).flatMap (fun depth =>
          iteratedCutoffMove cutoff selected depth emittedPrefix) =
        emittedPrefix ++
          (List.range steps).flatMap (fun depth =>
            iteratedCutoffMove cutoff selected (depth + 1)
              emittedPrefix)
  | 0 => by
      rfl
  | steps + 1 => by
      rw [List.range_succ, List.flatMap_append, List.flatMap_singleton,
        flat_iterated_move cutoff selected
          emittedPrefix steps,
        List.range_succ, List.flatMap_append, List.flatMap_singleton,
        List.append_assoc]

/-- Adding one triangular substitution step prepends the fixed emitted prefix
and advances every homogeneous orbit block once. -/
lemma move_prefix_succ
    (cutoff : ℕ)
    (selected : CWord Atom)
    (emittedPrefix : List (CWord Atom))
    (steps : ℕ) :
    cutoffMovePrefix cutoff selected emittedPrefix (steps + 1) =
      emittedPrefix ++
        cutoffMoveTrace cutoff selected
          (cutoffMovePrefix cutoff selected emittedPrefix steps) := by
  rw [cutoffMovePrefix,
    flat_iterated_move]
  unfold cutoffMovePrefix
  rw [cutoff_move_flat]
  apply congrArg (emittedPrefix ++ ·)
  apply List.flatMap_congr
  intro depth _hdepth
  rfl

/-- The trace emitted from an empty tail is exactly its finite homogeneous
orbit prefix. -/
lemma iterate_substitution_nil
    (emittedPrefix : List (CWord Atom))
    (cutoff : ℕ)
    (selected : CWord Atom) :
    ∀ steps : ℕ,
      iteratePrefixSubstitution emittedPrefix
          (cutoffMovePacket cutoff selected) steps [] =
        cutoffMovePrefix cutoff selected emittedPrefix steps
  | 0 => by
      rfl
  | steps + 1 => by
      rw [iteratePrefixSubstitution,
        iterate_substitution_nil
          emittedPrefix cutoff selected steps,
        move_prefix_succ]
      rfl

/-- Every triangular trace substitution is its explicit emitted orbit prefix
followed by the homogeneous orbit of the original tail. -/
lemma iterate_substitution_append
    (emittedPrefix : List (CWord Atom))
    (cutoff : ℕ)
    (selected : CWord Atom)
    (steps : ℕ)
    (tail : List (CWord Atom)) :
    iteratePrefixSubstitution emittedPrefix
        (cutoffMovePacket cutoff selected) steps tail =
      cutoffMovePrefix cutoff selected emittedPrefix steps ++
        iteratedCutoffMove cutoff selected steps tail := by
  rw [
    iterate_substitution_move,
    iterate_substitution_nil]

/-- Positive outer-packet traces split into their explicit emitted orbit prefix
and the homogeneous orbit of the original program tail. -/
lemma prepend_move_append
    (cutoff steps : ℕ)
    (tail : FRProgra) :
    (iteratePrepend cutoff isFirstCurrent WNTrace.trace
      steps tail).trace cutoff =
        cutoffMovePrefix cutoff firstConventionalInverse
            (positiveFilteredPrefix cutoff) steps ++
          iteratedCutoffMove cutoff firstConventionalInverse steps
            (tail.trace cutoff) := by
  rw [
    prepend_prefix_substitution,
    iterate_substitution_append]

/-- Negative outer-packet traces split into their explicit emitted orbit prefix
and the homogeneous orbit of the original program tail. -/
lemma iterate_prepend_append
    (cutoff steps : ℕ)
    (tail : FRProgra) :
    (iteratePrepend cutoff isFirstCurrent
      NNPower.inverseNormalizedTrace
        steps tail).trace cutoff =
      cutoffMovePrefix cutoff firstConventionalWord
          (negativeFilteredPrefix cutoff) steps ++
        iteratedCutoffMove cutoff firstConventionalWord steps
          (tail.trace cutoff) := by
  rw [
    iterate_prepend_substitution,
    iterate_substitution_append]

