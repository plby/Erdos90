          (n := n) x y z cutoff (Int.ofNat multiplicity)).prod := by
  simp_rw [
    address_parent_basis
      d n x y z cutoff hcutoff hparent]
  simpa [addressParentCoordinate] using
    (concreteParentBasis
      d n x y z hparent).sum_repr
        (TBluepr.lowerCentralClass
          (exponentAddressParent x y z)
