-- EndpointCountStateFold.lean

/-!
# Signed endpoint count-state folds for complete Hall-Witt schedules

The complete successor schedules are fixed outer prefixes followed by
successor-skew tails.  Signed Newton evaluation at formal predecessor input
`-1` commutes with the explicit affine bounded-term count-state compiler.
Consequently, the aggregate endpoint boundary is the evaluated image of one
finite fixed-prefix affine fold applied to the signed successor-skew tail
state.

This exposes the next cancellation problem as a finite affine-kernel
identity, without requiring individual bounded terms to vanish.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace CSFold

open WSTrace
open WHNorm
open WNTrace
open WSTail
open NPTail
open TBProf
open TACompos
open OTSubsti
open OTSched
open STSched
open SSExp
open STAlphab
open STRec
open SSCoord
open SCState
open PMExp
open SSFull
open TNForm
open FTVector
open TEAggreg

/-- Signed Newton evaluation of a natural integer family at formal input
`-1`, truncated at a prescribed degree bound. -/
def newtonSignedEvaluation
    (degreeBound : ℕ)
    (family : ℕ → ℤ) :
    ℤ :=
  ∑ k ∈ Finset.range (degreeBound + 1),
    natBinomialCoefficient family k * (-1 : ℤ) ^ k

/-- Signed Newton evaluation preserves addition. -/
lemma newton_evaluation_add
    (degreeBound : ℕ)
    (left right : ℕ → ℤ) :
    newtonSignedEvaluation degreeBound (fun steps => left steps + right steps) =
      newtonSignedEvaluation degreeBound left +
        newtonSignedEvaluation degreeBound right := by
  unfold newtonSignedEvaluation
  simp_rw [nat_binomial_add, add_mul, Finset.sum_add_distrib]

/-- Signed Newton evaluation of a constant family is that constant. -/
lemma newton_evaluation_const
    (degreeBound : ℕ)
    (value : ℤ) :
    newtonSignedEvaluation degreeBound (fun _steps => value) = value := by
  have hvalue :=
    BCExp.binomial_basis_succ
      1 degreeBound (by omega) (fun _steps : ℕ => value)
        (by
          simpa using
            valued_most_const degreeBound value)
  rw [BCExp.eval_int_binomial] at hvalue
  simpa [newtonSignedEvaluation] using hvalue

/-- Signed Newton evaluation of every coordinate of a count-state family. -/
def newtonEvaluationState
    (degreeBound : ℕ)
    (family : ℕ → BoundedCountState) :
    BoundedCountState :=
  fun target =>
    newtonSignedEvaluation degreeBound (fun steps => family steps target)

/-- Signed Newton evaluation commutes with a strict-predecessor coordinate
projection. -/
lemma newton_evaluation_predecessor
    (degreeBound cutoff : ℕ)
    (transition : SRTrans)
    (family : ℕ → BoundedCountState)
    (target : OCTerm) :
    newtonSignedEvaluation degreeBound
        (fun steps =>
          strictPredecessorCount cutoff transition (family steps) target) =
      strictPredecessorCount cutoff transition
        (newtonEvaluationState degreeBound family) target := by
  unfold strictPredecessorCount
  by_cases hlength : target.strictTransitions.length < cutoff
  · simp only [hlength, ↓reduceIte]
    cases hprevious : removePrepended? transition target with
    | none =>
        exact newton_evaluation_const degreeBound 0
    | some previous =>
        rfl
  · simp only [hlength, ↓reduceIte]
    exact newton_evaluation_const degreeBound 0

/-- Signed Newton evaluation commutes with one explicit affine bounded-term
count-state update. -/
lemma newton_evaluation_step
    (degreeBound cutoff : ℕ)
    (transition : SRTrans)
    (family : ℕ → BoundedCountState) :
    newtonEvaluationState degreeBound
        (fun steps => boundedStateStep cutoff transition
          (family steps)) =
      boundedStateStep cutoff transition
        (newtonEvaluationState degreeBound family) := by
  funext target
  unfold newtonEvaluationState boundedStateStep
  rw [newton_evaluation_add, newton_evaluation_add,
    newton_evaluation_predecessor,
    newton_evaluation_const]
  rfl

/-- Signed Newton evaluation commutes with every fixed explicit count-state
schedule fold. -/
lemma newton_evaluation_fold
    (degreeBound cutoff : ℕ)
    (schedule : List SRTrans)
    (family : ℕ → BoundedCountState) :
    newtonEvaluationState degreeBound
        (fun steps =>
          boundedStateFold cutoff schedule (family steps)) =
      boundedStateFold cutoff schedule
        (newtonEvaluationState degreeBound family) := by
  induction schedule with
  | nil =>
      rfl
  | cons transition schedule ih =>
      rw [show
        (fun steps =>
          boundedStateFold cutoff
            (transition :: schedule) (family steps)) =
          fun steps =>
            boundedStateStep cutoff transition
              (boundedStateFold cutoff schedule
                (family steps)) by
        rfl]
      rw [newton_evaluation_step, ih]
      rfl

/-- Integer-valued count state of one bounded-term list. -/
def boundedConstantState
    (terms : List OCTerm) :
    BoundedCountState :=
  boundedCountState terms

/-- The bounded-term count state of a concatenated transition schedule is
the explicit left-prefix fold applied to the suffix state. -/
lemma constant_state_append
    (cutoff : ℕ)
    (left right : List SRTrans) :
    boundedConstantState
        (boundedConstantTerms cutoff (left ++ right)) =
      boundedStateFold cutoff left
        (boundedConstantState
          (boundedConstantTerms cutoff right)) := by
  unfold boundedConstantState
  rw [constant_terms_append]
  exact count_state_fold cutoff left
    (boundedConstantTerms cutoff right)

/-- Signed bounded-term state of the positive successor-skew tail. -/
noncomputable def naturalSuccessorSkew
    (cutoff : ℕ) :
    BoundedCountState :=
  newtonEvaluationState
    (naturalFullBound cutoff)
    (fun steps =>
      boundedConstantState
        (boundedConstantTerms cutoff
          (middleSuccessorSkew cutoff
            firstConventionalInverse firstConventionalInverse
              firstConventionalWord secondConventionalInverse
                (positiveFilteredPrefix cutoff) steps)))

/-- Signed bounded-term state of the negative successor-skew tail. -/
noncomputable def negativeSuccessorSkew
    (cutoff : ℕ) :
    BoundedCountState :=
  newtonEvaluationState
    (negativeFullBound cutoff)
    (fun steps =>
      boundedConstantState
        (boundedConstantTerms cutoff
          (middleSuccessorSkew cutoff
            firstConventionalWord firstConventionalWord
              firstConventionalInverse secondConventionalWord
                (negativeFilteredPrefix cutoff) steps)))

/-- Signed bounded-term state represented by the positive complete-schedule
term recipe vector. -/
noncomputable def naturalFullState
    (cutoff : ℕ) :
    BoundedCountState :=
  fun target =>
    (naturalFullExpansion cutoff target).evalInt (-1)

/-- Signed bounded-term state represented by the negative complete-schedule
term recipe vector. -/
noncomputable def negativeFullState
    (cutoff : ℕ) :
    BoundedCountState :=
  fun target =>
    (negativeFullExpansion cutoff target).evalInt (-1)

/-- The positive complete signed state is the fixed positive outer-prefix
fold applied to the positive successor-skew tail signed state. -/
lemma natural_state_fold
    (cutoff : ℕ) :
    naturalFullState cutoff =
      boundedStateFold cutoff
        (positiveFixedPrefix cutoff)
          (naturalSuccessorSkew cutoff) := by
  unfold naturalFullState
    naturalFullExpansion
  rw [show
    (fun target =>
      (BCExp.binomialBasis 1
        (naturalFullBound cutoff)
          (by omega)
          (fun steps : ℕ =>
            ((boundedConstantTerms cutoff
              (naturalFullSchedule cutoff (steps + 1))).count
                target : ℤ))).evalInt (-1)) =
      newtonEvaluationState
        (naturalFullBound cutoff)
        (fun steps =>
          boundedConstantState
            (boundedConstantTerms cutoff
              (naturalFullSchedule cutoff (steps + 1)))) by
    funext target
    unfold newtonEvaluationState boundedConstantState
      boundedCountState newtonSignedEvaluation
    rw [BCExp.eval_int_binomial]
    simp]
  rw [show
    (fun steps =>
      boundedConstantState
        (boundedConstantTerms cutoff
          (naturalFullSchedule cutoff (steps + 1)))) =
      fun steps =>
        boundedStateFold cutoff
          (positiveFixedPrefix cutoff)
          (boundedConstantState
            (boundedConstantTerms cutoff
              (middleSuccessorSkew
                cutoff firstConventionalInverse
                  firstConventionalInverse firstConventionalWord
                    secondConventionalInverse
                      (positiveFilteredPrefix cutoff) steps))) by
    funext steps
    rw [natural_full_succ,
      constant_state_append]]
  rw [newton_evaluation_fold]
  rfl

/-- The negative complete signed state is the fixed negative outer-prefix
fold applied to the negative successor-skew tail signed state. -/
lemma negative_state_fold
    (cutoff : ℕ) :
    negativeFullState cutoff =
      boundedStateFold cutoff
        (negativeFixedPrefix cutoff)
          (negativeSuccessorSkew cutoff) := by
  unfold negativeFullState
    negativeFullExpansion
  rw [show
    (fun target =>
      (BCExp.binomialBasis 1
        (negativeFullBound cutoff)
          (by omega)
          (fun steps : ℕ =>
            ((boundedConstantTerms cutoff
              (negativeFullSchedule cutoff (steps + 1))).count
                target : ℤ))).evalInt (-1)) =
      newtonEvaluationState
        (negativeFullBound cutoff)
        (fun steps =>
          boundedConstantState
            (boundedConstantTerms cutoff
              (negativeFullSchedule cutoff (steps + 1)))) by
    funext target
    unfold newtonEvaluationState boundedConstantState
      boundedCountState newtonSignedEvaluation
    rw [BCExp.eval_int_binomial]
    simp]
  rw [show
    (fun steps =>
      boundedConstantState
        (boundedConstantTerms cutoff
          (negativeFullSchedule cutoff (steps + 1)))) =
      fun steps =>
        boundedStateFold cutoff
          (negativeFixedPrefix cutoff)
          (boundedConstantState
            (boundedConstantTerms cutoff
              (middleSuccessorSkew
                cutoff firstConventionalWord firstConventionalWord
                  firstConventionalInverse secondConventionalWord
                    (negativeFilteredPrefix cutoff) steps))) by
    funext steps
    rw [negative_full_succ,
      constant_state_append]]
  rw [newton_evaluation_fold]
  rfl

/-- Evaluate a signed bounded-term state in one cutoff-profile slot. -/
def boundedStateSlot
    (cutoff : ℕ)
    (state : BoundedCountState)
    (slot : CWord Atom) :
    ℤ :=
  ∑ term ∈ (boundedConstantAlphabet cutoff).toFinset,
    (Multiset.count slot (term.eval cutoff) : ℤ) * state term

/-- Positive aggregate endpoint signed recipes are the slot evaluations of
the fixed-prefix fold applied to the successor-skew tail signed state. -/
lemma natural_fold_state
    (cutoff : ℕ)
    (slot : CWord Atom) :
    naturalFullEndpoint cutoff slot =
      boundedStateSlot cutoff
        (boundedStateFold cutoff
          (positiveFixedPrefix cutoff)
            (naturalSuccessorSkew cutoff)) slot := by
  unfold naturalFullEndpoint
    boundedStateSlot
  rw [← natural_state_fold]
  rfl

/-- Negative aggregate endpoint signed recipes are the slot evaluations of
the fixed-prefix fold applied to the successor-skew tail signed state. -/
lemma negative_fold_state
    (cutoff : ℕ)
    (slot : CWord Atom) :
    negativeFullEndpoint cutoff slot =
      boundedStateSlot cutoff
        (boundedStateFold cutoff
          (negativeFixedPrefix cutoff)
            (negativeSuccessorSkew cutoff)) slot := by
  unfold negativeFullEndpoint
    boundedStateSlot
  rw [← negative_state_fold]
  rfl

/-- The positive successor-skew tail signed state lies in the evaluated
kernel after the fixed positive outer-prefix fold. -/
def SuccessorSkewSatisfies
    (cutoff : ℕ) :
    Prop :=
  ∀ slot,
    boundedStateSlot cutoff
      (boundedStateFold cutoff
        (positiveFixedPrefix cutoff)
          (naturalSuccessorSkew cutoff)) slot = 0

/-- The negative successor-skew tail signed state lies in the evaluated
kernel after the fixed negative outer-prefix fold. -/
def SuccessorSkewState
    (cutoff : ℕ) :
    Prop :=
  ∀ slot,
    boundedStateSlot cutoff
      (boundedStateFold cutoff
        (negativeFixedPrefix cutoff)
          (negativeSuccessorSkew cutoff)) slot = 0

/-- Positive aggregate endpoint cancellation is exactly the finite positive
prefix-kernel condition. -/
lemma full_sums_vanish
    (cutoff : ℕ) :
    NaturalSumsVanish cutoff ↔
      SuccessorSkewSatisfies cutoff := by
  apply forall_congr'
  intro slot
  rw [
    natural_fold_state]

/-- Negative aggregate endpoint cancellation is exactly the finite negative
prefix-kernel condition. -/
lemma negative_sums_vanish
    (cutoff : ℕ) :
    NegativeSumsVanish cutoff ↔
      SuccessorSkewState cutoff := by
  apply forall_congr'
  intro slot
  rw [
    negative_fold_state]

/-- The positive finite prefix-kernel identity discharges global positive
strict-tail cutoff-profile polynomiality. -/
lemma natural_strict_prefix
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (hkernel :
      SuccessorSkewSatisfies cutoff) :
    CPDataa cutoff
      (naturalStrictBound cutoff)
      (fun multiplicity =>
        cutoffProfile cutoff
          (NPTail.strictTrace multiplicity)) := by
  apply
    natural_sums_vanish
      cutoff hcutoff
  exact
    (full_sums_vanish
      cutoff).2 hkernel

/-- The negative finite prefix-kernel identity discharges global negative
strict-tail cutoff-profile polynomiality. -/
lemma negative_strict_prefix
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (hkernel :
      SuccessorSkewState cutoff) :
    CPDataa cutoff
      (negativeStrictBound cutoff)
      (fun multiplicity =>
        cutoffProfile cutoff
          (NNPower.strictTrace
            multiplicity)) := by
  apply
    endpoint_sums_vanish
      cutoff hcutoff
  exact
    (negative_sums_vanish
      cutoff).2 hkernel

end CSFold
end TCTex
end Submission

