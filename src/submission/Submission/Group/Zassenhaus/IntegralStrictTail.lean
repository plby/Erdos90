/-- Binding words whose weights are at least `inputWeight` multiplies the
formal unit-label weight lower bound by `inputWeight`. -/
lemma mul_weight_bind
    {α β : Type*}
    (wt : β → ℕ)
    (substitution : α → CWord β)
    (inputWeight : ℕ)
    (hsubstitution :
      ∀ atom, inputWeight ≤ (substitution atom).weight wt) :
    ∀ word : CWord α,
      word.weight (fun _ => 1) * inputWeight ≤
        (word.bind substitution).weight wt
  | .atom atom => by
      simpa using hsubstitution atom
  | .commutator left right => by
      simp only [CWord.weight_commutator,
        CWord.bind_commutator, Nat.add_mul]
      exact
        Nat.add_le_add
          (mul_weight_bind wt substitution inputWeight
            hsubstitution left)
          (mul_weight_bind wt substitution inputWeight
            hsubstitution right)

/-- Finite sums preserve a common integer-valued polynomial degree bound. -/
private lemma polynomial_finsetSum
    {ι : Type*}
    {degreeBound : ℕ}
    (slots : Finset ι)
    (family : ι → ℕ → ℤ)
    (hfamily :
      ∀ slot ∈ slots,
        IVMost
          (family slot) degreeBound) :
    IVMost
      (fun steps : ℕ => ∑ slot ∈ slots, family slot steps)
      degreeBound := by
  classical
  induction slots using Finset.induction_on with
  | empty =>
      simpa using
        TCTex.IVMost.zero
          degreeBound
  | @insert slot slots hslot ih =>
      simpa [Finset.sum_insert hslot] using
        TCTex.IVMost.add
          (hfamily slot (by simp))
          (ih (fun next hnext => hfamily next (by simp [hnext])))

/-- The positive collision-aggregated coordinate of a concrete substituted
word has its physical repeated-block degree bound. -/
lemma natural_bind_physical
    {β : Type*}
    [DecidableEq β]
    (wt : β → ℕ)
    (substitution : Atom → CWord β)
    (cutoff inputWeight : ℕ)
    (hcutoff : 3 < cutoff)
    (hinputWeight : 0 < inputWeight)
    (hsubstitution :
      ∀ atom, inputWeight ≤ (substitution atom).weight wt)
    (word : CWord β) :
    IVMost
      (bindFilteredSlot
        wt substitution cutoff word).natural.eval
      (word.weight wt / inputWeight) := by
  rw [show
      (bindFilteredSlot
        wt substitution cutoff word).natural.eval =
        fun multiplicity : ℕ =>
          ∑ slot ∈
              bindFilteredSlots
                wt substitution cutoff word,
            (strictSlotExpansion cutoff slot).natural.eval
              multiplicity by
    funext multiplicity
    simpa [bindFilteredSlot,
      ISExp.eval] using
        (slot_finset_sum cutoff
          (bindFilteredSlots wt substitution cutoff word)
          (strictSlotExpansion cutoff)
          (Int.ofNat multiplicity))]
  apply polynomial_finsetSum
  intro slot hslot
  apply
    TCTex.IVMost.mono
      (degreeBound := slot.weight (fun _ => 1))
  · rw [Nat.le_div_iff_mul_le hinputWeight]
    have hbind :
        slot.bind substitution = word :=
      (Finset.mem_filter.mp hslot).2.2
    rw [← hbind]
    exact
      mul_weight_bind wt substitution inputWeight
        hsubstitution slot
  · rw [strictSlotExpansion,
      natural_strict_slot cutoff hcutoff slot]
    exact
      count_profile_natural
        cutoff hcutoff slot

