/-!
# Singleton iterations in ordered Hall-Witt first-route programs

Repeatedly prefixing one selected word to an ordered first-route program is
literal iterated rightward movement across the existing tail trace.  Repeatedly
prefixing one unselected word is ordinary repeated retention.

The selected identity connects the ordered program layer directly to the
earlier repeated-move polynomial and recipe-expansion machinery.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace OSIterat

open CWTrace
open WSTrace
open WHNorm
open WNTrace
open WSTail
open NPTail
open STVocabu
open RMRecb
open TBProf
open ARProfa
open ARProfa.CPAffine
open TACompos
open OFProgra
open OFProgra.FRProgra
open RMSlot
open RMExp

/-- Iterating a selected singleton prefix is literal iterated rightward
movement across the existing ordered tail trace. -/
lemma iterate_singleton_current
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (left : CWord Atom)
    (hleft : isCurrent left = true)
    (tail : FRProgra) :
    ∀ steps : ℕ,
      (iteratePrepend cutoff isCurrent [left] steps tail).trace cutoff =
        unitBelowTrace cutoff
          (iteratedMoveHigher left steps (tail.trace cutoff))
  | 0 => by
      exact (unit_below_trace cutoff tail).symm
  | steps + 1 => by
      rw [iteratePrepend]
      simp only [prepend, if_pos hleft, trace_moved]
      rw [iterate_singleton_current
        cutoff isCurrent left hleft tail steps]
      rw [←
        unit_move_higher
          cutoff left]
      rfl

/-- Iterating an unselected singleton prefix is ordinary repeated retention
before the existing ordered tail trace. -/
lemma prepend_not_current
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (word : CWord Atom)
    (hword : isCurrent word ≠ true)
    (tail : FRProgra) :
    ∀ steps : ℕ,
      (iteratePrepend cutoff isCurrent [word] steps tail).trace cutoff =
        repeatTrace steps (unitBelowTrace cutoff [word]) ++
          tail.trace cutoff
  | 0 => by
      rfl
  | steps + 1 => by
      rw [iteratePrepend]
      simp only [prepend, if_neg hword, trace_retained]
      rw [prepend_not_current
        cutoff isCurrent word hword tail steps]
      simp [repeatTrace, List.append_assoc]

/-- The retained count in a selected singleton program iteration is the
earlier repeated-move retained count. -/
lemma prepend_singleton_current
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (left : CWord Atom)
    (hleft : isCurrent left = true)
    (tail : FRProgra)
    (steps : ℕ)
    (slot : CWord Atom) :
    unitBelowMultiplicity cutoff
        ((iteratePrepend cutoff isCurrent [left] steps tail).trace cutoff) slot =
      unitBelowMultiplicity cutoff
        (iteratedMoveHigher left steps (tail.trace cutoff)) slot := by
  rw [iterate_singleton_current
    cutoff isCurrent left hleft tail steps]
  unfold unitBelowMultiplicity
  rw [unit_below_idem]

/-- Selected first-family singleton program iterations have uniformly
cutoff-bounded slotwise integer-valued polynomial profiles. -/
lemma iterate_prepend_current
    (cutoff : ℕ)
    (left : CWord Atom)
    (hleft : isFirstCurrent left = true)
    (tail : FRProgra) :
    CPDataa cutoff cutoff
      (fun steps =>
        cutoffProfile cutoff
          ((iteratePrepend cutoff isFirstCurrent [left] steps tail).trace
            cutoff)) := by
  constructor
  · intro steps
    exact supported_vocabulary_profile cutoff _
  · intro slot
    rw [show
      (fun steps : ℕ =>
        (Multiset.count slot
          (cutoffProfile cutoff
            ((iteratePrepend cutoff isFirstCurrent [left] steps tail).trace
              cutoff)) : ℤ)) =
        repeatedMoveMultiplicity cutoff left (tail.trace cutoff) slot by
      funext steps
      unfold repeatedMoveMultiplicity cutoffProfile
      simpa [unitBelowMultiplicity] using
        prepend_singleton_current
          cutoff isFirstCurrent left hleft tail steps slot]
    exact
      repeated_move_most
        cutoff left (Or.inl hleft) (tail.trace cutoff) slot

/-- The repeated-move recipe vector evaluates to the retained counts of the
literal selected-singleton ordered program iteration. -/
lemma repeated_move_prepend
    (cutoff : ℕ)
    (left : CWord Atom)
    (hleft : isFirstCurrent left = true)
    (tail : FRProgra)
    (steps : ℕ) :
    (repeatedMoveVector
        cutoff left (tail.trace cutoff)).map
          (fun expansion => expansion.eval steps) =
      (orderedCutoffVocabulary cutoff).map fun slot =>
        (unitBelowMultiplicity cutoff
          ((iteratePrepend cutoff isFirstCurrent [left] steps tail).trace
            cutoff) slot : ℤ) := by
  rw [repeated_move_vector
    cutoff left (Or.inl hleft) (tail.trace cutoff) steps]
  apply List.map_congr_left
  intro slot _hslot
  norm_cast
  exact
    (prepend_singleton_current
      cutoff isFirstCurrent left hleft tail steps slot).symm

/-- The positive innermost singleton block is a repeated retained
second-family inverse trace. -/
lemma positive_innermost_program
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (steps : ℕ) :
    (iteratePrepend cutoff isFirstCurrent [secondConventionalInverse]
        steps .empty).trace cutoff =
      repeatTrace steps [secondConventionalInverse] := by
  rw [prepend_not_current
    cutoff isFirstCurrent secondConventionalInverse (by simp) .empty steps]
  simp [unitBelowTrace, weight_second_conventional, hcutoff]

/-- The negative innermost singleton block is a repeated retained
second-family trace. -/
lemma negative_innermost_program
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (steps : ℕ) :
    (iteratePrepend cutoff isFirstCurrent [secondConventionalWord]
        steps .empty).trace cutoff =
      repeatTrace steps [secondConventionalWord] := by
  rw [prepend_not_current
    cutoff isFirstCurrent secondConventionalWord (by simp) .empty steps]
  simp [unitBelowTrace, weight_conventional_word, hcutoff]

/-- The positive middle singleton block is literal iterated movement of the
first-family word across the positive innermost repeated trace. -/
lemma positive_middle_program
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (steps : ℕ) :
    (iteratePrepend cutoff isFirstCurrent [firstConventionalWord] steps
        (iteratePrepend cutoff isFirstCurrent [secondConventionalInverse]
          steps .empty)).trace cutoff =
      unitBelowTrace cutoff
        (iteratedMoveHigher firstConventionalWord steps
          (repeatTrace steps [secondConventionalInverse])) := by
  rw [iterate_singleton_current
    cutoff isFirstCurrent firstConventionalWord (by simp)]
  rw [positive_innermost_program cutoff hcutoff steps]

/-- The negative middle singleton block is literal iterated movement of the
first-family inverse word across the negative innermost repeated trace. -/
lemma negative_middle_program
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (steps : ℕ) :
    (iteratePrepend cutoff isFirstCurrent [firstConventionalInverse] steps
        (iteratePrepend cutoff isFirstCurrent [secondConventionalWord]
          steps .empty)).trace cutoff =
      unitBelowTrace cutoff
        (iteratedMoveHigher firstConventionalInverse steps
          (repeatTrace steps [secondConventionalWord])) := by
  rw [iterate_singleton_current
    cutoff isFirstCurrent firstConventionalInverse (by simp)]
  rw [negative_innermost_program cutoff hcutoff steps]

/-- Iterating an arbitrary fixed prefix packet emits the filtered literal
route of its repeated trace onto the existing ordered tail. -/
lemma iterate_prepend_repeat
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom))
    (steps : ℕ)
    (tail : FRProgra) :
    (iteratePrepend cutoff isCurrent packet steps tail).trace cutoff =
      unitBelowTrace cutoff
        (routeOnto isCurrent (repeatTrace steps packet) (tail.trace cutoff)) := by
  rw [← prepend_repeatTrace, trace_prepend]

/-- The complete positive first-route program is the outer repeated normalized
packet routed onto the explicit positive middle trace. -/
lemma natural_program_middle
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (steps : ℕ) :
    (naturalRouteProgram cutoff steps).trace cutoff =
      unitBelowTrace cutoff
        (routeOnto isFirstCurrent
          (repeatTrace steps WNTrace.trace)
          (unitBelowTrace cutoff
            (iteratedMoveHigher firstConventionalWord steps
              (repeatTrace steps [secondConventionalInverse])))) := by
  rw [natural_iterate_prepend]
  rw [iterate_prepend_repeat]
  rw [positive_middle_program cutoff hcutoff steps]

/-- The complete negative first-route program is the outer repeated inverse
normalized packet routed onto the explicit negative middle trace. -/
lemma route_program_middle
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (steps : ℕ) :
    (negativeRouteProgram cutoff steps).trace cutoff =
      unitBelowTrace cutoff
        (routeOnto isFirstCurrent
          (repeatTrace steps
            NNPower.inverseNormalizedTrace)
          (unitBelowTrace cutoff
            (iteratedMoveHigher firstConventionalInverse steps
              (repeatTrace steps [secondConventionalWord])))) := by
  rw [negative_iterate_prepend]
  rw [iterate_prepend_repeat]
  rw [negative_middle_program cutoff hcutoff steps]

/-- The positive strict-tail cutoff profile is the second affine compiler
applied to the explicit outer-route boundary trace. -/
lemma natural_route_middle
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (steps : ℕ) :
    cutoffProfile cutoff
        (NPTail.strictTrace steps) =
      (ofTrace cutoff isSecondCurrent
        (unitBelowTrace cutoff
          (routeOnto isFirstCurrent
            (repeatTrace steps WNTrace.trace)
            (unitBelowTrace cutoff
              (iteratedMoveHigher firstConventionalWord steps
                (repeatTrace steps [secondConventionalInverse])))))).apply
        0 := by
  rw [natural_second_affine cutoff hcutoff steps]
  rw [FRProgra.secondAffine,
    natural_program_middle cutoff hcutoff steps]

/-- The negative strict-tail cutoff profile is the second affine compiler
applied to the explicit inverse outer-route boundary trace. -/
lemma negative_route_middle
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (steps : ℕ) :
    cutoffProfile cutoff
        (NNPower.strictTrace steps) =
      (ofTrace cutoff isSecondCurrent
        (unitBelowTrace cutoff
          (routeOnto isFirstCurrent
            (repeatTrace steps
              NNPower.inverseNormalizedTrace)
            (unitBelowTrace cutoff
              (iteratedMoveHigher firstConventionalInverse steps
                (repeatTrace steps [secondConventionalWord])))))).apply 0 := by
  rw [negative_second_affine cutoff hcutoff steps]
  rw [FRProgra.secondAffine,
    route_program_middle
      cutoff hcutoff steps]

