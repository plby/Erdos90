namespace TCTex
namespace FSVector

open CWTrace
open WSTrace
open PSTail
open TOCoordi
open RMRecb
open STVocabu

/-- Fixed-slot cutoff multiplicities of an arbitrary formal trace. -/
def fixedSlotVector
    (cutoff : ℕ)
    (source : List (CWord Atom)) :
    List ℕ :=
  (orderedCutoffVocabulary cutoff).map
    (unitBelowMultiplicity cutoff source)

/-- Pointwise addition of two scalar vectors. -/
def pointwiseAdd
    (left right : List ℕ) :
    List ℕ :=
  List.zipWith (· + ·) left right

/-- The zero vector on the fixed Hall-Witt cutoff slots. -/
def slotMultiplicityVector
    (cutoff : ℕ) :
    List ℕ :=
  (orderedCutoffVocabulary cutoff).map fun _slot => 0

/-- The fixed-slot vector length depends only on the cutoff. -/
lemma length_slot_vector
    (cutoff : ℕ)
    (source : List (CWord Atom)) :
    (fixedSlotVector cutoff source).length =
      (orderedCutoffVocabulary cutoff).length := by
  simp [fixedSlotVector]

/-- The existing integral strict-tail occurrence vector is the generic
fixed-slot vector of its literal strict trace. -/
lemma fixed_slot_strict
    (cutoff : ℕ)
    (coefficient : ℤ) :
    fixedMultiplicityVector cutoff coefficient =
      fixedSlotVector cutoff (strictTrace coefficient) := by
  exact
    fixed_slot_below
      cutoff coefficient

/-- A rightward move adds the strict-correction vector to the retained higher
vector. -/
lemma slot_move_higher
    (cutoff : ℕ)
    (left : CWord Atom)
    (rights : List (CWord Atom)) :
    fixedSlotVector cutoff
        (moveHigherTrace left rights) =
      pointwiseAdd
        (fixedSlotVector cutoff
          (moveCorrectionTrace left rights))
        (fixedSlotVector cutoff rights) := by
  unfold fixedSlotVector pointwiseAdd
  induction orderedCutoffVocabulary cutoff with
  | nil =>
      rfl
  | cons slot slots ih =>
      simp only [List.map_cons, List.zipWith_cons_cons]
      rw [below_multiplicity_move]
      exact congrArg (List.cons _) ih

/-- One selected stable-routing step obeys pointwise fixed-slot addition. -/
lemma fst_cons_current
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (word : CWord Atom)
    (words : List (CWord Atom))
    (hcurrent : isCurrent word = true) :
    fixedSlotVector cutoff
        (stableRoute isCurrent (word :: words)).1 =
      pointwiseAdd
        (fixedSlotVector cutoff
          (moveCorrectionTrace word
            (stableRoute isCurrent words).1))
        (fixedSlotVector cutoff
          (stableRoute isCurrent words).1) := by
  unfold fixedSlotVector pointwiseAdd
  induction orderedCutoffVocabulary cutoff with
  | nil =>
      rfl
  | cons slot slots ih =>
      simp only [List.map_cons, List.zipWith_cons_cons]
      rw [
        stable_fst_cons
          cutoff isCurrent word slot words hcurrent]
      exact congrArg (List.cons _) ih

/-- One unselected stable-routing step adds only its retained singleton
vector. -/
lemma stable_fst_current
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (word : CWord Atom)
    (words : List (CWord Atom))
    (hcurrent : isCurrent word ≠ true) :
    fixedSlotVector cutoff
        (stableRoute isCurrent (word :: words)).1 =
      pointwiseAdd
        (fixedSlotVector cutoff [word])
        (fixedSlotVector cutoff
          (stableRoute isCurrent words).1) := by
  unfold fixedSlotVector pointwiseAdd
  induction orderedCutoffVocabulary cutoff with
  | nil =>
      rfl
  | cons slot slots ih =>
      simp only [List.map_cons, List.zipWith_cons_cons]
      rw [
        stable_cons_current
          cutoff isCurrent word slot words hcurrent]
      exact congrArg (List.cons _) ih

/-- Uniform Hall-Witt cutoff nilpotence becomes a literal zero fixed-slot
vector. -/
lemma slot_iterated_current
    (cutoff : ℕ)
    (left : CWord Atom)
    (hleft :
      NPTail.isFirstCurrent left = true ∨
        NPTail.isSecondCurrent left = true)
    (rights : List (CWord Atom)) :
    fixedSlotVector cutoff
        (iteratedMoveTrace left cutoff rights) =
      slotMultiplicityVector cutoff := by
  unfold fixedSlotVector slotMultiplicityVector
  apply List.map_congr_left
  intro slot _hslot
  unfold unitBelowMultiplicity
  rw [
    below_current_nil
      cutoff left hleft rights]
  rfl

/-- A trace is cutoff-supported when every retained occurrence lies in the
fixed formal vocabulary. -/
def SupportedBelowCutoff
    (cutoff : ℕ)
    (source : List (CWord Atom)) :
    Prop :=
  ∀ word ∈ unitBelowTrace cutoff source,
    word ∈ orderedCutoffVocabulary cutoff

/-- Every integral Hall-Witt strict trace is cutoff-supported. -/
lemma supported_below_trace
    (cutoff : ℕ)
    (coefficient : ℤ) :
    SupportedBelowCutoff cutoff (strictTrace coefficient) := by
  intro word hword
  apply vocabulary_below_trace
  rw [below_cutoff_strict]
  exact hword

/-- Equality of aligned mapped vectors gives equality at every listed slot. -/
lemma eq_eq_mem
    {α β : Type*}
    (entries : List α)
    (left right : α → β)
    (hmap : entries.map left = entries.map right)
    (entry : α)
    (hentry : entry ∈ entries) :
    left entry = right entry := by
  induction entries generalizing entry with
  | nil =>
      simp at hentry
  | cons head entries ih =>
      simp only [List.map_cons] at hmap
      injection hmap with hhead htail
      simp only [List.mem_cons] at hentry
      rcases hentry with rfl | hentry
      · exact hhead
      · exact ih htail entry hentry

/--
For traces supported on the fixed cutoff vocabulary, equality of fixed-slot
vectors recovers equality up to permutation of retained occurrences.
-/
lemma perm_slot_vector
    (cutoff : ℕ)
    (left right : List (CWord Atom))
    (hleft : SupportedBelowCutoff cutoff left)
    (hright : SupportedBelowCutoff cutoff right)
    (hvectors :
      fixedSlotVector cutoff left =
        fixedSlotVector cutoff right) :
    List.Perm
      (unitBelowTrace cutoff left)
      (unitBelowTrace cutoff right) := by
  rw [List.perm_iff_count]
  intro slot
  by_cases hslot : slot ∈ orderedCutoffVocabulary cutoff
  · exact
      eq_eq_mem
        (orderedCutoffVocabulary cutoff)
        (unitBelowMultiplicity cutoff left)
        (unitBelowMultiplicity cutoff right)
        hvectors slot hslot
  · have hleftSlot : slot ∉ unitBelowTrace cutoff left := by
      intro hslotLeft
      exact hslot (hleft slot hslotLeft)
    have hrightSlot : slot ∉ unitBelowTrace cutoff right := by
      intro hslotRight
      exact hslot (hright slot hslotRight)
    exact
      (List.count_eq_zero.mpr hleftSlot).trans
        (List.count_eq_zero.mpr hrightSlot).symm

/--
Equal fixed-slot occurrence vectors for two integral Hall-Witt tails recover
a permutation of their literal below-cutoff traces.
-/
lemma below_perm_vector
    (cutoff : ℕ)
    (leftCoefficient rightCoefficient : ℤ)
    (hvectors :
      fixedMultiplicityVector cutoff leftCoefficient =
        fixedMultiplicityVector cutoff rightCoefficient) :
    List.Perm
      (belowCutoffTrace cutoff leftCoefficient)
      (belowCutoffTrace cutoff rightCoefficient) := by
  rw [below_cutoff_strict,
    below_cutoff_strict]
  apply perm_slot_vector
      cutoff (strictTrace leftCoefficient) (strictTrace rightCoefficient)
      (supported_below_trace cutoff leftCoefficient)
      (supported_below_trace cutoff rightCoefficient)
  rw [←
    fixed_slot_strict,
    ←
      fixed_slot_strict]
  exact hvectors

end FSVector
