-- Merged from JacobiIntegralPowerStrictTailCutoffRepeatedMoveSlotPolynomial.lean

/-!
# Polynomial slot profiles for repeated Hall-Witt cutoff routing

The binomial profile of one repeatedly routed Hall-Witt current word has a
fixed polynomial description modulo cutoff.  The strict correction coefficient
at depth `k` vanishes once `cutoff ≤ k`, so the dynamic binomial expansion can
be truncated to the coefficient-independent range `Finset.range cutoff`.

This file packages every retained slot multiplicity as an explicit rational
Newton-basis polynomial with integer values on natural inputs.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace RMSlot

open CWTrace
open WSTrace
open RMRecb
open TBProf

/--
For a Hall-Witt current word, the repeated-move slot formula has a fixed
cutoff-sized support.  The terms beyond `steps` vanish by `Nat.choose`, while
the terms beyond `cutoff` vanish by strict-correction nilpotence.
-/
lemma iterated_move_range
    (cutoff : ℕ)
    (left : CWord Atom)
    (hleft :
      NPTail.isFirstCurrent left = true ∨
        NPTail.isSecondCurrent left = true)
    (rights : List (CWord Atom))
    (steps : ℕ)
    (slot : CWord Atom) :
    unitBelowMultiplicity cutoff
        (iteratedMoveHigher left steps rights) slot =
      ∑ k ∈ Finset.range cutoff,
        steps.choose k *
          unitBelowMultiplicity cutoff
            (iteratedMoveTrace left k rights) slot := by
  rw [below_iterated_move]
  rcases le_total cutoff (steps + 1) with hcutoff | hsteps
  · symm
    apply Finset.sum_subset (Finset.range_mono hcutoff)
    intro k _hkLarge hkNotSmall
    have hkCutoff : cutoff ≤ k := by
      simpa only [Finset.mem_range, not_lt] using hkNotSmall
    rw [
      iterated_move_current
        cutoff left hleft rights k hkCutoff slot,
      Nat.mul_zero]
  · apply Finset.sum_subset (Finset.range_mono hsteps)
    intro k _hkLarge hkNotSmall
    have hstepsLt : steps < k := by
      have : steps + 1 ≤ k := by
        simpa only [Finset.mem_range, not_lt] using hkNotSmall
      omega
    simp [Nat.choose_eq_zero_of_lt hstepsLt]

/-- One fixed retained-slot multiplicity after repeated rightward movement. -/
def repeatedMoveMultiplicity
    (cutoff : ℕ)
    (left : CWord Atom)
    (rights : List (CWord Atom))
    (slot : CWord Atom)
    (steps : ℕ) :
    ℤ :=
  unitBelowMultiplicity cutoff
    (iteratedMoveHigher left steps rights) slot

/-- Explicit Newton-basis polynomial for one retained-slot multiplicity. -/
noncomputable def repeatedMoveSlot
    (cutoff : ℕ)
    (left : CWord Atom)
    (rights : List (CWord Atom))
    (slot : CWord Atom) :
    Polynomial ℚ :=
  ∑ k ∈ Finset.range cutoff,
    Polynomial.C
        (unitBelowMultiplicity cutoff
          (iteratedMoveTrace left k rights) slot : ℚ) *
      natChoosePolynomial k

/-- The explicit slot polynomial has degree at most the cutoff. -/
lemma repeated_move_slot
    (cutoff : ℕ)
    (left : CWord Atom)
    (rights : List (CWord Atom))
    (slot : CWord Atom) :
    (repeatedMoveSlot cutoff left rights slot).natDegree ≤
      cutoff := by
  unfold repeatedMoveSlot
  apply Polynomial.natDegree_sum_le_of_forall_le
  intro k hk
  have hkLt : k < cutoff := Finset.mem_range.mp hk
  exact Polynomial.natDegree_mul_le.trans
    (by
      calc
        (Polynomial.C
              (unitBelowMultiplicity cutoff
                (iteratedMoveTrace left k rights) slot : ℚ)).natDegree +
              (natChoosePolynomial k).natDegree ≤
            0 + k := by
              gcongr
              · simp
              · exact degree_choose_polynomial k
        _ ≤ cutoff := by omega)

/-- The explicit rational polynomial evaluates to the repeated-move slot
multiplicity on every natural input. -/
lemma repeated_move_multiplicity
    (cutoff : ℕ)
    (left : CWord Atom)
    (hleft :
      NPTail.isFirstCurrent left = true ∨
        NPTail.isSecondCurrent left = true)
    (rights : List (CWord Atom))
    (slot : CWord Atom)
    (steps : ℕ) :
    (repeatedMoveSlot cutoff left rights slot).eval
        (steps : ℚ) =
      (repeatedMoveMultiplicity cutoff left rights slot steps : ℚ) := by
  rw [repeatedMoveSlot, Polynomial.eval_finsetSum]
  simp_rw [Polynomial.eval_mul, Polynomial.eval_C, eval_nat_choose]
  rw [repeatedMoveMultiplicity,
    iterated_move_range
      cutoff left hleft rights steps slot]
  norm_cast
  simp [Nat.mul_comm]

/--
Every retained Hall-Witt slot multiplicity after repeatedly routing one
current word is an integer-valued polynomial of cutoff-bounded degree.
-/
lemma repeated_move_most
    (cutoff : ℕ)
    (left : CWord Atom)
    (hleft :
      NPTail.isFirstCurrent left = true ∨
        NPTail.isSecondCurrent left = true)
    (rights : List (CWord Atom))
    (slot : CWord Atom) :
    IVMost
      (repeatedMoveMultiplicity cutoff left rights slot)
      cutoff := by
  exact
    ⟨repeatedMoveSlot cutoff left rights slot,
      repeated_move_slot
        cutoff left rights slot,
      repeated_move_multiplicity
        cutoff left hleft rights slot⟩

end RMSlot
end TCTex
