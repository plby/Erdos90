-- Alphabet.lean

/-!
# Finite alphabets for all-natural complete Hall-Witt schedules

The complete positive and negative transition schedules have an explicit
zero boundary and a successor normal form.  Every transition in either
all-natural schedule belongs to the fixed cutoff-dependent transition
alphabet, so their bounded affine terms live in the fixed finite term
alphabet as well.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace FTAlphab

open WSTrace
open WHNorm
open WNTrace
open WSTail
open NPTail
open OFState
open TOFact
open OTSubsti
open OTSched
open STSched
open SSExp
open STState
open SSFull
open TNForm

/-- Every transition in the positive all-natural schedule belongs to the
fixed cutoff-dependent transition alphabet. -/
lemma alphabet_natural_full
    (cutoff multiplicity : ℕ)
    (transition : SRTrans)
    (htransition :
      transition ∈ naturalFullSchedule cutoff multiplicity) :
    transition ∈ secondRouteAlphabet cutoff := by
  cases multiplicity with
  | zero =>
      simp at htransition
  | succ steps =>
      rw [natural_full_succ] at htransition
      rcases List.mem_append.mp htransition with htransition | htransition
      · unfold positiveFixedPrefix at htransition
        exact
          route_alphabet_prefix
            cutoff positiveOuterFactorization.before
              firstConventionalInverse
                positiveOuterFactorization.suffix (by simp)
                  transition htransition
      · exact
          middle_successor_skew
            cutoff steps firstConventionalInverse
              firstConventionalInverse firstConventionalWord
                secondConventionalInverse (by simp)
                  (positiveFilteredPrefix cutoff) transition
                    htransition

/-- Every transition in the negative all-natural schedule belongs to the
fixed cutoff-dependent transition alphabet. -/
lemma alphabet_full_schedule
    (cutoff multiplicity : ℕ)
    (transition : SRTrans)
    (htransition :
      transition ∈ negativeFullSchedule cutoff multiplicity) :
    transition ∈ secondRouteAlphabet cutoff := by
  cases multiplicity with
  | zero =>
      simp at htransition
  | succ steps =>
      rw [negative_full_succ] at htransition
      rcases List.mem_append.mp htransition with htransition | htransition
      · unfold negativeFixedPrefix at htransition
        exact
          route_alphabet_prefix
            cutoff negativeOuterFactorization.before firstConventionalWord
              negativeOuterFactorization.suffix (by simp)
                transition htransition
      · exact
          middle_successor_skew
            cutoff steps firstConventionalWord firstConventionalWord
              firstConventionalInverse secondConventionalWord (by simp)
                (negativeFilteredPrefix cutoff) transition
                  htransition

/-- Every bounded affine term of the positive all-natural schedule belongs
to the fixed cutoff-dependent term alphabet. -/
lemma supportedNaturalSchedule
    (cutoff multiplicity : ℕ) :
    SCAlphab cutoff
      (boundedConstantTerms cutoff
        (naturalFullSchedule cutoff multiplicity)) := by
  apply
    supported_alphabet_terms
  exact
    alphabet_natural_full
      cutoff multiplicity

/-- Every bounded affine term of the negative all-natural schedule belongs
to the fixed cutoff-dependent term alphabet. -/
lemma supportedNegativeSchedule
    (cutoff multiplicity : ℕ) :
    SCAlphab cutoff
      (boundedConstantTerms cutoff
        (negativeFullSchedule cutoff multiplicity)) := by
  apply
    supported_alphabet_terms
  exact
    alphabet_full_schedule
      cutoff multiplicity

end FTAlphab
end TCTex
end Submission

-- Merged from JacobiIntegralPowerStrictTailCutoffOrderedOuterPacketPolynomialClosure.lean

/-!
# Polynomial closure across factored Hall-Witt outer packets

One normalized Hall-Witt outer packet contributes a fixed transition prefix
followed by a dynamic crossing schedule over the previously emitted trace.
The fixed prefix is drawn from the cutoff transition alphabet.  Therefore,
once the dynamic crossing family has polynomial bounded-term coordinates, one
full outer packet preserves those coordinates without increasing their common
degree bound.

The fixed-alphabet multiplicity reduction then turns polynomial bounded-term
coordinates for either signed Hall-Witt schedule into slotwise polynomial
data for the complete strict-tail cutoff profile.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace TOClos

open WSTrace
open WHNorm
open WNTrace
open NPTail
open TACompos
open OFProgra
open OFProgra.FRProgra
open TOFact
open OTSched
open STSched
open SSExp
open STRec
open STState
open STClos
open OFState
open TMRed

/-- Polynomiality of the dynamic crossing family implies polynomiality after
one full factored outer packet. -/
lemma iterate_prepend_crossing
    (cutoff degreeBound : ℕ)
    (packet before suffix : List (CWord Atom))
    (selected : CWord Atom)
    (hpacket : packet = before ++ [selected] ++ suffix)
    (hselected : isFirstCurrent selected = true)
    (hbefore : ∀ word ∈ before, isFirstCurrent word ≠ true)
    (hsuffix : ∀ word ∈ suffix, isFirstCurrent word ≠ true)
    (tail : ℕ → FRProgra)
    (hcrossing :
      BCDataa cutoff degreeBound
        (fun steps =>
          boundedConstantTerms cutoff
            (((iteratePrepend cutoff isFirstCurrent packet steps
              (tail steps)).trace cutoff).map
                (SRTrans.crossed selected)))) :
    BCDataa cutoff degreeBound
      (fun steps =>
        boundedConstantTerms cutoff
          (transitionSchedule cutoff
            (iteratePrepend cutoff isFirstCurrent packet (steps + 1)
              (tail steps)))) := by
  apply
    (hcrossing.fold
      (fixedTransitionPrefix cutoff before selected suffix)
        (fun transition htransition =>
          route_alphabet_prefix
            cutoff before selected suffix hselected transition htransition)).congr
  intro steps
  rw [
    transition_prepend_append
      cutoff packet before suffix selected hpacket hselected hbefore hsuffix
        steps (tail steps),
    constant_terms_append]

/-- Positive normalized outer packets preserve polynomial bounded-term data
once their dynamic crossing family is polynomial. -/
lemma constant_positive_crossing
    (cutoff degreeBound : ℕ)
    (tail : ℕ → FRProgra)
    (hcrossing :
      BCDataa cutoff degreeBound
        (fun steps =>
          boundedConstantTerms cutoff
            (((iteratePrepend cutoff isFirstCurrent
              WNTrace.trace steps (tail steps)).trace
                cutoff).map
                  (SRTrans.crossed
                    firstConventionalInverse)))) :
    BCDataa cutoff degreeBound
      (fun steps =>
        boundedConstantTerms cutoff
          (transitionSchedule cutoff
            (iteratePrepend cutoff isFirstCurrent
              WNTrace.trace (steps + 1)
                (tail steps)))) := by
  apply
    iterate_prepend_crossing
      cutoff degreeBound WNTrace.trace
        positiveOuterFactorization.before
          positiveOuterFactorization.suffix
            firstConventionalInverse
  · exact positiveOuterFactorization.packet_eq
  · simp
  · exact positiveOuterFactorization.before_not_current
  · exact positiveOuterFactorization.suffix_not_current
  · exact hcrossing

/-- Negative inverted outer packets preserve polynomial bounded-term data
once their dynamic crossing family is polynomial. -/
lemma bounded_constant_crossing
    (cutoff degreeBound : ℕ)
    (tail : ℕ → FRProgra)
    (hcrossing :
      BCDataa cutoff degreeBound
        (fun steps =>
          boundedConstantTerms cutoff
            (((iteratePrepend cutoff isFirstCurrent
              NNPower.inverseNormalizedTrace
                steps (tail steps)).trace cutoff).map
                  (SRTrans.crossed firstConventionalWord)))) :
    BCDataa cutoff degreeBound
      (fun steps =>
        boundedConstantTerms cutoff
          (transitionSchedule cutoff
            (iteratePrepend cutoff isFirstCurrent
              NNPower.inverseNormalizedTrace
                (steps + 1) (tail steps)))) := by
  apply
    iterate_prepend_crossing
      cutoff degreeBound
        NNPower.inverseNormalizedTrace
          negativeOuterFactorization.before
            negativeOuterFactorization.suffix firstConventionalWord
  · exact negativeOuterFactorization.packet_eq
  · simp
  · exact negativeOuterFactorization.before_not_current
  · exact negativeOuterFactorization.suffix_not_current
  · exact hcrossing

/-- Polynomial bounded-term data for the positive schedule discharges the
positive strict-tail cutoff-profile polynomial obligation. -/
lemma natural_strict_term
    (cutoff degreeBound : ℕ)
    (hcutoff : 3 < cutoff)
    (hterms :
      BCDataa cutoff degreeBound
        (fun multiplicity =>
          boundedConstantTerms cutoff
            (transitionSchedule cutoff
              (naturalRouteProgram cutoff multiplicity)))) :
    CPDataa cutoff degreeBound
      (fun multiplicity =>
        TBProf.cutoffProfile
          cutoff
            (NPTail.strictTrace
              multiplicity)) := by
  exact
    cutoff_natural_multiplicity
      cutoff degreeBound hcutoff
        (fun term _hterm => hterms.2 term)

/-- Polynomial bounded-term data for the negative schedule discharges the
negative strict-tail cutoff-profile polynomial obligation. -/
lemma negative_strict_term
    (cutoff degreeBound : ℕ)
    (hcutoff : 3 < cutoff)
    (hterms :
      BCDataa cutoff degreeBound
        (fun multiplicity =>
          boundedConstantTerms cutoff
            (transitionSchedule cutoff
              (negativeRouteProgram cutoff multiplicity)))) :
    CPDataa cutoff degreeBound
      (fun multiplicity =>
        TBProf.cutoffProfile
          cutoff
            (NNPower.strictTrace
              multiplicity)) := by
  exact
    cutoff_negative_multiplicity
      cutoff degreeBound hcutoff
        (fun term _hterm => hterms.2 term)

end TOClos
end TCTex
end Submission

