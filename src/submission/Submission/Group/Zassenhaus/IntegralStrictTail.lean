/-!
# Successor orbit-prefix compiler for the Hall-Witt packet affine endpoint

The fixed packet affine prefix is exactly the ordinary second-route compiler
of the filtered emitted prefix.  The dynamic swap across an orbit prefix is
the ordinary compiler of one homogeneous cutoff move.  Composition therefore
recovers the ordinary compiler of the successor orbit prefix.

This turns the remaining formal-predecessor endpoint cancellation into the
origin boundary for one unshifted orbit-prefix compiler family.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace ASComp

open WSTrace
open WHNorm
open WNTrace
open NPTail
open ARProfa
open ARProfa.CPAffine
open ASFilt
open SARec
open TOFact
open OTSubsti
open OTDecomp
open EOPrefix
open APKern

/-- The fixed affine contribution of a factored outer packet is the compiler
of its filtered emitted prefix. -/
lemma affine_filtered_prefix
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (before : List (CWord Atom))
    (selected : CWord Atom)
    (suffix : List (CWord Atom))
    (hselected : isFirstCurrent selected = true) :
    fixedSecondAffine cutoff before selected suffix =
      ofTrace cutoff isSecondCurrent
        (filteredOuterPrefix cutoff before selected suffix) := by
  unfold fixedSecondAffine filteredOuterPrefix
  rw [second_current_below cutoff hcutoff]
  rw [ofTrace_append,
    move_higher_affine cutoff selected hselected]

/-- A homogeneous cutoff move compiles to its dynamic swap affine action. -/
lemma move_swap_affine
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (selected : CWord Atom)
    (hselected : isFirstCurrent selected = true)
    (rights : List (CWord Atom)) :
    ofTrace cutoff isSecondCurrent
        (cutoffMoveTrace cutoff selected rights) =
      swapSecondAffine cutoff selected rights := by
  rw [move_below_higher,
    second_current_below cutoff hcutoff,
    move_higher_affine cutoff selected hselected]

/-- One fixed packet compiler followed by its dynamic orbit swap is exactly
the ordinary compiler of the successor emitted orbit prefix. -/
lemma fixed_affine_succ
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (before : List (CWord Atom))
    (selected : CWord Atom)
    (suffix : List (CWord Atom))
    (hselected : isFirstCurrent selected = true)
    (steps : ℕ) :
    (fixedSecondAffine cutoff before selected suffix).comp
        (swapSecondAffine cutoff selected
          (cutoffMovePrefix cutoff selected
            (filteredOuterPrefix cutoff before selected suffix) steps)) =
      ofTrace cutoff isSecondCurrent
        (cutoffMovePrefix cutoff selected
          (filteredOuterPrefix cutoff before selected suffix)
            (steps + 1)) := by
  rw [affine_filtered_prefix
    cutoff hcutoff before selected suffix hselected]
  rw [move_prefix_succ, ofTrace_append]
  rw [move_swap_affine
    cutoff hcutoff selected hselected]

/-- Positive fixed-prefix/dynamic-swap evaluation is the successor positive
orbit-prefix compiler endpoint. -/
lemma positive_fixed_prefix
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (steps : ℕ) :
    (positiveSecondAffine cutoff).apply
        (positiveEmptyEndpoint cutoff steps) =
      (ofTrace cutoff isSecondCurrent
        (cutoffMovePrefix cutoff firstConventionalInverse
          (positiveFilteredPrefix cutoff) (steps + 1))).apply 0 := by
  unfold positiveSecondAffine
    positiveEmptyEndpoint positiveFilteredPrefix
  rw [← CPAffine.apply_comp]
  rw [
    fixed_affine_succ
      cutoff hcutoff positiveOuterFactorization.before
        firstConventionalInverse positiveOuterFactorization.suffix
          (by simp) steps]

/-- Negative fixed-prefix/dynamic-swap evaluation is the successor negative
orbit-prefix compiler endpoint. -/
lemma negative_fixed_prefix
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (steps : ℕ) :
    (negativeSecondAffine cutoff).apply
        (negativeEmptyEndpoint cutoff steps) =
      (ofTrace cutoff isSecondCurrent
        (cutoffMovePrefix cutoff firstConventionalWord
          (negativeFilteredPrefix cutoff) (steps + 1))).apply 0 := by
  unfold negativeSecondAffine
    negativeEmptyEndpoint negativeFilteredPrefix
  rw [← CPAffine.apply_comp]
  rw [
    fixed_affine_succ
      cutoff hcutoff negativeOuterFactorization.before
        firstConventionalWord negativeOuterFactorization.suffix
          (by simp) steps]

end ASComp
end TCTex
