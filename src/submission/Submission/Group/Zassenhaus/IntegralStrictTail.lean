    (cutoff : ℕ) :
    EmptySuccessorNewton
        cutoff ↔
      EmptyFormalPredecessor
        cutoff := by
  unfold
    EmptySuccessorNewton
    EmptyFormalPredecessor
    emptyFormalPredecessor
  apply forall_congr'
  intro slot
  rw [newton_evaluation_affine cutoff
    (negativeFullBound cutoff)
      (negativeSecondAffine cutoff)
        (negativeEmptyEndpoint cutoff)
          (supported_empty_endpoint
            cutoff) slot]

/-- The positive signed-profile fixed-affine kernel discharges global
positive strict-tail cutoff-profile polynomiality. -/
lemma natural_fixed_affine
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (hkernel :
