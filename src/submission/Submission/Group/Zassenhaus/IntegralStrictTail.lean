/-!
# Nested repeated-block normal forms for Hall-Witt first routes

The homogeneous cutoff movement induced by an outer Hall-Witt packet
distributes through concatenation and finite repetition.  Therefore the
dynamic suffix of the complete first route is a repetition of one nested
moved-singleton block.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace NRBlock

open WSTrace
open WHNorm
open WNTrace
open WSTail
open NPTail
open RMRecb
open TBProf
open OFProgra
open OFProgra.FRProgra
open ORBlock
open OTSubsti
open OTDecomp
open BDExp
open EOPrefix

/-- Iterated homogeneous cutoff movement preserves the empty trace. -/
lemma iterated_trace_nil
    (cutoff steps : ℕ)
    (selected : CWord Atom) :
    iteratedCutoffMove cutoff selected steps [] = [] := by
  simpa using
    (iterated_move_flat cutoff steps selected ([] : List Unit)
      (fun _unit => ([] : List (CWord Atom))))

/-- Iterated homogeneous cutoff movement distributes through concatenation. -/
lemma iterated_cutoff_append
    (cutoff steps : ℕ)
    (selected : CWord Atom)
    (left right : List (CWord Atom)) :
    iteratedCutoffMove cutoff selected steps (left ++ right) =
      iteratedCutoffMove cutoff selected steps left ++
        iteratedCutoffMove cutoff selected steps right := by
  simpa using
    (iterated_move_flat cutoff steps selected [left, right]
      (fun trace => trace))

/-- Iterated homogeneous cutoff movement commutes with finite trace
repetition. -/
lemma iterated_cutoff_repeat
    (cutoff steps : ℕ)
    (selected : CWord Atom)
    (trace : List (CWord Atom)) :
    ∀ copies : ℕ,
      iteratedCutoffMove cutoff selected steps (repeatTrace copies trace) =
        repeatTrace copies
          (iteratedCutoffMove cutoff selected steps trace)
  | 0 => by
      rw [repeatTrace, iterated_trace_nil]
      rfl
  | copies + 1 => by
      rw [repeatTrace, iterated_cutoff_append,
        iterated_cutoff_repeat cutoff steps selected trace copies,
        repeatTrace]

/-- The positive middle program remains a repeated singleton block after the
outer homogeneous cutoff movement. -/
lemma iterated_repeat_moved
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (steps : ℕ) :
    iteratedCutoffMove cutoff firstConventionalInverse steps
        ((iteratePrepend cutoff isFirstCurrent [firstConventionalWord] steps
          (iteratePrepend cutoff isFirstCurrent
            [secondConventionalInverse] steps .empty)).trace cutoff) =
      repeatTrace steps
        (iteratedCutoffMove cutoff firstConventionalInverse steps
          (unitBelowTrace cutoff
            (iteratedMoveHigher firstConventionalWord steps
              [secondConventionalInverse]))) := by
  rw [middle_repeat_singleton
    cutoff hcutoff steps, iterated_cutoff_repeat]

/-- The negative middle program remains a repeated singleton block after the
outer homogeneous cutoff movement. -/
lemma middle_repeat_moved
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (steps : ℕ) :
    iteratedCutoffMove cutoff firstConventionalWord steps
        ((iteratePrepend cutoff isFirstCurrent
          [firstConventionalInverse] steps
          (iteratePrepend cutoff isFirstCurrent [secondConventionalWord]
            steps .empty)).trace cutoff) =
      repeatTrace steps
        (iteratedCutoffMove cutoff firstConventionalWord steps
          (unitBelowTrace cutoff
            (iteratedMoveHigher firstConventionalInverse steps
              [secondConventionalWord]))) := by
  rw [middle_moved_singleton
    cutoff hcutoff steps, iterated_cutoff_repeat]

/-- The complete positive first route is an explicit outer orbit prefix
followed by a repeated nested moved-singleton block. -/
lemma route_moved_singleton
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (steps : ℕ) :
    (naturalRouteProgram cutoff steps).trace cutoff =
      cutoffMovePrefix cutoff firstConventionalInverse
          (positiveFilteredPrefix cutoff) steps ++
        repeatTrace steps
          (iteratedCutoffMove cutoff firstConventionalInverse steps
            (unitBelowTrace cutoff
              (iteratedMoveHigher firstConventionalWord steps
                [secondConventionalInverse]))) := by
  rw [natural_iterate_prepend,
    prepend_move_append,
    iterated_repeat_moved
      cutoff hcutoff steps]

/-- The complete negative first route is an explicit outer orbit prefix
followed by a repeated nested moved-singleton block. -/
lemma nested_moved_singleton
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (steps : ℕ) :
    (negativeRouteProgram cutoff steps).trace cutoff =
      cutoffMovePrefix cutoff firstConventionalWord
          (negativeFilteredPrefix cutoff) steps ++
        repeatTrace steps
          (iteratedCutoffMove cutoff firstConventionalWord steps
            (unitBelowTrace cutoff
              (iteratedMoveHigher firstConventionalInverse steps
                [secondConventionalWord]))) := by
  rw [negative_iterate_prepend,
    iterate_prepend_append,
    middle_repeat_moved
      cutoff hcutoff steps]

end NRBlock
end TCTex
end Submission

