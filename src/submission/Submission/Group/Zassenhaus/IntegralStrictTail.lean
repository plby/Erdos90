open NPTail
open TBProf
open ARProfa
open ARProfa.CPAffine
open ARProf
open TACompos

/-- Polynomial cutoff-profile data for the explicit positive first-pass
affine action. -/
lemma natural_pass_affine
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff) :
    CPDataa cutoff (cutoff + (cutoff + cutoff))
      (fun multiplicity =>
        (naturalPassAffine cutoff multiplicity).apply 0) := by
  rw [show
    (fun multiplicity =>
      (naturalPassAffine cutoff multiplicity).apply 0) =
        fun multiplicity =>
          (iterate
            (ofTrace cutoff isFirstCurrent
              WNTrace.trace) multiplicity).apply
            ((iterate
              (ofTrace cutoff isFirstCurrent [firstConventionalWord])
                multiplicity).apply
              ((iterate
                (ofTrace cutoff isFirstCurrent
                  [secondConventionalInverse]) multiplicity).apply 0)) by
      funext multiplicity
      simp [naturalPassAffine]]
  simpa using
    (((cutoff_profile_zero cutoff 0).iterate_trace_apply
        hcutoff isFirstCurrent [secondConventionalInverse])
      |>.iterate_trace_apply
        hcutoff isFirstCurrent [firstConventionalWord])
      |>.iterate_trace_apply
        hcutoff isFirstCurrent WNTrace.trace

/-- Every retained slot in the literal positive first routed trace is a
uniformly bounded integer-valued polynomial. -/
lemma natural_routed_fst
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff) :
    CPDataa cutoff (cutoff + (cutoff + cutoff))
      (fun multiplicity =>
        cutoffProfile cutoff
          (NPTail.firstRouted multiplicity).1) := by
  rw [show
    (fun multiplicity =>
      cutoffProfile cutoff
        (NPTail.firstRouted multiplicity).1) =
        fun multiplicity =>
          (naturalPassAffine cutoff multiplicity).apply 0 by
      funext multiplicity
      exact profile_routed_fst cutoff multiplicity]
  exact natural_pass_affine cutoff hcutoff

/-- Polynomial cutoff-profile data for the explicit negative first-pass
affine action. -/
lemma negative_pass_affine
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff) :
    CPDataa cutoff (cutoff + (cutoff + cutoff))
      (fun multiplicity =>
        (negativePassAffine cutoff multiplicity).apply 0) := by
  rw [show
    (fun multiplicity =>
      (negativePassAffine cutoff multiplicity).apply 0) =
        fun multiplicity =>
          (iterate
            (ofTrace cutoff isFirstCurrent
              NNPower.inverseNormalizedTrace)
              multiplicity).apply
            ((iterate
              (ofTrace cutoff isFirstCurrent [firstConventionalInverse])
                multiplicity).apply
              ((iterate
                (ofTrace cutoff isFirstCurrent [secondConventionalWord])
                  multiplicity).apply 0)) by
      funext multiplicity
      simp [negativePassAffine]]
  simpa using
    (((cutoff_profile_zero cutoff 0).iterate_trace_apply
        hcutoff isFirstCurrent [secondConventionalWord])
      |>.iterate_trace_apply
        hcutoff isFirstCurrent [firstConventionalInverse])
      |>.iterate_trace_apply
        hcutoff isFirstCurrent
          NNPower.inverseNormalizedTrace

/-- Every retained slot in the literal negative first routed trace is a
uniformly bounded integer-valued polynomial. -/
lemma negative_routed_fst
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff) :
    CPDataa cutoff (cutoff + (cutoff + cutoff))
      (fun multiplicity =>
        cutoffProfile cutoff
          (NNPower.firstRouted
            multiplicity).1) := by
  rw [show
    (fun multiplicity =>
      cutoffProfile cutoff
        (NNPower.firstRouted
          multiplicity).1) =
        fun multiplicity =>
          (negativePassAffine cutoff multiplicity).apply 0 by
      funext multiplicity
      exact cutoff_routed_fst cutoff multiplicity]
  exact negative_pass_affine cutoff hcutoff

