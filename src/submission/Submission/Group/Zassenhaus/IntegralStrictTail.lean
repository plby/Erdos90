            y.weight PEAddres.weight +
          z.weight PEAddres.weight + 1) :
    filteredReconstructedProfile
        PEAddres.weight x y z cutoff coefficient = 0 := by
  exact
    filtered_reconstructed_parent
      PEAddres.weight PEAddres.weight_pos
        x y z cutoff hcutoff coefficient hparent

/--
