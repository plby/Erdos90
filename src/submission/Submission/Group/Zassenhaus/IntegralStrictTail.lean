    (cutoff : ℕ)
    (coefficient : ℤ)
    (slot : CWord Atom) :
    ℕ :=
  ((belowCutoffTrace cutoff coefficient).filter fun word =>
    decide (word = slot)).length

/-- Slots outside the formal cutoff vocabulary have zero multiplicity. -/
lemma occurrence_multiplicity_vocabulary
    {cutoff : ℕ}
    {coefficient : ℤ}
    {slot : CWord Atom}
