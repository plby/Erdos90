namespace ODPoly

open CWTrace
open TACompos
open BDExp

/-- One binary strict/retained expansion step preserves the number of
depth-zero entries. -/
lemma count_flat_succ :
    ∀ depths : List ℕ,
      (depths.flatMap fun depth => [depth + 1, depth]).count 0 =
        depths.count 0
  | [] => by
      rfl
  | depth :: depths => by
      rw [List.flatMap_cons, List.count_append,
        count_flat_succ depths]
      simp [List.count_cons]
      omega

/-- At positive depth, one binary strict/retained expansion step satisfies
Pascal's recurrence. -/
lemma count_flat_self
    (target : ℕ) :
    ∀ depths : List ℕ,
      (depths.flatMap fun depth => [depth + 1, depth]).count (target + 1) =
        depths.count target + depths.count (target + 1)
  | [] => by
      rfl
  | depth :: depths => by
      rw [List.flatMap_cons, List.count_append,
        count_flat_self target depths]
      simp only [List.count_cons]
      simp
      omega

/-- The exact ordered strict-depth schedule has binomial depth
multiplicities. -/
lemma count_strict_schedule
    (steps depth : ℕ) :
    (strictDepthSchedule steps).count depth =
      steps.choose depth := by
  induction steps generalizing depth with
  | zero =>
      cases depth <;> simp [strictDepthSchedule]
  | succ steps ih =>
      cases depth with
      | zero =>
          rw [strictDepthSchedule, count_flat_succ, ih]
          simp
      | succ depth =>
          rw [strictDepthSchedule, count_flat_self, ih, ih]
          exact (Nat.choose_succ_succ' steps depth).symm

/-- Multiplicity of one strict depth after truncating the ordered schedule at
the cutoff. -/
def boundedStrictMultiplicity
    (cutoff depth steps : ℕ) :
    ℕ :=
  ((strictDepthSchedule steps).filter fun nextDepth =>
    decide (nextDepth < cutoff)).count depth

/-- Truncating the ordered schedule keeps precisely the binomial coordinates
inside the fixed bounded depth alphabet. -/
lemma bounded_multiplicity_ite
    (cutoff depth steps : ℕ) :
    boundedStrictMultiplicity cutoff depth steps =
      if depth < cutoff then steps.choose depth else 0 := by
  unfold boundedStrictMultiplicity
  rw [count_filter_ite, count_strict_schedule]
  simp

/-- Every cutoff-truncated strict-depth coordinate is an integer-valued
polynomial with its natural depth bound. -/
lemma bounded_valued_most
    (cutoff depth : ℕ) :
    IVMost
      (fun steps : ℕ =>
        (boundedStrictMultiplicity cutoff depth steps : ℤ))
      depth := by
  by_cases hdepth : depth < cutoff
  · simpa [bounded_multiplicity_ite, hdepth] using
      choose_valued_most depth
  · rw [show
      (fun steps : ℕ =>
        (boundedStrictMultiplicity cutoff depth steps : ℤ)) =
        fun _steps : ℕ => 0 by
      funext steps
      simp [bounded_multiplicity_ite, hdepth]]
    exact
      TCTex.IVMost.zero
