/-!
# Next-layer residual after concrete Hall recollection of strict tails

The concrete Hall-coordinate Newton recipes determine an ordered fixed-weight
Hall segment.  Removing that segment from the retained strict-tail product
leaves a residual in the next lower-central term.  This is the group-level
consequence of the associated-graded recipe reconstruction; it does not assert
an order for the original strict-tail packet.

This file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace
  PRResid

open TEAddres
open
  SAGraded
open
  GPBasis
open
  PRVector
open
  PRRecons

universe u


/-- Concrete Hall exponents of the positive retained strict-tail parent layer. -/
noncomputable def concreteParentCoordinates
    (d n : ℕ)
    (x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d)))
    (cutoff multiplicity : ℕ)
    (hparent :
      exponentAddressParent x y z + 1 < n) :
    AddressParentIndex d x y z → ℤ :=
  fun i =>
    (addressNaturalParent
      d n x y z cutoff hparent i).eval multiplicity

/--
Concrete Hall exponents of the shifted-negative retained strict-tail parent
layer.
-/
noncomputable def addressParentCoordinates
    (d n : ℕ)
    (x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d)))
    (cutoff magnitude : ℕ)
    (hparent :
      exponentAddressParent x y z + 1 < n) :
    AddressParentIndex d x y z → ℤ :=
  fun i =>
    (addressParentExpansion
      d n x y z cutoff hparent i).eval magnitude

/-- Concrete Hall exponents of either signed retained strict-tail branch. -/
noncomputable def concreteAddressCoordinates
    (d n : ℕ)
    (x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d)))
    (cutoff : ℕ)
    (coefficient : ℤ)
    (hparent :
      exponentAddressParent x y z + 1 < n) :
    AddressParentIndex d x y z → ℤ :=
  match coefficient with
  | .ofNat multiplicity =>
      concreteParentCoordinates
        d n x y z cutoff multiplicity hparent
  | .negSucc magnitude =>
      addressParentCoordinates
        d n x y z cutoff magnitude hparent

/--
Equality in one lower-central associated-graded layer says precisely that the
ordered Hall representative leaves a residual in the next layer.
-/
private lemma
  smul_associated_graded
    (d n layer : ℕ)
    (H : BCWta.{u} d (layer + 1))
    (e : H.index → ℤ)
    (terms :
      Subgroup.lowerCentralSeries
        (LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n)
        layer)
    (hclass :
      (∑ i, e i • (H.commutator i).associatedGradedClass (n := n)) =
        TBluepr.lowerCentralClass layer terms) :
    (H.collectedWeightProduct (n := n) e)⁻¹ * (terms :
      LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n) ∈
        Subgroup.lowerCentralSeries
          (LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n)
          (layer + 1) := by
  let N : Type u :=
    LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n
  let r := layer + 1
  letI : IsMulCommutative (AssociatedGradedLayer N r) :=
    associated_graded_commutative r
  letI : CommGroup (AssociatedGradedLayer N r) :=
    { (inferInstance : Group (AssociatedGradedLayer N r)) with
      mul_comm := mul_comm' }
  let A : Subgroup N := Subgroup.lowerCentralSeries N layer
  let B : Subgroup A := (Subgroup.lowerCentralSeries N (layer + 1)).subgroupOf A
  let q : A →* A ⧸ B := QuotientGroup.mk' B
  let segment : A := H.collected_lower_centralterm (n := n) e
  have hsegmentClass :
      q segment = q terms := by
    rw [show q segment =
        Additive.toMul
          (∑ i, e i • (H.commutator i).associatedGradedClass (n := n)) by
      exact H.collectedlower_centtermclas_eqmulsum e]
    rw [hclass]
    rfl
  have hresidual : segment⁻¹ * terms ∈ B := by
    apply (QuotientGroup.eq_one_iff (N := B) (segment⁻¹ * terms)).mp
    change q (segment⁻¹ * terms) = 1
    rw [map_mul, map_inv, hsegmentClass, inv_mul_cancel]
  exact hresidual

/--
Removing the positive concrete Hall recipe segment from the retained
strict-tail product leaves a next-layer residual.
-/
theorem address_natural_next
    (d n : ℕ)
    (x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d)))
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (hparent :
      exponentAddressParent x y z + 1 < n)
    (multiplicity : ℕ) :
    ((concreteCommutatorsWeight.{u} d
      (exponentAddressParent x y z + 1)).collectedWeightProduct
        (n := n)
        (concreteParentCoordinates
          d n x y z cutoff multiplicity hparent))⁻¹ *
      ((addressBelowTerms
        (n := n) x y z cutoff (Int.ofNat multiplicity)).prod :
          LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n) ∈
        Subgroup.lowerCentralSeries
          (LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n)
          (exponentAddressParent x y z + 1) := by
  apply
    smul_associated_graded
      d n (exponentAddressParent x y z)
        (concreteCommutatorsWeight.{u} d
          (exponentAddressParent x y z + 1))
        (concreteParentCoordinates
          d n x y z cutoff multiplicity hparent)
        (addressBelowTerms
          (n := n) x y z cutoff (Int.ofNat multiplicity)).prod
  exact
    associated_graded_cast
      d n x y z cutoff hcutoff hparent multiplicity

/--
Removing the shifted-negative concrete Hall recipe segment from the retained
strict-tail product leaves a next-layer residual.
-/
theorem address_negative_next
    (d n : ℕ)
    (x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d)))
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (hparent :
      exponentAddressParent x y z + 1 < n)
    (magnitude : ℕ) :
    ((concreteCommutatorsWeight.{u} d
      (exponentAddressParent x y z + 1)).collectedWeightProduct
        (n := n)
        (addressParentCoordinates
          d n x y z cutoff magnitude hparent))⁻¹ *
      ((addressBelowTerms
        (n := n) x y z cutoff (Int.negSucc magnitude)).prod :
          LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n) ∈
        Subgroup.lowerCentralSeries
          (LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n)
          (exponentAddressParent x y z + 1) := by
  apply
    smul_associated_graded
      d n (exponentAddressParent x y z)
        (concreteCommutatorsWeight.{u} d
          (exponentAddressParent x y z + 1))
        (addressParentCoordinates
          d n x y z cutoff magnitude hparent)
        (addressBelowTerms
          (n := n) x y z cutoff (Int.negSucc magnitude)).prod
  exact
    associated_graded_succ
      d n x y z cutoff hcutoff hparent magnitude

/--
Uniform signed form of the next-layer residual theorem.
-/
theorem address_prod_next
    (d n : ℕ)
    (x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d)))
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (hparent :
      exponentAddressParent x y z + 1 < n)
    (coefficient : ℤ) :
    ((concreteCommutatorsWeight.{u} d
      (exponentAddressParent x y z + 1)).collectedWeightProduct
        (n := n)
        (concreteAddressCoordinates
          d n x y z cutoff coefficient hparent))⁻¹ *
      ((addressBelowTerms
        (n := n) x y z cutoff coefficient).prod :
          LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n) ∈
        Subgroup.lowerCentralSeries
          (LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n)
          (exponentAddressParent x y z + 1) := by
  cases coefficient with
  | ofNat multiplicity =>
      exact
        address_natural_next
          d n x y z cutoff hcutoff hparent multiplicity
  | negSucc magnitude =>
      exact
        address_negative_next
          d n x y z cutoff hcutoff hparent magnitude

end
  PRResid
end TCTex
end Submission

