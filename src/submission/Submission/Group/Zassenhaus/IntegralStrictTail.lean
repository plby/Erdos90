/-- Common recipe target weight for positive complete-schedule bounded-term
successor coordinates. -/
noncomputable def naturalFullBound
    (cutoff : ℕ) :
    ℕ :=
  cutoff *
      (2 * cutoff + (positiveFilteredPrefix cutoff).length + 4) +
    1

/-- Common recipe target weight for negative complete-schedule bounded-term
successor coordinates. -/
noncomputable def negativeFullBound
    (cutoff : ℕ) :
    ℕ :=
  cutoff *
      (2 * cutoff + (negativeFilteredPrefix cutoff).length + 4) +
    1

/-- Newton-normalized positive successor expansion for one bounded affine
term. -/
noncomputable def naturalFullExpansion
    (cutoff : ℕ)
    (target : OCTerm) :
    BCExp 1
      (naturalFullBound cutoff) :=
  BCExp.binomialBasis 1
    (naturalFullBound cutoff) (by omega)
      (fun steps : ℕ =>
        ((boundedConstantTerms cutoff
          (naturalFullSchedule cutoff (steps + 1))).count
            target : ℤ))

/-- Newton-normalized negative successor expansion for one bounded affine
term. -/
noncomputable def negativeFullExpansion
    (cutoff : ℕ)
    (target : OCTerm) :
    BCExp 1
      (negativeFullBound cutoff) :=
  BCExp.binomialBasis 1
    (negativeFullBound cutoff) (by omega)
      (fun steps : ℕ =>
        ((boundedConstantTerms cutoff
          (negativeFullSchedule cutoff (steps + 1))).count
            target : ℤ))

/-- Positive bounded-term successor recipes, one for every formal bounded
term in the cutoff alphabet. -/
noncomputable def naturalFullVector
    (cutoff : ℕ) :
    List
      (BCExp 1
        (naturalFullBound cutoff)) :=
  (boundedConstantAlphabet cutoff).map fun target =>
    naturalFullExpansion cutoff target

/-- Negative bounded-term successor recipes, one for every formal bounded
term in the cutoff alphabet. -/
noncomputable def negativeFullVector
    (cutoff : ℕ) :
    List
      (BCExp 1
        (negativeFullBound cutoff)) :=
  (boundedConstantAlphabet cutoff).map fun target =>
    negativeFullExpansion cutoff target

/-- Every Newton coefficient of the zero bounded-term family vanishes. -/
lemma nat_binomial_family
    (k : ℕ) :
    natBinomialCoefficient (fun _steps : ℕ => 0) k = 0 := by
  induction k using Nat.strong_induction_on with
  | h k ih =>
      cases k with
      | zero =>
          simp [natBinomialCoefficient]
      | succ k =>
          simp only [natBinomialCoefficient, zero_sub, neg_eq_zero]
          apply Finset.sum_eq_zero
          intro i _hi
          rw [ih i i.isLt]
          simp

/-- Universal termwise alternating Newton boundary. -/
def NewtonSumsVanish
    (degreeBound : ℕ)
    (family : ℕ → List OCTerm) :
    Prop :=
  ∀ target,
    SuccessorAlternatingVanishes degreeBound
      (fun multiplicity : ℕ => ((family multiplicity).count target : ℤ))

/-- Finite-alphabet termwise alternating Newton boundary. -/
def AlternatingSumsVanish
    (cutoff degreeBound : ℕ)
    (family : ℕ → List OCTerm) :
    Prop :=
  ∀ target ∈ boundedConstantAlphabet cutoff,
    SuccessorAlternatingVanishes degreeBound
      (fun multiplicity : ℕ => ((family multiplicity).count target : ℤ))

/-- For supported bounded-term families, the universal alternating boundary
reduces to the finite bounded-term alphabet. -/
lemma sums_vanish_vocabulary
    {cutoff degreeBound : ℕ}
    {family : ℕ → List OCTerm}
    (hsupport :
      ∀ multiplicity,
        SCAlphab cutoff
          (family multiplicity)) :
    NewtonSumsVanish
        degreeBound family ↔
      AlternatingSumsVanish
        cutoff degreeBound family := by
  constructor
  · intro hall target _htarget
    exact hall target
  · intro hvocabulary target
    by_cases htarget :
        target ∈ boundedConstantAlphabet cutoff
    · exact hvocabulary target htarget
    · unfold SuccessorAlternatingVanishes
      rw [show
        (fun steps : ℕ => ((family (steps + 1)).count target : ℤ)) =
            fun _steps : ℕ => 0 by
        funext steps
        have hnotMem : target ∉ family (steps + 1) := by
          intro hmem
          exact htarget (hsupport (steps + 1) target hmem)
        simp [List.count_eq_zero.mpr hnotMem]]
      apply Finset.sum_eq_zero
      intro k _hk
      rw [nat_binomial_family]
      simp

/-- A finite vector of bounded-term coordinate expansions vanishes at formal
predecessor input `-1`. -/
def BoundedVectorVanishes
    {targetWeight : ℕ}
    (vector : List (BCExp 1 targetWeight)) :
    Prop :=
  ∀ expansion ∈ vector, expansion.evalInt (-1) = 0

/-- Positive finite-alphabet bounded-term cancellation is exactly signed
evaluation of the explicit positive recipe vector at `-1`. -/
lemma natural_full_vanishes
    (cutoff : ℕ) :
    BoundedVectorVanishes
        (naturalFullVector cutoff) ↔
      AlternatingSumsVanish
        cutoff (naturalFullBound cutoff)
          (fun multiplicity =>
            boundedConstantTerms cutoff
              (naturalFullSchedule cutoff multiplicity)) := by
  constructor
  · intro hvector target htarget
    have htargetExpansion :=
      hvector (naturalFullExpansion cutoff target)
        (by
          apply List.mem_map.mpr
          exact ⟨target, htarget, rfl⟩)
    unfold SuccessorAlternatingVanishes
    rw [naturalFullExpansion,
      BCExp.eval_int_binomial] at htargetExpansion
    simpa using htargetExpansion
  · intro hvocabulary expansion hexpansion
    change
      expansion ∈
        (boundedConstantAlphabet cutoff).map
          (naturalFullExpansion cutoff) at hexpansion
    rcases List.mem_map.mp hexpansion with ⟨target, htarget, rfl⟩
    have htargetBoundary := hvocabulary target htarget
    unfold SuccessorAlternatingVanishes at htargetBoundary
    rw [naturalFullExpansion,
      BCExp.eval_int_binomial]
    simpa using htargetBoundary

/-- Negative finite-alphabet bounded-term cancellation is exactly signed
evaluation of the explicit negative recipe vector at `-1`. -/
lemma negative_full_vanishes
    (cutoff : ℕ) :
    BoundedVectorVanishes
        (negativeFullVector cutoff) ↔
      AlternatingSumsVanish
        cutoff (negativeFullBound cutoff)
          (fun multiplicity =>
            boundedConstantTerms cutoff
              (negativeFullSchedule cutoff multiplicity)) := by
  constructor
  · intro hvector target htarget
    have htargetExpansion :=
      hvector (negativeFullExpansion cutoff target)
        (by
          apply List.mem_map.mpr
          exact ⟨target, htarget, rfl⟩)
    unfold SuccessorAlternatingVanishes
    rw [negativeFullExpansion,
      BCExp.eval_int_binomial] at htargetExpansion
    simpa using htargetExpansion
  · intro hvocabulary expansion hexpansion
    change
      expansion ∈
        (boundedConstantAlphabet cutoff).map
          (negativeFullExpansion cutoff) at hexpansion
    rcases List.mem_map.mp hexpansion with ⟨target, htarget, rfl⟩
    have htargetBoundary := hvocabulary target htarget
    unfold SuccessorAlternatingVanishes at htargetBoundary
    rw [negativeFullExpansion,
      BCExp.eval_int_binomial]
    simpa using htargetBoundary

/-- Vanishing of the positive finite bounded-term recipe vector discharges
global bounded-term polynomiality. -/
lemma constant_natural_vanishes
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (hvector :
      BoundedVectorVanishes
        (naturalFullVector cutoff)) :
    BCDataa cutoff
      (naturalFullBound cutoff)
      (fun multiplicity =>
        boundedConstantTerms cutoff
          (naturalFullSchedule cutoff multiplicity)) := by
  apply
    full_match_origin
      cutoff hcutoff
  intro target
  have hall :
      NewtonSumsVanish
        (naturalFullBound cutoff)
        (fun multiplicity =>
          boundedConstantTerms cutoff
            (naturalFullSchedule cutoff multiplicity)) := by
    rw [
      sums_vanish_vocabulary
        (fun multiplicity =>
          supportedNaturalSchedule
            cutoff multiplicity)]
    exact
      (natural_full_vanishes
        cutoff).1 hvector
  have hvanish :
      SuccessorVanishNeg
        (fun multiplicity : ℕ =>
          ((boundedConstantTerms cutoff
            (naturalFullSchedule cutoff multiplicity)).count
              target : ℤ)) := by
    apply
      (vanish_alternating_vanishes
        ((constant_natural_full
          cutoff hcutoff).2 target)).2
    exact hall target
  apply (successor_origin_vanish
    (f := fun multiplicity : ℕ =>
      ((boundedConstantTerms cutoff
        (naturalFullSchedule cutoff multiplicity)).count
          target : ℤ)) ?_).2
  · exact hvanish
  · simp [naturalFullSchedule, boundedConstantTerms,
      orderedConstantTerms]

/-- Vanishing of the negative finite bounded-term recipe vector discharges
global bounded-term polynomiality. -/
lemma bounded_constant_vanishes
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (hvector :
      BoundedVectorVanishes
        (negativeFullVector cutoff)) :
    BCDataa cutoff
      (negativeFullBound cutoff)
      (fun multiplicity =>
        boundedConstantTerms cutoff
          (negativeFullSchedule cutoff multiplicity)) := by
  apply
    constant_match_origin
      cutoff hcutoff
  intro target
  have hall :
      NewtonSumsVanish
        (negativeFullBound cutoff)
        (fun multiplicity =>
          boundedConstantTerms cutoff
            (negativeFullSchedule cutoff multiplicity)) := by
    rw [
      sums_vanish_vocabulary
        (fun multiplicity =>
          supportedNegativeSchedule
            cutoff multiplicity)]
    exact
      (negative_full_vanishes
        cutoff).1 hvector
  have hvanish :
      SuccessorVanishNeg
        (fun multiplicity : ℕ =>
          ((boundedConstantTerms cutoff
            (negativeFullSchedule cutoff multiplicity)).count
              target : ℤ)) := by
    apply
      (vanish_alternating_vanishes
        ((constant_full_succ
          cutoff hcutoff).2 target)).2
    exact hall target
  apply (successor_origin_vanish
    (f := fun multiplicity : ℕ =>
      ((boundedConstantTerms cutoff
        (negativeFullSchedule cutoff multiplicity)).count
          target : ℤ)) ?_).2
  · exact hvanish
  · simp [negativeFullSchedule, boundedConstantTerms,
