            (exponentAddressParent x y z)
            (addressBelowTerms
              (n := n) x y z cutoff (Int.ofNat multiplicity)).prod) :=
  address_natural_expansion
    x y z cutoff hcutoff
      (concreteParentBasis d n x y z hparent) i

lemma address_parent_expansion
    (d n : ℕ)
    (x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d)))
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (hparent :
      exponentAddressParent x y z + 1 < n)
    (i : AddressParentIndex d x y z) :
