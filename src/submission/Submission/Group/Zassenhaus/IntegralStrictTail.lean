/-- Finite sums preserve a common integer-valued polynomial degree bound. -/
private lemma polynomial_finsetSum
    {ι : Type*}
    {degreeBound : ℕ}
    (slots : Finset ι)
    (family : ι → ℕ → ℤ)
    (hfamily :
      ∀ slot ∈ slots,
        IVMost
          (family slot) degreeBound) :
    IVMost
      (fun steps : ℕ => ∑ slot ∈ slots, family slot steps)
      degreeBound := by
  classical
  induction slots using Finset.induction_on with
  | empty =>
      simpa using
        TCTex.IVMost.zero
          degreeBound
  | @insert slot slots hslot ih =>
      simpa [Finset.sum_insert hslot] using
        TCTex.IVMost.add
          (hfamily slot (by simp))
          (ih (fun next hnext => hfamily next (by simp [hnext])))

