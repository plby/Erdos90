    d n x y z cutoff hparent i).eval_recipe_span

/-- Every selected shifted-negative concrete Hall coordinate is a bounded recipe. -/
lemma address_parent_span
    (d n : ℕ)
    (x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d)))
    (cutoff : ℕ)
    (hparent :
      exponentAddressParent x y z + 1 < n)
    (i : AddressParentIndex d x y z) :
    IntCombinationRecipes 1
      (negativeStrictBound cutoff)
      (addressParentExpansion
        d n x y z cutoff hparent i).eval :=
  (addressParentExpansion
    d n x y z cutoff hparent i).eval_recipe_span

/-- Ordered positive recipe vector for every canonical Hall index in the layer. -/
noncomputable def concreteAddressVector
    (d n : ℕ)
    (x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d)))
    (cutoff : ℕ)
    (hparent :
      exponentAddressParent x y z + 1 < n) :
    List
      (BCExp 1
        (naturalStrictBound cutoff)) :=
  (Finset.univ.sort fun
    i j : AddressParentIndex d x y z => i ≤ j).map
      fun i =>
        addressNaturalParent
          d n x y z cutoff hparent i

/--
Ordered shifted-negative recipe vector for every canonical Hall index in the
layer.
-/
noncomputable def addressParentVector
    (d n : ℕ)
    (x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d)))
    (cutoff : ℕ)
    (hparent :
      exponentAddressParent x y z + 1 < n) :
    List
      (BCExp 1
        (negativeStrictBound cutoff)) :=
  (Finset.univ.sort fun
    i j : AddressParentIndex d x y z => i ≤ j).map
      fun i =>
        addressParentExpansion
          d n x y z cutoff hparent i

lemma length_parent_vector
    (d n : ℕ)
    (x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d)))
    (cutoff : ℕ)
    (hparent :
      exponentAddressParent x y z + 1 < n) :
    (concreteAddressVector
      d n x y z cutoff hparent).length =
      Fintype.card (AddressParentIndex d x y z) := by
  simp [concreteAddressVector]

lemma length_address_vector
    (d n : ℕ)
    (x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d)))
    (cutoff : ℕ)
    (hparent :
      exponentAddressParent x y z + 1 < n) :
    (addressParentVector
      d n x y z cutoff hparent).length =
      Fintype.card (AddressParentIndex d x y z) := by
  simp [addressParentVector]

/--
Evaluating the positive recipe vector returns all selected concrete Hall
coordinates in canonical index order.
-/
lemma address_natural_vector
    (d n : ℕ)
    (x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d)))
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
