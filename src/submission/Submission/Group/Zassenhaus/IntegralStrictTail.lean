    (cutoff steps : ℕ) :
    SCVocabu cutoff
      (negativeEmptyEndpoint cutoff steps) := by
  unfold negativeEmptyEndpoint
  simpa [CPAffine.apply] using
    (preserves_swap_second cutoff
      firstConventionalWord (by simp)
        (cutoffMovePrefix cutoff firstConventionalWord
          (negativeFilteredPrefix cutoff) steps)).2

