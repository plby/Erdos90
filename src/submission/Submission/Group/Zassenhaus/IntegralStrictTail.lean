-- ingScheduleBoundedTermPolynomial.lean

/-!
# Polynomial bounded terms for successor-skew complete crossing schedules

The successor-skew complete crossing schedule has polynomial
ordered-subsequence coordinates. Its bounded affine-term state is therefore
polynomial, and the factored outer-packet recurrence yields polynomial bounded
terms for the positive and negative full schedules at successor
multiplicities.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace FSTerm

open WSTrace
open WHNorm
open WNTrace
open WSTail
open NPTail
open TACompos
open OFProgra
open OFProgra.FRProgra
open OTSubsti
open STSched
open SSExp
open STState
open STClos
open TOClos
open DTPoly
open BSRec
open SSFull

/-- Bounded ordered-term coordinates of a successor-skew complete
outer-middle crossing schedule are polynomial. -/
lemma constantSkewPoly
    (cutoff : ℕ)
    (crossed outer selected right : CWord Atom)
    (hcrossed : isFirstCurrent crossed = true)
    (emittedPrefix : List (CWord Atom))
    (target : OCTerm) :
    IVMost
      (fun steps : ℕ =>
        ((boundedConstantTerms cutoff
          (middleSuccessorSkew cutoff
            crossed outer selected right emittedPrefix steps)).count
              target : ℤ))
      (cutoff * (2 * cutoff + emittedPrefix.length + 4) + 1) := by
  by_cases htarget : target.strictTransitions.length < cutoff
  · rw [show
      (fun steps : ℕ =>
        ((boundedConstantTerms cutoff
          (middleSuccessorSkew cutoff
            crossed outer selected right emittedPrefix steps)).count
              target : ℤ)) =
        fun steps : ℕ =>
          ∑ producer ∈
              (secondRouteAlphabet cutoff).toFinset,
            if target.constant = (producer.affine cutoff).constant then
              (orderedSubsequenceMultiplicity
                (target.strictTransitions ++ [producer])
                (middleSuccessorSkew
                  cutoff crossed outer selected right emittedPrefix steps) : ℤ)
            else
              0 by
      funext steps
      exact_mod_cast
        constant_ite_producers
          cutoff (secondRouteAlphabet cutoff)
            (middleSuccessorSkew cutoff
              crossed outer selected right emittedPrefix steps)
            (fun transition htransition =>
              middle_successor_skew
                cutoff steps crossed outer selected right hcrossed emittedPrefix
                  transition htransition)
            target |>.trans (if_pos htarget)]
    apply IVMost.finsetSum
    intro producer _hproducer
    by_cases hconstant :
        target.constant = (producer.affine cutoff).constant
    · simp only [hconstant, ↓reduceIte]
      apply
        TCTex.IVMost.mono
      · change
          (target.strictTransitions.length + 1) *
                (2 * cutoff + emittedPrefix.length + 4) + 1 ≤
            cutoff * (2 * cutoff + emittedPrefix.length + 4) + 1
        exact
          Nat.add_le_add_right
            (Nat.mul_le_mul_right (2 * cutoff + emittedPrefix.length + 4)
              (Nat.succ_le_iff.mpr htarget))
            1
      · simpa using
          subsequenceMultSkew
            cutoff crossed outer selected right emittedPrefix
              (target.strictTransitions ++ [producer])
    · simp only [hconstant, ↓reduceIte]
      exact
        valued_most_constant
          (cutoff * (2 * cutoff + emittedPrefix.length + 4) + 1) 0
  · rw [show
      (fun steps : ℕ =>
        ((boundedConstantTerms cutoff
          (middleSuccessorSkew cutoff
            crossed outer selected right emittedPrefix steps)).count
              target : ℤ)) =
          fun _steps : ℕ => 0 by
      funext steps
      exact_mod_cast
        constant_ite_producers
          cutoff (secondRouteAlphabet cutoff)
            (middleSuccessorSkew cutoff
              crossed outer selected right emittedPrefix steps)
            (fun transition htransition =>
              middle_successor_skew
                cutoff steps crossed outer selected right hcrossed emittedPrefix
                  transition htransition)
            target |>.trans (if_neg htarget)]
    exact
      valued_most_constant
        (cutoff * (2 * cutoff + emittedPrefix.length + 4) + 1) 0

/-- A successor-skew complete outer-middle crossing schedule supplies common
bounded-term polynomial data. -/
lemma middleSkewSchedule
    (cutoff : ℕ)
    (crossed outer selected right : CWord Atom)
    (hcrossed : isFirstCurrent crossed = true)
    (emittedPrefix : List (CWord Atom)) :
    BCDataa cutoff
      (cutoff * (2 * cutoff + emittedPrefix.length + 4) + 1)
      (fun steps =>
        boundedConstantTerms cutoff
          (middleSuccessorSkew cutoff
            crossed outer selected right emittedPrefix steps)) := by
  constructor
  · intro steps
    apply
      supported_alphabet_terms
    intro transition htransition
    exact
      middle_successor_skew
        cutoff steps crossed outer selected right hcrossed emittedPrefix
          transition htransition
  · exact
      constantSkewPoly
        cutoff crossed outer selected right hcrossed emittedPrefix

/-- The positive crossed tail needed by the outer-packet recurrence has
polynomial bounded-term coordinates. -/
lemma middleProgramSucc
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff) :
    BCDataa cutoff
      (cutoff *
          (2 * cutoff + (positiveFilteredPrefix cutoff).length + 4) +
        1)
      (fun steps =>
        boundedConstantTerms cutoff
          (((iteratePrepend cutoff isFirstCurrent
            WNTrace.trace steps
              (iteratePrepend cutoff isFirstCurrent [firstConventionalWord]
                (steps + 1)
                (iteratePrepend cutoff isFirstCurrent
                  [secondConventionalInverse] (steps + 1) .empty))).trace
                    cutoff).map
              (SRTrans.crossed
                firstConventionalInverse))) := by
  apply
    (middleSkewSchedule
      cutoff firstConventionalInverse firstConventionalInverse
        firstConventionalWord secondConventionalInverse (by simp)
          (positiveFilteredPrefix cutoff)).congr
  intro steps
  rw [
    crossed_iterate_prepend
      cutoff hcutoff steps]

/-- The negative crossed tail needed by the outer-packet recurrence has
polynomial bounded-term coordinates. -/
lemma constantMiddleProgram
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff) :
    BCDataa cutoff
      (cutoff *
          (2 * cutoff + (negativeFilteredPrefix cutoff).length + 4) +
        1)
      (fun steps =>
        boundedConstantTerms cutoff
          (((iteratePrepend cutoff isFirstCurrent
            NNPower.inverseNormalizedTrace
              steps
              (iteratePrepend cutoff isFirstCurrent
                [firstConventionalInverse] (steps + 1)
                (iteratePrepend cutoff isFirstCurrent [secondConventionalWord]
                  (steps + 1) .empty))).trace cutoff).map
              (SRTrans.crossed firstConventionalWord))) := by
  apply
    (middleSkewSchedule
      cutoff firstConventionalWord firstConventionalWord
        firstConventionalInverse secondConventionalWord (by simp)
          (negativeFilteredPrefix cutoff)).congr
  intro steps
  rw [
    crossed_prepend_middle
      cutoff hcutoff steps]

/-- The full positive transition schedule has polynomial bounded terms at
successor multiplicities. -/
lemma constant_route_program
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff) :
    BCDataa cutoff
      (cutoff *
          (2 * cutoff + (positiveFilteredPrefix cutoff).length + 4) +
        1)
      (fun steps =>
        boundedConstantTerms cutoff
          (transitionSchedule cutoff
            (naturalRouteProgram cutoff (steps + 1)))) := by
  apply
    (constant_positive_crossing
      cutoff
        (cutoff *
            (2 * cutoff +
                (positiveFilteredPrefix cutoff).length + 4) +
          1)
        (fun steps =>
          iteratePrepend cutoff isFirstCurrent [firstConventionalWord]
            (steps + 1)
            (iteratePrepend cutoff isFirstCurrent
              [secondConventionalInverse] (steps + 1) .empty))
        (middleProgramSucc
          cutoff hcutoff)).congr
  intro steps
  rw [natural_iterate_prepend]

/-- The full negative transition schedule has polynomial bounded terms at
successor multiplicities. -/
lemma constantRouteProgram
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff) :
    BCDataa cutoff
      (cutoff *
          (2 * cutoff + (negativeFilteredPrefix cutoff).length + 4) +
        1)
      (fun steps =>
        boundedConstantTerms cutoff
          (transitionSchedule cutoff
            (negativeRouteProgram cutoff (steps + 1)))) := by
  apply
    (bounded_constant_crossing
      cutoff
        (cutoff *
            (2 * cutoff +
                (negativeFilteredPrefix cutoff).length + 4) +
          1)
        (fun steps =>
          iteratePrepend cutoff isFirstCurrent [firstConventionalInverse]
            (steps + 1)
            (iteratePrepend cutoff isFirstCurrent [secondConventionalWord]
              (steps + 1) .empty))
        (constantMiddleProgram
          cutoff hcutoff)).congr
  intro steps
  rw [negative_iterate_prepend]

end FSTerm
end TCTex
end Submission

