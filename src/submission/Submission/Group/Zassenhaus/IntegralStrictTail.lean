    address_graded_functional
      x y z cutoff coordinate

/--
Any additive functional of the shifted-negative associated-graded correction
product is a bounded integer-valued polynomial.
-/
lemma termsNegPoly
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
