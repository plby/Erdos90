    (affineSlotExpansion
      cutoff tail slot).eval_recipe_span

/-- Every negative Hall-Witt outer-packet affine endpoint slot lies in the
bounded repeated-block recipe span at the sharpened degree. -/
lemma affineNegativeOverhead
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (tail : FRProgra)
    (slot : CWord Atom) :
