-- Merged from JacobiIntegralPowerStrictTailSignedLeafSubstitution.lean

/-!
# Signed-leaf substitution into integral Hall-Witt strict tails

The root-swap specialization of the integral Hall-Witt strict tail represents
inverse labels only when the substituted word is visibly a commutator.  A
compressed Hall branch may instead be atomic.  This file adds a signed-leaf
syntax that represents atomic inverses directly and swaps commutator roots
when a root is available.

The resulting strict trace evaluates exactly for arbitrary substituted words
and retains the formal weight-four strict-tail bound.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace SLSubsti

open scoped commutatorElement

open CWTrace
open WSTrace
open PSTail
open STSubsti

/-- A signed occurrence of an atom in a compressed Hall branch. -/
inductive SLeaf (β : Type*) where
  | positive : β → SLeaf β
  | negative : β → SLeaf β

namespace SLeaf

/-- Evaluate a signed atom by interpreting a negative leaf as an inverse. -/
def eval
    {β G : Type*}
    [Group G]
    (f : β → G) :
    SLeaf β → G
  | .positive atom => f atom
  | .negative atom => (f atom)⁻¹

/-- Forget the sign when computing physical weight. -/
def weight
    {β : Type*}
    (wt : β → ℕ) :
    SLeaf β → ℕ
  | .positive atom => wt atom
  | .negative atom => wt atom

end SLeaf

/-- Embed an unsigned compressed branch into the signed-leaf syntax. -/
def positiveWord
    {β : Type*} :
    CWord β → CWord (SLeaf β)
  | .atom atom => .atom (.positive atom)
  | .commutator left right => .commutator (positiveWord left) (positiveWord right)

/--
Represent the inverse of an unsigned compressed branch.  Atomic inverses use
negative leaves; commutator inverses swap the two positive child branches.
-/
def inverseWord
    {β : Type*} :
    CWord β → CWord (SLeaf β)
  | .atom atom => .atom (.negative atom)
  | .commutator left right => .commutator (positiveWord right) (positiveWord left)

@[simp]
lemma eval_positiveWord
    {β G : Type*}
    [Group G]
    (f : β → G) :
    ∀ word : CWord β,
      (positiveWord word).eval (SLeaf.eval f) = word.eval f
  | .atom _ => rfl
  | .commutator left right => by
      simp only [positiveWord, CWord.eval_commutator,
        eval_positiveWord f left, eval_positiveWord f right]

@[simp]
lemma eval_inverseWord
    {β G : Type*}
    [Group G]
    (f : β → G) :
    ∀ word : CWord β,
      (inverseWord word).eval (SLeaf.eval f) = (word.eval f)⁻¹
  | .atom _ => rfl
  | .commutator left right => by
      simp only [inverseWord, CWord.eval_commutator,
        eval_positiveWord f right, eval_positiveWord f left]
      exact (commutatorElement_inv (left.eval f) (right.eval f)).symm

@[simp]
lemma weight_positiveWord
    {β : Type*}
    (wt : β → ℕ) :
    ∀ word : CWord β,
      (positiveWord word).weight (SLeaf.weight wt) = word.weight wt
  | .atom _ => rfl
  | .commutator left right => by
      simp only [positiveWord, CWord.weight_commutator,
        weight_positiveWord wt left, weight_positiveWord wt right]

@[simp]
lemma weight_inverseWord
    {β : Type*}
    (wt : β → ℕ) :
    ∀ word : CWord β,
      (inverseWord word).weight (SLeaf.weight wt) = word.weight wt
  | .atom _ => rfl
  | .commutator left right => by
      simp only [inverseWord, CWord.weight_commutator,
        weight_positiveWord wt right, weight_positiveWord wt left]
      exact Nat.add_comm _ _

/-- Map the six signed Hall-Witt labels to arbitrary compressed branches. -/
def signedLeafSubstitution
    {β : Type*}
    (x y z : CWord β) :
    Atom → CWord (SLeaf β)
  | .inl index =>
      Fin.cases (positiveWord x)
        (fun index =>
          Fin.cases (inverseWord x)
            (fun index =>
              Fin.cases (positiveWord z) (fun _ => inverseWord z) index)
            index)
        index
  | .inr index =>
      Fin.cases (positiveWord y) (fun _ => inverseWord y) index

@[simp]
lemma leaf_substitution_x
    {β : Type*}
    (x y z : CWord β) :
    signedLeafSubstitution x y z xAtom = positiveWord x :=
  rfl

@[simp]
lemma leaf_substitution_inv
    {β : Type*}
    (x y z : CWord β) :
    signedLeafSubstitution x y z xInvAtom = inverseWord x :=
  rfl

@[simp]
lemma signed_leaf_z
    {β : Type*}
    (x y z : CWord β) :
    signedLeafSubstitution x y z zAtom = positiveWord z :=
  rfl

@[simp]
lemma leaf_substitution_z
    {β : Type*}
    (x y z : CWord β) :
    signedLeafSubstitution x y z zInvAtom = inverseWord z :=
  rfl

@[simp]
lemma signed_leaf_y
    {β : Type*}
    (x y z : CWord β) :
    signedLeafSubstitution x y z yAtom = positiveWord y :=
  rfl

@[simp]
lemma leaf_substitution_y
    {β : Type*}
    (x y z : CWord β) :
    signedLeafSubstitution x y z yInvAtom = inverseWord y :=
  rfl

/-- Signed-leaf substitution evaluates to the intended signed values for
arbitrary compressed branches. -/
lemma eval_leaf_substitution
    {β G : Type*}
    [Group G]
    (f : β → G)
    (x y z : CWord β) :
    (fun atom => (signedLeafSubstitution x y z atom).eval
      (SLeaf.eval f)) =
        signedEval (x.eval f) (y.eval f) (z.eval f) := by
  funext atom
  rcases atom with atom | atom
  · refine Fin.cases (eval_positiveWord f x) (fun atom => ?_) atom
    refine Fin.cases (eval_inverseWord f x) (fun atom => ?_) atom
    refine Fin.cases (eval_positiveWord f z) (fun atom => ?_) atom
    exact Fin.cases (eval_inverseWord f z) (fun atom => Fin.elim0 atom) atom
  · refine Fin.cases (eval_positiveWord f y) (fun atom => ?_) atom
    exact Fin.cases (eval_inverseWord f y) (fun atom => Fin.elim0 atom) atom

/-- Positive atomic weights make every signed-leaf substituted label
positive. -/
lemma leaf_substitution_pos
    {β : Type*}
    (wt : β → ℕ)
    (hwt : ∀ atom, 0 < wt atom)
    (x y z : CWord β) :
    ∀ atom,
      0 < (signedLeafSubstitution x y z atom).weight
        (SLeaf.weight wt) := by
  intro atom
  rcases atom with atom | atom
  · fin_cases atom
    · change
        0 < (signedLeafSubstitution x y z xAtom).weight
          (SLeaf.weight wt)
      simpa only [leaf_substitution_x, weight_positiveWord] using
        CWord.weight_pos wt hwt x
    · change
        0 < (signedLeafSubstitution x y z xInvAtom).weight
          (SLeaf.weight wt)
      simpa only [leaf_substitution_inv, weight_inverseWord] using
        CWord.weight_pos wt hwt x
    · change
        0 < (signedLeafSubstitution x y z zAtom).weight
          (SLeaf.weight wt)
      simpa only [signed_leaf_z, weight_positiveWord] using
        CWord.weight_pos wt hwt z
    · change
        0 < (signedLeafSubstitution x y z zInvAtom).weight
          (SLeaf.weight wt)
      simpa only [leaf_substitution_z, weight_inverseWord] using
        CWord.weight_pos wt hwt z
  · fin_cases atom
    · change
        0 < (signedLeafSubstitution x y z yAtom).weight
          (SLeaf.weight wt)
      simpa only [signed_leaf_y, weight_positiveWord] using
        CWord.weight_pos wt hwt y
    · change
        0 < (signedLeafSubstitution x y z yInvAtom).weight
          (SLeaf.weight wt)
      simpa only [leaf_substitution_y, weight_inverseWord] using
        CWord.weight_pos wt hwt y

/-- Signed-leaf specialization of the integral Hall-Witt strict trace. -/
def signedLeafStrict
    {β : Type*}
    (x y z : CWord β)
    (coefficient : ℤ) :
    List (CWord (SLeaf β)) :=
  bindTrace (signedLeafSubstitution x y z) coefficient

/-- Exact strict-tail evaluation without visible-commutator hypotheses. -/
lemma signed_leaf_strict
    {β G : Type*}
    [Group G]
    (f : β → G)
    (x y z : CWord β)
    (coefficient : ℤ) :
    wordListEval (SLeaf.eval f)
        (signedLeafStrict x y z coefficient) =
      ((CWord.commutator (.commutator x y) z).eval f)⁻¹ ^
          coefficient *
        ((CWord.commutator (.commutator x z) y).eval f ^
            coefficient *
          ((CWord.commutator (.commutator y z) x).eval f)⁻¹ ^
            coefficient) := by
  rw [signedLeafStrict, word_bind_trace,
    eval_leaf_substitution f x y z, word_strict_trace]
  rfl

/-- Every signed-leaf strict-tail factor still has weight at least four. -/
lemma four_leaf_strict
    {β : Type*}
    (wt : β → ℕ)
    (hwt : ∀ atom, 0 < wt atom)
    (x y z : CWord β)
    (coefficient : ℤ)
    (word : CWord (SLeaf β))
    (hword : word ∈ signedLeafStrict x y z coefficient) :
    4 ≤ word.weight (SLeaf.weight wt) := by
  exact
    four_bind_trace (SLeaf.weight wt)
      (signedLeafSubstitution x y z)
      (leaf_substitution_pos wt hwt x y z) coefficient word
        hword

end SLSubsti
end TCTex
end Submission
