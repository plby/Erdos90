    (degreeBound : ℕ)
    (family : ℕ → Multiset (CWord Atom)) :
    Prop :=
  ∀ slot,
    SuccessorAlternatingVanishes degreeBound
      (fun multiplicity : ℕ => (Multiset.count slot (family multiplicity) : ℤ))

