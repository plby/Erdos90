-- Merged from JacobiIntegralPowerStrictTailCutoffOrderedOuterPacketTraceOrbitDecomposition.lean

/-!
# Orbit decomposition for Hall-Witt outer trace substitutions

One factored outer packet acts on a filtered trace by adjoining a fixed
packet-local prefix and applying one homogeneous rightward-move substitution
to the carried trace.  Iteration therefore splits exactly into:

* the orbit emitted from the empty tail;
* the iterated homogeneous substitution of the original tail.

The homogeneous substitution is the existing cutoff-filtered
`iteratedMoveHigher`, so its slot coordinates are already governed
by the cutoff Newton-binomial formulas.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace OTDecomp

open CWTrace
open WSTrace
open WHNorm
open WNTrace
open NPTail
open RMRecb
open TBProf
open OFProgra
open OFProgra.FRProgra
open OTSubsti

/-- Homogeneous filtered move substitution on one carried trace. -/
def cutoffMoveTrace
    (cutoff : ℕ)
    (selected : CWord Atom)
    (rights : List (CWord Atom)) :
    List (CWord Atom) :=
  rights.flatMap (cutoffMovePacket cutoff selected)

/-- The homogeneous local substitution is exactly one filtered literal
rightward movement. -/
lemma move_below_higher
    (cutoff : ℕ)
    (selected : CWord Atom)
    (rights : List (CWord Atom)) :
    cutoffMoveTrace cutoff selected rights =
      unitBelowTrace cutoff (moveHigherTrace selected rights) := by
  exact
    (move_higher_flat
      cutoff selected rights).symm

/-- Iterate the homogeneous filtered move substitution. -/
def iteratedCutoffMove
    (cutoff : ℕ)
    (selected : CWord Atom) :
    ℕ → List (CWord Atom) → List (CWord Atom)
  | 0, rights =>
      rights
  | steps + 1, rights =>
      cutoffMoveTrace cutoff selected
        (iteratedCutoffMove cutoff selected steps rights)

/-- On an already-filtered source trace, iterating the homogeneous local
substitution is exactly filtering the existing literal repeated-move trace. -/
lemma iterated_below_higher
    (cutoff : ℕ)
    (selected : CWord Atom)
    (rights : List (CWord Atom))
    (hrights :
      unitBelowTrace cutoff rights = rights) :
    ∀ steps : ℕ,
      iteratedCutoffMove cutoff selected steps rights =
        unitBelowTrace cutoff
          (iteratedMoveHigher selected steps rights)
  | 0 => by
      exact hrights.symm
  | steps + 1 => by
      rw [iteratedCutoffMove,
        move_below_higher,
        iterated_below_higher
          cutoff selected rights hrights steps,
        iteratedMoveHigher]
      exact
        (unit_move_higher
          cutoff selected
            (iteratedMoveHigher selected steps rights)).symm

/-- Program traces are already filtered, so their homogeneous substitution
orbit is a filtered literal repeated-move trace. -/
lemma iterated_move_higher
    (cutoff : ℕ)
    (selected : CWord Atom)
    (program : FRProgra)
    (steps : ℕ) :
    iteratedCutoffMove cutoff selected steps (program.trace cutoff) =
      unitBelowTrace cutoff
        (iteratedMoveHigher selected steps (program.trace cutoff)) := by
  apply
    iterated_below_higher
  exact unit_below_trace cutoff program

/-- Iterating a triangular prefix substitution splits into the orbit emitted
from the empty tail and the homogeneous orbit of the original tail. -/
lemma iterate_substitution_move
    (emittedPrefix : List (CWord Atom))
    (cutoff : ℕ)
    (selected : CWord Atom) :
    ∀ (steps : ℕ) (tail : List (CWord Atom)),
      iteratePrefixSubstitution emittedPrefix
          (cutoffMovePacket cutoff selected) steps tail =
        iteratePrefixSubstitution emittedPrefix
            (cutoffMovePacket cutoff selected) steps [] ++
          iteratedCutoffMove cutoff selected steps tail
  | 0, tail => by
      simp [iteratePrefixSubstitution, iteratedCutoffMove]
  | steps + 1, tail => by
      rw [iteratePrefixSubstitution,
        iteratePrefixSubstitution,
        iterate_substitution_move
          emittedPrefix cutoff selected steps tail,
        List.flatMap_append,
        iteratedCutoffMove]
      simp only [cutoffMoveTrace, List.append_assoc]

/-- Positive outer-packet traces split into their empty-tail orbit and the
homogeneous repeated move of the original program tail. -/
lemma iterate_prepend_move
    (cutoff steps : ℕ)
    (tail : FRProgra) :
    (iteratePrepend cutoff isFirstCurrent WNTrace.trace
      steps tail).trace cutoff =
        iteratePrefixSubstitution
            (positiveFilteredPrefix cutoff)
            (cutoffMovePacket cutoff firstConventionalInverse) steps [] ++
          iteratedCutoffMove cutoff firstConventionalInverse steps
            (tail.trace cutoff) := by
  rw [
    prepend_prefix_substitution]
  exact
    iterate_substitution_move
      (positiveFilteredPrefix cutoff) cutoff
        firstConventionalInverse steps (tail.trace cutoff)

/-- Negative outer-packet traces split into their empty-tail orbit and the
homogeneous repeated move of the original program tail. -/
lemma prepend_empty_move
    (cutoff steps : ℕ)
    (tail : FRProgra) :
    (iteratePrepend cutoff isFirstCurrent
      NNPower.inverseNormalizedTrace
        steps tail).trace cutoff =
      iteratePrefixSubstitution
          (negativeFilteredPrefix cutoff)
          (cutoffMovePacket cutoff firstConventionalWord) steps [] ++
        iteratedCutoffMove cutoff firstConventionalWord steps
          (tail.trace cutoff) := by
  rw [
    iterate_prepend_substitution]
  exact
    iterate_substitution_move
      (negativeFilteredPrefix cutoff) cutoff firstConventionalWord
        steps (tail.trace cutoff)

end OTDecomp
end TCTex
