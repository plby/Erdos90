lemma lower_class_succ
    {G : Type*}
    [Group G]
    (layer : ℕ)
    (element : Subgroup.lowerCentralSeries G layer)
    (helement :
      (element : G) ∈ Subgroup.lowerCentralSeries G (layer + 1)) :
    TBluepr.lowerCentralClass layer element = 0 := by
  change TBluepr.lowerClassHom layer element = 1
  exact (QuotientGroup.eq_one_iff _).mpr helement

