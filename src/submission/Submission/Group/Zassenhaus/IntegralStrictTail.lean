/-- The literal count state of an ordinary crossing schedule is its atomic
depth-packet operator applied to the empty count state. -/
lemma constant_operator_empty
    (cutoff : ℕ)
    (outer selected right : CWord Atom)
    (steps : ℕ) :
    boundedConstantState
        (boundedConstantTerms cutoff
          (depthCrossingSchedule cutoff outer selected right
            steps)) =
      crossingStateOperator cutoff outer
        selected right steps (boundedCountState []) := by
  funext target
  unfold boundedConstantState boundedCountState
  rw [count_constant_fold]
  exact
    congrFun
      (state_fold_operator
        cutoff outer selected right steps (boundedCountState []))
      target

/-- Signed Newton evaluation of the successor family of crossing-packet
count states recovers its literal depth-zero seed. -/
lemma newton_evaluation_seed
    (cutoff : ℕ)
    (outer selected right : CWord Atom)
    (houter : isFirstCurrent outer = true) :
    newtonEvaluationState (cutoff * cutoff + 1)
        (fun steps =>
          boundedConstantState
            (boundedConstantTerms cutoff
              (depthCrossingSchedule cutoff outer selected right
                (steps + 1)))) =
      boundedConstantState
        (boundedConstantTerms cutoff
          (depthCrossingSchedule cutoff outer selected right
            0)) := by
  funext target
  unfold newtonEvaluationState boundedConstantState
  have heval :=
    BCExp.binomial_basis_succ
      1 (cutoff * cutoff + 1) (by omega)
      (fun steps : ℕ =>
        ((boundedConstantTerms cutoff
          (depthCrossingSchedule cutoff outer selected right
            steps)).count target : ℤ))
