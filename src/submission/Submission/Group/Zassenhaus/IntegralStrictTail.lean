a bounded active expansion. -/
lemma subsequence_expansions_rank
    (cutoff : ℕ) :
    ∀ (source target : List ℕ),
      (∀ depth ∈ source, depth < cutoff) →
        target ∈
          activeSubsequenceExpansions
            (strictStepPacket cutoff) source →
          depthWordRank target = depthWordRank source →
            target = source
  | [], target, _hsource, htarget, _hrank => by
      simpa only [activeSubsequenceExpansions, List.mem_singleton] using htarget
  | depth :: source, target, hsource, htarget, hrank => by
      simp only [activeSubsequenceExpansions] at htarget
      rcases List.mem_flatMap.mp htarget with
        ⟨suffix, hsuffix, htarget⟩
      rcases List.mem_map.mp htarget with
        ⟨head, hhead, rfl⟩
      have hheadRank :=
        nonempty_sublists_packet
          cutoff depth (hsource depth (by simp)) head hhead
      have hsuffixRank :=
        depth_subsequence_expansions
          cutoff source suffix
            (fun next hnext => hsource next (by simp [hnext]))
            hsuffix
      have hheadEq :
          depthWordRank head = depth + 1 := by
        rw [depth_rank_append, depth_rank_cons] at hrank
        omega
      have hsuffixEq :
          depthWordRank suffix = depthWordRank source := by
        rw [depth_rank_append, depth_rank_cons] at hrank
        omega
      rw [hheadRank.2 hheadEq]
      rw [
        subsequence_expansions_rank
          cutoff source suffix
            (fun next hnext => hsource next (by simp [hnext]))
            hsuffix hsuffixEq]
      rfl

/-- Every bounded source word survives as its retained active expansion. -/
lemma subsequence_expansions_self
    (cutoff : ℕ) :
    ∀ source : List ℕ,
      (∀ depth ∈ source, depth < cutoff) →
        source ∈
          activeSubsequenceExpansions
            (strictStepPacket cutoff) source
  | [], _hsource => by
      simp [activeSubsequenceExpansions]
  | depth :: source, hsource => by
      simp only [activeSubsequenceExpansions]
      apply List.mem_flatMap.mpr
      refine
        ⟨source,
          subsequence_expansions_self cutoff source
            (fun next hnext => hsource next (by simp [hnext])),
          ?_⟩
      apply List.mem_map.mpr
      exact
        ⟨[depth],
          singleton_nonempty_sublists
            cutoff depth (hsource depth (by simp)),
          rfl⟩

/-- Active bounded packet expansions remain in the finite depth alphabet. -/
lemma active_subsequence_expansions
    (cutoff : ℕ) :
    ∀ (source target : List ℕ),
      target ∈
          activeSubsequenceExpansions
            (strictStepPacket cutoff) source →
        ∀ depth ∈ target, depth < cutoff
  | [], target, htarget, depth, hdepth => by
      simp [activeSubsequenceExpansions] at htarget
      subst target
      simp at hdepth
  | sourceDepth :: source, target, htarget, depth, hdepth => by
      simp only [activeSubsequenceExpansions] at htarget
      rcases List.mem_flatMap.mp htarget with
        ⟨suffix, hsuffix, htarget⟩
      rcases List.mem_map.mp htarget with
        ⟨head, hhead, rfl⟩
      rw [List.mem_append] at hdepth
      rcases hdepth with hdepth | hdepth
      · have hheadSublist :
            List.Sublist head (strictStepPacket cutoff sourceDepth) :=
          List.mem_sublists.mp (List.mem_filter.mp hhead).1
        exact
          cutoff_strict_packet
            cutoff sourceDepth depth (hheadSublist.subset hdepth)
      · exact
          active_subsequence_expansions
            cutoff source suffix hsuffix depth hdepth

/-- Each active source packet contributes at least one output position. -/
lemma length_subsequence_expansions
    {α β : Type*}
    (packet : α → List β) :
    ∀ (source : List α) (target : List β),
      target ∈ activeSubsequenceExpansions packet source →
        source.length ≤ target.length
  | [], target, htarget => by
      simp [activeSubsequenceExpansions] at htarget
      subst target
      simp
  | item :: source, target, htarget => by
      simp only [activeSubsequenceExpansions] at htarget
      rcases List.mem_flatMap.mp htarget with
        ⟨suffix, hsuffix, htarget⟩
      rcases List.mem_map.mp htarget with
        ⟨head, hhead, rfl⟩
      have hheadNonempty : head ≠ [] :=
        of_decide_eq_true (List.mem_filter.mp hhead).2
      have hheadLength : 0 < head.length :=
        List.length_pos_iff_ne_nil.mpr hheadNonempty
      have hsuffixLength :
          source.length ≤ suffix.length :=
        length_subsequence_expansions
          packet source suffix hsuffix
      simp only [List.length_cons, List.length_append]
      omega

/-- Every non-retained bounded active expansion strictly raises rank. -/
lemma subsequence_expansions_ne
    (cutoff : ℕ)
    (source target : List ℕ)
    (hsource : ∀ depth ∈ source, depth < cutoff)
    (htarget :
      target ∈
        activeSubsequenceExpansions
          (strictStepPacket cutoff) source)
    (hne : target ≠ source) :
    depthWordRank source < depthWordRank target := by
  have hle :
      depthWordRank source ≤ depthWordRank target :=
    depth_subsequence_expansions
      cutoff source target hsource htarget
  have hnotEq :
      depthWordRank target ≠ depthWordRank source := by
    intro hrank
    exact hne
      (subsequence_expansions_rank
        cutoff source target hsource htarget hrank)
  omega

end ASTri
end TCTex
