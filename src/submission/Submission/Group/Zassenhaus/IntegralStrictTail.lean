    (cutoff degreeBound : ℕ)
    (family : ℕ → Multiset (CWord Atom)) :
    Prop :=
  ∀ slot ∈ orderedCutoffVocabulary cutoff,
    SuccessorAlternatingVanishes degreeBound
      (fun multiplicity : ℕ => (Multiset.count slot (family multiplicity) : ℤ))

/-- For supported profiles, the universal slot condition reduces to the finite
