/-!
# Newton recipes for Hall-basis coordinates of associated-graded strict tails

The signed Hall-Witt strict-tail correction has polynomial coordinates in any
chosen Hall basis of its associated-graded parent layer.  Normalize those
coordinate polynomials in the Newton-binomial basis.  The resulting objects
are explicit finite repeated-block recipes, not merely polynomial existence
witnesses.

This file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace
  BRExp

open TEAddres
open PMExp
open
  SAGraded
open
  GPBasis

universe u


/--
Newton-normalized repeated-block recipe for one positive Hall-basis
coordinate of the strict-tail parent-layer correction.
-/
noncomputable def addressParentBasis
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    {ι : Type*}
    (basis :
      Module.Basis ι ℤ
        (AddressParentLayer (n := n) x y z))
    (i : ι) :
    BCExp 1
      (naturalStrictBound cutoff) :=
  BCExp.binomialBasis 1
    (naturalStrictBound cutoff) (by omega)
      (fun multiplicity : ℕ =>
        addressParentCoordinate x y z basis i
          (TBluepr.lowerCentralClass
            (exponentAddressParent x y z)
            (addressBelowTerms
              (n := n) x y z cutoff (Int.ofNat multiplicity)).prod))

/--
Newton-normalized repeated-block recipe for one shifted-negative Hall-basis
coordinate of the strict-tail parent-layer correction.
-/
noncomputable def addressNegativeParent
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    {ι : Type*}
    (basis :
      Module.Basis ι ℤ
        (AddressParentLayer (n := n) x y z))
    (i : ι) :
    BCExp 1
      (negativeStrictBound cutoff) :=
  BCExp.binomialBasis 1
    (negativeStrictBound cutoff) (by omega)
      (fun magnitude : ℕ =>
        addressParentCoordinate x y z basis i
          (TBluepr.lowerCentralClass
            (exponentAddressParent x y z)
            (addressBelowTerms
              (n := n) x y z cutoff (Int.negSucc magnitude)).prod))

/--
The positive coordinate recipe evaluates to the selected coordinate of the
associated-graded correction class at every natural multiplicity.
-/
lemma address_natural_expansion
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    {ι : Type*}
    (basis :
      Module.Basis ι ℤ
        (AddressParentLayer (n := n) x y z))
    (i : ι) :
    (addressParentBasis
      x y z cutoff basis i).eval =
      fun multiplicity : ℕ =>
        addressParentCoordinate x y z basis i
          (TBluepr.lowerCentralClass
            (exponentAddressParent x y z)
            (addressBelowTerms
              (n := n) x y z cutoff (Int.ofNat multiplicity)).prod) := by
  apply BCExp.eval_binomialBasis
  simpa using
    castCoordPoly
      x y z cutoff hcutoff basis i

/--
The shifted-negative coordinate recipe evaluates to the selected coordinate
of the associated-graded correction class at every natural magnitude.
-/
lemma address_negative_expansion
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    {ι : Type*}
    (basis :
      Module.Basis ι ℤ
        (AddressParentLayer (n := n) x y z))
    (i : ι) :
    (addressNegativeParent
      x y z cutoff basis i).eval =
      fun magnitude : ℕ =>
        addressParentCoordinate x y z basis i
          (TBluepr.lowerCentralClass
            (exponentAddressParent x y z)
            (addressBelowTerms
              (n := n) x y z cutoff (Int.negSucc magnitude)).prod) := by
  apply BCExp.eval_binomialBasis
  simpa using
    basisCoordPoly
      x y z cutoff hcutoff basis i

/--
Every positive Hall-basis coordinate belongs to the span of bounded
repeated-block recipes at its computed degree bound.
-/
lemma exponent_address_parent
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    {ι : Type*}
    (basis :
      Module.Basis ι ℤ
        (AddressParentLayer (n := n) x y z))
    (i : ι) :
    IntCombinationRecipes 1
      (naturalStrictBound cutoff)
      (fun multiplicity : ℕ =>
        addressParentCoordinate x y z basis i
          (TBluepr.lowerCentralClass
            (exponentAddressParent x y z)
            (addressBelowTerms
              (n := n) x y z cutoff (Int.ofNat multiplicity)).prod)) := by
  rw [←
    address_natural_expansion
      x y z cutoff hcutoff basis i]
  exact
    (addressParentBasis
      x y z cutoff basis i).eval_recipe_span

/--
Every shifted-negative Hall-basis coordinate belongs to the span of bounded
repeated-block recipes at its computed degree bound.
-/
lemma address_negative_parent
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    {ι : Type*}
    (basis :
      Module.Basis ι ℤ
        (AddressParentLayer (n := n) x y z))
    (i : ι) :
    IntCombinationRecipes 1
      (negativeStrictBound cutoff)
      (fun magnitude : ℕ =>
        addressParentCoordinate x y z basis i
          (TBluepr.lowerCentralClass
            (exponentAddressParent x y z)
            (addressBelowTerms
              (n := n) x y z cutoff (Int.negSucc magnitude)).prod)) := by
  rw [←
    address_negative_expansion
      x y z cutoff hcutoff basis i]
  exact
    (addressNegativeParent
      x y z cutoff basis i).eval_recipe_span

/--
Explicit finite signed coordinate recipes for a basis of the strict-tail
parent layer.
-/
def AddressParentData
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ) :
    Prop :=
  ∃ basis :
      Module.Basis
        (H (exponentAddressParent x y z + 1)).index
        ℤ
        (AddressParentLayer (n := n) x y z),
    (∀ i,
      basis i =
        BCWt.associatedGradedClass (n := n)
          ((H (exponentAddressParent x y z + 1)).commutator i)) ∧
    ∀ i,
      (addressParentBasis
          x y z cutoff basis i).eval =
          (fun multiplicity : ℕ =>
            addressParentCoordinate x y z basis i
              (TBluepr.lowerCentralClass
                (exponentAddressParent x y z)
                (addressBelowTerms
                  (n := n) x y z cutoff (Int.ofNat multiplicity)).prod)) ∧
        (addressNegativeParent
          x y z cutoff basis i).eval =
          (fun magnitude : ℕ =>
            addressParentCoordinate x y z basis i
              (TBluepr.lowerCentralClass
                (exponentAddressParent x y z)
                (addressBelowTerms
                  (n := n) x y z cutoff (Int.negSucc magnitude)).prod))

/--
Collector-facing package: a Hall family forming the next associated-graded
basis supplies basis vectors and explicit finite signed coordinate recipes.
-/
theorem address_forms_associated
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (hH :
      (H (exponentAddressParent x y z + 1)).FormsAssocGradedbasis
        (n := n)) :
    AddressParentData
      (n := n) x y z cutoff := by
  unfold AddressParentData
  rcases
      coords_forms_associated
        x y z cutoff hcutoff hH with
    ⟨basis, hbasis, _hpolynomial⟩
  refine ⟨basis, hbasis, ?_⟩
  intro i
  exact
    ⟨address_natural_expansion
        x y z cutoff hcutoff basis i,
      address_negative_expansion
        x y z cutoff hcutoff basis i⟩

end
  BRExp
end TCTex
