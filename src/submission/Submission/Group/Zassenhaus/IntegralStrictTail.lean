-- EndpointCountStateAtomicDepthPacketSignedSeedRecovery.lean

/-!
# Signed seed recovery for the atomic strict-depth automaton

Every supported ordered depth-word coordinate of the bounded strict-depth
schedule is globally polynomial.  Signed Newton evaluation of its successor
trace therefore recovers its depth-zero seed.  Combining this with the exact
finite-alphabet substitution recurrence gives a finite weighted identity for
the signed predecessor-word coordinates.

This is the signed seed-recovery equation for the atomic depth-packet
automaton used by the endpoint kernel reduction.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace
  ASRecov

open CSFold
open DSRec
open BSRec
open DSReca
open BSPoly
open BDSubseq
open TEAggreg

/-- The bounded strict-depth orbit starts from the retained depth-zero seed
when that seed lies below cutoff. -/
lemma bounded_strict_depth
    (cutoff : ℕ) :
    boundedDepthSchedule cutoff 0 =
      if 0 < cutoff then [0] else [] := by
  by_cases hcutoff : 0 < cutoff <;>
    simp [boundedDepthSchedule,
      BDExp.strictDepthSchedule,
      hcutoff]

/-- Signed Newton evaluation of a supported successor depth-word coordinate
recovers its depth-zero seed value. -/
lemma newton_evaluation_subsequence
    (cutoff : ℕ)
    (target : List ℕ)
    (htarget : ∀ depth ∈ target, depth < cutoff) :
    newtonSignedEvaluation (strictDepthGrade target + 1)
        (fun steps : ℕ =>
          (orderedSubsequenceMultiplicity target
            (boundedDepthSchedule cutoff (steps + 1)) : ℤ)) =
      (orderedSubsequenceMultiplicity target
        (boundedDepthSchedule cutoff 0) : ℤ) := by
  have heval :=
    BCExp.binomial_basis_succ
      1 (strictDepthGrade target + 1) (by omega)
      (fun steps : ℕ =>
        (orderedSubsequenceMultiplicity target
          (boundedDepthSchedule cutoff steps) : ℤ))
      (by
        simpa using
          subsequence_multiplicity_strict
            cutoff target htarget)
  rw [BCExp.eval_int_binomial] at heval
  simpa [newtonSignedEvaluation] using heval

/-- The signed successor evaluation can be expanded through the fixed finite
depth-word substitution alphabet. -/
lemma newton_succ_alphabet
    (cutoff : ℕ)
    (target : List ℕ) :
    newtonSignedEvaluation (strictDepthGrade target + 1)
        (fun steps : ℕ =>
          (orderedSubsequenceMultiplicity target
            (boundedDepthSchedule cutoff (steps + 1)) : ℤ)) =
      ∑ source ∈ (wordsUpLength cutoff target.length).toFinset,
        (activeSubstitutionCoefficient cutoff source target : ℤ) *
          newtonSignedEvaluation (strictDepthGrade target + 1)
            (fun steps : ℕ =>
              (orderedSubsequenceMultiplicity source
                (boundedDepthSchedule cutoff steps) : ℤ)) := by
  rw [show
    (fun steps : ℕ =>
      (orderedSubsequenceMultiplicity target
        (boundedDepthSchedule cutoff (steps + 1)) : ℤ)) =
    (fun steps : ℕ =>
      ∑ source ∈ (wordsUpLength cutoff target.length).toFinset,
        (activeSubstitutionCoefficient cutoff source target : ℤ) *
          (orderedSubsequenceMultiplicity source
            (boundedDepthSchedule cutoff steps) : ℤ)) by
      funext steps
      exact_mod_cast
        (by
          simpa [nsmul_eq_mul, Nat.mul_comm] using
            subsequence_multiplicity_alphabet
              cutoff steps target)]
  unfold newtonSignedEvaluation
  exact
    successor_alternating_finset
      (strictDepthGrade target + 1)
      (wordsUpLength cutoff target.length).toFinset
      (fun source =>
        (activeSubstitutionCoefficient cutoff source target : ℤ))
      (fun source steps =>
        (orderedSubsequenceMultiplicity source
          (boundedDepthSchedule cutoff steps) : ℤ))

/-- For every supported target word, the finite weighted signed predecessor
sum of the atomic strict-depth automaton is exactly its depth-zero seed. -/
lemma substitution_evaluation_seed
    (cutoff : ℕ)
    (target : List ℕ)
    (htarget : ∀ depth ∈ target, depth < cutoff) :
    (∑ source ∈ (wordsUpLength cutoff target.length).toFinset,
      (activeSubstitutionCoefficient cutoff source target : ℤ) *
        newtonSignedEvaluation (strictDepthGrade target + 1)
          (fun steps : ℕ =>
            (orderedSubsequenceMultiplicity source
              (boundedDepthSchedule cutoff steps) : ℤ))) =
      (orderedSubsequenceMultiplicity target
        (boundedDepthSchedule cutoff 0) : ℤ) := by
  rw [←
    newton_succ_alphabet
      cutoff target]
  exact
    newton_evaluation_subsequence
      cutoff target htarget

/-- The weighted signed predecessor identity has an explicit singleton-or-
empty seed normal form. -/
lemma evaluation_explicit_seed
    (cutoff : ℕ)
    (target : List ℕ)
    (htarget : ∀ depth ∈ target, depth < cutoff) :
    (∑ source ∈ (wordsUpLength cutoff target.length).toFinset,
      (activeSubstitutionCoefficient cutoff source target : ℤ) *
        newtonSignedEvaluation (strictDepthGrade target + 1)
          (fun steps : ℕ =>
            (orderedSubsequenceMultiplicity source
              (boundedDepthSchedule cutoff steps) : ℤ))) =
      (orderedSubsequenceMultiplicity target
        (if 0 < cutoff then [0] else []) : ℤ) := by
  rw [← bounded_strict_depth cutoff]
  exact
    substitution_evaluation_seed
      cutoff target htarget

end ASRecov
end TCTex
end Submission

