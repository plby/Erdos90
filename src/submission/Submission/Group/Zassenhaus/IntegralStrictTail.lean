-- ssingSchedule.lean

/-!
# Successor-skew nested Hall-Witt crossing schedules

At the final outer-packet recurrence, the outer homogeneous orbit has depth
`steps` while the carried middle program has depth `steps + 1`. Introduce the
two-parameter nested crossing schedule and record its successor-skew
specialization.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace SSSched

open CWTrace
open WSTrace
open NPTail
open RMRecb
open TBProf
open TODepth
open BDExp
open DCSched
open OTDecomp
open OCState
open STSched
open DSRec
open FDCross
open NCSched
open BTRepeat

/-- Crossed transition schedule for independently bounded inner and outer
homogeneous orbits. -/
def nestedCrossingSchedule
    (cutoff : ℕ)
    (crossed outer selected right : CWord Atom)
    (innerSteps outerSteps : ℕ) :
    List SRTrans :=
  (boundedDepthSchedule cutoff innerSteps).flatMap fun innerDepth =>
    (iteratedMoveTrace selected innerDepth [right]).flatMap
      fun innerRight =>
        (boundedDepthSchedule cutoff outerSteps).flatMap fun outerDepth =>
          nestedCrossingPacket cutoff crossed outer
            innerRight outerDepth

/-- The aligned nested schedule is the diagonal specialization of the
two-parameter schedule. -/
lemma bounded_nested_crossing
    (cutoff : ℕ)
    (crossed outer selected right : CWord Atom)
    (steps : ℕ) :
    boundedNestedCrossing cutoff crossed outer selected
        right steps =
      nestedCrossingSchedule cutoff crossed outer selected
        right steps steps := by
  rfl

/-- Nested crossing schedule with one additional inner routing step. -/
def successorSkewCrossing
    (cutoff : ℕ)
    (crossed outer selected right : CWord Atom)
    (steps : ℕ) :
    List SRTrans :=
  nestedCrossingSchedule cutoff crossed outer selected
    right (steps + 1) steps

/-- A two-parameter nested schedule is the bounded inner depth word flattened
through ordinary outer bounded-depth crossing schedules. -/
lemma nested_crossing_flat
    (cutoff : ℕ)
    (crossed outer selected right : CWord Atom)
    (innerSteps outerSteps : ℕ) :
    nestedCrossingSchedule cutoff crossed outer selected
        right innerSteps outerSteps =
      (boundedDepthSchedule cutoff innerSteps).flatMap fun innerDepth =>
        depthCrossingSchedule cutoff crossed outer
          (iteratedLeftCommutator selected innerDepth right) outerSteps := by
  unfold nestedCrossingSchedule
    depthCrossingSchedule
    nestedCrossingPacket
    strictCrossingPacket
    boundedDepthSchedule
  apply List.flatMap_congr
  intro innerDepth _hinnerDepth
  rw [iterated_correction_singleton]
  simp only [List.flatMap_singleton]

/-- Crossing independently bounded nested homogeneous orbits gives the
two-parameter schedule. -/
lemma crossed_cutoff_singleton
    (cutoff innerSteps outerSteps : ℕ)
    (crossed outer selected right : CWord Atom)
    (houter :
      isFirstCurrent outer = true ∨
        isSecondCurrent outer = true)
    (hselected :
      isFirstCurrent selected = true ∨
        isSecondCurrent selected = true) :
    (iteratedCutoffMove cutoff outer outerSteps
      (unitBelowTrace cutoff
        (iteratedMoveHigher selected innerSteps [right]))).map
          (SRTrans.crossed crossed) =
      nestedCrossingSchedule cutoff crossed outer selected
        right innerSteps outerSteps := by
  rw [←
    iterated_move_literal
      cutoff innerSteps selected right]
  rw [
    iterated_move_schedule
      cutoff innerSteps selected right hselected,
    iterated_move_flat, map_flatMap]
  unfold nestedCrossingSchedule
  apply List.flatMap_congr
  intro innerDepth _hinnerDepth
  rw [iterated_cutoff_below]
  rw [
    iterated_below_schedule
      cutoff outerSteps outer houter,
    map_flatMap]
  apply List.flatMap_congr
  intro innerRight _hinnerRight
  rw [map_flatMap]
  rfl

/-- Every transition in a two-parameter nested schedule belongs to the fixed
second-route transition alphabet when the crossed word is first-family
current. -/
lemma alphabet_crossing_schedule
    (cutoff innerSteps outerSteps : ℕ)
    (crossed outer selected right : CWord Atom)
    (hcrossed : isFirstCurrent crossed = true)
    (transition : SRTrans)
    (htransition :
      transition ∈
        nestedCrossingSchedule cutoff crossed outer selected
          right innerSteps outerSteps) :
    transition ∈ secondRouteAlphabet cutoff := by
  rcases List.mem_flatMap.mp htransition with
    ⟨innerDepth, _hinnerDepth, htransition⟩
  rcases List.mem_flatMap.mp htransition with
    ⟨innerRight, _hinnerRight, htransition⟩
  rcases List.mem_flatMap.mp htransition with
    ⟨outerDepth, _houterDepth, htransition⟩
  apply
    second_alphabet_crossed
      cutoff crossed hcrossed
        (iteratedCutoffTrace cutoff outer outerDepth
          (unitBelowTrace cutoff [innerRight]))
  · rw [iterated_cutoff_below]
    exact
      supported_vocabulary_below cutoff
        (iteratedMoveTrace outer outerDepth [innerRight])
  · exact htransition

/-- Crossing a repeated independently bounded nested suffix gives repetition
of its two-parameter schedule. -/
lemma crossed_repeat_moved
    (cutoff innerSteps outerSteps copies : ℕ)
    (crossed outer selected right : CWord Atom)
    (houter :
      isFirstCurrent outer = true ∨
        isSecondCurrent outer = true)
    (hselected :
      isFirstCurrent selected = true ∨
        isSecondCurrent selected = true) :
    (repeatTrace copies
      (iteratedCutoffMove cutoff outer outerSteps
        (unitBelowTrace cutoff
          (iteratedMoveHigher selected innerSteps [right])))).map
            (SRTrans.crossed crossed) =
      repeatTransitionSchedule
        (nestedCrossingSchedule cutoff crossed outer
          selected right innerSteps outerSteps) copies := by
  rw [map_repeatTrace,
    crossed_cutoff_singleton
      cutoff innerSteps outerSteps crossed outer selected right houter
        hselected]

end SSSched
end TCTex
end Submission

