universe u

/-- Retain exactly the formal strict occurrences below one unit-label
cutoff. -/
def belowCutoffTrace
    (cutoff : ℕ)
    (coefficient : ℤ) :
    List (CWord Atom) :=
  (strictTrace coefficient).filter fun word =>
    decide (word.weight (fun _ => 1) < cutoff)

/-- A retained formal occurrence comes from the original integral strict
trace. -/
lemma strict_below_cutoff
    {cutoff : ℕ}
    {coefficient : ℤ}
    {word : CWord Atom}
    (hword : word ∈ belowCutoffTrace cutoff coefficient) :
    word ∈ strictTrace coefficient :=
  (List.mem_filter.mp hword).1

/-- Every retained formal occurrence lies strictly below cutoff. -/
lemma below_cutoff_trace
    {cutoff : ℕ}
    {coefficient : ℤ}
    {word : CWord Atom}
    (hword : word ∈ belowCutoffTrace cutoff coefficient) :
    word.weight (fun _ => 1) < cutoff := by
  exact of_decide_eq_true (List.mem_filter.mp hword).2

/-- Every retained formal occurrence belongs to the deduplicated fixed-slot
vocabulary. -/
lemma vocabulary_below_trace
    {cutoff : ℕ}
    {coefficient : ℤ}
    {word : CWord Atom}
    (hword : word ∈ belowCutoffTrace cutoff coefficient) :
    word ∈ orderedCutoffVocabulary cutoff := by
  apply (ordered_cutoff_vocabulary cutoff word).2
  exact
    cutoff_vocabulary_strict
      cutoff coefficient word
        (strict_below_cutoff hword)
          (below_cutoff_trace hword)

/-- Count retained occurrences of one formal fixed slot. -/
