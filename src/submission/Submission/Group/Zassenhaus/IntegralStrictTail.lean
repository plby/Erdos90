/-!
# Filtered semantics for bounded strict-depth subsequence states

The abstract triangular parser expands the unfiltered packet
`[depth + 1, depth]`.  The concrete bounded schedule erases emitted depths at
or above a fixed cutoff.  Such erased entries cannot contribute to a target
word already supported below that cutoff.

This file records that erasure invariance and identifies one bounded
successor step with the abstract triangular state step on supported targets.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace SFSem

open DSRec
open BSRec
open BSPoly
open DSSem

/-- Ordered subsequence multiplicity after adjoining one source entry. -/
lemma subsequence_multiplicity_cons
    (head : ℕ)
    (source target : List ℕ) :
    orderedSubsequenceMultiplicity target (head :: source) =
      orderedSubsequenceMultiplicity target source +
        match target with
        | [] =>
            0
        | targetHead :: targetTail =>
            if targetHead = head then
              orderedSubsequenceMultiplicity targetTail source
            else
              0 := by
  unfold orderedSubsequenceMultiplicity
  rw [(List.sublists_cons_perm_append head source).count_eq target,
    List.count_append, count_map_cons]

/-- Erasing source entries rejected by `keep` does not change the
multiplicity of a target all of whose entries are retained. -/
lemma ordered_subsequence_filter
    (keep : ℕ → Bool) :
    ∀ (source target : List ℕ),
      (∀ depth ∈ target, keep depth = true) →
        orderedSubsequenceMultiplicity target (source.filter keep) =
          orderedSubsequenceMultiplicity target source
  | [], target, _htarget => by
      rfl
  | sourceHead :: source, target, htarget => by
      by_cases hsourceHead : keep sourceHead = true
      · rw [show
          (sourceHead :: source).filter keep =
            sourceHead :: source.filter keep by
          simp [hsourceHead]]
        cases target with
        | nil =>
            rw [subsequence_multiplicity_cons,
              subsequence_multiplicity_cons]
            exact
              ordered_subsequence_filter keep source [] (by
                simp)
        | cons targetHead targetTail =>
            rw [subsequence_multiplicity_cons,
              subsequence_multiplicity_cons,
              ordered_subsequence_filter keep source
                (targetHead :: targetTail) htarget]
            simp only
            by_cases htargetHead : targetHead = sourceHead
            · have htargetTail :
                  ∀ depth ∈ targetTail, keep depth = true := by
                intro depth hdepth
                exact htarget depth (by simp [hdepth])
              simp [htargetHead,
                ordered_subsequence_filter keep source
                  targetTail htargetTail]
            · simp [htargetHead]
      · rw [show
          (sourceHead :: source).filter keep =
            source.filter keep by
          simp [hsourceHead]]
        rw [ordered_subsequence_filter keep source target
          htarget, subsequence_multiplicity_cons]
        cases target with
        | nil =>
            rfl
        | cons targetHead targetTail =>
            simp only
            have htargetHead : targetHead ≠ sourceHead := by
              intro hhead
              subst targetHead
              exact hsourceHead (htarget sourceHead (by simp))
            rw [if_neg htargetHead, Nat.add_zero]

/-- Below-cutoff target multiplicities are unchanged by erasing
above-cutoff source entries. -/
lemma subsequence_multiplicity_filter
    (cutoff : ℕ)
    (source target : List ℕ)
    (htarget : ∀ depth ∈ target, depth < cutoff) :
    orderedSubsequenceMultiplicity target
        (source.filter fun depth => decide (depth < cutoff)) =
      orderedSubsequenceMultiplicity target source := by
  apply ordered_subsequence_filter
  intro depth hdepth
  exact decide_eq_true (htarget depth hdepth)

/-- A below-cutoff source word is fixed by the cutoff filter. -/
lemma filter_cutoff_self
    (cutoff : ℕ)
    (source : List ℕ)
    (hsource : ∀ depth ∈ source, depth < cutoff) :
    (source.filter fun depth => decide (depth < cutoff)) =
      source := by
  apply List.filter_eq_self.mpr
  intro depth hdepth
  exact decide_eq_true (hsource depth hdepth)

/-- The bounded local substitution is the unfiltered binary substitution
followed by erasure of entries at or above cutoff. -/
lemma flat_strict_filter
    (cutoff : ℕ)
    (source : List ℕ)
    (hsource : ∀ depth ∈ source, depth < cutoff) :
    source.flatMap (strictStepPacket cutoff) =
      (source.flatMap fun depth => [depth + 1, depth]).filter fun depth =>
        decide (depth < cutoff) := by
  rw [filter_flat_self,
    filter_cutoff_self cutoff source hsource]

/-- Literal unfiltered packet subsequences are the selected-pattern
expansion semantics. -/
lemma literal_flat_expanded
    (source : List ℕ) :
    literalSubsequenceState
        (source.flatMap fun depth => [depth + 1, depth]) =
      expandedSubsequenceState source := by
  funext target
  unfold literalSubsequenceState
    expandedSubsequenceState
  change
    ((source.flatMap fun depth => [depth + 1, depth]).sublists.count target :
        ℤ) =
      ((selectedPatternExpansions source).count target : ℤ)
  exact_mod_cast
    (pattern_sublists_flat
      source).symm.count_eq target

/-- One bounded successor step is the abstract triangular predecessor-state
step on every target supported below cutoff. -/
lemma literal_subsequence_state
    (cutoff steps : ℕ)
    (target : List ℕ)
    (htarget : ∀ depth ∈ target, depth < cutoff) :
    literalSubsequenceState
        (boundedDepthSchedule cutoff (steps + 1)) target =
      strictSubsequenceState
        (literalSubsequenceState
          (boundedDepthSchedule cutoff steps)) target := by
  let source := boundedDepthSchedule cutoff steps
  have hsource :
      ∀ depth ∈ source, depth < cutoff := by
    intro depth hdepth
    exact
      cutoff_bounded_schedule cutoff steps depth hdepth
  calc
    literalSubsequenceState
          (boundedDepthSchedule cutoff (steps + 1)) target =
        literalSubsequenceState
          (source.flatMap (strictStepPacket cutoff)) target := by
      rw [bounded_schedule_succ]
    _ =
        literalSubsequenceState
          ((source.flatMap fun depth => [depth + 1, depth]).filter fun depth =>
            decide (depth < cutoff)) target := by
      rw [flat_strict_filter cutoff source
        hsource]
    _ =
        literalSubsequenceState
          (source.flatMap fun depth => [depth + 1, depth]) target := by
      unfold literalSubsequenceState
      exact_mod_cast
        subsequence_multiplicity_filter cutoff
          (source.flatMap fun depth => [depth + 1, depth]) target htarget
    _ =
        expandedSubsequenceState source target := by
      exact
        congrFun
          (literal_flat_expanded
            source)
          target
    _ =
        strictSubsequenceState
          (literalSubsequenceState source) target := by
      exact congrFun (expanded_subsequence_state source)
        target

end SFSem
end TCTex
