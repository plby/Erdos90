  have houterPos :
      1 ≤ outer.weight (fun _ : Atom => 1) :=
    CWord.weight_pos (fun _ : Atom => 1) (fun _ => by simp) outer
  have hselectedPos :
      1 ≤ selected.weight (fun _ : Atom => 1) :=
    CWord.weight_pos (fun _ : Atom => 1) (fun _ => by simp) selected
  have hrightPos :
      1 ≤ right.weight (fun _ : Atom => 1) :=
    CWord.weight_pos (fun _ : Atom => 1) (fun _ => by simp) right
