    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (tail : FRProgra)
    (slot : CWord Atom) :
    (negativeAffineSlot
      cutoff tail slot).eval =
        fun steps : ℕ =>
          (Multiset.count slot
            ((scheduleAffine cutoff
              (((iteratePrepend cutoff isFirstCurrent
                NNPower.inverseNormalizedTrace
                  steps tail).trace cutoff).map
                    (SRTrans.crossed
                      firstConventionalWord))).apply 0) : ℤ) := by
  apply BCExp.eval_binomialBasis
  simpa using
    countAffineOverhead
      cutoff hcutoff tail slot

/-- Every positive Hall-Witt outer-packet affine endpoint slot lies in the
bounded repeated-block recipe span at the sharpened degree. -/
lemma scheduleAffineOverhead
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (tail : FRProgra)
    (slot : CWord Atom) :
