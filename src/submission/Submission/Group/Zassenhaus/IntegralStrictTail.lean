/--
A physical parent-layer coefficient expansion for the fixed Hall-Witt head
packet.
-/
structure CHExp
    {d inputWeight : ℕ}
    (x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d)))
    (coefficient : ℕ → ℤ) where
  expansion :
    BCExp inputWeight
      (exponentAddressParent x y z)
  eval_expansion :
    expansion.eval = coefficient

namespace CHExp

/-- Reindex the shared coefficient expansion at the original Jacobi head. -/
def originalExpansion
    {d inputWeight : ℕ}
    {x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d))}
    {coefficient : ℕ → ℤ}
    (head :
      CHExp
        (inputWeight := inputWeight) x y z coefficient) :
    BCExp inputWeight
      ((addressJacobiOriginal x y z).weight
        PEAddres.weight) :=
  BCExp.reweight (by simp) head.expansion

/-- Reindex the shared coefficient expansion at the first Jacobi descendant. -/
def firstExpansion
    {d inputWeight : ℕ}
    {x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d))}
    {coefficient : ℕ → ℤ}
    (head :
