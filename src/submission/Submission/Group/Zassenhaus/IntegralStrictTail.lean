    (natural_outer_empty
      cutoff).2 hkernel

/-- The negative signed-profile fixed-affine kernel discharges global
negative strict-tail cutoff-profile polynomiality. -/
lemma negative_fixed_affine
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
