finite substitution packet. -/
lemma singleton_nonempty_sublists
    (cutoff depth : ℕ)
    (hdepth : depth < cutoff) :
    [depth] ∈ nonemptySublists (strictStepPacket cutoff depth) := by
  by_cases hnextDepth : depth + 1 < cutoff
  · simp [nonemptySublists, strictStepPacket, hdepth, hnextDepth]
  · simp [nonemptySublists, strictStepPacket, hdepth, hnextDepth]

/-- A nonempty active subsequence of one bounded depth packet has rank at
least that of its source depth.  Equality forces the retained singleton. -/
lemma nonempty_sublists_packet
    (cutoff depth : ℕ)
    (hdepth : depth < cutoff)
    (head : List ℕ)
    (hhead :
      head ∈ nonemptySublists (strictStepPacket cutoff depth)) :
    depth + 1 ≤ depthWordRank head ∧
      (depthWordRank head = depth + 1 → head = [depth]) := by
  by_cases hnextDepth : depth + 1 < cutoff
  · simp only [Order.add_one_le_iff] at ⊢
    change head ∈
      (strictStepPacket cutoff depth).sublists.filter
        (fun selected => decide (selected ≠ [])) at hhead
    have hfiltered := List.mem_filter.mp hhead
    have hnonempty : head ≠ [] := of_decide_eq_true hfiltered.2
    have hhead : head.Sublist [depth + 1, depth] := by
      simpa [strictStepPacket, hdepth, hnextDepth] using hfiltered.1
    cases head with
    | nil =>
        exact False.elim (hnonempty rfl)
    | cons first tail =>
        cases tail with
        | nil =>
            have hfirst : first = depth + 1 ∨ first = depth := by
              simpa using hhead
            rcases hfirst with rfl | rfl
            · simp
            · simp
        | cons second tail =>
            cases tail with
            | nil =>
                have hfirstSecond :
                    [first, second] = [depth + 1, depth] :=
                  hhead.eq_of_length (by simp)
                injection hfirstSecond with hfirst hsecond
                subst first
                have hsecondEq : second = depth := by
                  simpa using hsecond
                subst second
                constructor
                · simp only [depth_rank_cons, depth_rank_nil, Nat.add_zero]
                  omega
                · intro hrank
                  simp only [depth_rank_cons, depth_rank_nil,
                    Nat.add_zero] at hrank
                  omega
            | cons third tail =>
                have hlength := hhead.length_le
                simp at hlength
  · simp [nonemptySublists, strictStepPacket, hdepth, hnextDepth] at hhead
    subst head
    simp

