/-!
# Ordered cutoff routing for coefficient-dependent Hall-Witt sources

The final Hall-Witt route cannot be recovered from multiplicities alone:
stable routing is order-sensitive.  Replace the literal route by an exact
ordered cutoff reducer.  At each step it carries only the below-cutoff ordered
suffix, because moving one word rightward and then filtering gives the same
result as first filtering the crossed suffix.

The resulting state is still a list, but every state entry lies in the fixed
finite cutoff vocabulary.  This is the ordered finite-alphabet interface
needed for a later symbolic collector for the coefficient-dependent second
route.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace TORoute

open CWTrace
open WSTrace
open NPTail
open STVocabu
open RMRecb
open TBProf
open ARProfa
open ARProfa.CPAffine
open ARProf
open ASFilt

/-- Filtering a trace below one cutoff is idempotent. -/
lemma unit_below_idem
    (cutoff : ℕ)
    (source : List (CWord Atom)) :
    unitBelowTrace cutoff (unitBelowTrace cutoff source) =
      unitBelowTrace cutoff source := by
  induction source with
  | nil =>
      rfl
  | cons word words ih =>
      by_cases hweight : word.weight (fun _ => 1) < cutoff
      · simp [unitBelowTrace, hweight]
      · simp [unitBelowTrace, hweight]

/-- Filtering a cons whose tail is already filtered does not change the
result. -/
lemma unit_below_cons
    (cutoff : ℕ)
    (word : CWord Atom)
    (words : List (CWord Atom)) :
    unitBelowTrace cutoff
        (word :: unitBelowTrace cutoff words) =
      unitBelowTrace cutoff (word :: words) := by
  by_cases hweight : word.weight (fun _ => 1) < cutoff
  · simp [unitBelowTrace, hweight]
  · simp [unitBelowTrace, hweight]

/--
Modulo cutoff, moving one word rightward depends only on the already-filtered
crossed suffix.
-/
lemma unit_below_higher
    (cutoff : ℕ)
    (left : CWord Atom) :
    ∀ rights : List (CWord Atom),
      unitBelowTrace cutoff
          (moveHigherTrace left
            (unitBelowTrace cutoff rights)) =
        unitBelowTrace cutoff (moveHigherTrace left rights)
  | [] => by
      rfl
  | right :: rights => by
      by_cases hright : right.weight (fun _ => 1) < cutoff
      · have ih :=
          unit_below_higher
            cutoff left rights
        unfold unitBelowTrace at ih ⊢
        simp only [List.filter_cons, decide_eq_true_eq, if_pos hright,
          moveHigherTrace]
        rw [ih]
      · have hcommutator :
          ¬(CWord.commutator left right).weight (fun _ => 1) <
            cutoff := by
          simp only [CWord.weight_commutator]
          omega
        have ih :=
          unit_below_higher
            cutoff left rights
        unfold unitBelowTrace at ih ⊢
        simp only [List.filter_cons, decide_eq_true_eq, if_neg hright,
          moveHigherTrace, if_neg hcommutator]
        exact ih

/--
Exact ordered stable routing modulo cutoff.  The carried suffix is filtered
after every step, so it is a finite-alphabet state even when the literal route
contains arbitrarily heavy corrections.
-/
def cutoffRouteOnto
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool) :
    List (CWord Atom) →
      List (CWord Atom) →
        List (CWord Atom)
  | [], rights =>
      unitBelowTrace cutoff rights
  | word :: words, rights =>
      let routed := cutoffRouteOnto cutoff isCurrent words rights
      if isCurrent word = true then
        unitBelowTrace cutoff (moveHigherTrace word routed)
      else
        unitBelowTrace cutoff (word :: routed)

/-- The ordered cutoff reducer is exactly literal stateful routing followed
by cutoff filtering. -/
lemma cutoff_route_below
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool) :
    ∀ source rights : List (CWord Atom),
      cutoffRouteOnto cutoff isCurrent source rights =
        unitBelowTrace cutoff (routeOnto isCurrent source rights)
  | [], rights => by
      rfl
  | word :: words, rights => by
      simp only [cutoffRouteOnto, routeOnto]
      rw [cutoff_route_below
        cutoff isCurrent words rights]
      by_cases hcurrent : isCurrent word = true
      · rw [if_pos hcurrent, if_pos hcurrent]
        exact
          unit_below_higher
            cutoff word (routeOnto isCurrent words rights)
      · rw [if_neg hcurrent, if_neg hcurrent]
        exact
          unit_below_cons cutoff word
            (routeOnto isCurrent words rights)

/-- Ordered cutoff routing always returns an already-filtered state. -/
lemma below_route_onto
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (source rights : List (CWord Atom)) :
    unitBelowTrace cutoff
        (cutoffRouteOnto cutoff isCurrent source rights) =
      cutoffRouteOnto cutoff isCurrent source rights := by
  calc
    unitBelowTrace cutoff
          (cutoffRouteOnto cutoff isCurrent source rights) =
        unitBelowTrace cutoff
          (unitBelowTrace cutoff
            (routeOnto isCurrent source rights)) := by
      rw [cutoff_route_below]
    _ = unitBelowTrace cutoff
          (routeOnto isCurrent source rights) := by
      rw [unit_below_idem]
    _ = cutoffRouteOnto cutoff isCurrent source rights := by
      rw [cutoff_route_below]

/--
If every selected word survives the cutoff, the ordered cutoff reducer may
filter its source before routing.
-/
lemma route_below_source
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool) :
    ∀ (source rights : List (CWord Atom)),
      (∀ word ∈ source,
        isCurrent word = true →
          word.weight (fun _ => 1) < cutoff) →
        cutoffRouteOnto cutoff isCurrent
            (unitBelowTrace cutoff source) rights =
          cutoffRouteOnto cutoff isCurrent source rights
  | [], rights, _hsource => by
      rfl
  | word :: words, rights, hsource => by
      have htail :
          ∀ next ∈ words,
            isCurrent next = true →
              next.weight (fun _ => 1) < cutoff := by
        intro next hnext hcurrent
        exact hsource next (by simp [hnext]) hcurrent
      have ih :=
        route_below_source
          cutoff isCurrent words rights htail
      unfold unitBelowTrace at ih
      by_cases hweight : word.weight (fun _ => 1) < cutoff
      · simp only [unitBelowTrace, List.filter_cons,
          decide_eq_true_eq, if_pos hweight, cutoffRouteOnto]
        rw [ih]
      · have hnotCurrent : isCurrent word ≠ true := by
          intro hcurrent
          exact hweight (hsource word (by simp) hcurrent)
        simp only [unitBelowTrace, List.filter_cons,
          decide_eq_true_eq, if_neg hweight, cutoffRouteOnto, hnotCurrent]
        rw [ih]
        simp only [Bool.false_eq_true, if_false]
        exact
          (below_route_onto
            cutoff isCurrent words rights).symm

/-- Above weight three, the first-family ordered reducer may filter every
literal source trace before routing. -/
lemma route_current_below
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (source rights : List (CWord Atom)) :
    cutoffRouteOnto cutoff isFirstCurrent
        (unitBelowTrace cutoff source) rights =
      cutoffRouteOnto cutoff isFirstCurrent source rights := by
  apply route_below_source
  intro word _hword hcurrent
  rw [first_current_true word hcurrent]
  exact hcutoff

/-- Every state emitted by ordered cutoff routing lies in the fixed finite
cutoff vocabulary. -/
lemma vocabulary_route_onto
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (source rights : List (CWord Atom))
    (word : CWord Atom)
    (hword : word ∈ cutoffRouteOnto cutoff isCurrent source rights) :
    word ∈ orderedCutoffVocabulary cutoff := by
  rw [cutoff_route_below] at hword
  exact
    ordered_vocabulary_below
      cutoff (routeOnto isCurrent source rights) word hword

/-- The filtered positive first-pass source is exactly one ordered cutoff
route over its original repeated residual source. -/
lemma unit_routed_fst
    (cutoff multiplicity : ℕ) :
    unitBelowTrace cutoff
        (NPTail.firstRouted multiplicity).1 =
      cutoffRouteOnto cutoff isFirstCurrent
        (NPTail.naturalResidualTrace multiplicity)
        [] := by
  rw [NPTail.firstRouted,
    stable_fst_nil]
  exact
    (cutoff_route_below cutoff isFirstCurrent
      (NPTail.naturalResidualTrace multiplicity)
      []).symm

/-- The filtered negative first-pass source is exactly one ordered cutoff
route over its original repeated residual source. -/
lemma first_routed_fst
    (cutoff multiplicity : ℕ) :
    unitBelowTrace cutoff
        (NNPower.firstRouted
          multiplicity).1 =
      cutoffRouteOnto cutoff isFirstCurrent
        (NNPower.naturalResidualTrace
          multiplicity) [] := by
  rw [NNPower.firstRouted,
    stable_fst_nil]
  exact
    (cutoff_route_below cutoff isFirstCurrent
      (NNPower.naturalResidualTrace
        multiplicity) []).symm

/-- The filtered positive first-pass source is computed from an already
filtered finite-alphabet repeated residual source. -/
lemma below_routed_fst
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (multiplicity : ℕ) :
    unitBelowTrace cutoff
        (NPTail.firstRouted multiplicity).1 =
      cutoffRouteOnto cutoff isFirstCurrent
        (unitBelowTrace cutoff
          (NPTail.naturalResidualTrace
            multiplicity)) [] := by
  rw [unit_routed_fst]
  exact
    (route_current_below
      cutoff hcutoff
      (NPTail.naturalResidualTrace multiplicity)
      []).symm

/-- The filtered negative first-pass source is computed from an already
filtered finite-alphabet repeated residual source. -/
lemma routed_fst_filtered
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (multiplicity : ℕ) :
    unitBelowTrace cutoff
        (NNPower.firstRouted
          multiplicity).1 =
      cutoffRouteOnto cutoff isFirstCurrent
        (unitBelowTrace cutoff
          (NNPower.naturalResidualTrace
            multiplicity)) [] := by
  rw [first_routed_fst]
  exact
    (route_current_below
      cutoff hcutoff
      (NNPower.naturalResidualTrace
        multiplicity) []).symm

/--
The positive strict-tail cutoff profile is the second affine compiler applied
to one ordered finite-alphabet first-route state.
-/
lemma natural_route_onto
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (multiplicity : ℕ) :
    cutoffProfile cutoff
        (NPTail.strictTrace multiplicity) =
      (ofTrace cutoff isSecondCurrent
        (cutoffRouteOnto cutoff isFirstCurrent
          (NPTail.naturalResidualTrace
            multiplicity) [])).apply 0 := by
  rw [natural_filtered_route
    cutoff hcutoff multiplicity,
    unit_routed_fst]

/--
The negative strict-tail cutoff profile is the second affine compiler applied
to one ordered finite-alphabet first-route state.
-/
lemma negative_route_onto
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (multiplicity : ℕ) :
    cutoffProfile cutoff
        (NNPower.strictTrace
          multiplicity) =
      (ofTrace cutoff isSecondCurrent
        (cutoffRouteOnto cutoff isFirstCurrent
          (NNPower.naturalResidualTrace
            multiplicity) [])).apply 0 := by
  rw [filtered_second_route
    cutoff hcutoff multiplicity,
    first_routed_fst]

/--
The positive strict-tail cutoff profile is compiled from a fully filtered
finite-alphabet first-route source and state.
-/
lemma natural_route_filtered
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (multiplicity : ℕ) :
    cutoffProfile cutoff
        (NPTail.strictTrace multiplicity) =
      (ofTrace cutoff isSecondCurrent
        (cutoffRouteOnto cutoff isFirstCurrent
          (unitBelowTrace cutoff
            (NPTail.naturalResidualTrace
              multiplicity)) [])).apply 0 := by
  rw [natural_filtered_route
    cutoff hcutoff multiplicity,
    below_routed_fst
      cutoff hcutoff multiplicity]

/--
The negative strict-tail cutoff profile is compiled from a fully filtered
finite-alphabet first-route source and state.
-/
lemma route_filtered_source
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (multiplicity : ℕ) :
    cutoffProfile cutoff
        (NNPower.strictTrace
          multiplicity) =
      (ofTrace cutoff isSecondCurrent
        (cutoffRouteOnto cutoff isFirstCurrent
          (unitBelowTrace cutoff
            (NNPower.naturalResidualTrace
              multiplicity)) [])).apply 0 := by
  rw [filtered_second_route
    cutoff hcutoff multiplicity,
    routed_fst_filtered
      cutoff hcutoff multiplicity]

