    (cutoff : ℕ) :
    SignedCutoffProfile :=
  profileFormalPredecessor
    (naturalFullBound cutoff)
      (positiveEmptyEndpoint cutoff)

/-- Negative signed orbit-swap profile at formal predecessor input. -/
