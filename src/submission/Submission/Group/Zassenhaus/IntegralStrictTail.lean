/-!
# Nested bounded-depth crossing schedules for Hall-Witt first routes

The dynamic suffix of a complete Hall-Witt first route is a repetition of an
outer homogeneous orbit applied to one inner moved singleton.  Expanding both
homogeneous orbits gives a finite two-depth schedule.  This file records the
exact crossed transition schedule and its finite-alphabet support.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace NCSched

open CWTrace
open WSTrace
open WHNorm
open WNTrace
open WSTail
open NPTail
open RMRecb
open TBProf
open OFProgra
open OFProgra.FRProgra
open TODepth
open OTSubsti
open OTDecomp
open BDExp
open DCSched
open OCState
open STSched
open DSRec
open FDCross
open NRBlock
open BTRepeat

/-- Fixed transition packet at one inner correction depth and one outer
correction depth. -/
def nestedCrossingPacket
    (cutoff : ℕ)
    (crossed outer innerRight : CWord Atom)
    (outerDepth : ℕ) :
    List SRTrans :=
  (iteratedCutoffTrace cutoff outer outerDepth
    (unitBelowTrace cutoff [innerRight])).map
      (SRTrans.crossed crossed)

/-- Crossed transition schedule for the two nested bounded homogeneous
orbits. -/
def boundedNestedCrossing
    (cutoff : ℕ)
    (crossed outer selected right : CWord Atom)
    (steps : ℕ) :
    List SRTrans :=
  (boundedDepthSchedule cutoff steps).flatMap fun innerDepth =>
    (iteratedMoveTrace selected innerDepth [right]).flatMap
      fun innerRight =>
        (boundedDepthSchedule cutoff steps).flatMap fun outerDepth =>
          nestedCrossingPacket cutoff crossed outer
            innerRight outerDepth

/-- The nested schedule is the bounded inner depth word flattened through
ordinary outer bounded-depth crossing schedules. -/
lemma bounded_crossing_flat
    (cutoff : ℕ)
    (crossed outer selected right : CWord Atom)
    (steps : ℕ) :
    boundedNestedCrossing cutoff crossed outer selected
        right steps =
      (boundedDepthSchedule cutoff steps).flatMap fun innerDepth =>
        depthCrossingSchedule cutoff crossed outer
          (iteratedLeftCommutator selected innerDepth right) steps := by
  unfold boundedNestedCrossing
    depthCrossingSchedule
    nestedCrossingPacket
    strictCrossingPacket
    boundedDepthSchedule
  apply List.flatMap_congr
  intro innerDepth _hinnerDepth
  rw [iterated_correction_singleton]
  simp only [List.flatMap_singleton]

/-- Crossing the outer homogeneous orbit of an inner moved singleton is
exactly the nested two-depth schedule. -/
lemma crossed_higher_singleton
    (cutoff steps : ℕ)
    (crossed outer selected right : CWord Atom)
    (houter :
      isFirstCurrent outer = true ∨
        isSecondCurrent outer = true)
    (hselected :
      isFirstCurrent selected = true ∨
        isSecondCurrent selected = true) :
    (iteratedCutoffMove cutoff outer steps
      (unitBelowTrace cutoff
        (iteratedMoveHigher selected steps [right]))).map
          (SRTrans.crossed crossed) =
      boundedNestedCrossing cutoff crossed outer selected
        right steps := by
  rw [←
    iterated_move_literal
      cutoff steps selected right]
  rw [
    iterated_move_schedule
      cutoff steps selected right hselected,
    iterated_move_flat, map_flatMap]
  unfold boundedNestedCrossing
  apply List.flatMap_congr
  intro innerDepth _hinnerDepth
  rw [iterated_cutoff_below]
  rw [
    iterated_below_schedule
      cutoff steps outer houter,
    map_flatMap]
  apply List.flatMap_congr
  intro innerRight _hinnerRight
  rw [map_flatMap]
  rfl

/-- Every transition in a nested bounded-depth schedule belongs to the fixed
second-route transition alphabet when the crossed word is first-family
current. -/
lemma alphabet_nested_crossing
    (cutoff steps : ℕ)
    (crossed outer selected right : CWord Atom)
    (hcrossed : isFirstCurrent crossed = true)
    (transition : SRTrans)
    (htransition :
      transition ∈
        boundedNestedCrossing cutoff crossed outer selected
          right steps) :
    transition ∈ secondRouteAlphabet cutoff := by
  rcases List.mem_flatMap.mp htransition with
    ⟨innerDepth, _hinnerDepth, htransition⟩
  rcases List.mem_flatMap.mp htransition with
    ⟨innerRight, _hinnerRight, htransition⟩
  rcases List.mem_flatMap.mp htransition with
    ⟨outerDepth, _houterDepth, htransition⟩
  apply
    second_alphabet_crossed
      cutoff crossed hcrossed
        (iteratedCutoffTrace cutoff outer outerDepth
          (unitBelowTrace cutoff [innerRight]))
  · rw [iterated_cutoff_below]
    exact
      supported_vocabulary_below cutoff
        (iteratedMoveTrace outer outerDepth [innerRight])
  · exact htransition

/-- Crossing the repeated nested moved-singleton suffix is diagonal
repetition of the nested two-depth schedule. -/
lemma crossed_repeat_diagonal
    (cutoff steps : ℕ)
    (crossed outer selected right : CWord Atom)
    (houter :
      isFirstCurrent outer = true ∨
        isSecondCurrent outer = true)
    (hselected :
      isFirstCurrent selected = true ∨
        isSecondCurrent selected = true) :
    (repeatTrace steps
      (iteratedCutoffMove cutoff outer steps
        (unitBelowTrace cutoff
          (iteratedMoveHigher selected steps [right])))).map
            (SRTrans.crossed crossed) =
      repeatTransitionSchedule
        (boundedNestedCrossing cutoff crossed outer selected
          right steps) steps := by
  rw [map_repeatTrace,
    crossed_higher_singleton
      cutoff steps crossed outer selected right houter hselected]

end NCSched
end TCTex
end Submission

