      AddressParentLayer (n := n) x y z →+ ℤ) :
    IVMost
      (addressGradedFunctional
        x y z cutoff coordinate)
      ((exponentAddressParent x y z + 1) /
        inputWeight) := by
  unfold
    addressGradedFunctional
  apply polynomial_finsetSum
  intro word _hword
  by_cases hweight :
      word.weight PEAddres.weight ≤
        exponentAddressParent x y z + 1
  · simpa only [Pi.smul_apply, smul_eq_mul] using
      TCTex.IVMost.smul
        (coordinate
          (addressSlotClass
            (n := n) x y z word))
        ((address_natural_physical
          x y z cutoff inputWeight hcutoff hinputWeight hx hy hz word).mono
            (Nat.div_le_div_right hweight))
  · have hclass :
        addressSlotClass
            (n := n) x y z word = 0 :=
      address_slot_parent
        x y z word (Nat.lt_of_not_ge hweight)
    simpa [hclass] using
      TCTex.IVMost.zero
        ((exponentAddressParent x y z + 1) /
          inputWeight)

