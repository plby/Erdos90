      cutoff * ((negativeFilteredPrefix cutoff).length + 1) +
        (tail.trace cutoff).length + 1)
    (by omega)
    (fun steps : ℕ =>
      (Multiset.count slot
        ((scheduleAffine cutoff
          (((iteratePrepend cutoff isFirstCurrent
            NNPower.inverseNormalizedTrace
              steps tail).trace cutoff).map
                (SRTrans.crossed
                  firstConventionalWord))).apply 0) : ℤ))

/-- The positive Hall-Witt outer-packet endpoint recipe evaluates to its
literal semantic affine endpoint coordinate. -/
lemma affine_endpoint_expansion
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (tail : FRProgra)
    (slot : CWord Atom) :
    (affineSlotExpansion
      cutoff tail slot).eval =
        fun steps : ℕ =>
          (Multiset.count slot
            ((scheduleAffine cutoff
              (((iteratePrepend cutoff isFirstCurrent
                WNTrace.trace steps tail).trace
                  cutoff).map
                    (SRTrans.crossed
                      firstConventionalInverse))).apply 0) : ℤ) := by
  apply BCExp.eval_binomialBasis
  simpa using
    affinePositiveOverhead
      cutoff hcutoff tail slot

/-- The negative Hall-Witt outer-packet endpoint recipe evaluates to its
literal semantic affine endpoint coordinate. -/
