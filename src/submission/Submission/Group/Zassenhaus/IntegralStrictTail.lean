namespace TCTex
namespace ARExp

open CWTrace
open WSTrace
open NPTail
open STVocabu
open RMRecb
open TBProf
open ARProfa
open ARProfa.CPAffine
open ARPoly

/-- Newton-normalized repeated-block expansion for one retained fixed-packet
slot. -/
noncomputable def repeatedPacketSlot
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom))
    (slot : CWord Atom) :
    BCExp 1 cutoff :=
  BCExp.binomialBasis 1 cutoff (by omega)
    (repeatedPacketMultiplicity cutoff isCurrent packet slot)

/-- The normalized repeated-block expansion evaluates to the literal retained
slot multiplicity after any number of fixed-packet iterations. -/
lemma repeated_packet_expansion
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom))
    (slot : CWord Atom) :
    (repeatedPacketSlot cutoff isCurrent packet slot).eval =
      repeatedPacketMultiplicity cutoff isCurrent packet slot := by
  apply BCExp.eval_binomialBasis
  simpa using
    repeated_valued_most
      cutoff hcutoff isCurrent packet slot

/-- Every literal retained fixed-packet slot multiplicity belongs to the
bounded repeated-block recipe span. -/
lemma repeated_slot_span
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom))
    (slot : CWord Atom) :
    IntCombinationRecipes
      1 cutoff
      (repeatedPacketMultiplicity cutoff isCurrent packet slot) := by
  rw [← repeated_packet_expansion
    cutoff hcutoff isCurrent packet slot]
  exact
    (repeatedPacketSlot cutoff isCurrent packet slot).eval_recipe_span

/-- One coefficient-independent list of fixed-packet recipe expansions,
indexed by the ordered cutoff vocabulary. -/
noncomputable def repeatedExpansionVector
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom)) :
    List (BCExp 1 cutoff) :=
  (orderedCutoffVocabulary cutoff).map fun slot =>
    repeatedPacketSlot cutoff isCurrent packet slot

/-- The fixed-packet recipe vector has one coordinate for every formal cutoff
slot. -/
lemma length_repeated_vocabulary
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom)) :
    (repeatedExpansionVector cutoff isCurrent packet).length =
      (orderedCutoffVocabulary cutoff).length := by
  simp [repeatedExpansionVector]

/-- Evaluating the vocabulary-wide fixed-packet recipe vector recovers every
literal retained slot multiplicity after affine iteration. -/
lemma repeated_packet_vector
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom))
    (steps : ℕ) :
    (repeatedExpansionVector cutoff isCurrent packet).map
        (fun expansion => expansion.eval steps) =
      (orderedCutoffVocabulary cutoff).map fun slot =>
        repeatedPacketMultiplicity cutoff isCurrent packet slot steps := by
  unfold repeatedExpansionVector
  rw [List.map_map]
  apply List.map_congr_left
  intro slot _hslot
  rw [Function.comp_apply,
    repeated_packet_expansion cutoff hcutoff isCurrent packet slot]

/--
Evaluating the fixed-packet recipe vector recovers the cutoff multiplicities
of the literal stable route through any repeated fixed packet.
-/
lemma repeated_stable_route
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom))
    (steps : ℕ) :
    (repeatedExpansionVector cutoff isCurrent packet).map
        (fun expansion => expansion.eval steps) =
      (orderedCutoffVocabulary cutoff).map fun slot =>
        (unitBelowMultiplicity cutoff
          (stableRoute isCurrent (repeatTrace steps packet)).1 slot : ℤ) := by
  rw [repeated_packet_vector
    cutoff hcutoff isCurrent packet steps]
  apply List.map_congr_left
  intro slot _hslot
  rw [repeatedPacketMultiplicity]
  rw [show
      unitBelowMultiplicity cutoff
          (stableRoute isCurrent (repeatTrace steps packet)).1 slot =
        Multiset.count slot
          (cutoffProfile cutoff
            (stableRoute isCurrent (repeatTrace steps packet)).1) by
      simp [unitBelowMultiplicity, cutoffProfile]]
  rw [stable_fst_repeat]

end ARExp
end TCTex
