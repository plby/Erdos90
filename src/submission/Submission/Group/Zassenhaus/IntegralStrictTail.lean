    (cutoff : ℕ)
    (hcutoff : 3 < cutoff) :
    EmptySuccessorNewton
      cutoff := by
  apply
    empty_compiler_poly
      cutoff hcutoff
  exact
    empty_compiler_bound
      cutoff (by omega)

