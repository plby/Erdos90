strict-depth word through its fixed per-depth packets. -/
def depthCrossingSchedule
    (cutoff : ℕ)
    (outer selected right : CWord Atom)
    (steps : ℕ) :
    List SRTrans :=
  ((strictDepthSchedule steps).filter fun depth =>
    decide (depth < cutoff)).flatMap
      (strictCrossingPacket cutoff outer selected right)

