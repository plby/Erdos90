/-- Signed Newton evaluation of a polynomial family is evaluation of any
degree-bounded rational witness at `-1`. -/
lemma cast_newton_evaluation
    (degreeBound : ℕ)
    (family : ℕ → ℤ)
    (P : Polynomial ℚ)
    (hdegree : P.natDegree ≤ degreeBound)
    (heval : ∀ steps : ℕ, P.eval (steps : ℚ) = (family steps : ℚ)) :
    (newtonSignedEvaluation degreeBound family : ℚ) =
      P.eval (-1) := by
  have hcanonical :
      P = natBinomialExpansion family degreeBound :=
    polynomial_binomial_expansion P hdegree heval
  calc
    (newtonSignedEvaluation degreeBound family : ℚ) =
        (natBinomialExpansion family degreeBound).eval (-1) := by
          rw [binomial_expansion_neg]
          rfl
    _ = P.eval (-1) := by
      rw [← hcanonical]

/-- Signed Newton evaluation at a sufficiently large common bound preserves
products of polynomial families. -/
lemma newton_evaluation_polynomial
    (leftDegree rightDegree largerBound : ℕ)
    (hdegree : leftDegree + rightDegree ≤ largerBound)
    (left right : ℕ → ℤ)
    (hleft :
      IVMost left leftDegree)
    (hright :
      IVMost right rightDegree) :
    newtonSignedEvaluation largerBound
        (fun steps => left steps * right steps) =
      newtonSignedEvaluation leftDegree left *
        newtonSignedEvaluation rightDegree right := by
  rcases hleft with ⟨P, hPdegree, hPeval⟩
  rcases hright with ⟨Q, hQdegree, hQeval⟩
  have hPQdegree : (P * Q).natDegree ≤ largerBound :=
    Polynomial.natDegree_mul_le.trans
      ((Nat.add_le_add hPdegree hQdegree).trans hdegree)
  have hPQeval :
      ∀ steps : ℕ,
        (P * Q).eval (steps : ℚ) =
          ((left steps * right steps : ℤ) : ℚ) := by
    intro steps
    rw [Polynomial.eval_mul, hPeval, hQeval]
    norm_cast
  have hproduct :=
    cast_newton_evaluation largerBound
      (fun steps => left steps * right steps) (P * Q) hPQdegree hPQeval
  have hleftEval :=
    cast_newton_evaluation leftDegree left P
      hPdegree hPeval
  have hrightEval :=
    cast_newton_evaluation rightDegree right Q
      hQdegree hQeval
  rw [Polynomial.eval_mul, ← hleftEval, ← hrightEval] at hproduct
  exact_mod_cast hproduct

/-- At formal predecessor input `-1`, every transition-word coordinate of a
successor-skew tail is the corresponding emitted-orbit-prefix coordinate. -/
lemma newton_orbit_prefix
    (cutoff : ℕ)
    (crossed outer selected right : CWord Atom)
    (emittedPrefix : List (CWord Atom))
    (target : List SRTrans) :
    newtonSignedEvaluation
        (target.length * (2 * cutoff + emittedPrefix.length + 4) + 1)
        (fun steps : ℕ =>
          (orderedSubsequenceMultiplicity target
            (middleSuccessorSkew cutoff
              crossed outer selected right emittedPrefix steps) : ℤ)) =
      newtonSignedEvaluation
        (target.length * (2 * cutoff + emittedPrefix.length + 4) + 1)
        (fun steps : ℕ =>
          (orderedSubsequenceMultiplicity target
            (boundedCrossingSchedule cutoff crossed outer
              emittedPrefix steps) : ℤ)) := by
  let fullDegree :=
    target.length * (2 * cutoff + emittedPrefix.length + 4) + 1
  rw [show
    (fun steps : ℕ =>
      (orderedSubsequenceMultiplicity target
        (middleSuccessorSkew cutoff
          crossed outer selected right emittedPrefix steps) : ℤ)) =
      fun steps : ℕ =>
        ∑ suffix ∈ target.tails.toFinset,
          (orderedSubsequenceMultiplicity
            (target.take (target.length - suffix.length))
            (boundedCrossingSchedule cutoff crossed outer
              emittedPrefix steps) : ℤ) *
          (orderedSubsequenceMultiplicity suffix
            (repeatTransitionSchedule
              (successorSkewCrossing cutoff
                crossed outer selected right steps) (steps + 1)) : ℤ) by
    funext steps
    exact_mod_cast
      subsequence_append_tails target
        (boundedCrossingSchedule cutoff crossed outer
          emittedPrefix steps)
        (repeatTransitionSchedule
          (successorSkewCrossing cutoff crossed
            outer selected right steps) (steps + 1))]
  rw [newton_evaluation_finset]
  calc
    (∑ suffix ∈ target.tails.toFinset,
      newtonSignedEvaluation fullDegree
        (fun steps =>
          (orderedSubsequenceMultiplicity
            (target.take (target.length - suffix.length))
            (boundedCrossingSchedule cutoff crossed outer
              emittedPrefix steps) : ℤ) *
          (orderedSubsequenceMultiplicity suffix
            (repeatTransitionSchedule
              (successorSkewCrossing cutoff
                crossed outer selected right steps) (steps + 1)) : ℤ))) =
        ∑ suffix ∈ target.tails.toFinset,
          newtonSignedEvaluation
              ((target.take (target.length - suffix.length)).length *
                  (cutoff + emittedPrefix.length + 1) + 1)
              (fun steps : ℕ =>
                (orderedSubsequenceMultiplicity
                  (target.take (target.length - suffix.length))
                  (boundedCrossingSchedule cutoff crossed
                    outer emittedPrefix steps) : ℤ)) *
            ([[]].count suffix : ℤ) := by
      apply Finset.sum_congr rfl
      intro suffix hsuffix
      have hsuffixMem :
          suffix <:+ target :=
        (List.mem_tails suffix target).mp (List.mem_toFinset.mp hsuffix)
      have hdegree :
          (target.take (target.length - suffix.length)).length *
                  (cutoff + emittedPrefix.length + 1) +
                1 +
              suffix.length * (2 * cutoff + 3) ≤
            fullDegree := by
        rcases hsuffixMem with ⟨initial, rfl⟩
        simp only [List.length_append, Nat.add_sub_cancel_right,
          List.take_append_of_le_length (Nat.le_refl initial.length),
          List.take_length]
        dsimp [fullDegree]
        have hleft :
            cutoff + emittedPrefix.length + 1 ≤
              2 * cutoff + emittedPrefix.length + 4 := by
          omega
        have hright :
            2 * cutoff + 3 ≤
              2 * cutoff + emittedPrefix.length + 4 := by
          omega
        calc
          initial.length * (cutoff + emittedPrefix.length + 1) + 1 +
                suffix.length * (2 * cutoff + 3) ≤
              initial.length * (2 * cutoff + emittedPrefix.length + 4) + 1 +
                suffix.length * (2 * cutoff + emittedPrefix.length + 4) :=
            Nat.add_le_add
              (Nat.add_le_add_right
                (Nat.mul_le_mul_left initial.length hleft) 1)
              (Nat.mul_le_mul_left suffix.length hright)
          _ =
              (initial.length + suffix.length) *
                    (2 * cutoff + emittedPrefix.length + 4) +
                1 := by
            rw [Nat.add_mul]
            omega
          _ =
              (initial ++ suffix).length *
                    (2 * cutoff + emittedPrefix.length + 4) +
                1 := by
            rw [List.length_append]
      rw [newton_evaluation_polynomial
        ((target.take (target.length - suffix.length)).length *
            (cutoff + emittedPrefix.length + 1) + 1)
        (suffix.length * (2 * cutoff + 3)) fullDegree hdegree]
