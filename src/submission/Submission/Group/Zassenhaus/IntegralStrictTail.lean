    (cutoff : ℕ) :
    negativeSuccessorSkew cutoff =
      negativeSkewState cutoff := by
  unfold negativeSuccessorSkew
    negativeSkewState
    negativeFullBound
  exact
    newton_state_prefix
      cutoff firstConventionalWord firstConventionalWord
        firstConventionalInverse secondConventionalWord (by rfl)
          (negativeFilteredPrefix cutoff)

/-- Positive endpoint cancellation expressed against the emitted
orbit-prefix-only signed state. -/
def NaturalSuccessorSkew
    (cutoff : ℕ) :
    Prop :=
  ∀ slot,
    boundedStateSlot cutoff
      (boundedStateFold cutoff
        (positiveFixedPrefix cutoff)
          (naturalSkewState cutoff)) slot = 0

/-- Negative endpoint cancellation expressed against the emitted
orbit-prefix-only signed state. -/
def NegativeSuccessorSkew
    (cutoff : ℕ) :
    Prop :=
  ∀ slot,
    boundedStateSlot cutoff
      (boundedStateFold cutoff
        (negativeFixedPrefix cutoff)
          (negativeSkewState cutoff)) slot = 0

/-- The positive finite prefix-kernel obligation is unchanged after
removing the repeated nested suffix. -/
