-- Merged from JacobiIntegralPowerStrictTailCutoffAffineRouteUnipotence.lean

/-!
# Unipotence of fixed-packet Hall-Witt cutoff routing

The linear part of a compiled stable-routing packet is unipotent modulo every
positive cutoff.  Recursively isolate its strict correction endomorphism `N`.
Every emitted term of `N` gains at least one unit of formal weight, and every
emitted term remains strictly below cutoff.  Consequently `N ^ cutoff = 0`.

This is the nilpotent engine behind polynomial iteration of fixed affine
Hall-Witt routing packets.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace ARUnipot

open CWTrace
open WSTrace
open RMRecb
open TBProf
open ARProfa
open ARProfa.CPAffine

/-- Additive endomorphisms of formal cutoff profiles. -/
abbrev ProfileEnd :=
  AddMonoid.End (Multiset (CWord Atom))

/-- Strict bracket-correction endomorphism from the cutoff binomial profile
layer. -/
abbrev strictCorrectionEnd :=
  TBProf.correctionEnd

/-- Every emitted term originates in an input term whose unit weight rises by
at least `increment`. -/
def RUWt
    (increment : ℕ)
    (transform : ProfileEnd) :
    Prop :=
  ∀ source emitted,
    emitted ∈ transform source →
      ∃ original ∈ source,
        original.weight (fun _ => 1) + increment ≤
          emitted.weight (fun _ => 1)

/-- Every emitted term lies strictly below one unit-weight cutoff. -/
def OBCutoff
    (cutoff : ℕ)
    (transform : ProfileEnd) :
    Prop :=
  ∀ source emitted,
    emitted ∈ transform source →
      emitted.weight (fun _ => 1) < cutoff

namespace RUWt

/-- The zero endomorphism vacuously raises weight by every amount. -/
lemma zero
    (increment : ℕ) :
    RUWt increment (0 : ProfileEnd) := by
  intro source emitted hemitted
  simp at hemitted

/-- The identity endomorphism preserves unit weight. -/
lemma one :
    RUWt 0 (1 : ProfileEnd) := by
  intro source emitted hemitted
  exact ⟨emitted, hemitted, by simp⟩

/-- A proven weight rise may be weakened. -/
lemma mono
    {smaller larger : ℕ}
    {transform : ProfileEnd}
    (hbound : smaller ≤ larger)
    (htransform : RUWt larger transform) :
    RUWt smaller transform := by
  intro source emitted hemitted
  rcases htransform source emitted hemitted with
    ⟨original, horiginal, hweight⟩
  exact ⟨original, horiginal, (Nat.add_le_add_left hbound _).trans hweight⟩

/-- Sums preserve a common lower weight rise. -/
lemma add
    {increment : ℕ}
    {left right : ProfileEnd}
    (hleft : RUWt increment left)
    (hright : RUWt increment right) :
    RUWt increment (left + right) := by
  intro source emitted hemitted
  change emitted ∈ left source + right source at hemitted
  rw [Multiset.mem_add] at hemitted
  rcases hemitted with hemitted | hemitted
  · exact hleft source emitted hemitted
  · exact hright source emitted hemitted

/-- Composition adds guaranteed weight rises. -/
lemma mul
    {leftIncrement rightIncrement : ℕ}
    {left right : ProfileEnd}
    (hleft : RUWt leftIncrement left)
    (hright : RUWt rightIncrement right) :
    RUWt (leftIncrement + rightIncrement) (left * right) := by
  intro source emitted hemitted
  change emitted ∈ left (right source) at hemitted
  rcases hleft (right source) emitted hemitted with
    ⟨middle, hmiddle, hmiddleWeight⟩
  rcases hright source middle hmiddle with
    ⟨original, horiginal, horiginalWeight⟩
  refine ⟨original, horiginal, ?_⟩
  omega

/-- One strict bracket-correction endomorphism raises weight by the full
weight of its left input. -/
lemma correctionEnd
    (cutoff : ℕ)
    (left : CWord Atom) :
    RUWt (left.weight (fun _ => 1))
      (strictCorrectionEnd cutoff left) := by
  intro source emitted hemitted
  change emitted ∈
    (source.map (CWord.commutator left)).filter
      (fun word => word.weight (fun _ => 1) < cutoff) at hemitted
  rcases Multiset.mem_map.mp (Multiset.mem_filter.mp hemitted).1 with
    ⟨right, hright, rfl⟩
  exact
    ⟨right, hright, by
      simp [CWord.weight_commutator, Nat.add_comm]⟩

/-- Every strict bracket-correction endomorphism raises unit weight by at
least one. -/
lemma correctionEnd_one
    (cutoff : ℕ)
    (left : CWord Atom) :
    RUWt 1 (strictCorrectionEnd cutoff left) := by
  apply mono
  · exact
      CWord.weight_pos (fun _ => 1) (fun _ => by simp) left
  · exact RUWt.correctionEnd cutoff left

end RUWt

namespace OBCutoff

/-- The zero endomorphism vacuously has below-cutoff output. -/
lemma zero
    (cutoff : ℕ) :
    OBCutoff cutoff (0 : ProfileEnd) := by
  intro source emitted hemitted
  simp at hemitted

/-- Sums preserve below-cutoff output. -/
lemma add
    {cutoff : ℕ}
    {left right : ProfileEnd}
    (hleft : OBCutoff cutoff left)
    (hright : OBCutoff cutoff right) :
    OBCutoff cutoff (left + right) := by
  intro source emitted hemitted
  change emitted ∈ left source + right source at hemitted
  rw [Multiset.mem_add] at hemitted
  rcases hemitted with hemitted | hemitted
  · exact hleft source emitted hemitted
  · exact hright source emitted hemitted

/-- If the outer transform has below-cutoff output, so does a composition. -/
lemma mul_left
    {cutoff : ℕ}
    {left right : ProfileEnd}
    (hleft : OBCutoff cutoff left) :
    OBCutoff cutoff (left * right) := by
  intro source emitted hemitted
  exact hleft (right source) emitted hemitted

/-- Strict bracket-correction endomorphisms filter their output below cutoff. -/
lemma correctionEnd
    (cutoff : ℕ)
    (left : CWord Atom) :
    OBCutoff cutoff (strictCorrectionEnd cutoff left) := by
  intro source emitted hemitted
  change emitted ∈
    (source.map (CWord.commutator left)).filter
      (fun word => word.weight (fun _ => 1) < cutoff) at hemitted
  exact (Multiset.mem_filter.mp hemitted).2

end OBCutoff

/--
Strict correction part of the linear profile action compiled from one fixed
packet.  Selected words contribute one new outer bracket correction, while
retained words leave the linear correction part unchanged.
-/
def packetCorrectionEnd
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool) :
    List (CWord Atom) →
      ProfileEnd
  | [] =>
      0
  | word :: words =>
      let tail := packetCorrectionEnd cutoff isCurrent words
      if isCurrent word = true then
        strictCorrectionEnd cutoff word * (tail + 1) + tail
      else
        tail

/-- The compiled linear action is identity plus its strict packet correction
endomorphism. -/
lemma trace_linear_end
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool) :
    ∀ packet : List (CWord Atom),
      (ofTrace cutoff isCurrent packet).linear =
        packetCorrectionEnd cutoff isCurrent packet + 1
  | [] => by
      simp [ofTrace, packetCorrectionEnd, CPAffine.one]
  | word :: words => by
      by_cases hcurrent : isCurrent word = true
      · simp only [ofTrace, packetCorrectionEnd, hcurrent, if_pos, comp,
          selected]
        rw [trace_linear_end cutoff isCurrent
          words]
        simp only [moveEnd, add_mul, mul_add, one_mul]
        unfold strictCorrectionEnd
        simp only [add_assoc, add_comm, add_left_comm]
      · simp only [ofTrace, packetCorrectionEnd, hcurrent, comp,
          retained]
        rw [trace_linear_end cutoff isCurrent
          words]
        simp

/-- Every strict packet correction raises unit weight by at least one. -/
lemma packet_end_raises
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool) :
    ∀ packet : List (CWord Atom),
      RUWt 1 (packetCorrectionEnd cutoff isCurrent packet)
  | [] => by
      exact RUWt.zero 1
  | word :: words => by
      by_cases hcurrent : isCurrent word = true
      · simp only [packetCorrectionEnd, hcurrent, if_pos]
        apply RUWt.add
        · apply RUWt.mono (show 1 ≤ 1 + 0 by omega)
          apply RUWt.mul
          · exact RUWt.correctionEnd_one cutoff word
          · apply RUWt.add
            · exact
                (packet_end_raises cutoff isCurrent
                  words).mono (show 0 ≤ 1 by omega)
            · exact RUWt.one
        · exact
            packet_end_raises cutoff isCurrent words
      · simpa [packetCorrectionEnd, hcurrent] using
          packet_end_raises cutoff isCurrent words

/-- Every strict packet correction emits only terms surviving the cutoff
filter. -/
lemma end_outputs_below
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool) :
    ∀ packet : List (CWord Atom),
      OBCutoff cutoff (packetCorrectionEnd cutoff isCurrent packet)
  | [] => by
      exact OBCutoff.zero cutoff
  | word :: words => by
      by_cases hcurrent : isCurrent word = true
      · simp only [packetCorrectionEnd, hcurrent, if_pos]
        apply OBCutoff.add
        · exact
            OBCutoff.mul_left
              (OBCutoff.correctionEnd cutoff word)
        · exact end_outputs_below cutoff isCurrent words
      · simpa [packetCorrectionEnd, hcurrent] using
          end_outputs_below cutoff isCurrent words

/-- Powers multiply the guaranteed unit-weight rise. -/
lemma pow_raises_weight
    {transform : ProfileEnd}
    (htransform : RUWt 1 transform) :
    ∀ steps : ℕ,
      RUWt steps (transform ^ steps)
  | 0 => by
      simpa using RUWt.one
  | steps + 1 => by
      rw [_root_.pow_succ']
      simpa [Nat.add_comm] using
        RUWt.mul htransform
          (pow_raises_weight htransform steps)

/-- Every positive power of a below-cutoff transform still emits only
below-cutoff terms. -/
lemma pow_outputs_below
    {cutoff : ℕ}
    {transform : ProfileEnd}
    (htransform : OBCutoff cutoff transform) :
    ∀ steps : ℕ,
      0 < steps →
        OBCutoff cutoff (transform ^ steps)
  | 0, hsteps => by
      omega
  | steps + 1, _hsteps => by
      rw [_root_.pow_succ']
      exact OBCutoff.mul_left htransform

/-- The strict correction part of any fixed compiled packet is nilpotent
modulo every positive cutoff. -/
lemma packet_end_zero
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom)) :
    (packetCorrectionEnd cutoff isCurrent packet) ^ cutoff = 0 := by
  apply AddMonoidHom.ext
  intro source
  apply Multiset.ext.mpr
  intro emitted
  change
    Multiset.count emitted
        (((packetCorrectionEnd cutoff isCurrent packet) ^ cutoff) source) =
      Multiset.count emitted 0
  rw [Multiset.count_zero]
  apply Multiset.count_eq_zero.mpr
  intro hemitted
  rcases
      pow_raises_weight
        (packet_end_raises cutoff isCurrent packet)
        cutoff source emitted hemitted with
    ⟨original, _horiginal, hweight⟩
  have hemittedCutoff :=
    pow_outputs_below
      (end_outputs_below cutoff isCurrent packet)
      cutoff hcutoff source emitted hemitted
  have horiginalPositive :
      0 < original.weight (fun _ => 1) :=
    CWord.weight_pos (fun _ => 1) (fun _ => by simp) original
  omega

end ARUnipot
end TCTex
end Submission

-- Merged from JacobiIntegralPowerStrictTailCutoffAffineIterateBinomial.lean

/-!
# Binomial iteration of fixed affine Hall-Witt packets

The linear part of one compiled fixed packet is `1 + N`, where the strict
correction endomorphism `N` is nilpotent modulo cutoff.  This file separates
the elementary affine iteration algebra from the subsequent slotwise
polynomial compiler.

An affine iterate has linear part `L ^ q` and accumulated constant
`sum_{j < q} L ^ j c`.  For a compiled routing packet, nilpotence truncates the
binomial expansion of `L ^ q = (N + 1) ^ q` to the coefficient-independent
range `k < cutoff`.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace AIBinom

open CWTrace
open WSTrace
open TBProf
open ARProfa
open ARProfa.CPAffine
open ARUnipot

/-- The linear part of affine iteration is the corresponding endomorphism
power. -/
lemma linear_iterate
    (transform : CPAffine) :
    ∀ steps : ℕ,
      (iterate transform steps).linear = transform.linear ^ steps
  | 0 => by
      simp [iterate, CPAffine.one]
  | steps + 1 => by
      rw [iterate, CPAffine.comp, linear_iterate transform steps,
        _root_.pow_succ']

/-- The constant part of affine iteration is the geometric sum of translated
constants. -/
lemma constant_iterate
    (transform : CPAffine) :
    ∀ steps : ℕ,
      (iterate transform steps).constant =
        ∑ k ∈ Finset.range steps,
          (transform.linear ^ k) transform.constant
  | 0 => by
      simp [iterate, CPAffine.one]
  | steps + 1 => by
      rw [iterate, CPAffine.comp, constant_iterate transform steps,
        Finset.sum_range_succ']
      simp only [pow_zero, AddMonoid.End.one_apply]
      rw [map_sum]
      simp_rw [_root_.pow_succ']
      rfl

/-- Evaluate an affine iterate as a linear power plus its translated constant
sum. -/
lemma iterate_add_sum
    (transform : CPAffine)
    (steps : ℕ)
    (source : Multiset (CWord Atom)) :
    (iterate transform steps).apply source =
      (transform.linear ^ steps) source +
        ∑ k ∈ Finset.range steps,
          (transform.linear ^ k) transform.constant := by
  rw [CPAffine.apply, linear_iterate, constant_iterate]

/-- Nilpotence at one cutoff forces every later power to vanish as well. -/
lemma pow_zero_cutoff
    (strict : ProfileEnd)
    {cutoff steps : ℕ}
    (hstrict : strict ^ cutoff = 0)
    (hsteps : cutoff ≤ steps) :
    strict ^ steps = 0 := by
  obtain ⟨extra, rfl⟩ := Nat.exists_eq_add_of_le hsteps
  rw [pow_add, hstrict, zero_mul]

/--
The unipotent linear part of a compiled fixed packet has a cutoff-sized
binomial expansion.  Terms beyond `steps` vanish by `Nat.choose`; terms at and
beyond `cutoff` vanish by strict packet nilpotence.
-/
lemma trace_range_cutoff
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom))
    (steps : ℕ) :
    (ofTrace cutoff isCurrent packet).linear ^ steps =
      ∑ k ∈ Finset.range cutoff,
        (packetCorrectionEnd cutoff isCurrent packet) ^ k *
          (steps.choose k : ProfileEnd) := by
  rw [trace_linear_end]
  rw [(Commute.one_right
    (packetCorrectionEnd cutoff isCurrent packet)).add_pow steps]
  simp only [one_pow, mul_one]
  let strict := packetCorrectionEnd cutoff isCurrent packet
  have hstrict : strict ^ cutoff = 0 :=
    packet_end_zero
      cutoff hcutoff isCurrent packet
  rcases le_total cutoff (steps + 1) with hcutoffSteps | hstepsCutoff
  · symm
    apply Finset.sum_subset (Finset.range_mono hcutoffSteps)
    intro k _hkLarge hkNotSmall
    have hkCutoff : cutoff ≤ k := by
      simpa only [Finset.mem_range, not_lt] using hkNotSmall
    rw [pow_zero_cutoff strict hstrict hkCutoff, zero_mul]
  · apply Finset.sum_subset (Finset.range_mono hstepsCutoff)
    intro k _hkLarge hkNotSmall
    have hstepsLt : steps < k := by
      have : steps + 1 ≤ k := by
        simpa only [Finset.mem_range, not_lt] using hkNotSmall
      omega
    rw [Nat.choose_eq_zero_of_lt hstepsLt, Nat.cast_zero, mul_zero]

/--
The routed profile of a repeated fixed packet is an explicit affine geometric
sum whose linear powers each have a cutoff-sized binomial expansion.
-/
lemma iterate_geometric_sum
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom))
    (steps : ℕ)
    (source : Multiset (CWord Atom)) :
    (iterate (ofTrace cutoff isCurrent packet) steps).apply source =
      ((ofTrace cutoff isCurrent packet).linear ^ steps) source +
        ∑ k ∈ Finset.range steps,
          ((ofTrace cutoff isCurrent packet).linear ^ k)
            (ofTrace cutoff isCurrent packet).constant :=
  iterate_add_sum
    (ofTrace cutoff isCurrent packet) steps source

end AIBinom
end TCTex
end Submission

-- Merged from JacobiIntegralPowerStrictTailCutoffAffineRoutePolynomial.lean

/-!
# Polynomial iteration of fixed Hall-Witt cutoff-routing packets

Compile one fixed stable-routing packet to an affine cutoff-profile action.
Its linear part is `1 + N`, where `N ^ cutoff = 0`.  Iteration from zero has
the finite Newton-binomial expansion

`Σ k < cutoff, choose steps (k + 1) • N^k(constant)`.

Consequently, every retained formal slot multiplicity is represented by an
explicit rational Newton-basis polynomial with integer values on natural
inputs and degree at most the cutoff.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace ARPoly

open WSTrace
open TBProf
open ARProfa
open ARProfa.CPAffine
open ARUnipot

/-- The linear action of a fixed packet has a cutoff-truncated binomial
expansion on every input profile. -/
lemma linear_range_cutoff
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom))
    (steps : ℕ)
    (source : Multiset (CWord Atom)) :
    ((ofTrace cutoff isCurrent packet).linear ^ steps) source =
      ∑ k ∈ Finset.range cutoff,
        steps.choose k •
          ((packetCorrectionEnd cutoff isCurrent packet) ^ k) source := by
  rw [trace_linear_end]
  rw [(Commute.one_right
    (packetCorrectionEnd cutoff isCurrent packet)).add_pow steps]
  rw [end_sum_apply]
  simp_rw [one_pow, mul_one, end_nat_cast]
  rcases le_total cutoff (steps + 1) with hcutoffSteps | hstepsCutoff
  · symm
    apply Finset.sum_subset (Finset.range_mono hcutoffSteps)
    intro k _hkLarge hkNotSmall
    have hkCutoff : cutoff ≤ k := by
      simpa only [Finset.mem_range, not_lt] using hkNotSmall
    have hpow :
        (packetCorrectionEnd cutoff isCurrent packet) ^ k = 0 :=
      pow_eq_zero_of_le hkCutoff
        (packet_end_zero
          cutoff hcutoff isCurrent packet)
    simp [hpow]
  · apply Finset.sum_subset (Finset.range_mono hstepsCutoff)
    intro k _hkLarge hkNotSmall
    have hstepsLt : steps < k := by
      have : steps + 1 ≤ k := by
        simpa only [Finset.mem_range, not_lt] using hkNotSmall
      omega
    simp [Nat.choose_eq_zero_of_lt hstepsLt]

/-- Iterating an affine action from zero is its finite geometric sum applied
to the affine constant. -/
lemma iterate_geom_sum
    (transform : CPAffine) :
    ∀ steps : ℕ,
      (iterate transform steps).apply 0 =
        (∑ j ∈ Finset.range steps, transform.linear ^ j)
          transform.constant
  | 0 => by
      simp [apply_iterate_zero]
  | steps + 1 => by
      rw [apply_iterate_succ, iterate_geom_sum transform steps]
      unfold CPAffine.apply
      rw [geom_sum_succ]
      rfl

/-- Hockey-stick identity in the exact range form used by affine packet
iteration. -/
lemma sum_range_choose
    (steps k : ℕ) :
    ∑ j ∈ Finset.range steps, j.choose k =
      steps.choose (k + 1) := by
  induction steps with
  | zero =>
      simp
  | succ steps ih =>
      rw [Finset.sum_range_succ, ih, Nat.choose_succ_succ']
      simp [Nat.add_comm]

/--
Iterating one fixed compiled packet from zero has an explicit
cutoff-truncated Newton-binomial profile.
-/
lemma iterate_range_cutoff
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom))
    (steps : ℕ) :
    (iterate (ofTrace cutoff isCurrent packet) steps).apply 0 =
      ∑ k ∈ Finset.range cutoff,
        steps.choose (k + 1) •
          ((packetCorrectionEnd cutoff isCurrent packet) ^ k)
            (ofTrace cutoff isCurrent packet).constant := by
  rw [iterate_geom_sum, end_sum_apply]
  simp_rw [linear_range_cutoff
    cutoff hcutoff isCurrent packet]
  rw [Finset.sum_comm]
  apply Finset.sum_congr rfl
  intro k _hk
  rw [← Finset.sum_smul, sum_range_choose]

/-- One retained slot multiplicity after iterating a compiled fixed packet. -/
def repeatedPacketMultiplicity
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom))
    (slot : CWord Atom)
    (steps : ℕ) :
    ℤ :=
  Multiset.count slot
    ((iterate (ofTrace cutoff isCurrent packet) steps).apply 0)

/-- Scalar fixed-slot form of the affine packet binomial profile. -/
lemma repeated_slot_cutoff
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom))
    (slot : CWord Atom)
    (steps : ℕ) :
    repeatedPacketMultiplicity cutoff isCurrent packet slot steps =
      ∑ k ∈ Finset.range cutoff,
        (steps.choose (k + 1) *
          Multiset.count slot
            (((packetCorrectionEnd cutoff isCurrent packet) ^ k)
              (ofTrace cutoff isCurrent packet).constant) : ℕ) := by
  have hprofile :=
    congrArg (Multiset.count slot)
      (iterate_range_cutoff
        cutoff hcutoff isCurrent packet steps)
  rw [count_finset_sum] at hprofile
  have hprofile' :
      Multiset.count slot
          ((iterate (ofTrace cutoff isCurrent packet) steps).apply 0) =
        ∑ k ∈ Finset.range cutoff,
          steps.choose (k + 1) *
            Multiset.count slot
              (((packetCorrectionEnd cutoff isCurrent packet) ^ k)
                (ofTrace cutoff isCurrent packet).constant) := by
    simpa [Multiset.count_nsmul] using hprofile
  unfold repeatedPacketMultiplicity
  exact_mod_cast hprofile'

/-- Explicit rational Newton polynomial for one retained fixed-packet slot. -/
noncomputable def repeatedSlotMultiplicity
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom))
    (slot : CWord Atom) :
    Polynomial ℚ :=
  ∑ k ∈ Finset.range cutoff,
    Polynomial.C
        (Multiset.count slot
          (((packetCorrectionEnd cutoff isCurrent packet) ^ k)
            (ofTrace cutoff isCurrent packet).constant) : ℚ) *
      natChoosePolynomial (k + 1)

/-- The explicit fixed-packet slot polynomial has degree at most cutoff. -/
lemma repeated_slot_multiplicity
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom))
    (slot : CWord Atom) :
    (repeatedSlotMultiplicity
      cutoff isCurrent packet slot).natDegree ≤ cutoff := by
  unfold repeatedSlotMultiplicity
  apply Polynomial.natDegree_sum_le_of_forall_le
  intro k hk
  have hkLt : k < cutoff := Finset.mem_range.mp hk
  exact Polynomial.natDegree_mul_le.trans
    (by
      calc
        (Polynomial.C
              (Multiset.count slot
                (((packetCorrectionEnd cutoff isCurrent packet) ^ k)
                  (ofTrace cutoff isCurrent packet).constant) : ℚ)).natDegree +
              (natChoosePolynomial (k + 1)).natDegree ≤
            0 + (k + 1) := by
              gcongr
              · simp
              · exact degree_choose_polynomial (k + 1)
        _ ≤ cutoff := by omega)

/-- The explicit rational fixed-packet slot polynomial evaluates to the
literal iterated multiplicity on every natural input. -/
lemma repeated_packet_slot
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom))
    (slot : CWord Atom)
    (steps : ℕ) :
    (repeatedSlotMultiplicity cutoff isCurrent packet slot).eval
        (steps : ℚ) =
      (repeatedPacketMultiplicity cutoff isCurrent packet slot steps :
        ℚ) := by
  rw [repeatedSlotMultiplicity, Polynomial.eval_finsetSum]
  simp_rw [Polynomial.eval_mul, Polynomial.eval_C, eval_nat_choose]
  rw [repeated_slot_cutoff
    cutoff hcutoff isCurrent packet slot steps]
  norm_cast
  simp [Nat.mul_comm]

/--
Every retained slot multiplicity produced by repeatedly routing one fixed
packet is an integer-valued polynomial of cutoff-bounded degree.
-/
lemma repeated_valued_most
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom))
    (slot : CWord Atom) :
    IVMost
      (repeatedPacketMultiplicity cutoff isCurrent packet slot)
      cutoff := by
  exact
    ⟨repeatedSlotMultiplicity cutoff isCurrent packet slot,
      repeated_slot_multiplicity
        cutoff isCurrent packet slot,
      repeated_packet_slot
        cutoff hcutoff isCurrent packet slot⟩

end ARPoly
end TCTex
