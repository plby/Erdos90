            coefficient)) : ℤ) := by
  cases coefficient with
  | ofNat multiplicity =>
      simp only [ISExp.eval,
        strictSlotExpansion,
        PSTail.strictTrace]
      rw [natural_strict_slot cutoff hcutoff slot]
  | negSucc multiplicity =>
      simp only [ISExp.eval,
        strictSlotExpansion,
        PSTail.strictTrace]
      rw [negative_strict_slot cutoff hcutoff slot]

