-- Merged from JacobiIntegralPowerStrictTailCutoffAffineSecondRouteFilter.lean

/-!
# Filtering coefficient-dependent Hall-Witt second routes

The second Hall-Witt route receives the literal first-pass output, whose
ordered trace depends on the multiplicity.  Modulo one cutoff above weight
three, only its below-cutoff source words matter:

* every selected second-family current word has weight three and survives;
* every discarded unselected word contributes the identity affine action,
  because its retained singleton profile is filtered out.

Thus the remaining ordered second-route problem may be studied over lists
drawn from the fixed finite cutoff vocabulary.  This does not forget order;
it removes exactly the high-weight occurrences that cannot affect the
cutoff-profile compiler.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace ASFilt

open WSTrace
open NPTail
open STVocabu
open RMRecb
open TBProf
open ARProfa
open ARProfa.CPAffine
open ARProf

/-- A singleton at or above the cutoff has zero retained profile. -/
lemma cutoff_profile_singleton
    (cutoff : ℕ)
    (word : CWord Atom)
    (hweight : cutoff ≤ word.weight (fun _ => 1)) :
    cutoffProfile cutoff [word] = 0 := by
  unfold cutoffProfile unitBelowTrace
  simp [show ¬word.weight (fun _ => 1) < cutoff by omega]

/-- Retaining an unselected singleton at or above the cutoff is the affine
identity. -/
lemma retained_one_weight
    (cutoff : ℕ)
    (word : CWord Atom)
    (hweight : cutoff ≤ word.weight (fun _ => 1)) :
    retained cutoff word = CPAffine.one := by
  unfold retained CPAffine.one
  rw [cutoff_profile_singleton cutoff word hweight]

/--
If every selected source word lies below the cutoff, the affine compiler may
filter its source trace by unit weight before compiling.
-/
lemma trace_below_cutoff
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool) :
    ∀ source : List (CWord Atom),
      (∀ word ∈ source,
        isCurrent word = true →
          word.weight (fun _ => 1) < cutoff) →
        ofTrace cutoff isCurrent (unitBelowTrace cutoff source) =
          ofTrace cutoff isCurrent source
  | [], _hsource => by
      rfl
  | word :: words, hsource => by
      have htail :
          ∀ next ∈ words,
            isCurrent next = true →
              next.weight (fun _ => 1) < cutoff := by
        intro next hnext hcurrent
        exact hsource next (by simp [hnext]) hcurrent
      by_cases hweight : word.weight (fun _ => 1) < cutoff
      · have ih :=
          trace_below_cutoff cutoff isCurrent words htail
        unfold unitBelowTrace at ih
        simp only [unitBelowTrace, List.filter_cons, decide_eq_true_eq,
          if_pos hweight, ofTrace]
        rw [ih]
      · have hnotCurrent : isCurrent word ≠ true := by
          intro hcurrent
          exact hweight (hsource word (by simp) hcurrent)
        have hweightLe : cutoff ≤ word.weight (fun _ => 1) :=
          Nat.le_of_not_gt hweight
        have ih :=
          trace_below_cutoff cutoff isCurrent words htail
        unfold unitBelowTrace at ih
        simp only [unitBelowTrace, List.filter_cons, decide_eq_true_eq,
          if_neg hweight, ofTrace, hnotCurrent]
        rw [ih, retained_one_weight cutoff word hweightLe]
        simp

/-- Above weight three, the second-family compiler may filter every literal
source trace before compilation. -/
lemma second_current_below
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (source : List (CWord Atom)) :
    ofTrace cutoff isSecondCurrent (unitBelowTrace cutoff source) =
      ofTrace cutoff isSecondCurrent source := by
  apply trace_below_cutoff
  intro word _hword hcurrent
  rw [second_current_true word hcurrent]
  exact hcutoff

/-- Every cutoff-filtered source trace is drawn from the fixed finite cutoff
vocabulary. -/
lemma ordered_vocabulary_below
    (cutoff : ℕ)
    (source : List (CWord Atom))
    (word : CWord Atom)
    (hword : word ∈ unitBelowTrace cutoff source) :
    word ∈ orderedCutoffVocabulary cutoff := by
  apply (ordered_cutoff_vocabulary cutoff word).2
  apply cutoff_vocabulary_weight
  unfold unitBelowTrace at hword
  exact Nat.le_of_lt (of_decide_eq_true (List.mem_filter.mp hword).2)

/-- The positive strict-tail cutoff profile is computed by compiling only the
finite-vocabulary part of its literal first-pass source. -/
lemma natural_filtered_route
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (multiplicity : ℕ) :
    cutoffProfile cutoff
        (NPTail.strictTrace multiplicity) =
      (ofTrace cutoff isSecondCurrent
        (unitBelowTrace cutoff
          (NPTail.firstRouted multiplicity).1)).apply
            0 := by
  rw [cutoff_natural_strict]
  rw [second_current_below cutoff hcutoff]

/-- The negative strict-tail cutoff profile is computed by compiling only the
finite-vocabulary part of its literal first-pass source. -/
lemma filtered_second_route
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (multiplicity : ℕ) :
    cutoffProfile cutoff
        (NNPower.strictTrace
          multiplicity) =
      (ofTrace cutoff isSecondCurrent
        (unitBelowTrace cutoff
          (NNPower.firstRouted
            multiplicity).1)).apply 0 := by
  rw [cutoff_negative_strict]
  rw [second_current_below cutoff hcutoff]

end ASFilt
end TCTex
end Submission

-- Merged from JacobiIntegralPowerStrictTailCutoffOrderedFirstRouteProgram.lean

/-!
# Ordered cutoff programs for Hall-Witt first routes

The multiset cutoff profile of the first Hall-Witt route has polynomial slot
coordinates, but the second route still needs the literal order of the first
output.  Record that order in a small recursive program:

* an empty output;
* one retained unselected word before the remaining output;
* one selected first-family word moved across the remaining output.

The trace of the program is filtered below cutoff at every constructor.  It is
exactly the cutoff-filtered literal first-routing trace.  Prefixing a repeated
fixed packet is iteration of one fixed program operation, so the positive and
negative Hall-Witt first routes each become three explicit iterated program
blocks.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace OFProgra

open CWTrace
open WSTrace
open WHNorm
open WNTrace
open WSTail
open NPTail
open STVocabu
open RMRecb
open TBProf
open ARProfa
open ARProfa.CPAffine
open ASFilt

/-- Filtering below cutoff is idempotent. -/
@[simp]
lemma unit_below_idem
    (cutoff : ℕ)
    (source : List (CWord Atom)) :
    unitBelowTrace cutoff (unitBelowTrace cutoff source) =
      unitBelowTrace cutoff source := by
  simp [unitBelowTrace]

/-- Filtering below cutoff distributes over concatenation. -/
lemma unit_below_append
    (cutoff : ℕ)
    (left right : List (CWord Atom)) :
    unitBelowTrace cutoff (left ++ right) =
      unitBelowTrace cutoff left ++ unitBelowTrace cutoff right := by
  simp [unitBelowTrace]

/--
Discarded rights and their corrections remain discarded after one first-route
move, so a move may first filter its routed suffix.
-/
lemma unit_move_higher
    (cutoff : ℕ)
    (left : CWord Atom) :
    ∀ rights : List (CWord Atom),
      unitBelowTrace cutoff (moveHigherTrace left rights) =
        unitBelowTrace cutoff
          (moveHigherTrace left (unitBelowTrace cutoff rights))
  | [] => by
      rfl
  | right :: rights => by
      have ih :=
        unit_move_higher
          cutoff left rights
      unfold unitBelowTrace at ih
      by_cases hright : right.weight (fun _ => 1) < cutoff
      · have hrightDecide :
            decide (right.weight (fun _ => 1) < cutoff) = true := by
          simp [hright]
        simp only [unitBelowTrace, moveHigherTrace,
          List.filter_cons, hrightDecide, if_true]
        rw [ih]
      · have hcorrection :
            ¬(.commutator left right : CWord Atom).weight
                (fun _ => 1) < cutoff := by
          simp only [CWord.weight_commutator]
          omega
        have hrightDecide :
            decide (right.weight (fun _ => 1) < cutoff) = false := by
          simp [hright]
        have hcorrectionDecide :
            decide ((.commutator left right : CWord Atom).weight
              (fun _ => 1) < cutoff) = false := by
          exact decide_eq_false_iff_not.mpr hcorrection
        simp only [unitBelowTrace, moveHigherTrace,
          List.filter_cons, hrightDecide, hcorrectionDecide]
        exact ih

/-- Recursive ordered program for one cutoff-filtered first-route output. -/
inductive FRProgra where
  | empty
  | retained
      (word : CWord Atom)
      (tail : FRProgra)
  | moved
      (left : CWord Atom)
      (tail : FRProgra)

namespace FRProgra

/-- Literal ordered cutoff trace emitted by a first-route program. -/
def trace
    (cutoff : ℕ) :
    FRProgra → List (CWord Atom)
  | .empty =>
      []
  | .retained word tail =>
      unitBelowTrace cutoff [word] ++ tail.trace cutoff
  | .moved left tail =>
      unitBelowTrace cutoff
        (moveHigherTrace left (tail.trace cutoff))

@[simp]
lemma trace_empty
    (cutoff : ℕ) :
    FRProgra.empty.trace cutoff = [] := by
  rfl

@[simp]
lemma trace_retained
    (cutoff : ℕ)
    (word : CWord Atom)
    (tail : FRProgra) :
    (FRProgra.retained word tail).trace cutoff =
      unitBelowTrace cutoff [word] ++ tail.trace cutoff := by
  rfl

@[simp]
lemma trace_moved
    (cutoff : ℕ)
    (left : CWord Atom)
    (tail : FRProgra) :
    (FRProgra.moved left tail).trace cutoff =
      unitBelowTrace cutoff
        (moveHigherTrace left (tail.trace cutoff)) := by
  rfl

/-- Every emitted program trace is already filtered below cutoff. -/
@[simp]
lemma unit_below_trace
    (cutoff : ℕ) :
    ∀ program : FRProgra,
      unitBelowTrace cutoff (program.trace cutoff) =
        program.trace cutoff
  | .empty => by
      rfl
  | .retained word tail => by
      rw [trace_retained, unit_below_append,
        unit_below_idem, unit_below_trace cutoff tail]
  | .moved left tail => by
      rw [trace_moved, unit_below_idem]

/--
Prefix one source trace onto an existing first-route program.  The recursion is
the literal right-to-left stable-routing recursion.
-/
def prepend
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool) :
    List (CWord Atom) → FRProgra → FRProgra
  | [], tail =>
      tail
  | word :: words, tail =>
      let routed := prepend cutoff isCurrent words tail
      if isCurrent word = true then
        .moved word routed
      else
        .retained word routed

/-- Program prefixing composes across source concatenation. -/
lemma prepend_append
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (left right : List (CWord Atom))
    (tail : FRProgra) :
    prepend cutoff isCurrent (left ++ right) tail =
      prepend cutoff isCurrent left (prepend cutoff isCurrent right tail) := by
  induction left with
  | nil =>
      rfl
  | cons word left ih =>
      simp only [List.cons_append, prepend]
      rw [ih]

/--
The trace of a prefixed program is the filtered literal route of that prefix
onto the existing program trace.
-/
lemma trace_prepend
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (source : List (CWord Atom))
    (tail : FRProgra) :
    (prepend cutoff isCurrent source tail).trace cutoff =
      unitBelowTrace cutoff
        (routeOnto isCurrent source (tail.trace cutoff)) := by
  induction source with
  | nil =>
      exact (unit_below_trace cutoff tail).symm
  | cons word words ih =>
      by_cases hcurrent : isCurrent word = true
      · rw [prepend, routeOnto, if_pos hcurrent, trace_moved, ih]
        simp only [if_pos hcurrent]
        exact
          (unit_move_higher
            cutoff word _).symm
      · rw [prepend, routeOnto, if_neg hcurrent, trace_retained, ih,
          ← unit_below_append]
        simp only [if_neg hcurrent]
        rfl

/-- Program generated by routing one source trace onto the empty suffix. -/
def ofSource
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (source : List (CWord Atom)) :
    FRProgra :=
  prepend cutoff isCurrent source .empty

/-- The generated program emits the filtered literal first-route trace. -/
lemma trace_ofSource
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (source : List (CWord Atom)) :
    (ofSource cutoff isCurrent source).trace cutoff =
      unitBelowTrace cutoff (routeOnto isCurrent source []) := by
  rw [ofSource, trace_prepend]
  rfl

/-- Every generated program occurrence belongs to the fixed cutoff vocabulary. -/
lemma ordered_vocabulary_trace
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (source : List (CWord Atom))
    (word : CWord Atom)
    (hword : word ∈ (ofSource cutoff isCurrent source).trace cutoff) :
    word ∈ orderedCutoffVocabulary cutoff := by
  rw [trace_ofSource] at hword
  exact
    ordered_vocabulary_below
      cutoff (routeOnto isCurrent source []) word hword

/-- Iterate prefixing by one fixed source packet. -/
def iteratePrepend
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom)) :
    ℕ → FRProgra → FRProgra
  | 0, tail =>
      tail
  | steps + 1, tail =>
      prepend cutoff isCurrent packet
        (iteratePrepend cutoff isCurrent packet steps tail)

/-- Prefixing a repeated packet is iteration of its one-packet program action. -/
lemma prepend_repeatTrace
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom))
    (tail : FRProgra) :
    ∀ steps : ℕ,
      prepend cutoff isCurrent (repeatTrace steps packet) tail =
        iteratePrepend cutoff isCurrent packet steps tail
  | 0 => by
      rfl
  | steps + 1 => by
      rw [repeatTrace, prepend_append,
        prepend_repeatTrace cutoff isCurrent packet tail steps]
      rfl

/-- Compile the literal ordered program trace for the second routing pass. -/
def secondAffine
    (cutoff : ℕ)
    (program : FRProgra) :
    CPAffine :=
  ofTrace cutoff isSecondCurrent (program.trace cutoff)

end FRProgra

open FRProgra

/-- Positive Hall-Witt first routing as an ordered cutoff program. -/
def naturalRouteProgram
    (cutoff multiplicity : ℕ) :
    FRProgra :=
  FRProgra.ofSource cutoff isFirstCurrent
    (NPTail.naturalResidualTrace multiplicity)

/-- The positive program emits exactly the filtered literal first-pass trace. -/
lemma natural_route_program
    (cutoff multiplicity : ℕ) :
    (naturalRouteProgram cutoff multiplicity).trace cutoff =
      unitBelowTrace cutoff
        (NPTail.firstRouted multiplicity).1 := by
  rw [naturalRouteProgram, FRProgra.trace_ofSource,
    NPTail.firstRouted,
    stable_fst_nil]

/-- The positive first-route program is three iterated fixed packet prefixes. -/
lemma natural_iterate_prepend
    (cutoff multiplicity : ℕ) :
    naturalRouteProgram cutoff multiplicity =
      iteratePrepend cutoff isFirstCurrent WNTrace.trace
        multiplicity
        (iteratePrepend cutoff isFirstCurrent [firstConventionalWord]
          multiplicity
          (iteratePrepend cutoff isFirstCurrent
            [secondConventionalInverse] multiplicity .empty)) := by
  rw [naturalRouteProgram, FRProgra.ofSource,
    NPTail.naturalResidualTrace,
    prepend_append, prepend_append,
    ← repeatTrace_singleton firstConventionalWord multiplicity,
    ← repeatTrace_singleton secondConventionalInverse multiplicity,
    prepend_repeatTrace, prepend_repeatTrace, prepend_repeatTrace]

/-- The positive strict-tail profile is the second-pass affine action of its
ordered first-route program. -/
lemma natural_second_affine
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (multiplicity : ℕ) :
    cutoffProfile cutoff
        (NPTail.strictTrace multiplicity) =
      ((naturalRouteProgram cutoff multiplicity).secondAffine cutoff).apply
        0 := by
  rw [natural_filtered_route
      cutoff hcutoff multiplicity,
    FRProgra.secondAffine, natural_route_program]

/-- Negative Hall-Witt first routing as an ordered cutoff program. -/
def negativeRouteProgram
    (cutoff multiplicity : ℕ) :
    FRProgra :=
  FRProgra.ofSource cutoff isFirstCurrent
    (NNPower.naturalResidualTrace
      multiplicity)

/-- The negative program emits exactly the filtered literal first-pass trace. -/
lemma negative_route_program
    (cutoff multiplicity : ℕ) :
    (negativeRouteProgram cutoff multiplicity).trace cutoff =
      unitBelowTrace cutoff
        (NNPower.firstRouted
          multiplicity).1 := by
  rw [negativeRouteProgram, FRProgra.trace_ofSource,
    NNPower.firstRouted,
    stable_fst_nil]

/-- The negative first-route program is three iterated fixed packet prefixes. -/
lemma negative_iterate_prepend
    (cutoff multiplicity : ℕ) :
    negativeRouteProgram cutoff multiplicity =
      iteratePrepend cutoff isFirstCurrent
        NNPower.inverseNormalizedTrace
        multiplicity
        (iteratePrepend cutoff isFirstCurrent [firstConventionalInverse]
          multiplicity
          (iteratePrepend cutoff isFirstCurrent [secondConventionalWord]
            multiplicity .empty)) := by
  rw [negativeRouteProgram, FRProgra.ofSource,
    NNPower.naturalResidualTrace,
    prepend_append, prepend_append,
    ← repeatTrace_singleton firstConventionalInverse multiplicity,
    ← repeatTrace_singleton secondConventionalWord multiplicity,
    prepend_repeatTrace, prepend_repeatTrace, prepend_repeatTrace]

/-- The negative strict-tail profile is the second-pass affine action of its
ordered first-route program. -/
lemma negative_second_affine
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (multiplicity : ℕ) :
    cutoffProfile cutoff
        (NNPower.strictTrace
          multiplicity) =
      ((negativeRouteProgram cutoff multiplicity).secondAffine cutoff).apply
        0 := by
  rw [filtered_second_route
      cutoff hcutoff multiplicity,
    FRProgra.secondAffine, negative_route_program]

end OFProgra
