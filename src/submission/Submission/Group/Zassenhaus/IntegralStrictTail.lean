open DSRec
open BSRec
open BSPoly
open ASTri
open ASDecomp
open DSReca
open BDSubseq

/-- Fixed number of active source-depth selections that emit one requested
retained transition word. -/
def activeSubsequenceCoefficient
    (cutoff : ℕ)
    (selected right : CWord Atom)
    (source : List ℕ)
    (target : List SRTrans) :
    ℕ :=
  (activeSubsequenceExpansions
    (strictTransitionPacket cutoff selected right)
      source).count target

/-- An active source-depth word longer than the target transition word has
zero retained-subsequence coefficient. -/
lemma subsequence_coefficient_length
    (cutoff : ℕ)
    (selected right : CWord Atom)
    (source : List ℕ)
    (target : List SRTrans)
    (hlength : target.length < source.length) :
    activeSubsequenceCoefficient
        cutoff selected right source target =
      0 := by
  apply List.count_eq_zero.mpr
  intro htarget
  have :=
    length_subsequence_expansions
      (strictTransitionPacket cutoff selected right)
        source target htarget
  omega

/-- Retained transition-subword multiplicity is a finite fixed-coefficient
sum of bounded source-depth subword multiplicities. -/
