            Nat.succ_le_iff.mpr hsuffixPos
          have htrace :
              trace.length ≤ suffix.length * trace.length := by
            simpa [Nat.mul_comm] using
              Nat.mul_le_mul_right trace.length hone
          have hprefixLe :
              (target.take (target.length - suffix.length)).length +
                  suffix.length =
                target.length := by
            rw [htakeLength, Nat.sub_add_cancel hsuffixLength]
