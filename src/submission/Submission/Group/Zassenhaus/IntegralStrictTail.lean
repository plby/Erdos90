  unfold addressSlotClass
  rw [dif_pos (by omega)]
  apply lower_class_succ
  exact
    Subgroup.lowerCentralSeries_antitone (by omega)
      (CWord.eval_lower_series
        (PEAddres.freeLowerTruncation
          (n := n))
        PEAddres.weight
        PEAddres.weight_pos
        PEAddres.free_truncation_series
