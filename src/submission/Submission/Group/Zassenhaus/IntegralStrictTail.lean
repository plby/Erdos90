        (fun steps : ℕ =>
          (orderedSubsequenceMultiplicity target
            (boundedCrossingSchedule cutoff outer selected
              trace steps) : ℤ)) =
          (fun _steps : ℕ =>
            (orderedSubsequenceMultiplicity target [] : ℤ)) +
            (fun steps : ℕ =>
              ∑ depth ∈ Finset.range steps, increment depth) by
        funext steps
        simp only [Pi.add_apply]
        exact
          subsequence_mult_crossing
            cutoff outer selected trace target steps]
      exact
        (valued_most_const
          (target.length * (cutoff + trace.length + 1) + 1)
            (orderedSubsequenceMultiplicity target [] : ℤ)).add
          hincrement.partialSum
