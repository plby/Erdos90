polynomial of cutoff-bounded degree. -/
lemma homogeneous_valued_most
    (cutoff : ℕ)
    (selected : CWord Atom)
    (hselected :
      NPTail.isFirstCurrent selected = true ∨
        NPTail.isSecondCurrent selected = true)
    (rights : List (CWord Atom))
    (slot : CWord Atom) :
    IVMost
      (homogeneousMoveMultiplicity cutoff selected rights slot)
      cutoff := by
  rw [show
    homogeneousMoveMultiplicity cutoff selected rights slot =
      repeatedMoveMultiplicity cutoff selected rights slot by
        funext steps
        exact
          homogeneous_move_repeated
            cutoff selected rights slot steps]
