      (slot.weight (fun _ => 1) +
        cutoff * ((positiveFilteredPrefix cutoff).length + 1) +
          (tail.trace cutoff).length + 1)
      (fun steps : ℕ =>
        (Multiset.count slot
          ((scheduleAffine cutoff
            (((iteratePrepend cutoff isFirstCurrent
              WNTrace.trace steps tail).trace cutoff).map
                (SRTrans.crossed
                  firstConventionalInverse))).apply 0) : ℤ)) := by
  rw [←
    affine_endpoint_expansion
      cutoff hcutoff tail slot]
