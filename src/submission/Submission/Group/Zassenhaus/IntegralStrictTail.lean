/-!
# Atomic depth-packet decomposition of signed endpoint count states

The remaining signed endpoint kernel can be compiled entirely from fixed
transition packets.  Ordinary outer crossings are folds over bounded
outer-depth words.  Orbit prefixes are folds over a finite range and their
carried trace.  The nested successor-skew block is a fold over bounded inner
depths whose entries are ordinary outer-depth folds.

This file exposes that atomic finite-state normal form and transports the
positive and negative profile-polynomial adapters to it.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace
  CADecomp

open WSTrace
open WHNorm
open WNTrace
open WSTail
open NPTail
open TBProf
open TACompos
open OTSubsti
open OTSched
open BDExp
open DCSched
open STSched
open SCState
open DSRec
open BDRec
open ECSched
open BTRepeat
open PMExp
open FTVector
open CSFold
open ECDecomp
open CSDecomp

/-- Fixed count-state operator emitted by one bounded outer correction
depth. -/
def strictStateOperator
    (cutoff : ℕ)
    (crossed outer right : CWord Atom)
    (depth : ℕ) :
    BoundedCountState → BoundedCountState :=
  boundedStateFold cutoff
    (strictCrossingPacket cutoff crossed outer right depth)

/-- Ordinary crossed count-state operator as a fold of fixed depth-packet
operators over the bounded outer-depth word. -/
def crossingStateOperator
    (cutoff : ℕ)
    (crossed outer right : CWord Atom)
    (steps : ℕ) :
    BoundedCountState → BoundedCountState :=
  fun state =>
    (boundedDepthSchedule cutoff steps).foldr
      (fun depth state =>
        strictStateOperator cutoff crossed outer right
          depth state)
      state

/-- The count-state fold of an ordinary outer crossing schedule is its
bounded depth-packet fold operator. -/
lemma state_fold_operator
    (cutoff : ℕ)
    (crossed outer right : CWord Atom)
    (steps : ℕ)
    (state : BoundedCountState) :
    boundedStateFold cutoff
        (depthCrossingSchedule cutoff crossed outer right steps)
        state =
      crossingStateOperator cutoff crossed outer
        right steps state := by
  unfold crossingStateOperator
    strictStateOperator
  rw [
    crossing_schedule_flat,
    state_fold_flat]

/-- Atomic one-block count-state operator for the nested successor-skew
schedule. -/
def successorAtomicOperator
    (cutoff : ℕ)
    (crossed outer selected right : CWord Atom)
    (steps : ℕ) :
    BoundedCountState → BoundedCountState :=
  fun state =>
    (boundedDepthSchedule cutoff (steps + 1)).foldr
      (fun innerDepth state =>
        crossingStateOperator cutoff crossed
          outer (iteratedLeftCommutator selected innerDepth right) steps state)
      state

/-- The nested successor-skew one-block operator is its atomic two-depth
packet fold. -/
lemma successor_operator_atomic
    (cutoff : ℕ)
    (crossed outer selected right : CWord Atom)
    (steps : ℕ) :
    successorSkewOperator cutoff crossed outer selected
        right steps =
      successorAtomicOperator cutoff crossed outer
        selected right steps := by
  funext state
  unfold successorSkewOperator
    successorAtomicOperator
  simp_rw [
    state_fold_operator]

/-- Atomic count-state operator for a crossed emitted-orbit prefix. -/
def atomicStateOperator
    (cutoff : ℕ)
    (crossed outer : CWord Atom)
    (trace : List (CWord Atom))
    (steps : ℕ) :
    BoundedCountState → BoundedCountState :=
  fun state =>
    (List.range steps).foldr
      (fun depth state =>
        trace.foldr
          (fun right state =>
            crossingStateOperator cutoff crossed
              outer right depth state)
          state)
      state

/-- The count-state fold of a crossed emitted-orbit prefix is its atomic
range, trace, and depth-packet fold operator. -/
lemma state_fold_atomic
    (cutoff : ℕ)
    (crossed outer : CWord Atom)
    (trace : List (CWord Atom))
    (steps : ℕ)
    (state : BoundedCountState) :
    boundedStateFold cutoff
        (boundedCrossingSchedule cutoff crossed outer
          trace steps)
        state =
      atomicStateOperator
        cutoff crossed outer trace steps state := by
  unfold boundedCrossingSchedule
    atomicStateOperator
  rw [state_fold_flat]
  simp_rw [state_fold_flat]
  simp_rw [
    state_fold_operator]

/-- Successor-skew tail count state compiled entirely from fixed atomic
depth-packet folds. -/
def successorAtomicState
    (cutoff : ℕ)
    (crossed outer selected right : CWord Atom)
    (emittedPrefix : List (CWord Atom))
    (steps : ℕ) :
    BoundedCountState :=
  atomicStateOperator cutoff
    crossed outer emittedPrefix steps
      (iterateStateOperator
        (successorAtomicOperator cutoff crossed
          outer selected right steps)
        (boundedCountState []) (steps + 1))

/-- The inner-depth normal form of a successor-skew tail is its atomic
depth-packet compiler. -/
lemma successor_decomposed_atomic
    (cutoff : ℕ)
    (crossed outer selected right : CWord Atom)
    (emittedPrefix : List (CWord Atom))
    (steps : ℕ) :
    successorSkewDecomposed cutoff crossed outer
        selected right emittedPrefix steps =
      successorAtomicState cutoff crossed outer
        selected right emittedPrefix steps := by
  unfold successorSkewDecomposed
    successorAtomicState
  rw [
    successor_operator_atomic,
    state_fold_atomic]

/-- Positive signed tail state in atomic depth-packet form. -/
noncomputable def successorSkewAtomic
    (cutoff : ℕ) :
    BoundedCountState :=
  newtonEvaluationState
    (naturalFullBound cutoff)
    (fun steps =>
      successorAtomicState cutoff
        firstConventionalInverse firstConventionalInverse
          firstConventionalWord secondConventionalInverse
            (positiveFilteredPrefix cutoff) steps)

/-- Negative signed tail state in atomic depth-packet form. -/
noncomputable def skewAtomicState
    (cutoff : ℕ) :
    BoundedCountState :=
  newtonEvaluationState
    (negativeFullBound cutoff)
    (fun steps =>
      successorAtomicState cutoff
        firstConventionalWord firstConventionalWord
          firstConventionalInverse secondConventionalWord
            (negativeFilteredPrefix cutoff) steps)

/-- The positive inner-depth signed state equals its atomic depth-packet
normal form. -/
lemma successor_skew_atomic
    (cutoff : ℕ) :
    successorSkewState cutoff =
      successorSkewAtomic cutoff := by
  unfold successorSkewState
    successorSkewAtomic
  apply congrArg
  funext steps
  exact
    successor_decomposed_atomic cutoff
      firstConventionalInverse firstConventionalInverse
        firstConventionalWord secondConventionalInverse
          (positiveFilteredPrefix cutoff) steps

/-- The negative inner-depth signed state equals its atomic depth-packet
normal form. -/
lemma skew_decomposed_atomic
    (cutoff : ℕ) :
    skewDecomposedState cutoff =
      skewAtomicState cutoff := by
  unfold skewDecomposedState
    skewAtomicState
  apply congrArg
  funext steps
  exact
    successor_decomposed_atomic cutoff
      firstConventionalWord firstConventionalWord firstConventionalInverse
        secondConventionalWord (negativeFilteredPrefix cutoff) steps

/-- Positive endpoint cancellation expressed against the atomic depth-packet
signed successor-skew tail state. -/
def NaturalSkewAtomic
    (cutoff : ℕ) :
    Prop :=
  ∀ slot,
    boundedStateSlot cutoff
      (boundedStateFold cutoff
        (positiveFixedPrefix cutoff)
          (successorSkewAtomic cutoff))
      slot = 0

/-- Negative endpoint cancellation expressed against the atomic depth-packet
signed successor-skew tail state. -/
def SuccessorSkewAtomic
    (cutoff : ℕ) :
    Prop :=
  ∀ slot,
    boundedStateSlot cutoff
      (boundedStateFold cutoff
        (negativeFixedPrefix cutoff)
          (skewAtomicState cutoff))
      slot = 0

/-- The positive inner-depth prefix kernel is unchanged after compiling to
atomic depth packets. -/
lemma natural_skew_atomic
    (cutoff : ℕ) :
    NaturalSkewDecomposed
        cutoff ↔
      NaturalSkewAtomic
        cutoff := by
  rw [
    NaturalSkewDecomposed,
    NaturalSkewAtomic,
    successor_skew_atomic]

/-- The negative inner-depth prefix kernel is unchanged after compiling to
atomic depth packets. -/
lemma negative_skew_atomic
    (cutoff : ℕ) :
    SuccessorSkewDecomposed
        cutoff ↔
      SuccessorSkewAtomic
        cutoff := by
  rw [
    SuccessorSkewDecomposed,
    SuccessorSkewAtomic,
    skew_decomposed_atomic]

/-- The positive atomic depth-packet prefix-kernel identity discharges global
positive strict-tail cutoff-profile polynomiality. -/
lemma natural_atomic_prefix
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (hkernel :
      NaturalSkewAtomic
        cutoff) :
    CPDataa cutoff
      (naturalStrictBound cutoff)
      (fun multiplicity =>
        cutoffProfile cutoff
          (NPTail.strictTrace multiplicity)) := by
  apply
    natural_inner_prefix
      cutoff hcutoff
  exact
    (natural_skew_atomic cutoff).2
      hkernel

/-- The negative atomic depth-packet prefix-kernel identity discharges global
negative strict-tail cutoff-profile polynomiality. -/
lemma negative_atomic_prefix
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (hkernel :
      SuccessorSkewAtomic
        cutoff) :
    CPDataa cutoff
      (negativeStrictBound cutoff)
      (fun multiplicity =>
        cutoffProfile cutoff
          (NNPower.strictTrace
            multiplicity)) := by
  apply
    negative_inner_prefix
      cutoff hcutoff
  exact
    (negative_skew_atomic cutoff).2
      hkernel

end CADecomp
