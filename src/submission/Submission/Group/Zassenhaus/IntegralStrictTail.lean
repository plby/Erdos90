lemma subsequenceMultPoly
    (cutoff : ℕ)
    (outer selected : CWord Atom)
    (trace : List (CWord Atom)) :
    ∀ target : List SRTrans,
      IVMost
        (fun steps : ℕ =>
          (orderedSubsequenceMultiplicity target
            (boundedCrossingSchedule cutoff outer selected
              trace steps) : ℤ))
        (target.length * (cutoff + trace.length + 1) + 1)
  | target => by
      let increment : ℕ → ℤ :=
        fun steps =>
          ∑ suffix ∈ target.tails.toFinset.erase [],
            (orderedSubsequenceMultiplicity
              (target.take (target.length - suffix.length))
              (boundedCrossingSchedule cutoff outer
                selected trace steps) : ℤ) *
              (orderedSubsequenceMultiplicity suffix
                (trace.flatMap fun right =>
                  depthCrossingSchedule cutoff outer selected right
                    steps) : ℤ)
      have hincrement :
          IVMost increment
            (target.length * (cutoff + trace.length + 1)) := by
        apply IVMost.finsetSum
        intro suffix hsuffix
        have hsuffixData := Finset.mem_erase.mp hsuffix
        have hsuffixNe : suffix ≠ [] := hsuffixData.1
        have hsuffixMem :
            suffix <:+ target :=
          (List.mem_tails suffix target).mp
            (List.mem_toFinset.mp hsuffixData.2)
        have hsuffixPos : 0 < suffix.length := by
          cases suffix with
          | nil =>
              exact False.elim (hsuffixNe rfl)
          | cons head tail =>
              simp
        have hsuffixLength : suffix.length ≤ target.length := by
          rcases hsuffixMem with ⟨initial, htarget⟩
          rw [← htarget, List.length_append]
          omega
        have htakeLength :
            (target.take (target.length - suffix.length)).length =
              target.length - suffix.length := by
          rw [List.length_take, Nat.min_eq_left (Nat.sub_le _ _)]
        have hprefixLength :
