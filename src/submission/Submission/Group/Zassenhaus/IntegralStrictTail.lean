    crossed_middle_schedule
      cutoff hcutoff steps]

/-- Crossing the complete negative first route has polynomial bounded-term
coordinates. -/
lemma crossing_route_program
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff) :
    BCDataa cutoff
      (cutoff *
          (2 * cutoff + (negativeFilteredPrefix cutoff).length + 4) +
        1)
      (fun steps =>
        crossingConstantTerms cutoff firstConventionalWord
          ((negativeRouteProgram cutoff steps).trace cutoff)) := by
  apply
    (crossing_middle_schedule
      cutoff firstConventionalWord firstConventionalWord
        firstConventionalInverse secondConventionalWord (by simp)
          (negativeFilteredPrefix cutoff)).congr
