/-!
# Ordered second-route affine programs for Hall-Witt strict tails

The filtered first-route program retains the literal order required by the
second Hall-Witt pass.  Compile that order structurally.  Moving one
first-family word across one retained right word emits the ordered packet

`[commutator left right, right]`.

Its second-pass affine action is a fixed transition.  Moving across a list is
the ordered composition of those transitions.  High-weight rights may be
discarded before this compilation, and the recursive first-route program
compiles exactly to the affine action of its emitted trace.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace SAProgra

open CWTrace
open WSTrace
open NPTail
open RMRecb
open TBProf
open ARProfa
open ARProfa.CPAffine
open ASFilt
open OFProgra
open OFProgra.FRProgra

/-- Affine second-pass transition emitted by crossing one first-family word
over one retained right word. -/
def crossedSecondPacket
    (cutoff : ℕ)
    (left right : CWord Atom) :
    CPAffine :=
  ofTrace cutoff isSecondCurrent
    (unitBelowTrace cutoff [.commutator left right, right])

/-- Ordered affine second-pass action emitted by moving one first-family word
over a retained right trace. -/
def crossedSecondAffine
    (cutoff : ℕ)
    (left : CWord Atom) :
    List (CWord Atom) → CPAffine
  | [] =>
      CPAffine.one
  | right :: rights =>
      (crossedSecondPacket cutoff left right).comp
        (crossedSecondAffine cutoff left rights)

@[simp]
lemma crossed_affine_nil
    (cutoff : ℕ)
    (left : CWord Atom) :
    crossedSecondAffine cutoff left [] =
      CPAffine.one := by
  rfl

@[simp]
lemma crossed_affine_cons
    (cutoff : ℕ)
    (left right : CWord Atom)
    (rights : List (CWord Atom)) :
    crossedSecondAffine cutoff left (right :: rights) =
      (crossedSecondPacket cutoff left right).comp
        (crossedSecondAffine cutoff left rights) := by
  rfl

/-- The ordered crossing compiler is exactly the affine action of the literal
filtered crossing trace. -/
lemma crossed_affine_trace
    (cutoff : ℕ)
    (left : CWord Atom) :
    ∀ rights : List (CWord Atom),
      crossedSecondAffine cutoff left rights =
        ofTrace cutoff isSecondCurrent
          (unitBelowTrace cutoff (moveHigherTrace left rights))
  | [] => by
      rfl
  | right :: rights => by
      rw [crossed_affine_cons,
        show
          moveHigherTrace left (right :: rights) =
            [.commutator left right, right] ++
              moveHigherTrace left rights by
          rfl,
        unit_below_append, ofTrace_append,
        crossed_affine_trace cutoff left rights]
      rfl

/-- Ordered crossing compilation composes across concatenated right traces. -/
lemma crossed_affine_append
    (cutoff : ℕ)
    (left : CWord Atom)
    (rights nextRights : List (CWord Atom)) :
    crossedSecondAffine cutoff left (rights ++ nextRights) =
      (crossedSecondAffine cutoff left rights).comp
        (crossedSecondAffine cutoff left nextRights) := by
  induction rights with
  | nil =>
      exact (one_comp (crossedSecondAffine cutoff left nextRights)).symm
  | cons right rights ih =>
      simp only [List.cons_append, crossed_affine_cons]
      rw [ih, comp_assoc]

/-- The ordered crossing compiler may discard high-weight rights before
compiling. -/
lemma crossed_second_affine
    (cutoff : ℕ)
    (left : CWord Atom)
    (rights : List (CWord Atom)) :
    crossedSecondAffine cutoff left (unitBelowTrace cutoff rights) =
      crossedSecondAffine cutoff left rights := by
  rw [crossed_affine_trace, crossed_affine_trace,
    ←
      unit_move_higher
        cutoff left rights]

/-- A crossing transition over a discarded right word is the affine identity. -/
lemma crossed_second_weight
    (cutoff : ℕ)
    (left right : CWord Atom)
    (hright : cutoff ≤ right.weight (fun _ => 1)) :
    crossedSecondPacket cutoff left right =
      CPAffine.one := by
  have hrightNot :
      ¬right.weight (fun _ => 1) < cutoff := by
    omega
  have hcorrectionNot :
      ¬(.commutator left right : CWord Atom).weight
          (fun _ => 1) < cutoff := by
    simp only [CWord.weight_commutator]
    omega
  have hrightDecide :
      decide (right.weight (fun _ => 1) < cutoff) = false := by
    exact decide_eq_false_iff_not.mpr hrightNot
  have hcorrectionDecide :
      decide ((.commutator left right : CWord Atom).weight
        (fun _ => 1) < cutoff) = false := by
    exact decide_eq_false_iff_not.mpr hcorrectionNot
  simp only [crossedSecondPacket, unitBelowTrace, List.filter_cons,
    hrightDecide, hcorrectionDecide]
  rfl

/-- Structural second-pass affine interpreter for a first-route program. -/
def compileSecond
    (cutoff : ℕ) :
    FRProgra → CPAffine
  | .empty =>
      CPAffine.one
  | .retained word tail =>
      (ofTrace cutoff isSecondCurrent (unitBelowTrace cutoff [word])).comp
        (compileSecond cutoff tail)
  | .moved left tail =>
      crossedSecondAffine cutoff left (tail.trace cutoff)

/-- The structural interpreter is exactly the affine action of the emitted
ordered first-route trace. -/
lemma compile_second_affine
    (cutoff : ℕ) :
    ∀ program : FRProgra,
      compileSecond cutoff program =
        program.secondAffine cutoff
  | .empty => by
      rfl
  | .retained word tail => by
      rw [compileSecond, FRProgra.secondAffine,
        FRProgra.trace_retained, ofTrace_append,
        compile_second_affine cutoff tail,
        FRProgra.secondAffine]
  | .moved left tail => by
      rw [compileSecond, FRProgra.secondAffine,
        FRProgra.trace_moved,
        crossed_affine_trace]

/-- The generated first-route program compiles to the filtered literal
first-route trace without losing its order. -/
lemma compile_second_source
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (source : List (CWord Atom)) :
    compileSecond cutoff (FRProgra.ofSource cutoff isCurrent source) =
      ofTrace cutoff isSecondCurrent
        (unitBelowTrace cutoff (routeOnto isCurrent source [])) := by
  rw [compile_second_affine, FRProgra.secondAffine,
    FRProgra.trace_ofSource]

/-- Positive Hall-Witt strict-tail profiles are evaluated by the structural
ordered second-pass interpreter. -/
lemma natural_compile_second
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (multiplicity : ℕ) :
    cutoffProfile cutoff
        (NPTail.strictTrace multiplicity) =
      (compileSecond cutoff
        (naturalRouteProgram cutoff multiplicity)).apply 0 := by
  rw [natural_second_affine cutoff hcutoff,
    compile_second_affine]

/-- Negative Hall-Witt strict-tail profiles are evaluated by the structural
ordered second-pass interpreter. -/
lemma negative_compile_second
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (multiplicity : ℕ) :
    cutoffProfile cutoff
        (NNPower.strictTrace
          multiplicity) =
      (compileSecond cutoff
        (negativeRouteProgram cutoff multiplicity)).apply 0 := by
  rw [negative_second_affine cutoff hcutoff,
    compile_second_affine]

end SAProgra
end TCTex
end Submission

-- Merged from JacobiIntegralPowerStrictTailCutoffOrderedSecondRouteFiniteTransitionSchedule.lean

/-!
# Finite transition schedules for ordered Hall-Witt second routes

Externalize the structural second-pass interpreter as an ordered transition
schedule.  There are two transition forms:

* retain one below-cutoff first-route word;
* cross one first-family current word over one below-cutoff right word.

Every transition in the positive and negative Hall-Witt schedules belongs to
one fixed finite alphabet depending only on the cutoff.  Folding the affine
interpretation of the schedule recovers the exact strict-tail cutoff profile.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace STSched

open CWTrace
open WSTrace
open WHNorm
open WSTail
open NPTail
open STVocabu
open RMRecb
open TBProf
open ARProfa
open ARProfa.CPAffine
open ASFilt
open OFProgra
open OFProgra.FRProgra
open SAProgra
open SARec

/-- One ordered transition consumed by the second-pass affine interpreter. -/
inductive SRTrans where
  | retained
      (word : CWord Atom)
  | crossed
      (left right : CWord Atom)
deriving DecidableEq

namespace SRTrans

/-- Affine interpretation of one ordered second-route transition. -/
def affine
    (cutoff : ℕ) :
    SRTrans → CPAffine
  | .retained word =>
      secondAtomAffine cutoff word
  | .crossed left right =>
      crossedSecondPacket cutoff left right

end SRTrans

/-- Fold an ordered transition schedule into its affine action. -/
def scheduleAffine
    (cutoff : ℕ) :
    List SRTrans → CPAffine
  | [] =>
      CPAffine.one
  | transition :: transitions =>
      (transition.affine cutoff).comp
        (scheduleAffine cutoff transitions)

/-- Schedule interpretation composes across concatenation. -/
lemma scheduleAffine_append
    (cutoff : ℕ)
    (left right : List SRTrans) :
    scheduleAffine cutoff (left ++ right) =
      (scheduleAffine cutoff left).comp
        (scheduleAffine cutoff right) := by
  induction left with
  | nil =>
      exact (one_comp (scheduleAffine cutoff right)).symm
  | cons transition left ih =>
      simp only [List.cons_append, scheduleAffine]
      rw [ih, comp_assoc]

/-- A schedule of ordinary retained words is the ordinary second-pass affine
compiler. -/
lemma schedule_affine_retained
    (cutoff : ℕ) :
    ∀ words : List (CWord Atom),
      scheduleAffine cutoff (words.map SRTrans.retained) =
        ofTrace cutoff isSecondCurrent words
  | [] => by
      rfl
  | word :: words => by
      rw [List.map_cons, scheduleAffine, schedule_affine_retained,
        second_current_cons]
      rfl

/-- A schedule of crossings is the ordered crossing compiler. -/
lemma schedule_affine_crossed
    (cutoff : ℕ)
    (left : CWord Atom) :
    ∀ rights : List (CWord Atom),
      scheduleAffine cutoff
          (rights.map (SRTrans.crossed left)) =
        crossedSecondAffine cutoff left rights
  | [] => by
      rfl
  | right :: rights => by
      rw [List.map_cons, scheduleAffine, schedule_affine_crossed,
        crossed_affine_cons]
      rfl

/-- Ordered transition schedule extracted from one recursive first-route
program. -/
def transitionSchedule
    (cutoff : ℕ) :
    FRProgra → List SRTrans
  | .empty =>
      []
  | .retained word tail =>
      (unitBelowTrace cutoff [word]).map
          SRTrans.retained ++
        transitionSchedule cutoff tail
  | .moved left tail =>
      (tail.trace cutoff).map (SRTrans.crossed left)

/-- Folding the extracted transition schedule is exactly the structural
second-pass interpreter. -/
lemma schedule_affine_transition
    (cutoff : ℕ) :
    ∀ program : FRProgra,
      scheduleAffine cutoff (transitionSchedule cutoff program) =
        compileSecond cutoff program
  | .empty => by
      rfl
  | .retained word tail => by
      rw [transitionSchedule, scheduleAffine_append,
        schedule_affine_retained,
        schedule_affine_transition cutoff tail]
      rfl
  | .moved left tail => by
      rw [transitionSchedule, schedule_affine_crossed]
      rfl

/-- The two possible first-family current words. -/
def firstCurrentVocabulary :
    List (CWord Atom) :=
  [firstConventionalInverse, firstConventionalWord]

/-- Every recognized first-family current word belongs to its two-word
vocabulary. -/
lemma current_vocabulary_true
    (word : CWord Atom)
    (hword : isFirstCurrent word = true) :
    word ∈ firstCurrentVocabulary := by
  simp only [isFirstCurrent, decide_eq_true_eq] at hword
  simpa [firstCurrentVocabulary] using hword

/-- Fixed finite alphabet of all retained and crossed second-route transitions
that may survive below one cutoff. -/
def secondRouteAlphabet
    (cutoff : ℕ) :
    List SRTrans :=
  (orderedCutoffVocabulary cutoff).map SRTrans.retained ++
    firstCurrentVocabulary.flatMap fun left =>
      (orderedCutoffVocabulary cutoff).map
        (SRTrans.crossed left)

/-- Every below-cutoff retained transition belongs to the fixed transition
alphabet. -/
lemma route_alphabet_retained
    (cutoff : ℕ)
    (word : CWord Atom)
    (hword : word ∈ orderedCutoffVocabulary cutoff) :
    SRTrans.retained word ∈
      secondRouteAlphabet cutoff := by
  apply List.mem_append_left
  exact List.mem_map.mpr ⟨word, hword, rfl⟩

/-- Every first-family crossing over a below-cutoff right word belongs to the
fixed transition alphabet. -/
lemma transition_alphabet_crossed
    (cutoff : ℕ)
    (left right : CWord Atom)
    (hleft : isFirstCurrent left = true)
    (hright : right ∈ orderedCutoffVocabulary cutoff) :
    SRTrans.crossed left right ∈
      secondRouteAlphabet cutoff := by
  apply List.mem_append_right
  apply List.mem_flatMap.mpr
  exact
    ⟨left, current_vocabulary_true left hleft,
      List.mem_map.mpr ⟨right, hright, rfl⟩⟩

/-- A first-route program is well formed when every moved node records a
recognized first-family current word. -/
def FirstCurrentMoves :
    FRProgra → Prop
  | .empty =>
      True
  | .retained _word tail =>
      FirstCurrentMoves tail
  | .moved left tail =>
      isFirstCurrent left = true ∧ FirstCurrentMoves tail

/-- Prefixing with the first-family selector preserves well-formed moved-node
provenance. -/
lemma first_moves_prepend
    (cutoff : ℕ)
    (source : List (CWord Atom))
    (tail : FRProgra)
    (htail : FirstCurrentMoves tail) :
    FirstCurrentMoves (prepend cutoff isFirstCurrent source tail) := by
  induction source with
  | nil =>
      exact htail
  | cons word source ih =>
      simp only [prepend]
      by_cases hword : isFirstCurrent word = true
      · rw [if_pos hword]
        exact ⟨hword, ih⟩
      · rw [if_neg hword]
        exact ih

/-- Every generated first-family program has well-formed moved-node
provenance. -/
lemma first_current_moves
    (cutoff : ℕ)
    (source : List (CWord Atom)) :
    FirstCurrentMoves
      (FRProgra.ofSource cutoff isFirstCurrent source) := by
  exact first_moves_prepend cutoff source .empty trivial

/-- Every occurrence in an arbitrary first-route program trace belongs to the
fixed cutoff word vocabulary. -/
lemma ordered_vocabulary_program
    (cutoff : ℕ)
    (program : FRProgra)
    (word : CWord Atom)
    (hword : word ∈ program.trace cutoff) :
    word ∈ orderedCutoffVocabulary cutoff := by
  apply
    ordered_vocabulary_below
      cutoff (program.trace cutoff) word
  rw [FRProgra.unit_below_trace]
  exact hword

/-- Every transition extracted from a well-formed program belongs to the fixed
finite transition alphabet. -/
lemma transition_alphabet_schedule
    (cutoff : ℕ) :
    ∀ (program : FRProgra),
      FirstCurrentMoves program →
        ∀ transition ∈ transitionSchedule cutoff program,
          transition ∈ secondRouteAlphabet cutoff
  | .empty, _hprogram, transition, htransition => by
      simp [transitionSchedule] at htransition
  | .retained word tail, hprogram, transition, htransition => by
      rw [transitionSchedule, List.mem_append] at htransition
      rcases htransition with htransition | htransition
      · rcases List.mem_map.mp htransition with ⟨retained, hretained, rfl⟩
        apply route_alphabet_retained
        exact
          ordered_vocabulary_below
            cutoff [word] retained hretained
      · exact
          transition_alphabet_schedule
            cutoff tail hprogram transition htransition
  | .moved left tail, hprogram, transition, htransition => by
      rcases hprogram with ⟨hleft, _htail⟩
      rw [transitionSchedule] at htransition
      rcases List.mem_map.mp htransition with ⟨right, hright, rfl⟩
      exact
        transition_alphabet_crossed cutoff left right hleft
          (ordered_vocabulary_program
            cutoff tail right hright)

/-- Every positive Hall-Witt schedule transition belongs to one fixed finite
cutoff alphabet. -/
lemma alphabet_natural_schedule
    (cutoff multiplicity : ℕ)
    (transition : SRTrans)
    (htransition :
      transition ∈
        transitionSchedule cutoff
          (naturalRouteProgram cutoff multiplicity)) :
    transition ∈ secondRouteAlphabet cutoff := by
  exact
    transition_alphabet_schedule
      cutoff (naturalRouteProgram cutoff multiplicity)
        (first_current_moves cutoff
          (NPTail.naturalResidualTrace
            multiplicity))
        transition htransition

/-- Every negative Hall-Witt schedule transition belongs to one fixed finite
cutoff alphabet. -/
lemma alphabet_negative_schedule
    (cutoff multiplicity : ℕ)
    (transition : SRTrans)
    (htransition :
      transition ∈
        transitionSchedule cutoff
          (negativeRouteProgram cutoff multiplicity)) :
    transition ∈ secondRouteAlphabet cutoff := by
  exact
    transition_alphabet_schedule
      cutoff (negativeRouteProgram cutoff multiplicity)
        (first_current_moves cutoff
          (NNPower.naturalResidualTrace
            multiplicity))
        transition htransition

/-- The positive strict-tail cutoff profile is the affine fold of a schedule
over the fixed finite transition alphabet. -/
lemma profile_natural_affine
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (multiplicity : ℕ) :
    cutoffProfile cutoff
        (NPTail.strictTrace multiplicity) =
      (scheduleAffine cutoff
        (transitionSchedule cutoff
          (naturalRouteProgram cutoff multiplicity))).apply 0 := by
  rw [schedule_affine_transition,
    natural_compile_second cutoff hcutoff]

/-- The negative strict-tail cutoff profile is the affine fold of a schedule
over the fixed finite transition alphabet. -/
lemma profile_negative_affine
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (multiplicity : ℕ) :
    cutoffProfile cutoff
        (NNPower.strictTrace
          multiplicity) =
      (scheduleAffine cutoff
        (transitionSchedule cutoff
          (negativeRouteProgram cutoff multiplicity))).apply 0 := by
  rw [schedule_affine_transition,
    negative_compile_second cutoff hcutoff]

end STSched
end TCTex
end Submission

-- Merged from JacobiIntegralPowerStrictTailCutoffOrderedSecondRouteBoundedSubsequenceExpansion.lean

/-!
# Bounded ordered-subsequence expansion for Hall-Witt second routes

The affine fold of a variable ordered second-route schedule cannot be
recovered from transition multiplicities alone: the linear corrections do not
commute.  Expand it without forgetting order.

Every transition has linear part `1 + N`, where `N` is a strict
weight-raising endomorphism.  Applying a schedule fold to zero is therefore a
sum indexed by affine constants together with ordered subsequences of earlier
strict transitions.  Any term containing at least `cutoff` strict transitions
vanishes.  Thus the exact endpoint depends only on bounded ordered
subsequences.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace SSExp

open WSTrace
open NPTail
open RMRecb
open TBProf
open ARProfa
open ARProfa.CPAffine
open ARUnipot
open SARec
open SAProgra
open STSched

namespace TExp

/-- Fixed source packet whose strict linear correction is carried by one
ordered second-route transition. -/
def strictPacket
    (cutoff : ℕ) :
    SRTrans → List (CWord Atom)
  | .retained word =>
      [word]
  | .crossed left right =>
      unitBelowTrace cutoff [.commutator left right, right]

/-- Strict linear correction carried by one ordered second-route transition. -/
def strictLinear
    (cutoff : ℕ)
    (transition : SRTrans) :
    ProfileEnd :=
  packetCorrectionEnd cutoff isSecondCurrent
    (strictPacket cutoff transition)

/-- Every transition linear part is identity plus its strict correction. -/
lemma affine_linear_strict
    (cutoff : ℕ) :
    ∀ transition : SRTrans,
      (transition.affine cutoff).linear =
        strictLinear cutoff transition + 1
  | .retained word => by
      simp only [SRTrans.affine, strictLinear, strictPacket]
      rw [← trace_linear_end
        cutoff isSecondCurrent [word]]
      simp [ofTrace, secondAtomAffine, CPAffine.comp,
        CPAffine.one]
  | .crossed left right => by
      rw [SRTrans.affine, crossedSecondPacket, strictLinear,
        strictPacket,
        trace_linear_end]

/-- Each transition strict correction raises unit weight by at least one. -/
lemma strict_linear_raises
    (cutoff : ℕ)
    (transition : SRTrans) :
    RUWt 1 (strictLinear cutoff transition) :=
  packet_end_raises cutoff isSecondCurrent
    (strictPacket cutoff transition)

/-- Each transition strict correction emits only terms below cutoff. -/
lemma strict_outputs_below
    (cutoff : ℕ)
    (transition : SRTrans) :
    OBCutoff cutoff (strictLinear cutoff transition) :=
  end_outputs_below cutoff isSecondCurrent
    (strictPacket cutoff transition)

end TExp

/-- Ordered product of heterogeneous strict transition corrections. -/
def orderedStrictProduct
    (cutoff : ℕ) :
    List SRTrans → ProfileEnd
  | [] =>
      1
  | transition :: transitions =>
      TExp.strictLinear cutoff transition *
        orderedStrictProduct cutoff transitions

/-- An ordered product of strict transition corrections raises weight by its
number of selected transitions. -/
lemma ordered_raises_length
    (cutoff : ℕ) :
    ∀ transitions : List SRTrans,
      RUWt transitions.length
        (orderedStrictProduct cutoff transitions)
  | [] => by
      simpa [orderedStrictProduct] using RUWt.one
  | transition :: transitions => by
      simpa [orderedStrictProduct, Nat.add_comm] using
        RUWt.mul
          (TExp.strict_linear_raises
            cutoff transition)
          (ordered_raises_length cutoff transitions)

/-- A nonempty ordered strict product emits only below-cutoff terms. -/
lemma outputs_below_cutoff
    (cutoff : ℕ) :
    ∀ transitions : List SRTrans,
      transitions ≠ [] →
        OBCutoff cutoff (orderedStrictProduct cutoff transitions)
  | [], htransitions => by
      exact False.elim (htransitions rfl)
  | transition :: transitions, _htransitions => by
      rw [orderedStrictProduct]
      exact
        OBCutoff.mul_left
          (TExp.strict_outputs_below
            cutoff transition)

/-- Any heterogeneous ordered product containing at least `cutoff` strict
transitions vanishes below a positive cutoff. -/
lemma ordered_strict_length
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (transitions : List SRTrans)
    (htransitions : cutoff ≤ transitions.length) :
    orderedStrictProduct cutoff transitions = 0 := by
  have hnonempty : transitions ≠ [] := by
    intro hnil
    rw [hnil] at htransitions
    simp at htransitions
    omega
  apply AddMonoidHom.ext
  intro source
  apply Multiset.ext.mpr
  intro emitted
  change
    Multiset.count emitted (orderedStrictProduct cutoff transitions source) =
      Multiset.count emitted 0
  rw [Multiset.count_zero]
  apply Multiset.count_eq_zero.mpr
  intro hemitted
  rcases
      ordered_raises_length cutoff transitions
        source emitted hemitted with
    ⟨original, _horiginal, hweight⟩
  have hemittedCutoff :=
    outputs_below_cutoff cutoff transitions hnonempty
      source emitted hemitted
  have horiginalPositive :
      0 < original.weight (fun _ => 1) :=
    CWord.weight_pos (fun _ => 1) (fun _ => by simp) original
  omega

/-- One ordered-subsequence summand in the affine constant expansion. -/
structure OCTerm where
  strictTransitions : List SRTrans
  constant : Multiset (CWord Atom)
deriving DecidableEq

namespace OCTerm

/-- Add one earlier strict transition to an ordered-subsequence summand. -/
def prepend
    (transition : SRTrans)
    (term : OCTerm) :
    OCTerm where
  strictTransitions := transition :: term.strictTransitions
  constant := term.constant

/-- Evaluate one ordered-subsequence summand. -/
def eval
    (cutoff : ℕ)
    (term : OCTerm) :
    Multiset (CWord Atom) :=
  orderedStrictProduct cutoff term.strictTransitions term.constant

/-- An empty strict subsequence leaves its affine constant unchanged. -/
@[simp]
lemma eval_empty
    (cutoff : ℕ)
    (constant : Multiset (CWord Atom)) :
    OCTerm.eval cutoff
        { strictTransitions := [], constant := constant } =
      constant := by
  rfl

/-- Prepending a strict transition applies its correction after the previous
ordered strict product. -/
@[simp]
lemma eval_prepend
    (cutoff : ℕ)
    (transition : SRTrans)
    (term : OCTerm) :
    (term.prepend transition).eval cutoff =
      TExp.strictLinear cutoff transition
        (term.eval cutoff) := by
  rfl

/-- A summand with at least `cutoff` selected strict transitions vanishes. -/
lemma eval_cutoff_length
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (term : OCTerm)
    (hterm : cutoff ≤ term.strictTransitions.length) :
    term.eval cutoff = 0 := by
  rw [eval, ordered_strict_length
    cutoff hcutoff term.strictTransitions hterm]
  rfl

end OCTerm

/--
Ordered affine-constant expansion of a transition schedule.

For a current transition, each existing term contributes once through its
strict correction and once through the identity part of the linear action.
The current affine constant contributes one new empty-subsequence term.
-/
def orderedConstantTerms
    (cutoff : ℕ) :
    List SRTrans → List OCTerm
  | [] =>
      []
  | transition :: transitions =>
      (orderedConstantTerms cutoff transitions).map
          (OCTerm.prepend transition) ++
        orderedConstantTerms cutoff transitions ++
          [{ strictTransitions := []
             constant := (transition.affine cutoff).constant }]

/-- Additive endomorphisms distribute over the evaluated sum of a list. -/
lemma map_sum_list
    (transform : ProfileEnd)
    (sources : List (Multiset (CWord Atom))) :
    transform sources.sum =
      (sources.map transform).sum := by
  induction sources with
  | nil =>
      exact map_zero transform
  | cons source sources ih =>
      simp only [List.sum_cons, List.map_cons, map_add, ih]

/-- The affine fold of an ordered schedule, applied to zero, is exactly the
sum of its ordered-subsequence constant terms. -/
lemma schedule_affine_terms
    (cutoff : ℕ) :
    ∀ transitions : List SRTrans,
      (scheduleAffine cutoff transitions).apply 0 =
        ((orderedConstantTerms cutoff transitions).map
          (OCTerm.eval cutoff)).sum
  | [] => by
      rfl
  | transition :: transitions => by
      rw [scheduleAffine, CPAffine.apply_comp,
        schedule_affine_terms cutoff
          transitions]
      rw [CPAffine.apply,
        TExp.affine_linear_strict]
      change
        (TExp.strictLinear cutoff transition
            (((orderedConstantTerms cutoff transitions).map
              (OCTerm.eval cutoff)).sum) +
          ((orderedConstantTerms cutoff transitions).map
              (OCTerm.eval cutoff)).sum) +
            (transition.affine cutoff).constant =
          _
      rw [map_sum_list]
      simp only [orderedConstantTerms, List.map_append, List.sum_append,
        List.map_cons, List.map_nil, List.sum_cons, List.sum_nil, add_zero,
        OCTerm.eval_empty, List.map_map]
      ac_rfl

/-- Discard all summands whose ordered strict subsequence is already too long
to survive one cutoff. -/
def boundedConstantTerms
    (cutoff : ℕ)
    (transitions : List SRTrans) :
    List OCTerm :=
  (orderedConstantTerms cutoff transitions).filter fun term =>
    decide (term.strictTransitions.length < cutoff)

/-- Filtering away cutoff-long strict subsequences does not change the exact
evaluated sum. -/
lemma constant_terms_bounded
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff) :
    ∀ terms : List OCTerm,
      (terms.map (OCTerm.eval cutoff)).sum =
        ((terms.filter fun term =>
          decide (term.strictTransitions.length < cutoff)).map
            (OCTerm.eval cutoff)).sum
  | [] => by
      rfl
  | term :: terms => by
      by_cases hterm : term.strictTransitions.length < cutoff
      · have htermDecide :
          decide (term.strictTransitions.length < cutoff) = true :=
        decide_eq_true hterm
        simp [htermDecide,
          constant_terms_bounded
            cutoff hcutoff terms]
      · have htermDecide :
          decide (term.strictTransitions.length < cutoff) = false :=
        decide_eq_false_iff_not.mpr hterm
        have htermZero :
            term.eval cutoff = 0 :=
          term.eval_cutoff_length cutoff hcutoff (by omega)
        simp [htermDecide, htermZero,
          constant_terms_bounded
            cutoff hcutoff terms]

/-- Exact cutoff-bounded ordered-subsequence expansion of a variable affine
transition schedule. -/
lemma affine_constant_terms
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (transitions : List SRTrans) :
    (scheduleAffine cutoff transitions).apply 0 =
      ((boundedConstantTerms cutoff transitions).map
        (OCTerm.eval cutoff)).sum := by
  rw [schedule_affine_terms,
    constant_terms_bounded
      cutoff hcutoff]
  rfl

/-- Every retained ordered-subsequence term has length strictly below the
cutoff. -/
lemma length_constant_terms
    (cutoff : ℕ)
    (transitions : List SRTrans)
    (term : OCTerm)
    (hterm : term ∈ boundedConstantTerms cutoff transitions) :
    term.strictTransitions.length < cutoff := by
  exact of_decide_eq_true (List.mem_filter.mp hterm).2

end SSExp
end TCTex
