signed strict-tail factor.
-/
lemma signed_filtered_reconstructed
    {β : Type*}
    (wt : β → ℕ)
    (hwt : ∀ atom, 0 < wt atom)
    (x y z : CWord β)
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (coefficient : ℤ)
    (word : CWord β)
    (hword :
      word ∈
        filteredReconstructedProfile
          wt x y z cutoff coefficient) :
    word ∈ signedStrictTrace x y z coefficient :=
  (List.mem_filter.mp
    (filtered_reconstructed_profile
      wt hwt x y z cutoff hcutoff coefficient word hword)).1

/--
Every retained factor rebuilt from the signed Newton family is physically
below cutoff.
-/
lemma weight_filtered_reconstructed
    {β : Type*}
    (wt : β → ℕ)
    (hwt : ∀ atom, 0 < wt atom)
    (x y z : CWord β)
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (coefficient : ℤ)
    (word : CWord β)
    (hword :
      word ∈
        filteredReconstructedProfile
          wt x y z cutoff coefficient) :
    word.weight wt < cutoff := by
  exact
    of_decide_eq_true
      (List.mem_filter.mp
        (filtered_reconstructed_profile
          wt hwt x y z cutoff hcutoff coefficient word hword)).2

/--
Every retained reconstructed factor lies in the finite
coefficient-independent substituted vocabulary.
