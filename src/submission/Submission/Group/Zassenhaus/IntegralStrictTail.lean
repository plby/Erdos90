open STVocabu

/-- Every formal trace is cutoff-supported because the finite vocabulary
contains every bounded word over the complete six-label alphabet. -/
lemma supportedBelowCutoff
    (cutoff : ℕ)
    (source : List (CWord Atom)) :
    SupportedBelowCutoff cutoff source := by
  intro word hword
  apply (ordered_cutoff_vocabulary cutoff word).2
  apply cutoff_vocabulary_weight
  exact Nat.le_of_lt (of_decide_eq_true (List.mem_filter.mp hword).2)

/--
Strict corrections from discarded source words are themselves discarded:
below cutoff, the correction operator may first filter its source.
-/
lemma below_move_correction
    (cutoff : ℕ)
    (left : CWord Atom) :
    ∀ rights : List (CWord Atom),
      unitBelowTrace cutoff (moveCorrectionTrace left rights) =
        unitBelowTrace cutoff
          (moveCorrectionTrace left
            (unitBelowTrace cutoff rights))
  | [] => by
      rfl
  | right :: rights => by
      have ih :=
        below_move_correction
          cutoff left rights
      have ih' :
          (List.map (fun next => CWord.commutator left next) rights).filter
              (fun word => decide (word.weight (fun _ => 1) < cutoff)) =
            (List.map (fun next => CWord.commutator left next)
                (rights.filter fun word =>
                  decide (word.weight (fun _ => 1) < cutoff))).filter
              (fun word => decide (word.weight (fun _ => 1) < cutoff)) := by
        simpa only [unitBelowTrace, moveCorrectionTrace] using ih
      by_cases hright : right.weight (fun _ => 1) < cutoff
      · have hrightDecide :
            decide (right.weight (fun _ => 1) < cutoff) = true := by
          simp [hright]
        simp only [unitBelowTrace, moveCorrectionTrace,
          List.map_cons, List.filter_cons, hrightDecide, if_true]
        rw [ih']
      · have hcorrection :
            ¬(.commutator left right : CWord Atom).weight
                (fun _ => 1) < cutoff := by
          simp only [CWord.weight_commutator]
          omega
        have hrightDecide :
            decide (right.weight (fun _ => 1) < cutoff) = false := by
          simp [hright]
        have hcorrectionDecide :
            decide ((.commutator left right : CWord Atom).weight
              (fun _ => 1) < cutoff) = false := by
          exact decide_eq_false_iff_not.mpr hcorrection
        simp only [unitBelowTrace, moveCorrectionTrace,
          List.map_cons, List.filter_cons, hrightDecide, hcorrectionDecide]
