      · exact
          multSuccessorPoly
            cutoff crossed outer selected right suffix
    _ =
        newtonSignedEvaluation
          (target.length * (cutoff + emittedPrefix.length + 1) + 1)
          (fun steps : ℕ =>
            (orderedSubsequenceMultiplicity target
              (boundedCrossingSchedule cutoff crossed
                outer emittedPrefix steps) : ℤ)) := by
      rw [Finset.sum_eq_single []]
      · simp
      · intro suffix _hsuffix hsuffixNe
        simp [hsuffixNe]
      · simp
