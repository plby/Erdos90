namespace TCTex
namespace RMRecb

open CWTrace
open WSTrace
open NPTail
open PSTail
open TOCoordi
open STVocabu

/-- Retain one formal trace modulo a unit-label cutoff. -/
def unitBelowTrace
    (cutoff : ℕ)
    (source : List (CWord Atom)) :
    List (CWord Atom) :=
  source.filter fun word =>
    decide (word.weight (fun _ => 1) < cutoff)

/-- Count one formal fixed slot in a trace modulo cutoff. -/
def unitBelowMultiplicity
    (cutoff : ℕ)
    (source : List (CWord Atom))
    (slot : CWord Atom) :
    ℕ :=
  (unitBelowTrace cutoff source).count slot

/-- The integral strict-tail cutoff trace is the generic unit-label cutoff
filter applied to the integral strict trace. -/
lemma below_cutoff_strict
    (cutoff : ℕ)
    (coefficient : ℤ) :
    belowCutoffTrace cutoff coefficient =
      unitBelowTrace cutoff (strictTrace coefficient) := by
  rfl

/-- Existing fixed-slot occurrence coordinates are ordinary cutoff-filtered
list counts. -/
lemma occurrence_multiplicity_below
    (cutoff : ℕ)
    (coefficient : ℤ)
    (slot : CWord Atom) :
    occurrenceMultiplicityAt cutoff coefficient slot =
      unitBelowMultiplicity cutoff (strictTrace coefficient) slot := by
  unfold occurrenceMultiplicityAt unitBelowMultiplicity
  rw [below_cutoff_strict,
    length_filter_decide]

/-- The existing fixed-slot vector is the generic cutoff-count vector of the
integral strict trace. -/
lemma fixed_slot_below
    (cutoff : ℕ)
    (coefficient : ℤ) :
    fixedMultiplicityVector cutoff coefficient =
      (orderedCutoffVocabulary cutoff).map
        (unitBelowMultiplicity cutoff (strictTrace coefficient)) := by
  unfold fixedMultiplicityVector
  apply List.map_congr_left
  intro slot _hslot
  exact
    occurrence_multiplicity_below
      cutoff coefficient slot

/-- A rightward Hall-Witt move adds its bracketed strict-correction profile
to its retained higher profile modulo cutoff. -/
lemma below_multiplicity_move
    (cutoff : ℕ)
    (left slot : CWord Atom)
    (rights : List (CWord Atom)) :
    unitBelowMultiplicity cutoff
        (moveHigherTrace left rights) slot =
      unitBelowMultiplicity cutoff
          (moveCorrectionTrace left rights) slot +
        unitBelowMultiplicity cutoff rights slot := by
  exact count_filter_move
    (fun word => decide (word.weight (fun _ => 1) < cutoff))
      left slot rights

/-- One selected stable-routing step has the corresponding linear
cutoff-multiplicity recurrence. -/
lemma stable_fst_cons
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (word slot : CWord Atom)
    (words : List (CWord Atom))
    (hcurrent : isCurrent word = true) :
    unitBelowMultiplicity cutoff
        (stableRoute isCurrent (word :: words)).1 slot =
      unitBelowMultiplicity cutoff
          (moveCorrectionTrace word
            (stableRoute isCurrent words).1) slot +
        unitBelowMultiplicity cutoff
          (stableRoute isCurrent words).1 slot := by
  exact filter_fst_current
    (fun next => decide (next.weight (fun _ => 1) < cutoff))
      isCurrent word slot words hcurrent

/-- One unselected stable-routing step retains its singleton contribution
modulo cutoff. -/
lemma stable_cons_current
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (word slot : CWord Atom)
    (words : List (CWord Atom))
    (hcurrent : isCurrent word ≠ true) :
    unitBelowMultiplicity cutoff
        (stableRoute isCurrent (word :: words)).1 slot =
      unitBelowMultiplicity cutoff [word] slot +
        unitBelowMultiplicity cutoff
          (stableRoute isCurrent words).1 slot := by
  exact filter_stable_current
    (fun next => decide (next.weight (fun _ => 1) < cutoff))
      isCurrent word slot words hcurrent

/-- Every selected Hall-Witt current word has unit-label weight three. -/
lemma or_second_current
    (word : CWord Atom)
    (hword :
      isFirstCurrent word = true ∨
        isSecondCurrent word = true) :
    word.weight (fun _ => 1) = 3 := by
  rcases hword with hword | hword
  · exact first_current_true word hword
  · exact second_current_true word hword

/--
Iterated strict corrections from one Hall-Witt current word vanish below
cutoff as soon as their accumulated weight increase reaches the cutoff.
-/
lemma iterated_current_nil
    (lowerWeight cutoff : ℕ)
    (left : CWord Atom)
    (hleft :
      isFirstCurrent left = true ∨
        isSecondCurrent left = true)
    (rights : List (CWord Atom))
    (hrights :
      ∀ right ∈ rights,
        lowerWeight ≤ right.weight (fun _ => 1))
    (steps : ℕ)
    (hcutoff : cutoff ≤ steps * 3 + lowerWeight) :
    unitBelowTrace cutoff
        (iteratedMoveTrace left steps rights) =
      [] := by
  unfold unitBelowTrace
  apply filter_iterated_move
      (fun _ : Atom => 1) lowerWeight cutoff left rights hrights steps
  rw [or_second_current left hleft]
  exact hcutoff

/--
The strict correction operator for every Hall-Witt current word is uniformly
nilpotent modulo cutoff: `cutoff` iterations already vanish.
-/
lemma below_current_nil
    (cutoff : ℕ)
    (left : CWord Atom)
    (hleft :
      isFirstCurrent left = true ∨
        isSecondCurrent left = true)
    (rights : List (CWord Atom)) :
    unitBelowTrace cutoff
        (iteratedMoveTrace left cutoff rights) =
      [] := by
  apply
    iterated_current_nil
      0 cutoff left hleft rights
      (fun right _hright => Nat.zero_le (right.weight (fun _ => 1)))
      cutoff
  omega

