  · intro hallSlots slot _hslot
    exact hallSlots slot
  · intro hvocabulary slot
    by_cases hslot : slot ∈ orderedCutoffVocabulary cutoff
    · exact hvocabulary slot hslot
    · unfold SuccessorAlternatingVanishes
      rw [show
        (fun steps : ℕ =>
          (Multiset.count slot (family (steps + 1)) : ℤ)) =
            fun _steps : ℕ => 0 by
        funext steps
