/-!
# Successor-origin reduction for the Hall-Witt packet affine endpoint

The remaining fixed-affine orbit endpoint family is the successor shift of an
unshifted ordinary orbit-prefix compiler endpoint.  Any polynomial coordinate
of the unshifted family has signed Newton successor value equal to its value
at zero.  Here that zero value is definitionally zero.

Consequently, global symbolic recollection polynomiality is reduced to
slotwise polynomiality of one unshifted orbit-prefix compiler family.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace SORed

open WSTrace
open WHNorm
open NPTail
open TBProf
open ARProfa
open ARProfa.CPAffine
open TACompos
open TOFact
open OTSubsti
open EOPrefix
open PMExp
open FTVector
open CSFold
open APKern
open ASComp

/-- Signed Newton evaluation of a successor-shifted polynomial family is its
unshifted value at zero. -/
lemma newton_evaluation_succ
    (degreeBound : ℕ)
    (family : ℕ → ℤ)
    (hfamily :
      IVMost family degreeBound)
    (hzero : family 0 = 0) :
    newtonSignedEvaluation degreeBound (fun steps => family (steps + 1)) =
      0 := by
  have heval :=
    BCExp.binomial_basis_succ
      1 degreeBound (by omega) family (by simpa using hfamily)
  rw [BCExp.eval_int_binomial] at heval
  simpa [newtonSignedEvaluation, hzero] using heval

/-- Unshifted positive ordinary compiler endpoint of the emitted orbit
prefix. -/
noncomputable def positiveCompilerEndpoint
    (cutoff steps : ℕ) :
    Multiset (CWord Atom) :=
  (ofTrace cutoff isSecondCurrent
    (cutoffMovePrefix cutoff firstConventionalInverse
      (positiveFilteredPrefix cutoff) steps)).apply 0

/-- Unshifted negative ordinary compiler endpoint of the emitted orbit
prefix. -/
noncomputable def emptyCompilerEndpoint
    (cutoff steps : ℕ) :
    Multiset (CWord Atom) :=
  (ofTrace cutoff isSecondCurrent
    (cutoffMovePrefix cutoff firstConventionalWord
      (negativeFilteredPrefix cutoff) steps)).apply 0

@[simp]
lemma positive_empty_compiler
    (cutoff : ℕ) :
    positiveCompilerEndpoint cutoff 0 = 0 := by
  unfold positiveCompilerEndpoint
    cutoffMovePrefix
  exact apply_one 0

@[simp]
lemma negative_empty_compiler
    (cutoff : ℕ) :
    emptyCompilerEndpoint cutoff 0 = 0 := by
  unfold emptyCompilerEndpoint
    cutoffMovePrefix
  exact apply_one 0

/-- Polynomial data for the unshifted positive orbit-prefix compiler endpoint
implies the positive fixed-affine formal-predecessor kernel. -/
lemma natural_empty_compiler
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (hpoly :
      CPDataa cutoff
        (naturalFullBound cutoff)
          (positiveCompilerEndpoint cutoff)) :
    EmptySatisfiesNewton
      cutoff := by
  intro slot
  calc
    newtonSignedEvaluation
        (naturalFullBound cutoff)
        (fun steps =>
          (Multiset.count slot
            ((positiveSecondAffine cutoff).apply
              (positiveEmptyEndpoint cutoff steps)) : ℤ)) =
      newtonSignedEvaluation
        (naturalFullBound cutoff)
        (fun steps =>
          (Multiset.count slot
            (positiveCompilerEndpoint cutoff
              (steps + 1)) : ℤ)) := by
        apply congrArg
        funext steps
        rw [
          positive_fixed_prefix
            cutoff hcutoff]
        rfl
    _ = 0 :=
      newton_evaluation_succ
        (naturalFullBound cutoff)
          (fun steps =>
            (Multiset.count slot
              (positiveCompilerEndpoint cutoff steps) :
                ℤ))
            (hpoly.2 slot) (by simp)

/-- Polynomial data for the unshifted negative orbit-prefix compiler endpoint
implies the negative fixed-affine formal-predecessor kernel. -/
lemma empty_compiler_poly
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (hpoly :
      CPDataa cutoff
        (negativeFullBound cutoff)
          (emptyCompilerEndpoint cutoff)) :
    EmptySuccessorNewton
      cutoff := by
  intro slot
  calc
    newtonSignedEvaluation
        (negativeFullBound cutoff)
        (fun steps =>
          (Multiset.count slot
            ((negativeSecondAffine cutoff).apply
              (negativeEmptyEndpoint cutoff steps)) : ℤ)) =
      newtonSignedEvaluation
        (negativeFullBound cutoff)
        (fun steps =>
          (Multiset.count slot
            (emptyCompilerEndpoint cutoff
              (steps + 1)) : ℤ)) := by
        apply congrArg
        funext steps
        rw [
          negative_fixed_prefix
            cutoff hcutoff]
        rfl
    _ = 0 :=
      newton_evaluation_succ
        (negativeFullBound cutoff)
          (fun steps =>
            (Multiset.count slot
              (emptyCompilerEndpoint cutoff steps) :
                ℤ))
            (hpoly.2 slot) (by simp)

/-- Positive unshifted orbit-prefix compiler endpoint polynomiality discharges
global positive strict-tail cutoff-profile polynomiality. -/
lemma natural_compiler_endpoint
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (hpoly :
      CPDataa cutoff
        (naturalFullBound cutoff)
          (positiveCompilerEndpoint cutoff)) :
    CPDataa cutoff
      (naturalStrictBound cutoff)
      (fun multiplicity =>
        cutoffProfile cutoff
          (NPTail.strictTrace multiplicity)) := by
  apply
    natural_endpoint_newton
      cutoff hcutoff
  exact
    natural_empty_compiler
      cutoff hcutoff hpoly

/-- Negative unshifted orbit-prefix compiler endpoint polynomiality discharges
global negative strict-tail cutoff-profile polynomiality. -/
lemma poly_compiler_endpoint
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (hpoly :
      CPDataa cutoff
        (negativeFullBound cutoff)
          (emptyCompilerEndpoint cutoff)) :
    CPDataa cutoff
      (negativeStrictBound cutoff)
      (fun multiplicity =>
        cutoffProfile cutoff
          (NNPower.strictTrace
            multiplicity)) := by
  apply
    negative_endpoint_newton
      cutoff hcutoff
  exact
    empty_compiler_poly
      cutoff hcutoff hpoly

end SORed
