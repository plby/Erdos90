              1 + (suffix.length * cutoff + trace.length) ≤
                suffix.length * (cutoff + trace.length + 1) := by
            simp only [Nat.mul_add, Nat.mul_one]
            omega
          calc
            (target.take (target.length - suffix.length)).length *
                    (cutoff + trace.length + 1) +
                  1 +
                (suffix.length * cutoff + trace.length) ≤
                (target.take (target.length - suffix.length)).length *
                      (cutoff + trace.length + 1) +
                    suffix.length * (cutoff + trace.length + 1) :=
              by
                simpa only [Nat.add_assoc] using
                  Nat.add_le_add_left hsuffixBudget
                    ((target.take
                      (target.length - suffix.length)).length *
                        (cutoff + trace.length + 1))
            _ =
                ((target.take (target.length - suffix.length)).length +
                    suffix.length) *
                  (cutoff + trace.length + 1) := by
              rw [Nat.add_mul]
            _ = target.length * (cutoff + trace.length + 1) := by
              rw [hprefixLe]
        · exact
            TCTex.IVMost.mul
              (leftDegree :=
                (target.take (target.length - suffix.length)).length *
                    (cutoff + trace.length + 1) +
                  1)
              (rightDegree := suffix.length * cutoff + trace.length)
              (subsequenceMultPoly
                cutoff outer selected trace
                  (target.take (target.length - suffix.length)))
              (subsequenceMultFlat
                cutoff outer selected trace suffix)
