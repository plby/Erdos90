-- OriginCompatibility.lean

/-!
# Origin-compatible all-natural complete Hall-Witt schedules

Lower the remaining all-natural polynomial boundary from aggregated cutoff
profiles to the finite bounded affine terms of the explicit complete
transition schedules.  This retains the fixed outer prefix and dynamic
crossing structure needed for a termwise origin argument.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace TOCompat

open TBProf
open TACompos
open OTSubsti
open SSExp
open STState
open STClos
open TOClos
open FSTerm
open TNForm
open FTAlphab

/-- Every bounded-term successor polynomial matches the actual coordinate at
natural input zero. -/
def PolynomialsMatchOrigin
    (family : ℕ → List OCTerm) :
    Prop :=
  ∀ target,
    SuccessorPolynomialsOrigin
      (fun steps : ℕ => ((family steps).count target : ℤ))

/-- Successor-precomposed bounded-term polynomial data extends globally when
its coordinate witnesses match the missing origin. -/
lemma BCDataa.pred_match_origin
    {cutoff degreeBound : ℕ}
    {family : ℕ → List OCTerm}
    (hsucc :
      BCDataa cutoff degreeBound
        (fun steps => family (steps + 1)))
    (hsupportZero :
      SCAlphab cutoff (family 0))
    (horigin :
      PolynomialsMatchOrigin family) :
    BCDataa cutoff degreeBound family := by
  constructor
  · intro steps
    cases steps with
    | zero =>
        exact hsupportZero
    | succ steps =>
        simpa [Nat.succ_eq_add_one] using hsucc.1 steps
  · intro target
    exact
      TCTex.IVMost.pred_match_origin
        (hsucc.2 target) (horigin target)

/-- Origin compatibility for the positive all-natural complete transition
schedule. -/
def NaturalMatchOrigin
    (cutoff : ℕ) :
    Prop :=
  PolynomialsMatchOrigin
    (fun multiplicity =>
      boundedConstantTerms cutoff
        (naturalFullSchedule cutoff multiplicity))

/-- Origin compatibility for the negative all-natural complete transition
schedule. -/
def SuccessorMatchOrigin
    (cutoff : ℕ) :
    Prop :=
  PolynomialsMatchOrigin
    (fun multiplicity =>
      boundedConstantTerms cutoff
        (negativeFullSchedule cutoff multiplicity))

/-- Positive all-natural complete schedules have polynomial bounded terms
after precomposition with successor. -/
lemma constant_natural_full
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff) :
    BCDataa cutoff
      (cutoff *
          (2 * cutoff + (positiveFilteredPrefix cutoff).length + 4) +
        1)
      (fun steps =>
        boundedConstantTerms cutoff
          (naturalFullSchedule cutoff (steps + 1))) := by
  apply
    (constant_route_program
      cutoff hcutoff).congr
  intro steps
  rw [
    transition_program_full
      cutoff hcutoff]

/-- Negative all-natural complete schedules have polynomial bounded terms
after precomposition with successor. -/
lemma constant_full_succ
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff) :
    BCDataa cutoff
      (cutoff *
          (2 * cutoff + (negativeFilteredPrefix cutoff).length + 4) +
        1)
      (fun steps =>
        boundedConstantTerms cutoff
          (negativeFullSchedule cutoff (steps + 1))) := by
  apply
    (constantRouteProgram
      cutoff hcutoff).congr
  intro steps
  rw [
    route_program_full
      cutoff hcutoff]

/-- Positive all-natural complete schedules have globally polynomial bounded
terms once their finite term coordinates match at the origin. -/
lemma full_match_origin
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (horigin :
      NaturalMatchOrigin cutoff) :
    BCDataa cutoff
      (cutoff *
          (2 * cutoff + (positiveFilteredPrefix cutoff).length + 4) +
        1)
      (fun multiplicity =>
        boundedConstantTerms cutoff
          (naturalFullSchedule cutoff multiplicity)) := by
  apply
    BCDataa.pred_match_origin
  · exact
      constant_natural_full
        cutoff hcutoff
  · exact
      supportedNaturalSchedule
        cutoff 0
  · exact horigin

/-- Negative all-natural complete schedules have globally polynomial bounded
terms once their finite term coordinates match at the origin. -/
lemma constant_match_origin
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (horigin :
      SuccessorMatchOrigin cutoff) :
    BCDataa cutoff
