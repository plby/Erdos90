      CPDataa cutoff degreeBound
        (fun steps : ℕ => family (steps + 1))) :
    SuccessorPolynomialsVanish family ↔
      NewtonAlternatingVanish degreeBound family := by
  apply forall_congr'
  intro slot
  apply vanish_alternating_vanishes
