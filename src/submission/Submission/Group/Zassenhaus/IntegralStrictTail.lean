/-!
# Inner-depth decomposition of signed endpoint count states

The one-block nested successor-skew schedule is itself a flattened family of
ordinary outer crossing schedules indexed by bounded inner depths.  This file
lifts that flattening theorem to the finite bounded-term count-state compiler.

The remaining positive and negative endpoint kernels are thereby expressed
using an orbit-prefix fold and iteration of an explicit inner-depth fold.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace CSDecomp

open WSTrace
open WHNorm
open WNTrace
open WSTail
open NPTail
open TBProf
open TACompos
open OTSubsti
open OTSched
open BDExp
open DCSched
open STSched
open SCState
open DSRec
open ECSched
open BTRepeat
open SSSched
open PMExp
open FTVector
open CSFold
open ECDecomp

/-- Folding a flattened schedule is a right fold of its block-level
count-state transformers. -/
lemma state_fold_flat
    {ι : Type*}
    (cutoff : ℕ) :
    ∀ (blocks : List ι)
      (scheduleAt : ι → List SRTrans)
      (state : BoundedCountState),
      boundedStateFold cutoff
          (blocks.flatMap scheduleAt) state =
        blocks.foldr
          (fun block state =>
            boundedStateFold cutoff (scheduleAt block) state)
          state
  | [], _scheduleAt, _state => by
      rfl
  | block :: blocks, scheduleAt, state => by
      rw [List.flatMap_cons, state_fold_append,
        state_fold_flat cutoff blocks scheduleAt
          state]
      rfl

/-- Explicit one-block count-state operator for the nested successor-skew
schedule, as a right fold over bounded inner depths. -/
def successorSkewOperator
    (cutoff : ℕ)
    (crossed outer selected right : CWord Atom)
    (steps : ℕ) :
    BoundedCountState → BoundedCountState :=
  fun state =>
    (boundedDepthSchedule cutoff (steps + 1)).foldr
      (fun innerDepth state =>
        boundedStateFold cutoff
          (depthCrossingSchedule cutoff crossed outer
            (iteratedLeftCommutator selected innerDepth right) steps)
          state)
      state

/-- The count-state fold of one nested successor-skew block is its explicit
inner-depth fold operator. -/
lemma fold_skew_operator
    (cutoff : ℕ)
    (crossed outer selected right : CWord Atom)
    (steps : ℕ)
    (state : BoundedCountState) :
    boundedStateFold cutoff
        (successorSkewCrossing cutoff crossed
          outer selected right steps) state =
      successorSkewOperator cutoff crossed outer
        selected right steps state := by
  unfold successorSkewCrossing
    successorSkewOperator
  rw [
    nested_crossing_flat,
    state_fold_flat]

/-- The repeated nested successor-skew suffix iterates its explicit
inner-depth one-block count-state operator. -/
lemma successor_skew_operator
    (cutoff : ℕ)
    (crossed outer selected right : CWord Atom)
    (steps : ℕ) :
    successorSkewRepeated cutoff crossed outer selected right
        steps =
      iterateStateOperator
        (successorSkewOperator cutoff crossed outer
          selected right steps)
        (boundedCountState []) (steps + 1) := by
  unfold successorSkewRepeated
  apply congrArg (fun operator =>
    iterateStateOperator operator
      (boundedCountState []) (steps + 1))
  funext state
  exact
    fold_skew_operator
      cutoff crossed outer selected right steps state

/-- Successor-skew tail count state after exposing both the orbit-prefix
fold and the iterated inner-depth one-block operator. -/
def successorSkewDecomposed
    (cutoff : ℕ)
    (crossed outer selected right : CWord Atom)
    (emittedPrefix : List (CWord Atom))
    (steps : ℕ) :
    BoundedCountState :=
  boundedStateFold cutoff
    (boundedCrossingSchedule cutoff crossed outer
      emittedPrefix steps)
    (iterateStateOperator
      (successorSkewOperator cutoff crossed outer
        selected right steps)
      (boundedCountState []) (steps + 1))

/-- The decomposed successor-skew tail state is the explicit orbit-prefix
fold applied to iteration of the inner-depth one-block operator. -/
lemma successor_decomposed_state
    (cutoff : ℕ)
    (crossed outer selected right : CWord Atom)
    (emittedPrefix : List (CWord Atom))
    (steps : ℕ) :
    decomposedCountState cutoff crossed outer selected right
        emittedPrefix steps =
      successorSkewDecomposed cutoff crossed outer
        selected right emittedPrefix steps := by
  unfold decomposedCountState
    successorSkewDecomposed
  rw [successor_skew_operator]

/-- Positive signed tail state with the inner-depth decomposition exposed. -/
noncomputable def successorSkewState
    (cutoff : ℕ) :
    BoundedCountState :=
  newtonEvaluationState
    (naturalFullBound cutoff)
    (fun steps =>
      successorSkewDecomposed cutoff
        firstConventionalInverse firstConventionalInverse
          firstConventionalWord secondConventionalInverse
            (positiveFilteredPrefix cutoff) steps)

/-- Negative signed tail state with the inner-depth decomposition exposed. -/
noncomputable def skewDecomposedState
    (cutoff : ℕ) :
    BoundedCountState :=
  newtonEvaluationState
    (negativeFullBound cutoff)
    (fun steps =>
      successorSkewDecomposed cutoff
        firstConventionalWord firstConventionalWord
          firstConventionalInverse secondConventionalWord
            (negativeFilteredPrefix cutoff) steps)

/-- The positive decomposed signed state equals its inner-depth normal
form. -/
lemma natural_successor_decomposed
    (cutoff : ℕ) :
    naturalDecomposedState cutoff =
      successorSkewState cutoff := by
  unfold naturalDecomposedState
    successorSkewState
  apply congrArg
  funext steps
  exact
    successor_decomposed_state cutoff
      firstConventionalInverse firstConventionalInverse
        firstConventionalWord secondConventionalInverse
          (positiveFilteredPrefix cutoff) steps

/-- The negative decomposed signed state equals its inner-depth normal
form. -/
lemma skew_decomposed_state
    (cutoff : ℕ) :
    successorDecomposedState cutoff =
      skewDecomposedState cutoff := by
  unfold successorDecomposedState
    skewDecomposedState
  apply congrArg
  funext steps
  exact
    successor_decomposed_state cutoff
      firstConventionalWord firstConventionalWord firstConventionalInverse
        secondConventionalWord (negativeFilteredPrefix cutoff) steps

/-- Positive endpoint cancellation expressed against the inner-depth
decomposed signed successor-skew tail state. -/
def NaturalSkewDecomposed
    (cutoff : ℕ) :
    Prop :=
  ∀ slot,
    boundedStateSlot cutoff
      (boundedStateFold cutoff
        (positiveFixedPrefix cutoff)
          (successorSkewState cutoff))
      slot = 0

/-- Negative endpoint cancellation expressed against the inner-depth
decomposed signed successor-skew tail state. -/
def SuccessorSkewDecomposed
    (cutoff : ℕ) :
    Prop :=
  ∀ slot,
    boundedStateSlot cutoff
      (boundedStateFold cutoff
        (negativeFixedPrefix cutoff)
          (skewDecomposedState cutoff))
      slot = 0

/-- The positive decomposed prefix kernel is unchanged after exposing the
inner-depth fold. -/
lemma natural_skew_decomposed
    (cutoff : ℕ) :
    SkewDecomposedSatisfies
        cutoff ↔
      NaturalSkewDecomposed
        cutoff := by
  rw [SkewDecomposedSatisfies,
    NaturalSkewDecomposed,
    natural_successor_decomposed]

/-- The negative decomposed prefix kernel is unchanged after exposing the
inner-depth fold. -/
lemma successor_skew_decomposed
    (cutoff : ℕ) :
    SkewDecomposedState
        cutoff ↔
      SuccessorSkewDecomposed
        cutoff := by
  rw [SkewDecomposedState,
    SuccessorSkewDecomposed,
    skew_decomposed_state]

/-- The positive inner-depth finite prefix-kernel identity discharges global
positive strict-tail cutoff-profile polynomiality. -/
lemma natural_inner_prefix
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (hkernel :
      NaturalSkewDecomposed
        cutoff) :
    CPDataa cutoff
      (naturalStrictBound cutoff)
      (fun multiplicity =>
        cutoffProfile cutoff
          (NPTail.strictTrace multiplicity)) := by
  apply
    natural_decomposed_prefix
      cutoff hcutoff
  exact
    (natural_skew_decomposed
      cutoff).2 hkernel

/-- The negative inner-depth finite prefix-kernel identity discharges global
negative strict-tail cutoff-profile polynomiality. -/
lemma negative_inner_prefix
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (hkernel :
      SuccessorSkewDecomposed
        cutoff) :
    CPDataa cutoff
      (negativeStrictBound cutoff)
      (fun multiplicity =>
        cutoffProfile cutoff
          (NNPower.strictTrace
            multiplicity)) := by
  apply
    negative_decomposed_prefix
      cutoff hcutoff
  exact
    (successor_skew_decomposed
      cutoff).2 hkernel

end CSDecomp
