/-!
# Polynomial composition for Hall-Witt cutoff profiles

Below cutoff, every formal routing profile is supported on one finite ordered
vocabulary.  Reconstruct a supported multiset from its fixed-slot counts and
deduce that applying any fixed additive endomorphism preserving that support
preserves slotwise polynomiality.

This is the finite-vocabulary composition layer needed to feed the output of
one polynomially repeated affine routing block into the next.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace TACompos

open WSTrace
open NPTail
open STVocabu
open RMRecb
open TBProf
open ARProfa
open ARProfa.CPAffine
open ARUnipot
open AIBinom
open ARPoly

/-- A formal profile is supported on the fixed ordered cutoff vocabulary. -/
def SCVocabu
    (cutoff : ℕ)
    (source : Multiset (CWord Atom)) :
    Prop :=
  ∀ word ∈ source, word ∈ orderedCutoffVocabulary cutoff

/-- Every cutoff-filtered literal trace is supported on the fixed vocabulary. -/
lemma supported_vocabulary_profile
    (cutoff : ℕ)
    (source : List (CWord Atom)) :
    SCVocabu cutoff (cutoffProfile cutoff source) := by
  intro word hword
  change word ∈ unitBelowTrace cutoff source at hword
  have hweight :
      word.weight (fun _ => 1) < cutoff :=
    of_decide_eq_true (List.mem_filter.mp hword).2
  apply (ordered_cutoff_vocabulary cutoff word).2
  exact cutoff_vocabulary_weight cutoff word (Nat.le_of_lt hweight)

/-- Fixed-vocabulary support is preserved by profile addition. -/
lemma SCVocabu.add
    {cutoff : ℕ}
    {left right : Multiset (CWord Atom)}
    (hleft : SCVocabu cutoff left)
    (hright : SCVocabu cutoff right) :
    SCVocabu cutoff (left + right) := by
  intro word hword
  rw [Multiset.mem_add] at hword
  rcases hword with hword | hword
  · exact hleft word hword
  · exact hright word hword

/-- An additive endomorphism preserves fixed cutoff support. -/
def PCVocabu
    (cutoff : ℕ)
    (transform : ProfileEnd) :
    Prop :=
  ∀ source,
    SCVocabu cutoff source →
      SCVocabu cutoff (transform source)

/-- The identity endomorphism preserves cutoff support. -/
lemma preserves_vocabulary_one
    (cutoff : ℕ) :
    PCVocabu cutoff (1 : ProfileEnd) := by
  intro source hsource
  exact hsource

/-- Sums of support-preserving endomorphisms preserve support. -/
lemma PCVocabu.add
    {cutoff : ℕ}
    {left right : ProfileEnd}
    (hleft : PCVocabu cutoff left)
    (hright : PCVocabu cutoff right) :
    PCVocabu cutoff (left + right) := by
  intro source hsource
  exact (hleft source hsource).add (hright source hsource)

/-- Compositions of support-preserving endomorphisms preserve support. -/
lemma PCVocabu.mul
    {cutoff : ℕ}
    {left right : ProfileEnd}
    (hleft : PCVocabu cutoff left)
    (hright : PCVocabu cutoff right) :
    PCVocabu cutoff (left * right) := by
  intro source hsource
  exact hleft (right source) (hright source hsource)

/-- Any transform whose output is filtered below cutoff lands in the fixed
vocabulary. -/
lemma preserves_outputs_below
    {cutoff : ℕ}
    {transform : ProfileEnd}
    (htransform : OBCutoff cutoff transform) :
    PCVocabu cutoff transform := by
  intro source _hsource word hword
  apply (ordered_cutoff_vocabulary cutoff word).2
  exact
    cutoff_vocabulary_weight cutoff word
      (Nat.le_of_lt (htransform source word hword))

/-- Every strict packet correction endomorphism lands in the fixed cutoff
vocabulary. -/
lemma preserves_cutoff_end
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom)) :
    PCVocabu cutoff
      (packetCorrectionEnd cutoff isCurrent packet) :=
  preserves_outputs_below
    (end_outputs_below cutoff isCurrent packet)

/-- The compiled linear action of one fixed packet preserves cutoff support. -/
lemma preserves_vocabulary_linear
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom)) :
    PCVocabu cutoff (ofTrace cutoff isCurrent packet).linear := by
  rw [trace_linear_end]
  exact
    (preserves_cutoff_end cutoff isCurrent packet).add
      (preserves_vocabulary_one cutoff)

/-- Powers of the compiled linear action preserve cutoff support. -/
lemma preserves_vocabulary_pow
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom)) :
    ∀ steps : ℕ,
      PCVocabu cutoff
        ((ofTrace cutoff isCurrent packet).linear ^ steps)
  | 0 => by
      simpa using preserves_vocabulary_one cutoff
  | steps + 1 => by
      rw [_root_.pow_succ']
      exact
        (preserves_vocabulary_linear cutoff isCurrent packet).mul
          (preserves_vocabulary_pow cutoff isCurrent packet
            steps)

/--
The count of one output slot under a fixed additive endomorphism is a finite
linear combination of the input fixed-slot counts.
-/
lemma count_cutoff_vocabulary
    (cutoff : ℕ)
    (transform : ProfileEnd)
    (source : Multiset (CWord Atom))
    (hsource : SCVocabu cutoff source)
    (slot : CWord Atom) :
    Multiset.count slot (transform source) =
      ∑ input ∈ (orderedCutoffVocabulary cutoff).toFinset,
        Multiset.count slot (transform {input}) *
          Multiset.count input source := by
  calc
    Multiset.count slot (transform source) =
        Multiset.count slot
          (transform
            (∑ input ∈ source.toFinset,
              Multiset.count input source • ({input} :
                Multiset (CWord Atom)))) := by
          rw [Multiset.toFinset_sum_count_nsmul_eq]
    _ =
        Multiset.count slot
          (∑ input ∈ source.toFinset,
            Multiset.count input source • transform {input}) := by
          congr 1
          rw [map_sum]
          apply Finset.sum_congr rfl
          intro input _hinput
          exact map_nsmul transform (Multiset.count input source) {input}
    _ =
        ∑ input ∈ source.toFinset,
          Multiset.count slot (transform {input}) *
            Multiset.count input source := by
          change
            (Multiset.countAddMonoidHom slot)
                (∑ input ∈ source.toFinset,
                  Multiset.count input source • transform {input}) =
              _
          rw [map_sum]
          simp [Multiset.count_nsmul, Nat.mul_comm]
    _ =
        ∑ input ∈ (orderedCutoffVocabulary cutoff).toFinset,
          Multiset.count slot (transform {input}) *
            Multiset.count input source := by
          apply Finset.sum_subset
          · intro input hinput
            exact
              List.mem_toFinset.mpr
                (hsource input (Multiset.mem_toFinset.mp hinput))
          · intro input _hinputVocabulary hinputSource
            have hnotMem : input ∉ source := by
              simpa only [Multiset.mem_toFinset] using hinputSource
            simp [Multiset.count_eq_zero_of_notMem hnotMem]

/-- Slotwise cutoff-profile polynomial data with one common degree bound. -/
def CPDataa
    (cutoff degreeBound : ℕ)
    (family : ℕ → Multiset (CWord Atom)) :
    Prop :=
  (∀ steps, SCVocabu cutoff (family steps)) ∧
    ∀ slot,
      IVMost
        (fun steps : ℕ => (Multiset.count slot (family steps) : ℤ))
        degreeBound

namespace IVMost

/-- Finite sums preserve a common integer-valued polynomial degree bound. -/
lemma finsetSum
    {ι : Type*}
    {degreeBound : ℕ}
    (slots : Finset ι)
    (family : ι → ℕ → ℤ)
    (hfamily :
      ∀ slot ∈ slots,
        IVMost
          (family slot) degreeBound) :
    IVMost
      (fun steps : ℕ => ∑ slot ∈ slots, family slot steps)
      degreeBound := by
  classical
  induction slots using Finset.induction_on with
  | empty =>
      simpa using
        TCTex.IVMost.zero
          degreeBound
  | @insert slot slots hslot ih =>
      simpa [Finset.sum_insert hslot] using
        TCTex.IVMost.add
          (hfamily slot (by simp))
          (ih (fun next hnext => hfamily next (by simp [hnext])))

end IVMost

/-- Applying a fixed support-preserving additive operator preserves slotwise
polynomial data and its degree bound. -/
lemma CPDataa.apply_fixed
    {cutoff degreeBound : ℕ}
    {family : ℕ → Multiset (CWord Atom)}
    (hfamily : CPDataa cutoff degreeBound family)
    (transform : ProfileEnd)
    (htransform : PCVocabu cutoff transform) :
    CPDataa cutoff degreeBound
      (fun steps => transform (family steps)) := by
  constructor
  · intro steps
    exact htransform (family steps) (hfamily.1 steps)
  · intro slot
    rw [show
      (fun steps : ℕ => (Multiset.count slot (transform (family steps)) : ℤ)) =
        fun steps : ℕ =>
          ∑ input ∈ (orderedCutoffVocabulary cutoff).toFinset,
            (Multiset.count slot (transform {input}) : ℤ) *
              (Multiset.count input (family steps) : ℤ) by
        funext steps
        exact_mod_cast
          count_cutoff_vocabulary
            cutoff transform (family steps) (hfamily.1 steps) slot]
    apply IVMost.finsetSum
    intro input _hinput
    simpa [Pi.smul_apply, smul_eq_mul] using
      IVMost.smul
        (Multiset.count slot (transform {input}) : ℤ)
        (hfamily.2 input)

/-- Fixed-vocabulary support is preserved by natural scalar multiplication. -/
lemma SCVocabu.nsmul
    {cutoff : ℕ}
    {source : Multiset (CWord Atom)}
    (hsource : SCVocabu cutoff source)
    (multiplicity : ℕ) :
    SCVocabu cutoff (multiplicity • source) := by
  intro word hword
  exact hsource word (Multiset.mem_of_mem_nsmul hword)

/-- Powers of the strict packet-correction operator preserve cutoff support. -/
lemma preserves_vocabulary_end
    (cutoff : ℕ)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom)) :
    ∀ steps : ℕ,
      PCVocabu cutoff
        ((packetCorrectionEnd cutoff isCurrent packet) ^ steps)
  | 0 => by
      simpa using preserves_vocabulary_one cutoff
  | steps + 1 => by
      rw [_root_.pow_succ']
      exact
        (preserves_cutoff_end
          cutoff isCurrent packet).mul
            (preserves_vocabulary_end
              cutoff isCurrent packet steps)

/-- The zero profile family has polynomial coordinates at every degree bound. -/
lemma cutoff_profile_zero
    (cutoff degreeBound : ℕ) :
    CPDataa cutoff degreeBound
      (fun _steps => 0) := by
  constructor
  · intro steps word hword
    simp at hword
  · intro slot
    simpa using
      TCTex.IVMost.zero
        degreeBound

/-- A common profile-polynomial degree bound may be enlarged. -/
lemma CPDataa.mono
    {cutoff degreeBound largerBound : ℕ}
    {family : ℕ → Multiset (CWord Atom)}
    (hdegree : degreeBound ≤ largerBound)
    (hfamily : CPDataa cutoff degreeBound family) :
    CPDataa cutoff largerBound family := by
  exact
    ⟨hfamily.1, fun slot =>
      TCTex.IVMost.mono
        hdegree (hfamily.2 slot)⟩

/-- Pointwise profile addition preserves a common polynomial degree bound. -/
lemma CPDataa.add
    {cutoff degreeBound : ℕ}
    {left right : ℕ → Multiset (CWord Atom)}
    (hleft : CPDataa cutoff degreeBound left)
    (hright : CPDataa cutoff degreeBound right) :
    CPDataa cutoff degreeBound
      (fun steps => left steps + right steps) := by
  constructor
  · intro steps
    exact (hleft.1 steps).add (hright.1 steps)
  · intro slot
    simpa [Multiset.count_add] using
      TCTex.IVMost.add
        (hleft.2 slot) (hright.2 slot)

/-- The Newton basis function `steps ↦ choose steps k` is an integer-valued
polynomial of degree at most `k`. -/
lemma choose_valued_most
    (k : ℕ) :
    IVMost
      (fun steps : ℕ => (steps.choose k : ℤ)) k := by
  exact
    ⟨natChoosePolynomial k, degree_choose_polynomial k,
      fun steps => by simpa using eval_nat_choose steps k⟩

/-- Scaling a profile-polynomial family by `choose steps k` adds at most `k`
to its degree bound. -/
lemma CPDataa.choose_nsmul
    {cutoff degreeBound : ℕ}
    {family : ℕ → Multiset (CWord Atom)}
    (hfamily : CPDataa cutoff degreeBound family)
    (k : ℕ) :
    CPDataa cutoff (k + degreeBound)
      (fun steps => steps.choose k • family steps) := by
  constructor
  · intro steps
    exact (hfamily.1 steps).nsmul (steps.choose k)
  · intro slot
    simpa [Multiset.count_nsmul] using
      TCTex.IVMost.mul
        (choose_valued_most k)
        (hfamily.2 slot)

/-- Pointwise finite sums preserve a common profile-polynomial degree bound. -/
lemma cutoff_finset_sum
    {ι : Type*}
    {cutoff degreeBound : ℕ}
    (slots : Finset ι)
    (family : ι → ℕ → Multiset (CWord Atom))
    (hfamily :
      ∀ slot ∈ slots,
        CPDataa cutoff degreeBound (family slot)) :
    CPDataa cutoff degreeBound
      (fun steps => ∑ slot ∈ slots, family slot steps) := by
  classical
  constructor
  · intro steps word hword
    rw [Multiset.mem_sum] at hword
    rcases hword with ⟨slot, hslot, hword⟩
    exact (hfamily slot hslot).1 steps word hword
  · intro word
    rw [show
      (fun steps : ℕ =>
        (Multiset.count word (∑ slot ∈ slots, family slot steps) : ℤ)) =
          fun steps : ℕ =>
            ∑ slot ∈ slots,
              (Multiset.count word (family slot steps) : ℤ) by
        funext steps
        norm_cast
        change
          (Multiset.countAddMonoidHom word)
              (∑ slot ∈ slots, family slot steps) =
            _
        exact map_sum (Multiset.countAddMonoidHom word)
          (fun slot => family slot steps) slots]
    exact
      IVMost.finsetSum slots
        (fun slot steps => (Multiset.count word (family slot steps) : ℤ))
        (fun slot hslot => (hfamily slot hslot).2 word)

/-- Iteration of one affine transform differs from its linear power by the
same accumulated constant obtained by iterating from zero. -/
lemma iterate_linear_zero
    (transform : CPAffine)
    (steps : ℕ)
    (source : Multiset (CWord Atom)) :
    (iterate transform steps).apply source =
      (transform.linear ^ steps) source +
        (iterate transform steps).apply 0 := by
  rw [iterate_add_sum, iterate_add_sum]
  simp

/-- The profile family obtained by the varying linear power of one compiled
packet preserves polynomiality, with degree increased by at most cutoff. -/
lemma CPDataa.trace_lin_powapply
    {cutoff degreeBound : ℕ}
    (hcutoff : 0 < cutoff)
    {family : ℕ → Multiset (CWord Atom)}
    (hfamily : CPDataa cutoff degreeBound family)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom)) :
    CPDataa cutoff (cutoff + degreeBound)
      (fun steps =>
        ((ofTrace cutoff isCurrent packet).linear ^ steps) (family steps)) := by
  rw [show
    (fun steps =>
      ((ofTrace cutoff isCurrent packet).linear ^ steps) (family steps)) =
        fun steps =>
          ∑ k ∈ Finset.range cutoff,
            steps.choose k •
              ((packetCorrectionEnd cutoff isCurrent packet) ^ k)
                (family steps) by
      funext steps
      exact
        linear_range_cutoff
          cutoff hcutoff isCurrent packet steps (family steps)]
  apply cutoff_finset_sum
  intro k hk
  have hkLe : k ≤ cutoff := Nat.le_of_lt (Finset.mem_range.mp hk)
  apply CPDataa.mono (Nat.add_le_add_right hkLe degreeBound)
  exact
    (hfamily.apply_fixed
      ((packetCorrectionEnd cutoff isCurrent packet) ^ k)
      (preserves_vocabulary_end
        cutoff isCurrent packet k)).choose_nsmul k

/-- Iterating one compiled packet from zero has cutoff-bounded slotwise
polynomial data. -/
lemma cutoff_profile_iterate
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom)) :
    CPDataa cutoff cutoff
      (fun steps => (iterate (ofTrace cutoff isCurrent packet) steps).apply 0) := by
  constructor
  · intro steps
    change
      SCVocabu cutoff
        ((iterate (ofTrace cutoff isCurrent packet) steps).apply 0)
    rw [← stable_fst_repeat]
    exact supported_vocabulary_profile cutoff _
  · intro slot
    simpa [repeatedPacketMultiplicity] using
      repeated_valued_most
        cutoff hcutoff isCurrent packet slot

/--
Applying a polynomially repeated fixed packet to an already-polynomial input
profile family preserves slotwise polynomiality, increasing the common degree
bound by at most the cutoff.
-/
lemma CPDataa.iterate_trace_apply
    {cutoff degreeBound : ℕ}
    (hcutoff : 0 < cutoff)
    {family : ℕ → Multiset (CWord Atom)}
    (hfamily : CPDataa cutoff degreeBound family)
    (isCurrent : CWord Atom → Bool)
    (packet : List (CWord Atom)) :
    CPDataa cutoff (cutoff + degreeBound)
      (fun steps =>
        (iterate (ofTrace cutoff isCurrent packet) steps).apply
          (family steps)) := by
  rw [show
    (fun steps =>
      (iterate (ofTrace cutoff isCurrent packet) steps).apply
        (family steps)) =
      fun steps =>
        ((ofTrace cutoff isCurrent packet).linear ^ steps) (family steps) +
          (iterate (ofTrace cutoff isCurrent packet) steps).apply 0 by
      funext steps
      exact
        iterate_linear_zero
          (ofTrace cutoff isCurrent packet) steps (family steps)]
  exact
    (hfamily.trace_lin_powapply hcutoff isCurrent packet).add
      ((cutoff_profile_iterate
        cutoff hcutoff isCurrent packet).mono
          (Nat.le_add_right cutoff degreeBound))

end TACompos
end TCTex
end Submission

