/-- Bounded ordered affine-term multiplicities of a crossed empty-orbit prefix
are integer-valued polynomials in the orbit-prefix length. -/
lemma countConstantPoly
    (cutoff : ℕ)
    (outer selected : CWord Atom)
    (houter : isFirstCurrent outer = true)
    (trace : List (CWord Atom))
    (target : OCTerm) :
    IVMost
      (fun steps : ℕ =>
        ((boundedConstantTerms cutoff
          (boundedCrossingSchedule cutoff outer selected
            trace steps)).count target : ℤ))
      (cutoff * (cutoff + trace.length + 1) + 1) := by
  by_cases htarget : target.strictTransitions.length < cutoff
  · rw [show
      (fun steps : ℕ =>
        ((boundedConstantTerms cutoff
          (boundedCrossingSchedule cutoff outer selected
            trace steps)).count target : ℤ)) =
        fun steps : ℕ =>
          ∑ producer ∈
              (secondRouteAlphabet cutoff).toFinset,
            if target.constant = (producer.affine cutoff).constant then
              (orderedSubsequenceMultiplicity
                (target.strictTransitions ++ [producer])
                (boundedCrossingSchedule cutoff outer
                  selected trace steps) : ℤ)
            else
              0 by
      funext steps
      exact_mod_cast
        constant_ite_producers
          cutoff (secondRouteAlphabet cutoff)
            (boundedCrossingSchedule cutoff outer selected
              trace steps)
            (fun transition htransition =>
              route_crossing_schedule
                cutoff steps outer selected houter trace transition htransition)
            target |>.trans (if_pos htarget)]
    apply IVMost.finsetSum
    intro producer _hproducer
    by_cases hconstant :
        target.constant = (producer.affine cutoff).constant
    · simp only [hconstant, ↓reduceIte]
      apply
        TCTex.IVMost.mono
      · change
          (target.strictTransitions.length + 1) *
                (cutoff + trace.length + 1) +
              1 ≤
            cutoff * (cutoff + trace.length + 1) + 1
        exact
          Nat.add_le_add_right
            (Nat.mul_le_mul_right (cutoff + trace.length + 1)
              (Nat.succ_le_iff.mpr htarget))
            1
      · simpa using
          subsequenceMultPoly
            cutoff outer selected trace
              (target.strictTransitions ++ [producer])
    · simp only [hconstant, ↓reduceIte]
      exact
        valued_most_constant
          (cutoff * (cutoff + trace.length + 1) + 1) 0
  · rw [show
      (fun steps : ℕ =>
        ((boundedConstantTerms cutoff
          (boundedCrossingSchedule cutoff outer selected
            trace steps)).count target : ℤ)) =
          fun _steps : ℕ => 0 by
      funext steps
      exact_mod_cast
        constant_ite_producers
          cutoff (secondRouteAlphabet cutoff)
            (boundedCrossingSchedule cutoff outer selected
              trace steps)
            (fun transition htransition =>
              route_crossing_schedule
                cutoff steps outer selected houter trace transition htransition)
            target |>.trans (if_neg htarget)]
    exact
      valued_most_constant
        (cutoff * (cutoff + trace.length + 1) + 1) 0

/-- A crossed empty-orbit prefix supplies common polynomial data for the
complete bounded affine-term state. -/
lemma constant_crossing_schedule
    (cutoff : ℕ)
    (outer selected : CWord Atom)
    (houter : isFirstCurrent outer = true)
    (trace : List (CWord Atom)) :
    BCDataa cutoff
      (cutoff * (cutoff + trace.length + 1) + 1)
      (fun steps =>
        boundedConstantTerms cutoff
          (boundedCrossingSchedule cutoff outer selected
            trace steps)) := by
  constructor
  · intro steps
    apply
      supported_alphabet_terms
    intro transition htransition
    exact
      route_crossing_schedule
        cutoff steps outer selected houter trace transition htransition
  · exact
      countConstantPoly
        cutoff outer selected houter trace

/-- Crossing a literal filtered empty-orbit prefix has polynomial bounded
affine-term coordinates. -/
lemma constantMoveBelow
    (cutoff : ℕ)
    (outer selected : CWord Atom)
    (houter : isFirstCurrent outer = true)
    (hselected :
      isFirstCurrent selected = true ∨
        isSecondCurrent selected = true)
    (trace : List (CWord Atom)) :
    BCDataa cutoff
      (cutoff * (cutoff + trace.length + 1) + 1)
      (fun steps =>
        crossingConstantTerms cutoff outer
          (cutoffMovePrefix cutoff selected
            (unitBelowTrace cutoff trace) steps)) := by
  apply
    (constant_crossing_schedule
      cutoff outer selected houter trace).congr
  intro steps
  unfold crossingConstantTerms
  rw [
    crossed_move_below
      cutoff steps outer selected hselected trace]

end ETPoly
