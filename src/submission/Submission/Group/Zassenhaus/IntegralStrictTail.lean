namespace TCTex
namespace EOPrefix

open CWTrace
open WSTrace
open WHNorm
open WNTrace
open NPTail
open OFProgra
open OFProgra.FRProgra
open OTSubsti
open OTDecomp
open BDExp

/-- Ordered homogeneous-orbit prefix emitted before a fixed triangular
substitution tail. -/
def cutoffMovePrefix
    (cutoff : ℕ)
    (selected : CWord Atom)
    (emittedPrefix : List (CWord Atom))
    (steps : ℕ) :
    List (CWord Atom) :=
  (List.range steps).flatMap fun depth =>
    iteratedCutoffMove cutoff selected depth emittedPrefix

