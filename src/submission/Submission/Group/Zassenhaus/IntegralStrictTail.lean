  intro activeCopies hactiveCopies
  have hactiveCopiesLe :
      activeCopies ≤ target.length :=
    Nat.lt_succ_iff.mp (Finset.mem_range.mp hactiveCopies)
  exact
    TCTex.IVMost.mono
      (by
        calc
          activeCopies +
                (target.length * (2 * cutoff + 1) + activeCopies) =
              target.length * (2 * cutoff + 1) + activeCopies * 2 := by
            omega
          _ ≤ target.length * (2 * cutoff + 1) + target.length * 2 :=
            Nat.add_le_add_left
              (Nat.mul_le_mul_right 2 hactiveCopiesLe)
              (target.length * (2 * cutoff + 1))
