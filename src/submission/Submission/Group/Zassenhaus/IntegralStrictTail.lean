/-!
# Physical-weight symbolic sources for concrete Hall strict-tail coordinates

The concrete Hall-coordinate strict-tail recipes currently carry a coarse
global Newton bound.  Operational symbolic Hall factors require the sharper
bound supplied by the physical Hall layer of the word to which a recipe is
attached.

This file isolates that remaining estimate.  Given physical-weight coordinate
expansions, it constructs the ordered symbolic Hall segment and proves its
exact evaluation, truncation, and support.  Given an exact symbolic source for
the complete strict trace, it then constructs the residual-source certificate
consumed by semantic upward recollection.

The file is intentionally not imported by the existing collection proof.
-/

noncomputable section

namespace Submission
namespace TCTex
namespace
  PCSrc

open CWTrace
open STSubsti
open TEAddres
open
  GPBasis
open
  PRVector
open
  PRResid
open
  RSRecol

universe u


/--
Physical-weight recipe expansions for every canonical Hall coordinate in the
strict-tail parent layer.

Unlike the existing coarse global expansions, these expansions have target
weight exactly equal to the physical Hall layer to which they will be
attached.
-/
structure PPExpans
    {d n inputWeight : ℕ}
    (x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d)))
    (hparent :
      exponentAddressParent x y z + 1 < n)
    (coefficient : ℕ → ℤ) where
  expansion :
    ∀ _i : AddressParentIndex d x y z,
      BCExp inputWeight
        (exponentAddressParent x y z + 1)
  eval_expansion :
    ∀ i : AddressParentIndex d x y z,
      (expansion i).eval =
        fun q : ℕ =>
          concreteAddressCoordinates
            d n x y z n (coefficient q) hparent i

namespace PPExpans

/-- Ordered symbolic factors for the concrete Hall segment. -/
def factors
    {d n inputWeight : ℕ}
    {x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d))}
    {hparent :
      exponentAddressParent x y z + 1 < n}
    {coefficient : ℕ → ℤ}
    (coordinates :
      PPExpans
        (inputWeight := inputWeight) x y z hparent coefficient) :
    List
      (SPFactora
        (concreteBasicCommutators.{u} d) inputWeight) :=
  (Finset.univ.sort fun
    i j : AddressParentIndex d x y z =>
      i ≤ j).flatMap fun i =>
        (coordinates.expansion i).symbolicPowerFactors
          (.atom
            (⟨exponentAddressParent x y z + 1, i⟩ :
              HEAddres (concreteBasicCommutators.{u} d)))

/-- The ordered physical factors evaluate to the concrete Hall segment. -/
lemma listEval_factors
    {d n inputWeight : ℕ}
    {x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d))}
    {hparent :
      exponentAddressParent x y z + 1 < n}
    {coefficient : ℕ → ℤ}
    (coordinates :
      PPExpans
        (inputWeight := inputWeight) x y z hparent coefficient)
    (q : ℕ) :
    SPFactora.listEval (n := n) q coordinates.factors =
      (concreteCommutatorsWeight.{u} d
        (exponentAddressParent x y z + 1)).collectedWeightProduct
          (n := n)
          (concreteAddressCoordinates
            d n x y z n (coefficient q) hparent) := by
  rw [factors]
  simp only [BCWta.collectedWeightProduct,
    BCWta.collected_lower_centralterm,
    BCWt.evalin_freelower_centtrunterm]
  induction
      (Finset.univ.sort fun
        i j : AddressParentIndex d x y z =>
          i ≤ j) with
  | nil =>
      rfl
  | cons i indices ih =>
      simp only [List.flatMap_cons, List.map_cons, List.prod_cons,
        SPFactora.listEval_append]
      rw [BCExp.list_power_factors,
        ih]
      have hi :
          (coordinates.expansion i).eval q =
            concreteAddressCoordinates
              d n x y z n (coefficient q) hparent i :=
        congrFun (coordinates.eval_expansion i) q
      congr 1
      simpa only using
        congrArg
          (fun exponent : ℤ =>
            ((concreteCommutatorsWeight.{u} d
              (exponentAddressParent x y z + 1)).commutator
                i).freeLowerTruncation (n := n) ^ exponent)
          hi

/-- Every emitted segment factor has exactly the strict-tail parent weight. -/
lemma word_factors
    {d n inputWeight : ℕ}
    {x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d))}
    {hparent :
      exponentAddressParent x y z + 1 < n}
    {coefficient : ℕ → ℤ}
    (coordinates :
      PPExpans
        (inputWeight := inputWeight) x y z hparent coefficient)
    {factor :
      SPFactora
        (concreteBasicCommutators.{u} d) inputWeight}
    (hfactor : factor ∈ coordinates.factors) :
    factor.word.weight PEAddres.weight =
      exponentAddressParent x y z + 1 := by
  rcases List.mem_flatMap.mp hfactor with ⟨i, _hi, hfactor⟩
  rw [BCExp.symbolic_power_factors
    (.atom
      (⟨exponentAddressParent x y z + 1, i⟩ :
        HEAddres (concreteBasicCommutators.{u} d)))
    (coordinates.expansion i) hfactor]
  rfl

/-- The ordered concrete Hall segment is physically below the cutoff. -/
lemma isTruncated_factors
    {d n inputWeight : ℕ}
    {x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d))}
    {hparent :
      exponentAddressParent x y z + 1 < n}
    {coefficient : ℕ → ℤ}
    (coordinates :
      PPExpans
        (inputWeight := inputWeight) x y z hparent coefficient) :
    SPFactora.IsTruncated n coordinates.factors := by
  intro factor hfactor
  rw [coordinates.word_factors hfactor]
  exact hparent

/-- The ordered concrete Hall segment lies in its physical parent layer. -/
lemma weight_least_factors
    {d n inputWeight : ℕ}
    {x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d))}
    {hparent :
      exponentAddressParent x y z + 1 < n}
    {coefficient : ℕ → ℤ}
    (coordinates :
      PPExpans
        (inputWeight := inputWeight) x y z hparent coefficient) :
    SPFactora.WordWeightLeast
      (exponentAddressParent x y z + 1)
      coordinates.factors := by
  intro factor hfactor
  rw [coordinates.word_factors hfactor]

/--
The exact sharper polynomial estimate is sufficient to construct physical
coordinate expansions by Newton normalization.
-/
noncomputable def ofPolynomial
    {d n inputWeight : ℕ}
    {x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d))}
    {hparent :
      exponentAddressParent x y z + 1 < n}
    {coefficient : ℕ → ℤ}
    (hinputWeight : 0 < inputWeight)
    (hpolynomial :
      ∀ i : AddressParentIndex d x y z,
        IVMost
          (fun q : ℕ =>
            concreteAddressCoordinates
              d n x y z n (coefficient q) hparent i)
          ((exponentAddressParent x y z + 1) /
            inputWeight)) :
    PPExpans
      (inputWeight := inputWeight) x y z hparent coefficient where
  expansion i :=
    BCExp.binomialBasis inputWeight
      (exponentAddressParent x y z + 1)
      hinputWeight
      (fun q : ℕ =>
        concreteAddressCoordinates
          d n x y z n (coefficient q) hparent i)
  eval_expansion i :=
    BCExp.eval_binomialBasis hinputWeight
      (hpolynomial i)

end PPExpans

/--
An exact fixed symbolic source for the complete signed Hall-Witt strict trace.
-/
structure TWSrc
    {d n inputWeight : ℕ}
    (x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d)))
    (coefficient : ℕ → ℤ) where
  source :
    List
      (SPFactora
        (concreteBasicCommutators.{u} d) inputWeight)
  source_isTruncated :
    SPFactora.IsTruncated n source
  source_weight_least :
    SPFactora.WordWeightLeast
      (exponentAddressParent x y z + 1) source
  list_full_trace :
    ∀ q : ℕ,
      SPFactora.listEval (n := n) q source =
        wordListEval
          (PEAddres.freeLowerTruncation
            (n := n))
          (signedStrictTrace x y z (coefficient q))

namespace TWSrc

/-- Remove the ordered parent Hall segment from an exact strict-trace source. -/
def residualSource
    {d n inputWeight : ℕ}
    {x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d))}
    {hparent :
      exponentAddressParent x y z + 1 < n}
    {coefficient : ℕ → ℤ}
    (strictTrace :
      TWSrc
        (n := n) (inputWeight := inputWeight) x y z coefficient)
    (coordinates :
      PPExpans
        (inputWeight := inputWeight) x y z hparent coefficient) :
    List
      (SPFactora
        (concreteBasicCommutators.{u} d) inputWeight) :=
  SPFactora.inverseList coordinates.factors ++
    strictTrace.source

/--
Physical coordinate expansions and an exact strict-trace packet construct the
residual-source certificate consumed by semantic upward recollection.
-/
noncomputable def toResidualSource
    {d n inputWeight : ℕ}
    {x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d))}
    {hparent :
      exponentAddressParent x y z + 1 < n}
    {coefficient : ℕ → ℤ}
    (strictTrace :
      TWSrc
        (n := n) (inputWeight := inputWeight) x y z coefficient)
    (coordinates :
      PPExpans
        (inputWeight := inputWeight) x y z hparent coefficient) :
    TWSrca
      (inputWeight := inputWeight) x y z hparent coefficient where
  source := strictTrace.residualSource coordinates
  source_isTruncated := by
    intro factor hfactor
    rcases List.mem_append.mp hfactor with hfactor | hfactor
    · exact
        SPFactora.truncated_inverse_list
          coordinates.isTruncated_factors factor hfactor
    · exact strictTrace.source_isTruncated factor hfactor
  source_weight_least := by
    intro factor hfactor
    rcases List.mem_append.mp hfactor with hfactor | hfactor
    · exact
        SPFactora.least_inverse_list
          coordinates.weight_least_factors factor hfactor
    · exact strictTrace.source_weight_least factor hfactor
  list_eval_residual := by
    intro q
    rw [residualSource, SPFactora.listEval_append,
      SPFactora.list_eval_inverse,
      coordinates.listEval_factors,
      strictTrace.list_full_trace]

/--
A per-coordinate physical-degree theorem and an exact strict-trace packet are
enough to build the residual-source certificate directly.
-/
noncomputable def residualCoordinateBounds
    {d n inputWeight : ℕ}
    {x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d))}
    {hparent :
      exponentAddressParent x y z + 1 < n}
    {coefficient : ℕ → ℤ}
    (strictTrace :
      TWSrc
        (n := n) (inputWeight := inputWeight) x y z coefficient)
    (hinputWeight : 0 < inputWeight)
    (hpolynomial :
      ∀ i : AddressParentIndex d x y z,
        IVMost
          (fun q : ℕ =>
            concreteAddressCoordinates
              d n x y z n (coefficient q) hparent i)
          ((exponentAddressParent x y z + 1) /
            inputWeight)) :
    TWSrca
      (inputWeight := inputWeight) x y z hparent coefficient :=
  strictTrace.toResidualSource
    (PPExpans.ofPolynomial
      hinputWeight hpolynomial)

end TWSrc

end
