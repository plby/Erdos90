lemma
    vocabulary_filtered_reconstructed
    {β : Type*}
    (wt : β → ℕ)
    (hwt : ∀ atom, 0 < wt atom)
    (x y z : CWord β)
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (coefficient : ℤ)
    (word : CWord β)
    (hword :
      word ∈
        filteredReconstructedProfile
          wt x y z cutoff coefficient) :
    word ∈ signedOrderedVocabulary x y z cutoff := by
  exact
    signed_vocabulary_below
      wt hwt x y z cutoff coefficient word
