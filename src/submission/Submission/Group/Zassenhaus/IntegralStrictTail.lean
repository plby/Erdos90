-- dedTermPolynomial.lean

/-!
# Polynomial bounded terms for bounded depth-crossing schedules

Every ordered affine-constant term chooses one transition occurrence as its
constant producer and an ordered strict-transition subsequence before that
producer.  Grouping by the producer's value expresses a fixed term
multiplicity as a finite sum of crossed transition-word subsequence
multiplicities.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace DTPoly

open CWTrace
open WSTrace
open NPTail
open TACompos
open STSched
open SSExp
open STRec
open SSCoord
open STState
open STClos
open DCSched
open BSRec
open DSPoly

/-- Counting after prepending one fixed entry to every listed word. -/
lemma count_map_cons
    {α : Type*}
    [BEq α] [LawfulBEq α] [DecidableEq α]
    (head : α)
    (words : List (List α)) :
    ∀ target : List α,
      (words.map fun word => head :: word).count target =
        match target with
        | [] =>
            0
        | targetHead :: targetTail =>
            if targetHead = head then
              words.count targetTail
            else
              0
  | [] => by
      apply List.count_eq_zero.mpr
      simp
  | targetHead :: targetTail => by
      simp only
      by_cases hhead : targetHead = head
      · rw [if_pos hhead]
        subst targetHead
        rw [List.count_map_of_injective words (fun word => head :: word)]
        intro left right heq
        exact (List.cons.inj heq).2
      · rw [if_neg hhead]
        apply List.count_eq_zero.mpr
        intro htarget
        rcases List.mem_map.mp htarget with ⟨word, _hword, heq⟩
        exact hhead (List.cons.inj heq).1.symm

/-- Ordered subsequence multiplicity after adjoining one source entry. -/
lemma subsequence_multiplicity_cons
    {α : Type*}
    [BEq α] [LawfulBEq α] [DecidableEq α]
    (head : α)
    (source target : List α) :
    orderedSubsequenceMultiplicity target (head :: source) =
      orderedSubsequenceMultiplicity target source +
        match target with
        | [] =>
            0
        | targetHead :: targetTail =>
            if targetHead = head then
              orderedSubsequenceMultiplicity targetTail source
            else
              0 := by
  unfold orderedSubsequenceMultiplicity
  rw [(List.sublists_cons_perm_append head source).count_eq target,
    List.count_append, count_map_cons]

/-- The empty word occurs once as an ordered subsequence. -/
@[simp]
lemma subsequence_multiplicity_nil
    {α : Type*}
    [BEq α] [LawfulBEq α]
    (source : List α) :
    orderedSubsequenceMultiplicity [] source =
      1 := by
  classical
  induction source with
  | nil =>
      rfl
  | cons head source ih =>
      rw [orderedSubsequenceMultiplicity]
      rw [(List.sublists_cons_perm_append head source).count_eq [],
        List.count_append, count_map_cons]
      simpa [orderedSubsequenceMultiplicity] using ih

/-- Distribute an additive branch whose false case is zero. -/
lemma ite_add_zero
    (condition : Prop)
    [Decidable condition]
    (left right : ℕ) :
    (if condition then left + right else 0) =
      (if condition then left else 0) +
        (if condition then right else 0) := by
  by_cases hcondition : condition <;>
    simp [hcondition]

/-- Summing an indicator refined by a producer value selects its unique
listed producer. -/
lemma sum_producer_indicator
    (cutoff : ℕ)
    (alphabet : List SRTrans)
    (head : SRTrans)
    (hhead : head ∈ alphabet)
    (constant : Multiset (CWord Atom)) :
    (∑ producer ∈ alphabet.toFinset,
      if constant = (producer.affine cutoff).constant then
        if producer = head then 1 else 0
      else
        0) =
      if constant = (head.affine cutoff).constant then 1 else 0 := by
  classical
  rw [Finset.sum_eq_single head]
  · rw [if_pos rfl]
  · intro producer _hproducer hproducer
    simp [hproducer]
  · simp [List.mem_toFinset.mpr hhead]

/-- Multiplicity of one affine-constant term before the length cutoff is the
finite sum of its producer-refined transition-word subsequence
multiplicities. -/
lemma count_constant_producers
    (cutoff : ℕ)
    (alphabet : List SRTrans) :
    ∀ (schedule : List SRTrans),
      (∀ transition ∈ schedule, transition ∈ alphabet) →
      ∀ target : OCTerm,
        (orderedConstantTerms cutoff schedule).count target =
          ∑ producer ∈ alphabet.toFinset,
            if target.constant = (producer.affine cutoff).constant then
              orderedSubsequenceMultiplicity
                (target.strictTransitions ++ [producer]) schedule
            else
              0
  | [], _hschedule, target => by
      apply Eq.symm
      apply Finset.sum_eq_zero
      intro producer _hproducer
      simp [orderedSubsequenceMultiplicity]
  | head :: schedule, hschedule, target => by
      have hhead : head ∈ alphabet :=
        hschedule head (by simp)
      have htail :
          ∀ transition ∈ schedule, transition ∈ alphabet :=
        fun transition htransition =>
          hschedule transition (by simp [htransition])
      rw [orderedConstantTerms, List.count_append, List.count_append,
        count_map_prepend]
      cases target with
      | mk strictTransitions constant =>
          cases strictTransitions with
          | nil =>
              rw [count_constant_producers
                cutoff alphabet schedule htail
                  { strictTransitions := [], constant := constant }]
              simp only [removePrepended?, List.nil_append]
              simp_rw [subsequence_multiplicity_cons]
              simp_rw [ite_add_zero]
              rw [Finset.sum_add_distrib]
              simp only [zero_add, subsequence_multiplicity_nil]
              rw [sum_producer_indicator cutoff alphabet head hhead constant]
              by_cases hconstant :
                  constant = (head.affine cutoff).constant
              · subst constant
                simp
              · rw [if_neg hconstant]
                congr 1
                apply List.count_eq_zero.mpr
                intro hterm
                simp only [List.mem_singleton] at hterm
                exact hconstant
                  (congrArg OCTerm.constant hterm)
          | cons strictHead strictTail =>
              rw [count_constant_producers
                cutoff alphabet schedule htail
                  { strictTransitions := strictHead :: strictTail,
                    constant := constant }]
              by_cases hstrictHead : strictHead = head
              · subst strictHead
                simp only [removePrepended?, ↓reduceIte]
                rw [count_constant_producers
                  cutoff alphabet schedule htail
                    { strictTransitions := strictTail, constant := constant }]
                simp only [List.cons_append]
                simp_rw [subsequence_multiplicity_cons]
                simp_rw [ite_add_zero]
                rw [Finset.sum_add_distrib]
                simp only [not_false_eq_true, ne_eq,
                  OCTerm.mk.injEq, List.nil_eq, reduceCtorEq, false_and,
                  List.count_cons_of_ne, List.count_nil, add_zero,
                  ↓reduceIte]
                exact Nat.add_comm _ _
              · simp only [removePrepended?, hstrictHead, ↓reduceIte,
                  List.cons_append]
                simp_rw [subsequence_multiplicity_cons]
                simp [hstrictHead]

/-- The cutoff-bounded affine-term multiplicity is the producer-refined
transition-subsequence sum whenever the target itself survives the cutoff. -/
lemma constant_ite_producers
    (cutoff : ℕ)
    (alphabet schedule : List SRTrans)
    (hschedule :
      ∀ transition ∈ schedule, transition ∈ alphabet)
    (target : OCTerm) :
    (boundedConstantTerms cutoff schedule).count target =
      if target.strictTransitions.length < cutoff then
        ∑ producer ∈ alphabet.toFinset,
          if target.constant = (producer.affine cutoff).constant then
            orderedSubsequenceMultiplicity
              (target.strictTransitions ++ [producer]) schedule
          else
            0
      else
        0 := by
  unfold boundedConstantTerms
  rw [count_filter_ite]
  rw [count_constant_producers cutoff alphabet schedule
    hschedule]
  simp only [decide_eq_true_eq]

/-- Bounded ordered affine-term multiplicities of one bounded depth-crossing
schedule are polynomial in the strict-correction depth. -/
lemma count_constant_crossing
    (cutoff : ℕ)
    (outer selected right : CWord Atom)
    (houter : isFirstCurrent outer = true)
    (target : OCTerm) :
    IVMost
      (fun steps : ℕ =>
        ((boundedConstantTerms cutoff
          (depthCrossingSchedule cutoff outer selected right
            steps)).count target : ℤ))
      (cutoff * cutoff + 1) := by
  by_cases htarget : target.strictTransitions.length < cutoff
  · rw [show
      (fun steps : ℕ =>
        ((boundedConstantTerms cutoff
          (depthCrossingSchedule cutoff outer selected right
            steps)).count target : ℤ)) =
        fun steps : ℕ =>
          ∑ producer ∈
              (secondRouteAlphabet cutoff).toFinset,
            if target.constant = (producer.affine cutoff).constant then
              (orderedSubsequenceMultiplicity
                (target.strictTransitions ++ [producer])
                (depthCrossingSchedule
                  cutoff outer selected right steps) : ℤ)
            else
              0 by
      funext steps
      exact_mod_cast
        constant_ite_producers
          cutoff (secondRouteAlphabet cutoff)
            (depthCrossingSchedule cutoff outer selected right
              steps)
            (fun transition htransition =>
              route_alphabet_schedule
                cutoff steps outer selected right houter transition
                  htransition)
            target |>.trans (if_pos htarget)]
    apply IVMost.finsetSum
    intro producer _hproducer
    by_cases hconstant :
        target.constant = (producer.affine cutoff).constant
    · simp only [hconstant, ↓reduceIte]
      apply
        TCTex.IVMost.mono
      · change
          (target.strictTransitions.length + 1) * cutoff + 1 ≤
            cutoff * cutoff + 1
        exact
          Nat.add_le_add_right
            (Nat.mul_le_mul_right cutoff (Nat.succ_le_iff.mpr htarget)) 1
      · exact
          (by
            simpa using
              subsequence_multiplicity_crossing
                cutoff outer selected right
                  (target.strictTransitions ++ [producer]))
    · simp only [hconstant, ↓reduceIte]
      exact
        valued_most_constant
          (cutoff * cutoff + 1) 0
  · rw [show
      (fun steps : ℕ =>
        ((boundedConstantTerms cutoff
          (depthCrossingSchedule cutoff outer selected right
            steps)).count target : ℤ)) =
          fun _steps : ℕ => 0 by
      funext steps
      exact_mod_cast
        constant_ite_producers
          cutoff (secondRouteAlphabet cutoff)
            (depthCrossingSchedule cutoff outer selected right
              steps)
            (fun transition htransition =>
              route_alphabet_schedule
                cutoff steps outer selected right houter transition
                  htransition)
            target |>.trans (if_neg htarget)]
    exact
      valued_most_constant
        (cutoff * cutoff + 1) 0

/-- The bounded depth-crossing schedule supplies common polynomial data for
the complete bounded affine-term state. -/
lemma bounded_crossing_schedule
    (cutoff : ℕ)
    (outer selected right : CWord Atom)
    (houter : isFirstCurrent outer = true) :
    BCDataa cutoff (cutoff * cutoff + 1)
      (fun steps =>
        boundedConstantTerms cutoff
          (depthCrossingSchedule cutoff outer selected right
            steps)) := by
  constructor
  · intro steps
    apply
      supported_alphabet_terms
    intro transition htransition
    exact
      route_alphabet_schedule
        cutoff steps outer selected right houter transition htransition
  · exact
      count_constant_crossing
        cutoff outer selected right houter

end DTPoly
end TCTex
