open CWTrace
open WSTrace
open WHNorm
open PSTail
open STMultid

/-- Every formal integral strict-tail word has weighted degree at least one
above its parent triple. -/
lemma parent_succ_strict
    (xWeight yWeight zWeight : ℕ)
    (hxWeight : 0 < xWeight)
    (hyWeight : 0 < yWeight)
    (hzWeight : 0 < zWeight)
    (coefficient : ℤ)
    (word : CWord Atom)
    (hword : word ∈ strictTrace coefficient) :
    xWeight + yWeight + zWeight + 1 ≤
      word.weight (signedWeight xWeight yWeight zWeight) :=
  parent_strictly_higher
    xWeight yWeight zWeight hxWeight hyWeight hzWeight word
      (strictly_higher_strict coefficient word hword)

/-- The six-label weighted alphabet is positive when its three source
weights are positive. -/
lemma signedWeight_pos
    (xWeight yWeight zWeight : ℕ)
    (hxWeight : 0 < xWeight)
    (hyWeight : 0 < yWeight)
    (hzWeight : 0 < zWeight) :
    ∀ atom, 0 < signedWeight xWeight yWeight zWeight atom := by
  intro atom
  rcases atom with atom | atom
  · fin_cases atom
    · change 0 < signedWeight xWeight yWeight zWeight xAtom
      simpa only [signedWeight_x] using hxWeight
    · change 0 < signedWeight xWeight yWeight zWeight xInvAtom
      simpa only [signed_x_inv] using hxWeight
    · change 0 < signedWeight xWeight yWeight zWeight zAtom
      simpa only [signedWeight_z] using hzWeight
    · change 0 < signedWeight xWeight yWeight zWeight zInvAtom
      simpa only [signed_z_inv] using hzWeight
  · fin_cases atom
    · change 0 < signedWeight xWeight yWeight zWeight yAtom
      simpa only [signedWeight_y] using hyWeight
    · change 0 < signedWeight xWeight yWeight zWeight yInvAtom
      simpa only [signed_y_inv] using hyWeight

/-- The signed evaluator places every formal label in the lower-central
layer prescribed by its weighted alphabet value. -/
lemma signed_lower_series
    {G : Type*}
    [Group G]
    (x y z : G)
    (xWeight yWeight zWeight : ℕ)
    (hx : x ∈ Subgroup.lowerCentralSeries G (xWeight - 1))
    (hy : y ∈ Subgroup.lowerCentralSeries G (yWeight - 1))
    (hz : z ∈ Subgroup.lowerCentralSeries G (zWeight - 1)) :
    ∀ atom,
      signedEval x y z atom ∈
        Subgroup.lowerCentralSeries G
          (signedWeight xWeight yWeight zWeight atom - 1) := by
  intro atom
  rcases atom with atom | atom
  · fin_cases atom
    · change
        signedEval x y z xAtom ∈
          Subgroup.lowerCentralSeries G
            (signedWeight xWeight yWeight zWeight xAtom - 1)
      simpa only [signedEval_x, signedWeight_x] using hx
    · change
        signedEval x y z xInvAtom ∈
          Subgroup.lowerCentralSeries G
            (signedWeight xWeight yWeight zWeight xInvAtom - 1)
      simpa only [eval_x_inv, signed_x_inv] using
        (Subgroup.lowerCentralSeries G (xWeight - 1)).inv_mem hx
    · change
        signedEval x y z zAtom ∈
          Subgroup.lowerCentralSeries G
            (signedWeight xWeight yWeight zWeight zAtom - 1)
      simpa only [signedEval_z, signedWeight_z] using hz
    · change
        signedEval x y z zInvAtom ∈
          Subgroup.lowerCentralSeries G
            (signedWeight xWeight yWeight zWeight zInvAtom - 1)
      simpa only [eval_z_inv, signed_z_inv] using
        (Subgroup.lowerCentralSeries G (zWeight - 1)).inv_mem hz
  · fin_cases atom
    · change
        signedEval x y z yAtom ∈
          Subgroup.lowerCentralSeries G
            (signedWeight xWeight yWeight zWeight yAtom - 1)
      simpa only [signedEval_y, signedWeight_y] using hy
    · change
        signedEval x y z yInvAtom ∈
          Subgroup.lowerCentralSeries G
            (signedWeight xWeight yWeight zWeight yInvAtom - 1)
      simpa only [eval_y_inv, signed_y_inv] using
        (Subgroup.lowerCentralSeries G (yWeight - 1)).inv_mem hy

/-- Every explicit strict-tail factor evaluates in the next lower-central
layer above its parent triple. -/
lemma lower_strict_trace
    {G : Type*}
    [Group G]
    (x y z : G)
    (xWeight yWeight zWeight : ℕ)
    (hxWeight : 0 < xWeight)
    (hyWeight : 0 < yWeight)
    (hzWeight : 0 < zWeight)
    (hx : x ∈ Subgroup.lowerCentralSeries G (xWeight - 1))
    (hy : y ∈ Subgroup.lowerCentralSeries G (yWeight - 1))
    (hz : z ∈ Subgroup.lowerCentralSeries G (zWeight - 1))
    (coefficient : ℤ)
    (word : CWord Atom)
    (hword : word ∈ strictTrace coefficient) :
    word.eval (signedEval x y z) ∈
      Subgroup.lowerCentralSeries G (xWeight + yWeight + zWeight) := by
  have heval :=
    CWord.eval_lower_series
      (signedEval x y z) (signedWeight xWeight yWeight zWeight)
      (signedWeight_pos xWeight yWeight zWeight hxWeight hyWeight hzWeight)
      (signed_lower_series x y z xWeight yWeight zWeight
        hx hy hz)
      word
  exact
    Subgroup.lowerCentralSeries_antitone
      (by
        have hweight :=
          parent_succ_strict
            xWeight yWeight zWeight hxWeight hyWeight hzWeight coefficient
              word hword
        omega)
      heval

/-- The full explicit strict trace evaluates in the next lower-central layer
above its parent triple. -/
lemma strict_lower_series
    {G : Type*}
    [Group G]
    (x y z : G)
    (xWeight yWeight zWeight : ℕ)
    (hxWeight : 0 < xWeight)
    (hyWeight : 0 < yWeight)
    (hzWeight : 0 < zWeight)
    (hx : x ∈ Subgroup.lowerCentralSeries G (xWeight - 1))
    (hy : y ∈ Subgroup.lowerCentralSeries G (yWeight - 1))
    (hz : z ∈ Subgroup.lowerCentralSeries G (zWeight - 1))
    (coefficient : ℤ) :
    wordListEval (signedEval x y z) (strictTrace coefficient) ∈
      Subgroup.lowerCentralSeries G (xWeight + yWeight + zWeight) := by
  apply Subgroup.list_prod_mem
  intro value hvalue
  rcases List.mem_map.mp hvalue with ⟨word, hword, rfl⟩
  exact
    lower_strict_trace
      x y z xWeight yWeight zWeight hxWeight hyWeight hzWeight hx hy hz
        coefficient word hword

/-- The signed Jacobi residual itself belongs to the next lower-central layer
by its explicit strict-tail trace. -/
lemma jacobi_zpow_residual
    {G : Type*}
    [Group G]
    (x y z : G)
    (xWeight yWeight zWeight : ℕ)
    (hxWeight : 0 < xWeight)
    (hyWeight : 0 < yWeight)
    (hzWeight : 0 < zWeight)
    (hx : x ∈ Subgroup.lowerCentralSeries G (xWeight - 1))
    (hy : y ∈ Subgroup.lowerCentralSeries G (yWeight - 1))
    (hz : z ∈ Subgroup.lowerCentralSeries G (zWeight - 1))
    (coefficient : ℤ) :
    (originalWord.eval (signedEval x y z))⁻¹ ^ coefficient *
        (firstConventionalWord.eval (signedEval x y z) ^ coefficient *
          (secondConventionalWord.eval (signedEval x y z))⁻¹ ^
            coefficient) ∈
      Subgroup.lowerCentralSeries G (xWeight + yWeight + zWeight) := by
  rw [← PSTail.word_strict_trace]
  exact
    strict_lower_series
      x y z xWeight yWeight zWeight hxWeight hyWeight hzWeight hx hy hz
