/-!
# Polynomial coordinates for repeated bounded-term schedules

A fixed schedule of bounded Hall-Witt transitions is still triangular on
ordered-term multiplicities.  Its increment at a target coordinate depends
polynomially only on coordinates with shorter strict-transition words.

Package that graded increment property compositionally, then combine it with
discrete antidifferentiation.  Repeating any fixed alphabet-supported
transition schedule has cutoff-bounded integer-valued polynomial
multiplicities.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace BTRepeat

open STSched
open SSExp
open STAlphab
open STState
open SSCoord
open SCState
open STClos
open TRTrans

/-- An operator has a graded polynomial increment when its change at one
target coordinate is polynomial whenever all strictly shorter coordinates
are polynomial with their natural triangular bounds. -/
def GPIncrem
    (operator : BoundedCountState → BoundedCountState) :
    Prop :=
  ∀ (family : ℕ → BoundedCountState) (target : OCTerm),
    (∀ previous : OCTerm,
      previous.strictTransitions.length < target.strictTransitions.length →
        IVMost
          (fun steps : ℕ => family steps previous)
          (previous.strictTransitions.length + 1)) →
      IVMost
        (fun steps : ℕ =>
          operator (family steps) target - family steps target)
        target.strictTransitions.length

/-- The identity state operator has zero graded increment. -/
lemma graded_increment_id :
    GPIncrem id := by
  intro _family target _hfamily
  simpa using
    valued_most_const
      target.strictTransitions.length 0

/-- One bounded-term state transition has graded polynomial increment. -/
lemma graded_increment_state
    (cutoff : ℕ)
    (transition : SRTrans) :
    GPIncrem
      (boundedStateStep cutoff transition) := by
  intro family target hfamily
  rw [show
    (fun steps : ℕ =>
      boundedStateStep cutoff transition (family steps) target -
        family steps target) =
      fun steps : ℕ =>
        strictPredecessorCount cutoff transition (family steps) target +
          singletonConstantCount cutoff transition target by
    funext steps
    unfold boundedStateStep
    ring]
  apply
    TCTex.IVMost.add
  · by_cases hlength : target.strictTransitions.length < cutoff
    · cases hprevious : removePrepended? transition target with
      | none =>
          simpa [strictPredecessorCount, hlength, hprevious] using
            valued_most_const
              target.strictTransitions.length 0
      | some previous =>
          have hprepend :
              previous.prepend transition = target :=
            prepend_remove_prepended?_eq_some
              transition target previous hprevious
          have hpreviousLength :
              previous.strictTransitions.length + 1 =
                target.strictTransitions.length := by
            rw [← hprepend]
            simp [OCTerm.prepend]
          have hpreviousLength_lt :
              previous.strictTransitions.length <
                target.strictTransitions.length := by
            omega
          simpa [strictPredecessorCount, hlength, hprevious,
            hpreviousLength] using
              hfamily previous hpreviousLength_lt
    · simpa [strictPredecessorCount, hlength] using
        valued_most_const
          target.strictTransitions.length 0
  · exact
      valued_most_const
        target.strictTransitions.length
          (singletonConstantCount cutoff transition target)

/-- Graded polynomial increments are preserved by operator composition. -/
lemma GPIncrem.comp
    {left right : BoundedCountState → BoundedCountState}
    (hleft : GPIncrem left)
    (hright : GPIncrem right) :
    GPIncrem (fun state => left (right state)) := by
  intro family target hfamily
  have hrightIncrement :
      IVMost
        (fun steps : ℕ =>
          right (family steps) target - family steps target)
        target.strictTransitions.length :=
    hright family target hfamily
  have hrightFamily :
      ∀ previous : OCTerm,
        previous.strictTransitions.length < target.strictTransitions.length →
          IVMost
            (fun steps : ℕ => right (family steps) previous)
            (previous.strictTransitions.length + 1) := by
    intro previous hprevious
    have hpreviousIncrement :
        IVMost
          (fun steps : ℕ =>
            right (family steps) previous - family steps previous)
          previous.strictTransitions.length :=
      hright family previous
        (fun prior hprior => hfamily prior (hprior.trans hprevious))
    rw [show
      (fun steps : ℕ => right (family steps) previous) =
        (fun steps : ℕ => family steps previous) +
          (fun steps : ℕ =>
            right (family steps) previous - family steps previous) by
      funext steps
      simp only [Pi.add_apply]
      ring]
    exact
      (hfamily previous hprevious).add
        (TCTex.IVMost.mono
          (Nat.le_succ previous.strictTransitions.length)
          hpreviousIncrement)
  have hleftIncrement :
      IVMost
        (fun steps : ℕ =>
          left (right (family steps)) target - right (family steps) target)
        target.strictTransitions.length :=
    hleft (fun steps => right (family steps)) target hrightFamily
  rw [show
    (fun steps : ℕ =>
      left (right (family steps)) target - family steps target) =
      (fun steps : ℕ =>
        left (right (family steps)) target - right (family steps) target) +
        (fun steps : ℕ =>
          right (family steps) target - family steps target) by
    funext steps
    simp only [Pi.add_apply]
    ring]
  exact hleftIncrement.add hrightIncrement

/-- Every fixed bounded-term schedule fold has graded polynomial increment. -/
lemma graded_increment_fold
    (cutoff : ℕ) :
    ∀ schedule : List SRTrans,
      GPIncrem
        (boundedStateFold cutoff schedule)
  | [] => by
      simpa [boundedStateFold] using
        graded_increment_id
  | transition :: schedule => by
      rw [show
        boundedStateFold cutoff (transition :: schedule) =
          fun state =>
            boundedStateStep cutoff transition
              (boundedStateFold cutoff schedule state) by
        rfl]
      exact
        (graded_increment_state
          cutoff transition).comp
            (graded_increment_fold
              cutoff schedule)

/-- Iterate an arbitrary bounded-term count-state operator. -/
def iterateStateOperator
    (operator : BoundedCountState → BoundedCountState)
    (initial : BoundedCountState) :
    ℕ → BoundedCountState
  | 0 =>
      initial
  | steps + 1 =>
      operator (iterateStateOperator operator initial steps)

lemma iterate_operator_succ
    (operator : BoundedCountState → BoundedCountState)
    (initial : BoundedCountState)
    (steps : ℕ) :
    iterateStateOperator operator initial (steps + 1) =
      operator (iterateStateOperator operator initial steps) := by
  rfl

/-- Operator iteration is the initial coordinate plus the sum of its
increments along the orbit. -/
lemma iterate_state_operator
    (operator : BoundedCountState → BoundedCountState)
    (initial : BoundedCountState)
    (target : OCTerm) :
    ∀ steps : ℕ,
      iterateStateOperator operator initial steps target =
        initial target +
          ∑ j ∈ Finset.range steps,
            (operator
                (iterateStateOperator operator initial j)
                  target -
              iterateStateOperator operator initial j target)
  | 0 => by
      simp [iterateStateOperator]
  | steps + 1 => by
      rw [iterate_operator_succ,
        Finset.sum_range_succ]
      have hprevious :=
        iterate_state_operator
          operator initial target steps
      linear_combination hprevious

/-- Iterating a graded triangular operator from any fixed initial state has
integer-valued polynomial coordinates with their natural triangular bounds. -/
lemma GPIncrem.iterate_apply
    {operator : BoundedCountState → BoundedCountState}
    (hoperator : GPIncrem operator)
    (initial : BoundedCountState) :
    ∀ target : OCTerm,
      IVMost
        (fun steps : ℕ =>
          iterateStateOperator operator initial steps target)
        (target.strictTransitions.length + 1)
  | target => by
      have hincrement :
          IVMost
            (fun steps : ℕ =>
              operator
                  (iterateStateOperator
                    operator initial steps) target -
                iterateStateOperator
                  operator initial steps target)
            target.strictTransitions.length := by
        apply hoperator
        intro previous hprevious
        exact hoperator.iterate_apply initial previous
      rw [show
        (fun steps : ℕ =>
          iterateStateOperator operator initial steps target) =
          (fun _steps : ℕ => initial target) +
            (fun steps : ℕ =>
              ∑ j ∈ Finset.range steps,
                (operator
                    (iterateStateOperator
                      operator initial j) target -
                  iterateStateOperator
                    operator initial j target)) by
        funext steps
        simp only [Pi.add_apply]
        exact
          iterate_state_operator
            operator initial target steps]
      exact
        (valued_most_const
          (target.strictTransitions.length + 1) (initial target)).add
            hincrement.partialSum
termination_by target => target.strictTransitions.length
decreasing_by
  assumption

/-- Repeat one finite transition schedule a prescribed number of times. -/
def repeatTransitionSchedule
    (schedule : List SRTrans) :
    ℕ → List SRTrans
  | 0 =>
      []
  | steps + 1 =>
      schedule ++ repeatTransitionSchedule schedule steps

/-- Every transition in a repeated schedule already occurs in its source
schedule. -/
lemma repeat_transition_schedule
    (schedule : List SRTrans) :
    ∀ (steps : ℕ) (transition : SRTrans),
      transition ∈ repeatTransitionSchedule schedule steps →
        transition ∈ schedule
  | 0, transition, htransition => by
      simp [repeatTransitionSchedule] at htransition
  | steps + 1, transition, htransition => by
      simp only [repeatTransitionSchedule, List.mem_append] at htransition
      rcases htransition with htransition | htransition
      · exact htransition
      · exact
          repeat_transition_schedule
            schedule steps transition htransition

/-- Folding a repeated schedule is iteration of its one-schedule fold. -/
lemma fold_repeat_transition
    (cutoff : ℕ)
    (schedule : List SRTrans)
    (initial : BoundedCountState) :
    ∀ steps : ℕ,
      boundedStateFold cutoff
          (repeatTransitionSchedule schedule steps) initial =
        iterateStateOperator
          (boundedStateFold cutoff schedule) initial steps
  | 0 => by
      rfl
  | steps + 1 => by
      rw [repeatTransitionSchedule,
        state_fold_append,
        iterate_operator_succ,
        fold_repeat_transition
          cutoff schedule initial steps]

/-- Literal bounded-term coordinates of a repeated fixed schedule have their
natural triangular polynomial degree bounds. -/
lemma count_constant_repeat
    (cutoff : ℕ)
    (schedule : List SRTrans)
    (target : OCTerm) :
    IVMost
      (fun steps : ℕ =>
        ((boundedConstantTerms cutoff
          (repeatTransitionSchedule schedule steps)).count target : ℤ))
      (target.strictTransitions.length + 1) := by
  rw [show
    (fun steps : ℕ =>
      ((boundedConstantTerms cutoff
        (repeatTransitionSchedule schedule steps)).count target : ℤ)) =
      fun steps : ℕ =>
        iterateStateOperator
          (boundedStateFold cutoff schedule)
            (boundedCountState []) steps target by
    funext steps
    rw [count_constant_fold,
      fold_repeat_transition]]
  exact
    (graded_increment_fold
      cutoff schedule).iterate_apply (boundedCountState []) target

/-- Repeating any fixed alphabet-supported schedule supplies common
cutoff-bounded polynomial data for all bounded ordered-term coordinates. -/
lemma constant_repeat_schedule
    (cutoff : ℕ)
    (schedule : List SRTrans)
    (hschedule :
      ∀ transition ∈ schedule,
        transition ∈ secondRouteAlphabet cutoff) :
    BCDataa cutoff cutoff
      (fun steps =>
        boundedConstantTerms cutoff
          (repeatTransitionSchedule schedule steps)) := by
  constructor
  · intro steps
    apply
      supported_alphabet_terms
    intro transition htransition
    exact
      hschedule transition
        (repeat_transition_schedule
          schedule steps transition htransition)
  · intro target
    by_cases htarget :
        target ∈ boundedConstantAlphabet cutoff
    · apply
        TCTex.IVMost.mono
          (Nat.succ_le_iff.mpr
            (length_constant_alphabet
              cutoff target htarget))
      exact
        count_constant_repeat
          cutoff schedule target
    · rw [show
        (fun steps : ℕ =>
          ((boundedConstantTerms cutoff
            (repeatTransitionSchedule schedule steps)).count target : ℤ)) =
          fun _steps : ℕ => 0 by
        funext steps
        norm_cast
        apply List.count_eq_zero.mpr
        intro htargetTerms
        exact
          htarget
            (constant_alphabet_terms
              cutoff (repeatTransitionSchedule schedule steps)
                (fun transition htransition =>
                  hschedule transition
                    (repeat_transition_schedule
                      schedule steps transition htransition))
                target htargetTerms)]
      exact
        valued_most_constant cutoff 0

/-- Newton-normalized bounded repeated-block expansion for one coordinate of
a repeated fixed transition schedule. -/
noncomputable def repeatedMultiplicityExpansion
    (cutoff : ℕ)
    (schedule : List SRTrans)
    (target : OCTerm) :
    BCExp 1 cutoff :=
  BCExp.binomialBasis 1 cutoff (by omega)
    (fun steps : ℕ =>
      ((boundedConstantTerms cutoff
        (repeatTransitionSchedule schedule steps)).count target : ℤ))

/-- The normalized repeated-block expansion evaluates to the literal
bounded-term coordinate of the repeated schedule. -/
lemma repeated_multiplicity_expansion
    (cutoff : ℕ)
    (schedule : List SRTrans)
    (hschedule :
      ∀ transition ∈ schedule,
        transition ∈ secondRouteAlphabet cutoff)
    (target : OCTerm) :
    (repeatedMultiplicityExpansion cutoff schedule target).eval =
      fun steps : ℕ =>
        ((boundedConstantTerms cutoff
          (repeatTransitionSchedule schedule steps)).count target : ℤ) := by
  apply BCExp.eval_binomialBasis
  simpa using
    (constant_repeat_schedule
      cutoff schedule hschedule).2 target

/-- Every repeated fixed-schedule bounded-term coordinate belongs to the
explicit span of cutoff-bounded repeated-block recipes. -/
lemma repeated_multiplicity_span
    (cutoff : ℕ)
    (schedule : List SRTrans)
    (hschedule :
