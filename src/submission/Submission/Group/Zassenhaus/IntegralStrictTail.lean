/-!
# Polynomial iteration of ordered Hall-Witt swap packets

A fixed first-family swap packet has the same unipotent linear action as the
ordinary second-pass compiler of its crossed trace.  Its affine constant also
records the inserted first-family bracket corrections.  Iterate that fixed
affine action from zero and expand the geometric sum in the Newton basis.

Every retained formal slot produced by repeated ordered swapping is therefore
an integer-valued polynomial of cutoff-bounded degree.  This is the polynomial
building block for recursively interpreting repeated `moved` nodes in the
ordered first-route program.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace OSAffine

open CWTrace
open WSTrace
open NPTail
open TBProf
open ARProfa
open ARProfa.CPAffine
open ARUnipot
open ARPoly
open SARec

/-- The linear action of one fixed swap packet has the ordinary
cutoff-truncated binomial expansion. -/
lemma swap_affine_cutoff
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (left : CWord Atom)
    (rights : List (CWord Atom))
    (steps : ℕ)
    (source : Multiset (CWord Atom)) :
    ((swapSecondAffine cutoff left rights).linear ^ steps) source =
      ∑ k ∈ Finset.range cutoff,
        steps.choose k •
          ((packetCorrectionEnd cutoff isSecondCurrent rights) ^ k) source := by
  rw [swap_affine_trace]
  exact
    linear_range_cutoff
      cutoff hcutoff isSecondCurrent rights steps source

/--
Iterating one fixed swap packet from zero has an explicit cutoff-truncated
Newton-binomial profile.
-/
lemma iterate_swap_affine
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (left : CWord Atom)
    (rights : List (CWord Atom))
    (steps : ℕ) :
    (iterate (swapSecondAffine cutoff left rights) steps).apply 0 =
      ∑ k ∈ Finset.range cutoff,
        steps.choose (k + 1) •
          ((packetCorrectionEnd cutoff isSecondCurrent rights) ^ k)
            (swapSecondAffine cutoff left rights).constant := by
  rw [iterate_geom_sum, end_sum_apply]
  simp_rw [swap_affine_cutoff
    cutoff hcutoff left rights]
  rw [Finset.sum_comm]
  apply Finset.sum_congr rfl
  intro k _hk
  rw [← Finset.sum_smul, sum_range_choose]

/-- Iterating one fixed swap transform is exactly compiling a first-family
move across a repeated crossed packet. -/
lemma iterate_move_repeat
    (cutoff : ℕ)
    (left : CWord Atom)
    (hleft : isFirstCurrent left = true)
    (rights : List (CWord Atom))
    (steps : ℕ) :
    iterate (swapSecondAffine cutoff left rights) steps =
      ofTrace cutoff isSecondCurrent
        (moveHigherTrace left (repeatTrace steps rights)) := by
  rw [← swap_affine_repeat cutoff left rights steps,
    ← move_higher_affine
      cutoff left hleft (repeatTrace steps rights)]

/-- One retained slot multiplicity after repeated ordered swapping. -/
def repeatedSwapMultiplicity
    (cutoff : ℕ)
    (left : CWord Atom)
    (rights : List (CWord Atom))
    (slot : CWord Atom)
    (steps : ℕ) :
    ℤ :=
  Multiset.count slot
    ((iterate (swapSecondAffine cutoff left rights) steps).apply 0)

/-- Repeated-swap slot multiplicity is the literal retained count after moving
one first-family word across a repeated crossed packet and routing the result
through the second pass. -/
lemma repeated_slot_literal
    (cutoff : ℕ)
    (left : CWord Atom)
    (hleft : isFirstCurrent left = true)
    (rights : List (CWord Atom))
    (slot : CWord Atom)
    (steps : ℕ) :
    repeatedSwapMultiplicity cutoff left rights slot steps =
      Multiset.count slot
        (cutoffProfile cutoff
          (stableRoute isSecondCurrent
            (moveHigherTrace left (repeatTrace steps rights))).1) := by
  unfold repeatedSwapMultiplicity
  rw [iterate_move_repeat
    cutoff left hleft rights steps]
  rw [profile_stable_fst]

/-- Scalar fixed-slot form of the repeated ordered-swap binomial profile. -/
lemma repeated_swap_cutoff
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (left : CWord Atom)
    (rights : List (CWord Atom))
    (slot : CWord Atom)
    (steps : ℕ) :
    repeatedSwapMultiplicity cutoff left rights slot steps =
      ∑ k ∈ Finset.range cutoff,
        (steps.choose (k + 1) *
          Multiset.count slot
            (((packetCorrectionEnd cutoff isSecondCurrent rights) ^ k)
              (swapSecondAffine cutoff left rights).constant) : ℕ) := by
  have hprofile :=
    congrArg (Multiset.count slot)
      (iterate_swap_affine
        cutoff hcutoff left rights steps)
  rw [count_finset_sum] at hprofile
  have hprofile' :
      Multiset.count slot
          ((iterate (swapSecondAffine cutoff left rights) steps).apply 0) =
        ∑ k ∈ Finset.range cutoff,
          steps.choose (k + 1) *
            Multiset.count slot
              (((packetCorrectionEnd cutoff isSecondCurrent rights) ^ k)
                (swapSecondAffine cutoff left rights).constant) := by
    simpa [Multiset.count_nsmul] using hprofile
  unfold repeatedSwapMultiplicity
  exact_mod_cast hprofile'

/-- Explicit rational Newton polynomial for one repeated ordered-swap slot. -/
noncomputable def repeatedSwapSlot
    (cutoff : ℕ)
    (left : CWord Atom)
    (rights : List (CWord Atom))
    (slot : CWord Atom) :
    Polynomial ℚ :=
  ∑ k ∈ Finset.range cutoff,
    Polynomial.C
        (Multiset.count slot
          (((packetCorrectionEnd cutoff isSecondCurrent rights) ^ k)
            (swapSecondAffine cutoff left rights).constant) : ℚ) *
      natChoosePolynomial (k + 1)

/-- The explicit repeated ordered-swap polynomial has degree at most cutoff. -/
lemma repeated_swap_slot
    (cutoff : ℕ)
    (left : CWord Atom)
    (rights : List (CWord Atom))
    (slot : CWord Atom) :
    (repeatedSwapSlot cutoff left rights slot).natDegree ≤
      cutoff := by
  unfold repeatedSwapSlot
  apply Polynomial.natDegree_sum_le_of_forall_le
  intro k hk
  have hkLt : k < cutoff := Finset.mem_range.mp hk
  exact Polynomial.natDegree_mul_le.trans
    (by
      calc
        (Polynomial.C
              (Multiset.count slot
                (((packetCorrectionEnd cutoff isSecondCurrent rights) ^ k)
                  (swapSecondAffine cutoff left rights).constant) : ℚ)).natDegree +
              (natChoosePolynomial (k + 1)).natDegree ≤
            0 + (k + 1) := by
              gcongr
              · simp
              · exact degree_choose_polynomial (k + 1)
        _ ≤ cutoff := by omega)

/-- The explicit repeated ordered-swap polynomial evaluates to its literal
slot multiplicity on every natural input. -/
lemma repeated_swap_multiplicity
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (left : CWord Atom)
    (rights : List (CWord Atom))
    (slot : CWord Atom)
    (steps : ℕ) :
    (repeatedSwapSlot cutoff left rights slot).eval
        (steps : ℚ) =
      (repeatedSwapMultiplicity cutoff left rights slot steps : ℚ) := by
  rw [repeatedSwapSlot, Polynomial.eval_finsetSum]
  simp_rw [Polynomial.eval_mul, Polynomial.eval_C, eval_nat_choose]
  rw [repeated_swap_cutoff
    cutoff hcutoff left rights slot steps]
  norm_cast
  simp [Nat.mul_comm]

/--
Every retained slot multiplicity produced by repeated ordered swapping is an
integer-valued polynomial of cutoff-bounded degree.
-/
lemma repeated_slot_most
    (cutoff : ℕ)
    (hcutoff : 0 < cutoff)
    (left : CWord Atom)
    (rights : List (CWord Atom))
    (slot : CWord Atom) :
    IVMost
      (repeatedSwapMultiplicity cutoff left rights slot)
      cutoff := by
  exact
    ⟨repeatedSwapSlot cutoff left rights slot,
      repeated_swap_slot
        cutoff left rights slot,
      repeated_swap_multiplicity
        cutoff hcutoff left rights slot⟩

end OSAffine
