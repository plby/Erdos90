  BRExp

universe u


/-- The finite concrete Hall index type in the strict-tail parent layer. -/
abbrev AddressParentIndex
    (d : ℕ)
    (x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d))) :
    Type u :=
  (concreteCommutatorsWeight.{u} d
    (exponentAddressParent x y z + 1)).index

/--
The canonical Hall-family theorem supplies a basis in every strict-tail
parent layer lying below the truncation class.  Choose that basis.
-/
noncomputable def concreteParentBasis
    (d n : ℕ)
    (x y z :
      CWord
        (HEAddres (concreteBasicCommutators.{u} d)))
    (hparent :
      exponentAddressParent x y z + 1 < n) :
    Module.Basis
      (AddressParentIndex d x y z)
      ℤ
      (AddressParentLayer (n := n) x y z) :=
  Classical.choose
    (concrete_forms_associated
      d n (exponentAddressParent x y z + 1)
        (by omega) hparent)

/-- The selected concrete basis consists of the canonical Hall classes. -/
