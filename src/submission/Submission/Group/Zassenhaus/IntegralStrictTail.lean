/-!
# Hall-basis coordinates of associated-graded Hall-Witt profile recipes

The functional polynomial endpoint specializes directly to coordinate
functionals of a Hall basis in the next ordinary lower-central layer.  This
file records that specialization and packages the basis supplied by
`FormsAssocGradedbasis`.

This file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace
  GPBasis

open TEAddres
open PMExp
open
  SAGraded
open
  AGFunc

universe u


/-- The zero-based parent layer of one strict-tail Hall-Witt correction. -/
abbrev exponentAddressParent
    {d : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H)) :
    ℕ :=
  x.weight PEAddres.weight +
      y.weight PEAddres.weight +
    z.weight PEAddres.weight

/-- The additive associated-graded parent layer of one strict-tail correction. -/
abbrev AddressParentLayer
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H)) :
    Type u :=
  Additive
    (TBluepr.LowerGradedLayer
      (LowerCentralTruncation (FreeGroup (FreeGenerator.{u} d)) n)
      (exponentAddressParent x y z))

/-- One coordinate functional of a chosen basis in the strict-tail parent layer. -/
noncomputable def addressParentCoordinate
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    {ι : Type*}
    (basis :
      Module.Basis ι ℤ
        (AddressParentLayer (n := n) x y z))
    (i : ι) :
    AddressParentLayer (n := n) x y z →+ ℤ :=
  (basis.coord i).toAddMonoidHom

/-- A chosen basis coordinate is the Kronecker delta on basis vectors. -/
@[simp]
lemma address_parent_coordinate
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    {ι : Type*}
    [DecidableEq ι]
    (basis :
      Module.Basis ι ℤ
        (AddressParentLayer (n := n) x y z))
    (i j : ι) :
    addressParentCoordinate x y z basis i
        (basis j) =
      if j = i then 1 else 0 := by
  by_cases hji : j = i
  · subst j
    simp [addressParentCoordinate]
  · have hij : i ≠ j := fun hij => hji hij.symm
    simp [addressParentCoordinate, hji, hij]

/--
Every chosen Hall-basis coordinate of the positive correction class is a
bounded integer-valued polynomial.
-/
lemma castCoordPoly
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    {ι : Type*}
    (basis :
      Module.Basis ι ℤ
        (AddressParentLayer (n := n) x y z))
    (i : ι) :
    IVMost
      (fun multiplicity : ℕ =>
        addressParentCoordinate x y z basis i
          (TBluepr.lowerCentralClass
            (exponentAddressParent x y z)
            (addressBelowTerms
              (n := n) x y z cutoff (Int.ofNat multiplicity)).prod))
      (naturalStrictBound cutoff) :=
  termsCastPoly
    x y z cutoff hcutoff
      (addressParentCoordinate x y z basis i)

/--
Every chosen Hall-basis coordinate of the shifted-negative correction class is
a bounded integer-valued polynomial.
-/
lemma basisCoordPoly
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    {ι : Type*}
    (basis :
      Module.Basis ι ℤ
        (AddressParentLayer (n := n) x y z))
    (i : ι) :
    IVMost
      (fun magnitude : ℕ =>
        addressParentCoordinate x y z basis i
          (TBluepr.lowerCentralClass
            (exponentAddressParent x y z)
            (addressBelowTerms
              (n := n) x y z cutoff (Int.negSucc magnitude)).prod))
      (negativeStrictBound cutoff) :=
  termsNegPoly
    x y z cutoff hcutoff
      (addressParentCoordinate x y z basis i)

/--
Any Hall family forming the next associated-graded basis supplies a basis of
the strict-tail parent layer whose signed correction coordinates are bounded
integer-valued polynomials.
-/
theorem coords_forms_associated
    {d n : ℕ}
    {H : ∀ r : ℕ, BCWta.{u} d r}
    (x y z : CWord (HEAddres H))
    (cutoff : ℕ)
    (hcutoff : 3 < cutoff)
    (hH :
      (H (exponentAddressParent x y z + 1)).FormsAssocGradedbasis
        (n := n)) :
    ∃ basis :
        Module.Basis
          (H (exponentAddressParent x y z + 1)).index
          ℤ
          (AddressParentLayer (n := n) x y z),
      (∀ i,
        basis i =
          BCWt.associatedGradedClass (n := n)
            ((H (exponentAddressParent x y z + 1)).commutator i)) ∧
      ∀ i,
        IVMost
            (fun multiplicity : ℕ =>
              addressParentCoordinate x y z basis i
                (TBluepr.lowerCentralClass
                  (exponentAddressParent x y z)
                  (addressBelowTerms
                    (n := n) x y z cutoff (Int.ofNat multiplicity)).prod))
            (naturalStrictBound cutoff) ∧
          IVMost
            (fun magnitude : ℕ =>
              addressParentCoordinate x y z basis i
                (TBluepr.lowerCentralClass
                  (exponentAddressParent x y z)
                  (addressBelowTerms
                    (n := n) x y z cutoff (Int.negSucc magnitude)).prod))
            (negativeStrictBound cutoff) := by
  rcases hH with ⟨basis, hbasis⟩
  refine ⟨basis, hbasis, ?_⟩
  intro i
  exact
    ⟨castCoordPoly
        x y z cutoff hcutoff basis i,
      basisCoordPoly
        x y z cutoff hcutoff basis i⟩

end
  GPBasis
end TCTex
end Submission

