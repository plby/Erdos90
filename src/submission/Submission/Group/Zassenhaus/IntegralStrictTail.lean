/-!
# Finite crossing states for Hall-Witt outer trace substitutions

The dynamic input in the outer bounded-term recurrence is the state of a
crossing schedule over the previously emitted trace.  The trace itself obeys
the fixed prefix-plus-local-substitution recurrence.  Connect these two
interfaces: concatenating a supported crossed trace applies one finite
schedule operator, and one triangular trace-substitution step therefore
becomes one finite crossing-state recurrence.

The file is intentionally not imported by the existing collection proof.
-/

namespace Submission
namespace TCTex
namespace OCState

open CWTrace
open WSTrace
open WHNorm
open WNTrace
open NPTail
open STVocabu
open RMRecb
open ASFilt
open OFProgra
open OFProgra.FRProgra
open TOFact
open OTSubsti
open OTSched
open STSched
open SSExp
open STRec
open STState
open OFState

/-- A literal trace is supported on the fixed cutoff word vocabulary. -/
def TSVocabu
    (cutoff : ℕ)
    (trace : List (CWord Atom)) :
    Prop :=
  ∀ word ∈ trace, word ∈ orderedCutoffVocabulary cutoff

/-- Every cutoff-filtered literal trace is vocabulary-supported. -/
lemma supported_vocabulary_below
    (cutoff : ℕ)
    (trace : List (CWord Atom)) :
    TSVocabu cutoff
      (unitBelowTrace cutoff trace) := by
  intro word hword
  exact
    ordered_vocabulary_below
      cutoff trace word hword

/-- Vocabulary support is preserved by trace concatenation. -/
lemma TSVocabu.append
    {cutoff : ℕ}
    {left right : List (CWord Atom)}
    (hleft : TSVocabu cutoff left)
    (hright : TSVocabu cutoff right) :
    TSVocabu cutoff (left ++ right) := by
  intro word hword
  rw [List.mem_append] at hword
  rcases hword with hword | hword
  · exact hleft word hword
  · exact hright word hword

/-- Flattening local filtered rightward-move packets preserves cutoff
vocabulary support. -/
lemma vocabulary_flat_move
    (cutoff : ℕ)
    (selected : CWord Atom)
    (trace : List (CWord Atom)) :
    TSVocabu cutoff
      (trace.flatMap (cutoffMovePacket cutoff selected)) := by
  intro word hword
  rcases List.mem_flatMap.mp hword with ⟨right, _hright, hword⟩
  exact
    supported_vocabulary_below
      cutoff [.commutator selected right, right] word hword

/-- The packet-local filtered trace prefix is vocabulary-supported. -/
lemma vocabulary_filtered_prefix
    (cutoff : ℕ)
    (before : List (CWord Atom))
    (selected : CWord Atom)
    (suffix : List (CWord Atom)) :
    TSVocabu cutoff
      (filteredOuterPrefix cutoff before selected suffix) := by
  exact
    supported_vocabulary_below cutoff
      (before ++ moveHigherTrace selected suffix)

/-- Iterating a supported filtered prefix-plus-local-substitution operation
preserves vocabulary support. -/
lemma vocabulary_iterate_substitution
    (cutoff : ℕ)
    (emittedPrefix : List (CWord Atom))
    (selected : CWord Atom)
    (hemittedPrefix :
      TSVocabu cutoff emittedPrefix) :
    ∀ (steps : ℕ) (tail : List (CWord Atom)),
      TSVocabu cutoff tail →
        TSVocabu cutoff
          (iteratePrefixSubstitution emittedPrefix
            (cutoffMovePacket cutoff selected) steps tail)
  | 0, tail, htail => by
      exact htail
  | steps + 1, tail, htail => by
      rw [iteratePrefixSubstitution]
      exact
        hemittedPrefix.append
          (vocabulary_flat_move
            cutoff selected
              (iteratePrefixSubstitution emittedPrefix
                (cutoffMovePacket cutoff selected) steps tail))

/-- Every emitted first-route program trace is vocabulary-supported. -/
lemma supported_vocabulary_program
    (cutoff : ℕ)
    (program : FRProgra) :
    TSVocabu cutoff (program.trace cutoff) := by
  intro word hword
  exact
    ordered_vocabulary_program
      cutoff program word hword

/-- Bounded-term multiplicity state of crossing one selected first-family word
over one supported literal trace. -/
def crossingMultiplicityVector
    (cutoff : ℕ)
    (selected : CWord Atom)
    (trace : List (CWord Atom)) :
    List ℕ :=
  boundedConstantVector cutoff
    (boundedConstantTerms cutoff
      (trace.map (SRTrans.crossed selected)))

/-- Every transition in a crossed supported trace belongs to the fixed
second-route transition alphabet. -/
lemma second_alphabet_crossed
    (cutoff : ℕ)
    (selected : CWord Atom)
    (hselected : isFirstCurrent selected = true)
    (trace : List (CWord Atom))
    (htrace : TSVocabu cutoff trace)
    (transition : SRTrans)
    (htransition :
      transition ∈ trace.map (SRTrans.crossed selected)) :
    transition ∈ secondRouteAlphabet cutoff := by
  rcases List.mem_map.mp htransition with ⟨word, hword, rfl⟩
  exact
    transition_alphabet_crossed cutoff selected word
      hselected (htrace word hword)

/-- Crossing-state concatenation applies the finite schedule operator of the
left crossed prefix to the crossing state of the right suffix. -/
lemma crossing_vector_append
    (cutoff : ℕ)
    (selected : CWord Atom)
    (hselected : isFirstCurrent selected = true)
    (left right : List (CWord Atom))
    (hleft : TSVocabu cutoff left)
    (hright : TSVocabu cutoff right) :
    crossingMultiplicityVector cutoff selected (left ++ right) =
      boundedConstantOperator cutoff
        (left.map (SRTrans.crossed selected))
        (crossingMultiplicityVector cutoff selected right) := by
  unfold crossingMultiplicityVector
  rw [List.map_append, constant_terms_append]
  symm
  apply schedule_operator_vector
  · intro transition htransition
    exact
      second_alphabet_crossed
        cutoff selected hselected left hleft transition htransition
  · apply
      supported_alphabet_terms
    intro transition htransition
    exact
      second_alphabet_crossed
        cutoff selected hselected right hright transition htransition

/-- One prefix-plus-local-substitution trace iteration becomes one finite
crossing-state schedule update. -/
lemma crossing_iterate_substitution
    (cutoff : ℕ)
    (outer selected : CWord Atom)
    (houter : isFirstCurrent outer = true)
    (emittedPrefix tail : List (CWord Atom))
    (hemittedPrefix :
      TSVocabu cutoff emittedPrefix)
    (steps : ℕ) :
    crossingMultiplicityVector cutoff outer
        (iteratePrefixSubstitution emittedPrefix
          (cutoffMovePacket cutoff selected) (steps + 1) tail) =
      boundedConstantOperator cutoff
        (emittedPrefix.map (SRTrans.crossed outer))
        (crossingMultiplicityVector cutoff outer
          ((iteratePrefixSubstitution emittedPrefix
            (cutoffMovePacket cutoff selected) steps tail).flatMap
              (cutoffMovePacket cutoff selected))) := by
  rw [iteratePrefixSubstitution]
  apply crossing_vector_append
  · exact houter
  · exact hemittedPrefix
  · exact
      vocabulary_flat_move cutoff selected
        (iteratePrefixSubstitution emittedPrefix
          (cutoffMovePacket cutoff selected) steps tail)

/-- The positive dynamic crossing state obeys the finite recurrence induced
by its normalized outer trace substitution. -/
lemma crossing_vector_substitution
    (cutoff steps : ℕ)
    (tail : FRProgra) :
    crossingMultiplicityVector cutoff firstConventionalInverse
        (iteratePrefixSubstitution
          (positiveFilteredPrefix cutoff)
          (cutoffMovePacket cutoff firstConventionalInverse)
            (steps + 1) (tail.trace cutoff)) =
      boundedConstantOperator cutoff
        ((positiveFilteredPrefix cutoff).map
          (SRTrans.crossed firstConventionalInverse))
        (crossingMultiplicityVector cutoff
          firstConventionalInverse
          ((iteratePrefixSubstitution
            (positiveFilteredPrefix cutoff)
            (cutoffMovePacket cutoff firstConventionalInverse)
              steps (tail.trace cutoff)).flatMap
                (cutoffMovePacket cutoff firstConventionalInverse))) := by
  apply
    crossing_iterate_substitution
  · simp
  · exact
      vocabulary_filtered_prefix cutoff
        positiveOuterFactorization.before firstConventionalInverse
          positiveOuterFactorization.suffix

/-- The negative dynamic crossing state obeys the finite recurrence induced
by its inverted outer trace substitution. -/
lemma crossing_substitution_succ
    (cutoff steps : ℕ)
    (tail : FRProgra) :
    crossingMultiplicityVector cutoff firstConventionalWord
        (iteratePrefixSubstitution
          (negativeFilteredPrefix cutoff)
          (cutoffMovePacket cutoff firstConventionalWord)
            (steps + 1) (tail.trace cutoff)) =
      boundedConstantOperator cutoff
        ((negativeFilteredPrefix cutoff).map
