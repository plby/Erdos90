    occurrenceMultiplicityAt cutoff coefficient slot = 0 := by
  classical
  unfold occurrenceMultiplicityAt
  apply List.length_eq_zero_iff.mpr
  apply List.filter_eq_nil_iff.mpr
  intro word hword
  simp only [decide_eq_true_eq]
  intro hwordSlot
  subst word
  exact hslot (vocabulary_below_trace hword)

/-- Fixed-length scalar occurrence vector indexed by the ordered formal
cutoff vocabulary. -/
def fixedMultiplicityVector
    (cutoff : ℕ)
    (coefficient : ℤ) :
    List ℕ :=
  (orderedCutoffVocabulary cutoff).map
    (occurrenceMultiplicityAt cutoff coefficient)

/-- The scalar Hall-Witt occurrence vector has a coefficient-independent
length. -/
lemma length_multiplicity_vector
    (cutoff : ℕ)
    (coefficient : ℤ) :
    (fixedMultiplicityVector cutoff coefficient).length =
      (orderedCutoffVocabulary cutoff).length := by
  simp [fixedMultiplicityVector]

/-- Retain exactly the physically below-cutoff occurrences after signed word
substitution. -/
def signedBelowTrace
    {β : Type*}
    (wt : β → ℕ)
    (x y z : CWord β)
    (cutoff : ℕ)
    (coefficient : ℤ) :
    List (CWord β) :=
  (signedStrictTrace x y z coefficient).filter fun word =>
    decide (word.weight wt < cutoff)

/-- Every physically retained signed occurrence belongs to the substituted
deduplicated fixed-slot vocabulary. -/
lemma signed_vocabulary_below
    {β : Type*}
    (wt : β → ℕ)
    (hwt : ∀ atom, 0 < wt atom)
    (x y z : CWord β)
    (cutoff : ℕ)
    (coefficient : ℤ)
    (word : CWord β)
    (hword : word ∈ signedBelowTrace wt x y z cutoff coefficient) :
    word ∈ signedOrderedVocabulary x y z cutoff := by
  have hword' := List.mem_filter.mp hword
  apply
    signed_vocabulary_strict
      wt hwt x y z cutoff coefficient word hword'.1
  exact of_decide_eq_true hword'.2

/--
