import Towers.ClassField.KummerTheory.KummerCorrespondence

/-!
# Finite degree bounds for multiradical extensions

This file proves the finite-degree part of the construction occurring in
Kummer correspondence.  A field generated by `r` elements whose `n`th
powers lie in the ground field has degree at most `n ^ r`.  In particular,
the field attached to a finite power-class subgroup in Appendix A is a
finite-dimensional extension.
-/

namespace Towers.CField.KTheory

noncomputable section

open Polynomial

universe u v

/-- Adjoining one element whose `n`th power lies in the base field has
degree at most `n`.  This is the one-step estimate used in the multiradical
tower. -/
theorem finrank_adjoin_pow
    {K E : Type*} [Field K] [Field E] [Algebra K E]
    (n : ℕ) (hn : 0 < n) (x : E) (hx : x ^ n ∈ (⊥ : IntermediateField K E)) :
    Module.finrank K (IntermediateField.adjoin K {x}) ≤ n := by
  rw [IntermediateField.mem_bot] at hx
  obtain ⟨a, ha⟩ := hx
  have hxpow : x ^ n = algebraMap K E a := by
    simpa using ha.symm
  have hxint : IsIntegral K x := by
    refine ⟨X ^ n - C a, monic_X_pow_sub_C a hn.ne', ?_⟩
    simp [hxpow]
  rw [IntermediateField.adjoin.finrank hxint]
  have hminpoly : minpoly K x ∣ X ^ n - C a := by
    apply minpoly.dvd
    simp [hxpow]
  have hdegree := natDegree_le_of_dvd hminpoly
    (monic_X_pow_sub_C a hn.ne').ne_zero
  simpa using hdegree

/-- A finite family of `n`th radicals generates an extension of degree at
most the product of the one-step bounds.  The statement uses a `Finset`, so
duplicate generators are automa discarded and the exponent is the
actual number of generators. -/
theorem finrank_adjoin_finset
    {K E : Type*} [Field K] [Field E] [Algebra K E]
    (n : ℕ) (hn : 0 < n) (S : Finset E)
    (hpow : ∀ x ∈ S, x ^ n ∈ (⊥ : IntermediateField K E)) :
    Module.finrank K (IntermediateField.adjoin K (S : Set E)) ≤ n ^ S.card := by
  classical
  induction S using Finset.induction_on with
  | empty =>
      rw [Finset.coe_empty, IntermediateField.adjoin_empty,
        IntermediateField.finrank_bot]
      exact le_rfl
  | @insert x S hxS ih =>
      let L := IntermediateField.adjoin K (S : Set E)
      let A := IntermediateField.adjoin L {x}
      have hxpowK : x ^ n ∈ (⊥ : IntermediateField K E) :=
        hpow x (Finset.mem_insert_self x S)
      have hxpowL : x ^ n ∈ L := by
        exact (show (⊥ : IntermediateField K E) ≤ L from bot_le) hxpowK
      have hstep : Module.finrank L A ≤ n := by
        apply finrank_adjoin_pow n hn x
        rw [IntermediateField.mem_bot]
        exact ⟨⟨x ^ n, hxpowL⟩, rfl⟩
      have htower :
          A.restrictScalars K =
            IntermediateField.adjoin K ((insert x S : Finset E) : Set E) := by
        dsimp [A, L]
        rw [IntermediateField.restrictScalars_adjoin_eq_sup]
        rw [Finset.coe_insert, Set.insert_eq, Set.union_comm,
          IntermediateField.adjoin_union]
      have ih' : Module.finrank K L ≤ n ^ S.card := by
        apply ih
        intro y hy
        exact hpow y (Finset.mem_insert_of_mem hy)
      rw [← htower]
      calc
        Module.finrank K (A.restrictScalars K) =
            Module.finrank K L * Module.finrank L A := by
          exact (Module.finrank_mul_finrank K L A).symm
        _ ≤ n ^ S.card * n := Nat.mul_le_mul ih' hstep
        _ = n ^ (insert x S).card := by
          rw [Finset.card_insert_of_notMem hxS, pow_succ]

/-- Set-theoretic form of the multiradical degree bound.  This is convenient
when the generators arise as an image or a range rather than as an explicit
enumeration. -/
theorem finrank_adjoin_finite
    {K E : Type*} [Field K] [Field E] [Algebra K E]
    (n : ℕ) (hn : 0 < n) (S : Set E) (hS : S.Finite)
    (hpow : ∀ x ∈ S, x ^ n ∈ (⊥ : IntermediateField K E)) :
    Module.finrank K (IntermediateField.adjoin K S) ≤ n ^ hS.toFinset.card := by
  classical
  have hbound := finrank_adjoin_finset n hn hS.toFinset (by
    intro x hx
    exact hpow x (hS.mem_toFinset.mp hx))
  rw [hS.coe_toFinset] at hbound
  exact hbound

/-- The same hypotheses also give actual finite-dimensionality, rather than
merely a numerical statement about `finrank`.  Each generator is integral
because it is annihilated by a monic polynomial `X ^ n - a`. -/
theorem dimensional_adjoin_pow
    {K E : Type*} [Field K] [Field E] [Algebra K E]
    (n : ℕ) (hn : 0 < n) (S : Set E) (hS : S.Finite)
    (hpow : ∀ x ∈ S, x ^ n ∈ (⊥ : IntermediateField K E)) :
    FiniteDimensional K (IntermediateField.adjoin K S) := by
  letI : Fintype S := hS.fintype
  apply IntermediateField.finiteDimensional_adjoin
  intro x hx
  have hxbase := hpow x hx
  rw [IntermediateField.mem_bot] at hxbase
  obtain ⟨a, ha⟩ := hxbase
  have hxpow : x ^ n = algebraMap K E a := by
    simpa using ha.symm
  refine ⟨X ^ n - C a, monic_X_pow_sub_C a hn.ne', ?_⟩
  simp [hxpow]

/-- The field generated by chosen radicals for a finite power-class subgroup
is finite-dimensional, with the elementary bound `n ^ |B|`. -/
theorem finrank_kummer_card
    (K Ω : Type u) [Field K] [Field Ω] [Algebra K Ω] [IsAlgClosure K Ω]
    (n : ℕ) (hn : 0 < n) (B : PCSubgro K n) :
    Module.finrank K (kummerField K Ω n hn B) ≤ n ^ B.card := by
  classical
  letI : Fintype B.carrier := B.finite_carrier.fintype
  let roots : Finset Ω := Finset.univ.image fun b : B.carrier ↦
    kummerRoot K Ω n hn b.1
  have hpow : ∀ x ∈ roots, x ^ n ∈ (⊥ : IntermediateField K Ω) := by
    intro x hx
    simp only [roots, Finset.mem_image, Finset.mem_univ, true_and] at hx
    obtain ⟨b, rfl⟩ := hx
    rw [kummerRoot_pow]
    exact (IntermediateField.mem_bot).2
      ⟨((powerClassRepresentative K n b.1 : Kˣ) : K), rfl⟩
  have hbound := finrank_adjoin_finset n hn roots hpow
  have hcard : roots.card ≤ B.card := by
    calc
      roots.card ≤ (Finset.univ : Finset B.carrier).card :=
        by simpa [roots] using
          (Finset.card_image_le :
            (Finset.univ.image fun b : B.carrier ↦
              kummerRoot K Ω n hn b.1).card ≤
                (Finset.univ : Finset B.carrier).card)
      _ = B.card := by
        rw [Finset.card_univ, PCSubgro.card]
        exact (B.finite_carrier.card_toFinset).symm
  have hpowcard : n ^ roots.card ≤ n ^ B.card :=
    pow_le_pow_right' hn hcard
  have hroots : (roots : Set Ω) =
      Set.range (fun b : B.carrier ↦ kummerRoot K Ω n hn b.1) := by
    ext x
    simp [roots]
  change Module.finrank K
      (IntermediateField.adjoin K
        (Set.range fun b : B.carrier ↦ kummerRoot K Ω n hn b.1)) ≤
        n ^ B.card
  rw [← hroots]
  exact hbound.trans hpowcard

/-- The radical-generated Kummer field is a finite-dimensional extension.
This supplies the finiteness datum needed to turn it into the extension-side
object of Theorem A.3. -/
theorem dimensional_kummer_field
    (K Ω : Type u) [Field K] [Field Ω] [Algebra K Ω] [IsAlgClosure K Ω]
    (n : ℕ) (hn : 0 < n) (B : PCSubgro K n) :
    FiniteDimensional K (kummerField K Ω n hn B) := by
  letI : Fintype B.carrier := B.finite_carrier.fintype
  let roots : Set Ω :=
    Set.range fun b : B.carrier ↦ kummerRoot K Ω n hn b.1
  letI : Fintype roots :=
    (Set.finite_range fun b : B.carrier ↦ kummerRoot K Ω n hn b.1).fintype
  dsimp [kummerField]
  apply IntermediateField.finiteDimensional_adjoin
  intro x hx
  obtain ⟨b, rfl⟩ := hx
  let a : K := (powerClassRepresentative K n b.1 : Kˣ)
  refine ⟨X ^ n - C a, monic_X_pow_sub_C a hn.ne', ?_⟩
  simp [a, kummerRoot_pow]

end

end Towers.CField.KTheory
