import Towers.ClassField.KummerTheory.KummerFiniteDegree
import Mathlib.FieldTheory.SeparableClosure

/-!
# Multiradical Kummer extensions

This file proves the structural half of Theorem VII.A.3.  If a field is
generated by elements whose `n`th powers lie in the base field, and the base
field contains a primitive `n`th root of unity, then the extension is Galois,
its Galois group is abelian, and every automorphism has exponent dividing
`n`.  The results are stated first for an arbitrary generating set, so they
can be reused independently of the chosen representatives in `kummerField`.
-/

namespace Towers.CField.KTheory

open IntermediateField Polynomial

noncomputable section

variable {K L : Type*} [Field K] [Field L] [Algebra K L]

/-- An automorphism sends an `n`th radical generator to a root-of-unity
multiple of that generator.  This is the basic conjugate calculation behind
the multiradical Kummer theorem. -/
theorem aut_primitive_mul
    {n : ℕ} (hn : 0 < n) {ζ : K} (hζ : IsPrimitiveRoot ζ n)
    (x : L) (hx : x ^ n ∈ Set.range (algebraMap K L))
    (σ : L ≃ₐ[K] L) :
    ∃ i < n, σ x = algebraMap K L (ζ ^ i) * x := by
  obtain ⟨a, ha⟩ := hx
  have hσpow : (σ x) ^ n = x ^ n := by
    calc
      (σ x) ^ n = σ (x ^ n) := (map_pow σ x n).symm
      _ = σ (algebraMap K L a) := by rw [ha]
      _ = algebraMap K L a := σ.commutes a
      _ = x ^ n := ha
  have hmem : σ x ∈ nthRoots n (x ^ n) :=
    (mem_nthRoots hn).2 hσpow
  have hζL : IsPrimitiveRoot (algebraMap K L ζ) n :=
    hζ.map_of_injective (algebraMap K L).injective
  rw [hζL.nthRoots_eq (show x ^ n = x ^ n from rfl)] at hmem
  simp only [Multiset.mem_map, Multiset.mem_range] at hmem
  obtain ⟨i, hi, hσx⟩ := hmem
  refine ⟨i, hi, ?_⟩
  simpa [map_pow] using hσx.symm

/-- Iterating an automorphism on one radical generator multiplies it by the
corresponding root of unity to the iteration power. -/
theorem aut_primitive_root
    {i : ℕ} {ζ : K}
    (x : L) (σ : L ≃ₐ[K] L)
    (hσx : σ x = algebraMap K L (ζ ^ i) * x) (m : ℕ) :
    (σ ^ m) x = algebraMap K L (ζ ^ i) ^ m * x := by
  induction m with
  | zero => simp
  | succ m ih =>
      rw [pow_succ, AlgEquiv.mul_apply, hσx, map_mul, (σ ^ m).commutes,
        ih, pow_succ]
      ring

/-- Every automorphism of a radical-generated extension has exponent
dividing `n`.  No finiteness assumption on the generating set is needed. -/
theorem aut_nth_roots
    {n : ℕ} (hn : 0 < n) {ζ : K} (hζ : IsPrimitiveRoot ζ n)
    (S : Set L) (hgen : IntermediateField.adjoin K S = ⊤)
    (hpow : ∀ x ∈ S, x ^ n ∈ Set.range (algebraMap K L))
    (σ : L ≃ₐ[K] L) :
    σ ^ n = 1 := by
  have hSalg : Algebra.adjoin K S = ⊤ := by
    rw [← IntermediateField.adjoin_toSubalgebra_of_isAlgebraic]
    · rw [hgen]
      rfl
    · intro x hx
      obtain ⟨a, ha⟩ := hpow x hx
      exact (show IsIntegral K x from ⟨X ^ n - C a,
        monic_X_pow_sub_C a hn.ne', by simp [ha]⟩).isAlgebraic
  have heq : (σ ^ n).toAlgHom = (1 : L ≃ₐ[K] L).toAlgHom := by
    apply AlgHom.ext_of_adjoin_eq_top hSalg
    intro x hx
    obtain ⟨i, hi, hσx⟩ :=
      aut_primitive_mul hn hζ x (hpow x hx) σ
    change (σ ^ n) x = x
    rw [aut_primitive_root x σ hσx]
    rw [← map_pow, ← pow_mul, mul_comm i n, pow_mul, hζ.pow_eq_one,
      one_pow, map_one, one_mul]
  exact AlgEquiv.ext fun x ↦ DFunLike.congr_fun heq x

/-- Automorphisms of an extension generated by `n`th radicals commute.
Each automorphism acts diagonally on the radical generators by scalars from
the base field, and those scalars commute. -/
theorem aut_commute_nth
    {n : ℕ} (hn : 0 < n) {ζ : K} (hζ : IsPrimitiveRoot ζ n)
    (S : Set L) (hgen : IntermediateField.adjoin K S = ⊤)
    (hpow : ∀ x ∈ S, x ^ n ∈ Set.range (algebraMap K L))
    (σ τ : L ≃ₐ[K] L) :
    σ * τ = τ * σ := by
  have hSalg : Algebra.adjoin K S = ⊤ := by
    rw [← IntermediateField.adjoin_toSubalgebra_of_isAlgebraic]
    · rw [hgen]
      rfl
    · intro x hx
      obtain ⟨a, ha⟩ := hpow x hx
      exact (show IsIntegral K x from ⟨X ^ n - C a,
        monic_X_pow_sub_C a hn.ne', by simp [ha]⟩).isAlgebraic
  have heq : (σ * τ).toAlgHom = (τ * σ).toAlgHom := by
    apply AlgHom.ext_of_adjoin_eq_top hSalg
    intro x hx
    obtain ⟨i, hi, hσx⟩ :=
      aut_primitive_mul hn hζ x (hpow x hx) σ
    obtain ⟨j, hj, hτx⟩ :=
      aut_primitive_mul hn hζ x (hpow x hx) τ
    change σ (τ x) = τ (σ x)
    calc
      σ (τ x) = algebraMap K L (ζ ^ j) *
          (algebraMap K L (ζ ^ i) * x) := by
        rw [hτx, map_mul, σ.commutes, hσx]
      _ = algebraMap K L (ζ ^ i) *
          (algebraMap K L (ζ ^ j) * x) := by ring
      _ = τ (σ x) := by
        rw [hσx, map_mul, τ.commutes, hτx]
  exact AlgEquiv.ext fun x ↦ DFunLike.congr_fun heq x

/-- A finite extension generated by `n`th radicals is Galois when the base
field contains a primitive `n`th root of unity.  The proof shows that every
generator's minimal polynomial divides a split Kummer polynomial, and then
uses propagation of splitting through an adjoin. -/
theorem adjoin_nth_roots
    [FiniteDimensional K L]
    {n : ℕ} (hn : 0 < n) {ζ : K} (hζ : IsPrimitiveRoot ζ n)
    (S : Set L) (hgen : IntermediateField.adjoin K S = ⊤)
    (hpow : ∀ x ∈ S, x ^ n ∈ Set.range (algebraMap K L)) :
    IsGalois K L := by
  rw [isGalois_iff]
  refine ⟨?_, ?_⟩
  · haveI hsep : Algebra.IsSeparable K (IntermediateField.adjoin K S) :=
      (IntermediateField.isSeparable_adjoin_iff_isSeparable K L).2 fun x hx ↦ by
        by_cases hx0 : x = 0
        · subst x
          simpa using (isSeparable_algebraMap (K := L) (0 : K))
        · obtain ⟨a, ha⟩ := hpow x hx
          have ha0 : a ≠ 0 := by
            intro ha0
            apply pow_ne_zero n hx0
            rw [← ha, ha0, map_zero]
          letI : NeZero n := ⟨hn.ne'⟩
          have hnK : (n : K) ≠ 0 := by
            letI := hζ.neZero'
            exact NeZero.ne _
          exact (separable_X_pow_sub_C a hnK ha0).of_dvd
            (minpoly.dvd K x (by simp [ha]))
    let e : IntermediateField.adjoin K S ≃ₐ[K] L :=
      (IntermediateField.equivOfEq hgen).trans IntermediateField.topEquiv
    exact AlgEquiv.Algebra.isSeparable e
  · rw [normal_iff]
    intro x
    refine ⟨IsIntegral.of_finite K x, ?_⟩
    apply IntermediateField.splits_of_mem_adjoin
      (F := K) (K := L) (S := S) (L := L)
    · intro y hy
      obtain ⟨a, ha⟩ := hpow y hy
      have hyint : IsIntegral K y := by
        refine ⟨X ^ n - C a, monic_X_pow_sub_C a hn.ne', ?_⟩
        simp [ha]
      refine ⟨hyint, ?_⟩
      have hdvd : minpoly K y ∣ X ^ n - C a := by
        apply minpoly.dvd
        simp [ha]
      have hsplit : ((X ^ n - C a).map (algebraMap K L)).Splits := by
        simpa only [Polynomial.map_sub, Polynomial.map_pow, map_X, map_C]
          using X_pow_sub_C_splits_of_isPrimitiveRoot
            (hζ.map_of_injective (algebraMap K L).injective) ha.symm
      exact hsplit.of_dvd
        (map_ne_zero (monic_X_pow_sub_C a hn.ne').ne_zero)
        (Polynomial.map_dvd (algebraMap K L) hdvd)
    · rw [hgen]
      exact IntermediateField.mem_top

end

universe u

section KummerField

variable (K Ω : Type u) [Field K] [Field Ω] [Algebra K Ω]
  [IsAlgClosure K Ω]

/-- The chosen radicals, regarded as elements of their generated Kummer
field rather than as elements of the ambient algebraic closure. -/
def kummerGeneratorSet (n : ℕ) (hn : 0 < n)
    (B : PCSubgro K n) :
    Set (kummerField K Ω n hn B) :=
  Set.range fun b : B.carrier ↦
    ⟨kummerRoot K Ω n hn b.1,
      kummer_root_field K Ω n hn B b⟩

/-- The chosen radicals generate the Kummer field even after being bundled
as elements of that field. -/
theorem adjoin_kummer_top (n : ℕ) (hn : 0 < n)
    (B : PCSubgro K n) :
    IntermediateField.adjoin K (kummerGeneratorSet K Ω n hn B) = ⊤ := by
  let F := kummerField K Ω n hn B
  apply IntermediateField.map_injective F.val
  rw [IntermediateField.adjoin_map, ← AlgHom.fieldRange_eq_map,
    IntermediateField.fieldRange_val]
  change IntermediateField.adjoin K
      (Subtype.val '' kummerGeneratorSet K Ω n hn B) = F
  have himage :
      Subtype.val '' kummerGeneratorSet K Ω n hn B =
        Set.range (fun b : B.carrier ↦ kummerRoot K Ω n hn b.1) := by
    ext x
    simp only [kummerGeneratorSet, Set.mem_image, Set.mem_range]
    constructor
    · rintro ⟨y, ⟨b, rfl⟩, rfl⟩
      exact ⟨b, rfl⟩
    · rintro ⟨b, rfl⟩
      exact ⟨⟨kummerRoot K Ω n hn b.1,
        kummer_root_field K Ω n hn B b⟩, ⟨b, rfl⟩, rfl⟩
  rw [himage]
  rfl

/-- Every concrete Kummer generator has `n`th power in the base field. -/
theorem kummer_set_pow (n : ℕ) (hn : 0 < n)
    (B : PCSubgro K n) :
    ∀ x ∈ kummerGeneratorSet K Ω n hn B,
      x ^ n ∈ Set.range
        (algebraMap K (kummerField K Ω n hn B)) := by
  intro x hx
  obtain ⟨b, rfl⟩ := hx
  refine ⟨((powerClassRepresentative K n b.1 : Kˣ) : K), ?_⟩
  apply Subtype.ext
  exact (kummerRoot_pow K Ω n hn b.1).symm

/-- The field `K[B^(1/n)]` is Galois over `K`.  This is the first major
structural assertion needed to send a finite power-class subgroup to the
extension side of Theorem A.3. -/
theorem kummer_galois (n : ℕ) (hn : 0 < n)
    {ζ : K} (hζ : IsPrimitiveRoot ζ n)
    (B : PCSubgro K n) :
    IsGalois K (kummerField K Ω n hn B) := by
  letI : FiniteDimensional K (kummerField K Ω n hn B) :=
    dimensional_kummer_field K Ω n hn B
  exact adjoin_nth_roots hn hζ
    (kummerGeneratorSet K Ω n hn B)
    (adjoin_kummer_top K Ω n hn B)
    (kummer_set_pow K Ω n hn B)

/-- Every element of the Galois group of `K[B^(1/n)]` has order dividing
`n`. -/
theorem kummer_field_galois (n : ℕ) (hn : 0 < n)
    {ζ : K} (hζ : IsPrimitiveRoot ζ n)
    (B : PCSubgro K n)
    (σ : Gal(kummerField K Ω n hn B/K)) :
    σ ^ n = 1 :=
  aut_nth_roots hn hζ
    (kummerGeneratorSet K Ω n hn B)
    (adjoin_kummer_top K Ω n hn B)
    (kummer_set_pow K Ω n hn B) σ

/-- The Galois group of a finite Kummer field is abelian. -/
theorem kummer_galois_commute (n : ℕ) (hn : 0 < n)
    {ζ : K} (hζ : IsPrimitiveRoot ζ n)
    (B : PCSubgro K n)
    (σ τ : Gal(kummerField K Ω n hn B/K)) :
    σ * τ = τ * σ :=
  aut_commute_nth hn hζ
    (kummerGeneratorSet K Ω n hn B)
    (adjoin_kummer_top K Ω n hn B)
    (kummer_set_pow K Ω n hn B) σ τ

/-- The actual reverse-map object in Theorem A.3: a finite subgroup of
power classes produces a finite abelian Galois subextension of exponent
dividing `n`, with carrier exactly `K[B^(1/n)]`. -/
def kummerFieldSubextension (n : ℕ) (hn : 0 < n)
    {ζ : K} (hζ : IsPrimitiveRoot ζ n)
    (B : PCSubgro K n) :
    AESubext K Ω n where
  carrier := kummerField K Ω n hn B
  finiteDimensional := dimensional_kummer_field K Ω n hn B
  isGalois := kummer_galois K Ω n hn hζ B
  isAbelian := ⟨⟨fun σ τ ↦
    kummer_galois_commute K Ω n hn hζ B σ τ⟩⟩
  exponent_dvd := kummer_field_galois K Ω n hn hζ B

@[simp]
theorem kummer_subextension_carrier (n : ℕ) (hn : 0 < n)
    {ζ : K} (hζ : IsPrimitiveRoot ζ n)
    (B : PCSubgro K n) :
    (kummerFieldSubextension K Ω n hn hζ B).carrier =
      kummerField K Ω n hn B :=
  rfl

end KummerField

end Towers.CField.KTheory
