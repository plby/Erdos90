/-- The full Kummer construction restricts to the cyclic Kummer
construction generated by its first entry.  Thus the bilinear full symbol
and the norm-detecting cyclic symbol are the same pairing. -/
theorem hilbert_symbol_artin
    (n : ℕ) (hn : 0 < n) {ζ : K} (hζ : IsPrimitiveRoot ζ n)
    (a b : PowerClassGroup K n) :
    localKummerSymbol K n hn hζ a b =
