variable [CharZero K]

theorem local_power_class
    (n : ℕ) (hn : 0 < n) {ζ : K} (hζ : IsPrimitiveRoot ζ n) :
    Set.Finite (Set.univ : Set (PowerClassGroup K n)) := by
  letI : NeZero n := ⟨hn.ne'⟩
  have hformula := nonarchimedean_field_formula
    exponentialHerbrandBridge
    valuationIndexBridge K n hn
  have hindex : (powMonoidHom n : Kˣ →* Kˣ).range.index ≠ 0 := by
    intro hi
    rw [hi] at hformula
    simp only [Nat.cast_zero, zero_mul] at hformula
    have hcard : Nat.card (rootsOfUnity n K) = n := by
      rw [Nat.card_eq_fintype_card, hζ.card_rootsOfUnity]
    rw [hcard] at hformula
    have hnR : (n : ℝ) ≠ 0 := Nat.cast_ne_zero.mpr hn.ne'
    exact (mul_ne_zero hnR hnR) hformula.symm
  letI : Finite (PowerClassGroup K n) :=
    Subgroup.index_ne_zero_iff_finite.mp hindex
  exact Set.toFinite _

/-- The full finite subgroup of local `n`th-power classes. -/
def localClassSubgroup
    (n : ℕ) (hn : 0 < n) {ζ : K} (hζ : IsPrimitiveRoot ζ n) :
    PCSubgro K n where
  carrier := ⊤
  finite_carrier := local_power_class K n hn hζ

/-- The Kummer extension obtained by adjoining roots of all local
`n`th-power classes. -/
def fullKummerExtension
    (n : ℕ) (hn : 0 < n) {ζ : K} (hζ : IsPrimitiveRoot ζ n) :
    AESubext K (AlgebraicClosure K) n :=
  kummerFieldSubextension K (AlgebraicClosure K) n hn hζ
    (localClassSubgroup K n hn hζ)

theorem kummer_radical_top
    (n : ℕ) (hn : 0 < n) {ζ : K} (hζ : IsPrimitiveRoot ζ n) :
    radicalPowerClasses K (AlgebraicClosure K) n
        (fullKummerExtension K n hn hζ).carrier = ⊤ := by
  let hroots : (primitiveRoots n K).Nonempty :=
    ⟨ζ, (mem_primitiveRoots hn).2 hζ⟩
  simpa [fullKummerExtension, localClassSubgroup] using
    (radical_classes_field
      (K := K) (Omega := AlgebraicClosure K) n hn hroots
      (localClassSubgroup K n hn hζ))

/-- Every local power class is canonically a radical class in the full
Kummer extension. -/
def localRadicalEquiv
    (n : ℕ) (hn : 0 < n) {ζ : K} (hζ : IsPrimitiveRoot ζ n) :
    PowerClassGroup K n ≃*
      radicalPowerClasses K (AlgebraicClosure K) n
        (fullKummerExtension K n hn hζ).carrier :=
  Subgroup.topEquiv.symm.trans <|
    MulEquiv.subgroupCongr
      (kummer_radical_top K n hn hζ).symm

/-- Local reciprocity on the full Kummer extension factors through
`Kˣ / Kˣⁿ`, since every Galois automorphism has exponent dividing `n`. -/
def fullKummerArtin
    (n : ℕ) (hn : 0 < n) {ζ : K} (hζ : IsPrimitiveRoot ζ n) :
    PowerClassGroup K n →*
      Gal((fullKummerExtension K n hn hζ).carrier/K) := by
  let E := fullKummerExtension K n hn hζ
  apply QuotientGroup.lift (powMonoidHom n : Kˣ →* Kˣ).range
    (abelianArtinHom K E.carrier)
  rintro _ ⟨x, rfl⟩
  change abelianArtinHom K E.carrier (x ^ n) = 1
  rw [map_pow]
  exact E.exponent_dvd _

theorem full_kummer_surjective
    (n : ℕ) (hn : 0 < n) {ζ : K} (hζ : IsPrimitiveRoot ζ n) :
    Function.Surjective (fullKummerArtin K n hn hζ) := by
  intro σ
  obtain ⟨x, hx⟩ := abelian_artin_surjective K
    (fullKummerExtension K n hn hζ).carrier σ
  refine ⟨powerClass n x, ?_⟩
  simpa [fullKummerArtin, powerClass] using hx

theorem full_kummer_artin
    (n : ℕ) (hn : 0 < n) {ζ : K} (hζ : IsPrimitiveRoot ζ n) :
    Nat.card (PowerClassGroup K n) =
      Nat.card Gal((fullKummerExtension K n hn hζ).carrier/K) := by
  let hroots : (primitiveRoots n K).Nonempty :=
    ⟨ζ, (mem_primitiveRoots hn).2 hζ⟩
  let B := localClassSubgroup K n hn hζ
  calc
    Nat.card (PowerClassGroup K n) = Nat.card B.carrier :=
      Nat.card_congr Subgroup.topEquiv.symm.toEquiv
    _ = B.card := (PCSubgro.card_eq_card K B).symm
    _ = Module.finrank K (kummerField K (AlgebraicClosure K) n hn B) :=
      (finrank_kummer_field n hn hroots B).symm
    _ = Module.finrank K (fullKummerExtension K n hn hζ).carrier := rfl
    _ = Nat.card Gal((fullKummerExtension K n hn hζ).carrier/K) :=
      (IsGalois.card_aut_eq_finrank K
        (fullKummerExtension K n hn hζ).carrier).symm

theorem full_kummer_injective
    (n : ℕ) (hn : 0 < n) {ζ : K} (hζ : IsPrimitiveRoot ζ n) :
    Function.Injective (fullKummerArtin K n hn hζ) := by
  letI : Finite (PowerClassGroup K n) :=
    Finite.of_finite_univ (local_power_class K n hn hζ)
  exact ((Nat.bijective_iff_surjective_and_card
    (fullKummerArtin K n hn hζ)).2
      ⟨full_kummer_surjective K n hn hζ,
        full_kummer_artin K n hn hζ⟩).1

/-- The unit-valued Hilbert pairing obtained by evaluating Kummer
characters at local Artin symbols. -/
def kummerHilbertPairing
    (n : ℕ) (hn : 0 < n) {ζ : K} (hζ : IsPrimitiveRoot ζ n) :
    PowerClassGroup K n →* (PowerClassGroup K n →* Kˣ) := by
  let E := fullKummerExtension K n hn hζ
  letI : CommGroup Gal(E.carrier/K) :=
    { (inferInstance : Group Gal(E.carrier/K)) with
      mul_comm := mul_comm' }
  let hroots : (primitiveRoots n K).Nonempty :=
    ⟨ζ, (mem_primitiveRoots hn).2 hζ⟩
  let radicalEquiv := localRadicalEquiv K n hn hζ
  let artin := fullKummerArtin K n hn hζ
  exact
    { toFun := fun a =>
        (radicalKummerPairing K (AlgebraicClosure K) n E hn hroots
          (radicalEquiv a)).comp artin
      map_one' := by
        apply MonoidHom.ext
        intro b
        simp
      map_mul' := fun a c => by
        apply MonoidHom.ext
        intro b
        simp }

/-- The root-of-unity-valued Hilbert symbol attached to the full Kummer
extension and local reciprocity. -/
def localKummerSymbol
    (n : ℕ) (hn : 0 < n) {ζ : K} (hζ : IsPrimitiveRoot ζ n)
    (a b : PowerClassGroup K n) : rootsOfUnity n K :=
  let E := fullKummerExtension K n hn hζ
  let hroots : (primitiveRoots n K).Nonempty :=
    ⟨ζ, (mem_primitiveRoots hn).2 hζ⟩
  radicalRootCharacter K (AlgebraicClosure K) n E hn hroots
    (fullKummerArtin K n hn hζ b)
    (localRadicalEquiv K n hn hζ a)

