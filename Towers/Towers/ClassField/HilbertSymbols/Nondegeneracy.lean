  change radicalRootCharacter K (AlgebraicClosure K) n M hn
      ⟨ζ, (mem_primitiveRoots hn).2 hζ⟩ sigma rM =
    radicalRootCharacter K (AlgebraicClosure K) n L hn
      ⟨ζ, (mem_primitiveRoots hn).2 hζ⟩
      (cyclicKummerArtin K n hn hζ a b) rL
  rw [← hartin]
  exact hnat

set_option maxHeartbeats 1000000 in
-- The norm criterion transports the cyclic result through the full Kummer
-- extension and its splitting-field comparison.
/-- The norm criterion for the same full Hilbert symbol used in the
bilinearity and nondegeneracy theorems. -/
theorem hilbert_symbol_subgroup
    (n : ℕ) (hn : 0 < n) {ζ : K} (hζ : IsPrimitiveRoot ζ n)
    (E : Type) [Field E] [Algebra K E]
    (a b : Kˣ)
    (hsplit : IsSplittingField K E (X ^ n - C (a : K)))
    (hirr : Irreducible (X ^ n - C (a : K))) :
    localKummerSymbol K n hn hζ
        (powerClass n a) (powerClass n b) = 1 ↔
      b ∈ normSubgroup K E := by
  rw [hilbert_symbol_artin K n hn hζ]
  exact
    kummer_hilbert_symbol
      K n hn hζ E a b hsplit hirr

/-- The diagonal norm identity: `(a,-a)_n = 1`.  Unlike the irreducible
norm criterion, this holds for every power class because the preceding norm
calculation works in the possibly lower-degree cyclic Kummer field. -/
theorem hilbert_symbol_diagonal
    (n : ℕ) (hn : 0 < n) {ζ : K} (hζ : IsPrimitiveRoot ζ n)
    (a : PowerClassGroup K n) :
    localKummerSymbol K n hn hζ a
      (powerClass n (-1 : Kˣ) * a) = 1 := by
  let b : Kˣ := (-1 : Kˣ) * powerClassRepresentative K n a
  have hbclass : powerClass n b = powerClass n (-1 : Kˣ) * a := by
    dsimp [b]
    rw [map_mul, power_class_representative]
  rw [hilbert_symbol_artin K n hn hζ]
  rw [← hbclass]
  exact (kummer_artin_symbol K n hn hζ a b).2
    (neg_representative_kummer K n hn hζ a)

@[simp]
theorem hilbert_symbol_coe
    (n : ℕ) (hn : 0 < n) {ζ : K} (hζ : IsPrimitiveRoot ζ n)
    (a b : PowerClassGroup K n) :
    ((localKummerSymbol K n hn hζ a b : rootsOfUnity n K) : Kˣ) =
      kummerHilbertPairing K n hn hζ a b :=
  rfl

@[simp]
theorem local_hilbert_pairing
    (n : ℕ) (hn : 0 < n) {ζ : K} (hζ : IsPrimitiveRoot ζ n)
    (a b : PowerClassGroup K n) :
    kummerHilbertPairing K n hn hζ a b =
      radicalKummerPairing K (AlgebraicClosure K) n
        (fullKummerExtension K n hn hζ) hn
        ⟨ζ, (mem_primitiveRoots hn).2 hζ⟩
        (localRadicalEquiv K n hn hζ a)
        (fullKummerArtin K n hn hζ b) :=
  rfl

theorem hilbert_symbol_left
    (n : ℕ) (hn : 0 < n) {ζ : K} (hζ : IsPrimitiveRoot ζ n)
    (a c b : PowerClassGroup K n) :
    localKummerSymbol K n hn hζ (a * c) b =
      localKummerSymbol K n hn hζ a b *
        localKummerSymbol K n hn hζ c b := by
  apply Subtype.ext
  simp

theorem hilbert_symbol_right
    (n : ℕ) (hn : 0 < n) {ζ : K} (hζ : IsPrimitiveRoot ζ n)
    (a b c : PowerClassGroup K n) :
    localKummerSymbol K n hn hζ a (b * c) =
      localKummerSymbol K n hn hζ a b *
        localKummerSymbol K n hn hζ a c := by
  apply Subtype.ext
  exact map_mul (kummerHilbertPairing K n hn hζ a) b c

/-- **Theorem III.4.4(b), skew symmetry.**  Polarizing the diagonal identity
`(x,-x)=1` gives `(a,b)(b,a)=1`; hence `(b,a)=(a,b)⁻¹`. -/
theorem kummer_hilbert_skew
    (n : ℕ) (hn : 0 < n) {ζ : K} (hζ : IsPrimitiveRoot ζ n)
    (a b : PowerClassGroup K n) :
    localKummerSymbol K n hn hζ b a =
      (localKummerSymbol K n hn hζ a b)⁻¹ := by
  let mone : PowerClassGroup K n := powerClass n (-1 : Kˣ)
  have ha :
      localKummerSymbol K n hn hζ a mone *
          localKummerSymbol K n hn hζ a a = 1 := by
    rw [← hilbert_symbol_right K n hn hζ a mone a]
    exact hilbert_symbol_diagonal K n hn hζ a
  have hb :
      localKummerSymbol K n hn hζ b mone *
          localKummerSymbol K n hn hζ b b = 1 := by
    rw [← hilbert_symbol_right K n hn hζ b mone b]
    exact hilbert_symbol_diagonal K n hn hζ b
  have haa : localKummerSymbol K n hn hζ a a =
      (localKummerSymbol K n hn hζ a mone)⁻¹ :=
    eq_inv_of_mul_eq_one_right ha
  have hbb : localKummerSymbol K n hn hζ b b =
      (localKummerSymbol K n hn hζ b mone)⁻¹ :=
    eq_inv_of_mul_eq_one_right hb
  have hab := hilbert_symbol_diagonal K n hn hζ (a * b)
  rw [hilbert_symbol_left K n hn hζ a b,
    hilbert_symbol_right K n hn hζ a mone (a * b),
    hilbert_symbol_right K n hn hζ a a b,
    hilbert_symbol_right K n hn hζ b mone (a * b),
    hilbert_symbol_right K n hn hζ b a b,
    haa, hbb] at hab
  have hcross :
      localKummerSymbol K n hn hζ a b *
        localKummerSymbol K n hn hζ b a = 1 := by
    simpa [mul_assoc, mul_comm, mul_left_comm] using hab
  exact eq_inv_of_mul_eq_one_right hcross

theorem kummer_hilbert_pairing
    (n : ℕ) (hn : 0 < n) {ζ : K} (hζ : IsPrimitiveRoot ζ n) :
    Function.Injective (kummerHilbertPairing K n hn hζ) := by
  intro a c hac
  apply (localRadicalEquiv K n hn hζ).injective
  apply kummer_pairing_injective K (AlgebraicClosure K) n
    (fullKummerExtension K n hn hζ) hn
    ⟨ζ, (mem_primitiveRoots hn).2 hζ⟩
  apply MonoidHom.ext
  intro σ
  obtain ⟨b, rfl⟩ := full_kummer_surjective K n hn hζ σ
  exact DFunLike.congr_fun hac b

/-- The Kummer--Artin Hilbert pairing has trivial left kernel. -/
theorem hilbert_symbol_kernel
    (n : ℕ) (hn : 0 < n) {ζ : K} (hζ : IsPrimitiveRoot ζ n)
    (a : PowerClassGroup K n)
    (ha : ∀ b, localKummerSymbol K n hn hζ a b = 1) :
    a = 1 := by
  apply kummer_hilbert_pairing K n hn hζ
  apply MonoidHom.ext
  intro b
  have h := congrArg Subtype.val (ha b)
  simpa using h

/-- The Kummer--Artin Hilbert pairing has trivial right kernel. -/
theorem local_hilbert_symbol
    (n : ℕ) (hn : 0 < n) {ζ : K} (hζ : IsPrimitiveRoot ζ n)
    (b : PowerClassGroup K n)
    (hb : ∀ a, localKummerSymbol K n hn hζ a b = 1) :
    b = 1 := by
  letI : NeZero n := ⟨hn.ne'⟩
  apply full_kummer_injective K n hn hζ
  let E := fullKummerExtension K n hn hζ
  let hroots : (primitiveRoots n K).Nonempty :=
    ⟨ζ, (mem_primitiveRoots hn).2 hζ⟩
  have hexp : Monoid.exponent Gal(E.carrier/K) ∣ n :=
    Monoid.exponent_dvd_of_forall_pow_eq_one E.exponent_dvd
  letI : HasEnoughRootsOfUnity K n :=
    HasEnoughRootsOfUnity.of_card_le (by rw [hζ.card_rootsOfUnity])
  letI : HasEnoughRootsOfUnity K (Monoid.exponent Gal(E.carrier/K)) :=
    HasEnoughRootsOfUnity.of_dvd K hexp
  rw [← CommGroup.forall_apply_eq_apply_iff
    (G := Gal(E.carrier/K)) (M := K)]
  intro φ
  obtain ⟨r, hr⟩ := radical_kummer_pairing
    K (AlgebraicClosure K) n E hn hroots φ
  obtain ⟨a, ha⟩ :=
    (localRadicalEquiv K n hn hζ).surjective r
  have hb' : kummerHilbertPairing K n hn hζ a b = 1 := by
    have h := congrArg Subtype.val (hb a)
    simpa using h
  calc
    φ (fullKummerArtin K n hn hζ b) =
        (radicalKummerPairing K (AlgebraicClosure K) n E hn hroots r)
          (fullKummerArtin K n hn hζ b) := by rw [hr]
    _ = kummerHilbertPairing K n hn hζ a b := by
      rw [← ha]
      rfl
    _ = 1 := hb'
    _ = φ (fullKummerArtin K n hn hζ 1) := by simp

/-- In characteristic zero, the full Kummer--Artin Hilbert symbol is
bilinear and nondegenerate in both variables. -/
theorem symbol_bilinear_nondegenerate
    (n : ℕ) (hn : 0 < n) {ζ : K} (hζ : IsPrimitiveRoot ζ n) :
    (∀ a a' b : PowerClassGroup K n,
      localKummerSymbol K n hn hζ (a * a') b =
        localKummerSymbol K n hn hζ a b *
          localKummerSymbol K n hn hζ a' b) ∧
    (∀ a b b' : PowerClassGroup K n,
      localKummerSymbol K n hn hζ a (b * b') =
        localKummerSymbol K n hn hζ a b *
          localKummerSymbol K n hn hζ a b') ∧
    (∀ a : PowerClassGroup K n,
      (∀ b, localKummerSymbol K n hn hζ a b = 1) → a = 1) ∧
    (∀ b : PowerClassGroup K n,
      (∀ a, localKummerSymbol K n hn hζ a b = 1) → b = 1) :=
  ⟨hilbert_symbol_left K n hn hζ,
    hilbert_symbol_right K n hn hζ,
    hilbert_symbol_kernel K n hn hζ,
    local_hilbert_symbol K n hn hζ⟩

end CharacteristicZero

