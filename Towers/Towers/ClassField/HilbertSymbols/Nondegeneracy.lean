/-- If `X^n-a` is irreducible, the canonical cyclic Kummer field generated
by the class of `a` is itself a splitting field of that polynomial.  The
degree comparison uses the exact multiradical Kummer degree formula; it is
what permits transport of the norm criterion to an arbitrary splitting
field model. -/
theorem cyclic_kummer_splitting
    (n : ℕ) (hn : 0 < n) {ζ : K} (hζ : IsPrimitiveRoot ζ n)
    (a : Kˣ) (hirr : Irreducible (X ^ n - C (a : K))) :
    IsSplittingField K
      (cyclicKummerExtension K n hn hζ (powerClass n a)).carrier
      (X ^ n - C (a : K)) := by
  let B := cyclicClassSubgroup K n hn (powerClass n a)
  let F := (cyclicKummerExtension K n hn hζ (powerClass n a)).carrier
  let hroots : (primitiveRoots n K).Nonempty :=
    ⟨ζ, (mem_primitiveRoots hn).2 hζ⟩
  have hclasses :
      powerClass n (powerClassRepresentative K n (powerClass n a)) =
        powerClass n a := by
    rw [power_class_representative]
  obtain ⟨z, hz, heq⟩ := (QuotientGroup.mk'_eq_mk' _).mp hclasses
  obtain ⟨d, rfl⟩ := hz
  let alpha : F :=
    cyclicKummerGenerator K n hn hζ (powerClass n a) *
      algebraMap K F (d : K)
  have halphaPow : alpha ^ n = algebraMap K F (a : K) := by
    dsimp [alpha]
    rw [mul_pow, cyclic_kummer_pow, ← map_pow, ← map_mul]
    exact congrArg (fun u : Kˣ ↦ algebraMap K F (u : K)) heq
  have hupper : Module.finrank K F ≤ n := by
    calc
      Module.finrank K F = B.card :=
        finrank_kummer_field n hn hroots B
      _ = Nat.card B.carrier :=
        PCSubgro.card_eq_card K B
      _ = orderOf (powerClass n a) := Nat.card_zpowers _
      _ ≤ n := orderOf_le_of_pow_eq_one hn
        (power_class_pow n (powerClass n a))
  have hmin : X ^ n - C (a : K) = minpoly K alpha := by
    apply minpoly.eq_of_irreducible_of_monic hirr
    · simp [aeval_def, halphaPow]
    · exact monic_X_pow_sub_C (a : K) hn.ne'
  have hlower : n ≤ Module.finrank K F := by
    rw [← natDegree_X_pow_sub_C (R := K) (n := n) (r := (a : K)), hmin]
    exact minpoly.natDegree_le alpha
  have hfin : Module.finrank K F = n := le_antisymm hupper hlower
  have hadjoin : IntermediateField.adjoin K {alpha} = ⊤ := by
    apply IntermediateField.eq_of_le_of_finrank_eq le_top
    rw [IntermediateField.adjoin.finrank (IsIntegral.of_finite K alpha), ← hmin,
      natDegree_X_pow_sub_C, IntermediateField.finrank_top', hfin]
  have halphaPow' :
      alpha ^ (Module.finrank K F) = algebraMap K F (a : K) := by
    rw [hfin]
    exact halphaPow
  have hroots' : (primitiveRoots (Module.finrank K F) K).Nonempty := by
    simpa only [hfin] using hroots
  have hsplit : IsSplittingField K F
      (X ^ Module.finrank K F - C (a : K)) :=
    isSplittingField_X_pow_sub_C_of_root_adjoin_eq_top
      (K := K) (L := F) hroots' halphaPow' hadjoin
  simpa only [hfin] using hsplit

set_option maxHeartbeats 1000000 in
-- The arbitrary splitting-field model is compared through an algebraic
-- equivalence, including preservation of the field norm.
/-- **Theorem III.4.4(d), with an arbitrary splitting-field model.**
Algebraic equivalence of splitting fields preserves the field norm, so the
canonical norm criterion transports to every irreducible Kummer splitting
field. -/
theorem kummer_hilbert_symbol
    (n : ℕ) (hn : 0 < n) {ζ : K} (hζ : IsPrimitiveRoot ζ n)
    (E : Type) [Field E] [Algebra K E]
    (a b : Kˣ)
    (hsplit : IsSplittingField K E (X ^ n - C (a : K)))
    (hirr : Irreducible (X ^ n - C (a : K))) :
    kummerHilbertSymbol K n hn hζ
        (powerClass n a) (powerClass n b) = 1 ↔
      b ∈ normSubgroup K E := by
  let F := (cyclicKummerExtension K n hn hζ (powerClass n a)).carrier
  letI : IsSplittingField K E (X ^ n - C (a : K)) := hsplit
  letI : FiniteDimensional K E :=
    IsSplittingField.finiteDimensional E (X ^ n - C (a : K))
  letI : IsSplittingField K F (X ^ n - C (a : K)) :=
    cyclic_kummer_splitting K n hn hζ a hirr
  let e : E ≃ₐ[K] F :=
    (IsSplittingField.algEquiv E (X ^ n - C (a : K))).trans
      (IsSplittingField.algEquiv F (X ^ n - C (a : K))).symm
  rw [kummer_artin_symbol K n hn hζ]
  rw [norm_alg_equiv K E F e]

